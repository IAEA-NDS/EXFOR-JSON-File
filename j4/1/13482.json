          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "CALCULATED FROM RELATIVE CUMULATIVE YIELDS FOR",
                " ELEMENTS RU, SR, Y, ZR, MO, AND RU WHICH WERE",
                " NORMALIZED TO EACH OTHER THROUGH THE YILED OF",
                " MASS 95 CHAIN OBTAINED FROM MOLYBDINUM.",
                "SUMMED TO 100.12%, ASSUMING INTERPOLATED VALUES (IN",
                " % YIELD) FOR: 72-82 (0.59), 99 (6.44), 105 (5.50),",
                "  107 (2.44),  108 (2.44),  110 (0.76), 113 (0.080),",
                "  114 (0.060), 115 (0.041), 116-118 (0.122), AND THE",
                "  RADIOCHEMICAL YIELDS TAKEN FROM KATCOFF, ET AL.,",
                "  NUCLEONICS 16,78(1958) FOR: 109 (1.50), 111(0.27),",
                "  112 (0.10)."
              ]
            }
          ],
