          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 259Lr was produced at the Lawrence Berkeley Lab.",
                "88-Inch Cyclotron via the 248Cm(15N,4n) reaction.",
                "The target contained 0.50 mg/cm2 248Cm (97% isotopic",
                "purity) as the oxide (0.55 mg/cm2 Cm2O3) deposited",
                "by the molecular plating method in a 0.6-cm-diam",
                "circle on 1-mil-thick beryllium foil. The 95-MeV beam",
                "of l5N4+ ions passed through a 2.75.mg/cm2 Be entrance",
                "window, 0.3 mg/cm2 of N2 cooling gas, and the Be target",
                "backing to result in a beam energy in the target",
                "material of 81 MeV (laboratory system)."
              ]
            }
          ],
