          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The fission target consisted of eight 1mg/cm2 thin",
                "layers of high-purity 238U, each deposited onto a",
                "photovoltaic (solar) cell by a mass separator. The",
                "total mass of 238U in the target was about 25mg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Array of HPGE detectors GEANIE was comprised",
                "of 26 high-resolution germanium (Ge) gamma-ray",
                "detectors, twenty of which were equipped with bismuth",
                "germanate background suppression shields. Eleven of",
                "the shielded Ge detectors were planar detectors",
                "dedicated to low-energy photon spectroscopy,",
                "typically, from 10 keV up to 300 keV"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PHVC"
              ],
              "free_text": [
                " Fission material 238U was deposited onto solar",
                "cell forming independent detector able to detect one",
                "of the fission fragments with an efficiency higher",
                "than 80%."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutrons were produced through spallation",
                "induced by 800 MeV protons emitted in sub-nanosecond",
                "pulses every 1.8 mu-s impinging on a tungsten target.",
                "The experiment was installed on the 60deg right flight",
                "path and located 20.34 m away from the spallation",
                "target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Incident neutron energy was determined by neutron",
                "time of flight."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between fission fragments and",
                "gamma ray detector was required"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Prompt K X-ray emission yields in the fission induced",
                "by neutrons on 238U were measured. From the spectra of",
                "K X-rays yields of individual fission products were",
                "determined for different incident neutron energies"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " uncertainty of the fit of X-ray spectra"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " uncertainty of fit added quadratically with",
                "uncertainty corresponding to 50% relative",
                "uncertainty associated with K(Z) as taken from",
                "Reisdorff et al. (see REL-REF). K(Z) is the mean K",
                "X-ray emission probability per fragment of element Z"
              ]
            }
          ],
