          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "GSPEC"
              ],
              "free_text": [
                " Triple gamma coincidence technique.",
                "Two methods used.",
                "1) Double gates set on 2+->0+ and 4+->2+ transitions",
                "   in even-even fragment, and intensities of 2+->0+",
                "   transitions in correlated fragments measured.",
                "   Relative yields are determined for set of correlated",
                "   pairs. Total yields are normalized to Wahl, or to",
                "   experimental total yields, if known.  Missing",
                "   isotopes are evaluated by interpolation from",
                "   neighbors, and sum of heavy yields is normalized to",
                "   Wahl.",
                "2) 1st gate set on one fragment, 2nd gate set on its",
                "   correlated partner, and intensities of gamma",
                "   transitions determined.  Using branching ratios,",
                "   relative binary yields are determined and normalized",
                "   to Wahl."
              ]
            }
          ],
