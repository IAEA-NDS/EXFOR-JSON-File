          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Failure of Bohr's compound nucleus hypothesis for the",
                " 98Mo(n,gamma)99Mo reaction"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                " Oak Ridge Electron Linear Accelerator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two samples, thicknesses of 0.00428 and 0.04345",
                " atom/barn. Enriched to 97.63% 98Mo in form of",
                " powdered oxide. Diameter of 2.74-cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight with 78.203-meter flight path.",
                " Sample of 98Mo, background sample, and empty holder",
                " cycled through beam. Time-of-flight dependent back-",
                " ground determined by using samples of polyethylene",
                " with uranium, copper, and iron with blacked out",
                " resonances. Filters of 0.635-cm lead and 0.6-gm/sq-cm",
                " 10Be used to eliminate low-energy gammas and overlap",
                " neutrons in beam. Thick and thin samples used to get",
                " consistent set of neutron widths."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 1.27-cm thick 6Li glass scintillator"
              ]
            }
          ],
          "ANALYSIS": [
