            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 232Th target of isotopic purity 99.99%, was a",
                "self-supporting metallic foil with a thickness of",
                "889(45)mu-g/cm2.",
                "The 236U target of 184(5) mu-g/cm2 thickness was",
                "prepared by electroplating uranium onto a 2.29 mg/cm2",
                "Ta foil. The isotopic composition of the 236U target",
                "was 99.7% 236U and 0.3% 234U."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Charged particles detected by two",
                "particle telescopes each consisting of two double-",
                "sided Micron Semiconductor S2 type silicon detectors",
                " (22 mm active inner diameter and 70 mm active outer",
                "diameter), a 150 mu-m dE detector and a 994 mu-mE",
                "detector, covering a forward angle range of 36deg to",
                "67deg relative to the beam axis."
              ]
            }
          ],
