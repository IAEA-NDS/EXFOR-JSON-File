              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target consisted of approximately 2.1% 59Ni and 0.5%",
                " 63Ni as well as ~64.6% 58Ni, ~26.7% 60Ni, ~3.1% 62Ni,",
                " ~1.9% 61Ni, and ~1.1% 64Ni; prepared for two months by",
                " irradiating 25 g of natural nickel  in a high neutron",
                " flux (1E15 n/sec) at the Oak Ridge high flux isotope",
                " reactor (HFIR)."
              ]
            }
          ],
