          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ABSFY",
                "INTB"
              ],
              "free_text": [
                " The capture-to-fission ratio, alpha, for",
                "the irradiation is equal to the ratio of the number",
                "of 236U produced to the number of 235U nuclei",
                "fission. The number of fissions can be determined from",
                "the post-irradiation concentration of 137Cs as",
                "measured by gamma counting. 236U concentration in the",
                "sample can be determined from mass-spectrometric",
                "analysis. Uranium samples were wrapped in Cd shield",
                "with a cut-off threshold of 0.51 eV."
              ]
