          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Six foils of 235U and four foils of 239Pu were used",
                "in the experiment. All the foils were deposited on 1",
                "or 2 mil Pt. All the weights are based on a half life",
                "for 239Pu of 24,400 years."
              ]
            }
          ],
