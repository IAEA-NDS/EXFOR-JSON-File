          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "SAMPLE GAS TYPICALLY 97-PERCENT ORTHO- AND 3-PERCENT",
                " PARA-DEUTERIUM. PRESSURE RANGES FROM 145 TO 300 TORR."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "NEUTRON BEAM COLLIMATED BY 1.6-CM DIAMETER HOLES IN",
                " LITHIUM-LOADED PLASTIC. ATTENUATION MEASURED WITH",
                " 3.035-METER LENGTH HELIUM FILLED ALUMINUM TUBE. DUMMY",
                " SAMPLE SWITCHED WITH TARGET APPROX 120 TIMES DURING",
                " RUN. DATA NORMALIZED TO 22.4 DEGREES KELVIN SAMPLE",
                " TEMPERATURE. DATA MEASURED AS FUNCTION OF PRESSURE,",
                " THE AVERAGE VALUE IS GIVEN."
              ]
            }
          ],
