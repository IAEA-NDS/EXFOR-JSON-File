            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Compiler's comment: 1 eV is approximately equal 11600",
                "K or 1 K = 0.0862 meV. This ratio was used to convert",
                "temperatures into neutron energies. Therefore, 18 K",
                "neutron temperature is 1.5516 meV (0.0015516 eV)."
              ]
            }
          ],
