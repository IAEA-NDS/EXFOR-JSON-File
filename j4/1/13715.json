            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                " Neutrons detected using liquid scintillation",
                "tank loaded with Cd and viewed by photomultipliers.",
                "Absolute efficiency of scintillator tank = 76.9+-2.2%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " parallel plate fission chamber positioned",
                "along the axis of liquid scintillation tank. Pulses",
                "from detectors were detected with oscilloscope and",
                "photocamera."
              ]
            }
          ],
