          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Element yields in 252Cf spontaneous fission",
                "determined from measured X-ray multiplicities"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.J.Lipinski",
                "B.W.Wehring"
              ],
