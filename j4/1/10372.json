              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured azimuthal asymmetry in scattered neutrons,",
                " which is related to neutron polarization, using a",
                " single fixed detector; a spin rotation magnet was",
                " used to rotate the neutron beam polarization through",
                " 180 degr."
              ]
            }
          ],
