          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "88Zr was produced by projectile fragmentation of",
                "140 MeV/A 92Mo primary beam at NSLS. 88ZR fragments",
                "were separated by A1900 projectile fragment separator",
                "and collected in water target irradiation cell. Water",
                "target was then radiochemically processed  and",
                "concentrated as the final Zr stock containing 7 mu-Ci",
                "of 88Zr and 1.1 mu-Ci of 88Y resulting  from 88Zr",
                "decay, and detectable amounts of 85Sr and 83Rb.",
                "Two 88Y targets were prepared by pipetting Zr stock",
                "into 4 mm/6 mm diameter Suprasil quartz tubes, dried",
                "and sealed."
              ]
            }
          ],
