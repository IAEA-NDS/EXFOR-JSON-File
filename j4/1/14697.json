          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "39-Y-88",
                "field_identifier": "ENR",
                "value": 0.96
              },
              "free_text": [
                " 88Y was produced by projectile",
                "fragmentation of 140 MeV/A 92Mo primary beam at NSLS,",
                "fragments were separated by A1900 projectile fragment",
                "separator and collected in water target irradiation",
                "cell. Water target was then radiochemically processed",
                "and concentrated as the final Y stock containing 0.9",
                "mu-Ci of 88Y 0.3 mu-Ci of 85Sr, and 0.02 mu-Ci of",
                "83Rb and no detectable 88Zr. Two 88Y targets were",
                "prepared by pipetting Y stock into 4 mm/6 mm diameter",
                "Suprasil quartz tubes, dried and sealed"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Since reaction product 89Y is stable,",
                "the upper limit for thermal neutron capture",
                "cross section for 88Y was determined from",
                "the disappearance of 88Y by measurement of",
                "88Y activity before and after irradiation."
              ]
            }
          ],
