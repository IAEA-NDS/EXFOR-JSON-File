          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "At MURR, one set of samples was irradiated for 1 hour",
                "and a second one for 10 hours in the graphite reflector",
                "At MNRC, two sets of samples containing 88Zr and Fe,",
                "Zr, and Mo monitor foils were separately encapsulated",
                "in quartz and irradiated for 12 hours in the Neutron",
                "Transmutation Doping location. This location has the",
                "highest ratio of thermal (<0.5 eV) to fast (>1 MeV)",
                "neutrons in the MNRC reactor. One set of samples was",
                "irradiated with a 1-mm-thick cadmium wrapping, to",
                "reduce the thermal flux by two orders of magnitude."
              ]
            }
          ],
