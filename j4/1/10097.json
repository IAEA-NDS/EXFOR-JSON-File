          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma-ray production cross sections for the",
                " O16 (n,x gamma) reaction from 6.35- to 16.52-mev",
                " neutron energy"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                " Pulsed 55 MeV electron linear accelerator.",
                " Pulse width 50 nsec, repitition rate 520 pps."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "EVAP"
                ],
                "reaction": null
              },
              "free_text": [
                " Evaporation spectrum from Ta-Be target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Ring-shaped scattering sample of D2O (25.4 cm i.d.,",
                " 50.8 cm o.d., and 5.7 cm thick) enclosed in plexiglas",
                " Container, 0.32 cm thick."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 30 cc Ge(Li) gamma detector"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Flux monitored by calibrated proton-recoil",
                " scintillator (NE-211), 2 in diameter by 2 in long.",
                "50-m evaluated flight path.  Ring scatterer centered on",
                " flight path axis.  Ge(Li) detector positioned at an",
                " angle of approximately 125 deg, but sample dimensions",
                " resulted in subtended angle range from 112 to 142 deg."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute Ge(Li) efficiency determined with",
                " calibrated (+-3%) radioactive sources.  Relative",
                " efficiency curve shape obtained from known relative",
                " intensities of gammas from thermal capture in Fe and",
                " Cl."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for multiple scattering flux attenuation",
                " and for gamma attenuation in the sample."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Following errors estimated:",
                "  Absolute neutron flux               about 10%",
                "  Ge(Li) efficiency - below 2.7 MeV   about 5%",
                "                    - above 2.7 MeV   about 10%",
                "  Flux attenuation and multiple",
                "    Scattering                        <5%",
                "  Gamma attenuation in sample         <2%",
                "Overall uncertainty, apart from counting statistics,  1",
                "  about 15%."
              ]
            }
          ],
