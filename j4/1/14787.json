          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct measurement of 59Ni(n,p)59Co and 59Ni(n,a)",
                "56Fe at fast-neutron energies from 500 keV to 10 MeV"
              ]
            }
          ],
