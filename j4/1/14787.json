          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "28-NI-59",
                "field_identifier": "ENR",
                "value": 0.95
              },
              "free_text": [
                " The target thicknes was 91 mu-",
                "g/cm2. A 59Ni target with an additional 104 mu-g/cm2",
                "6LiF deposit was used to check the overall flux",
                "normalization via the 6Li(n,t) 4He reaction"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Charged particles were detected using two S1",
                "detectors from Micron Semiconductors Ltd., located",
                "downstream of the sample, covering forward laboratory",
                "angles 15-30 deg and 45-65 deg."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Neutron energy was determined by time-of-",
                "flight. The time structure of the proton beam",
                "consisted of 100 macropulses/sec, with each 625 mu-s",
                "long macropulse consisting of approximately 340",
                "micropulses, each separated by 1.8 mu-s. Measurements",
                "were made at flight path 15R, at a distance of 15m."
              ]
            }
          ],
