          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-Sensitivity Neutron-Capture Gamma-Ray Facility"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " Reactor CP-5."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Reactor core."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor spectrum with cadmium ratio 7."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples of N, C, B, Li; (natural or enriched);",
                " differing in size from a few mg to many g and placed",
                " in the center of a 10.6-cm dia. aluminum tube that",
                " passes through the reactor core."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Internal-target arrangement used so that the sample",
                " (capture-gamma-ray source) was located in the",
                " high-flux region of a reactor and was viewed (through",
                " a collimator) by a detector located outside of the",
                " reactor."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detector having a resolution width of",
                " 6.7 keV for 7-MeV gamma rays. The neutron flux on the",
                " detector was reduced by collimators with neutron",
                " absorbing and scattering materials (filters)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The intensities were calculated from observed areas of",
                " the gamma-ray lines, relative efficiencies established",
                " experimentally in advance, calculated gamma-ray",
                " transmission of the neutron filter in the gamma-ray",
                " beam and a normalizing factor that is a constant for",
                " a given spectrum."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The lines from capture in 12C present in the graphite",
                " sample holder and 14N (when introduced in the tube)",
                " were used as reference energy lines known with good",
                " accuracy."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction of the observed gamma-ray-line areas for the",
                " background - mainly neutron-capture gamma rays emitted",
                " from structural components in the system."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Calculated by combining the statistical",
                " error of the observed gamma-ray line area and the",
                " systematic error of the relative efficiency."
              ]
            },
