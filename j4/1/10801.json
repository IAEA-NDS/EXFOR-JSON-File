          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distributions of the 6Li(n,t) alpha and",
                " 10B(n,alpha)7Li reactions at 2 and 24 keV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USABNL"
              },
              "free_text": [
                " Brookhaven high flux beam reactor"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Monoenergetic beams obtained by transmission through",
                " -bismuth single crystals, thermal neutrons with",
                "  flux of 10**8 n/cm**2/sec",
                " -scandium, 2-keV neutrons, flux of 10**7 n/cm**2/sec",
                " -isotopic 56Fe, 24-keV neutrons, flux of",
                "  10**7 n/cm**2/sec"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Silicon surface barrier detectors, 300-microns",
                " thick in cylindrical holder with defining and anti-",
                " scattering collimators."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron beam collimated with two 3.175-mm borated nylon",
                " collimators placed 1-meter apart. Polyethylene scat-",
                " terer used between exit collimator and fission chamber",
                " to minimize detector non-uniformity. One detector",
                " fixed at 90-deg to beam, other detector at variable",
                " angles. Sample placed so normal bisects detector",
                " angle. Collimator adjusted to yield maximum counting",
                " rate."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for high energy neutrons in beam."
              ]
            }
          ],
