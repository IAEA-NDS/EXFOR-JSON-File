              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS",
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron beam polarization determined",
                " using the quench-ratio technique.  The absolute value",
                " of the neutron polarization was known to an accuracy",
                " of about 3%."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The spread in neutron energy was mainly caused by the",
                " deuteron energy loss in the gas of the deuterium cell."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cylinder of 209-Bi(2.0cm in diameter and 3.3 cm in",
                " height)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PSD"
              ],
              "free_text": [
                " Pulse-shape used to discriminate against",
                " gamma-ray induced events"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " All detectors were liquid-organic scintillators"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Monte Carlo code JANE was used to correct the",
                " measured asymmetries for finite-geometery effects,",
                " taking into account the sizes of the deuterium gas",
                " cell, the scatterer, and the detector, as well as",
                " attenutation and multiple scattering of the neutrons",
                " in the scatterer",
                "Compound-nucleus corrections applied to 6 MeV data."
              ]
            }
