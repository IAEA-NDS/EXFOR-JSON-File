            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Analyzing power measurements for 209Bi(n,n) at 6 and",
                "9 MeV and consistent dispersive optical-model analyses",
                "for n+209Bi and n+208Pb from -20 to +80 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
