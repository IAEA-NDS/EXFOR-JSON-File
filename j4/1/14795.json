          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USALAS"
              },
              "free_text": [
                " 15R beam line at the Los Alamos",
                "National Laboratory, Los Alamos Neutron Science",
                "Center at the Weapons Neutron Research (LANSCE-WNR)",
                "facility."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " \"White spectrum\" neutron beams were generated",
                "from an unmoderated tungsten spallation source using",
                "the 800-MeV proton beam from the LANSCE linear",
                "accelerator."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Fission fragments were detected by nine pairs of",
                "1-cm2 Si p-i-n diode detectors (Hamamatsu S3590-09)",
                "positioned 3.5 cm from the target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The time of flight of each interacting neutron",
                "was measured using a timing pulse from a Si p-i-n",
                "diode and the accelerator rf signal. The distance",
                "from the spallation target to the Pu targets was",
                "measured to be 1384.9 +- 1.1 cm. The solid angle",
                "covered by the Si p-i-n diodes was ~11% of 2pi."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 2E method was used to measure the fission product",
                "masses and their TKE by detecting the fission",
                "products and determining their energies after neutron",
                "emission."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections for PHD, the pulse-height defect, and",
                "energy loss of fragments in the target and backing",
                "foils are also applied."
              ]
            }
          ],
