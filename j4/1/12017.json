              "coded_information": null,
              "free_text": [
                "The cross-section of the reaction Cs-134(n,gamma)Cs-135",
                "and the half-life of Cs-134."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
