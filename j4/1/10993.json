          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PSD"
              ],
              "free_text": [
                " The fission chambers were located at a",
                "distance of 13.4 m from a water-cooled tantalum",
                "target. The incident neutron energy was measured",
                "using TOF. Signals produced in the liquid",
                "scintillator were analyzed for pulse shape to",
                "distinguish neutrons from gamma rays. A separate",
                "fission chamber with 8.3 mg of 235U was situated",
                "between two 242mAm chambers and provided",
                "normalization at every data point."
              ]
            }
