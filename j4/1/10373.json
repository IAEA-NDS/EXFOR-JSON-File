          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Searched for two-photon np capture by looking for",
                " gamma rays of the appropiate energy emerging in",
                " coincidence. Foreground plus background spectra",
                " accumulated in straightforward coincidence runs",
                " with H2O target in place.",
                "Accidental component measured in a delayed-coincidence",
                " spectra obtained with an arbitrary delay in one leg",
                " of the coincidence circuit using the H2O target.",
                "Background-prompt-coincidence spectra obtained using",
                "  D2O in place of H2O."
              ]
            }
          ],
