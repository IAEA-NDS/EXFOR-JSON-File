          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two samples of 239Pu were used. Thin sample (approx.",
                "1 mg of 239Pu) was measured in a parallel plate",
                "avalanche counter to measure capture cross section.",
                "A second target with mass of 50 mg of 239Pu was",
                "measured to achieve good statistics at higher energies.",
                "Scattered neutron background was measured using 208Pb",
                "target with Ni foils on both sides to represent thick",
                " (200 mg/cm2) cladding which surrounded the 239Pu."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BAF2",
                "PPAC"
              ],
              "free_text": [
                " Gamma rays were detected using DANCE array,",
                "consisting of 160 BaF2 crystals covering the whole",
                "4Pi solid angle. DANCE is located on the 20 m neutron",
                "flight path 14. Coincidence window was set to 6 ns."
              ]
            }
          ],
