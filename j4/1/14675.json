          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "O",
                "subentry_number": "14696001",
                "author": "J.R.Dunning",
                "reference": {
                  "code": "J,PR,45,586,1934",
                  "field": {
                    "reference_type": "J",
                    "reference": {
                      "code": "PR",
                      "number": null,
                      "volume": "45",
                      "part": null,
                      "issue": null,
                      "page": "586"
                    },
                    "date": 1934
                  }
                }
              },
              "free_text": [
                " First",
                "measurement with fast neutrons."
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAPTN"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ACCEL"
                ],
                "institute": "1USAPTN"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutrons were produced by the action of",
                "100 keV deuterons on targets of heavy ice."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " A paraffin-lined ionization chamber."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Scatterers were cylindrical and were slightly larger",
                "in diameter than the ionization chamber (4.2 cm) and",
                "between 4 and 6 cm in length."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron energy was varied by rotating the counter",
                "and scatterer about the target, that is, by varying",
                "the angle theta between the paths of the neutrons and",
                "the deuterons."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section for a particular scatterer was",
                "calculated from the measured transmission, i.e., the",
                "ratio of the number of neutrons indicated by the",
                "counter with the scatterer in front of it to that",
                "indicated with the scatterer removed, the times being",
                "such that the electroscope deflections in each case",
                "were the same. The possible reactions to be",
                "considered are elastic and inelastic scattering and",
                "neglected too, being about 10**-4 times as probable",
                "as scattering. Inelastic scattering also is",
                "apparently small."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A correction was made for the number of neutrons",
                "deflected by the scatterer into the ionization",
                "chamber on the assumption that the scattering was",
                "isotropic."
              ]
            }
          ],
          "STATUS": [
            {
