          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements for neutron-induced",
                "reactions off C, Al, SiO2, Si and Au producing",
                "relatively short-lived radionuclides at neutron",
                "energies between 70 and 160 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.M.Sisterson"
