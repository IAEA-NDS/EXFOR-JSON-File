          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-BE"
                ],
                "reaction": null
              },
              "free_text": [
                " A thin 5 mm thick Be target was used to",
                "produce 73.5 MeV neutrons, for all other neutron",
                "energies the Be target was 10 mm."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Quasi-monoenergetic neutron beam.",
                "  Irradiation parameters:",
                " Neutron      Primary neutron     Irradiation",
                " energy       fluence neutrons        time",
                "   MeV              cm2               (h)",
                "  70.7       9.35 +- 0.65E+10          38.98",
                "  73.5       3.08 +- 0.24E+10          47.7",
                " 110.8       6.63 +- 0.45E+10          40.72",
                " 111.8       6.87 +- 0.42E+10          47.08",
                " 112.0       4.59 +- 0.38E+10          22.32",
                " 112.2       7.2 +- 0.75E+10           32.4",
                " 151.6       1.1 +- 0.07E+10           38.47"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "SiO2 targets - 1.5 cm in diameter and 0.6 cm thick",
                " (weight 2.3 g) or 5 x 5 cm**2 and 0.3 cm thick",
                " (wight 16.6 g), the natSi targets 1.5 cm in diameter",
                "and 0.077 cm thick (weight 0.33 g)",
                "The monitor foils were 1.5 cm in diameter,",
                "the natural C and Al monitor foils were 0.1 cm thick",
                "with weight of 0.34 g and 0.46 g,respectively,",
                "Au monitor foils were 0.025 cm thick and weighed 0.9 g.",
                "The purity of all  materials was 99.9%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " Target stacks were designed such that the",
                "neutron beam transmission through the targets was >90%",
                "and were wrapped in Al foil for stability.",
                "A target stack could have up to two target materials.",
                "Two identical target stacks were irradiated in beam",
                "lines at 0. and 16. degr. to the incident proton beam",
                "direction. The yield at an unique neutron energy was",
                "obtained by subtracting the yield measured at 16.degr.",
                " (after suitable normalization) from that",
                "                             measured at 0. degr.",
                "Many different elements were used as monitor foils",
                "including nat-C, Al and Au, to identify good",
                "monitor reactions."
              ]
            }
          ],
