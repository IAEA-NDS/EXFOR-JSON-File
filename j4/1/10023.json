          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two H2O samples.  First sample = 7.64 g, enriched",
                " to 3.85%. Second sample = 1.686 g, enriched to 34.0%.",
                " Both contained in 2.54 cm diameter stainless steel",
                " disks, wall thickness 0.127 mm.",
                "Disks 10 cm from source at 90 deg to accelerator axis."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Five 3He proportional counters, imbedded in 23",
                " cm diameter polyethylene cylinder. Measured to have",
                " flat efficiency (within +-3%) over energy range of",
                " neutron groups. Detectors 31 cm from sample disks."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determined delayed neutron half-life to be 4.17+-0.02",
                " sec. Cross section is average of results for thin",
                " sample (21.4+-1.7 mb) and for thick sample",
                " (21.8+-2.0 mb)."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For flux normalization, counted source alphas. For",
                " efficiency, calibrated 238PuLi and 238PuLiF neutron",
                " sources."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determined effects of neutron scattering and absorption",
                " and self-absorption of delayed neutrons. Effects of",
                " room-return source neutrons assumed small due to room",
                " geometry."
              ]
            }
          ],
