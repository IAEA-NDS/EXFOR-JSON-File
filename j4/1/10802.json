              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For low temperature, two 7.62-cm diameter sheets of",
                " highly enriched (less than 4-ppm 235U) 238U with a",
                " combined thickness of 0.053 cm.",
                "For high temperature, single 5.77-cm diameter sheet of",
                " highly enriched (less than 10-ppm 235U) 238U.",
                "Depleted uranium shielding samples of various",
                " thicknesses with 0.26+-0.03 atom% 235U."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight with 25.65-m flight path.",
                " Shielding sample located approx 4 meters from sample,",
                " cycled in and out of beam. Collimators of steel, CH2,",
                " and B4C located near target, B4C and lead located near",
                " detector. Lead sheet, 0.34-cm thick, used to reduce",
                " gamma flash. Thermal and overlapping neutrons",
                " suppressed with cadmium and B4C filters. Sample placed",
                " at center of scintillator and is shielded with 5-cm",
                " thick LiH to prevent counts due to low energy neutrons",
                " scattered off sample. Shield also prevents low energy",
                " neutrons scattered into detector solution from",
                " returning to the sample."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                " Liquid scintillator, 1.25-m diameter with",
                " 1100 liters of xylene-based boron loaded solution and",
                " photomultipliers."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 5-cm thick by 20-cm diameter NaI detector for",
                " monitor."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Plastic scintillator with photomultiplier for",
                " neutrons"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative flux determined using 10B4-NaI flux detector.",
                " Normalized to 6.67-eV saturated capture resonance."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for deadtime, background, relative flux",
                " measurement and multiple scattering."
              ]
            }
          ],
