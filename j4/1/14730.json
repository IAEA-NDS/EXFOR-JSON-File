          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spontaneous fission in separated uranium isotopes"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
