          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A spontaneous fission sample 252Cf with 5mm diameter",
                "with a 50 mu-g/cm2 gold cover and an approximate",
                "activity of 0.73 mu-Ci,was placed approximately 3cm",
                "from the conversion foil of the first start timing",
                "detector."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PS",
                "MCPLT"
              ],
              "free_text": [
                "Measurement was performed using",
                "SPIDER spectrometer, consisting of two opposite arms",
                "capable to measure velocity and energy of two fission",
                "fragments on opposite sides of the target.",
                "Velocity of the fission fragment was measured",
                "using two position sensitive detectors, each",
                "consisting of a thin carbon conversion foil,",
                "electrostatic mirror for directing conversion",
                "electrons 90 deg relative to fission fragments and",
                "microchannel plate (MCP) with delay line anode for",
                "MCP position sensitive readout. Timing information",
                "was used for fragment velocity determination.",
                "Position information was used for corrections of path",
                "length for fragments traveling at angles relative to",
                "central trajectory."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Energy of the fission fragment was measured",
                "in an ionization chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "COINC"
              ],
              "free_text": [
                " Fragment velocity was measured using time",
                "of flight. Triple coincidence of two MCP detectors and",
                "ionization chamber was required for each fragment."
              ]
            }
          ],
