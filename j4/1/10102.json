              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Precise measurement of neutron-proton total cross",
                " section from 25 to 60 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
