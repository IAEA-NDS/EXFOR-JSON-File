          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pulsed neutron method. A burst of fast neutrons is",
                "produced in the container (2.8 MeV proton beam on",
                "thick lithium target) when it filled with water and",
                "thermalized, and the decay of the thermal flux is",
                "measured. The water is replaced with a solution, and",
                "the measurement is repeated. The difference in the",
                "decay constants is a function of the capture cross",
                "section in the solute."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for background, dead time, and any",
                "temperature difference between the solutions and",
                "water (typically 1 degree)."
              ]
            }
          ],
