              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " The PT-1 irradiation location of the High Flux",
                "Isotope Reactor. The measured/calculated thermal flux",
                "was (4.2801+-0.1218) E+14 n/cm2/s, epithermal flux",
                " (9.441~+-0.0814) E+12 n/cm2/s and epithermal index",
                "0.022+-0.0007."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 237Np capture target consisted of (148.3+-3.2) ng",
                "of 99.9999+% pure 237Np deposited in a quartz vial,",
                "which was placed in a graphite capsule"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "93-NP-237",
                "field_identifier": "ENR",
                "value": 0.999999
              },
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma rays were measured using a coaxial n-",
                "type HPGe detector, with 58% relative efficiency. The",
                "distance between the target and the detector was 20 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The thermal flux in PT-1 location at 100% power",
                "is typically about 4E+14 n/cm2/s.Activated samples were",
                "transferred from reactor PT-1 position via decay",
                "station to measuring position using pneumatic transfer",
                "system. The measurements were collected over a 72-h",
                "period with measurement times starting at 1 hr and",
                "increasing to 4 hr per measurement."
              ]
            }
          ],
