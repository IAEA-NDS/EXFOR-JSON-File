          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin layers of Pu and U (2.54 cm diam.) deposited onto",
                " stainless steel plates (0.25 mm thick) or molybdenum",
                " plates (0.13 mm thick).",
                "The sample masses were measured by three methods:",
                " - Low geometry alpha counting and calculated specific",
                "   activities,",
                " - Relative thermal fission rates of 235U samples and",
                "   240Pu samples containing 9% 239Pu,",
                " - Isotopic dilution analysis.",
                "------------------------------------------------------",
                " Sample#  Weight(g)  Isotopic composition (at.%)",
                "-------------------------------------------------------",
                "                   238Pu 239Pu 240Pu  241Pu 242Pu 241Am",
                "-------------------------------------------------------",
                " 240Pu-38 0.0754   0.012 0.677 98.386 0.426 0.370 0.128",
                " 240Pu-39 0.260    0.012 0.674 98.394 0.421 0.370 0.129",
                " 240Pu-40 0.0945   0.009 9.490 89.634 0.381 0.338 0.148",
                " 240Pu-41 0.333    0.016 9.330 89.825 0.384 0.336 0.110",
                "-------------------------------------------------------",
                "                   234U  235U   236U  238U",
                "-------------------------------------------------------",
                " 235U 5-1 1.066    1.032 98.402 0.445 0.121",
                " 235U 5-2 0.832    1.032 98.402 0.445 0.121",
                "-------------------------------------------------------"
              ]
            }
          ],
