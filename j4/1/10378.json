          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uncertainty in energy determination estimated to be",
                " +- 3 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metallic lithium on 0.025-cm tantalum backing.",
                "Target thicknesses 6-24 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight measurements over 50-180 cm paths",
                " for alpha detectors and 220-430 cm for neutron",
                " detectors."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " Lithium glass detector for alpha detection.",
                "Neutron flux monitored by 3 different detectors:",
                ". Majority of measurements made using Grey Neutron",
                "  Detector, water and vanadium sulfate used as",
                "  moderators and neutron-to-gamma converters.",
                ". Black neutron detector, used for some measurements",
                "  above 500 keV, consisting of cylindrical plastic",
                "  scintillator viewed by 5 photomultipliers.",
                ". Long Counter used for some measurements in the",
                "  energy range 200-270 keV."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Normalized to absolute measurements made with a",
                " vanadium bath calibrated with 252Cf sources."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for:",
                ". detector efficiencies,",
                ". attenuation of neutron beam in lithium glass (8%),",
                "  and in air between lithium glass and neutron",
                "  detectors (<8%),",
                ". second neutron group from Li(p,n) (0-12%),",
                ". inscattering (<1.5%),",
                ". energy dependent transmission through collimator",
                "  walls, for measurements using a 2nd collimator",
                "  between lithium glass and neutron detectors,",
                "  (0.6-1.1%),",
                ". averaging caused by energy spread of neutron beam,",
                "  for values measured at peak of resonance, (<1.1%)."
              ]
            }
          ],
