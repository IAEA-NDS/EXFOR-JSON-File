          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "GSPEC"
              ],
              "free_text": [
                " To establish absolute radiative partial",
                "widths for the plutonium resonances, it was necessary",
                "to prepare and run in a separate experiment a",
                "composite sample of plutonium and platinum. The",
                "7921-keV transition found in the 11.9-eV Pt-resonance",
                "was used as a standard for line intensities. The",
                "widths are obtained from gamma-ray intensities under",
                "the assumption of a constant total radiation width of",
                "0.04 eV for 239Pu (BNL-325)."
              ]
            }
          ],
