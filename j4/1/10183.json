              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " D(d,n) source. Gaseous flow target. Energy spread",
                " due to deuteron energy loss in gas 385 keV at 3.3 MeV",
                " neutron energy, decreasing to 110 keV at 5.6 MeV",
                " average neutron energy."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI",
                "NAICR"
              ],
              "free_text": [
                " 45cm3 Ge(Li) detector inserted into NaI",
                " (Tl) annulus, operating in anti-coincidence."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " Flux monitored by long counter which was",
                " calibrated against a proton recoil telescope for",
                " absolute flux."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total gamma ray production cross sections calculated",
                " from differential measurement using angular distri-",
                " butions calculated using Mathur (TNC Report ORO-2791-",
                " 21,1966) coefficients. Lowest-order gamma transitions",
                " assumed since higher-order admixtures unknown."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Ge(Li) photopeak efficiency determined with",
                " standard gamma sources."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for flux attenuation through sample and for",
                " multiple scattering."
              ]
            }
          ],
          "ERR-ANALYS": [
