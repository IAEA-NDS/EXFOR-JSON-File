          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron flux is 4.-5.e13 neutrons cm-2 sec-1, and",
                "cadmium ratios, determined by measuring 95Zr, are about",
                "of 55 for fission of 235U and about of 20 for fission",
                "of 233U."
              ]
            }
          ],
