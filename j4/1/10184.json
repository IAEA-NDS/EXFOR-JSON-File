              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron energy in reference 2535 keV. Authors revised",
                " value to 2533 keV due to new high precision value for",
                " energy of 7Li(p,n) second group (see Phys.Rev.C5,284",
                " (1972)). New value 429 keV versus value of 431 keV",
                " used in reference."
              ]
            }
          ],
