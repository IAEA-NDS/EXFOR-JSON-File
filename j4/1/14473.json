            {
              "pointer": "",
              "coded_information": [
                "FNB",
                "PHWT",
                "TOF"
              ],
              "free_text": [
                " The filtered-beam runs were performed by",
                "placing a 30 cm slab of elemental iron in the path of",
                "the neutron beam. A 5/32 in. thick B4C filter was also",
                "placed in the beam to remove any low-energy overlap",
                "neutrons."
              ]
            }
          ],
