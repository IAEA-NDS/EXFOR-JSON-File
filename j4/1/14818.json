          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular Distribution of Neutrons Produced by 40- and",
                "80-Mev Alpha Particles on a Thick Tantalum Target"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
