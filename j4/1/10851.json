          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A wobbled and water-cooled 238U disc scattering sample,",
                " 3.8 cm in  diameter and 1.2 cm thick."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G",
                "N"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI",
                "NAICR",
                "SCIN",
                "FISCH"
              ],
              "free_text": [
                " A 40 cm3 Ge(Li) detector",
                "surrounded by NaI(Tl) detector for gamma-ray",
                "detection. Neutron flux monitored with a plastic",
                "scintillator and a fission chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC",
                "COINC",
                "TOF"
              ],
              "free_text": [
                " De-excited gamma rays from the",
                "scatterer were detected with Ge(Li) detector placed",
                "at 125 degrees with respect to the incident neutron",
                "flux and 88 cm from the center of scatterer. An",
                "annular NaI(Tl) detector, which was surrounded the",
                "Ge(Li) detector, was used to detect Compton events.",
                "Neutron monitoring during the data runs was done by a",
                "neutron time-of-flight detector. The 0 degree -",
                "neutron fluence was measured after each run with a",
                "long counter and a fission chamber in a TOF system."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "4PI1A"
              ],
              "free_text": [
                " The 125 degrees data obtained from energy",
                "spectra were converted to gamma-ray production cross",
                "sections. Angle-integrated cross sections were",
                "deduced from the gamma-ray production results by",
                "multiplying the data by 4 pi, therefore assuming that",
                "contributions due to P4 and higher-order Legendre",
                "polynomials are negligible."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total uncertainties in gamma-ray production",
                "cross sections were typically 10% for the strong",
                "transitions and 20% for the weak ones."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 0.0,
                "maximum_value": 3.0,
                "correlation_property": null
              },
              "free_text": [
                " 4 pi integration error."
              ]
            }
          ],
          "STATUS": [
            {
