          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Prompt gamma rays emitted in the",
                "thermal-neutron-induced fission of 235U"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "F.Pleasonton",
                "R.L.Ferguson",
                "H.W.Schmitt"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAORL"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,6,1023,1972",
                "code_unit": [
                  {
                    "unit": "J,PR/C,6,1023,1972",
                    "doi": "10.1103/PhysRevC.6.1023",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "6",
                        "part": null,
                        "issue": null,
                        "page": "1023"
                      },
                      "date": 1972
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "#doi:10.1103/PhysRevC.6.1023"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                " Measurements were performed at the",
                "Oak Ridge research reactor using conventially",
                "collimated neutron beam with a flux of more than",
                "10.0E+8 thermal neutrons/(cm2 sec)"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutrons"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 1 cm diameter target prepared by vacuum",
                "evaporation of thin deposit (30mug/cm2) of U335 onto",
                "a thin carbon film. Fissile material contained 99.44%",
                "of 235U, 0.0001% of 233U and 0.56% of even uranium",
                "isotopes."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The fission fragments were detected by two",
                "silicon surface barrier detectors. First detector",
                "with area of 600 mm2 was placed at a distance of 3.5",
                "cm from neutron beam axis was limited by a",
                "collimator with diameter of 7/8 in., the second",
                "detector with area of 400 mm2 was collimated using",
                "collimator with diameter of 5/8 in."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Gamma rays were detected by an NaI(Tl)",
                "crystal with diameter of 5 in. and thickness of 4",
                "in., placed at a distance of 89 cm from the target",
                "center. NaI(Tl) detector was placed in a lead",
                "collimator, limiting its solid angle to 1.602E-2 sr."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between fission detector and",
                "NaI(Tl) detector was required."
              ]
            }
          ],
