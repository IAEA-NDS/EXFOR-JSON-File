              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "2.318-g radiogenic lead sample; 72.3 atom % 208Pb,",
                " held under vacuum in magnesium alloy chamber.",
                "Sample oriented at 45 degrees to neutron beam."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " High purity germanium detector surrounded by",
                " bismuth germanate (BGO) Compton-suppression detector.",
                " Detector surrounded by 10-cm-thick layer of lead and",
                " 6Li-loaded plastic."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Detector calibrated using gamma yield from 152Eu",
                " source and from 35Cl(n,gamma)36Cl reaction."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determined by assuming that ratio of 208Pb(n,gamma) to",
                " 12C(n,gamma) for cold neutrons is the same at thermal",
                " energies."
              ]
            }
          ],
