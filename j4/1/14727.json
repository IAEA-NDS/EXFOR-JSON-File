          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons of energy <250 keV energy were slowed",
                "down by ~60 gm paraffin. The thermalized neutrons",
                "produced fissions in a cylinder of uranium metal. The",
                "plates were then placed 15 cm from the uranium so",
                "that the fission neutrons would be well collimated."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A cylinder of uranium metal (weight 330 grams, size",
                "approximately 3/4\" x 5/4\")."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " The photographic emulsion technique. The",
                "plates were 100 microm thick Ilford Special Halftone",
                "plates, and were wrapped first in thin aluminum foil",
                "and then in black paper."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " The spectrum was inferred from the ranges of 850",
                "protons recoiling in the forward direction. It shows",
                "a very wide maximum at ~1.5 MeV with an exponentially",
                "decreasing high energy tail which extends beyond 7 MeV."
              ]
            }
          ],
