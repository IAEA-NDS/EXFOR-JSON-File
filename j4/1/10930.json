          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Fission neutrons counted with 30 helium-3",
                "detectors, 2.5-cm diameter, 60-cm long, 6-atm",
                "pressure, embedded in a cylindrical paraffin and",
                "polyethylene matrix, 54-cm diameter, 90-cm long."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Gas filled counter with hemispherical",
                "geometry. Active sample deposited on convex surface,",
                "electron charge collected on concentric surface 2-mm",
                "from source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Fission chamber inserted into a 10-cm",
                "diameter hole that penetrates central core of",
                "paraffin-polyethylene cylinder. Helium-3 counters",
                "placed parallel to cylinder axis, spaced symmetrically",
                "into 3 concentric rings. Fission of known Cf-252",
                "sample used to calibrate He-3 counters. A pulse from",
                "a fission chamber serves to open a gate to count",
                "nearly all neutrons detected in coincidence with the",
                "fission fragment."
              ]
            }
          ],
