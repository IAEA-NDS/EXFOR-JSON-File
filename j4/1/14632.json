          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,101,024312,2020",
                "code_unit": [
                  {
                    "unit": "J,PR/C,101,024312,2020",
                    "doi": "10.1103/PhysRevC.101.024312",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "101",
                        "part": null,
