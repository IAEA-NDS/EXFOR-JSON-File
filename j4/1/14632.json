          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beta-delayed neutron emission studies of 137,138I and",
                "144,145Cs performed with trapped ions"
              ]
            }
          ],
          "AUTHOR": [
            {
