          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T",
                  "D-D",
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons of 3.5 MeV were produced by",
                "4.2-MeV protons from the T(p,n)He3 reaction at zero",
                "degrees to the incident beam. The D(d,n)He3 reaction",
                "was used as the source for the 4.7-MeV and 7.1-MeV",
                "neutrons with bombarding energies of 1.47 and 3.8",
                "MeV, respectively. The T(d,n)He3 reaction was used as",
                "the source for 12.7-MeV and 14.1-MeV neutrons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The neutron detectors were made of an organic",
                "scintillator which gave light pulses from recoil",
                "protons caused by neutron scattering in the",
                "scintillator."
              ]
            }
          ],
