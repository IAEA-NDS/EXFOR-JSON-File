              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Magnetic spectrometer system using four multi-",
                " wire proportional counters and three scintillation",
                " detectors used to detect scattered protons"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute normalization uses known cross sections for",
                " neutron-proton collisions yielding deuterium and",
                " neutral pions."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Magnetic spectrometer used to obtain time of",
                " flight information for scattered protons. Background",
                " measured using empty target. Computer program KIOWA",
                " used to derive cross sections from raw data. Since",
                " monitor only good for angles less than 13.2-degrees,",
                " average value of absolute normalization to dual-flux-",
                " monitor-counts ratio used for relative normalization",
                " of larger angles."
              ]
            }
