          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Integral Testing of Spallation Cross Sections for",
                "Neutron Dosimetry at 113 and 256 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
