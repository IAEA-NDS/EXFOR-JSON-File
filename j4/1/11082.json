          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total Cross Section of Li6 for Neutrons"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " for neutrons up to 1.5 MeV"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " for higher energy neutrons"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "5 samples of metallic Li, cast into thin-walled",
                "cylindrical stainless steel cans, enriched in Li-6",
                "to between 89.0 and 93.8%, chemical purity between",
                "95.49 and 99.97%, diameter between 2.0 and 3.0 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " for neutrons between 0.035 and 0.18 MeV"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " for neutron between 0.18 and 1.5 MeV, a",
                " propane-filled proportional recoil counter;",
                " for energies above 1.5 MeV, a high-pressure hydrogen",
                " chamber was used."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Background corrections were appreciable for the BF3",
                "counter measurement but negligible (below 1%) for the",
                "recoil counters."
              ]
            }
          ],
          "HISTORY": [
