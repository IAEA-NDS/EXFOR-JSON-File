          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-C12"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons were produced by impinging a 25 MeV",
                "2H+ beam on a 3.5-mm-thick carbon breakup target in",
                "the cyclotron vault."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "SCIN"
              ],
              "free_text": [
                " The Gamma Energy Neutron Energy",
                "Spectrometer for Inelastic Scattering (GENESIS). For",
                "this experiment, three Eurisys two-fold segmented",
                "HPGe CLOVER detectors and twenty-six 5.08 cm dia. x",
                "5.08 cm h. right-circular cylindrical EJ-309 organic",
                "liquid scintillators with pulse shape discrimination",
                "capabilities were included in the array. The CLOVER",
                "detectors were positioned in the horizontal plane of",
                "the beam at polar angles of 63, 122.5, and 151",
                "degrees with respect to incident neutron beam",
                "direction. The angular coverage of the CLOVER",
                "detectors when operated in total detection mode was",
                "6.4, 4.5, and 4.7 degrees, respectively. The EJ-309",
                "cells covered an angular range of 11-165 degrees with",
                "respect to the incoming neutron beam and were",
                "positioned at a radial distance of approximately 0.45",
                "m to 0.9 m from the carbon target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A pressed graphite carbon target of 98.9% 12C",
                "elemental purity. The target was an elliptic cylinder,",
                "1 mm in thickness, with a minor diameter of 76.2 mm,",
                "major diameter of 107.8 mm, and weight of 6.564 g,",
                "the latter determined using an analytical balance."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PSD",
                "TOF"
              ],
              "free_text": [
                " The 12C partial gamma-ray cross sections",
                "were extracted at 63, 122.5, and 150 degrees with",
                "respect to the incoming neutron beam and integrated",
                "using angular distribution data available in the",
                "literature."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A correction for air attenuation between the target",
                "location and the location of sTOF (approx. 2.7 m) was",
                "required as a modification to the neutron spectral",
                "flux used in the determination of the partial",
                "gamma-ray cross section data."
              ]
            }
          ],
