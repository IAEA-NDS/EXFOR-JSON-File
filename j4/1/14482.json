          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-238",
                "field_identifier": "ENR",
                "value": 0.9997
              },
              "free_text": [
                " A total of six 1.27 cm diameter",
                "depleted 238U targets were used. They were mounted",
                "normal to the incident beam at a distance of 2.54 cm",
                "downstream from the end of the deuterium gas cell when",
                "the  2H(d,n)3He reaction was employed. At 14 MeV the",
                "238U  target was positioned at a distance of 2.54 cm",
                "from the 0.4 mm thick Cu backing of the tritiated",
                "titanium foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The targets were gamma-ray counted in TUNL's",
                "low-background counting facility, using a set of high",
                "efficient standard HPGe and HPGe Clover detectors.",
                "The dead time of the counting system was less than",
                "1%. Over a period of 1 - 2 months, the targets were",
                "measured using a number of different counting cycles,",
                "depending on the half-lives of the product nuclei."
              ]
            }
          ],
