          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma Rays from Thermal Neutron Capture in 28Si, 29Si",
                " and 30Si."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " Reactor CP-5."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Reactor core with a neutron flux ~3E+13",
                " n/cm**2 s."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor spectrum."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Internal-target facility used; target sample placed in",
                " high-flux region of reactor and viewed (through a",
                " collimator) by a detector located outside the reactor.",
                "Counting rate kept below 2000/sec to avoid peak",
                " broadening."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detector having an active volume of",
                " 4 cm**3 and a resolution width of 6.7 keV for 7-MeV",
                " gamma rays. The neutron flux on the detector was",
                " reduced by collimators with neutron absorbing and",
                " scattering materials (filters)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A singles spectrum was taken by each sample and a",
                " double escape spectrum was obtained by requiring",
                " coincidence between the Ge(Li) detector signal and",
                " the accompanying annihilation radiation observed with",
                " two NaI(Tl) detectors.",
                "Impurity lines were identified from the known",
                " background of the system as well as by a comparison",
                " with spectra from enriched isotopes."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "14-SI-29(N,G)14-SI-30,,SPC,,SPA",
                  "code_unit": [
                    {
                      "unit": "14-SI-29(N,G)14-SI-30,,SPC,,SPA",
                      "field": {
                        "reaction": "14-SI-29(N,G)14-SI-30",
                        "target": "14-SI-29",
                        "projectile": "N",
                        "process": "G",
                        "product": "14-SI-30",
                        "quantity": ",SPC",
                        "data_type": null,
                        "general_quantity_modifier": "SPA",
                        "quantity_236": ",SPC"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " Relative intensities",
                " normalized to average of the intensities other",
                " investigators have reported for strong 6744 keV.",
                "Gamma-ray calibration based primarily on the peaks",
                " from the 4945.43 keV transition in carbon. Relative",
                " intensities were obtained by first summing the counts",
                " under the individual peaks and then employing the",
                " relative efficiency curve determined for the Ge(Li)",
                " detector."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for the various thicknesses of the borated",
                " polyethylene absorber."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors in the peak areas given."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The results from the 28Si(n,gamma)29Si reaction agreed",
                " well with those from other investigations using",
                " natural or enriched 28Si as targets."
              ]
            }
          ],
