          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of gaseous fission product yields from",
                "14 MeV neutron induced fission of 238U at the National",
                "Ignition Facility"
              ]
            }
          ],
