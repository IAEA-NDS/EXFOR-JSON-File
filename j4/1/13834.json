                "reaction": null
              },
              "free_text": [
                " Highly collimated external beam of thermal",
                " neutrons, (height ~2 cm, width ~0.5 cm, thermal flux",
                " ~5E7 neutrons/cm2/s) effectively free of fast",
                " neutrons and pile gamma rays, extracted from a",
                " modified thermal-column at the CP-5 reactor."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal spectrum (cadmium ratio ~570)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets consisted of pressed cylindrical pellets of",
                " of WO3 enriched to 97.2% in 186W and contained in",
                " thin-walled (4.5 mg/cm2) aluminum holders."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Two coaxially drifted Ge(Li) detectors (active",
                " volumes ~20 and ~30 cm3) mounted at 180 deg to",
                " each other and positioned 2.5 cm from the beam axis.",
                " Energy resolution of both detectors ~2.7 keV at 1.33",
                " MeV. The detectors shielded from scattered neutrons by",
                " thin (0.25 cm thick) 6LiF disks."
              ]
            }
          ],
