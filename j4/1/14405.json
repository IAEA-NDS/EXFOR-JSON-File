          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spontaneous fission source",
                "Two 252Cf sources were measured independently. The",
                "manufacture date and intensity at the time of the",
                "measurement were 1994 and 56 000 fissions/s for",
                "source 1, and 2005 and 4800 fissions/s for source 2.",
                "Sources were initially loaded with 82% of 252Cf and",
                "10% of 250Cf by weight.Based on the initial",
                "composition and branching ratios for these sources,",
                "14.5% and 1.8% of fissions are from 250Cf for sources",
                "1 and 2, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Measurement setup consisted of an array of 14",
                "EJ-309 liquid scintillation detectors, arranged in a",
                "ring around a 252Cf source directly on a thin metal",
                "table. Each cell is cylindrical and has dimensions of",
                "7.62- cm diameter x 5.08-cm length and is read out by",
                "7.62-cm-diam ET-Enterprises 9821B photomultiplier tubes"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between two neutron detectors",
                "required"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " Pulse shape analysis was used to identify",
                "fission neutrons"
              ]
            }
          ],
