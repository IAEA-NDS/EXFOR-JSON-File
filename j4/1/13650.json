          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the (n,H3) Cross Section in Nitrogen",
                "and Its Relationship to the Tritium Production in the",
                "Atmosphere"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
