          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal spectrum. A bismuth filter used to provide a",
                " thermal neutron beam (collimated to 1-cm diameter;",
                " intensity of 7E6 n/cm2/s)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target of ~500 mg Er2O3 powder, enriched to 91.54% in",
                " 167Er and placed in the center of the array, 20 cm",
                " from the Ge detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                ". 1.5E+8 two-detector coincidence events",
                " obtained. Gates placed on strong transitions in order",
                " to locate gamma rays that feed into known levels from",
                " higher, unknown levels."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " Array of 16 Ge detectors with Bismuth germanate",
