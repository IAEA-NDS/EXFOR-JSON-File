          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Five stacked foils of natural Pb (natPb) angled 20 deg",
                "off the normal of the beam direction. Each foil",
                "measured nominally 5 cm x 5 cm in area and 0.475 mm",
                "in thickness. Sample was located at the center of",
                "gamma ray detector array."
              ]
            }
          ],
          "DETECTOR": [
