          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Statistical tests for the detection of intermediate",
                "structure: Application to the structure of the 238U",
                "neutron capture cross section between 5 keV and 0.1 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
