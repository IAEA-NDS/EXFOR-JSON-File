          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "HPGE"
              ],
              "free_text": [
                " Three telescopes each composed typically",
                "of three hyperpure Ge detectors mounted inside a common",
                "cryostat. Protons emitted at three angles are detected",
                "simultaneously by three telescopes.",
                "With one additional run with deflecting magnetic field",
                "is turned on, a complete six point angular distribution",
                "out to 20. degr. can be obtained."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " In front of each Ge telescope a thin dE plastic",
                "scintillator is placed to provide a fast trigger in",
                "coincidence with signals in the first detector of the",
                "corresponding telescope."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "COINC"
              ],
              "free_text": [
                "",
                "Background was measured with the target removed.",
                "Thus, a measurement at a given field setting was",
                "accomplished by cycling back and forth through the",
                "target sequence: 6Li, CH2, blank."
              ]
            }
