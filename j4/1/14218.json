          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The H2O samples were between two thin quartz disks.",
                "The sample thicknesses were used: 0.3213+-0.0025,",
                "0.7635+-0.0025, and 1.2713+-0.0025 cm. The sample",
                "temperature was 23 degrees Celsius."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " 4 in. cadmium covered cube of 1 wt.% of borated",
                "polyethylene that acted as a source of thermal",
                "neutrons. The assembly was excited by fast neutrons",
                "obtained from LINAC electron pulse on tungsten",
                "target. The neutron beam was extracted through a hole",
                "and collimated along 16 m flight path to a bank of 32",
                "BF3 detectors."
              ]
            }
          ],
