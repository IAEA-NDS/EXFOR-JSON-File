          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USALAS"
              },
              "free_text": [
                "Experiment performed at white neutron",
                "source of the Lujan Center, based on spallation",
                "reactions on a tungsten target using a pulsed 800-MeV",
                "proton beam, accumulated and compressed in a proton",
                "storage ring."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "71-LU-176",
                "field_identifier": "ENR",
                "value": 0.9995
              },
              "free_text": [
                " 176Lu target was prepared by",
                "176Lu ion deposition onto a 1 mu-m thin aluminized",
                "mylar foil. Target thickness was 0.5mg/cm2 and",
                "diameter 7 mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BAF2"
              ],
              "free_text": [
                " 4PI gamma-detector array DANCE, composed of",
                "160 BaF2 scintillators. DANCE provides the total",
                "g-ray calorimetry and the multiplicity information",
                "of the g-cascade following neutron capture."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Incident neutron energy determined by time of",
                "flight. Proton beam was compressed to a 250 ns pulse",
                "and delivered into tungsten spallation target at a",
                "repetition rate of 20 Hz. DANCE array was located on",
                "a 20.25 m long flight path."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " 800 MeV proton beam was compressed using the",
                "proton storage ring to a 250 ns pulse. A 100 mu-A",
                "beam is delivered at a rate of 20 Hz onto the",
                "tungsten spallation target. The produced neutrons were",
                "moderated in water located just downstream from the",
                "neutron production target"
              ]
            }
          ],
          "ERR-ANALYS": [
