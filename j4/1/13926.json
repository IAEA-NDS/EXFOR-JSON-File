          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "By author:",
                "The use of thick samples in the measurement of fission",
                " yields causes the observed yields to depend upon",
                " pulse height, which in turn depends upon the",
                " ionization released by the recoil fission fragment.",
                "With the operating conditions used in our experiment",
                " this means that the thick sample yield values",
                " probably are uncertain by as much as 20%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Bi,Pb,Tl,Hg,Au,Pt(n,f) energy dependent relative thick",
                " target fission yields in Fig.4 of Phys.Rev.73,1135",
                " (1948)."
              ]
            }
          ],
