              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USABNL"
              },
              "free_text": [
                " High flux beam reactor"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor beam filtered with 12-inches of Fe-56 and",
                " 7-inches of Al."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sample sandwiched between two layers of 0.022 gm/cm**2",
                " Cd foils and packed together with 1 gm/cm**2 gold",
                " monitor"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Germanium-lithium detector surrounded by bismuth",
                " and lithium loaded polyethylene to shield detector",
                " from gamma and neutron backgrounds."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "79-AU-197(N,G)79-AU-198,,SIG",
