          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Detectors registered particles with relative",
                " timings expected for H(n,gamma)D reactions. Neutron",
                " velocity, and directions and velocities of deuterons",
                " and gamma rays were measured. Data from counters were",
                " fed to a PDP-10 computer on line."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 17 scintillation and one Cerenkov counter used.",
                "Movable photon detector and deuteron counters subtended",
                " approximately the same solid angle (c.m.) at each of",
                " nine separate angles and each of four neutron energies"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The H(n,gamma)D events were recognized as a narrow",
                " peak above a broad background in a plot of events",
                " as a function of coplanarity."
              ]
            }
          ],
