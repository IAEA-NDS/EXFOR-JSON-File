          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detectors 15 to 40 cm3",
                " Typical energy resolution is 2.2 keV FWHM for 1.33",
