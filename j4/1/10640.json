                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-BE"
                ],
                "reaction": null
              },
              "free_text": [
                " 10-MeV protons on 9Be to approximate a prompt",
                " fission neutron spectrum."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "2-second cycle consisting of a 1.0-sec irradiaiton",
                " followed by a 0.080-sec delay and a 1.0-sec counting",
                " period with a 0.020-sec wait."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Proton-recoil proportional counters"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Detectors calibrated using 3He(n,p)3H reaction"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for energy-dependent detector efficiencies",
                " and for carbon-recoil events in the methane detector.",
                "Not corrected for finite detector size and field",
                " effects (correction about 5%), or for possible bias",
                " resulting from lead shield."
              ]
            }
          ],
