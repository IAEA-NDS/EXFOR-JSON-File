          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured Near-Equilibrium Delayed Neutron Spectra",
                " Produced by Fast-Neutron-Induced Fission of 232Th,",
                " 233U, 235U, 238U, and 239Pu."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
