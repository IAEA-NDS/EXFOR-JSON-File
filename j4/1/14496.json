              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " the thulium and monitor foils were gamma ray",
                "counted in TUNL's Low-Background Counting Facility",
                "using 25%, 55%, or 60% relative efficiency",
                "high-purity germanium detectors"
              ]
            }
          ],
