          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two targets; one enriched to 60% in Te123, the other",
                " natural-abundance tellurium."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI",
                "NAICR"
              ],
              "free_text": [
                " Anihilation-pair spectrometer with an",
                " efficiency of 30%, consisting of a 9-cc Ge(Li)",
                " detector mounted in the 5-cm-diameter hole passing",
                " axially through a four-quadrant NaI(Tl) split-annulus",
                " scintillator.",
                "Two Ge(Li) detectors having volumes of 1 and 4 cc used",
                " in preliminary experiments."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Obtained three types of spectrum, which were used to",
                " distinguish between full-energy, single-escape, and",
                " double-escape peaks.",
                "1.) singles spectrum, only using the Ge(Li) detector.",
                "2.) coincidence spectrum, gated by a coincidence pulse",
                " generated whenever two annihilation quanta escaping",
                " from the Ge(Li) detector are detected simultaneously",
                " in opposite quadrants of the scintillator.",
                "3.) anticoincidence spectrum with enhanced full-energy",
                " peaks.",
                "Line intensities were computed from singles data using",
                " efficiency versus energy curve for full-energy and",
                " double-escape peaks."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "4945-keV gamma ray of C13 and the 10830-keV gamma ray",
                " from N15 used for calibration."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Line intensities were corrected for energy-dependent",
                " absorption in the polyethelene and lead absorbers,",
                " in the carbon target holder, and in the beam tube."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "E-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
