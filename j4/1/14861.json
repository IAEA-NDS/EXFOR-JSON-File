          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of a cold neutron cross section for the",
                "40Ca(n,alpha)37Ar reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Kh.A.Shah",
                "S.T.Castro",
