              "coded_information": null,
              "free_text": [
                "POLARIZED NEUTRON CAPTURE ON 13-C."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
