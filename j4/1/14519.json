          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beta-decay half-lives of 134,134mSb and their",
                "isomeric yield ratio produced by the spontaneous",
                "fission of 252Cf"
              ]
            }
          ],
