                  {
                    "unit": "25-MN-55(N,THS)25-MN-55,INC,SIG,,MSC,DERIV",
                    "field": {
                      "reaction": "25-MN-55(N,THS)25-MN-55",
                      "target": "25-MN-55",
                      "projectile": "N",
                      "process": "THS",
                      "product": "25-MN-55",
                      "quantity": "INC,SIG",
                      "data_type": "DERIV",
                      "general_quantity_modifier": "MSC",
                      "quantity_236": "INC,SIG"
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "Paramagnetic scattering cross section of Mn++ in",
                "manganous fluoride."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The difference between the experimental and",
                "hypothetical curve in the regions 0 to 4.2A and 5.5",
                "to 6.2A was taken as the paramagnetic cross section.",
                "For simplicity, we assume that there is no loss of",
                "coherent scattering in the hypothetical curve up to",
                "5.46A, the cut-off wave-length for Bragg reflections",
                "for MnF2. Beyond the cut-off the equation of the",
                "curve is given by sigma = (1.0+2.31**(-1/2)); the",
                "assumed residual incoherent scattering cross section",
                "of 1.0 barn appears to be a justifiable approximation",
                "on the basis of other studies carried out here."
              ]
            }
          ],
