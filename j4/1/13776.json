              "coded_information": null,
              "free_text": [
                "Fission Cross Section of Uranium-234"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
