          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total cross sections for 14-MeV neutrons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "D.I.Meyer",
                "W.Nyer"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "R,LA-1279,1951",
                "code_unit": [
                  {
                    "unit": "R,LA-1279,1951",
                    "doi": null,
                    "field": {
                      "reference_type": "R",
                      "reference": {
                        "code": "LA-",
                        "number": "1279",
                        "volume": null,
                        "part": null,
                        "issue": null,
                        "page": null
                      },
                      "date": 1951
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USALAS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "1USALAS"
              },
              "free_text": [
                " A Cockcroft-Walton accelerator operated",
                "at 250 kilovolts."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " If the reaction energy is taken as 17.60 MeV,",
                "the neutron energies range from 14.08 to 14.35 MeV at",
                "the angle (70 degrees to the beam) at which the",
                "measurements were made."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " Copper spirals wrapped around Geiger tube to",
                "detect Cu(n,2n) reaction neutrons were used.",
                "Background was reduced by shielding the detector with",
                "cadmium."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "All samples were 1 inch in diameter except for",
                "Cu samples which were 1/2 inch and 1 inch diameter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " The transmission is defined as the ratio of the",
                "neutron flux as measured by the detector with a",
                "scattering sample in the path of the neutrons to the",
                "neutron flux with no scattering sample in the path of",
                "the neutrons. In general the length of the scattering",
                "sample was such as to give a transmission of",
                "approximately 0.5."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections were evaluated by relation sigma =",
                " (1/nx)*log(1/T), where n is the number of atoms or",
                "molecules per cm3, x is the length of the scattering",
                "sample in centimeters, and T is the transmission",
                "corrected for the effect of room-scattered neutrons."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Standard deviations."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 0.25,
                "maximum_value": 1.0,
                "correlation_property": null
              },
              "free_text": [
                " Small-angle scattering effects."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Error due to elastic neutron scattering was about",
                "0.25 to 1 percent. No correction for this effect was",
                "considered. Corrections due to room scattered",
                "neutrons were considered."
              ]
            }
          ],
