          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the 75As(n,2n) cross section at 14.1",
                "MeV at the National Ignition Facility"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.N.Kmak",
                "J.D.Despotopulos",
                "J.Jeet",
                "T.L.Huynh"
              ],
              "free_text": [
