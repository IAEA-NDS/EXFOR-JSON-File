          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pu-241, in form of 37-gms Pu(O)2. sample placed in",
                "nickel cans, 2.86-cm long by 0.91-cm outer diameter.",
                "Cans placed in basket then loaded into stainless",
                "steel inner liner. Inner liner placed into stainless",
                "steel outer tube. Sodium bonding used between",
                "components."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " Isotope dilution mass spectroscopy. Absolute",
                "number of fissions determined using summation",
                "technique. Total irradiation time of four years."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Presence of Ba-134 and Cs-134 assumed to Be from",
                "neutron capture on Cs-133. totals added to Cs-133.",
                "less than 1-percent correction",
                "-neodymium corrected for burning and burnout by neutron",
                "capture. Corrections of 0.5-1.3 percent",
                "-Sm-147,149,151 corrected for Nd-146,148,150 burnout",
                "-Sm-148 added to  Sm-147 totals",
                "-Sm-150 added to Sm-149 totals"
              ]
            }
