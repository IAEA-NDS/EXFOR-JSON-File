              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detector having sensitive volume of",
                " ~4 cm3 and an energy resolution width of 6 keV at a",
                " deposited energy of 6 MeV; operated in singles and",
                " pair-spectrometer modes."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Two 4x4-in. NaI(Tl) scintillators mounted 180",
                " degrees apart, straddled the Ge(Li) detector in order",
                " to clarify and confirm certain lines as double-escape",
                " peaks in the pair-spectrometer mode of the detector",
                " system."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Intensities normalized to the intensity of strongest",
                " transition observed in spectrum.",
                "4946 and 3684 keV gamma lines used as gamma-ray energy",
                " energy standards."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Computer code used for analyzing spectra by employing",
                " Gaussian line shape in a variable-metric minimization",
                " procedure. Double-escape peak assignments corroborated",
                " by the pair-spectrometer spectrum."
              ]
            }
          ],
