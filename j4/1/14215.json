          },
          "BIB": {
            "N1": 10,
            "N2": 0
          },
          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the average energy and multiplicity",
                "of prompt-fission neutrons from 238U(n,f) and",
                "237Np(n,f) from 1 to 200MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Taieb",
                "T.Granier",
                "T.Ethvignot",
                "M.Devlin",
                "R.C.Haight",
                "R.O.Nelson",
                "J.M.O'Donnell",
                "D.Rochman"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USALAS",
                "2FR BRC",
                "1USABNL"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "C,2007NICE,1,429,2007",
                "code_unit": [
                  {
                    "unit": "C,2007NICE,1,429,2007",
                    "doi": null,
                    "field": {
                      "reference_type": "C",
                      "reference": {
                        "code": "2007NICE",
                        "number": null,
                        "volume": "1",
                        "part": null,
                        "issue": null,
                        "page": "429"
                      },
                      "date": 2007
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USALAS"
              },
              "free_text": [
                "Experiment was performed at the LANSCE",
                "using the fast neutrons produced by the WNR spallation",
                "source. The 800 MeV proton beam impinges on a",
                "tungsten target producing high-energy neutrons.The",
                "proton-beam structure consists of 300 ps pulses",
                "spaced every 1.8mu-s."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                "10 cm long ionization chamber containing 94",
                "plates where 380 mg of pure actinide (resp. 238U or",
                "237Np) were deposited was used for detection of",
                "fission fragments and provided a time signal for",
                "neutron energy measurement by time of flight method."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 20 scintillation detectors located 1 m from the",
                "fission chamber covering angles from 45 to 135 degrees",
                "were used. The setup is known as FIGARO and was located",
                "at a distance of 22 m from the spallation target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PSD"
              ],
              "free_text": [
                "Kinetic energy of the incoming neutrons was",
                "measured by time-of-flight defined by linac pulse",
                "timing and ionization chamber time signal. The energy",
                "of fission neutrons was determined by measurement of",
                "time between fission chamber event and timing signal",
                "from scintillation detector. Pulse-shape analysis",
                "was used to separate gammas from neutrons."
              ]
            }
          ],
          "INC-SOURCE": [
