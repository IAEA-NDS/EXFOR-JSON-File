          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron scattering from Os isotopes at 60 keV and Re-Os",
                "nucleochronology."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
