          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Shielded mass 136 yield from fast fission of 233U,",
                "235U,237Np,and 239-242Pu."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USAINL"
              },
              "free_text": [
                " Experimental breeder reactor II."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "",
                "The irradiation time was 1340 hrs with reactor at",
                "62.5 MW."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron spectrum mean energy ranged from 250-485 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Chemical separation followed by isotope",
                " isotope dilution mass spectrometry."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "99.99 percent pure oxide powder targets were",
                "individually mixed with 99.99 percent nickel powder.",
                "Row 8 was used for irradiation location."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Number of fissions determined by measuring 90 percent",
                "nuclides in heavy mass peak and estimating remainder."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
