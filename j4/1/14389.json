          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "ACTIV"
              ],
              "free_text": [
                " An activation cross section measurement",
                "of the isotopes during the course of a neutron",
                "irradiation. A uranium sample was used to measure Np",
                "and Pu cross sections. Np and Pu were produced by",
                "n-capture on U, 2 beta decays, capture again. The",
                "competing channels are shown in the diagrams."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MASSP"
              ],
              "free_text": [
                " Further work involved one month cooling,",
                "chemical processing, mass spectrographic analysis."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The principal analyses required by this method are",
                "the mass spectrographic determination of the",
                "234U/233U and 240Pu/239Pu ratios, the analyses of the",
                "233U and 239Pu produced in the 232Th and 238U",
                "respectively, and the irradiation times."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
