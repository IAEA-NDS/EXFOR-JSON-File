          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scattered neutrons were detected using two NE218",
                "scintillation detectors with diameter of 8.88 and 12.7",
                "cm and height 5.08 cm. Both detectors were heavily",
                "shielded and located on movable carriages at distances",
                "4m and 6 m from scattering target, respectively."
              ]
            }
