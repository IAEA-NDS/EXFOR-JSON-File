              "coded_information": [
                "1USAUSA"
              ],
              "free_text": [
                " 9 Bolleana Pl, Athens, Ohio"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "R,INDC(USA)-108,2015",
                "code_unit": [
                  {
                    "unit": "R,INDC(USA)-108,2015",
                    "doi": null,
