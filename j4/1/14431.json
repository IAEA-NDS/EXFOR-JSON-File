          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Verification of the 252Cf standard in the energy",
                "range 2 - 20 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "N.V.Kornilov"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
