          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Level Structure of 148Sm and 150Sm from Average",
                " Resonance Neutron Capture."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USAANL"
              },
              "free_text": [
                " In-pile (n,gamma) facility at Argonne",
                " CP-5 research reactor."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Reactor core with a thermal-neutron flux ~3e+13",
                " n/(cm2.s) and an epithermal flux per unit energy",
                " interval ~c/E, where c=1.8e+12 n/(cm2.s). Integrated",
                " epithermal flux between 100 eV (cut-off) and 10 keV",
                " ~8e+12 n/(cm2.s)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor spectrum effectively limited by boron that",
                " removes low-energy neutrons. The dominant",
                " contributions to the spectrum were from neutrons in",
                " the approximate energy range  0.1-10 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metal capturing target of 28 g natural samarium",
                " (14.97% 147Sm, 13.83% 149Sm) in the form of a disk",
                " 5/8 in. in diameter and 3/4 in. long, placed in a",
                " graphite holder and completely surrounded by",
                " 1/8-in.-thick absorber of 10B powder."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Pulse-height-spectra taken both in singles",
                " [with Ge(Li) detector only in use] and in triple",
                " coincidence [when the double-escape peak in the Ge(Li)",
                " detector coincides with the two annihilation gamma",
                " rays on the opposite sides of the NaI(Tl) detector].",
                " The coincidence mode allowed only double escape events",
                " to be recorded.",
                "Measured average intensity of primary gamma transitions",
                " to low-lying levels where neutron capture takes place",
                " in a large number of resonances. Averaging process",
                " removes the large fluctuations in gamma widths",
                " normally observed with neutron capture in a single",
                " resonance."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI",
                "NAICR"
              ],
              "free_text": [
                " Ge(Li)-NaI(Tl) spectrometer located about",
                " 5 m from the target. The Ge(Li) detector, with an",
                " active volume of 6 cm3 and a resolution of 5.4 keV at",
                " 6 MeV, was surrounded by a split-ring NaI(Tl)",
                " detector."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy calibration based on the well-measured",
                " 4945.46-keV line in 13C and on a number of strong",
                " lines from 15N between 5.2 and 7.3 MeV.",
                "The relative efficiency for double-escape peaks in the",
                " Ge(Li)-NaI(Tl) coincidence spectrometer was determined",
                " from the observed spectrum of 13C and 15N lines",
                " introduced in a calibration run."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma-ray lines were identified by their relative",
                " energies used in conjunction with previously published",
                " level schemes, and by comparison of the average-",
                " resonance capture spectrum with thermal-capture",
                " spectra.",
                "Two different line shapes used in the analysis, one for",
                " El peaks and a second with a longer high-energy tail",
                " for M1 and E2 peaks."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data corrected for spectrometer efficiency and",
                " gamma-ray absorption."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "E-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainties in gamma-ray energies; do not",
                " include the absolute error in the Q value."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Intensity uncertainties; include both",
                " statistical error and the probable systematic errors",
                " in the corrections for spectrometer efficiency and",
                " gamma-ray absorption.",
                "Systematic uncertainties of line intensities due to",
                " residual fluctuations in the average intensities",
                " related to the Porter-Thomas distributions of",
                " radiation widths are 10%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Unique spin and parity assignments given for almost all",
                " the states below 2.2 MeV in both isotopes. The neutron",
                " binding energies of 148Sm and 150Sm found to be",
                " 8140.6(18) and 7986.4(18) keV, respectively, after",
                " correction for the energy spectrum of the captured",
                " neutrons."
              ]
            }
          ],
          "STATUS": [
