          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectroscopically pure, normal chromium, 9.5% 53Cr."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " \"Spec. pure\" normal chromium was",
                "irradiated for about 13.4 hours in the fast neutron",
                "flux of the Los Alamos Water Boiler. Vanadium was",
                "chemically separated from the chromium and the",
                "vanadium sample counted in a beta proportional",
                "counter. This sample had a maximum beta activity of",
                "approximately 3 cpm which might be attributed to",
                "23-hour V53. No measurable gamma activity was present."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Assuming 5 MeV to be a reasonable value for the",
                "effective threshold for 53Cr(n,p) reaction and using",
                "what is considered to be the approximate value of the",
                "flux of neutrons greater than 5 MeV, an approximate",
                "limit of the average cross section for this reaction",
                "was calculated to be approximately 3.4*10**-5 mb."
              ]
            }
          ],
          "DECAY-DATA": [
