          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "94-PU-242",
                "field_identifier": "ENR",
                "value": 0.87
              },
              "free_text": [
                " A foil stack containing five",
                "targets of 242Pu, each ~50 microg/cm2 over a 3 mm",
                "diam spot on a 1 mm Be backing. The targets were",
                "prepared by vacuum evaporation of Pu feed material",
                "which was ~87% 242Pu."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC",
                "COINC"
              ],
              "free_text": [
                " The 242mAm fission isomer was produced",
                "using the (t,3n) reaction on 242Pu. A 2-3 microA beam",
                "of 17 MeV tritons from the LASL FN tandem Van de",
                "Graaff impinged on a foil stack. The recoil reaction",
                "products were thermalized in a He atmosphere which",
                "had been partially passed over a container of water.",
                "Coincident and single fission events were recorded",
                "with the two solid state detectors and buffer stored",
                "with the use of an on line SDS-930 computer. The",
                "experiment was performed for ~3 days during which",
                "time 41342 binary fission events were recorded. To",
                "insure that the measured fission activity was from",
                "the decay of 242mAm the half-life was measured by",
                "pulsing the beam."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energies and masses of the coincident fission",
                "fragments were obtained using the \"mass defect\"",
                "calibration procedure. The primary fission",
                "calibration standard was 252Cf."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron correction based on method of Terrell."
              ]
            }
          ],
