          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Symmetric fission observed in thermal-neutron-induced",
                "and spontaneous fission of 257Fm"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
