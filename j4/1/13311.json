                "BY B.F.RIDER:",
                " FRACTIONAL INDEPENDENT YIELD RATIO OF I-135 TO I-133",
                "  IS RATIO OF SLOPES (-1.36+-0.04/-0.056+-0.04).",
                " ASSUMING SUM OF BOTH FI'S=0.504 THEN",
                "  (.056/(1.36+.056))*.504 = 0.020+-0.014 FI FOR I-133",
                "    AND",
                "  (1.36/(1.36+.056))*0.504 = 0.484+-0.024 FI FOR I-135"
              ]
            }
