          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute mass calibration of fission product",
                "distributions measured with the E-v method"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "P.Gastis",
                "J.R.Winkelbauer",
                "D.S.Connolly",
                "S.A.Kuvin",
                "S.M.Mosby",
                "C.J.Prokop",
                "I.Stetcu"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/A,1037,166853,2022",
                "code_unit": [
                  {
                    "unit": "J,NIM/A,1037,166853,2022",
                    "doi": "10.1016/j.nima.2022.166853",
                    "field": {
                      "reference_type": "J",
                      "reference": {
