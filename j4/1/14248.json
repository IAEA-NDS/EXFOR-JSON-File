          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "MACS are derived from ENDF/B-VII.0 renormalized to",
                "the measured SACS. The final MACS values were",
                "obtained from thermalized energy-differential cross",
                "sections <sigma>kT =(2/sqrt(pi)) *(Integral from zero",
                "to infinity[sigma(En)NF](En*exp(-En/kT)dE)) /(Integral",
                "from zero to infinity[En*exp(-En/kT)dEn]) where En is",
                "the neutron energy and exp(-En/kT) the Boltzmann factor",
                " for a thermal energy kT."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section value in subentry 14248.004 is",
                "renormalized   for new gold cross section."
              ]
            }
          ],
