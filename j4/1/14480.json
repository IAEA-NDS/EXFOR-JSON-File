          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the 209Bi(n,4n)206Bi and",
                "169Tm(n,3n)167Tm cross sections between 23.5 and 30.5",
                "MeV relevant to reaction-in-flight neutron studies at",
                "the National Ignition Facility"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.E.Gooden",
