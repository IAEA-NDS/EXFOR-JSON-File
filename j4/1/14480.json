          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Quasimonoenergetic neutrons were produced with",
                "the 3H(d,n)4He reaction. Accelerated deuterons were",
                "incident onto a neutron production target consisting",
                "of 2.1 Ci tritium absorbed onto a 19 mm diameter",
                "deposit of titanium on a 0.4 mm thick Cu backing.",
                "Neutron energy was measured using neutron",
                "time-of-flight. Neutron spectrum showed main peak and",
                "a group of low energy off-energy neutrons."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for contribution of off-energy neutrons.",
                "Corrections ranged from 0.1% for 23 MeV neutrons and",
                "almost 50% for 30 MeV neutrons"
              ]
            }
          ],
