          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Gamma-ray spectra were recorded in both",
                "single and coincidence mode from thermal neutron",
                "capture in ZrO."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A crude estimate of the neutron capture cross section",
                "can be made by arbitrarily assuming that 50% of the",
                "decay proceeds by transitions to states below 4000",
                "keV and calibrating the observed decay transitions",
                "from these states against the 934 keV (37.5%)",
                "transition from 91Zr capture (sigma=1030 mb). This",
                "yields 14.4 mb. The 50% assumed intensity would",
                "appear conservative and therefore the 14.4 mb",
                "estimate may in fact be high."
              ]
            }
          ],
