          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 0.49 mg/cm2 248Cm target in the form of CmF3, on a",
                "0.013-mm Be foil was used in these experiments."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Si(Au) surface-barrier detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "REC"
              ],
              "free_text": [
                " Irradiations were performed with 18O ions",
                "with intensities of 2-3 microA. The calculated",
                "average energy of the 18O ions in the 248CmF3, target",
                "was 95 MeV. Nuclides recoiling from the target were",
                "transported via a He-jet system containing NaCl",
                "aerosol through 1.1-mm Teflon tubing to the",
                "collection point about 10 m away. Four pairs of",
                "detectors were used to measure the kinetic energies",
                "of fission fragments from the spontaneously",
                "fashioning nuclides deposited on the polypropylene",
                "foils."
              ]
            }
          ],
