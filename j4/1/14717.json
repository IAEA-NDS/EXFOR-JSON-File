          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission properties of the 1.5-s spontaneous fission",
                "activity produced in bombardment of 248Cm with 18O"
              ]
            }
          ],
          "AUTHOR": [
