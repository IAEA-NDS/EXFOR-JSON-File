          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Large and small rectangular water samples with values",
                " of the geometrical buckling from 0.014 cm**(-2) to",
                " 0.59 cm**(-2)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pulsed neutron method applied to measure the time-",
                " dependent flux distributions as a function of",
                " geometrical size.",
                "Thermal absorption cross section of hydrogen inferred",
                " from theoretical fit to the measured data."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Small fission counter placed in an external",
                " position for dimension <5 in. and at the center of the",
                " large samples. Two fission counters used for the",
                " large-geometry measurements."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron mean lifetimes measured for a variety of",
                " sample sizes and fitted to the diffusion-theory",
                " representation by the method of least squares.",
                " Fourier analysis applied for time-dependent spatial",
                " distribution of thermalized neutrons to separate",
                " fundamental mode decay from higher modes in large",
                " geometries. Spatial distribution assumed",
                " approximately separable in x,y, and z at some time",
                " after initial pulse of fast neutrons."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Raw data corrected for coincidence losses and",
                " normalized to constant source intensity.",
                "Flight-time and container-reflection effects taken",
                " into account."
              ]
            }
          ],
