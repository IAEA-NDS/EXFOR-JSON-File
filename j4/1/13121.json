              ],
              "free_text": [
                " 25.4 CM LONG, 25.4 CM DIAMETER CYLINDRICAL NAI",
                "SURROUNDED BY A 12.7 CM THICK PLASTIC SCINTILLATOR AS",
                "AN ANTICOINCIDENCE SHIELD."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "99.75 PERCENT PURE HEAVY WATER, WITH A DISTILLED WATER",
                "SAMPLE FOR BACKGROUND SUBTRACTION. SECOND SAMPLE WAS A",
                "DEUTERATED LIQUID SCINTILLATOR, C6D12, 4.18 CM LONG,",
                "3.70 CM DIAMETER. THE DENSITY WAS 0.89 G/CC AND 45 CC",
                "IN VOLUME."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "SOURCE OF SYSTEMATIC UNCERTAINTIES ARE AS FOLLOWS:",
                "  - CHOICE OF SUMMING REGION (3 %)",
                "  - CORRECTION FOR ACCIDENTAL STOPS IN TIME TO ANALOG",
                "    CONVERTER (2 %)",
                "  - CORRECTION FOR FINITE GEOMETRY (5 %)",
                "  - DETECTOR EFFICIENCY AND SOLID ANGLE (4-8 %)",
                "  - SCINTILLATING TARGET EFFICIENCY FOR DETECTING TRITO",
                "    RECOILS (2 %)",
                "  - RECIPROCAL SQUARE OF DISTANCE FROM CENTER OF THE GA",
                "    CELL TO THE CENTER OF THE TARGET (2 %)",
                "  - NUMBER OF TARGET NUCLEI, HEAVY WATER (1 %)",
                "  - DEUTERATED LIQUID SCINTILLATOR (5 %)",
                "  - INTEGRATED CHARGE OF THE DEUTERIUM BEAM PASSING THR",
                "    THE GAS CELL (3 %)",
                "  - DENSITY OF THE DEUTERIUM ATOMS IN THE CELL (2 %)",
                "  - LENGTH OF THE CELL (2 %)",
                "  - ZERO DEGREE CROSS SECTION FOR THE REACTION 2H(D,N)3",
                "    AS A FUNCTION OF DEUTERON BEAM ENERGY (2 %)",
                "  - CORRECTION TO THE ZERO DEGREE FLUX APPLICABLE TO TH",
                "    POLARIZED BEAMS (2 %)"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
