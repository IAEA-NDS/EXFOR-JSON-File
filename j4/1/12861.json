          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "EXPERIMENTAL DETERMINATION OF ANAMALOUS SCATTERING",
                "LENGTHS OF SAMARIUM FOR THERMAL NEUTRONS."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USABNL"
              },
              "free_text": [
                " BROOKHAVEN HIGH FLUX BEAM REACTOR."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "DIFFR"
              ],
              "free_text": [
                " DIFFRACTION.",
                "  1800 INDEPENDENT REFLECTIONS WERE MEASURED AT A",
                "  WAVE LENGTH OF 1.3 ANGSTROM AND THE CRYSTAL STRUCTURE",
                "  REFINED TO A FINAL R-VALUE OF 0.058.",
                "140 REFLECTIONS WITH STRONG SM-CONTRIBUTION WERE",
                "  MEASURED AT A NUMBER OF WAVELENGTHS BETWEEN 0.827",
                "  AND 1.300 ANGSTROMS."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " 002 BE FACE CRYSTAL WAS USED TO OBTAIN THE",
                "       MONOCHROMATIC NEUTRON BEAM WITH WAVE LENGTHS",
                "       BETWEEN 0.827 AND 1.300 ANGSTROMS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A SINGLE CRYSTAL OF A SODIUM SAMARIUM EDTA COMPLEX",
                "  NA+(SM(C10H12N2O8).3H2O-5H2O WAS USED.",
                "  SAMPLE AT 37 DEGREES KELVIN IN HELIUM ATMOSPHERE."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A LEAST-SQUARED ANALYSIS OF THE REAL AND IMAGINARY",
                "  PARTS OF THE SCATTERING LENGTH IN RELEVANT",
                "  TERMS WAS PERFORMED TO OBTAIN THE SCATTERING",
                "  LENGTH FOR NATURAL SAMARIUM."
              ]
            }
          ],
          "ASSUMED": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "THE SCATTERING RADIUS WAS ASSUMED TO BE 7.98 FERMI."
              ]
            }
          ],
