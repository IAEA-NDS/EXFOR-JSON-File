          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For transmission measurement-",
                " 3.45-cm thick 206Pb, enriched to 88.38%.  Compensator",
                "  sample consists of 0.173-cm thick natural Pb with",
                "  0.292-cm thick 207Pb enriched to 92.4%.",
                "For capture measurement-",
                " 10.03-gms of 206Pb enriched to 88.38%, 2.50-cm  by",
                "  4.77-cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight.",
                "For transmission measurements-",
                " Flight path of 78.203 meters. 300-mg/sq-cm 10B filter",
                " used to eliminate slow neutrons. Gamma flash",
                " eliminated with 0.6-cm lead filter. Compensated",
                " sample used to account for other isotope contributions",
                " and to act as thin sample for large neutron widths.",
                " Effective sample thickness with compensator is",
                " 0.0989-atoms/barn with apparent enrichment of 99.9%.",
                " Gamma background measured by eliminating neutrons",
                " with thick polyethylene filter and correcting for",
                " gamma attenuation in sample.",
                "For capture measurements-",
                " Flight path of 40.12 meters. 0.48-gms/sq-cm thick 10B",
                " filter used to absorb low energy neutrons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 11-cm diameter by 1.3-cm thick 6Li glass",
                " detector for transmission measurement.",
                "Pair of fluorocarbon-based liquid scintillators with",
                " low neutron sensitivity and 15% efficiency for cascade",
                " gammas. Bias set above 197 keV to reject 19F inelastic",
                " gammas.",
                "0.5-mm 6Li glass scintillator to monitor neutron flux",
                " shape and intensity."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "MLA"
              ],
              "free_text": [
                " Multi-level Breit-Wigner analysis. Least squares",
                " fitting with SIOB (transmission) and ORGLS2 (capture)",
                " computer codes. Capture data normalized to saturated",
                " 4.9-eV gold resonance."
              ]
            }
          ],
