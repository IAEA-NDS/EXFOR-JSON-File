          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 1-10 milligrams of PuO2 enclosed in in thin (0.0005",
                "in) nickel foil to catch fission fragments."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Side-window, gas-flow, proportional counters."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                " Three irradiations were performed at",
                "thermal neutron flux of 10**14 n/cm**2/sec with 1 mg",
                "sample. A fourth irradiation of approximately 10 mg",
                "of PuO2 was performed at a flux of 1.5*10**13",
                "n/cm**2/sec. After irradiation the capsules were",
                "opened and nickel-wrapped samples were removed. The",
                "samples, including the nickel foil, were dissolved in",
                "hot HCl and then treated with HNO3. All counting was",
                "done in proportional counters. The radiochemical",
                "purity of each sample was determined by its decay",
                "characteristics."
              ]
            }
          ],
