            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "THCOL"
                ],
                "reaction": null
              },
              "free_text": [
                "Activation were performed in reactor thermal",
                "column with nominal thermal and epithermal neutron",
                "fluxes 7E+10 and 2E+8 n/cm2/s-1, respectively. Some",
                "samples were irradiated using fast pneumatic transfer",
                "facility with neutron fluxes 1E+13 and 3.5E+11",
                "n/cm2/s-1, respectively"
              ]
            }
