          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Pd metal of thickness 0.025 mm was used as a",
                "sample. Simultaneous irradiations of Au, Co, and Zr",
                "were done to determine the neutron flux."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma rays were observed with a high-",
                "purity Ge detector with efficiency of 35% compared",
                "with NaI at 1332 keV. The detector resolution was",
                "typically 1.68 keV at 1332 keV."
              ]
            }
          ],
