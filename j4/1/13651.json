              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross Sections for Products of 90-Mev Neutrons on",
                "Carbon"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "D.A.Kellogg"
              ],
              "free_text": [
