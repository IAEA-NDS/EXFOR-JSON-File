          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BAF2"
              ],
              "free_text": [
                " DANCE is located at the Los Alamos National",
                "Laboratory. This detector is a 4pi gamma ray",
                "calorimeter composed of an array of 160 BaF2 crystals,",
                "each coupled to a PMT."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consists of a hollow aluminum cylinder (2.9",
                "cm long and 3 cm in diameter) sealed by two 0.0762 mm",
                "thick Kapton windows spaced apart by 2.30+-0.05 cm.",
                "The target volume was filled with high purity (99.999%",
                "Ar) gaseous natural argon and pressurized (T=296.7+-1K,",
                "p=1.0987+-0.0005 bara) above the local atmospheric",
                "pressure throughout the data taking period. The target",
                "is located at the center of the DANCE spectrometer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The Argon Capture Experiment at DANCE (ACED) is",
                "a time-of-flight (TOF) system capable of measuring",
                "neutron energy in the thermal range to an accuracy of",
                "a few meV. Events in DANCE are recorded in a 15 ms",
                "acquisition window, triggered by either a beam spill or",
                "an external pulser - provided the energy deposit is",
                ">150 keV. Individual gamma rays are reconstructed via",
                "a nearest neighbor clustering algorithm. The number of",
                "reconstructed clusters provides the multiplicity of the",
                "event; the energy of each cluster provides the",
                "individual reconstructed gamma energy, with the summed",
                "energy yielding the total reconstructed event energy.",
                "Both a total energy and a cluster multiplicity cut are",
                "applied in order to select events from neutron captures",
                "on 40Ar."
              ]
            }
          ],
