          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The fit of the 40Ar cross section as a function of the",
                "neutron velocity, in the energy range 0.01-0.15 eV,",
                "using 1/v law, yields sigmamp=670+-26(stat)+-43(sys) mb",
                "and T=294+-36 K for the most probable cross section",
                "and the temperature of the target. Correcting for the",
                "average temperature of the moderator and the target,",
                "<T>=296+-36 K, yields sigma2200=673+-26(stat)+-59(sys)",
                "mb for the standard thermal cross section."
              ]
            }
          ],
