              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Neutrons were detected by a 13.7cm diameter BC-",
                "501A liquid scintillator, which was housed in a lead",
                "and wax shield, with a 4.4cm lead lining in the",
                "internal aperture and a 7cm wax lining around the lead."
              ]
            }
          ],
