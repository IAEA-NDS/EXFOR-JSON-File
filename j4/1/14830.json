              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,110,014626,2024",
                "code_unit": [
                  {
                    "unit": "J,PR/C,110,014626,2024",
                    "doi": "10.1103/PhysRevC.110.014626",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "110",
                        "part": null,
                        "issue": null,
