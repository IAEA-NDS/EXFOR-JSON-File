          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New constraint on the 237Np(n,gamma)238Np integral",
                "cross section using the Godiva-IV critical assembly"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.S.Tamashiro",
                "S.Burcher",
                "J.T.Harke",
                "B.Pierson",
                "J.G.Duarte",
                "Y.Mishnayot",
                "S.W.Padgett",
                "P.Zhao",
