          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three enriched 238U samples with weights 0.3675,",
                "0.3549, and 0.3550 g, with a maximum weight",
                "uncertainty of 0.2% and areas of 4.99, 4.72,",
                "and 4.88 cm2. Sample with 8 monitor foils was placed",
                "inside Energy Tuning Assembly (ETA), which was designed",
                "to spectrally shape the deuterium-tritium 14.1 MeV",
                "fusion neutron spectrum into a modified thermonuclear",
                "and prompt fission neutron spectrum."
              ]
            }
          ],
