            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Measurements of microdosimetric spectra and",
                "absorbed doses were made at WNR with an Ar-CO2-filled",
                "Rossi counter used with time-of-flight neutron energy",
                "discrimination. A fission chamber was used to measure",
                "the neutron spectral fluences."
              ]
            }
          ],
