                "1USALAS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,85,021601,2012",
                "code_unit": [
                  {
                    "unit": "J,PR/C,85,021601,2012",
                    "doi": "10.1103/PhysRevC.85.021601",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
