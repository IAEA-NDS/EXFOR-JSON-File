          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Evidence for the stochastic aspect of prompt gamma",
                "emission in spontaneous fission"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.Chyzh",
                "C.Y.Wu",
                "E.Kwan",
                "R.A.Henderson",
