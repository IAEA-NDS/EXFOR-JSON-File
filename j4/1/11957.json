          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Because the 3.0 sec activity was observed in cross-",
                "bombardments of highly enriched 120Sn, natural tin,",
                "and natural antimony, it can be assigned definitely",
                "to 120In. It is a hard beta-emitter, but its radiation",
                "characteristics have not been studied otherwise.",
                "It is formed in the 120Sn(n,p) reaction with a",
                "cross-section of approximately 1 millibarn at 14.8 MeV."
              ]
            }
          ],
