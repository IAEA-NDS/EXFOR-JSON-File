          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BSPEC"
              ],
              "free_text": [
                " The Xe from each run was measured into two",
                "counters, designated a and b, each of which was",
                "counted ten times, over a period of two weeks,",
                "starting about 10 days after irradiation, on each of",
                "two electronic circuits, designated 1 and 2. Eight",
                "different counters were used for the five runs."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The basic Xe activity datum that enters the fission",
                "yield calculation in a given run is the mean of the",
                "corrected a and b averages of that run. This gives",
                "the disintegration rate of the total Xe in the given",
                "slug 253 hr after the end of a 1-hr bombardment. Of",
                "this total activity, about 98.8 percent was 5.27-day",
                "Xe133, one percent was 2.3-day Xe133m, and the",
                "remaining 0.2 percent was 12.0-day Xe131m."
              ]
            }
          ],
