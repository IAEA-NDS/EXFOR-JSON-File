          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections for geometrical size of sample, for",
                "absorption, and for multiple scattering can be made",
                "by obtaining the slope at zero thickness of an",
                "intensity vs sample thickness curve. Such intensity",
                "curves made with materials of known cross sections",
                "make it possible to calculate the corrections for",
                "samples of unknown scattering cross sections."
              ]
            }
          ],
