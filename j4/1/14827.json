          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron source strength of 2.3*10**8 s-1. The flux",
                "density was monitored with by indium foils, using the",
                "the average result of the two In foils yielding a",
                "flux of 3.7*10**7 cm-2 s-1."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metallic niobium foils of 10 mm diameter and 28",
                "micrometer thickness."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The activity of thick metallic niobium foils",
                "after irradiation with 252Cf spontaneous fission",
                "neutrons was derived by measuring the emitted 16.6",
                "keV XKalpha-rays with a calibrated Ge detector",
                "considering self-absorption in the foils. The",
                "irradiation time was about 40 days and the neutron",
                "fluence 1.2*10**14 cm-2."
              ]
            }
          ],
