          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1.88-cm high by 2.00-cm diameter with mass of 67.08-gm.",
                " enriched to 99.75% Pb-208."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 5.08-cm thick by 18.4-cm diameter liquid scin-",
                " tillator with photomultiplier used for scattered",
                " neutrons with 7-20 MeV incident energy. Shielded with",
                " paraffin, iron, water, and lead. Shadow bar also used.",
                " neutron flux monitored with 5.0-cm diameter by 5.0-cm",
                " long liquid scintillator."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Normalized by measurements of neutron flux per monitor",
                " count at zero degrees with scattering sample removed."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight with a 3.74-M path for 7-MeV",
                " neutrons and a path of 6.62-M for other energies.",
                " Detector threshold set to half of maximum scattered",
                " energy. Sample suspended by light thread in center of",
                " tritium or deuterium gas. Gamma events eliminated with",
                " pulse shape discrimination. Background measured and",
                " subtracted channel by channel after monitor normaliz-",
                " ation."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for-",
                " -dead time",
                " -source anisotropy",
                " -relative detector efficiency",
                " -finite geometry (Monte-Carlo method)",
                " -neutron flux attenuation (Monte-Carlo method)",
