          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Highly enriched 241Am targets with enrichment of 99.9%",
                " 241Am were produced as a dry nitrate were,",
                " 1 cm-diameter layer of 241Am was electroplated from",
                " an isopropanol/dilute nitric acid solution on a",
                " 12.7 um-thick Pt foil.",
                "Total thickness of 241Am layer was about 1000 ug/cm2,",
                " mass of 241Am 800-1000 ug and activity around 3 mCi.",
                "Target was placed in thin aluminum container sealed",
                " with 2 cm-diameter Havar windows."
              ]
            }
          ],
