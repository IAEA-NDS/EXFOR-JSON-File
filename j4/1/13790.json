          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "On the Neutrons from the Deuteron-Deuteron Reaction."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron-deuterium reaction produced with 400 kv",
                " outfit, molecular beam and target of heavy ice.",
                " 2.44 MeV neutrons at 90 deg with respect to ion",
                " beam. Neutron energy practically independent of",
                " deuteron energy in the interval studied (50-300 keV)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Transmission."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Paraffin-lined ionization chamber of 2.5 cm",
                " diameter placed 27 cm from the target."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Results corrected for:",
                ". neutrons scattered into chamber from parts of the",
                "  apparatus near target (about 3% of the total yield",
                "  at 27 cm).",
                ". neutrons scattered into chamber from scatterer",
                "  (few percent of measured transmission). Correction",
                "  calculated assuming isotropic scattering."
              ]
            }
          ],
