                "reaction": null
              },
              "free_text": [
                " T(d,n) source.",
                " The sample of titanium was placed immediately behind",
                " a 600 mu-g/cm2 Zr-T target which was bombarded by",
                " 300 keV deuterons"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A sample was of pure Ti02"
