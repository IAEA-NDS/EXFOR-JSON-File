          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The spectrum of gamma-rays from the irradiated sample",
                "was recorded at varying intervals over a period of",
                "several weeks.The relative yields of the 46Ti(n,p)46Sc,",
                "48Ti(n,p)48Sc and 50Ti(n,p)50Sc reactions were",
                "determined by analysis of gamma-ray photopeaks at 1.12,",
                "1.31 and 1.56 MeV due to the decay of 46Sc, 48Sc and",
                "50Sc, respectively"
              ]
            }
          ],
