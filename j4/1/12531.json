          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Attempts to measure 254Es (276d) led to erroneous",
                "results until an aged sample of einsteinium from an",
                "extensive Savannah River Reactor irradiation was",
                "obtained. In this sample the 255Es content (20.7d)",
                "had decayed to the point where alpha particle pile-up",
                "in the fission counter did not obscure the",
                "neutron-induced fission activity. The quantity of",
                "254Es in the sample was measured by comparing the 1",
                "MeV gamma ray activity from the 250Bk in equilibrium",
                "with 254Es to the gamma ray activity of a small, pure",
                "254Es standard."
              ]
            }
          ],
