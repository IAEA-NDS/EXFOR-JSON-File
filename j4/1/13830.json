          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Low-energy level structure of 151Sm by neutron capture",
                " reactions and theoretical interpretation."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USAANL"
              },
              "free_text": [
                " In-pile (n,gamma) facility at Argonne",
                " CP-5 research reactor."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Reactor core with a neutron flux at the in-pile",
                " sample position ~3e+13 n/(cm2.s)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor spectrum effectively limited by boron that",
                " removes low-energy neutrons. The dominant",
                " contributions to the spectrum were from neutrons in",
                " the approximate energy range  0.1-4 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Capturing target of 4 g of Sm2O3 enriched to",
                " 95.48(10) at.% in 150Sm, surrounded by 3.2 mm of 10B."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "62-SM-150",
                "field_identifier": "ENR",
                "value": 0.9548
              },
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured average intensity of primary gamma",
                " transitions to low-lying levels, where neutron",
                " capture takes place in a large number of resonances.",
                " The averaging reduces the strong Porter-Thomas",
                " fluctuations in the intensities of the primary gamma",
                " rays normally associated with neutron capture in",
                " single resonances."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energies and relative intensities of primary gamma-ray",
                " transitions were calibrated using the 14N(n,gamma)15N",
                " spectrum, by adding a small amount of nitrogen gas to",
                " the He atmosphere arround the in-pile sample.",
                "Gamma-ray lines were identified by comparing with",
                " avarage resonance capture data for the other Sm",
                " isotopes."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma-ray energies corrected for the average energy of",
                " the captured neutrons."
              ]
            }
          ],
