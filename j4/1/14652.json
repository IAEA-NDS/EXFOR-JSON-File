          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "From a comparison of the mass distributions obtained",
                "from double-energy measurements with the mass",
                "distributions obtained from double-velocity",
                "time-of-flight measurements, it is possible to deduce",
                "the average number of prompt neutrons emitted as a",
                "function of the fragment mass."
              ]
            }
