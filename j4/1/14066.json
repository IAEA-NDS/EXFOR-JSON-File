          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Emission of long-range alpha particles in the",
                " spontaneous fission of Cf-252"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cf-252 sample with about 1.54E7 spontaneous fission per",
                " minutes, on  100 microg/cm2 nickel backing"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD",
                "COINC"
              ],
              "free_text": [
                " triple coincidence LF,HF,LRA",
                ".The singles counting rates in the two fission-fragment",
                "counters were approximately 1.5 x 10**5 counts/min.",
                ".The singles counting rate of the a counter was appro-",
                "ximately 500 counts/min, and the triple-coincidence",
                "rate was approximately 8.5 counts/min for an angle of",
                "90. degr. between the fission and a counters.",
                ".The 'alpha-particle' events do therefore include a",
                "small fraction of events in which other Z>=2 particles",
                "were emitted."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " The alpha-particle counter assembly consisted",
                "of two Li-drifted Si detectors of 1-cm diam placed on",
                "top of each other and connected in parallel.",
                " * The two alpha-particle lines at 6.63 MeV (Es-253)",
                "   and at 5.48 MeV (Am-24l) served as calibration",
                "   points for the alpha-particle counter."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Double fission chamber. The two fission-fragment",
                "counter assemblies consisted each of two guard-ring",
                "P-diffused solid-state detectors of 2.S-cm diam",
                " (1700 cm3 base material) connected in parallel and",
                "placed on top of each other.",
                " * The fission-fragment counters were calibrated",
                "   using the two peaks of the single-fragment energy",
                "   distribution in binary fission of Cf-252. The energy",
                "   values for the two peaks were taken from the",
                "   time-of-flight measurement of Fraser (see REL-REF)."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "R",
                "subentry_number": null,
                "author": "J.S.Fraser+",
                "reference": {
                  "code": "J,CJP,41,2080,1963",
                  "field": {
                    "reference_type": "J",
                    "reference": {
                      "code": "CJP",
                      "number": null,
                      "volume": "41",
                      "part": null,
                      "issue": null,
                      "page": "2080"
                    },
                    "date": 1963
                  }
                }
              },
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for the finite size of the detectors and the",
                "source."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental system did not differentiate between",
                "alpha particles and other Z>=2 particles emitted in",
                "the fission process. The \"alpha-particle\" events do",
                "therefore include a small fraction of events in which",
                "other Z >= 2. particles were emitted."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "More information in the article (Figs.10,11,12 and 14)",
                "function of mass ratio not coded in this compilation"
              ]
            }
          ],
