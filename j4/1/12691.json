          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mass chain yields depends on ZP and sigma Z. Since",
                "distributions are very arrow and independent yields",
                "are only known for even-even nuclei, therefore there",
                "are no mass chains that have more than two nuclei.",
                "This allowed to solve the equation analytically for",
                "A = 102, 106, 112, 136, 140, 144, 146, 154."
