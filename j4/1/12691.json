          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The measurement of gamma-rays from 2+1->0+1",
                "transitions in coincidence with fission fragment",
                "pulses proportional to their kinetic energy enables",
                "to extract independent fission yields. About 5% of",
                "the ground state yield is expected to by-pass the",
                "lowest 2+1 state."
              ]
            }
          ],
