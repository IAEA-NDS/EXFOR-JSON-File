          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutrons were detected by measuring secondary charged",
                "particles, predominantly protons using NUEX detector.",
                "Charged particles were produced by neutron scattering",
                "in a thin CH2 foil,exposed to collimated neutron beam",
                "from the exploding nuclear device. Scattered protons",
                "were detected using Faraday cup. The time dependence of",
                "the Faraday cup current is a measure of the energy",
                "spectrum of the neutrons that leak from the device."
              ]
            }
          ],
