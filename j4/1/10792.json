                " proportional chamber spectrometer. Angular acceptance",
                " of spectrometer approximately +-2 degrees.",
                " Momentum resolution about 1%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterons from elastic scattering sorted into 10-milli-",
