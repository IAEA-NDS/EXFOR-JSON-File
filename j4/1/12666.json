          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "SPIN DEPENDENCE OF SLOW NEUTRON SCATTERING BY",
                "DEUTERONS."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " ANL HEAVY WATER PILE"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "EPITHERMAL NEUTRON CROSS SECTION FOR DEUTERIUM WAS",
                "  MEASURED FOR RESONANCE NEUTRONS OF INDIUM AND",
                "  SILVER.",
                "THERMAL NEUTRONS WERE ABSORBED WITH THE HELP OF",
                "  A CADMIUM FOIL."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "BEO FILTER WAS USED TO REMOVE NEUTRONS WHOSE WAVE",
                "  LENGTH IS LESS THAN 4.5A. THE AVERAGE WAVE LENGTH",
                "  OF THE NEUTRONS WAS FOUND TO BE 5.43A."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "LONG BF3 COUNTER"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "DETETERIUM GAS IN A HEAVY WALLED GAS TUBE.THE",
                "  TEMPERATURE OF THE TUBE WAS MAINTAINED AT 77.5K."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "TWO ABSORBERS (D2O,H2O,BE) AND (BEO,O2,N2) WERE USED",
                "  IN TWO MEASUREMENTS. THE RATIO OF THE INTENSITY",
                "  TRANSMITTED BY ABSORBER 1 TO THAT TRANSMITTED BY",
                "  ABSORBER 2 WAS USED IN COMBINATION WITH CROSS",
                "  SECTIONS FOR BE(6.1B),O(4.1B),H(21.B) AND N(10.B)."
              ]
            }
          ],
