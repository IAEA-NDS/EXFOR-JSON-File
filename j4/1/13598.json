          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Helium production by 9.85-MeV neutrons in elemental",
                " iron, nickel, and copper and in 56Fe and 58,60,61Ni"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
