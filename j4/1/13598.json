          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "HE-AC"
              ],
              "free_text": [
                " Activation, followed by isotope-dilution",
                " gas mass spectrometry."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The sample package consisted of foils, thicker pure-",
                "element disks, and irregular pieces (chunks) of",
                "separated isotopes in metallic form. The foils",
                "were used for dosimetry, whereas the thicker disks and",
                "the irregular pieces were later analyzed for helium",
                "produced in the irradiation. Both natural elements and",
                "enriched isotopes, including iron, nickel, and copper",
                "and 54Fe, 56Fe, 58Ni, 60Ni, and 61Ni were in the",
                "package. The total thickness of material in the",
                "                                package was ~11 g/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " Calibrated germanium gamma-ray detectors at",
                " Argonne National Laboratory."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for:",
                ".contamination due to low-energy neutrons produced by",
                " triton breakup in the gas cell and down-scattered",
                " neutrons within the sample package"
              ]
            }
          ],
