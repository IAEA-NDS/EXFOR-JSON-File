          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The spectroscopic factors (SF) and asymptotic",
                "normalization coefficient (ANC) of the 15Cg.s. were",
                "determined from angular distributions using the",
                "distorted-wave Born approximation (DWBA) theory. Two",
                "consistent SFs were derived from the (p,d) and (d,t)",
                "reactions, which were subsequently used to deduce the",
                "14C(n,gamma)15C reaction cross section and the",
                "corresponding stellar reaction rate."
              ]
            }
          ],
