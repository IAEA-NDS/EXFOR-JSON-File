                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Reactor core with a thermal-neutron flux ~3.E+13",
                " neutrons/cm2/s at the sample position."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two samples of used (contained in graphite holders)",
                ". natural-abundance Ge02 powder sample (1.43 g Ge",
                "  fraction),",
                ". 0.189 g of metallic Ge powder enriched to 84.1% 73Ge."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "73Ge(n,gamma)74Ge transitions identified by ratio",
                " R=0.65(15) of enriched-sample intensity to natural-",
                " sample intensity.",
                "In the low-energy region, both double-escape and",
                " full-energy peaks were considered."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Disk-shaped Ge(Li) crystal with active volume",
                " of 4 cm3 used as principal gamma-ray detection device.",
                "In an auxiliary experiment two NaI detectors used with",
                " the Ge(Li) detector in pair-spectrometer mode to",
                " distinguish double-escape peaks from single-escape",
                " and full-energy peaks."
              ]
            }
          ],
