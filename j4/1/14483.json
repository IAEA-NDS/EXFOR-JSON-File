          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A new measurement of the 6Li(n,alpha)t cross section",
                "at MeV energies using a 252Cf fission chamber and 6Li",
                "scintillators"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "L.E.Kirsch",
                "M.Devlin",
                "S.M.Mosby",
                "J.A.Gomez"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAUCX",
                "1USALAS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/A,874,57,2017",
                "code_unit": [
                  {
                    "unit": "J,NIM/A,874,57,2017",
                    "doi": "10.1016/j.nima.2017.08.046",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NIM/A",
                        "number": null,
                        "volume": "874",
                        "part": null,
                        "issue": null,
                        "page": "57"
                      },
                      "date": 2017
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cs2LiYCl6:Ce scintillators (CLYC)enriched in 6-Li and",
                "6LiI(Eu) enriched in 6Li were used as active samples."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation detectors with scintillators",
                "6-LiI(Eu) 25 mm in diameter by 3 mm in thickness",
                "at a distance of 125 cm from the fission chamber",
                "and a C6-LYC with 25.4 mm diameter and 10 mm thickness",
                "were used as active targets."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PSD"
              ],
              "free_text": [
                "  Cf252 fission source was located at",
                "the electrode of the fission chamber and was used as",
                "neutron source.  Fission fragments recoil through an",
                "electrically biased gas cell and produce a timing",
                "signal. Neutron energy was determined by time of",
                "flight."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "CF252"
                ],
                "reaction": null
              },
              "free_text": [
                " Roughly 0.345 mu-g of Cf252 with 3.76 prompt",
                "neutrons per fission. The fission fragments emit total",
                "of approximately 795,000 neutrons per second."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Several corrections were made. Their systematic",
                "uncertainties are given as fractions of the calculated",
                "correction:",
                "- room scattered neutrons                  0.5%",
                "- neutron scattering in fission chamber    25%",
                "- neutron downscatter into the detector    33%",
                "- loss of high energy alphas and tritons",
                "  from detector faces                      25%"
              ]
            }
          ],
