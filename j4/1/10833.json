          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "CYLINDER APPROX 1,52-CM DIAM BY 2-CM HIGH, ENRICHED TO",
                " 99.6-PERCENT BY WEIGHT, ENCLOSED IN BRASS SLEEVES WITH",
                " 0.025-CM THICK STAINLESS STEEL ENDS."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME OF FLIGHT METHOD USED TO AVOID FALSE DETEC-",
                " TOR COUNTS DUE TO RADIOACTIVITY OF SAMPLE. TRANS-",
                " MISSION OF COLLIMATED BEAM THROUGH EIGHT SAMPLES WAS",
                " MEASURED, CARBON, SILICON, FLUORINE, AND IRON USED",
                " FOR ENERGY DETERMINATION. CARBON ALSO USED TO TEST",
                " EXPERIMENTAL PROCEDURE. ALL SAMPLES MOUNTED ON WHEEL",
                " WHICH RAPIDLY PLACED EACH SAMPLE INTO BEAM. EMPTY",
                " CYLINDER USED FOR VOID MEASUREMENTS."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "VALUES DERIVED AS EFFECTIVE CROSS SECTIONS FROM",
                " TRANSMISSION FOR 0.094388 NUCLEI/BARN AND QUOTED FOR",
                " 293+-5 DEGR.(K)."
              ]
            }
          ],
