          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Input (prior) cross sections were adjusted to reproduce",
                " the results of the mass spectrometer measurements."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections factors were calculated to convert the",
