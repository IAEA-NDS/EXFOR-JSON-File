          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mass-spectrometric measurements of 3H, 3He, and 4He",
                "produced in thermal- neutron ternary fission of 235U:",
                "evidence for short-range 4He"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "G.Kugler",
                "W.B.Clarke"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1CANMCM"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,5,551,1972",
                "code_unit": [
                  {
                    "unit": "J,PR/C,5,551,1972",
                    "doi": "10.1103/PhysRevC.5.551",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "5",
                        "part": null,
                        "issue": null,
                        "page": "551"
                      },
                      "date": 1972
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "#doi:10.1103/PhysRevC.5.551",
                "#NSR: 1972KU02"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1CANMCM"
              },
              "free_text": [
                " The McMaster reactor"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " The flux was about 1.5E+13 n/cm**2/sec"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal spectrum"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDEG",
                "MASSP"
              ],
              "free_text": [
                "  The thick catcher Pb foils, 30 mg/cm2",
                "thick, were placed together to give a total thickness",
                "of 330 mg/cm2, sufficient to stop normally incident",
                "alpha particles of 40 MeV and tritons of 14 MeV.",
                "In order to detect possible short-range components of",
                "the light particles, stacks of Pb foils were arranged",
                "in such a way that He contents could be measured for",
                "each foil individually.",
                "Helium and fission-product Kr were extracted from the",
                "Pb foils by vaporizing these in a vacuum. 3H was",
                "removed completely by the use of titanium sponge at",
                "room temperature.",
                "Calibration of the mass spectrometer for peak-height",
                "response and mass discrimination was achieved by",
                "analyzing atmospheric He prepared from aliquots of air",
                "of known volume introduced immediately after each",
                "fission He sample.",
                "The number of fissions in each sample was determined by",
                "absolute measurements of the fission 86Kr content."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-235",
                "field_identifier": "ENR",
                "value": 0.9318
              },
              "free_text": [
                " Samples of 235U weighing a few",
                "tenths of 1 mg were prepared by evaporation of weak",
                "uranyl nitrate solution onto Pb foil."
              ]
            }
          ],
