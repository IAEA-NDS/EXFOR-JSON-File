          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " A fission chamber containing two fixed",
                "semiconductor detectors (for the two fission",
                "fragments), one movable semiconductor detector (for",
                "the alpha particle).",
                "A 16-mg/cm2 Au foil was placed in front of the alpha",
                "particle detector in order to prevent the 6.1-MeV",
                "alpha particles from the alpha decay of Cf252 and",
                "fission fragments from reaching the detector."
              ]
            }
          ],
