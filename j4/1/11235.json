          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total cross section sample consisted of boron",
                "powder packed in a 2.54 cm diameter tantalum cylinder",
                "with a wall thickness of 0.014 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Plastic scintillator having a diameter of 5.08",
                "cm and a length of 2.54 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight discrimination was used. The",
                "neutrons were detected by a plastic scintillator",
                "which was placed in the collimator at a distance of",
                "92 cm from the boron sample. An identical tantalum",
                "cylinder containing no boron was used to determine",
                "the \"sample-out\" counts."
              ]
            }
          ],
