              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distribution of gamma rays from inelastic",
                " neutron scattering near threshold"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1USASRL"
              },
              "free_text": [
                " Standard pile of Savannah River"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Protons from the Stanford 3 MeV Van de Graaff",
                " accelerator bombarded tritium absorbed in a thin",
                " zirconium layer deposited on a thick silver disk"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Gamma rays following inelastic neutron",
                " scattering in the sample were detected by two",
                " 7.6 cm diam x 7.6 cm NaI(Tl) crystals."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural targets of iron and cerium. The scattering",
                " samples were hollow circular cylinders 7.6 cm",
                " outside diamx 7.6 cm high with wall thicknesses",
                " varying between 0.477 cm and 0.635 cm."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The system was calibrated using 60Co, 137Cs and 22Na",
                " sources."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made for multiple neutron scattering",
                " in the sample and for the effect of the finite sizes",
                " of the detector and sample"
              ]
            }
          ],
