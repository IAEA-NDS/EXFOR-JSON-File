                ],
                "reaction": null
              },
              "free_text": [
                " The deuterium gas target was contained at about",
                "25-cm pressure in a cell of depth 2.23 cm; deuterons",
                "passed into the cell through a 0.025-mil nickel foil."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "BaF2 crystal as a target for neutron bombardment and",
                "as a detector of the induced N-16 activity."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
