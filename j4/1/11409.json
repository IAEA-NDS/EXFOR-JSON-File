          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The relative curve was normalized to an average of",
                "three absolute measurements, performed at 4.48 MeV. Two",
                "of these determinations were made with the cylindrical",
                "barium fluoride crystal at target-crystal distances of",
                "3.0 inches and 5.0 inches. The third was made with an",
                "irregularly shaped barium fluoride crystal at a",
                "distance of about five inches."
              ]
            }
