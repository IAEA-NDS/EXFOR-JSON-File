          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron capture cross sections of 194Hg and the",
                "decays of 195Hg"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.F.Dorsett",
                "K.S.Krane"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAORU"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ARI,96,83,2015",
                "code_unit": [
                  {
                    "unit": "J,ARI,96,83,2015",
                    "doi": "10.1016/j.apradiso.2014.11.004",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "ARI",
                        "number": null,
                        "volume": "96",
                        "part": null,
                        "issue": null,
                        "page": "83"
                      },
                      "date": 2015
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USAORU"
              },
              "free_text": [
                " Experiment performed at TRIGA reactor",
                "at the Oregon State University"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "194Hg is radioactive nucleus with half-life of 520y.",
                "The 194Hg activity was produced at the Los Alamos",
                "Meson Physics Facility by 800-MeV proton spallation",
                "reactions on a Pb target and was obtained in the form",
                "of HNO3 solution after the Hg activity was separated",
                "by ion exchange. The proton irradiation was done in",
                "the early 1980s and the separation in 1996, so there",
                "should be no activities present in the sample with",
                "half-lives less than a few years. The specific",
                "activity of the 194Hg was approximately 1 mu-Ci/ml.",
                "Samples for neutron irradiation were prepared either",
                "in the liquid form or dried on aluminum foil and",
                "typically amounted to 0.1 - 0.2 mu-Ci of the 194Hg",
                "activity."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " The gamma rays were observed with high-",
                "resolution Ge detectors (efficiency 35-40% compared",
                "with NaI at 1332 keV, resolution 1.68 keV at 1332 keV)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Several locations in reactor were used for",
                " samples iradiations, these included",
                " - central core(nominal thermal and epithermal flux",
                "   respectively 1.0E+13 and 3.0E+11 n/cm2/s",
                " -Cd-lined central core(0 and 1.2E+12 n/cm2/s)",
                " -thermal column (6.4E+10 and 1.8E+8 n/cm2/s)",
                " -fast pneumatic transfer system (1.0E+13 and",
                "  3.5E+11 n/cm2/s)"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty includes contributions from",
                " branching ratios, detector efficiencies and flux",
