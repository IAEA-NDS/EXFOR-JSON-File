              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured gadolinium capture gamma-rays in liquid",
                " scintillator and normalized data using absolute",
                " differential efficiency measurements of Verbinski,",
                " et al., Nucl.Instr.Meth. 65,8 (1965).",
                "Detector efficiency relative to 252Cf spontaneous",
                " fission prompt nu(bar) = 3.733."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections made for dead times and background on all",
                " runs. Sample run corrected for multiple fissions.",
                " Final cross sectional values corrected for tank",
                " efficiency, target mass and incident neutron flux."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two series of runs made for each measurement, one with",
