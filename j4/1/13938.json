              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " GeLi. inside a NaI annulus 30 cm long with a",
                " 20 cm o.d. and a 6.5 cm bore. The relative detection",
                " efficiency was determined with a series of",
                " radioactive sources of known relative intensity and",
                " with the 411.8 keV transition in 198Hg following a",
                " timed irradiation of a weighed target of 197Au."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " used for gamma energy below 150 keV"
              ]
            }
          ],
