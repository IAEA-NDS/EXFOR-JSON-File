              },
              "free_text": [
                " The same data for spontaneous",
                "fission of 253Es as main ref., data for",
                "thermal-neutron-induced fission of 255Fm and 251Cf",
                "included in EXFOR #10516.",
                "#NSR: 1973FLZQ"
              ]
            }
          ],
          "REL-REF": [
