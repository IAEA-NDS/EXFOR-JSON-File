          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elements in natural abundance were mixed into epoxy",
                " resin,formed,cured and cut into disks ranging",
                " 221-to 238-mg weight and 0.588 mm thickness,14.33 mm",
                " diam.",
                " Contents of disk was .1464 pt powder,.2375 molybdic-",
                " acid,.3206 Zn-O2,.00991 As(2)-O3,.02769 (Al-.01Au)",
                " alloy powder,.00729 (Al-.01In) alloy powder and",
                " .2506 R313 bonding agent by weight."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Trials were performed on epoxy only disks,on several",
                " disks under the same irradiation conditions,and",
                " different densities of elements to assure uniformity",
                " of the test disks.Cd ratio 2.95+-0.07."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Na-I(Tl) scintillation spectrometer used for",
                " one of the uniformity tests"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Lithium-drift Ge spectrometers 6cm**2 area",
                " SMM depletion layer at liquid nitrogen temperatures",
                " resolution full width half-maximum of 3 keV at 100 keV",
                " and 6 keV at 1.3 MeV."
              ]
            }
          ],
