          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the 73As(n,gamma) cross section at",
                "thermal neutron energies"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.N.Kmak",
                "J.D.Despotopulos",
                "R.O.Hughes",
                "C.K.Holiski",
                "W.M.Kerlin",
                "B.N.Sammis",
                "N.D.Scielzo",
                "K.Thomas",
                "T.Wooddy"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,113,034322,2026",
                "code_unit": [
                  {
                    "unit": "J,PR/C,113,034322,2026",
                    "doi": "10.1103/649f-jvy5",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "113",
                        "part": null,
                        "issue": null,
