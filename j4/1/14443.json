          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "54-XE-124",
                "field_identifier": "ENR",
                "value": 0.996
              },
              "free_text": [
                " The xenon gas enriched in",
                "124Xe, was contained in a stainless steel sphere with",
                "inner diameter of 20 mm and wall thickness of 0.6 mm,",
                "resulting in a 124Xe mass of 2.697 g and a pressure of",
                "about 120 atm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "SCIN"
              ],
              "free_text": [
                " After irradiation, the 124Xe sphere was",
                "gamma-ray counted using a calibrated and shielded 60%",
                "high-purity germanium (HPGe) detector of well-known",
                "efficiency.Liquid scintillation detector was used as",
                "neutron flux detector"
              ]
            }
          ],
