          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The time-of-flight was measured by a 262,000",
                "channel analyzer and the energy by a 256-channel ADC.",
                "These were connected to a PDP-8 computer which stored",
                "histograms on a fixed head disk for monitoring",
                "purposes and wrote event by event on a magnetic tape."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SLA",
                "AREA",
                "MLA"
              ],
              "free_text": [
                " The data were analyzed on a SEL 810B",
                "computer and resonance areas were calculated from",
                "least-squares fits to resolution and",
                "Doppler-broadened single-level Breit-Wigner formulas",
                "and also to the multilevel Adler-Adler formalism."
              ]
            }
          ],
