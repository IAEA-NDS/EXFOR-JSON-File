              },
              "free_text": [
                " 238U filtered beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam filtered through natural uranium slug encapsulated",
                " in Al and pressed in Fe sleeves. Runs taken with U",
                " bearing Fe sleeves and Fe sleeves alone.",
                " Se, Mn and Ge were added to uranium to reduce",
                " the background of other energy neutrons.",
                "Beam purity (percentage of beam intensity due to 186",
                " eV neutrons as compared to total beam intensity)",
                " measured as a function of thickness of filter",
                " components using W sample and W in - W out technique."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
