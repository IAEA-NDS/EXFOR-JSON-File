              "free_text": [
                "Experiment performed at white neutron",
                "source of the Lujan Center, based on spallation",
                "reactions on a tungsten target using a pulsed",
                "800-MeV proton beam, accumulated in the proton",
                "storage ring."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BAF2"
              ],
              "free_text": [
                " DANCE BaF2 array consisting of 160 BaF2 crystals",
                "arranged in a 4pi geometry. Each crystal has a depth",
                "of 15 cm and a volume of  approx. 734 cm3.DANCE",
                "provides the total gamma ray calorimetry and the",
                "multiplicity information of the gamma cascade",
                "following neutron capture."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
