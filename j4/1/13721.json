          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission-Fragment Energy-Correlation Measurements for",
                " the Thermal-Neutron Fission of 233U"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " Oak Ridge Research Reactor"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutrons, cadmium ratio ~20 (flux 1E+8 neutrons",
                " per sec)"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "99.3% enriched 233U target prepared by vacuum",
                " evaporation of 1-cm diameter ~25 microg/cm2 deposit of",
                " 233U(3)O(8) onto thin carbon film covering an aperture",
                " of ~2.2-cm diameter in a Ni frame. After evaporation",
                " the target",
                " - is set at an angle of 52.5 deg to the beam axis",
                "   midway between the detectors.",
                " - measured ~40 microg/cm2 in the direction of the",
                "   detectors with energy loss of the fission fragments",
                "   in the carbon backing <2.5 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier detectors of 300",
                " mm2 area used to detect the fission fragments.",
                " Detectors mounted papallel to the beam, at distancies",
                "  of ~8.5 cm from its axis."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute energy calibration obtained by comparison",
                " with the pulse-height response of the same detectors",
                " to a thin 252Cf source measured in the same geometry",
                " as the 233U source."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Double-energy measurements of the postneutron-emission",
                " fission fragments made."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Preneutron-emission mass distributions were corrected",
                " for dispersion to account for the effects of detector",
                " resolution and neutron emission."
              ]
            }
          ],
          "ERR-ANALYS": [
