          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors in the angular-distribution data",
                " are mainly the errors propagated through:",
                "  * the statistical deviations in the scatterer-in and",
                "    scatterer-out counts;",
                "  * statistical errors in the stripping process, which",
                "    includes the subtraction of the Compton",
                "    distribution from the gamma-ray photopeaks in the",
                "    spectra;",
                "  * and the statistical errors in the long-counter",
                "    counts used for the normalization of data runs;",
                "  * the error involved in the determination of the",
                "    long-counter and the NaI(Tl) spectrometer",
                "    efficiencies;",
                "  * the neutron attenuation and the self-absorption",
                "    of gamma-rays in the scatterer itself; and",
                "  * the error caused by the Compton distribution due",
                "    to the scattering in the sample.",
                " The upper limit on the errors in the determination of",
                " absolute cross sections has been calculated to be 20%"
              ]
            }
