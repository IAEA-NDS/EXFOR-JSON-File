          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two uranium metal samples, 1.27 cm diam. and 0.132 cm",
                "thick. Isotopic impurities for:",
                ". 2.9 sample - 2 ppm 234U, 2 ppm 235U, 2 ppm 236U;",
                ". 3.0 g sample - 3 ppm 234U, 400 ppm 235U, <1 ppm 236U.",
                "Samples mounted in helium-filled through-tube."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Annihilation-pair spectrometer having energy",
                " resolution of 3.1 keV at 3.7 MeV and a large signal-",
                " to-background ratio for thermal capture."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energies and intensities of observed lines obtained by",
                " fitting spectra with a shape determined from strong",
                " isolated lines.",
                "Impurity lines identified by measuring and",
                " quantitatively comparing line intensities in spectra",
                " for two samples from different sources with different",
                " percentage of impurities."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron binding energy in 238U determined to be",
                " 4806.4(4) keV. Parities and spins of the observed",
                " levels established by using average resonance-capture",
                " spectra."
              ]
            }
          ],
          "REL-REF": [
