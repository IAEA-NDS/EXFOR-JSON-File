          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Branching ratio of 242m Am decay."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Approximately 1 mg samples of this americium were",
                "sealed in quartz capsules and irradiated in the",
                " 'rabbit' facility of the MTR."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USALRL"
              },
              "free_text": [
                " U235-H2O reactor, MTR."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Four irradiations of 24 hours and one of 48 hours were",
                "made in neutron fluxes in the range",
                " 1-2 x 10**14 neutrons/cm2/sec. The neutron fluxes",
                "were monitored using cobalt activation standards."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " The alpha counting was done in an argon-filled,",
                "ionization-type counter of known efficiency  (52%).",
                "The alpha pulse analyses were performed in an argon",
                "filled ionization chamber connected to a 50 channel",
                "differential pulse-height analyser. The mass analyses",
                "of the plutonium were performed using a 12 in. radius,",
                "60.degr. sector, magnetic mass-spectrograph."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty includes statistical errors in",
                "the alpha counting and mass analyses and the",
                "uncertainties in flux measurements and in the assumed",
                "cross-section for 242m-Am destruction."
              ]
            }
