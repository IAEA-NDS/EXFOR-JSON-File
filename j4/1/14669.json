          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " A coincidence chamber with a sample mounted",
                "on a thin film, taking advantage of the fact that the",
                "fission fragments fly apart in opposite directions.",
                "The two samples were put successively in the",
                "ionization chamber, the chamber was filled with",
                "nitrogen, and an yttrium-plus-beryllium source was",
                "put in a standard position above the chamber."
              ]
            }
          ],
