          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The fragment detectors were silicon",
                "surface-barrier detectors with sensitive areas of",
                "400 mm2. Each detector was located 2.4 cm from the",
                "source foil. The sensitive area of each fragment",
                "detector was reduced to the center 254 mm2 by the use",
                "of aluminum apertures to eliminate edge effects in the",
                "fragment spectrum."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " The x-ray detector was a 1-mm-thick NaI(Tl)",
                "scintillator mounted on an RCA 6342A phototube, covered",
                "by a 0.13-mm-thick Be window and presenting an active",
                "circular area of 3.37 cm2 at 5 cm from the source foil.",
                "The detector was restricted by a cylindrical copper",
                "collimator to view the first centimeter of fragment",
                "path."
              ]
            }
          ],
          "SAMPLE": [
