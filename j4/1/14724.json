                "R.Perry",
                "H.R.Richards",
                "R.F.Taschek",
                "C.H.Turner",
                "J.H.Williams"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "R,LA-46,1944",
                "code_unit": [
                  {
                    "unit": "R,LA-46,1944",
                    "doi": null,
                    "field": {
