          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A comparison of boron and 25 fission cross-sections",
                "for neutrons of energies from thermal to 3 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "C.L.Bailey",
                "J.M.Blair",
                "W.C.Bright",
