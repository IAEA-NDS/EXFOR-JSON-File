          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total neutron cross section for Americium-241."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USALRL"
              },
              "free_text": [
                " 100-MeV linac."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight; 250 meter flight path."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A large sample of isotopically pure (99.975%) 241Am",
                " oxide was reduced to metal. The resultant 50 gram",
                " sample was doubly encapsulated in aluminum cans",
                " (0.05-cm thick walls and 0.025-cm thick ends.)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Electron beam of the linac was pulsed with 10 nsec",
                " burst width. On striking a tantalum target cooled by",
                " heavy water,this electron beam produced a continuous",
                " energy spectrum of neutrons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation detector"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron flight time spectra were corrected for",
                " dead time losses and added together to give the",
                " transmitted spectrum for each sample.",
                "A small measured background (less than 5%) due only",
                " to cosmic ray events was subtracted from each of",
                " these spectra."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
