          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calibration of a Li-glass detector for neutron",
                " energies above 50 keV by the 1H(t,n)3He reaction."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
