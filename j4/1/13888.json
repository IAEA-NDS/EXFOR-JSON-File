              "coded_information": [
                "ACTIV",
                "INTB"
              ],
              "free_text": [
                " Five niobium foils were irradiated in",
                "the cavity fission source of the NIST reactor. Foils",
                "were counted with Ge-detectors and the analysis done",
                "with the 934-keV gamma ray. The activity of each foil",
                "was measured several times over a two week decay",
                "period."
              ]
            }
          ],
