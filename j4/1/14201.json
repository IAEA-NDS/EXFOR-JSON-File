          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectrum of photons emitted in coincidence with",
                "fission of 235U by thermal neutrons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.W.Peelle",
                "F.C.Maienschein"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAORL"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,3,373,1971",
                "code_unit": [
                  {
                    "unit": "J,PR/C,3,373,1971",
                    "doi": "10.1103/PhysRevC.3.373",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "3",
                        "part": null,
                        "issue": null,
                        "page": "373"
                      },
                      "date": 1971
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                " Experiment performed at the thermal",
                "column of the Oak Ridge graphite reactor."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched uranium samples with weight of 0.019,0.023",
                "and 0.23 g were used for gamma ray spectra",
                "measurement with single crystal, compton spectrometer",
                "and pair spectrometer, respectively"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " In the energy range 0.01 - 0.8 MeV a single",
                "crystal NaI(Tl) spectrometer with crystal diameter of",
                "4.45cm and height of 2.54 cm  was used.",
                "In the energy range 0.4-2.4 MeV a Compton spectrometer",
                "with dimensions of 0.95 cm x 2.2cm x 2.2 cm and side",
                "crystal dimensions of 3.8cm x 3.8cm x 2.54 cm was used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BPAIR"
              ],
              "free_text": [
                " In energy range 1.6-10.5 MeV a pair",
                "spectrometer with central crystal dimensions of",
                "1.9cm x 2.5cm x 2.5 cm was used.",
                "Annihilation quanta were detected in NaI(Tl) crystals",
                "with diameter of 5.1 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                "Spiral-wound fission chamber was used at",
                "higher energies and the parallel plate chamber at",
                "lower gamma ray energies"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "COINC"
              ],
              "free_text": [
                " Coincidence was required between fission",
                "chamber and gamma spectrometer and time of flight was",
                "used to discriminate neutron induced events in gamma",
                "ray spectrometer."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photon energy spectrum was obtained from measured",
                "pulse height spectrum by unfolding procedure with",
                "empirically chosen response functions."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data corrected for",
                "    - background caused by neutrons",
                "    - background from random coincidences",
                "    - counting losses"
              ]
            }
          ],
