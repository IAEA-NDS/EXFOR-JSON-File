          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " WNR white neutron source at Los Alamos was",
                " produced by 800 MeV protons from LAMPF bombarding",
                " a tungsten target 7.5 cm long and 3 cm in diameter."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target multiple foils had a diameter of 10.2 cm",
                " and were evaporated to a thickness of 200 ug/cm2 onto",
                " a stainless steel foil backing."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " The fission reaction rate was determined using",
                " a fast parallel plate ionization chamber and time-of-",
                " flight techniques."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The experiment was performed at the 20 m flight",
                " path which viewed the neutron source at a production",
                " angle of 60 degrees.",
                "The neutron beam was contained in an evacuated flight",
                " tube and passed through a 2.54 cm thick polyethylene",
                " (CH2) filter to reduce frame overlap.",
                "A permanent magnet was used to sweep out charged",
                " particles, and a system of three iron collimators",
                " gave the beam a diameter of 12.5 cm at the fission",
                " sample location.",
                "The flight paths used for these results were obtained",
                " using 12C (5 inch thick) neutron transmission",
                " resonances 2.08, 5.37 MeV and others."
              ]
            }
          ],
