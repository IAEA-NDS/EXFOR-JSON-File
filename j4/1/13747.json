          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "GSPEC"
              ],
              "free_text": [
                " Prompt gamma-gamma coincidence",
                " spectroscopy of fission fragments.",
                "Yields of correlated pairs obtained using double",
                " gating of 3-dimensional spectra."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " 32 HPGe Compton suppressed gamma detectors",
                " with 80% efficiency and ~ 2.5 keV resolution for",
                " 1332-keV gamma rays.",
                "Detector efficiency calibrated using calibration",
                " sources 56Co, 152Eu, and 154Eu."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For every combination of fission fragments the most",
                " significant lines of both light and heavy fragment",
                " have been used for gating."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for",
                ". background,",
                ". spectrometer efficiency for both gating gamma rays",
                "  and summed peak in gated spectrum."
              ]
            }
          ],
