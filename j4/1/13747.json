          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The independent yields were  obtained from measured",
                "relative yields by normalizing to known",
                "integral-independent yields. The integral-",
                "independent yields for thermal-neutron-induced fission",
                "of 241Pu for the Xe-Zr pair were used as an",
                "approximation to the integral-independent yields for",
                "242Pu SF. This normalization is based on the assumption",
                "that the thermal-neutron-induced fission of 241Pu is",
                "the same as 242Pu SF with extra energy. The sum of the",
                "relative yields for 140Xe and 138Xe was normalized to",
                "the same sum for the integral-independent yields of",
                "241Pu(n,f)."
              ]
            }
          ],
