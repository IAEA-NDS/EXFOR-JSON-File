          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "5-B-10",
                "field_identifier": "ENR",
                "value": 0.9236
              },
              "free_text": [
                " For the CFRMF irradiations low",
                "flux levels made it desirable to maximize the amount",
                "of 10B present. Enriched 10B powder, from a different",
                "lot supplied by ORNL, was packed as tightly as",
                "possible into the vanadium capsules. The mass of the",
                "10B powder (~3 mg) was determined at ORNL with an",
                "estimated 2sigma uncertainty of 0.005 mg by",
                "subtracting the weight of the empty capsule and lid",
                "from the filled capsule with the lid in place."
              ]
            }
          ],
