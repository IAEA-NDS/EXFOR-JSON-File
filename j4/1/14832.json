          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determining the 9Be(n,gamma)10Be integral cross",
                "section at fission neutron energies"
              ]
            }
          ],
          "AUTHOR": [
