          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beryllium fluoride encapsulated in an aluminum can with",
                " berylliun end windows."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sample irradiated in the through-hole facility at the",
                " reactor. De-excitation gamma rays of 20F investigated."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No description given"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma rays from 10Be used as calibration lines as well",
                " as the 1294-keV line in 41K following the beta decay",
                " of 41Ar."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Dominant feature of the high-energy end of the spectrum",
                " is a gamma ray of energy 6018 keV as a result of",
                " transition from the capture state to a level of",
                " 6018 keV which then decays. The decay from the capture",
                " state (6601 keV) to the second excited state was not",
                " observed . Tentative spin assignments for the",
                " low-lying levels of 20F was made."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected in the low-energy region of the spectrum for",
                " gamma rays of 20Ne following the beta decay of 20F."
              ]
            }
          ],
