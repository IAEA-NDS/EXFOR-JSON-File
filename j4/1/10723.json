          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fast reactor fission yields for Np-237"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USAINL"
              },
              "free_text": [
                " Experimental Breeder Reactor (EBR-II)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Oxide powder, greater than 99.9% 237Np, mixed with",
                " high purity nickel powder and weld-sealed in nickel",
                " capsules."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mass spectrometer to determine fission products."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " for gamma detection of non-fissionable spectrum",
                " monitors."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Monitors used include wires of cobalt,iron,nickel,",
                " titanium,and copper, scandium powder, U-235, U-235,",
                " and Np-237 oxide."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " Isotope dilution mass spectroscopy used.",
                " Fissionable monitors analyzed using gamma counting of",
                " 137Cs. Neutron spectra determined from monitor data",
                " using the fitting code SPECTRA. Absolute number of",
                " fissions determined using summation technique."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Quoted error is standard deviation including",
                " allowances for known systematic errors. Determined by:",
                " .approximating functions used to calculate the fission",
                "  yields,",
                " .using the linear terms of a Taylor series expansion,",
                " .calculating the standard deviation of the linear sum",
                "  of random variables."
              ]
            }
          ],
