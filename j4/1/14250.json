          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Each target was made by electroplating uranium onto",
                "a 2.29 mg/cm2 Ta foil. The 234U fission target had",
                "an areal density of 253+-8 mu-g/cm2 and the 236U",
                "target consisted of 99.68% 236U and 0.32% 234U with",
                "an areal density of 184+-5 mu-g/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                "The Silicon Telescope Array for",
                "Reaction Studies (STARS) was used to detect",
                "scattered alpha particles in coincidence with",
                "outgoing fission fragments.The STARS array consisted",
                "of three double-sided silicon strip detectors, each",
                "segmented into 48 rings and 16 sectors. Each",
                "detector had adjacent rings and sectors bussed",
                "together for a total of 24 rings and 8 sectors."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                "The particle telescope consisted of two",
                "detectors, a 152 mu-m dE and a 994 mu-m E detector."
              ]
            }
