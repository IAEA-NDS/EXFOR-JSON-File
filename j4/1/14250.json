          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SURGT"
              ],
              "free_text": [
                " Ratio of fission probabilities was determined",
                "using the Surrogate Method, based on the assumption",
                "that a direct reaction can be used to form a compound",
                "nucleus and the exit channel is independent of the",
                "entrance channel."
              ]
            }
          ],
          "CRITIQUE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Weak point of the surrogate method is the assumption,",
                "that a very similar distribution of compound states (in",
                "spin (J) x excitation energy (E) plane) is excited in",
                "the neutron capture and surrogate direct reactions.",
                " (Compiler's comment)"
              ]
            }
