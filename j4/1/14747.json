          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear spectrometry of 9.6 h 196Aum2 and the",
                "reaction of 197Au with fast neutrons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
