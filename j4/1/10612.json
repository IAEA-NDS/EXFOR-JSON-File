          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Li-glass and liquid scintillator detector measurements",
                "were used to determine specrtum shapes in 6 data sets.",
                "Each set was normalised, then they were combined using",
                "a fit in overlapping energy ranges and the combined",
                "spectrum normalised again and the separate data sets",
                "are presented."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data corrected for multiple scattering, and random,",
                " scattered and delayed gamma background."
