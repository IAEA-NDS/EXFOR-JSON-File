          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Number of Neutrons per Fission for 25 and 49"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "T.M.Snyder",
                "R.W.Williams"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
