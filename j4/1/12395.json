          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For 49 the thin foil was made by transferring",
                "quantitatively an aliquot of the total sample on to a",
                "thin platinum disk. The value thus obtained was",
                "checked by comparing the fission counts from this",
                "foil with the fission mounts from a very small 49",
                "foil which had been alpha-counted accurately; and",
                "alpha-counting a very small aliquot from the total",
                "sample (note that the ratio is independent of the",
                "specific activity of 49)."
              ]
            }
          ],
