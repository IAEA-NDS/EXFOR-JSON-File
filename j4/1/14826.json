          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cumulative fission yields of short-lived fission",
                "products from 235U and 239Pu measured by HPGe",
                "gamma-ray spectroscopy"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Kim",
                "S.J.Martoff",
                "M.Dion",
                "D.Glasgow"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/A,1059,169001,2024",
                "code_unit": [
                  {
                    "unit": "J,NIM/A,1059,169001,2024",
