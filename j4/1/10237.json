              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples deposited on 0.25-mm thick polished stainless",
                " steel or 0.13-mm thick Mo backings by electroplating",
                " or by vacuum evaporation.",
                "Below 2 MeV, deposit diameter 2.5 cm, approximate",
                " thicknesses either 150 or 500 ug/cm2.",
                "Above 3 MeV, deposit diameter 5 cm, thickness",
                " approximately 500 ug/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Low-mass double ionization chamber using",
                " methane as the counting gas.",
                " Below 2 MeV, detector 5 cm from neutron source.",
                " Above 3 MeV, detector 52 cm from neutron source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight used to reduce and measure",
                " time-independent background.",
                "Sample mass ratios for normalization measured by",
                " comparing thermal thermal fission rate of 235U",
                " samples and 238U samples containing 10% 235U.",
                "Sample masses also measured by calorimetric analysis."
              ]
            }
          ],
