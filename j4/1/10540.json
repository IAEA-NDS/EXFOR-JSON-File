          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " A 0.5 in. thick Li-6 enriched glass",
                "scintillation neutron detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " A flight path of 25.1 meters. The neutron",
                "background was determined by measuring the counting",
                "rate under Co and Mn notch filters which were in the",
                "beam for about one half of the total measuring time.",
                "The resonances in the filters conveniently bracketed",
                "the Ni-59 resonance. The background was about 3% of",
                "the blank sample counting rate in the neighborhood of",
                "the resonance. A 120 mg/cm2 B-10 filter was used to",
                "prevent the overlap of neutrons from successive",
                "neutron bursts."
              ]
            }
          ],
