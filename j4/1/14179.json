          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USALAS"
              },
              "free_text": [
                "Measurements were performed at the",
                " Manuel Lujan Jr. Neutron Scattering Center pulsed",
                "spallation neutron source at Los Alamos Neutron",
                "Science Center.The measurements were performed on",
                "flight path 2, which views a gadolinium-poisoned water",
                "moderator and has a cadmium/boron liner to reduce the",
                "number of low-energy neutrons emerging in the tail of",
                "the neutron pulse. After the moderator the neutrons are",
                "collimated to a 10-cm diameter beam inside a 4-m thick",
                "biological shield."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cylindrical sample of natural antimony had an",
                "areal density of 3.67E23 atoms/cm2 of 121Sb and",
                "2.74E23 atoms/cm2 of 123Sb. Enriched Sb sample",
                "was enriched to 99.48% in 121Sb. The natural",
                "crystalline iodine target had an areal density",
                "of 7.24E23 atoms/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The 10B-loaded liquid scintillation neutron",
                "detector was located 56.7 m from the neutron source.",
                "The 55-cell segmented detector can handle",
                "instantaneous counting rates up to 9 MHz per cell.",
                "The neutron mean capture time in the detector",
                "was 416+-5 ns"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Neutron energy was determined by time-of-flight"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Transmission method was used."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS",
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutrons pass through a",
                "polarized-proton spin filter where neutrons with one",
                "of the two helicity states are preferentially scattered",
                "out of the beam, leaving a beam of longitudinally",
                "polarized neutrons with polarization of 70%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "MLA"
              ],
              "free_text": [
                " A multilevel, multichannel formalism of Reich",
                "and Moore was used for the neutron cross sections,",
                "which were convoluted with the TOF resolution function"
              ]
            }
          ],
