          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-section measurements of neutron-induced",
                "reactions on GaAs using monoenergetic beams from 7.5",
                "to 15 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
