          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " The monoenergetic neutron beam was produced via",
                "the 2H(d,n)3He reaction, known for its high neutron",
                "yield in the energy regime of the measurements.",
                "Deuterium gas was contained in a 3-cm-long",
                "cylindrical cell, at a pressure of around 3 atm. The",
                "cell was sealed from the beam line vacuum by a",
                "0.635-mm, thin Havar foil. The pressure in the gas",
                "cell and the energy losses of the deuteron beam in",
                "the Havar foil contributed to the energy spread of",
                "the neutron beam."
              ]
            }
          ],
