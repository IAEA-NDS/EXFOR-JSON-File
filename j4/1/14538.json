          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission yield measurements from highly enriched",
                "uranium irradiated inside a boron carbide capsule"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "L.A.Metz",
