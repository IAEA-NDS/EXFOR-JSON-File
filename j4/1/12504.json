          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between 239Pu (49) fissions in an",
                "ionization chamber and proton recoils in a paraffin",
                "lined proportional counter caused by the neutrons",
                "given off during fission are compared to similar",
                "coincidence when 235U (25) is used in an identical",
                "geometry. To produce fissions, the chamber was placed",
                "in the 11'x7'x6'8\" graphite block about 4' back from",
                "the face exposed to the cyclotron neutrons."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Weighted mean of nubar239Pu/nubar235U for all data was",
                "adopted."
              ]
            }
          ],
