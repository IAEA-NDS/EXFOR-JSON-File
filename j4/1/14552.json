          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The uranium was irradiated as U3O8 powder in 0.2, 0.5",
                "and 1.0 gramme quantities. National Bureau of Standards",
                "U3O8 and U308 prepared from commercial uranyl nitrate",
                "hexahydrate  were  used.  The commercial uranium was",
                "purified by dissolution in nitric acid followed by an",
                "ether extraction and subsequent ignition to U308."
              ]
            }
          ],
