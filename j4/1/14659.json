          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pure water target was a part of active Cherenkov",
                "detector volume"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "CEREN"
              ],
              "free_text": [
                " Pure water target was contained within a 5-cm-",
                "thick acrylic vessel with a radius of 6.0 m, which is",
                "submerged in water. Surrounding the vessel, a",
                "geodesic structure with a radius of 8.9 m supports",
                "more than 9300 Hamamatsu R1408 photomultiplier tubes",
                "that face inward. Cherenkov light produced by 4.4 MeV",
                "gammas (emmited in approx. 60% of neutron producing",
                "reactions alpha+9Be -> 12C +n ) and 2.2 MeV produced",
                "in p+n -> 2H were used in analysis. Trigger for the",
                "event analysis was set to coincident pulses from",
                "7 PMTs. Detector is located at SNOLAB, Creighton Mine,",
                "Sudbury, 2.0 km underground."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Delayed coincidence between 4.4 MeV and 2.2",
                "MeV gamma rays was analysed"
              ]
            }
          ],
