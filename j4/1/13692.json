          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the 8Li(n,gamma)9Li cross section at",
                " astrophysical energies by reverse kinematics"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAMSU"
              },
              "free_text": [
                " National Superconducting Cyclotron",
                " Laboratory (NSCL)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Virtual gamma field in the U or Pb target",
                " generated by beam of 9Li produced by A1200",
                " Spectrograph"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopically pure 9Li beam produced by a fragmentation",
                " reaction of 60 MeV/nucleon 15N on a thick 9Be target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TOF method with 5.07-m fligh path used to",
                " determine energy of neutrons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Si-CsI fragment telescope used to detect",
                " 8Li fragments.",
                " Telescope consisted of 3 individual detectors:",
                " . Si-strip detector for DE and timing information;",
                " . Si PIN diode detector for additional DE information",
                " . CsI stopping detector for residual energy",
                "   information."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Neutron Wall Array viewed by photomultiplier",
                " tubes used to detect neutrons.",
                " Wall Array consists of 25 glass cells filled with",
                " liquid scintillator NE-213 having the property of",
                " pulse-shape discrimination and distinguishing between",
                " neutron and gamma ray events.",
                "Both detectors placed at zero degrees with respect to",
                " the beam and working in coincidence."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Si detectors calibrated with both a 228Th alpha-",
                " particle source and a series of calibration beams."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DTBAL"
              ],
              "free_text": [
                "",
                "Photon energy determined as difference between the",
                " neutron separation energy 4.05 MeV and the decay",
                " energy measured by complete kinematic analysis of the",
                " neutron and 8Li fragment.",
                "Upper limit of the 9Li Coulomb dissociation and of the",
                " photodisintegration cross section are determined from",
                " measured total 9Li dissociation without subtracting",
                " the nuclear dissociation."
              ]
            }
          ],
