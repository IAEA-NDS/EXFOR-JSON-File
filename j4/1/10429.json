          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma-ray spectra and level structure of 55Cr from",
                " thermal neutron capture in 54Cr"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "1USALRL"
              },
              "free_text": [
                " Reactor filtering out fast-neutron and",
                " gamma-ray components with liquid-nitrogen-cooled",
                " quartz and bismuth crystals. Net thermal flux was",
                " 5E+7 neutrons/cm**2 sec."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Maxwellian spectrum."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1.9 grams of 54Cr as Cr2O3 enriched to 94.1% 54Cr.",
                " Sample is encapsulated in deuterated polyethylene",
                " and centered in a 6Li2H lined beam pipe."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "  Sample flanked by separate Ge(Li)-NaI(Tl)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " spectrometers optimized for high-and low-energy",
                "        gammas respectively."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma-ray energies and intensities obtained by",
                "fitting a Gaussian with an exponential tail on the low",
                "energy side."
              ]
            }
          ],
