          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production Cross Sections for (n,t) Reactions in Some",
                " Medium and Heavy Mass Nuclei at 14.6 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1USASMU"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " 300-kV magnetically analysed deuterons on an",
                " air-cooled tritium target.",
                "The neutron flux density at the position of the sample",
                " was generally about 10E+10/sec-cm**2"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples were high purity powder in thin wall",
                " cylindrical containers placed in front of and near the",
                " tritium target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The activation technique and high-resolution",
                " gamma-ray spectroscopy were used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " The activation spectra were measured by a",
                " coaxial germanium-lithium detector and recorded on",
                " a 4096 channel analyzer. The resolution of the system",
                " was 2.6 keV at the 1332.5 keV 60Co line."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections were determined relative to an internal",
                " monitor and calculated from the areas of the respectiv",
                " photo peaks."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "All monitor cross sections are chosen from Handbook",
                " on Nuclear Activation Cross Section, Technical Report",
                " series no.156, page 87, Vienna (1974)."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made for decay gamma-ray branching,",
                " internal conversion,detector efficiency, self-",
                " absorption and isotope abundance."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty includes error of photo peak",
                " area, cross section of the monitor, and relative",
                " photo-peak efficiency of the detector."
              ]
            }
          ],
