          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SHAPE"
              ],
              "free_text": [
                " Resonance parameters were determined by",
                "analysis of the data summed over both helicity",
                "states. The shape analysis was performed with the",
                "code FITXS, which was written specifically to",
                "analyze the TOF spectra measured by the TRIPLE",
                "Collaboration. From the recorded indium data, 140",
                "capture gamma-ray spectra corresponding to the TOF",
                "intervals of indium resonances or background regions",
                "were sorted. The orbital angular momentum l was",
                "assigned by two indirect methods: one uses a Bayesian",
                "probabilistic argument and the other uses the decay",
                "properties of primary gamma rays. The first method",
                "applies Bayes' theorem to the Porter-Thomas",
                "distributions of neutron widths for s- and p-wave",
                "resonances."
              ]
            }
          ],
