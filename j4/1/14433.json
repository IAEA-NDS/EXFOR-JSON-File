          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SIBAR"
              ],
              "free_text": [
                " Four two-element detector",
                "telescopes with angular acceptance between 9 and 13",
                "degrees. The front element of each telescope was a",
                "gas proportional counter filled with 25 Torr of",
                "Xenon. The stopping detectors were 450 mm2 silicon",
                "detectors (500 microm depth) capable of stopping",
                "alpha-particles up to 33 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Multi-element ionization chamber containing",
                "steel foils coated with films of U-235 and U-238 served",
                "as beam monitor."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Determination of neutron energies was performed",
                "via TOF measurements between microbursts (~250 ps",
                "wide with a 1.8 microsec interval) of the LAMPF 800",
                "MeV primary proton beam on the spallation target and",
                "hits in our detectors."
              ]
            }
          ],
