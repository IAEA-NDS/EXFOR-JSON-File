            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was isotopically enriched 56Fe with areal",
                "density of 3.23 mg/cm2. It was large enough to cover",
                "entire 5 cm x 5 cm beam spot."
              ]
            }
          ],
