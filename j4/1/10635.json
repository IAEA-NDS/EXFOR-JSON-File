          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                "",
                "Ten-section large fission chamber has first 8 Al plates",
                " coated with 238U (less than 2-ppm impurities) and",
                " last 2 plates coated with 235U (less than 0.12%",
                " impurities). Only the counting rates from the last",
                " 238U plate and first 235U plate were utilized.",
                "Three-section small fission chamber was uesd for",
                " normalization. The inner section is mixture of 238U",
                " and 235U sandwiched between sections of high purity",
                " 235U coatings."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Chamber at 40 m station of flight path #6.",
                "Pulse width was 5 ns and repetition rate was",
                " 800 pulse/sec.",
                "Background minimized by collimation of beam and cadmium",
                " shield surrounding chamber."
              ]
            }
          ],
