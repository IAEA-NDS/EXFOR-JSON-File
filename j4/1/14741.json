              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The chamber was irradiated with slow neutrons",
                "from the cyclotron. A coincidence circuit registered",
                "events occurring simultaneously on each side of the",
                "chamber. Alpha particles are emitted in coincidence",
                " (within 5*10**-6 sec.) with fission in U235 and Pu239."
              ]
            }
