          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections for decay of cobalt standard were less",
                "than 10%, the self-shielding of cobalt wire was",
                "estimated at 2.3%, contribution of activation by",
                "epithermal neutrons was a compensating factor from",
                "about 1% to to about 2.8%."
              ]
            }
          ],
