          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mass spectrometric studies of pile poisons and their",
                "yields in the fission of uranium-233, uranium-235, and",
                "plutonium-239"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
