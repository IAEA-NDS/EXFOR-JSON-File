          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental study of the 11,12B(n,gamma) reactions",
                "and their influence on r-process nucleosynthesis of",
                "light elements"
              ]
            }
          ],
          "AUTHOR": [
