              "pointer": "",
              "coded_information": null,
              "free_text": [
                "ERRORS DUE TO-",
                " -STATISTICAL ERROR IN NUMBER OF LI-6 PARTICLES",
                "   DETECTED",
                " -ERROR IN PRIMARY(3+) DATA CORRECTION",
                " -ERROR IN REACTION ENERGY ADDED IN QUADRATURE WITH",
                "  TOTAL ERROR OF ELASTIC CROSS SECTIONS."
