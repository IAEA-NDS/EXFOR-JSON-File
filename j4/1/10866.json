          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "71 MICRO-GMS/CM**2 TITANIUM TRITIDE ON NICKEL BACKING",
                " 1.4 MILLI-GMS/CM**2 THICK."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " TWO SILICON SURFACE BARRIER DETECTORS WITH",
                " THICKNESSES OF 16.7(HIGH ENERGY LI-6 IONS) AND 15.3",
                " (LOW ENERGY LI-6 IONS) MICRO-METERS. SIX POSITION",
                " APERTURE WHEEL USED.",
                "COLLIMATED ENERGY-MASS IDENTIFIER DETECTOR FOR ELASTIC",
                " MONITOR TRITONS"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "TRITON YIELD FROM ALPHAS-ON-TRITIUM REACTION. MEASURED",
                " AT 15 AND 30-DEGREES, USED TO CREATE ABSOLUTE SCALE",
                " FOR LI-6 REACTION."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "DIPOLE MAGNET USED TO SEPERATE LI-6 IONS FROM BEAM",
                " ALPHAS. ALPHA BACKGROUND IN DETECTOR REDUCED BY THICK",
                " NI TARGET BACKING, CHOICE OF MATERIAL FOR APERTURE",
                " OF MAGNET ASSEMBLY, CAREFULL BEAM FOCUSING AND",
                " COLLIMATOR SIZING, HIGH VACUUM, AND PROPER BAFFLING",
                " OF VACUUM BOX. MONITOR REACTION MEASURED SEPERATELY IN",
                " ORDER TO ESTABLISH ABSOLUTE SCALE. MONITOR DETECTORS",
                " AT 15 AND 30-DEG MEASURED SCATTERED TRITONS DURING THE",
                " RUN. ALL RELEVANT GEOMETRICAL QUANTITES ACCURATELY",
                " DETERMINED."
              ]
            }
          ],
          "ERR-ANALYS": [
