          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " 6Li glass scintillator, approximately 2%",
                " natural Li by weight.",
                "Thickness was 0.67 mm, two 5-inch phototubes placed at",
                " either end."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " 2.54-cm thick parallel plate ionization chamber",
                " containing enriched BF3 at a partial pressure of",
                " 18.75 cm Hg."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Background measured with Au and Co foils"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cd and Pb foils used to reduce neutron overlap and",
                " gamma flash. Only central portion of Li detector used",
                " so as to minimize neutron scattering from phototubes",
                " and surrounding structures."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " 20 m station used"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction made for",
                " - Self shielding in Li detector (<0.2%)",
                " - Neutron absorption in 10B ionization chamber",
                "    (0.5% AT 1 eV)",
                " - Flux attenuation in 10B ionization chamber (uses",
                "    ENDF/B-V total cross sections)",
                " - Backgrounds from reactions caused by out-of-time",
                "    neutrons and gamma interactions with detectors,",
                "    5% at 5 ev and 20% at 130 eV for 6Li,",
                "    2% at 5 ev and 5% at 130 eV for 10B.",
                " - Deadtime"
              ]
            }
          ],
