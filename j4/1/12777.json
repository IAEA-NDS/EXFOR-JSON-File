              "coded_information": null,
              "free_text": [
                "Polarized neutron capture on 3He at E(n) = 9.0 MeV"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "All of the data were taken with a 5.1-cm long",
                "deuterium-filled gas cell having a pressure of 620 kPa",
                " (absolute). This cell produced an energy spread of",
                "about 770 keV for the 9.0 MeV neutrons."
              ]
            }
          ],
