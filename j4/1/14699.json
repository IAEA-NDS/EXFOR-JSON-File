          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A sheet of Cd 0.5 mm thick reduces the neutron counts",
                "to 8.4 percent of the total; 5.7 percent are",
                "absorbable in heavy layers of boron. Assuming the 1/v",
                "law for the absorption of neutrons in boron the",
                "absorption limit in Cd is found to be 0.41 eV. With",
                "the aid of data from the wheel experiment of Rasetti",
                "and collaborators the resonance energy and the",
                "half-width are calculated."
              ]
            }
          ],
