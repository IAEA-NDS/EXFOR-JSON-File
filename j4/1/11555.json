          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The scattering samples were liquid argon, contained in",
                "cylindrical polyethylene containers 2.54 cm in diam.",
                "and 5.1 cm in length. The polyethylene containers were",
                "lowered into a cylindrical hole cut in a piece of",
                "Styrofoam filled with liquid nitrogen."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
