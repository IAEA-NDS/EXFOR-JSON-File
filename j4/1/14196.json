          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-235",
                "field_identifier": "ENR",
                "value": 0.998
              },
              "free_text": [
                "",
                "For radiochemical measurements enriched 235U metal",
                " (99.8 at.%) was cast into ingots in a graphite mold,",
                "hot rolled into plates 2 or 62.5 mil thick, and",
                "1-cm-diam disks were punched from the annealed plates.",
                "For on-line measurements the 235U target (200 to",
                "1000 mu-g) was deposited on a thick platinum backing"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " For off-line measurement the tritium gas was",
                "separated from uranium sample by tritium separation",
                "apparatus. Separated hydrogen gas was counted in a",
                "low level internal gas proportional counter and",
                "tritium yield was determined"
              ]
            }
          ],
