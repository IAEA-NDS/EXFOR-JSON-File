          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 50 cm3, 1-cm-thick EG&G Ortec solid state",
                "detector."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
