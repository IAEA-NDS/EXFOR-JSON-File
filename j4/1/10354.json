              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Half-life of 178(m2)Hf and its neutron capture",
                " production"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
