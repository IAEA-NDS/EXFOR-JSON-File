          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                "Two Micron Semiconductor S2 double-sided",
                "silicon detectors stacked together, referred to as",
                "the dE (140 mu-m) and E (1000 mu-m) detectors, were",
                "used to identify the light ions."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Array of six circular L-series detectors, each",
                "5000 mu-m thick with an active area of 200 mm2 and",
                "pointing concentrically toward the target at 45deg,",
                "was placed behind the E detector to stop protons up",
                "to 30 MeV in energy."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Upstream from the target, another 140 mu-m thick",
                "S2 silicon detector was placed to detect fission",
                "fragments. The S2 detectors were instrumented into 8",
                "sector channels and 24 ring channels for the",
                "electronics readout."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
