          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SURGT"
              ],
              "free_text": [
                " Cross section determined by surrogate ratio",
                "method. Reactions 236U (3He,p) and 238U(3He,p)",
                "with the reference cross section given by the",
                "well-known 237Np(n,f) cross section. The ratio of",
                "observed fission reactions resulting from the two",
                "formed compound nuclei, and 240Np,was multiplied 238Np",
                "by the directly measured 237Np(n,f) cross section",
                "to determine the 239Np(n,f) cross section."
              ]
            }
          ],
