          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Multiscale spectrum fitted to a + b x exp(-lambda T)",
                "where a is normalized fission rate for 235-U-g in the",
                "        deposit at long times after separation,",
                "        including background and possible fissions",
                "        from plutonium",
                "      B is related to ratio of the isomeric to the",
                "        ground state cross sections",
                "      T is the time elapsed since the end of the",
                "        grow-in period during chemical separation",
                " lambda is the isomeric state decay constant, 0.02656",
                "        minutes(-1)."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction made for fissions due to any plutonium",
                " found in the deposit by later alpha counting the disk."
              ]
            }
          ],
