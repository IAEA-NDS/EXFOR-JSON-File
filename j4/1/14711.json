          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Validation of neutron-induced reactions on natural",
                "carbon using an active target at neutron energies up",
                "to 22 MeV at LANSCE"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
