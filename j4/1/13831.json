          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-Energy Gamma Spectra Resulting from Neutron",
                " Capture in Hafnium Isotopes."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " In-pile facility at the Argonne CP-5 research",
                " reactor."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Core of CP-5 research reactor with a thermal",
                " neutron flux ~3E+13 n/(cm2.s) at the sample position."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor spectrum."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data collected as a series of runs of relatively short",
                " duration (~3h) to avoid drifts. Collimators reduced",
                " ratio of the 'aluminum' background to hafnium capture",
                " lines to 10-20%.",
                "Isotopic identification of gamma lines based on the",
                " variation in their intensities from sample to sample."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Lithium-drifted germanium detector with a volume",
                " of 1.0 cc, installed in a vacuum chamber and cooled to",
                " liquid nitrogen temperature; resolution width of",
                " system ~6 keV at 7.7 MeV and ~3 keV at 1 MeV."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "72-HF-178(N,G)72-HF-179,,SPC",
