                "TO A SURFACE DENSITY OF 1+-.3 GRAM/M."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A .25PERCENT UNCERTAINTY IS APPLIED TO RATIOS DUE TO",
                "DISCREPANT RESULTS FROM USING 2 CF252 FISSION CHAMBERS",
