          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Polyester track detector."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-235",
                "field_identifier": "ENR",
                "value": 0.9986
              },
              "free_text": [
                " A 235U target 99.86 percent",
                " (isotopically pure) with a deposit thickness of 0.937",
                "mg/cm2 backed by a 0.127-mm-thick platinum foil."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "CHSEP"
              ],
              "free_text": [
                " After the exposure, the polyester film",
                "detector was etched in a solution of KOH. Fragment",
                "tracks for angles of 1, 15, 30, 60, 75 and 90 were",
                "counted. The experiments were carried out using",
                "average neutron energies of 265, 770, and 964 keV,",
                "corresponding to the median energies of",
                "sodium-deuterium, lanthan-beryllium, and",
                "sodium-beryllium photoneutron sources."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data were corrected for: 1. solid angle; 2.",
                "thermal-neutron fission; 3. For low-energy neutrons",
                "in the 7Li(p,n)7Be reaction; 4. scattering;"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "With s-wave neutron capture, the fission",
                "angular distribution is expected to be isotropic.",
                "Small deviations from isotropic yield were observed",
                "in the thermal-neutron data. After normalization by",
                "the thermal-neutron run, the corrected data for each",
                "neutron energy were least-square fitted with the",
                "expression W(theta) = 1 + A2 x cos2 theta, where A2 is",
                " defined as the anisotropy factor."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The estimated error values are based on the",
                "uncertainties in the corrections as well as from",
                "counting statistics and an assumed possible",
                "systematic error."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " 1.5 % for all corrections."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " 1.0 % systematic error in the normal counting",
                "process."
              ]
            }
          ],
