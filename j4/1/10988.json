          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distribution of fission fragments from fast",
                "fission of U-235"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
