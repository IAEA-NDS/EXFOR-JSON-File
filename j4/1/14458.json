          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "From the measured cadmium ratio and two recent",
                "thermal cross section measurements averaged at",
                "212+-12 barns the resonance integral was calculated.",
                "The Atlas of Neutron Resonances 2006 thermal cross",
                "section value of 206+-6 barns would produce a",
                "slightly different resonance integral."
              ]
            }
          ],
