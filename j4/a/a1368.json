          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron yield are determined with the modified long",
                "counter in position behind the slow counter, and are",
                "not corrected for the variation of counter sensitivity",
                "with neutron energy."
              ]
            }
