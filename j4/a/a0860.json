          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": "4RUSITE"
              },
              "free_text": [
                " Measurements were performed on the",
                "internal beam of the ITEP synchrophasotron operating",
                "in the mode of a storage ring of the TVA ITEP",
                "heavy-ion facility within the FRAGM experiment. Carbon",
                "ions C+4 were accelerated in the TVA booster to",
                "301.6MeV/nucleon, which corresponded to their momentum",
                "of 0.8079 GeV/s/nucleon. They were then completely",
                "stripped in a thin target and accumulated in the ring",
                "of the U-10 synchrotron,operating in the stretcher mode"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A scintillation hodoscope with 20 and 8 counters",
                " 20x1x1 cm in size -for measuring the beam.",
                "The scintillators of all counters were viewed by two",
                "FEU-143 or FEu-30 photomultipliers."
              ]
            }
