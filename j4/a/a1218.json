          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of a 5 cm long, 1.8 cm diam,",
                "gold-lined stainless steel cylinder. The thickness of",
                "the stainless was 0.75 mm, and that of the gold 0.25 mm",
                "enriched deuterium gas was used through,at a",
                "pressure of about 500 mm Hg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " The Stanford 24 cm * 24 cm"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made for gamma-ray absorption in the",
                "wall of the gas cell and in paraffin and other",
                "shielding materials between cell and crystal, as well",
                "as for overall detector efficiency."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total error. Absolute cross sections are",
                " uncertain to 10-15%, shown in several points on fig."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
