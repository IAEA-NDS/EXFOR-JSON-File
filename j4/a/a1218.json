            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainty of detector efficiency and",
                "line-shape extrapolation."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-4",
                "minimum_value": 2.0,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainty of gas pressure (2-5%)."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-5",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty in the centering of the target.",
                "Improper shapes for the gamma(0) or gamma(1) decay",
                "spectra due to small inaccuracies in either the theory",
                "or the detector response function could also lead to",
                "significant systematic error in the relative size",
                "of the gamma(1) cross section.",
                "Cross sections at 90 degr. were measured for",
                "excitation energies in 5Li from 17.1 to 26.5 MeV."
              ]
            }
          ],
