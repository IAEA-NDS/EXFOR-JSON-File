          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experiments were performed using a 34 MeV/A primary",
                "beam of 11B delivered by the JINR U-400M cyclotron. The",
                "secondary beams of 6He and 8He nuclei produced by the",
                "double achromatic magnetic separator ACCULINNA."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The spectrometer ACCULINNA was used to",
                "separate 8He from all other reaction products."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " A telescope consisting of one 300 um",
                "and 1 mm thick annular Si detectors. The active areas",
                "of these detectors had the outer and inner diameters",
                "of 82 mm and 32 mm, respectively. The first, 300 um",
                "detector, was segmented in 16 rings on one side and",
                "16 sectors on the other side and the second, 1 mm",
                "detector, was not segmented. A veto detector was",
                "installed upstream of the proton telescope to alert",
                "to the signals generated by the beam halo- for",
                "protons. A zero-angle Si detector telescope for the",
                "6He and 8He included six squared (60*60 mm) 1 mm thick",
                "detectors. The first two detectors of the telescope",
                "were segmented in 16 strips each in the vertical and",
                "horizontal directions. All other detectors in the",
                "telescope were segmented in 4 strips in the 8He run",
                "and in 16 strips in the 6He run. An array of 48",
                "detector modules of the neutron time of flight",
                "spectrometer DEMON was installed in the forward",
                "direction at a distance of 3.1 m from the target. In",
                "events where triple p-6He-n coincidences were",
                "detected the complete reaction kinematics was",
                "reconstructed."
              ]
            }
          ],
