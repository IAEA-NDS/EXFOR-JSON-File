          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Rhodium foils of thickness 1.24 mg/cm2 each. The purity",
                "of the material was better than 99.9%.",
                "Aluminium degraders of thickness 6.25 mg/cm2 were",
                "used for degrading the alpha-particle beam incident",
                "on individual foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A high resolution (FWHM 2 keV at 1.33 MeV)",
                "100 cm3 ORTEC Ge(Li) detector, coupled with a",
                "precalibrated 4096 channel CARBERRA-88 analyzer and",
                "associated electronics. 152Eu standard gamma source of",
                "known strength was used for energy and efficiency",
                "calibration, by keeping it at target position."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "STTA"
              ],
              "free_text": [
                " Six rhodium foils were used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation and cooling times are unknown"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Number of measurements and its duration are",
                "unknown."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measured excitation functions for the reactions",
                "are the weighted average of the cross sections values",
                "corresponding to various identified gamma-rays, weak",
                "gamma-rays, as well as gamma-rays having energies",
                "higher than 1.5 MeV, are not taken into consideration",
                "because of their low detection efficiencies."
              ]
            }
          ],
