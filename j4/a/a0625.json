              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The absolute error on the cross section is",
                "estimated to be 10% and arises from the precision of",
                "the estimation of the solid angles, the integration of",
                "the incident current, the measurement of the retained",
                "dose in the implanted standard and the statistical",
                "error from measuring the area of each peak."
              ]
            }
          ],
