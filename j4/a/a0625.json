          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements of the N-14(He3,p)O-16",
                "and N-14(He3,alpha)N-13 reactions between 1.6",
                "and 2.8 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
