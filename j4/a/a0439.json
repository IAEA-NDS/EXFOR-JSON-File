                      },
                      "date": 1993
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Li Wenxin",
                "Sun Tongyu",
                "Chih Tahai",
                "Li Yunsheng",
                "Zheng Yuming",
