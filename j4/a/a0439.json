          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target fragments from the interaction of 93-Nb and",
                "181-Ta with 47 MeV/nucleon 12-C ions"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,48,628,1993",
                "code_unit": [
                  {
                    "unit": "J,PR/C,48,628,1993",
                    "doi": "10.1103/PhysRevC.48.628",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
