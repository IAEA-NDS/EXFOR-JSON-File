          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The sum of thirty gamma-ray spectra collected between",
                "E(alpha) =3.82 MeV and 5.92 MeV revealed only one",
                "strong ground-state transition in Ti-46, namely the",
                "889 keV 1-0 transition. The sum of all other",
                "ground-state yields was estimated to be less than 2%",
                "of the 889 keV yield. However, in many individual",
                "spectra gamma-rays from resonance states direct to",
                "the ground states were observed. The strength of these",
                "R-0 transitions varied greatly from energy to energy",
                "and the total gamma-ray yield at each energy was",
                "obtained from the sum of the 1-0 and R-0 yields."
              ]
            }
          ],
