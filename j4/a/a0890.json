          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The target consisted of the enriched isotope Am-243",
                " (99.9%) deposited as AmO(2) onto 1.5-mum Ti foils to",
                "a thickness of 0.36 mg/cm**2 of Am-243Am, the foils",
                "were covered by a C-layer 35 mug/cm**2. Each of six",
                "targets had an area of 5.3 cm**2 in the shape of an",
                "arc segment with an angular extension of 60 degree and",
                "an average radius of 60 mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                "  a 4-cm*12-cm semiconductor detector array with",
                "12 vertical position-sensitive strips surrounded by",
                "eight 4-cm*4-cm side detectors without position",
                "sensitivity, forming a box open to the front (beam)",
                "side. The position-averaged detection efficiency for",
                "full-energy alpha-particles emitted in the decays of",
                "implanted nuclei was 87%."
              ]
            }
          ],
