          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Zinc and tungsten foil of high purity were cut and",
                "washed very carefully and placed between copper or",
                "aluminium monitoring foils for the irradiations.",
                "In the reactions with chromium,a chemical compound",
                "between copper and potassium chromate was prepared.",
                "The powder was suspended in water,and then deposited",
                "onto thin aluminium foils, which were folded over",
                "after drying."
              ]
            }
          ],
