          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of about 1 mg/cm2 thickness were prepared by",
                "vacuum evaporation of natural rubidium chloride on",
                "7 mg/cm2 aluminium backing. The target thickness was",
                "measured by weighting the foils before and after",
                "deposition of the target material. The target assembly",
                "consisted of a number of rubidium targets sandwiched",
                "between aluminium catcher and degrader foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
