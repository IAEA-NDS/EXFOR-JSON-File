                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The duration of each irradiation was about",
                "3 hours and the beam current was around 300 nanoampere."
              ]
            }
          ],
