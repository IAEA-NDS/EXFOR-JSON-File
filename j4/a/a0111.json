          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- By Authors - In the case of Y-87, the half lives of",
                "the isomeric state and ground state are comparable.",
                "Therefore their yields were measured independently and",
                "from the sum of the yields of Y-87-g and Y-87-m, the",
                "production cross section of Y-87 was determined."
              ]
            }
