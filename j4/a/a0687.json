          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 232-Th target was either a 1.8 mg/cm2 rolled",
                "thorium foil or a 250 mug/cm2 thin layer of thorium,",
                "deposited on a 600 mug/cm2 aluminum foil.",
                "The 235-U target was of thickness 300-400 mug/cm2,",
                "electrodeposited on a 600 mug/cm2 aluminum  foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " E-delta-E silicon surface barrier",
                "telescopes. Delta-E detector are fully depleted silicon",
                "detectors having an active area of 70-100 mm**2 and of",
                "thickness 10-12 microns.  The E-detectors are either",
                "fully depleted or partially depleted silicon detectors",
                "having an active area of 150 mm2 and a thickness of 300",
                "microns."
