          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacks of self-supporting niobium foils of thickness",
                "11. mu-g/cm**2 each and purity greater than 99.99%",
                "were interspersed with suitable aluminium degraders, to",
                "degrade  the  alpha-particle energies from 45 MeV.  At",
                "the front of the stack, an aluminium foil of  thickness",
                "20. mu-g/cm**2 was used as a flux monitor."
              ]
            }
          ],
