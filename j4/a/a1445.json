          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Negative ion beams of 6Li and 7Li were obtained from",
                "the exchange canal of a negative helium ion source.",
                "Hydrogen gas was used in the duoplasmatron source to",
                "provide the ionizing beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "CH4. At a target pressure of 3.0 Torr, the gas",
                "consumption was about 251 of CH4, per hour (at STP),",
                "with over 98% of this flowing through the Roots pump.",
                "Lithium beams and a CH4 gas target at equivalent",
                "proton energies"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three movable counters and a fixed counter at 90 degr.",
                "were used in the experiment.",
                "Foils of thickness 0.9 and 3.4 mg/cm2 were used in the",
                "forward counter and 0.22 and 1.4 mg/cm2 in the backward",
                "counter, for 6Li and 7Li, respectively."
              ]
            }
          ],
