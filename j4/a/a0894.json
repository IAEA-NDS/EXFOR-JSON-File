          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were prepared by evaporation of lead or",
                "bismuth deposited in layers of 450 mug/cm**2 on carbon",
                "backing foils of 40 mug/cm**2. The target layers were",
                "then covered by evaporation of a 10 mug/cm**2 thick",
                "carbon layer to protect the targets from sputtering and",
                "to enhance radiative cooling.",
                "The total thickness of these carbon foils amounted",
                "to 190 mug/cm**2."
              ]
            }
          ],
          "FACILITY": [
