          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were made of Gd+F(3) evaporated on a thin",
                "carbon foil. Three different targets, with 68, 47 and",
                "20 um/cm2 thicknesses were employed. Their energy",
                "thicknesses were 8.3, 5.6, 2.4 keV for 872-keV",
                "protons and 6.5, 4.4, 1.9 keV for 1370-keV protons,",
                "respectively. The three targets had stoichiometric",
                "ratio of F to Gd equal to 2.89, 2.22, 2.82,",
                "respectively."
              ]
            }
          ],
