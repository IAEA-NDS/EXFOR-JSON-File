              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A gas target. The tritium gas (at just under 1 atm",
                "pressure) was contained within a stainless steel",
                "cylinder 4 in. long x 1 in. diam. The proton entered",
                "the target through a 0.00025-in. about 12 mg/cm2",
                "tantalum foil."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "EXTB",
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A cylinder 1-in.diam. and 1-in thick neutron",
                "detector"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Each cross section measured was corrected for dead",
                "time of the pulse-height analyzer, which was",
                "occasionally as high as 20% but was more typically",
                "10%. In addition, the data at back angles were",
                "corrected for neutron attenuation due to the flanges",
                "of the gas target, the target foil retaining assembly,",
                "and the beam pipe. The correction ranged from about",
                "5% at 90. degr. to about 25% at 150. degr."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainty in the beam energy due to the",
                "range measurement, the intrinsic energy spread of the",
                "cyclotron beam, and drifting of the beam energy."
              ]
            }
          ],
