          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distributions of T(p,n)3He neutrons for 3.4 to",
                "12.4 MeV protons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.D.Goldberg",
                "J.D.Anderson",
                "J.P.Stoering",
