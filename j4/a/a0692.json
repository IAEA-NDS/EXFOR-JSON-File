          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Rolling vanadium foils. The thickness of the targets",
                "for excitation function measurements was about 2.0 um.",
                "The average thickness of the target and degrader foils",
                "was determined by weighing."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Faraday cup with electron suppressing."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " The stacks were formed by placing alternatively",
                "4.34 um aluminium foils as degraders of 12-C energy",
                "over the targets. There were 13 targets in the stack",
                "for the excitation function measurement."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " The beam current on the targets was kept below",
                "200 electric nA."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC",
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
