          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In NSD experiment stacks of three self-supporting",
                "~ 600 ug/cm2 rhodium metal foils interspersed with",
                "2-mg/cm2 - thick Al foils were used. In TRM targets",
                "of metallic rhodium of thickness around 100 ug/cm2",
                "with 100 ug/cm2 Al backing were used. The catchers",
                "used were evaporated aluminum foils, typically",
                "100 ug/cm2 thick."
              ]
            }
