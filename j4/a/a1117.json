              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty in n - value (see ANALYSIS)"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  The cross section per unit solid angle for proton-",
                "proton scattering is given by",
                "   sigma = Y x sin(theta)/(N x n x G), detected by",
                "the where Y is the number of scattered protons",
                "proportional counter when N protons of energy Ep are",
                "incident on (n/2) molecules/cm3 of hydrogen gas and",
                "the detected protons are scattered through a lab.",
                "angle (theta). The factor G=2bA/Rh is a measure of",
                "the gas scattering volume and solid angle defined by",
                "the entrance slits and final aperture of the analyzing",
                "system between the scattering volume N, n, and G."
              ]
            }
          ],
