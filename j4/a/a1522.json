          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NaI(Tl) crystal consisted of a 3.8 cm hole",
                "drilled in 12.7 cm of lead. Additional anti-coincidence",
                "detector was used  to reduce the number of cosmic ray",
                "pulses counted. It consisted of a concentric cylinder",
                "of plastic scintillator surrounding the main gamma-ray",
                "crystal, a 10 cm diameter by 12.7 cm long cylinder of",
                "NaI(Tl)."
              ]
            }
          ],
