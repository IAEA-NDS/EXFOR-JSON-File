          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An assembly of seven lead foils 12 mu-m thick having a",
                "natural isotopic composition (natPb: 1.48% 204Pb, 23.6%",
                "206Pb, 22.6% 207Pb, and 52.3% 208Pb). For catch foils,",
                "aluminum plates 20 u-m thick arranged on the two sides",
                "of the target in the direction orthogonal to the",
                "beam axis were used."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "It was exposed to a 7Li beam of intensity 30 nA (about",
                "10**10 nucl./s) for 30 minutes, and the spectra were",
                "measured for five months"
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "RANGE"
              ],
              "free_text": [
                " The kinematic characteristics of the decay",
                "products and of the composite nuclei have been",
                "investigated. The estimations of the complete and",
                "incomplete fusion contribution in the initial",
                "interaction have been obtained."
              ]
            }
          ],
