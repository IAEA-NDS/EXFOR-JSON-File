          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Purity deuterium gas and the only significant impurity",
                "0.3% 2H"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "TOF"
              ],
              "free_text": [
                " The absolute differential cross section",
                "has been determined at E = 5.0, 5.8, 9.0 and 10.0 MeV",
                "by the detection of the 3He particles, and at E = 5.0",
                "and 5.8 MeV by the neutron time-of-flight method. The",
                "scattering chamber is 35.6 cm in diameter and has",
                "detector slit positions at 5. degr. intervals from",
                "10. to 170. degr.",
                "See REL-REF for details of TOF system."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " A thin solid state detector was used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " 3He particles were detected in eight or nine",
                "detectors simultaneously between 10. and 50. degr.",
                "The detector thicknesses ranged from 150. um at 10.",
                "degr. to 30. um at 50. degr.",
                "See REL-REF for details of neutron detection."
              ]
            }
          ],
          "REL-REF": [
