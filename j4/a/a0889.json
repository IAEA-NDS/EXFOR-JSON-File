          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 32-cm2 rotating targets, consisted of the enriched",
                "isotopes U-233 (99.97%), U-238(99.3%), Pu-242(99.98%)",
                "and Cm-248(97.4%) deposited as U(3)O(8), PuO(2) and",
                "CmO(2) onto 1.5 um Ti foils to thicknesses of about",
                " 0.44, 0.35, 0.40 and 0.35 mg/cm**2, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " A 4-cm x 12-cm semiconductor detector array",
                "with 12 vertical position-sensitive strips surrounded",
                "by eight 4-cm x 4-cm side detectors without position",
                "sensitivity, forming a box open to the front (beam)",
                "side. The position-averaged detection efficiency for",
                "full-energy alpha-particles emitted in the decays of",
                "implanted nuclei was 87%."
              ]
            }
          ],
