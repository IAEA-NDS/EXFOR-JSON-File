          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A pellet method for the measurement of excitation",
                "functions:  cross-sections for 140-Ce(p,2n)139-Pr and",
                "140-Ce(p,3n)138-m-Pr"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.K.Zeisler",
                "D.W.Becker"
              ],
              "free_text": [
                ""
              ]
            }
          ],
