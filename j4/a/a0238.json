          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin natural antimony targets were prepared by vacuum",
                "distillation of antimony powder (99.999%) onto disks",
                "of aluminium foil (99.99%) of 0.001 in thickness. Two",
                "to three Mg were deposited over an area of 3.46 cm2.",
                "Degradation of the 4He or 3He particle beams by",
                "this thickness of antimony would in no case exceed 2%",
                "over the energy range considered. The uniformity of",
                "color of these targets indicated that there was",
                "little variation of thickness although no attempt was",
                "made to confirm this by measurement. After careful",
                "weighing these coated target foils were covered with",
                "a 0.001 inch aluminium foil to protect the coating,",
                "and the edges crimped to form a sealed envelope."
              ]
            }
          ],
