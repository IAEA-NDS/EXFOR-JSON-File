          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "26-FE-54",
                "field_identifier": "ENR",
                "value": 0.879
              },
              "free_text": [
                " Fe-54,87.9% enrichment, was used",
                "as target. The elemental 54Fe was pressed into 5 mm",
                "diameter pellets each weighing 25 mg."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "/By authors/ In order to use Co-55 as tracer for",
                "bleomycin for patient investigations, the presence of",
                "Co-57 and Co-56 is highly undesirable because of their",
                "long half-lives which results in an unnecessary",
                "increase in radiation dose. The only way to minimize",
                "the production of Co-57 is to use enriched Fe-54 as a",
                "target."
              ]
            }
          ],
