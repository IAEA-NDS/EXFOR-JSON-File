          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three monoisotopic or quasi-monoisotopic elements V-51,",
                "Nb-93 and Au-197 were chosen for investigations. For",
                "each element 5 foils of 13 mm diam. Were stacked",
                "together. The thickness of each foil was chosen such",
                "that the recoil loss of Be-7 particles of up to",
                " 200 MeV energy would be negligible."
              ]
            }
          ],
