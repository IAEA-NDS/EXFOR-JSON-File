          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,678,355,2000",
                "code_unit": [
                  {
                    "unit": "J,NP/A,678,355,2000",
                    "doi": "10.1016/S0375-9474(00)00339-0",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NP/A",
                        "number": null,
                        "volume": "678",
                        "part": null,
                        "issue": null,
                        "page": "355"
