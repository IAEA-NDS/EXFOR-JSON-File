          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "STTA",
                "ACTIV"
              ],
              "free_text": [
                "",
                "Foil thickness and alpha particles flux were measured",
                "and used to calculate production cross sections for",
                "each of the active isotopes found in each foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " Ge intrinsic detector"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The lead foils were analyzed spectroscopically",
                "for interfering impurities, the amounts of these",
                "were found to be negligible. The stacks, used for",
                "the determination of excitation functions and thick",
                "target yields, were during the irradiations interlaid",
                "by copper and aluminum foils."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainties in the cross-section values",
                "were estimated by propagating in square the",
                "contributions for",
                " * decay curve and peak analyses including counting",
                "   statistics,",
                " * absolute detector efficiencies,",
                " * disintegration schemes,",
                " * target thicknesses and alpha particles flux.",
                "  - The eventual losses of reaction products by recoil",
                "    were assumed to be negligible.",
                "  - As for any reaction that might occur due to",
                "    secondary neutrons, additional foils were set up",
                "    beyond the range of alpha particles. Spectra from",
                "    those foils showed no significant contribution to",
                "    the data."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The areas of all gamma-peaks observed were corrected",
                "for efficiency of detection and the activities",
                "of the radioactive products were calculated separately",
                "for each peak on the basis of the nuclear data.",
                "  No corrections were made either for the energy spread",
                "at each foil /as resulting from foil thickness",
                "variations/ or for energy losses at the preceding foils"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " *By authors* No absolute beam energy determination",
                "was performed in this experiment. On the basis of",
                "other determinations of the external beam of Buenos",
                "Aries synchrocyclotron, we assumed an energy of",
                "55.0 MeV for alpha particles with an error of 0.55 MeV",
                "in each case the target stack was thick enough to stop",
                "the 55.0 MeV external alpha-beam. The uncertainty in",
                "the incident particle energy for each data point",
                "arises from the energy spread of the incident alpha-",
                "particle beam as well as from the straggling energy",
                "losses. Effective energy spreads of 0.5 MeV were",
                "obtained for 10 MeV alpha-particles."
              ]
            }
          ],
