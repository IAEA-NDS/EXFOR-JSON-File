          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The sample consisted of a carbon substrate made of",
                "pyrolytic graphite, and was covered with layers of",
                "Al/2-O/3  (174.6 nm) and Au (10.0 nm) on top.  The gold",
                "film was deposited by electron beam evaporation and was",
                "used as an internal dose reference.  The thicknesses of",
                "the layers were determined by 4-He ion backscattering",
                "at 2023 KeV incident energy.  The atomic ratio of",
                "oxygen to aluminium was determined to be 3:2 with an",
                "accuracy of 2%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                "  PIPS detector"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "2GERGAR"
              },
              "free_text": [
                " 3 MV tandem"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                "  Measurements were made with Li+ below 5 MeV and",
                "with Li++ above 5 MeV.  The energy spread of the beam",
                "is below 1 KeV for protons at 1000 KeV and is assumed",
                "to be of the same order for Li ions, which are produced",
                "with the same source.  About 10-20 microcoulomb total",
                "charge were collected for each data point at energies",
                "below 5 MeV, and between 60 and 240 microcoulomb in the",
                "5-6 MeV range to improve the statistics of the",
                "measurements."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SITA",
                "MOMIX"
              ],
              "free_text": [
                " See SAMPLE"
              ]
            }
          ],
