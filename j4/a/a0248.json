          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin samples of highly enriched tellurium-124 were",
                "produced by electrolytic deposition on 20, 25 and 30 um",
                "thick titanium backing foils.",
                "Isotopic composition: 123-Te - 0.2%,",
                "                      124-Te - 99.8%",
                "The purity was >99%. The deposits were covered by 10 um",
                "thick aluminium foils to protect them and",
                "to avoid any loss of tellurium or radioiodine."
              ]
            }
          ],
