            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Each with 5 to 10 tellurium samples and",
                "additional nat-Ti-,nat-Ni and nat-Fe foils as beam",
                "monitors and energy degraders."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The stacks were irradiated for about 30 minutes",
                "with deuterons at a beam current of about 100 nA",
                "and a primary energy 14.06+-0.2 MeV"
