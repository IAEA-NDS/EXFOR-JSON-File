              "free_text": [
                "",
                "The dE-E system detected the reaction products, proton",
                "and 7Be, in coincidence, and the NaI(Tl) was used for",
                "measuring the gamma-rays from the first excited state",
                "of 7Be at 429 keV."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
