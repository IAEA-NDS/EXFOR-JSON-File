            {
              "pointer": "",
              "coded_information": [
                "NAICR",
                "SCIN"
              ],
              "free_text": [
                " E-dE plastic detector hodoscope.",
                "The detection efficiency is evaluated by Monte-Carlo",
                "simulation.",
                "The detection system consisted of a dE-E plastic",
                "scintillator hodoscope and a NaI(Tl) detector",
                "array DALI (see REL-REF)."
              ]
            }
          ],
