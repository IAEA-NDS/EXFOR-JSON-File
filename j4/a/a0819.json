          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New measurement of the astrophysical S factor for",
                "C-12(p,g)N-13 reaction at low energies and the",
                "asymptotic normalization coefficient(nuclear vertex",
                "constant) for the p+C-12--N-13 reaction"
              ]
            }
          ],
