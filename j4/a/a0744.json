          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "RSD"
              ],
              "free_text": [
                "  The evaporation residues were separated from the",
                "background of beam and beam-like particles at 0  degree",
                "and nearby angles by means of an electrostatic",
                "deflector.  The beam ions were stopped at the exit of",
                "the deflector, whereas evaporation residues were",
                "detected by an energy time-of-flight telescope.",
                "The beam rejection factor of the setup is 1E+08."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "MCPLT",
                "SIBAR"
              ],
              "free_text": [
                " The energy time-of-flight telescope",
                "consisting of a microchannel plate detector and a 300",
                "mm2 silicon surface-barrier detector."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "2ITYPAD"
              },
              "free_text": [
                " The XTU-accelerator"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " 48-Ca beams.  The current on target were  3-7",
                "particle nano-ampere in the energy range 133-174 MeV",
                " (from 7%-8% below to 17%-18% above the coulomb",
                "barriers)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD"
              ],
              "free_text": [
                " Total fusion cross sections were derived from",
                "the normalized 0 degree evaporation residues yields,",
                "from the angular distributions, and from the",
                "transmission of the electrostatic deflector."
              ]
            }
