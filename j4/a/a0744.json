          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were evaporations of metallic 90Zr (50",
                "mug/cm2) and of 96zrO(2) (50 mug/cm2) on carbon backing",
                " (15 mug/cm2) facing the beam. The isotopic enrichments",
                "were 99.4% and 95.6%, respectively. The beam energy",
                "losses in the carbon backings (180 keV) and in the",
                "targets were taken into account"
              ]
            }
          ],
