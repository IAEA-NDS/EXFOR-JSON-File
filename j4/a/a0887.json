          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The errors in the cross-section measurements for",
                "different alpha-particle energy are 8-23% with",
                "confidence probability 68%. The errors in the following",
                "were also taken into account: the counting rate in the",
                "total absorption peaks of the gamma-ray lines, the",
                "determination of the efficiency of the gamma detector,",
                "the quantum yield of the gamma-ray lines, the",
                "determination of the number of nuclei of the krypton",
                "isotopes irradiated by alpha-particles, the integral",
                "flux of alpha-particles irradiating the krypton",
                "isotopes in the target facility and the alpha-particle",
                "energy."
              ]
