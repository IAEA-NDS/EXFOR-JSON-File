          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1.  The modeless restoration of all even spin-tensor",
                "components of the density matrix of the 3- (6.13 MeV)",
                "state of residual nucleus was carried out.",
                "2.  The angular dependence of magnetic substrates",
                "population and orientation tensor components for 3-",
                " (6.13 MeV) state are also presented.  The experimental",
                "results are compared with calculations incorporating",
                "the triton pickup mechanism by coupled-channel method",
                "and the compound nucleus production mechanism."
              ]
