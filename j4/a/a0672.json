          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " A 36-Ar beam with 1050 A MeV in spills of 8",
                "second duration with a repetition rate of 1/16",
                "1/second.  Typical beam intensities varied between",
                "1.E+08 and 1.E+09 ions per spill, depending on the",
                "cross section to be measured."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The primary-beam intensities were measured with",
                "a secondary-electron transmission monitor."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                " A thick (1625 mg/cm2) 9be target located at the",
                "entrance of the FRS."
              ]
            },
