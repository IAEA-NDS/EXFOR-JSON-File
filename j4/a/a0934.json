          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Th-232, U-238, U-235, Bi-209 and Au-197 targets had a",
                "diameter of 1.2 cm. The mass of the radioactive targets",
                "was measured using alpha and gamma spectrometry",
                "gamma spectrometry-(mug)",
                "Th-232 136+-6, U-238 95+-12, U-235 104+-6",
                "alpha spectrometry(mug)-",
                "Th-232 target- Th-232 126+-6, U-238 7+-1,",
                "U-238  target- U-238 91+-7",
                "U-235  target- U-238 less than 9, U-235 99+-14,",
                "               U-234 1.3+-0.2"
              ]
            }
          ],
          "DETECTOR": [
