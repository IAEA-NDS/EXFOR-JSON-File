          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thickness of the Sm oxide targets varied between 20",
                "and 350 micro-gramm/cm**2.  The 144-Sm oxide material",
                "was enriched to 87 and 96% and deposited onto thin",
                "aluminium or nickel foils.  To increase the target",
                "stability during the bombardment, a very thin aluminium",
                "layer was evaporated onto the samarium oxide layer."
              ]
            }
          ],
