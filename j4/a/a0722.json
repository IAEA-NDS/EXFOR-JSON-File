          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 23O beam with a kinetic energy of 422 MeV/nucleon",
                "was produced via fragmentation reactions of a primary",
                "Ar-40 beam (500 MeV/nucleon) from the SIS synchrotron",
                "at GSI, Darmstadt. A beryllium production target,",
                " 4 g/cm2 was used at the entrance of the fragment",
                "separator-FRS."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " O-22 fragments, neutrons and gamma rays have",
                " been detected in coincidence."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
