          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1.  The modelless restoration of all even spin-tensor",
                "components of the density matrix of the 2+ (3.37 MeV)",
                "state of residual nucleus was carried out.",
                "2.  The angular dependences of magnetic substates",
                "population and orientation tensor components for 2+",
                " (3.37 MeV) state are also presented.  The experimental",
                "results are compared with calculations incorporating",
                "the nucleon stripping mechanism by coupled-channel",
                "method and the compound nucleus production mechanism."
              ]
            }
          ],
