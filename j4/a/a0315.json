              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular Distribution Measurements of 12-C(D,P)13-C",
                "Reaction Below 350 KeV Deuteron Energies Using Nuclear",
                "Track Detectors"
              ]
            }
