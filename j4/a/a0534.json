          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "3INDNSD"
              },
              "free_text": [
                " The experiment was carried out using the",
                " 15UD Pelletron accelerator at Nuclear Science Centre"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " Beam current was 6 to 10 pnA."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                " See SAMPLE"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Si target was made by vacuum evaporation of 99.99%",
                "enriched 28-Si oxide with carbon backing.  Thicknesses",
                "of the two Si oxide targets used were 30 microgram/cm2",
                "and 67 microgram/cm2 determined from the energy loss",
                "of alpha-particles from a 241-Am source.  The thickness",
                "of carbon backing was 10 microgram/cm2."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "14-SI-28(14-SI-28,EL)14-SI-28,,DA",
                  "code_unit": [
                    {
                      "unit": "14-SI-28(14-SI-28,EL)14-SI-28,,DA",
                      "field": {
                        "reaction": "14-SI-28(14-SI-28,EL)14-SI-28",
                        "target": "14-SI-28",
                        "projectile": "14-SI-28",
                        "process": "EL",
                        "product": "14-SI-28",
                        "quantity": ",DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "The absolute cross-section values were obtained by",
                "normalizing the yield to the elastic monitor counts,",
                "the cross section at the monitor angle being purely",
                " Coulombic and well described by the Mott scattering",
                "for spin zero particles."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Five such detectors (300 mu-m) were used and",
                "arranged in one of the two movable arms in the chamber.",
                "The solid angles subtended by the detectors were",
                "between 3.5-7.5 msr. Two monitor detectors (300/mu-m)",
                "were placed symmetrically at 11. degr. on either",
                "side of the beam."
              ]
            }
          ],
