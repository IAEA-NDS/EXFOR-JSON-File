          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 7-Be oxide evaporated on a 1 millimeter thick copper",
                "backing. The target was mounted on the axis of a",
                "stepping motor, which moved the target by a 180 degrees",
                "rotation between the proton-beam irradiation position",
                "and the 8-B-decay counting position, in a repeating",
                "cycle."
              ]
            }
          ],
          "DETECTOR": [
