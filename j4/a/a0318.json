          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A comparative investigation of nuclear reactions",
                "leading to the formation of short-lived 30P and",
                "optimization of its production via the 27Al(alpha,n)30P",
                "process at a compact cyclotron"
              ]
            }
          ],
