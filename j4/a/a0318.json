          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "By converting ordinary sulphur (purity 99.9999%) into",
                "plastic sulphur (through melting and pouring into",
                "water) and subsequent pressing at a pressure of 2.5",
                "t/cm2 on to a Ti-foil (thickness 20 um, diameter 13",
                "mm) it was possible to obtain 'S'-pellet on Ti-foil",
                "was further supported by fixing a 2 mm broad Al-ring",
                "at the periphery of the 'S-'pellet. These samples",
                "containing metastable state of did not deteriorate",
                "over several days. Nonetheless, all the samples were",
                "prepared freshly prior to each irradiation."
              ]
            }
          ],
