          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The first boron targets were made by evaporating B20",
                "onto a 3 mg/cm2 gold foil, but it was found more",
                "satisfactory to evaporate amorphous boron onto the",
                "foil by heating in vacuo in a carbon crucible. The",
                "targets used were of this type and were generally",
                "0.8 mg/cm2 in thickness."
              ]
            }
