          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets consisted of up to 12 stacked aluminium",
                "foils (3.428 or 1.714 mg/cm2) onto which bismuth",
                "had been evaporated to a thickness of 2.0+-0.1 mg/cm2.",
                " in some stacks the bismuth lager on each fo",
                "foil was sealed by a 1.714 mg/**2 aluminium coverfoil",
                "to prevent eventual evaporation and recoil losses of",
                "product nuclei. Nine target stacks were irradiated for",
                "1-2 hr each at constant beam intensities (+-10%)",
                "ranging between 30 and 100 nanoAmpers for separate",
                "experiments."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
