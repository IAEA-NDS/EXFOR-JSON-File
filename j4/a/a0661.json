          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "R",
                "subentry_number": null,
                "author": "B.M.BOBCHENKO+",
                "reference": {
                  "code": "J,YF,30,1553,1979",
                  "field": {
