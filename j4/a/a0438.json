          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2JPNIPC"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam was impinging a target assembly, which",
                "consisted of three pieces of 15.7 ug/cm**2 iron",
                "foils, 99.99% in purity."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " 135 MeV/nucleon 12-C beam and 80 MeV/nucleon",
                "16-O beam, with an intensity of 200 electric",
                "nano-Ampere"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " In the experiment with 12-C ions, a 6.2 min",
                "irradiation was performed in order to obtain",
                "information for the short-lived target fragments.  An",
                "additional irradiation of longer duration, 48.8 min,",
                "was performed for the longer-lived fragments.  In the",
                "experiment with 16-O beam, a single irradiation, 60 min",
                "in duration, was conducted."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The sample from the short irradiation was",
                "measured for 8 hr, starting a few min after the end of",
                "bombardment. Those from the longer irradiation were",
                "measured for approximately 4 weeks."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Decay curves were analyzed by an iterative",
                "least-square fit code. Assignments of radioactive",
                "nuclides were made on the basis of energy, half-life,",
                "and concordance with other gamma-rays, if any, emitted",
                "by the presumed nuclide."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties in these values are standard",
                "deviations, including errors in analysis of the",
                "gamma-ray spectra, in the resolution of the decay",
                "curves by the least-squares method, and ERR-1."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Error in detector efficiencies.",
                "While the uncertainty in the thickness of the target",
                "was negligible, the uncertainty in beam current",
                "measurement was not taken into account."
              ]
            }
          ],
          "REL-REF": [
