              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,EPJ/A,7,397,2000",
                "code_unit": [
                  {
                    "unit": "J,EPJ/A,7,397,2000",
                    "doi": null,
