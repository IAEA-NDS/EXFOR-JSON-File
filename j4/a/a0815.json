          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The CTOF measurements and Monte Carlo analyses of",
                "neutron spectra for backward direction from tungsten",
                "target irradiated by protons with energies from 200",
                "to 1200 MeV."
              ]
            }
          ],
