          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metallic thorium foils were used as targets. The foils",
                "dimensions were 17*50 mm and thickness from",
                "0.045+-0.003 to 0.069+-0.004 mm.",
                "Each Th-foil in a plastic frame was wrapped into Al",
                "foil envelope together with Cu-foils (0.038+-0.002 mm",
                "thickness) and Al-foils (0.100+-0.004 mm) for beam",
                "monitoring. In addition, graphite plates 2-4 mm",
                "thickness were used as degraders for adjusting proton",
                "energies to desirable values."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                "  Two stacked-foil target assemblies-",
                "First stack consisting of 13 Th targets was irradiated",
                "with initial proton energy in the accelerator",
                "158.5+-0.3 MeV. Second stack consisting of 6 Th targets",
                "was irradiated with initial energy 100.1+-0.3 MeV in",
                "order to diminish energy uncertainties."
              ]
            },
