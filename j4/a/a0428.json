          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD"
              ],
              "free_text": [
                " The values for Sigma(E1), Sigma(E2)/Sigma(E1),",
                "and Sigma(E2) have been obtained by using the formula",
                "for the interference of E1 and E2 transitions in",
                "angular distributions, given in the paper of Dyer and",
                "barnes. The parameter (PHASE) of this formula was not",
                "kept open, but determined by using the elastic alpha -",
                "scattering data of Plaga and D'Agostino Bruno."
              ]
            }
          ],
