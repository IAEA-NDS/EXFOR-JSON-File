          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was produced by implanting 12-C atoms",
                "into gold. The gold layered backing used for this",
                "purpose was especially developed for long term",
                "experiments and high beam power of up to 10 KW/cm2.",
                "The depletion in respect to the detrimental 13-C was",
                "improved by a factor of 1000. The target was replaced",
                "when a deterioration of about 20% was found."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
