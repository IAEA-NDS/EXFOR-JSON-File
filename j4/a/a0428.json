                "GSPEC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " An array of three or four large detectors in",
                "close geometry, actively shielded with bismuth",
                "germanate crystals."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " The crystals were used for active shielding and",
                "anti-Compton detectors.",
                "The whole detector setup was placed on a heavy",
                "motor-driven revolving table."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The S(E1) and S(E2) factors deduced from the gamma",
                "angular distributions have been extrapolated to the",
                "range of helium burning temperatures applying the",
                "R-Matrix method, which yielded",
                "S(E1)/300 = (76 +/-20) keV*b and",
                "S(E2)/300 = =(85 +/- 30) keV*b."
              ]
            }
          ],
