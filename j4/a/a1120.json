                        "product": "2-HE-3",
                        "quantity": ",DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " The two parts of the curve given by the two reactions",
                "were normalized to each other in the region several",
                "MeV wide in which they overlap. By means of the",
                "sensitivity curve obtained in this way, it is then",
                "possible to compare directly the yields obtained for",
                "the breakup neutrons and the neutrons from the reaction",
                "D(d,n)3He in terms of the known cross section of the",
                "latter reaction"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainty in the absolute value of",
                "the cross-section scale is due to the uncertainty of",
                "the normalizing procedure, and to the uncertainty in",
                "the cross section of the D(d,n)HE-3 reaction."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors are the sum of the statistical",
                "uncertainty and an additional error, which is hard",
                "to estimate, due to inaccuracy of the background",
                "subtraction."
              ]
            }
          ],
