          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An estimate of the differential cross section was",
                "made by comparison with the 7Li(d,p)8Li(0) reaction,",
                "for which the differential cross section is",
                "determined by Sellshop at the same deuteron energy",
                "and at one of the same angles (30 degr.). From that",
                "value and the mass ratio 5: 95 for the 7Li : 6Li",
                "abundance, one obtains a differential cross section",
                "of 0.6 +- 0.3 mb/sr at an angle of 36. degr. in the",
                "center of mass system."
              ]
            }
          ],
