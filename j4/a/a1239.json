          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental study of excited 4H, 4He and 4Li",
                "nuclear systems"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1USALAS"
              },
              "free_text": [
                " beams from the multiple electrostatic",
                "accelerator system at the Los Alamos Scientific",
                "Laboratory were used"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The gas target was 3.8 cm in diam. and used 12- or",
                "25-mu, beryllium entrance and exit foils"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy resolution in the range of interest was",
                "measured by means of the sharp peaks of contaminant",
                "reactions and had a value (full width at half maximum)",
                "of 120 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "DRFTC",
                "SIBAR"
              ],
              "free_text": [
                " The E detector was a Li-drifted counter",
                "either 2 or 3 mm in depth. The dE detectors were",
                "surface-barrier units ranging in thickness from 50 to",
                "350 mum, and were either oriented or were tilted",
                "15.degr. to avoid the effects of channeling."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections in the absolute values of the cross section",
                "were made for calibrations of the target pressure gauge",
                "and beam-current integrator, for dead time in the pulse",
                "height analyzer and other electronic effects, and for",
                "target gas purity."
              ]
            }
          ],
