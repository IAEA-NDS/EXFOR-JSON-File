            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total neutron yield from a thick heavy ice target",
                "has been measured at four bombarding energies from 100",
                "to 300 keV by comparison of the activity induced in a",
                "large tank of MnSO4 solution surrounding the source",
                "with the activity induced by a standard Ra-Be source."
              ]
            }
