              "free_text": [
                " The 14UD Pelletron."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 180 ug/cm2 208-Pb-Cl(2) on a 15 ug/cm2 natural",
                "carbon backing."
              ]
            }
          ],
          "MONITOR": [
