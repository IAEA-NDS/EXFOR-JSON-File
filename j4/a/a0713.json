          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The breakup cross sections are derived",
                "using formulae-",
                "Sigma-a(singles) approx. equal-",
                "sigma(incomplete fusion)+2(sigma(transfer+",
                "sigma(breakup)), where the factor of 2 reflects the",
                "fact that these processes results in two alpha-",
                "particles in the exit channel."
              ]
            }
          ],
