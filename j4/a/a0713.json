          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*. The number of alpha-singles events was",
                "determined by subtracting off an exponentially falling",
                "background, resulting from reactions on light",
                "components of the target-for first reaction.",
                "Double-alpha events arising from the decay of Be-8 can",
                "be identified in the delta-E-E spectrum from the",
                "detector telescopes where they appear as Li-7 events-",
                "for second reaction."
              ]
            }
