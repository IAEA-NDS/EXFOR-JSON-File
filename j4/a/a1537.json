          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target of 101+-2.5 mu-g/cm**2 of 7LiF evaporated on",
                "an aluminum backing approximately 700 mu-g/cm**2",
                "thick. The Li was 99.99% 7Li. A second 7LiF target of",
                "comparable thickness was also obtained. A third target",
                "was also used in the comparison which, by direct",
                "weighing,contained 4.3+-0.4 mu-g of 7Li."
              ]
            }
          ],
          "DETECTOR": [
