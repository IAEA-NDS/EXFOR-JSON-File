          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched isotopes of 128-Te(87%) and 130-Te(61%). The",
                "elements were deposited on aluminum foils of",
                "thickness 6.75 mg/cm2. Thicknesses of 128-Te and",
                "130-Te deposits were 920 and 1100 ug/cm2, respectively."
              ]
            }
          ],
