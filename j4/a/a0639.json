              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 12x12 inch crystal with a central bore hole",
                "of 35 mm diameter and a 0.5 mm aluminum wall",
                "thickness. The target is at the center of the bore",
                "hole. In this geometry, the total gamma-ray",
                "efficiency of this 4-pi crystal was observed to be",
                "energy- independent with a value of efficiency",
                "=75+/-8%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Two Ge(Li) detectors (each with 20% efficiency",
                "at Egamma = 1.3 MeV), placed of angles of 0. and",
                "150. and respective distances from the target of",
                "d = 17.5 cm and 10.2 cm. Detectors used for",
                "high-resolution measurements of forward- backward",
                "anisotropies."
              ]
            }
          ],
