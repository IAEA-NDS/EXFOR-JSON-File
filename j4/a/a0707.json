          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " The intensity of the 7-Be beam was 10000",
                "particles/seconds.  The purity of the beam was 99%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                "  The scattering events were detected in a compact",
                "and efficient delta-E(gas)-E(Si) telescope detector",
                "system.  All details see in detector and original",
                "paper."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 7-Li target was prepared by evaporation of 7-Li",
                "material (99.9% pure) on a thin (10 mug/cm2) carbon",
                "backing.  Special care was taken in preparing the",
                "target as 7-Li is highly hygroscopic."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "3-LI-7"
              ],
              "free_text": [
