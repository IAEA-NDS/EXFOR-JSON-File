          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The lithium targets of natural lithium or LiF were",
                "evaporated on 20 mil Ta backings and were usually",
                "10 keV thick for 2-MeV protons."
              ]
            }
          ],
          "MONITOR": [
