          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "ANGD"
              ],
              "free_text": [
                "  Angular distribution measurements of the",
                "have been carried out with Ti15N solid targets at six",
                "energies in the range of Ep= 149 to 750keV. They were",
                "described by the expression W(theta)=1+a1(Ep)cos(theta)",
                "Thus a1(Ep) was calculated to be equal",
                "                        0.50-0.53/360 x Ep (Ep in keV).",
                " Astrophysical factor (on fig.)"
              ]
            }
