          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Subthreshold resonance in the 6-Li(D,A)4-He reaction",
                "and its astrophysical implications"
              ]
            }
          ],
          "AUTHOR": [
