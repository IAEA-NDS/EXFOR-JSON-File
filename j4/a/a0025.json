          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute values of the cross sections were",
                "obtained from the relative measurements of the",
                "counting rates of the p-gamma and alpha-gamma",
                "coincidences and from the counting rate of the alpha",
                "particles. The differential cross sections were",
                "measured using production of alpha particles from 58Ni,",
                "which was measured earlier (differential cross-section",
                "of producing alpha-particle at 120 ang. degree",
                "assumed = 25+-3 mb/sr, see REL-REF)."
              ]
            }
          ],
