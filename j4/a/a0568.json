          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity natural V in metallic form was used as a",
                "target material for irradiations. The thicknesses of V",
                "foils were determined by weight and area measurements",
                "for each individual foil. The stack consisting of 25",
                "numbered circular V foils (the foils weighed between-",
                " 0.8573 g and 0.8950 g ,had thicknesses about 0.5 mm",
                "and were cut into 19 mm diam. discs) was exposed to",
                "an external proton beam."
              ]
            }
          ],
