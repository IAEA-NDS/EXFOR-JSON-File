          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 0.37-mg/cm2 rotating targets of Am-243 (99.5-99.9%)",
                "deposited onto 1.5-um Ti foils.",
                "When determining cross sections in the experiments",
                "with the 0.68 and 0.84 mg/cm2 targets,we corrected the",
                "separator's transmission for increased scattering",
                "losses in the target. In calculations of the cross",
                "sections in both these cases we used 35% or the",
                "effective target thickness of 0.4 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " A 4-cm x 12-cm semiconductor detector array",
                "with 12 vertical position-sensitive strips surrounded",
                "by eight 4-cm x 4-cm side detectors without position",
                "sensitivity, forming a box open to the front (beam)",
                "side. The position-averaged detection efficiency for",
                "full-energy alpha-particles emitted in the decays of",
                "implanted nuclei was 87%."
              ]
            }
