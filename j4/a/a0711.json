          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The following individual uncertainties are",
                "included in the propagated error:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The number of target nuclei including",
                "non-uniformity (5%)."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Incident particle intensity (5%)."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Detection efficiency (5%)."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 1.0,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " Determination of the peak areas including",
                "statistical errors (1%-5%)."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-4",
                "minimum_value": 1.0,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " Absolute abundance of the used",
                "                                 gamma rays (1%-5%).",
                "The total resulting uncertainty amounts to 8%-13%",
                "obtained as positive square root of a sum of the",
                "contributing sources in quadrature. The strongly",
                "non-linear effect of the possible uncertainty of the",
                "half-lives was not taken into account."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  Overall uncertainty in the average energy",
                "for the last foil of the longest stack (irradiation",
                "with 28.5 MeV protons, 15 foils) was estimated to be",
                "1.7 MeV, taking into account the cumulative effects of",
                "the possible variations in incident energy and number",
                "of target atoms."
              ]
            }
