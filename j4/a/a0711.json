            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity natural 12.14 and 7.99 um Pd foils (> 99.9%",
                "pure) were used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " Five stacks were irradiated with beams of",
                "incident energy on the first foil of 20.5 and 15.1 MeV",
                "for deuterons and 37.3, 28.5 and 15.9 MeV for protons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " The number of foils in each stack was such as to",
                "cover the whole energy range from the maximum energy",
                "down to the threshold of the (p,xn) and (d,xn)",
                "reactions in nearly uniform energy steps and to get",
                "overlapping energy regions between stacks.",
                "High purity Ti, Cu and Ni foils (purity >99.6%)",
                "were inserted between the stacked Pd foils, in order to",
                "monitor the intensity and the energy of the incident",
                "charged particles."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The beam current was kept constant (about",
                " 200 nA) during the irradiations (0.5 hour)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Faraday cup was used and monitor reactions too."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Measurements of the individual foils were",
                "carried out between 1 and 3 hours after EOB."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
