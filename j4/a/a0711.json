          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements of proton and deuteron",
                "induced formation of 103-Ag in natural palladium"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RCA,92,215,2004",
                "code_unit": [
                  {
                    "unit": "J,RCA,92,215,2004",
