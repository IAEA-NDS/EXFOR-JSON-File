          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Scattering of 3He from 4He and states in 7Be"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
