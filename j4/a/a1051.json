              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " 3He + 4He",
                "The two excitation curves at the most forward angle",
                "were obtained by counting the recoil 4He nuclei in",
                "detector No.1 with the coincident 3He nuclei in",
                "detector No.2, while the rest of the excitation curves",
                "were obtained by counting the scattered 3He nuclei in",
                "detector No.1 with the coincident 4He nuclei in",
                "detector No.2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "CSICR",
                "CSICR"
              ],
              "free_text": [
                " Two detectors were used"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " A reasonable estimate of the probable error",
                "is 5% from 70. to 90. degr. in the center-of-mass",
                "system and 10% outside of this range.",
                "Coincidence losses, and the high background at",
                "backward angles, makes an estimate of the errors in",
                "the present experiment difficult."
              ]
            }
          ],
