              ],
              "free_text": [
                " The cross sections were measured by using",
                "a magnetic spectrometer and 5x50 mm positive-sensitive",
                "detector with depletion depth of 120 micr."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NaI(Tl) crystal was mounted outside the",
                "scattering chamber to serve as a monitor of the",
                "target condition."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
