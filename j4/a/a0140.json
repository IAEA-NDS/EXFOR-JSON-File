          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural iron was soldered on to a copper backing and",
                "bombarded with an extracted beam of 100 microAmpere",
                "of 25 MeV He3 particles."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  *By authors* Ni-57 and Co-55 for the labelling of",
                "bleomycin were produced by bombardment of natural",
                "iron with 25 MeV helium-3. The thick target yields",
                "were 32 muCi/muAhr of Ni-57 and 21 muCi/muAhr of",
                "Co-55 of 25 MeV helium-3. The bleomycin was",
                "successfully labelled with the carrier-free isotopes."
              ]
            }
          ],
