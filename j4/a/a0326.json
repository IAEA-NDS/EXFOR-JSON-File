          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Overall errors are typically of the order",
                "of 12%, although relative errors for comparative yields",
                "from the various reactions would be considerably",
                "smaller, since systematic uncertainties in detector",
                "efficiencies and nuclear decay properties",
                "would be removed."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty in the dead time losses."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 3.0,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " The counting error at the 95.5%",
                "confidence level for 123Xe and 123I was less than 3%.",
                "For 125Xe(125I) the error was 5%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainties in the irradiation parameters",
                "resulting from any lack of uniformity in the tellurium",
                "thickness, and specifically from heterogeneous",
                "distribution, if any, with time and place of the",
                "incident beam density."
              ]
            },
