            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements and a direct-reaction-plus-Hauser-",
                "Feshbach analysis of 89Y(p,n)89Zr, 89Y(p,2n)88Zr",
                "and 89Y(p,n+p)88Y reactions up to 40 MeV."
              ]
            }
          ],
