              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " 7Li2+ and 7Li3+ beams.  Beam currents were of",
                "the order of 30 nA."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The alpha group was well discriminated in the",
                "forward detectors with the DE-E technique."
              ]
            }
          ],
