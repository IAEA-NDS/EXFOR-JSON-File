          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ".The error limits for cross sections arise",
                "in the determination of the product nuclide activity",
                "and the alpha- particle flux. The gamma-ray yield",
                "involves the photopeak counts, the photopeak efficiency",
                "of the detector, gamma-ray transition probability,",
                "the internal conversion correction and a correction",
                "for the self-absorption in the sample. Since the",
                "alpha-particle flux involves the same quantities, the",
                "error in the flux measurments is estimated to Be equal",
                "to combined errors of these quantities. Error in",
                "timing,weight of the sample and in background",
                "subtraction were also estimated."
              ]
            }
          ],
