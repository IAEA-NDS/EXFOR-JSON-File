          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The tellurium foils were obtained by homogeneous",
                "dispersion of powdered metallic tellurium in the",
                "cellulosic suspension. Natural tellurium targets were",
                "stacked with copper foils with the purpose of",
                "monitoring the alpha particle flux."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The energy of the incident alpha-",
                "beam was 55.0 MeV with the uncertainty estimated",
                "below 1%. Reaction products losses by recoil were",
                "assumed to be negligible."
              ]
            }
