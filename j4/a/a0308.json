          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Element Fe-56 targets were prepared from a starting",
                "material Fe(2)O(3) isotopically enriched to 99.7%.",
                "Shiny metallic 56Fe targets condensed on to 0.025 cm",
                "spectroscopically pure Ta blanks, upon evaporation",
                "under vacuum. The target thickness was determined by",
                "measuring the mass difference of the Ta substrate",
                "before and after deposition. A target of thickness",
                "234 +- 11 ug/cm2 was selected for the experiment."
              ]
            }
          ],
