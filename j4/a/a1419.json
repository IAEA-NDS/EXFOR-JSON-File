          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were prepared by vacuum evaporation of",
                "metallic natural lithium on to tantalum discs. The",
                "thicknesses of the targets were found to be 30+-6 keV",
                "at a proton energy of 2 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PHD"
              ],
              "free_text": [
