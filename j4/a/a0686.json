          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 180- mug/cm2-thick, self-supported natural silicon",
                "target, tilted by +/- 40 degree (depending on the",
                "detector position).  A liquid-nitrogen cold trap close",
                "to the target holder reduced the target contamination",
                "on carbon to minimum."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "14-SI-28(3-LI-6,EL)14-SI-28,,DA",
                  "code_unit": [
                    {
                      "unit": "14-SI-28(3-LI-6,EL)14-SI-28,,DA",
                      "field": {
                        "reaction": "14-SI-28(3-LI-6,EL)14-SI-28",
                        "target": "14-SI-28",
                        "projectile": "3-LI-6",
                        "process": "EL",
                        "product": "14-SI-28",
                        "quantity": ",DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "  The scattering at",
                "+/- 15 degree, concerning the present bombarding",
                "energies, can be considered as being pure Rutherford."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " The DE silicon detector was 10",
                "micrometers thick, while the E detector was 300",
                "micrometers thick measuring the forward-angle",
                "scattering. The alpha group was well discriminated in",
                "the forward detectors with the DE-E technique."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "  A thin, 20- or 25- micrometers - thick silicon",
                "detector measuring the backward scattering.  The choice",
                "of the thickness of the backward detector was such as",
                "to allow light particles, like alphas from breakup",
                "transfer and other contaminant reactions (6Li+12C), to",
                "go through while Li particles stop in the detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " 6Li+ beam.  Beam currents were of the order of",
                "30 nA."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The alpha group was well discriminated in the",
                "forward detectors with the DE-E technique."
              ]
            }
          ],
