          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin 6-Li-F target (10 ug/cm2 on a 10 ug/cm2 carbon",
                "backing). The target thickness corresponded to an",
                "energy loss of 2-3 keV for deuterons and to 10-20 keV",
                "for the measured 7-Li and 7-Be recoil nuclei."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " 100 mm2 PIPS-detector being placed at an",
                "angle of 150 degrees with respect to the beam in 10",
                "cm distance from the target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "SITA",
                "EXTB"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "By means of recoil nuclei spectroscopy the",
                " 6-Li(d,p0)7-Li and 6-Li(d,n0)7-Be mirror reactions",
                "have been measured for deuteron energies between 65 and",
                "135 KeV.  The results have been compared with",
                "theoretical calculations including effects of the",
                "isospin mixed subthreshold resonance state in 8-Be."
              ]
            }
          ],
