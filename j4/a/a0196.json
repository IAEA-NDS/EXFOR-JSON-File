          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The vanadium plate of 99.99% purity was rolled from",
                "9.15 mg/cm**2 down to foils with thickness from 1.73 to",
                "2.52 mg/cm**2. The target assembly consisted of a",
                "number of vanadium target sandwiched between aluminium",
                "degradation foils to avoid the loss of the product",
                "nuclei due to recoil. The stack was composed of such",
                "sandwiches. the inhomogeneity of the target thickness",
                "was less than 5%."
              ]
            }
          ],
