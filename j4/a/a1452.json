          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Recoil angular distributions of the 6Li(d,n)7Be and",
                "12C(d,n)13N reactions"
              ]
            }
          ],
          "AUTHOR": [
