            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " To detect either the scattered proton or",
                "        deuteron, SMART, see [T.Ichihara et al.,",
                "        Nucl.Phys.A569(1994)287c] with Focal-plane",
                "        polarimeter DPOL to measure proton",
                "        polarization, see [S.Ishida et al., AIP",
                "        Conf.Proc.343(1995)182]."
              ]
            }
          ],
