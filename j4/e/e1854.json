                        "quantity_236": "CUM,SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "Beam current was continuously monitored by a secondary",
                "emission chamber, which was calibrated by activation",
                "method using the shown monitor reaction."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam intensity is about 1.4e11 PPS. (Beam intensity",
                "was continuously monitored by a SEC (secondary",
                "emission chamber), which was calibrated by the",
                "activation method using the 27Al(p,3pn)24Na reaction.)"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- Chemical-form of target is element.",
                "- Physical-form of target is solid. Thin metal foil",
                "  target. Each target consists of three stacked foils",
                "  of the same thickness. A middle foil was used for",
                "  counting and chemical assays, while the outer foils",
                "  served to compensate for recoil loss. Each target",
                "  was bundled together and placed in order of target",
                "  atomic weight."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "Irradiation time was 37 min."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                "Average intensity of proton beam was 1.4e+11",
                "      proton/sec."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                "Irradiated targets were stored in a",
                "       refrigerator (about 6 deg), and the tritium",
                "       analysis was carried out about three months",
                "       after the bombardment. The irradiated foil was",
                "       dissolved completely in acid. See Fig.1 of",
                "       reference for the dissolution apparatus used in",
                "       this experiment."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": "2JPNLEP"
              },
              "free_text": [
                "External primary beam line of the 12",
                "               GeV proton synchrotron"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "To measure 24Na radioactivity in the Al foil"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "To measure radioactivity of tritium. Counting",
                "      efficiency was determined by an auto-external",
                "      standard method using standard tritium sources,",
                "      to be about 22%."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for recoil loss was made and about 10%",
                "error is included because of recoil correction for",
                "thin target."
              ]
            }
          ],
