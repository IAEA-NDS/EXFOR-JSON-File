          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Effects of nuclear deformation on fusion probability",
                "in the reactions of 82Se+natCe and 76Ge+150Nd near the",
                "Coulomb barrier"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
