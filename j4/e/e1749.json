              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,63,044610,200104",
                "code_unit": [
                  {
                    "unit": "J,PR/C,63,044610,200104",
                    "doi": "10.1103/PhysRevC.63.044610",
                    "field": {
                      "reference_type": "J",
