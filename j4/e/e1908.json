                "institute": "2JPNWER"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section 0 deg is obtained by sigma(0deg) =",
                "sigma(ref)* (N(0deg)/Omega(0deg))/(N(ref)/Omega(ref))",
                "for N(0deg) particles recoiled at solid angle",
                "Omega(0deg). 'ref' means reference angle. The ratio of",
                "the solid angles Omega(ref)/Omega(0) is 0.79 with an",
                "error of 1.4%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "E-RSL is about 25 keV.(Measured by alpha-particle from",
                "241Am)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " To detect recoil protons and deuterons"
              ]
            }
          ],
