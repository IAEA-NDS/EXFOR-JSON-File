          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Chemical-form of target is element.",
                "Physical-form of target is solid. Aluminium foils",
                "which consisted of three or four layers are used. An",
                "inner aluminium foil which was sandwiched with outer",
                "aluminium foils was used as a sample in order to",
                "cancel scattering-in and scattering-out nuclei by",
                "incident protons [A.M. Poskanzer et al., Phys. Rev.",
                "102(1956)1390].",
                "Target-thickness is 5.26+-0.05, 3.44+-0.03mg/cm**2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "Immediately after irradiation foils were",
                "       removed from the hot area, and a sample portion",
                "       of the inner foil which corresponded to a beam",
                "       spot size was cut and sealed in a disk",
                "       container made of lucite."
              ]
            }
          ],
