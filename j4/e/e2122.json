          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Efficiency: particle detection efficiency was found to",
                "be around 60-70% at laboratory scattering angles of",
                "less than 8.0 degree, while it suddenly decreases to",
                "0% at 10.0 degree. The overall efficiency was found to",
                "be 64+-4% for the 78,80Ge+Pb scattering"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Si telescope consisted of 16 silicon detector.",
                "        To identify the outgoing particles by DeltaE-E",
                "        method"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NaI(Tl) calorimeter composed of 132 NaI(Tl)",
                "        crystals. To identify the outgoing particles",
                "        by DelataE-E method, and to determine the",
                "        scattering angle"
              ]
            }
          ],
          "CORRECTION": [
