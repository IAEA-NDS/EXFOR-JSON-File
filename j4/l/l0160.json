          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                " Bremstrahlung produced by electrons",
                "accelerated to 2.60+-0.03 MeV in converter target",
                "consisting of a 102 mu-m thick Au layer on a 1",
                "cm-thick water-cooled Cu backing. The electron",
                "current incident upon the converter was approximately",
                "65 mu-A throughout the experiment."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photon spectra that reached the transmission",
                "detection sheet after emission from each of the assay",
                "targets were calculated by Monte-Carlo method using",
                "code MCNPX."
              ]
            }
