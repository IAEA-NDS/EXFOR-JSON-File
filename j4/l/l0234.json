          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reagent quality dicyandiamide, C2H4N4, was pressed",
                "into disks of diameter 4.5 cm and thickness 1.2 cm;",
                "the mean weight of the samples was 24.86 g, the",
                "maximum deviation from this value being 0.03 g."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Two 2 in. x 2 in. NaI crystals."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The targets were irradiated in the X-ray beam",
                "of the University of Saskatchewan betatron at regular",
                "intervals of approximately 0.2 MeV from 10.5 to 25 MeV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The scale of the yield curve was determined by",
                "comparing the yields from thin samples of copper and",
                "dicyandiamide at 22 MeV with the aid of a flow",
                "counter; the yield from the reaction",
                "Cu63(gamma,n)Cu62 was assumed to be 2.25x10**8",
                "disintegrations per mole per 100 roentgens (dose)",
                " (Roalsvig et al. 1959.)"
              ]
            }
          ],
          "REL-REF": [
            {
