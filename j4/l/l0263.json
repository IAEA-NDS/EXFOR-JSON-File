          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USAISU"
              },
              "free_text": [
                " Experiment was performed at the Idaho",
                "Accelerator Center, using short-pulsed",
                "L-band-frequency electron linear accelerator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Depleted uranium target in the shape of a thin strip",
                "with dimensions of 4 x 2 x 0.05 cm3 and a mass of 7.6g",
                "Depleted uranium contains typically 0.22% of 235U."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Measurements were made using array of 14",
                "polyvinyltoluene scintillation detectors. Ten",
                "detectors had dimensions 76.2 x 15.2 x 3.8 cm and",
                "four were of 1/3 of the length, i.e. 25.4 cm. Long",
                "detectors were readout at both ends using",
                "photomultipliers. Short detectors were read out using",
                "single PMT. All detectors vere arranged in vertical",
                "position in a circle around the target at a distance",
                "of (125+-9) cm from the target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Neutron energy was determined using",
                "      time of flight"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence of two fission neutrons",
                "       was required"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                " Bremsstrahlung photons were produced by 10.5",
                "MeV electrons impinging on an Al radiator. A sweeping",
                "magnet was placed downstream from the bremsstrahlung",
                "radiator to remove charged particles from the photon",
                "beam. The photom beam then traveled through a series",
                "of polyethylene and lead collimators to define the",
                "photon beam."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "To account for efficiency and acceptance of detector",
                "array, correlations were calculated as a ratio of",
                "correlated neutron distribution from the same fission",
                "event and uncorrelated neutron distribution from two",
                "independent events."
              ]
            }
          ],
          "ERR-ANALYS": [
