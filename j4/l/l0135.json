          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The sample consisted of 82 .36 g of Si02+, enriched to",
                " 95.28 +/-0.05 % in 29Si. This was contained in a",
                " thin-walled lucite cylinder 2.5 cm in diameter by",
                " 10 cm long"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "PLA"
              ],
              "free_text": [
                " Unfolding of the yield curve to obtain the",
                " cross section was carried out using the",
                " Variable-Bin-Penfold-Leiss (VBPL) method developed",
                " at this laboratory"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Since the sample was in the form of Si02 it was",
                " necessary to allow for the neutron contribution from",
                " the oxygen. To do this a photoneutron yield curve of",
                " 160 was measured using a water target."
              ]
            }
          ],
