                "reaction": null
              },
              "free_text": [
                " Bremsstrahlung was produced by electrons",
                "from the NRCC linear accelerator impinging on an 0.8 mm",
                "tantalum radiator. The linac delivered electron",
                "bursts of 1 A of current and 6 ns duration at 720 Hz."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Each neutron detector consisted of a 25mm",
                "thick NE104 plastic scintillator of diameter 125mm",
                "viewed by two Phillips XP1040 photomultiplier tubes."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "7-N-15",
                "field_identifier": "ENR",
                "value": 0.98
              },
              "free_text": [
                " The 15N sample was in the form of",
                "135 g of ammonium sulphate which was 98% (15NH3)2SO4",
                "giving 30 g of 15N isotope."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight spectra were recorded at 8",
                "angles simultaneously over 10 m flight paths. Ground",
                "state cross sections were obtained by stepping the",
                "bremsstrahlung end point over the energy region of",
                "interest in 2 MeV intervals."
              ]
            }
          ],
