          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FISCT"
              ],
              "free_text": [
                " The Ilford emulsions loaded with bismuth were",
                "exposed to the beam of Illinois betatron. The plates",
                "were developed with the usual Occhialini temperature",
                "procedure, omitting however presoaking. The fissions",
                "were counted and recognized as such from the length",
                "of the track and from the density and aspect of the",
                "tracks."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " Ilford emulsions: Emulsion 200 micron thick",
                "of D1 type, contains 0.27 of a gram of bismuth per",
                "cm3 of emulsion, 1600 r of bremsstrahlung at the plate",
                " (measured with a Victorean trimble ionization",
                "chamber, behind a flat sheet of 1/8 inch Pb)."
              ]
            }
          ],
          "PART-DET": [
