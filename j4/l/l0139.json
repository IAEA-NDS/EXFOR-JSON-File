                "facility": [
                  "VDG"
                ],
                "institute": "1USAMIT"
              },
              "free_text": [
                " Experiment performed at the 4 MeV Van",
                "de Graaff electron accelerator at the High Voltage",
                "Research Laboratory at the Massachusetts Institute",
                "of Technology. Bremsstrahlung photons were produced by",
                "impinging an electron beam onto a radiator consisting",
                "of 102-mum Au backed by 1-cm Cu"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Scattered gamma rays were measured with two",
                "HPGe detectors at 40 to 50 cm from the target and",
                "+/- 120 deg with respect to the beam direction. Both",
                "detectors were encased in thick Pb shielding to",
                "reduce background and collimated to view only the",
                "NRF target"
              ]
            }
          ],
