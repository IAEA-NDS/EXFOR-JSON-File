          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Kinetic energy and fragment mass distribution for the",
                " spontaneous and photo-induced fission of 244Pu"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2BLGMOL"
              },
              "free_text": [
                " For 241Pu(nth,f) calibration runs a",
                " collimated n-beam of the reactor BR1 of SCK/CEN was",
                " used"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "244Pu, enrichment 88 %, consisting of a layer of 29",
                " microgram/cm**2 Pu sandwiched between two 30",
                " microgram/cm**2 thick polyimide backings with 20",
                " microgram/cm**2 Au",
                "241Pu, enrichment 91 %,used for calibration, thickness",
                " 40 microgram/cm**2. Targets were prepared by",
                " electrospraying of pu-acetate."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Two heavy ion detectors were mounted",
                " symmetrically on both sides of the fission target at",
                " 90 degrees. Calibration method PR137,B837,1965",
                "Detector calibration constants of Neiler et al.",
                " PR149,894,1966"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Surface barrier detectors"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For the calculation of the average total preneutron",
                " kinetic energy the measured value of 2.30+-0.19",
                " (C.J.ORTH,J,NSE,43,54,71) was used."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Each measurement was accompanied by a calibration",
                " run with 20 MeV bremsstrahlung. These runs were",
                " calibrated with 241Pu(nth,f) data."
              ]
            }
          ],
