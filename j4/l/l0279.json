              "coded_information": {
                "code": "30-ZN-0(G,TOT),,INT",
                "code_unit": [
                  {
                    "unit": "30-ZN-0(G,TOT),,INT",
                    "field": {
                      "reaction": "30-ZN-0(G,TOT)",
                      "target": "30-ZN-0",
                      "projectile": "G",
                      "process": "TOT",
                      "product": "",
                      "quantity": ",INT",
