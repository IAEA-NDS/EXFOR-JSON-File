          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " Nearly monochromatic polarized photon beam",
                "produced by Compton backscattering of laser beam on",
                "electrons, circulating in a synchrotron. The photon",
                "beam is macroscopically continuous but photons arrive",
                "in bunches 180 ns apart, since photons are scattered",
                "on internal bunched electrons beam. Photon rates of",
                "up to 10E+7 photons/s were used in these measurements."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Because of short flight path between the target and",
                "the neutron detector cells (406 mm), the TOF spectrum",
                "does not have sufficient resolution to unambiguously",
                "identify the (g,n0) neutrons. Therefore the light-",
                "output was used to eliminate neutrons from other",
                "reaction channels."
              ]
            }
          ],
