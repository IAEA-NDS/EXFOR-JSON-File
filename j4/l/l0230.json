          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Statistical and nonstatistical neutron decay of the",
                "giant electric dipole resonance of 208Pb"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
