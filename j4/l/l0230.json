          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "To obtain sufficient target material, two samples of",
                "radiogenic lead with different isotopic composition",
                "were used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Neutron energy was determined by time-of-flight",
                "over a 1.5-m flight path. With an overall time",
                "resolution of 1.8 ns (full width at half maximum),",
                "the neutron-energy resolution varied between 0.17 at",
                "2 MeV and 1.0 at 8 MeV. The differential cross",
                "section for the 208Pb(gamma,n)207Pb reaction was",
                "measured at three angles, 55, 90, and 125 degrees.",
                "The yield for Pb was found by combining data from the",
                "two targets."
              ]
            }
          ],
          "DETECTOR": [
            {
