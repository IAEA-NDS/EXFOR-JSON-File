          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of 265 ml of liquid neon of 99%",
                "purity. This was contained in a 5 cm diameter by 15 cm",
                "long thin walled Kapton cylinder."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                ""
              ]
