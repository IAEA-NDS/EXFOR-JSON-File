          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute differential cross section for ground",
                "state 19Ne was established by comparing the yields of",
                "ground state photoneutrons from 20Ne with the yield",
                "of photoneutrons from an identical volume of liquid",
                "deuterium contained in the same target assembly."
              ]
            }
          ],
