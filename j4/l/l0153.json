              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,194,49,1972",
                "code_unit": [
                  {
                    "unit": "J,NP/A,194,49,1972",
                    "doi": "10.1016/0375-9474(72)91051-2",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NP/A",
                        "number": null,
                        "volume": "194",
                        "part": null,
                        "issue": null,
