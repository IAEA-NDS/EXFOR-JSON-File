          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Differential polarization of photoneutrons from",
                "deuterium"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.Nath",
                "F.W.K.Firk",
                "H.L.Schultz"
