          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The radioactive sodium was dissolved in D2O 99% pure,",
                "contained in a glass sphere. Two sizes of the spheres",
                "were used, a large one of 3.25 cm radius and a small",
                "one of 1.93 cm radius. From the gamma intensity and",
                "neutron output it is clearly possible to measure",
                "cross-sections for photo-disintegration, by",
                "introducing the effective path for the gamma-rays in",
                "the source. For a homogeneous sphere such path is",
                "0.75 times the radius."
              ]
            }
          ],
