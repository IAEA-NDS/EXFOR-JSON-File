          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The self-attenuation correction accounts for photons",
                "absorbed by the target itself. This correction is",
                "typically <1% for the thin target used. In addition,",
                "a correction was applied to account for any",
                "fluctuations from the strict timing cycle of the",
                "cyclic activation equation. Once again, this",
                "correction was typically <1%. Lastly, coincidence",
                "summing corrections were applied using the algorithm",
                "of truecoinc. The summing correction factors for this",
                "experiment were typically found to be <3%."
              ]
            }
          ],
