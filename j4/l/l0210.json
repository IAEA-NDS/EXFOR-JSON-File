            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ACCEL"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " The capture gamma-ray facility at the",
                "Triangle Universities Nuclear Laboratory"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 25.4 x 25.4 cm NaI crystal having a plastic",
                "anticoincidence shield."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "1-H-2",
                "field_identifier": "ENR",
                "value": 0.92
              },
              "free_text": [
                " CD2 ~1 mg/cm2 and ~0.2 mg/cm2",
                "deuterium gas targets."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured was the energy distribution over an",
                "excitation range in 3He of Ex=7.5 to 15.4 MeV or direct",
                " absolute cross section from E = 3.0 to 14.8 MeV. The",
                "energy distribution was to 12 MeV with the CD2 target,",
                "while for the higher energies a deuterium gas cell",
                "was used and normalized to the solid target results",
                "at several overlapping energies. Since the",
                "spectrometer efficiency was determined at 15.1 MeV,",
                "the efficiencies at other energies have been obtained",
                "by correcting for the experimentally determined",
                "energy dependence of (1) the crystal response",
                "function, (2) the attenuation of the gamma-rays by",
                "the shielding in front of the crystal, and (3) the",
                "rejection rate due to the anticoincidence shield. For",
                "the lowest energy the efficiency was taken as 14.5%",
                " (a 15% correction relative to the calibration point).",
                "The energy loss of the primary proton beam in the",
                "target was also taken into account."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DTBAL"
              ],
              "free_text": [
                " The cross sections have been converted to",
                "that for photo disintegration using detailed balance."
              ]
            }
          ],
