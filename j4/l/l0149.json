          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the differential cross section for",
                "the two- body photodisintegration of 3He at",
                "theta(LAB) = 90deg using tagged photons in the",
                "energy range 14 - 31 MeV"
              ]
            }
          ],
