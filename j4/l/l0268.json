          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Tour high-purity germanium detectors with a",
                "relative efficiency of 55 % were used. Two detectors",
                "were placed in the plane perpendicular to the",
                "direction of the gamma-ray beam (theta = 90 deg),",
                "with one detector parallel (phi = 0 deg) and one",
                "detector perpendicular (phi = 90 deg) to the plane of",
                "polarization of the gamma-ray beam. Two detectors were",
                "placed at backward angles (theta = 135 deg with",
                "phi = 225 deg and 315 deg)."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " Quasi-monochromatic linearly polarized gamma-ray",
                "beams were produced from laser Compton backscattering",
                "of free-electron laser photons off relativistic",
                "electrons. The resulting gamma-ray beam was",
                "collimated by a cylindrical lead collimator with a",
                "diameter of 19.05 mm."
              ]
            }
