          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "MPH"
                ],
                "reaction": {
                  "code": "26-FE-56(N,G)26-FE-57",
                  "field": {
                    "target": "26-FE-56",
                    "projectile": "N",
                    "process": "G",
                    "product": "26-FE-57"
                  }
                }
              },
              "free_text": [
                "",
                "The gamma-ray source consisted of 0.5 kg of natural",
                "iron placed near the reactor core."
              ]
            }
          ],
