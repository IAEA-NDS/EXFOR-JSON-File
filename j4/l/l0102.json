              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Np target was in the form of 237Np02 powder, 4.5 cm",
                " diam. and 7.0 g/cm2 thick, inserted in a thin-walled",
                " aluminium container. In the case of 165Ho and 1599Tb,",
                " thick (9 g/cm2) and thin (2.7 g/cm2) metallic disks of",
                " diameters 8.0 and 3.5 cm respectively, were used as",
                " targets."
              ]
            }
