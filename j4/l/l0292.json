          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of gamma-induced reactions between 10 and",
                "19 MeV on natural zinc with potential application to",
                "67Cu production"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
