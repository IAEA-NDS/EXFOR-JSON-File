              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Each neutron detector consisted of a 25mm",
                "thick NE104 plastic scintillator of diameter 125mm",
                "viewed by two Phillips XP1040 photomultiplier tubes."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A thin (6 mm) disc target of natural sulphur (rhombic",
                "state) supported in the beam by a multi-armed",
                "rotating sample changer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The photonuclear target was viewed by eight",
                "well-collimated neutron time-of-flight detection",
                "systems with flight paths of 10 m. The detectors",
                "covered the laboratory angular range from 48 degree",
                "to 139 degree in 13 degree steps."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The contamination in each time-of-flight spectrum of",
                "counts from 34S (4.21% abundant in the natural",
                "sulphur sample) was removed by an analysis of the",
                "counts in the time region occurring before the",
                "arrival of the fastest neutrons from the 32S isotope."
              ]
            }
