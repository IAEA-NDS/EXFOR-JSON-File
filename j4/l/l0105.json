          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Kinetic energy and fragment mass distributions for",
                " 240Pu(0,f),239Pu(n,f) and 240Pu(g,f)"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "2BLGGHT"
              },
              "free_text": [
                " Bremsstrahlung produced by electron",
                " beam from a linear accelerator."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                " Bremsstrahlung"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 240Pu sample consisted of a 109 micro-g/cm-sq PuF3",
                " layer on a 40 micro-g/cm-sq polymide backing with 10",
                " micro-g/cm-sq gold. The isotopic composition was",
                " 0.68 % 239Pu, 98.47 % 240Pu, 0.48 % 241Pu and 0.37 %",
                " 242Pu.",
                "The 239Pu sample consisted of a 118 micro-g/cm-sq PuF3",
                " layer on the same backing as 240Pu. The isotopic",
                " abundance of 239Pu was 99.98 %. The diameter of the",
                " active layer was 25 mm in both cases"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Each spontanious fission experiment was accompanied by",
                " a calibration 240Pu(g,f) run with 20 MeV",
                " bremsstrahlung. The 240Pu photofission runs were",
                " calibrated by 239Pu(n,f) with thermal neutrons using",
                " a calibration procedure according to PR137,B837,1965",
                " and parameters from PR149,894,1966. These 239Pu(n,f)",
                " measurements were done with a well-thermalized and",
                " collimated neutron beam from the reactor."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                "2 Ortec F-series heavy ion detectors",
                " mounted symmetrically on both sides of the fission",
                " sample at a distance of 7 cm from the sample and at",
                " an angle of 90 degrees to the bremsstrahlung or",
                " neutron beam axis."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20060315,
                "history": "C"
              },
              "free_text": [
                " DR"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data corrected for",
                " - spontaneous fission of other pu-isotopes",
                " - drift in the measuring system"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uncertainty in target thickness was about 2 %"
              ]
            }
          ],
