              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " Monoenergetic photons, with high",
                "polarization and selectable energy, were produced at",
                "the HIgS facility using intracavity backscattering of",
                "free-electron-laser (FEL) photons from electrons in",
                "the DFELL storage ring. Photon energy was changed",
                "from 2 MeV to 4 MeV with resolution of 5 %. The",
                "linear polarization of the beam was almost 100%."
              ]
            }
