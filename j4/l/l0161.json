          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-235",
                "field_identifier": "ENR",
                "value": 0.937
              },
              "free_text": [
                "The 235U targets consisted of two",
                "or three 0.03-cm-thick square foils, each with a",
                "surface area of 2.54 x 2.54 cm2 and sealed with",
                "0.01-cm-thick plastic laminates.The targets were",
                "enriched to 93.7% in 235U with a total mass of 3.08 g",
                "or 4.62 g."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma rays from the target were measured with",
                "a HPGe detector array positioned about 4.8 m",
                "downstream from the collimator. The array consists",
                "of four HPGe detectors with 60% efficiency, positioned",
                "10 cm away from the center of the target and at an",
                "angle of 90 deg relative to the photon beam. Two",
                "detectors were located in the horizontal plane and two",
                "in the vertical plane."
              ]
            }
          ],
