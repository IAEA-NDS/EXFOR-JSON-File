          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "232Th and 197Au foils had thickness of 0.88 mg/cm2 and",
                "1.07 mg/cm2, respectively. All the targets used ranged",
                "in thickness from 0.6 to 1.1 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                ""
              ]
