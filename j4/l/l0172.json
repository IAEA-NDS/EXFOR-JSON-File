          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The bremsstrahlung beam was generated in a 0.020-inch",
                "platinum target and passed into a thick-walled",
                "ionization chamber. The counting rate per",
                "microcoulomb collected was also measured versus the",
                "voltage on the collecting and cancellation electrodes,",
                " and a suitable plateau was found. The fissioning",
                "effect of photoneutrons was estimated by using the",
                "235U sample."
              ]
            }
          ],
