          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of prompt neutron polarization",
                "asymmetries in photofission of 235,238U, 239Pu, and",
                "232Th"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
