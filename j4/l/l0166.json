          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,85,014605,2012",
                "code_unit": [
                  {
                    "unit": "J,PR/C,85,014605,2012",
                    "doi": "10.1103/PhysRevC.85.014605",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "85",
                        "part": null,
                        "issue": null,
                        "page": "014605"
                      },
                      "date": 2012
                    }
