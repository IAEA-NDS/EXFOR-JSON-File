          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The background of the system was taken with each change",
                "of the neutron capture target. To account for any",
                "potential scattering of neutrons in the beam by the",
                "fissile target, a copper foil of equal mass was  placed",
                "in the detector during the background measurements."
              ]
            }
          ],
