            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "693.9 mg of 26MgO enriched to 98.4% in 26Mg,",
                "combined with 455.5 mg of 11B. Diameter of the",
                "sample was about 20 mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                "Scattered photons were measured with four high-",
                "purity germanium (HPGe) detectors of about 100%",
                "efficiency relative to a 3 x 3 in. NaI detector.",
                "Two HPGe detectors were placed vertically at 90deg",
                "relative to the photon-beam direction at a",
                "distance of 28 cm from the target resulting in opening",
                "angles of 16deg. The other two HPGe detectors were",
                "positioned in a horizontal plane at 127deg to the beam",
                "at a distance of 32 cm from the target with opening",
                "angles of 14deg."
              ]
            }
          ],
