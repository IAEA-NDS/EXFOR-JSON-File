          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " The facility provides quasimonochromatic photon",
                "beams from laser-Compton backscattering (LCB) in the",
                "MeV range. The machine was operated in a new",
                "high-resolution mode. It reduces the spectral",
                "bandwidth of the photon beam to about 1.8% by",
                "optimizing the electron beam parameters and using",
                "narrower apertures for the Compton-scattering",
                "geometry at the expense of photon-flux intensity."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "SCIN"
              ],
              "free_text": [
                " Four high-purity germanium (HPGe)",
                "detectors, four lanthanum bromide (LaBr3) detectors."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "60-ND-150",
                "field_identifier": "ENR",
                "value": 0.936
              },
              "free_text": [
                " Target composed of 11.583(1) g",
                "of Nd2O3 enriched to 93.60(2)% of 150Nd."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear resonance fluorescence (NRF) experiment with",
                "quasimonochromatic linearly polarized photon beams",
                "below particle separation thresholds. The measured",
                "experimental average cross sections sigmaexp are the",
                "sum of nonresonant elastic scattering processes and",
                "NRF processes."
              ]
            }
          ],
