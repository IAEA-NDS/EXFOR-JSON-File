          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural LiF sample. Three LiF targets with thickness",
                "of 300 and 600 mu-g/cm2 deposited on a 1.3 mu-g/cm2",
                "mylar foil were used in experiment"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Charged particles - alpha and tritons from Li",
                "photodesintegration were detected using Si array",
                "SIDAR in lamp-shade configuration, consisting of 6",
                "upstram and 6 downstream Si strip detectors type YY1",
                "of 300, 500, and 1000 mu-m thickness. Each detector",
                "is tilted at 42deg from the plane perpendicular to",
                "the beam axis. YY1 detectors are segmented into 5 mm",
                "wide annular strips and cover an active area with an",
                "inner radius of 5 cm and an outer radius of 13 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector when placed at small angle to",
                "photon beam was used for detection of photons",
                "scattered from Cu sample. When placed in the",
                "attenuated beam it was used for photon energy",
                "measurement."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between upstream and downstream",
                "array of SIDAR detectors detecting alphas and",
                "tritons, respectively (or vice-versa) was required"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "79-AU-197(G,N)79-AU-196,,SIG",
