          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reaction thresholds were measured in the present",
                "work: High voltage x-rays have been used to",
                "redetermine the thresholds for the",
                "photodisintegration of beryllium and deuterium nuclei,",
                "giving 1.627+-0.010 MeV and 2.183+-0.012 MeV,",
                "respectively. The cross section ratio was deduced by",
                "comparing neutron counting rates 15 keV above the",
                "reaction thresholds. Therefore, the beryllium cross",
                "section energy was 1.642 MeV and deuterium cross",
                "section energy is 2.198 MeV."
              ]
            }
          ],
