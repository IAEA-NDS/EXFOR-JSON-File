              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The single-channel detector used with the",
                "36-in. magnetic spectrometer was replaced by a",
                "multichannel detector that allowed simultaneous",
                "collection of data at ten different values of",
                "electron momenta."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Authors used targets of Ca40, V51, Co59, In115, Sb121,",
                "123, and Bi209. The targets used were thin enough so",
                "that multiple scattering and straggling could not",
                "cause part of the beam to miss either the secondary",
                "emission monitor or the Faraday cup which were used",
                "to integrate the primary electron beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross sections were obtained by comparison with",
                "scattering from the proton."
              ]
            }
          ],
