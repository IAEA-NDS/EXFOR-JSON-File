          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties in this paper regarding the",
                "bremsstrahlung weighted cross section of the",
                "58Ni(g,n)57Ni cross section were not propagated. The",
                "reason for this lies in the normalization via the",
                "photon flux. The systematic errors from this flux are",
                "calculated the same. Then, as we normalize to that",
                "flux [i.e., take the ratios], errors stemming from",
                "this largely cancel and do not contribute",
                "substantially to the errors reported. Furthermore,",
                "note that the random statistical uncertainties of the",
                "simulations are very small in comparison to the",
                "experimental statistical uncertainties."
              ]
            }
          ],
