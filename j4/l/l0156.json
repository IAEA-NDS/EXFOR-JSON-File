          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " Monoenergetic photons with high polarization",
                "and selectable energy were produced at the HIgS",
                "facility using intracavity backscattering of free-",
                "electron-laser (FEL) photons from electrons in the",
                "DFELL storage ring."
              ]
            }
          ],
