          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SRING"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " Measurements were carried out at the",
                "High Intensity Gamma- Ray Source (HIgS) facility",
                "located on the campus of Duke University"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thick 9Be sample with thickness 3.14x10**23",
                "nuclei/cm2 (2.54cm), density 1.848 g/cm3 and mass",
                "9.012 g/mol"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Emitted neutrons from the (g,n) reaction were",
                "detected using a 4Pi assembly of 3He proportional",
                "counters, fabricated into a single unit. The assembly",
                "consists of 18 individual counters, arranged in two",
                "concentric rings. Each counter was filled with 3He",
                "gas at 6 atm pressure. The space around the counters",
                "was stuffed with polyethelene and graphite that",
                "thermalizes the emitted neutrons before they are",
                "captured (detected)in the 3He counters."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " The facility has a 0.24-1.2 GeV storage ring",
                "where quasi-monoenergetic gamma-beam is produced by",
                "the intracavity Compton back-scattering of the free",
                "electron laser photons from the electron bunches. The",
                "photon beam was defined by a 12-mm-diameter, 30.5 cm",
                "thick lead collimator."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "From the experimental arrangement designed to detect",
                "neutrons emitted in the reaction follows, that the",
                "actually measured cross section was 9Be(g,x+n), the",
                "most probable reaction being 9Be(g,n)8Be"
              ]
            }
          ],
