          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-section measurement of 9Be(g,n)8Be and",
                "implications for alpha + alpha + n --> 9Be in the r",
                "process"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "C.W.Arnold",
                "T.B.Clegg",
