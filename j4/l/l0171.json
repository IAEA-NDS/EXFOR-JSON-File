                "J.R.Tompkins",
                "C.R.Howell"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USANCA",
                "1USATNL",
                "1USADKE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,85,044605,2012",
                "code_unit": [
                  {
                    "unit": "J,PR/C,85,044605,2012",
                    "doi": "10.1103/PhysRevC.85.044605",
                    "field": {
