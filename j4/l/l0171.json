          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Realistic beam energy distribution was taken into",
                "account and cross sections were obtained by",
                "iteration procedure. Energy distribution of the",
                "photon beam was obtained by deconvolution of",
                "HPGe spectrum at each energy. The trial cross",
                "section was assumed to be sum of six Breit-Wigner",
                "functions. The trial cross section was iteratively",
                "adjusted until the global deviation between the",
                "calculated yield and the experimental yield was",
                "minimized. Bin width of 1.6 keV was used. The first",
                "point at the 1665.4 keV threshold was taken to be",
                "known for fitting purposes"
              ]
            }
          ],
          "ENDBIB": {
