          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " Quasi monoenergetic polarized gamma rays were",
                "obtained by Compton backscattering of photons from",
                "free electron laser on high energy electrons in",
                "electron storage ring. The target assembly was",
                "irradiated for about 9 h with approximately",
                " 1E+7 gamma/(cm2s)."
              ]
            }
