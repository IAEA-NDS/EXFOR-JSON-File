          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Exploratory study of fission product yield",
                "determination from photofission of 239Pu at 11 MeV",
                "with monoenergetic photons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
