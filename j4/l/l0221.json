                "institute": "1USATNL"
              },
              "free_text": [
                " Experiment was conducted at TUNL's",
                "High Intensity Gamma-Ray Source HIgS"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The previously unirradiated 239Pu target was",
                "provided by Los Alamos National Laboratory.",
                "Target of 1.24 cm diameter and mass of",
                "0.2337 g was sandwiched between Au foils of the same",
                "diameter and thickness of 0.01 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detectors of 60% efficiency in TUNLs low-",
                "background counting facility were used for the",
                "gamma-ray counting of the 239Pu target and gold",
                "monitor foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Sample was irradiated for 9 hours. After",
                "irradiation, the 239Pu target was gamma-ray counted",
                "over a period of 2 months for a number of different",
                "counting cycles ranging from hours (at the very",
                "beginning) to days to measure the decay of the",
                "induced activity of the fission products."
              ]
            }
          ],
