                ],
                "institute": "1USAPEN"
              },
              "free_text": [
                " Electrostatic accelerator -",
                " Van de Graaff."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "MPH"
                ],
                "reaction": {
                  "code": "1-H-3(P,G)2-HE-4",
                  "field": {
                    "target": "1-H-3",
                    "projectile": "P",
                    "process": "G",
                    "product": "2-HE-4"
                  }
                }
              },
              "free_text": [
                " Gamma-ray energy resolution",
                " about 250 keV at energy of 20.48 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Positron activity was determined by a",
                " coincidence detector, consisting of two 5 by 2 inch",
                " NaI crystals set on the annihilation radiation",
                " photopeaks. This detector was calibrated against a",
                " 18F positron source standardized in a 2pi flow",
                " counter.",
                "Gamma-rays were monitored by a 3 by 4 inch NaI crystal",
                " and calibrated with a 4.5 * 6 inch crystal whose",
                " response curve to the gamma rays was determined. The",
                " absorption coefficient of these photons in 'NaI' was",
                " determined by a good geometry transmission experiment"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "AR"
              ],
              "free_text": [
                " Positron annihilation radiation."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct measurement of positron activity."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Represents standard error due to counting",
                " statistics and other gaussian errors, but does not",
                " include the error involved in the determination of",
                " the absolute efficiency of the positron and photon",
                " detectors.",
                "The uncertainty in the calibration of the gamma-ray",
                " monitor was estimated to be less then 3.5%; the error",
                " attributed to efficiency of the positron detector",
                " varied from 1 to 3%."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Structure in the 12C(gamma,n)11C and 19F(gamma,n)18F",
                " reactions, although reported by other experiments,",
                " was not observed."
              ]
            }
          ],
