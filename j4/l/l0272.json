          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " LaBr3 scintillator crystal mounted to a",
                "photomultiplier tube (PMT)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The irradiation target consisted of a 1 cm right",
                "cylinder LaBr3 scintillator crystal which served as",
                "an active target. The LaBr3 crystal is manufactured",
                "with natural bromine which contains an abundance of",
                "50.69% 79Br, with the remainder composed of 81Br."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Solid-density active LaBr3 targets absorb",
                "real and virtual photons up to 35+-2.5 MeV and",
                "deexcite through gamma cascade into different states.",
                "For each irradiation case, intershot spectra were",
                "summed to create a shot-integrated decay spectrum."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
