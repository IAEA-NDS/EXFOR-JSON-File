          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR",
                "PROPC",
                "IOCH"
              ],
              "free_text": [
                " Large NaI(Tl) gamma-ray detectors.",
                "Gas ionization detector and multiwire proportional",
                "chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC",
                "TOF"
              ],
              "free_text": [
                " The reaction yields (YToF) were extracted",
                "from time-of-flight histograms which were constructed",
                "with cuts on measured recoil-particle energy,",
                "specific energy loss (dE/dx), and gamma-ray energy."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The E1 cross sections were determined from the",
                "equation sigma E1 = YToF/(beta[1+(eff. E2/eff.",
                "E2)(sigma E2/sigma E1)]), where YToF is the peak",
                "yield from the time-of-flight spectra, and beta is",
                "the product of the number of incident particles, the",
                "number of target particles per square centimeter, the",
                "total E 1 detection efficiency, the CSF, and the",
                "detector live-time fraction."
              ]
            }
          ],
