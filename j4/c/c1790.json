          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " A primary beam of 18-O with energy of 120 MeV/A",
                "bombarded a 9Be target. Projectile fragmentation",
                "products 12Be were selected by the A1900 separator. The",
                "secondary 12Be beam had intensity of 1E+5 ions/s,",
                "purity of 87%, and momentum acceptance of +-0.5%."
              ]
            }
          ],
