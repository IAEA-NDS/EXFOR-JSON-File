          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "CSICR"
              ],
              "free_text": [
                " Charged particles produced in the",
                "reaction were detected in the HiRA array,which",
                "consisted of 16 dE-E [Si-CsI(Tl)] telescopes located",
                "60 cm downstream of the target. The telescopes were",
                "arranged in four towers of four telescopes each,",
                "with two towers on each side of the beam. The array",
                "subtended the angular region between 2.7deg and",
                "24.8deg. Each telescope consisted of a 1.5-mm-thick,",
                "double-sided Si strip dE detector followed by a 4-cm-",
                "thick CsI(Tl) E detector. The dE detectors are 6.4",
                "cm x 6.4 cm in area with the faces divided into 32",
                "strips."
              ]
            }
          ],
