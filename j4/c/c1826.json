          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated-polyethylene (CD2) with an areal density",
                "of 251 +-5 mu -g/cm2 and the D:H ratio enriched to 98%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Charged particles were detected with a TESCA",
                "detector array, consisting up to 16 Si strip",
                "detectors with 16 strips and thickness of 300+- 10",
                "mu-m. Detector array was positioned upstream of the",
                "CD2 target at distances of 2.8, 5, 12 and 20 cm,",
                "covering laboratory angles from 102 to 165 deg. TESCA",
                "covered total solid angles between 0.68 and 1.86 sr,",
                "depending on the distance between the array and the",
                "target."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The primary beam of 14C from K500 cyclotron was",
                "tuned through MARS spectrometer with no primary",
                "production target in place."
              ]
            }
          ],
