          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of the natTi(d,x)49V excitation",
                "function by liquid scintillation analysis"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "C.R.Kleinfeldt",
                "V.S.Bodnar",
                "S.D.Essenmacher",
                "A.M.Miller",
                "G.M.Brown",
                "G.F.Peaslee",
                "G.W.Severin"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAMSU",
                "1USANOT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/B,562,165652,2025",
                "code_unit": [
                  {
                    "unit": "J,NIM/B,562,165652,2025",
                    "doi": "10.1016/j.nimb.2025.165652",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NIM/B",
                        "number": null,
                        "volume": "562",
                        "part": null,
                        "issue": null,
                        "page": "165652"
                      },
                      "date": 2025
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "#doi:10.1016/j.nimb.2025.165652"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USANOT"
              },
              "free_text": [
                " The Nuclear Science Laboratory at the",
                "University of Notre Dame using a Pelletron tandem",
                "accelerator (HV FN type)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": [
                "EN-RSL"
              ],
              "free_text": [
                " The beam was tuned to the energies within 1%",
                "uncertainty, and the current was recorded every",
                "second using a Digital Current Integrator (ORTEC 439",
                "Digital Current Integrator)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A stack of thin titanium foils (Alfa-Aesar, 99.94%",
                "metals basis, 0.025 mm thick), containing four to",
                "eight foils each, depending on the incident deuteron",
                "beam energy. Each foil mid-thickness taken to be 7.15",
                "mg/cm2."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The cross-sections were calculated as:",
                "sigma=A/(I*rho*(1-exp(-lambda*t))), using the",
                "absolute activity (A) at the end of bombardment, the",
                "average deuteron current (I), the areal number",
                "density of the foil (rho), in atoms/cm2), the decay",
                "constant of the radionuclide of interest (lambda),",
                "and the irradiation duration (t)."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20251211,
                "history": "C"
              },
              "free_text": [
                " BP"
              ]
            }
          ],
          "ENDBIB": {
