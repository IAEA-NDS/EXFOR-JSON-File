          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Formation cross-sections and chromatographic",
                "separation of protactinium isotopes formed in",
                "proton-irradiated thorium metal"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "V.Radchenko",
                "J.W.Engle",
