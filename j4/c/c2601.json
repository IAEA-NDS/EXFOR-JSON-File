          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thorium metal foil with purity of 0.9995, thickness",
                "of a (0.25+-0.01) mm and diameter of (60.0+-0.1) mm",
                "was hermetically sealed within a (127+-6) mu-m thick",
                "Inconel 600 capsule. Inconel was used as a monitor",
                "foil. The thorium foil was dissolved after irradiation",
                "in 10 M HNO3 + 12.5 mM HF, evaporated to a dry thorium",
                "nitrate salt and solved in a final (86.0+-0.2) mL",
                "volume of 1 M HNO3. Aliquots of this solution were",
                "analyzed by gamma-ray spectroscopy."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A N-type coaxial HPGe detector was used"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Spectra were acquired multiple times over",
                "a period of 7 to 269 d after the end of irradiation"
              ]
            }
          ],
