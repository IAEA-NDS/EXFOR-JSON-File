          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclide production cross sections from irradiation of",
                "thorium by 438 MeV protons and a comparison to FLUKA",
                "and GEANT4 simulations"
              ]
            }
          ],
