          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Branching ratio Galpha/Ggamma of the 4.033 MeV 3/2+",
                " state in 19Ne"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAANL"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 20Ne beam bombarded a 1.5-mm-long gas cell filled",
                " with 3He at 700 mbar."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The gas target was cooled to liquid nitrogen",
                " temperature, resulting in a 3He thickness of 50",
                " microg/cm2. The pressure in the 3He target was kept",
                " constant to better than 1%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The outgoing a particles from the",
                " 3He(20Ne,a)19Ne reaction were detected in a Si strip",
                " detector telescope consisting of a 500-mm-thick, 40x40",
                " mm2 DE detector backed by a 50x50 mm2, 300-mm-thick",
                " Eres detector tilted by an angle of 50 degree in order",
                " to increase its effective thickness for the incident",
                " particles to about 500 mm. The DE detector was",
                " subdivided in the front and back into 32 vertical and",
                " horizontal strips (1-mm width) which were read out",
                " individually."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inverse kinematics"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The telescope was calibrated using a 228Th a source and",
                " energy resolutions of 45 keV for the DE and Eres",
                " detectors were obtained."
              ]
            }
          ],
