              },
              "free_text": [
                " The Oak Ridge tandem Van de Graaff",
                "accelerator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The radium target consisted of a 50 microg/cm2",
                "deposit of RaBr2, vacuum-evaporated onto a 20",
                "microg/cm2 carbon backing."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier detectors were",
                "placed at 90 degrees to the proton beam in the",
                "compound-nucleus c.m. system, one on either side of",
                "the radium target at a distance of 7.5 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Correlated fragment pulse heights from the",
                "two surface barrier detectors were recorded event-",
                "by-event in 256 x 256 channels on punched paper tape.",
                "Neutron emission from the fragments, however, was not",
                "taken into account, and the masses of the present",
                "work are the so-called provisional masses."
              ]
            }
          ],
