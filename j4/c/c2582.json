          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Windowless gas target filled with H2 gas. Experiment",
                "was performed at several gas pressures between 2 and 5",
                "Torr. The center of mass target thickness was in the",
                "range of 7 - 20 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Selected reaction recoils (23Na) were",
                "transported through DRAGON recoil separator,",
                "consisting of two magnetic dipoles and two",
                "electrostatic dipoles complemented with focusing",
                "elements."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " Windowless gas target is surrounded by a 4PI",
                "gamma detector array, coinsisting of 30 BGO",
                "scintillation detectors. Total solid angle coverage",
                "of the array was 92%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " A pair microchannel plate detectors were used",
                "for local time of flight measurement for recoil",
                "identification"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " A double-sided silicon strip detector placed",
                "in the DRAGON focal plane where the recoils were",
                "stopped and their kinetic energy measured."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inverse kinematics was used"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between gamma rays in BGO array",
                "and recoils detected in DRAGON focal plane detectors"
              ]
            }
          ],
