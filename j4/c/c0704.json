          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "30-ZN-64",
                "field_identifier": "ENR",
                "value": 0.93
              },
              "free_text": [
                "  Natural zinc foils and foils",
                "enriched to 93% in 64Zn.",
                " Zinc foils were plated on thin gold foils.",
                " Areal density of 64Zn enriched foils 1-2 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR",
                "SCIN"
              ],
              "free_text": [
                " positron spectrum was measured with 2x2-",
                "in. plastic scintillation counter. Gamma ray sectra",
                "were investigated both with a 1.5x1.5-in. NaI",
                "well-counter and a 4x4-in. NaI scintillation counter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Immediately after irradiation, the target was",
                "chemically processed to separate germanium. The",
                "plated zinc was dissolved off its gold backing in",
                "concentrated HCI in the presence of Ge carrier.",
                "KCl(O)3 was added to reoxidize the germanium to the",
                "+4 state, and Ge(Cl)4 was distilled from the solution."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Targets stacked between aluminum degrader foils."
              ]
            }
          ],
