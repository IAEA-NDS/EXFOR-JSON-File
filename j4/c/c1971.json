          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "PGS",
                "INTAD"
              ],
              "free_text": [
                " Numerical calculations using GEANT were",
                "used to extrapolate the efficiency function to 3.3",
                "MeV using a functional form eff = exp(a0 +",
                "a1*ln(Eg/E0)), where E0 is an arbitrary reference",
                "energy and a0 and a1 are fitted parameters."
              ]
            }
          ],
