          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "9Be reaction target with thickness of 188 mg/cm2 was",
                "located at the target position of the S800",
                "spectrograph."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Reaction products were momentum analyzed in",
                "S800 superconducting magnetic spectrometer. Particles",
                "were identified using detection system in located in",
                "spectrometer focal plane"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A gamma-ray array GRETINA, consisting of 12",
                "detector modules, each with 36-fold segmentation was",
                "used for gamma ray detection. Detector modules were",
                "arranged in two rings with four located at 58deg and",
                "eight at 90deg with respect to the beam axis."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DRFTC",
                "IOCH",
                "SCIN"
              ],
              "free_text": [
                " The focal plane detector system",
                "consists of a pair of cathode readout drift chambers",
                "located about 1 m apart, followed by a multi-",
                "segmented ion chamber and four large plastic",
                "scintillators of thicknesses 3 mm, 5 cm, 10 cm and 20",
                "cm, respectively."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between gamma rays and reaction",
                " residues was required"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " Online pulse-shape analysis of signals from",
                " segmented HPGe detector provided the gamma-ray",
                " interaction points. Recoiled nuclei 40SC travel",
                " at about 30% of the speed of light."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Interaction point as well as tracking of incident",
                "beam was used for Doppler reconstruction of gamma",
                "ray energy"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " The 38Ca secondary beam was produced by",
                "fragmentation of a stable 40Ca beam at energy of",
                "140-MeV/nucleon impinging on a 799 mg/cm2 9Be",
                "production target and separated in the A1900 fragment",
                "separator. Purity of 38Ca secondary beam was about 86%."
              ]
            }
          ],
