          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "ANASEN active target detector filled with pure",
                "deuterium gas at a pressure of 400 Torr. The length",
                "of the active area is 340 mm, the beam stopped about",
                "5cm before the end of the detetcor."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MWPC",
                "SISD",
                "CSICR"
              ],
              "free_text": [
                " Active target detector array ANASEN",
                "has cylindrical symetry with incomong beam on its",
                "axis. The innermost layer is a multi-anode",
                "position-sensitive proportional counter MWPC which",
                "enables the active-target mode. Anodes are arranged",
                "cylindrically at radial distance of 30 mm. At radii",
                "of 88 mm from the beam axis, three identical rings of",
                "12 rectangular Si strip detectors are surrounding the",
                "proportional counter Si strip detectors are backed by",
                "CsI(Tl) crystals of trapezodial-bar geometry."
              ]
            }
          ],
