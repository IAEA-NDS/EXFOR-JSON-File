          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission Product Yields of Uranium Bombarded with",
                "Deuterons of Various Energies (20-190 MeV)"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
