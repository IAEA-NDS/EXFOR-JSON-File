          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Carbon analysis using energetic ion beams"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/B,222,538,2004",
                "code_unit": [
