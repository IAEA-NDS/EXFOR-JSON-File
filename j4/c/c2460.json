          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental identification of the T = 1, Jpi = 6+",
                "state of 54Co and isospin symmetry in A = 54 studied",
                "via one-nucleon knockout reactions"
              ]
