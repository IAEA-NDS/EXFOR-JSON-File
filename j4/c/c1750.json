          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polyethylene plastic (CH2) with thickness of 1.6",
                "mg/cm2, mounted together with a thin gold target",
                "with thickness of 350 mu- g/cm2. Simultaneous",
                "elastic-scattering measurement of 8Li on carbon and",
                "gold targets was used to obtain the overall",
                "normalization"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Three telescopes covering the range of",
                "laboratory angles from 20deg to 60deg. The",
                "telescopes consisted of 20 mu-m Si dE detectors with",
                "an area of 300 mm2 backed by 1000 mu-m thick Si E",
                "detectors. The telescopes had rectangular apertures",
                "that subtended a solid angle of about 12 msr. 12 msr."
              ]
            }
