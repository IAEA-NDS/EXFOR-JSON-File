          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A beam of protons with center-of-mass energies",
                "between 1.5 and 4.5 MeV was impinged upon a target of",
                "isotopically enriched 94Mo. The beam current ranged",
                "from 5-900 nA and was increased at lower beam",
                "energies to compensate for the decreasing reaction",
                "cross section. The uncertainty in the center-of-mass",
                "energy comes from a combination of the uncertainty in",
                "the beam energy resolution and the energy loss",
                "through the target. The beam resolution from the 5U",
                "has an uncertainty of 1-2 keV and the energy loss",
                "through the targets ranged between 20 and 60 keV."
              ]
            }
          ],
