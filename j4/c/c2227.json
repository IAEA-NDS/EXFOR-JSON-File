          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Evaporation residues and fission fragments were",
                "detected in two 300 mu-m, 600 mu-m2 Si counters,",
                "placed at forward angles on either side of the beam",
                "axis and were moved during the experiment to sample",
                "the angular region 8 - 20 deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " Secondary electrons liberated during the",
                "passage of incident particles through the Au surface",
                "layer of each Si detector were accelerated by a 4 kV",
                "potential into double-microchannel-plate assemblies.",
                "Timing signals from these assemblies were used to",
                "measure the time of flight of detected particles."
              ]
            }
          ],
