              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " An array of 300 microm and 1001 microm thick",
                "  Si surface barrier detectors separated by 10 degree",
                "  were used."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural metallic calcium (96.78 % 40Ca), about 125",
                " microg/cm2, from a tantalum boat onto 15 microg/cm2",
                " carbon backing under vacuum and transferring the",
                " targets directly to the scattering chamber without",
                " breaking vacuum. Because KF (93.7 % 39K) is",
                " hygroscopic, the same process was used to make 39K",
                " (150 microg/cm2) targets on carbon backings (75",
                " microg/cm2)."
              ]
            }
