          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic pd Scattering at 316, 364, 470, and 590 MeV",
                "in the Backward Hemisphere"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
