          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct cross-section measurement of the weak r-",
                "process 88Sr(alpha,n)91Zr reaction in nu-driven",
                "winds of core-collapse supernovae"
              ]
            }
          ],
