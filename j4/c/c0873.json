          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton Capture Gamma Rays from the Reaction",
                " 31P(p,gamma)32S Leading to the Ground and First",
                " Excited States of 32S"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1CANCRC"
              },
              "free_text": [
                " Electrostatic accelerator",
                "Protons energy analyzed by 90-degree magnet."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam current in the range 5 - 20 microamps.",
                " Proton energy held constant to ~0.1%."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Zn3P2 evaporated on 20-mil tantalum backings to a",
                " thickness of about 700 eV for the yield measurements",
                " and about 10 keV thickness for angular distribution",
                " measurements."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                "",
                "Beam defined on target to about 1/4 inch diameter by a",
                " 1/8 inch aperture in a 20-mil tantalum disk situated",
                " about 8 feet from the target.",
                "Target thickness measured in an additional measurement",
                " of energy loss in the target by comparing the step in",
                " the thick-target yield curve with the area under the",
                " thin-target yield for the well-isolated resonance at",
                " 1.248 MeV."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma-ray data were corrected for absorption in the",
                " tantalum backing of the target (correction on order",
                " of 10%)."
              ]
            }
          ],
