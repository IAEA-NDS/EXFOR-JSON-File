                  "CYCLO"
                ],
                "institute": "1USABRK"
              },
              "free_text": [
                " Experiment was carried out at the 88-",
                "Inch Cyclotron at Lawrence Berkeley National",
                "Laboratory."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Outgoing light ions were detected using",
                "the Silicon Telescope Array for Reaction Studies",
                "STARS. it consists of two segmented Micron S2 silicon",
                "annular detectors arranged in a telescope formation.",
                "The telescope arrangement allows particle",
                "identification utilizing the characteristic energy",
                "deposition of the different mass particles. The",
                "excitation energy of the residual nucleus can be",
                "reconstructed from the energy of the outgoing light",
                "ion."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma rays were measured in coincidence with",
                "the detected particles using the Livermore Berkeley",
                "Array for Collaborative Experiments LIBERACE. The",
                "LIBERACE array consisted of five high-purity",
                "germanium clover detectors which were arranged around",
                "the STARS chamber. All detectors were in the same",
                "plane. Two detectors were placed at 90deg, two at",
                "forward angles of 50deg, and one at a backward angle",
                "of 130deg."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence of light particle and gamma ray",
                "was required."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data is normalized to the area of the corresponding",
                "theoretical curve, they are not measure of absolute",
                "cross section"
              ]
            }
