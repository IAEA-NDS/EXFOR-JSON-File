          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron transfer in the 13C + 197Au reaction from",
                "gold isotope residuals"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "B.H.Daub",
                "D.L.Bleuel",
