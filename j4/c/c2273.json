              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,96,024602,2017",
                "code_unit": [
                  {
                    "unit": "J,PR/C,96,024602,2017",
                    "doi": "10.1103/PhysRevC.96.024602",
                    "field": {
                      "reference_type": "J",
                      "reference": {
