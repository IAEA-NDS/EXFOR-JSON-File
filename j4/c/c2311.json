          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Because of the thickness of the radium deposit",
                " (about 0.5 mg/cm2) and the overlapping gold, the",
                "fission fragments emitted at oblique angles to the",
                "foil normal could not escape from the target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                " After bombardment the catcher foil was",
                "dissolved in an acid or basic solution containing",
                "carrier amounts, usually 10 mg, of the fission",
                "product elements to be separated. The type of solvent",
                "used depended on the elements to be separated. Each",
                "sample was counted in one of a set of four end-window",
                "G-M counters with nearly identical shelf assemblies."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The decay curves were plotted and analyzed in",
                "the usual way, and saturation counting rates were",
                "determined for each radioactive species."
              ]
            }
