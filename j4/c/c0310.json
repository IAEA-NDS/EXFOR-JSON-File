          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute cross sections were corrected for the dead-",
                "time losses; no correction was made for neutron",
                "losses in the n-gamma discrimination analysis; the",
                "maximum neutron attenuation through the air was",
                "estimated to be less than 2% for the lowest neutron",
                "kinetic energy (5 MeV)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative uncertainties were primarily statistical and",
                "included contributions from the shadow-bar background",
                "subtractions. They were typically a few percent and",
                "small compared to the overall scale uncertainties.",
                " Scale uncertainties (%) were as follows:",
                " -  beam integration               5",
                " -  target thickness               5",
                " -  detector efficiency          7 - 10",
                " -  neutron attenuation            2",
                " -  solid angle                  < 0.5",
                " -  live time                    < 1.0",
                " -  n-gamma losses               < 1.0",
                " Overall                          12"
              ]
            }
          ],
