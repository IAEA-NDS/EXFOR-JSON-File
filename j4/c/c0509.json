          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Astrophysical S factors for the 9Be(p(pol),gamma)10B",
                " reaction."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "ATOMI"
                ],
                "reaction": null
              },
              "free_text": [
                " TUNL Atomic Beam Polarized Ion Source (ABPIS).",
                "30 microA polarized proton beam, polarization switched",
                " at a rate of 10Hz in order to minimize systematic",
                " errors."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target was a 1 cm x 1 cm x 0.5 mm thick sheet of",
                " 99.5 % pure 9-Be, which stopped the beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA"
              ],
              "free_text": [
                " Bombarding of thin targets with protons",
                " and observation the gamma spectra.",
                "Direct measurements of the reaction yields for up and",
                " down proton polarization spins."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detectors whose front faces were 12.7",
                " cm from the target at angles of 62, 90, and 120",
                " degree."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The observed analyzing powers",
                " are explained, within experimental uncertainty, as",
                " arising from the interference of the E1 direct",
                " capture amplitudes with the tails of nearby p-wave",
                " and s-wave resonances."
              ]
            }
          ],
