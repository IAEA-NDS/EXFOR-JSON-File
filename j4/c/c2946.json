          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New constraints on sodium production in globular",
                "clusters from the 23Na(3He,d)24Mg reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
