          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For these runs targets were ~25 microg/cm2 of Bi on",
                "aluminum leaf backing."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " Angular distributions of 212mPo were determined",
                "using two different methods. In the first method a",
                "thin ~5-10 microg/cm2 Al leaf backed target was",
                "placed 2.5 cm from an Al leaf catcher foil. A",
                "collimator in front of the catcher foil allowed us to",
                "select 2 degrees increments of recoils from the",
                "target. In the second method a position sensitive",
                "detector was used to determine the recoil",
                "distributions of 212mPo. The target was irradiated",
                "for a pre-determined interval. After the irradiation",
                "the catcher was moved in front of a position-sensitive",
                "detector. Position signals from the detector in",
                "coincidence with certain alpha-particle energy groups",
                "were either stored directly in a pulse-height",
                "analyzer or divided by the corresponding cc-particle",
                "energy signal and the quotient then stored in the",
                "pulse-height analyzer."
              ]
            }
          ],
