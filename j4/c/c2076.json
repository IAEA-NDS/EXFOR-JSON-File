              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Evaporated Na2WO4 onto 38mm x 38 mm x 0.3-mm thick",
                "tantalum backings made from high-purity (99.993%)",
                "tantalum. Targets had thicknesses on the order of dE",
                "= 50 keV at a proton bombarding energy of 150 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The target was viewed by a 135% coaxial HPGe",
                "detector, 89.0+-0.5 mm in diameter, and 91.6+-1.0",
                "mm in length, located at 0deg. HPGe was used to detect",
                "characteristic gamma i.e. 1369 keV"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " HPGe detector was surrounded with annular",
                "NaI(Tl) detector which detected fraction of the decay",
                "energy associated with the deexcitation of the",
                "11831-keV state in coincidence with the full energy",
                "of a characteristic cascade transition (e.g. the 1369-",
                "keV transition), measured in the HPGe detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between characteristic gamma",
                "radiation detected in HPGe and high energy gamma",
                "transitions detected in NaI(Tl) was required"
              ]
            }
          ],
