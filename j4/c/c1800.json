          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A mixed 7BeO/7LiO beam was injected into the Tandem",
                "Van de Graaff  accelerator where the molecules were",
                "broken up during stripping at the  terminal. Positive",
                "7Be/7Li ions were then further accelerated  before",
                "delivery to the DRS. Beam currents peaked  at about",
                "2E+7 7Be/s with typical beam compositions of  7Li/7Be",
                "= 7/1."
              ]
            }
