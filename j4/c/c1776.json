                ],
                "institute": "1USABRK"
              },
              "free_text": [
                " Experiment performed at the Lawrence",
                "Berkeley National Laboratory's 88-Inch Cyclotron using",
                "newly implemented 242Pu target facility at the",
                "Berkeley Gas-filled Separator (BGS)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 9.5-cm diameter rotating target wheel containing",
                "four target segments with 440, 340, 320, and 270",
                "mu-g/cm2 of 242Pu in form PuO2 as PuO2 on 2.4 mu-m",
                "thick Ti backing. Pu target was enriched in 242Pu",
                "more than 99.9%.The targets were prepared by",
                "molecular plating. 48Ca beam entered BGS through a",
                "45 mu-g/cm2 thick carbon window."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MWPC",
                "SISD"
              ],
              "free_text": [
                " Focal plane detector consisted of",
                "multiwire proportional counter, used to determine",
                "time of flight and location of impact of evaporation",
                "residues. Second focal plane detector consists of",
                "48 Si-strips (three 6x6cm2 cards, sixteen strips each),",
                "which provide horizontal resolution and was used for",
                "implantation of evaporation residues. Vertical position",
                "was determined by resistive charge division within",
                "each strip."
              ]
            }
          ],
          "METHOD": [
            {
