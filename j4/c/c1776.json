              "coded_information": null,
              "free_text": [
                "48Ca11+ beam produced by Advanced Electron Cyclotron",
                "Resonance source was accelerated to 263 MeV by the",
                "LBNL 88-Inch Cyclotron with typical intensities of",
                "300 - 400 pnA."
              ]
            }
