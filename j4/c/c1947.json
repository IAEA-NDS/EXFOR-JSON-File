          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " Recoiling 3He ions from the",
                "28Si(p,3He) reaction were detected at forward",
                "laboratory angles using the highly segmented Silicon",
                "Detector Array (SIDAR), covering laboratory angles",
                "18deg to 50deg. For particle identification a 100",
                "mu-m dE detector was backed by 1000 mu-m total energy",
                "E detector. A modified implementation of the Oak",
                "Ridge Rutgers University Barrel Array (ORRUBA) was",
                "used to cover angles between the edge of SIDAR and",
                "90deg in the laboratory. ORRUBA array was used to",
                "detect decay protons from highly excited heavy recoil",
                "nucleus 26Al."
              ]
            }
          ],
