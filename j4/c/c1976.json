                "institute": "1USANOT"
              },
              "free_text": [
                "Experiment performed at FN Tandem",
                "accelerator at the University of Notre Dame using",
                "TwinSol facility"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched 58Ni foil, with thicknesses of 426 mu-g/cm2,",
                "used for the measurements at 12.7 and 11.5 MeV",
                "Enriched 58Ni foil, with thicknesses of 924mu-g/cm2,",
                "used for the measurements at 10.2 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Protons were detected using dE-E",
                "telescopes optimized to detect protons at backward",
                "angles. Their dE detectors stopped backscattered low",
                "energy alpha particles. Telescopes were placed at",
                "backward angles of 117, 132, 147, and 162 deg. Two",
                "additional dE-E telescopes were placed at forward",
                "angles of +41 deg and -47deg for detection of",
                "elastically scattered particles."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                "Secondary beam produced by elastic scattering",
                "of primary He3 beam on Be foil was used in this",
                "experiment. Elastically scattered primary beams of",
                "16.5, 15.2, and 13.9 MeV, produced secondary beams",
                "with laboratory energies at the center of the target",
                "of 12.7, 11.5, and 10.2 MeV, respectively. This method",
                "was used, because it served the additional purpose of",
                "determining the contribution of the He3 contaminant",
                "beam to the proton yield in companion experiment."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for backward scattered proton from target",
                "holder and shielding."
              ]
            }
          ],
