          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative normalization of 13,14,15C measurements",
                "was achieved by using elastically scattered particles",
                "detected by Si detectors at forward angles of 35 deg."
              ]
            }
          ],
