          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Four 5 x 5 cm2 Si surface barrier detectors",
                "subdivided into four quadrants surrounded the 232Th",
                "target with two pairs opposite to each other,",
                "covering the angular range between 25deg and 70deg",
                "and between 115deg and 160deg."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 15C beam was produced via the in-flight technique",
                "by bombarding a cryogenically cooled gas cell filled",
                "with deuterium at 1.4 atm with an intense (100 pnA)",
                "14C beam delivered by the ATLAS accelerator. The 15C",
                "ions produced via the d(14C,15C)p reaction were",
                "focused with a superconducting solenoid located",
                "behind the gas cell and rebunched with a",
                "superconducting resonator.Energy changes for",
                "excitation function measurement were achieved by Au",
                "energy degrading foils."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
