          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " A radioactive 13N7+ beam was created with a",
                "50 MeV 12C5+ primary beam using the 12C(d,n)13N",
                "reaction via the in-flight technique. A magnet is used",
                "for separating the 13N beam from the primary 12C beam",
                "The beam energy of the secondary 13N was 34.6*-0.7 MeV"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Active target - the filling of MUSIC chamber was used",
                "as the sample. Detector was filled with He-Kr mixture",
                "with 95%-5% by volume. The pressure inside detector was",
                "measured to be 402 torr."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " The cross section was measured using the multi-",
                "sampling ionization chamber.The anode is segmented",
                "in 18 strips, each with a width of 15.78 mm. The 16",
                "center strips are subdivided in asymmetric left and",
                "right sections. Each strip corresponds to a different",
                "incident energy."
              ]
            }
          ],
