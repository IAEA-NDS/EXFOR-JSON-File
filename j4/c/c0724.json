          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "26-FE-54",
                "field_identifier": "ENR",
                "value": 0.9506
              },
              "free_text": [
                " Iron target, electroplated onto",
                "gold foils. Areal density 10.2-10.9 mg/cm2."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "26-FE-56",
                "field_identifier": "ENR",
                "value": 0.0484
              },
              "free_text": [
                ""
