          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Detection of delayed fission and half life",
                "determinations were made by a direct electronic",
                "measurement of the elapsed time between arrival of a",
                "burst of particles at the target and the time of",
                "fission decay. The time distribution of fission",
                "events is determined by using fast signals from a",
                "semiconductor fission detector, and a signal from the",
                "cyclotron oscillator or Van de Graaff beam chopper to",
                "start and stop, respectively a time-to-amplitude",
                "converter."
              ]
            }
          ],
