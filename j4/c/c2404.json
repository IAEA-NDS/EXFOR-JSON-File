          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USACAL"
              },
              "free_text": [
                " The Kellogg Laboratory 2-Mv",
                "electrostatic generator."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "CSICR"
              ],
              "free_text": [
                " A CsI(Tl) crystal and DuMont 6291",
                "photomultiplier were used to detect those particles",
                "which pass through the spectrometer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The magnetic spectrometer was set to count the doubly",
                "charged alpha particles emerging from the target."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thus the number of doubly charged alpha particles",
                "which emerge from the target is less than the actual",
                "number produced by the reaction in the target.",
                "Therefore, the number of alpha particles which are",
                "counted must be corrected for this effect in order to",
                "obtain the true yield."
              ]
            }
          ],
          "HISTORY": [
