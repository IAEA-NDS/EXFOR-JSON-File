          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental Study of the O17(p,alpha)N14 Reaction",
                "and a Calculation of the Rate of this Reaction in the",
                "CNO Cycle in Stars"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.E.Brown"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR,125,347,1962",
                "code_unit": [
                  {
                    "unit": "J,PR,125,347,1962",
                    "doi": "10.1103/PhysRev.125.347",
                    "field": {
