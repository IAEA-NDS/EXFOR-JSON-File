          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A monoenergetic He+ beam with incident energy in the",
                "  range 1.0-3.0 MeV impinges on the sample"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The energy spectrum of the forward-scattered",
                " deuterons is obtained using a surface barrier",
                " detector."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two detectors were used to allow simultaneous",
                " collection of Elastic Recoil Spectrometry (ERS) and",
                " Rutherford Backscattering Spectra (RBS). The RBS",
                " detector was at 170 degree with a solid angle of",
                " 2.88 msr at the sample. The angle of the ERS detector",
                " was adjustable, and its active surface was 11.8 mm x",
                " 2.1 mm; its solid angle was 0.846 msr."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples consisted of 600 A of deuterated",
                " polystyrene (C8D8)n, (Polymer Labs, UK) spun onto",
                " 3 in. Si wafers. The monomer contained about 1 at.%",
                " of hydrogen (1H) which was also present in the film."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "D"
              ],
              "free_text": [
                " Recoil deuteron from alpha scattering on 2H"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                " Outoging alpha from alpha scattering on C"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The accelerator energy scale was calibrated with",
                " reference to an 241Am alpha source, resonance energies",
                " for 19F(p,alpha+g) at 340 keV and 27Al(p,g)28Si at",
                " 770 and 992 keV, and the 7Li(p,n)7Be threshold at",
                " 1881 keV."
              ]
            }
          ],
