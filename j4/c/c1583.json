          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1CANTMF"
              },
              "free_text": [
                "40Ca beam was provided by the",
                "off-line ion source of the ISAC facility. 40Ca beam",
                "was accelerated to 0.153 MeV/nucleon by the 35.4 MHz",
                "RFQ accelerator, to energies of Eb = 0.605 - 1.153",
                "MeV/nucleon (Ecm = 2.28 - 4.19 MeV) by 106 MHz",
                "variable energy DTL."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Windowless He gas target. The gas cell had a",
                "physical length of 11 cm, entrance and exit",
                "apertures of 6 and 8 mm, respectively,",
                "operated at pressures up to 8.5 Torr. The effective",
                "length of the gas target was 12.3+-0.4 cm"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                "recoil mass spectrometer DRAGON, consisting",
                "of two stages, each with a sequence of bending",
                "magnets and electrostatic dipoles. A series of",
                "magnetic quadrupoles focuses the beam and four",
                "sextupoles correct for higher order aberrations"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " a high efficiency gamma-ray detector",
                "consisting of 30 BGO scintillator detectors",
                "surrounded the gas target and covered about 90% of",
                "the solid angle"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                "44Ti recoils were identified in an ion chamber",
                "with a segmented anode that provided two energy-loss",
                "signals to allow isobar identification."
              ]
            }
          ],
