          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Foils of Au,  thickness 25 mg/cm2 surrounded by ~15",
                "mg/cm2 A1 catcher foils."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gaussian charge dispersions were fitted to independent",
                "yield formation cross sections for all radionuclides",
                "and integrated to obtain the mass yield cross sections."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No corrections were made for the contributions to the",
                "foil activities from secondary induced reactions",
                "because comparison of the ratio of in beam (Au, Pb) foi",
                " activity to out-of-beam (Au, Pb) monitor foil activity",
                " with similar ratios for U targets where secondary",
                "corrections are well-known revealed the secondary",
                "corrections for the (Pb, Au) experiments to be <7%."
              ]
            }
          ],
