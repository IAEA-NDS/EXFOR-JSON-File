          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC",
                "ACTIV"
              ],
              "free_text": [
                " Foils were irradiated for 162 min",
                "at the BEVALAC. Gamma and X-ray spectroscopic",
                "measurements of the radioactivity induced in the",
                "target and catcher foils began one hour after",
                "bombardment and continued for about three weeks. Over",
                "75 radionuclides were identified in this work on the",
                "basis of their gamma-, X-ray energy, half-life and",
                "radiation intensity."
              ]
            }
          ],
