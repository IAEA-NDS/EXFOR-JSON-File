          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Most of the targets consisted of self-supporting",
                "rolled metal, 500 to >= 600 microg/cm2 thick, or",
                "material evaporated onto thin carbon or Al backings.",
                "A few thick targets of thicknesses > 1 mg/cm2 were",
                "also employed."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " 300 or 600 mm silicon surface-barrier",
                "detectors, 60 to 150 microm thick, placed on opposing",
                "movable arms."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The target-detector distances were typically 15",
                "to 40 cm and the solid angles of the detectors were",
                "1.2 to 20 msr, corresponding to angular acceptances",
                "of 2 to 8 degrees."
              ]
            }
          ],
