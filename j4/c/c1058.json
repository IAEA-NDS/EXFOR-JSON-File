          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "12-MG-26",
                "field_identifier": "ENR",
                "value": 0.9946
              },
              "free_text": [
                " The 26Mg target was prepared by",
                "evaporating magnesium metal enriched to 99.46% in",
                "26Mg to a 0.25 mm tantalum backing. The target",
                "thickness was determined to be 400+-40 microg/cm2",
                "by the crystal oscillator method. An enriched 26Mg",
                "target was also deposited on to an aluminum backing",
                "at the same time as the tantalum-backed target was",
                "produced. The target thickness was taken to be",
                "395+-35 microg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Two 7.6 cm x 7.6 cm NaI(Tl) detectors were",
                "placed on either side of the target chamber at right",
                "angles to the beam line and surrounded by 2.5 cm of",
                "lead to reduce background."
              ]
            }
          ],
