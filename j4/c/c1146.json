          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of 9Li and 11Li from 12C at 50 MeV",
                " per nucleon"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAMSU"
              },
              "free_text": [
                " The S800 spectrograph was used."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The secondary 9,11Li beams were produced by",
                "fragmentation of a primary 80 MeV per nucleon 18-O(6+)",
                "beam of intensity approximately 150 pnA, obtained from",
                "the MSU K1200 cyclotron. Yielded beam purities of",
                ">99.4% for both 9Li and 11Li, with intensities of",
                "approximately 5000 pps and 100 pps, respectively, was",
                "reached."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Graphite targets (99% 12C) with thickness of 178 and",
                " 887 mg/cm2, with purities of 99.95 and more than",
                " 99.5 %, respectively"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Two tracking detectors S803 and S804 were located",
                "upstream of the target and separated by 30.3 cm, with",
                "S804 just 8.32 cm in front of the target. Two",
                "more tracking detectors were located in the focal",
                "plane of the spectrograph: S801 at the computed focus",
                "and S802 approximately 1 m stream of the",
                "focal point."
              ]
            }
          ],
