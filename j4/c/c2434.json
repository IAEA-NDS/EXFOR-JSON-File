          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Binary and Ternary Fission of U238 Induced by",
                "Intermediate-Energy He3 Ions"
              ]
            }
          ],
          "AUTHOR": [
