          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy determined from the centroids of the gamma-peaks",
                "in 90 degree detectors and reaction Q value=7162 keV.",
                "The weighted average of the six values (from the full",
                "energy, single and double escape peaks) was typically",
                "20-30 keV below the center-of-mass energy deduced from",
                "the incident beam energy and slightly higher than the",
                "value at half of target thickness.",
                "The spread in the beam energy was less than 3 keV at",
                "all energies."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopically separated targets prepared by implanting",
                " 12C targets at an energy of 110 keV into a thick gold",
                " layer. The backings were 25-mm square copper sheets,",
                " 0.5 mm thick, on which thin layer of nickel and then",
                " gold were electroplated to assure good adhesion.",
                " A total of nine targets was eventually used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " Six large-volume germanium detectors situated",
                " at angles of 28, 60, 90, 90, 120, and 143 degr.",
                " distances of 5.0,5.0,3.8,3.8,6.0, and 8.0 cm. The two",
                " 90 degr. counters were located below and above the",
                " target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Six plastic scintillation counters were placed",
                " above the germanium detector so that they subtended an",
                " angle of close to 2pi."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The E1 and E2 contributions were divided by target",
                " thickness and total charge deposited on the target to",
                " produce a relative yield curve.",
                "Data above 2 MeV are averaged over several runs at 5",
                " out of 9 energies."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
