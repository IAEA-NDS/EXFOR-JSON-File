          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "12C(alpha,gamma)16O cross sections at stellar energies"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
