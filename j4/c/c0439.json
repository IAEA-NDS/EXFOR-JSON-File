          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Analysis of all the available E1 cross sections with",
                " the K-matrix method and with a three-level R-matrix",
                " method yields a consistent prediction of 79(+-16)keV-b",
                " for the E1 S factor at 300 keV.",
                "The contribution of E2 transitions at the same energy",
                " is 36(+-6)keV from a cluster-model analysis of the",
                " present data.",
                "The best estimate of the total S factor at 300 keV is",
                " 120 keV-b."
              ]
            }
          ],
