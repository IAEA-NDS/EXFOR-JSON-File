          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three counters. Counter No 3 is a symmetrical ring,",
                "divided into two parts along a vertical diameter",
                "parallel to polarization of the incident beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Protons scattered into the left and right",
                "halves of counter No. 3 were counted independently,",
                "each in coincidence with counters Nos. 1 and 2. A",
                "typical value of the fraction of protons scattered",
                "into one-half of the counter by the 2.80 grams per",
                "square centimeter of hydrogen in the target was",
                "2x10**-4. At each angle, data were taken with the",
                "target both full and empty."
              ]
            }
          ],
