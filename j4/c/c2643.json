          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The asymmetry was obtained from the formula, e = [(fl-",
                "fr)/(fl+fr)]*(phi*sin phi), where fl, fr are the",
                "fractions of beam protons scattered into the left and",
                "right sides of counter No 3, respectively, and 2*phi is",
                "the azimuthal angle covered by either half of",
                "counter. Since the beam polarization has been",
                "previously measured in elastic scattering experiments,",
                "we may calculate directly the polarizations arising",
                "from the p-p scattering in this experiment through",
                "the relation P=e/Pb, where Pb has been taken to be",
                "0.74+-0.01."
              ]
            }
          ],
