          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section was obtained by adding the",
                "fractions of the beam scattered by hydrogen into the",
                "two halves of counter No 3 and multiplying this by the",
                "appropriate geometrical factors for each angle. Since",
                "the relative accuracy is better than the absolute,",
                "the values have been adjusted to give 3.7x10**-27 cm2",
                "per steradian at 20 degrees (center of mass)."
              ]
            }
          ],
