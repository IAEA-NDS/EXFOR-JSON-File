          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Chromium foils were prepared by the electrodeposition",
                "of chromium metal to a thickness of 12 mg/cm2 on",
                "sheet copper. After 20 hours annealing and outgassing",
                "at 225 degC and and < 1 micro Hg pressure, the",
                "mechanical properties of the foils were adequate for",
                "this work."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NaI(Tl) crystal scintillator."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV",
                "PHD"
              ],
              "free_text": [
                " A stack of 26 chromium foils was",
                "bombarded for 2.72 microa-hr at 14.70 MeV. Each foil",
                "was dissolved in hydrochloric acid, carrier manganese",
                "and vanadium added, and the chloride removed by",
                "boiling with nitric acid. All activities were",
                "measured on solution aliquots with a well-type",
                "NaI(Tl) scintillation counter."
              ]
            }
          ],
