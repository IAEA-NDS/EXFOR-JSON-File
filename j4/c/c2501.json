              "coded_information": [
                "1USABNW"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,CJC,61,786,1983",
                "code_unit": [
                  {
                    "unit": "J,CJC,61,786,1983",
                    "doi": "10.1139/v83-145",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "CJC",
                        "number": null,
                        "volume": "61",
                        "part": null,
                        "issue": null,
                        "page": "786"
