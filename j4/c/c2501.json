          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAWAU"
              },
              "free_text": [
                " The University of Washington 54-in",
                "sector-focused  cyclotron."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of 238U or 232Th powder (10 mu-m",
                "size) intimately mixed with graphite powder and",
                "pressed into a small block about 100 mg/cm2 thick.",
                "The ratio of metal-to-graphite was 4-to-1 by weight."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MASSP"
              ],
              "free_text": [
                " The technique of on-line mass spectrometry",
                "involves placing a suitable target in the ion source",
                "of a mass spectrometer and bombarding the target with",
                "projectiles. Nuclear reaction products diffuse out of",
                "a graphite matrix and are ionized by surface",
                "ionization on a hot tantalum surface."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for background, overlap from adjacent peaks",
                " (about 5%), saturation factor, loss due to radioactive",
                "decay, and loss due to diffusion of Kr precursors."
              ]
            }
          ],
          "HISTORY": [
