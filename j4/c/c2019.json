          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear charge dispersion in the fission of 235U by",
                "protons of energy 20-85 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
