          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "3H(p,g)4He reaction below Ep=80 keV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ACCEL"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " the TUNL Atomic Beam Polarized Ion",
                " Source (ABPIS)"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 80 keV and 40 keV polarized proton beams"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets used in this work were tritiated titanium",
                " foils, and the beam was stopped in the target. These",
                " targets contained about 0.5 tritium atoms for every",
                " titanium atom. The targets were manufactured in 1990,",
                " so that 40% of their original tritium content had",
                " decayed. The tritium density was measured by means of",
                " the 3H(d,n)4He reaction, at incident beam energies",
                " of 40, 60, and 80 keV"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The outgoing alpha particles were detected at",
                " back angles using a silicon-surface-barrier detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " The 19.8 MeV gamma rays were detected in",
                "10 in.x10 in. NaI detectors"
              ]
            }
          ],
