          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " After irradiation, the cerium produced",
                "in the reaction was chemically separated from the",
                "target and backing material using the solvent",
                "extraction procedure. The cerium was precipitated as",
                "the oxalate, dried, weighed as Ce2(C2O4) 3x9H2O and",
                "mounted on aluminum counting plates."
              ]
            }
          ],
