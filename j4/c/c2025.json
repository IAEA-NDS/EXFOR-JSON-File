              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " The 28Si recoils with a charge state q = 8+",
                "were detected at the focal plane by a double-sided",
                "silicon strip detector (DSSD)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " Gamma rays were detected in the BGO gamma-ray",
                "array."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Unambiguous identification of the 28Si compound",
                "nucleus (CN) was performed using the recoil time-of-",
                "flight measured between the BGO array and the DSSD,",
                "together with the energy of the recoils recorded at",
                "the focal plane."
              ]
            }
