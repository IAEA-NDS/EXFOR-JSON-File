          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The complete fusion cross sections derived from our",
                "analysis of angular correlation functions from",
                "4He-ion induced fission of 238U as a function of",
                "bombarding energy. By integrating contour diagram of",
                "angular correlations for both total experimental",
                "events and predicted complete fission events, the",
                "upper limit for the complete fusion cross section in",
                "reactions between He ions and 238U was deduced."
              ]
            }
          ],
