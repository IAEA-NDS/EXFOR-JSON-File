          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopically enriched 238U and monoisotopic 209Bi and",
                "197Au targets were prepared by vacuum evaporation",
                "onto carbon films. Target material thicknesses were",
                "in most cases 80-140 microg/cm2 and backing",
                "thicknesses ranged from 20 to 100 microg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A heavy ion surface-barrier semiconductor",
                "detector placed on one side of the beam axis and a",
                "50x6-mm position- sensitive semiconductor detector.",
                "The position-sensitive detector (PSD) was mounted 15",
                "cm from the target and intercepted approximately +-10",
                "degrees of the reaction plane."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MAGFR"
              ],
              "free_text": [
                " The measurements reported here were performed",
                "in a 75-cm diam scattering chamber using a",
                "magnetically analyzed and focused beam of 140- and",
                "150-MeV 4He ions from the University of Maryland",
                "cyclotron."
              ]
            }
          ],
