          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting Nd metal target, isotopically enriched",
                " to 99.8% 144Nd."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PSSCN"
              ],
              "free_text": [
                " Position-sensitive gas counter.",
                "Ejectiles momentum analysed using quadrupole-dipole-",
                " dipole-dipole spectrograph."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Peak centroids and intensities obtained.  Individual",
                " states were obscured at particular angles by peaks",
                " corresponding to elastic scattering from carbon,",
                " oxygen, and silicon contaminants and inelastic",
                " scattering to the 1.78-MeV level of 28Si.  Where",
                " necessary the Gaussian peak-fitting program GELIFT was",
                " used."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No uncertainties given.",
                "Estimated minimum error in measured cross sections 10%",
                " from comparison with calculations."
              ]
            }
          ],
