          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "PS"
              ],
              "free_text": [
                " The reaction products were analyzed",
                "with an Enge split-pole magnetic spectrometer, with a",
                "position-sensitive proportional counter in the focal",
                "plane. This detector comprises a 0.3 mm resolution",
                "position-sensitive section followed by two",
                "conventional proportional counters which could be",
                "used in coincidence."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were 50-100 mu-g/cm2 of 168Er evaporated",
                "onto 20 mu-g/cm2 carbon foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP",
                "STRUC"
              ],
              "free_text": [
                " Isoscalar transition strengths have been",
                "extracted by a coupled-channels distorted wave",
                "calculation involving collective model form factors.",
                "For quadrupole excitation the results agree in several",
                "ways with predictions of the interacting boson",
                "approximation model and the geometrical models and for",
                "octupole states there is a good agreement with",
                "theoretical results of Neergard and Vogel."
              ]
            }
          ],
