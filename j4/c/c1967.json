              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Core of the SuN (Summing NaI(Tl)) is a",
                "cylinder,16in. in diameter and 16in. long,with a",
                "1.8in. diameter borehole along its axis. The cylinder",
                "comprised two separate halves enclosed in aluminium",
                "casings that allow for placing the detector around a",
                "beam line. Within the two aluminium casings, each of",
                "the halves is additionally divided into four",
                "optically isolated segments separated by 0.5mm",
                "aluminium plates covered with 0.25mm reflecting",
                "material."
              ]
            }
