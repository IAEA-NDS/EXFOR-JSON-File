          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "PPAC",
                "IOCH"
              ],
              "free_text": [
                " Prompt gamma-rays resulting from",
                " (alpha,n) reactions were detected using the TIGRESS",
                "high-purity germanium (HPGe) array, in coincidence",
                "with heavy-ion recoils transmitted to the focal plane",
                "of the EMMA recoil mass spectrometer. Detectors at",
                "the focal plane of EMMA comprised a position-",
                "sensitive parallel grid avalanche counter (PGAC),",
                "followed by an ionization chamber and an",
                "ion-implanted silicon detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Only the PGAC signals were used for recoil",
                "gamma coincidence identification, with an associated",
                "94(1) % detection efficiency from the wire grid",
                "transparency. Specifically, the reaction kinematics,",
                "energy loss, and straggling of recoils passing",
                "through the target and degrader foil were simulated",
                "using GEANT4."
              ]
            }
          ],
