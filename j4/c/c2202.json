          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural He gas target. High pressure gas (cca",
                "16000Torr) is injected through a Laval nozzle to form",
                "a dense jet of gas approximately 4mm wide. The",
                "effective areal density of the jet was estimated by",
                "measuring the energy loss of alpha particles emitted",
                "from a 244Cm source and was found to be approx. 4E+18",
                "Ne atoms/cm2"
              ]
            }
          ],
