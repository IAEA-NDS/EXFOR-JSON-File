          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " A radiochemical study. Bombardments were",
                "accomplished with either the 41 MeV helium ion beam",
                "of the cyclotron at the University of Washington in",
                "Seattle, or the 65 MeV helium ion beam of the",
                "cyclotron at the University of California at",
                "Berkeley. In each case the bombarded targets were",
                "flown and/or driven to our laboratories here in",
                "Bellingham for analysis where the fission fragments",
                "were separated and purified using standard",
                "radiochemical techniques."
              ]
            }
          ],
