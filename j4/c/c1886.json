            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " The light ejectiles were detected in a set of",
                "three annular segmented silicon detectors which",
                "recorded their position and energy at backward",
                "laboratory angles. The laboratory segmentation of the",
                "annular detectors was approximately 1deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Heavy beam-like fragments, including",
                "7,8,9Li, or 4,6He ions were detected and identified",
                "in a set of silicon dE-E telescopes covering 1deg <",
                "theta(lab) < 7deg."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Inverse kinematics was used"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An 81MeV 7Li beam of intensity 45 pnA bombarded a",
                "cryogenically cooled D2 gas cell kept at a pressure",
                "between 1000 and 1250mbar. Secondary beams of 8Li and",
                "6He were produced with the 2H(7Li,p)8Li, and",
                "2H(7Li,3He)6He reactions, respectively"
              ]
            }
