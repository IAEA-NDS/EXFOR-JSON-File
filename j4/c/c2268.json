          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Amount of produced reoiled 36Cl nuclei were",
                "determined by AMS performed at Purdue's Rare Isotope",
                "Measurement (PRIME) Laboratory"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "After passing through the entrance foil, the  33S",
                "beam reacted along the length of the gas-filled",
                "volume and forward-recoiled 36Cl atoms were stopped",
                "in a 0.25 mm thick Al foil at the back of the gas",
                "cell. SRIM simulations shown that, for all energies,",
                "more than 99% of recoils are caught in the 9 cm",
                "diameter circular cross section of the foil."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " After irradiation chemical separation was",
                "performed with overal efficienfy of 97.5%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "AMS"
              ],
              "free_text": [
                " Atomic mass spectroscopy was used to determine",
                "number of 36Cl nuclei produced. The AMS measurements",
                "were normalized to the 36Cl standard material KNSTD500."
              ]
            }
          ],
