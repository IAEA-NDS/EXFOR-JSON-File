          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative cross-sections for formation of the shielded",
                "isomeric pair 134mCs and 134Cs in medium energy fission"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
