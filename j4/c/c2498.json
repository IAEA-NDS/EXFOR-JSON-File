          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An isotopically separated 178Hf target of thickness",
                "100 microg/cm2 was prepared in an isotope separator",
                "on a 60-microg/cm2 carbon foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Silicon surface-barrier semiconductor",
                "detectors, each of area 400 mm2 and a nominal",
                "depletion depth ~100 microm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Double energy technique.",
                "Fission coincidence events were detected with",
                "three pairs of silicon surface-barrier semiconductor",
                "detectors placed inside the 162-cm-diam scattering",
                "chamber at IUCF. Detectors were calibrated with a",
                "252Cf source. Approximately 2100 valid coincidence",
                "events were observed during the course of these",
                "experiments. Of these, about 12% were attributed to",
                "actinide fission. Of the remaining 1850 events, it",
                "was estimated that less than 3% of these could be due",
                "to heavy-element fission."
              ]
            }
          ],
