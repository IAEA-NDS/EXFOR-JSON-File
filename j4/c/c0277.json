              "coded_information": null,
              "free_text": [
                "High-Sensitivity Mass Spectrometric Measurement of",
                " Stable Helium and Argon Isotopes Produced by High-",
                " Energy Protons in Iron"
              ]
            }
          ],
          "FACILITY": [
            {
