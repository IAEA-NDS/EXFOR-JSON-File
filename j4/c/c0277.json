          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "At 0.16-GeV, two steel pieces, 1-mm thick used;",
                "At 0.43-GeV, three pieces of 0.3-mm thick nonmagnetic",
                " steel used;",
                "At 3.0-GeV, vacuum-fused pure iron used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP",
                "BCINT"
              ],
              "free_text": [
                " The helium was determined in the mass",
                "spectrometer and compared with the current as indicated",
                "by the Faraday cup.",
                "All the measurements were determined at least two times",
                "In the case of the 0.43-Bev Chicago irradiations, two",
                "separate bombardments were performed."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The mass spectrometer used in the studies",
                "had a symmetrical 60.degr. magnetic analyzer with",
                "6-in. radius of curvature."
              ]
            }
          ],
