            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Windowless gas target with an effective length of",
                "12.3 cm was operated at He pressures ranging from",
                "7.08 to 9.13 Torr. This resulted in target thicknesses",
                "ranging from 55 to 75 keV in the CM system."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " DRAGON's gamma detector array consists of 30",
                "bismuth germanate (BGO) scintillators in a close-",
                "packed geometry covering 92% of the solid angle",
                "surrounding the gas target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Heavy reaction products were momentum",
                "analyzed in DRAGON spectrometer and identified in",
                "spectrometer focal plane."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " Heavy reaction products were identified in",
                "focal plane using time-of-flight system consisting of",
                "two microchannel plates"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " A multi-anode ionization chamber measured the",
                "energy loss and total kinetic energy of heavy ions",
                "transmitted to DRAGON's focal plane."
              ]
            }
          ],
