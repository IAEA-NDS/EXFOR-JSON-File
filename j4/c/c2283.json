          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An isotopically pure beam of 34S ions was generated",
                "by the Supernanogan electron cyclotron resonance",
                "plasma source using a gas supply of SF6 enriched in",
                "34S. The beam was accelerated through the ISAC-I",
                "Radio-Frequency Quadrupole and the Drift-Tube Linac",
                "to energies between 20.23 and 25.75 MeV"
              ]
            }
          ],
