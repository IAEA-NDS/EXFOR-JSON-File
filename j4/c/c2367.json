              },
              "free_text": [
                " Brookhaven alternating gradient",
                "synchrotron (AGS)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Approximately 2.5x10**15 protons per minute",
                "interacted in the target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI",
                "NAICR",
                "PROPC",
                "SIBAR"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Each target consisted of a 51 micro-m thick tantalum",
                "foil sandwiched between two stacks of three 25 micro-m",
                "aluminum foils"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "CHSEP"
              ],
              "free_text": [
                " Most of the tantalum targets were",
                "irradiated for 30 min each in the circulating proton",
                "beam of the Brookhaven alternating gradient",
                "synchrotron. These irradiations mere typically 5 min in",
                " duration, and the alpha radiations of both the",
                "upstream and the downstream target pieces were",
                "assayed directly with surface-barrier Si detectors",
                "after they were punched out. The tantalum foil was",
                "dissolved in a platinum crucible containing the",
                "appropriate rare-earth carriers and a few ml of",
                "concentrated HF."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The decay curves were analyzed by means of",
                "the CLSQ program to obtain the end-of-bombardment or",
                "time-of-separation activities and their standard",
                "deviations."
              ]
            }
          ],
