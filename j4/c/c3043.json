          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Differential cross section measurements of the 7Li",
                " (3He,p0)9Be, 7Li(3He,p2)9Be, and 7Li(3He,d0)8Be",
                "reactions from 2 to 4 MeV"
              ]
            }
          ],
