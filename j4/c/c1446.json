          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "First experimental constraints on the interference",
                " of 3/2+ resonances in the 18F(p,alpha)15O reaction"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "OLMS"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                " ORNL Holifield Radioactive Ion Beam",
                " Facility (HRIBF) using the Isotope Separator",
                " On-Line (ISOL) method"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A beam of 4He from the Oak Ridge Isochronous Cyclotron",
                " (ORIC) bombarded a thick HfO2 target to produce 18F",
                " atoms via 16O(a,pn)18F reaction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Recoil a particles and 15O ions from the",
                " 1H(18F,a)15O reaction were detected in coincidence by",
                " two large area silicon detector arrays (SIDAR and",
                " MINI, respectively). The SIDAR was tilted forward 43",
                " degree from the perpendicular to the beam axis in",
                " order to cover a large angular range (29 degree <",
                " Theta-lab < 73 degree), while the smaller annular",
                " detector (MINI) covers 11.5 degree < Theta-lab <",
                " 22.5 degree)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Scattered 18F and 18O ions were also",
                " continuously detected by a gas-filled ionization",
                " counter enabling a constant monitor of the beam",
                " composition"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 70 microg/cm2 CH2 target."
              ]
            }
