          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2SF JYV"
              },
              "free_text": [
                " Experiment was performed with the",
                "JYFLTRAP Penning trap setup at the Department of",
                "Physics, University of Jyvaskyla. The ions of interest",
                "were produced in light-ion induced fusion reactions",
                "at the IGISOL facility"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " 26Si nuclei were produced in reaction",
                "27Al(p,2n)26Si. The recoiling products were stopped,",
                "thermalized and extracted from the IGISOL gas cell,",
                "accelerated, magnetically separated and 26Si ions",
                "transported to the JYFLTRAP setup. The beam was",
                "cooled, purified and 26Si ions were transported into",
                "a high precision Penning trap."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Penning trap allows wery precise determination of",
                "charged particle masses. In this experiment it was",
                "used to meaasure masses of singly charged 26Si ions",
                "and its decay products 25mAl and 25Al. From the mass",
                "values, resonance properties of 26Si were determined."
              ]
            }
          ],
          "HISTORY": [
