          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "4He gas cell target 2 cm in depth, with pressure of",
                "110+-1 Torr giving a target thickness at 293 K of",
                "47.9+-0.4 mu-g/cm2 or an energy loss for the 23Na",
                "beam of approximately Elab=1.1MeV (Ecm = 0.14MeV)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " Reaction protons were detected in",
                "an energy loss-energy (DE-E) silicon telescope,",
                "which consisted of two  Micron S2-type",
                "double sided silicon strip detectors,",
                "providing particle identification. Two data sets were",
                "taken. In the first, the DE-E telescope comprised a",
                "70 mu-m DE S2 and a 500 mu-m E S2 detector,",
                "positioned 3.4 cm from the exit window of the gas",
                "target. The latter detector was replaced with a 1000",
                "mu-m E S2 for the second data set, and the telescope",
                "was moved further downstream by 2.1 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Inverse kinematics was used. Following reactions",
                " natNi(23Na,el) and 197Au(23Na,el) were used to",
                " determine cross sections in tis work"
              ]
            }
