          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP"
              ],
              "free_text": [
                " Rutherford backscattering (RBS) and particle-",
                "induced x-ray emission data were taken simultaneously."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "These cross sections can be related via the solid",
                "angle ratio OmegaS/OmegaX that is determined entirely",
                "from quantities associated with element target A. In",
                "other words, in this system the differential",
                "non-Rutherford scattering cross section can be",
                "determined just from a single element target, and",
                "furthermore, it is not necessary to know the total",
                "number of incident particles, the solid angles, or",
                "the number of target atoms. Applying the theoretical",
                "formalism, the differential Rutherford cross section",
                "is readily calculated because the x-ray production",
                "cross sections may be obtained from a variety of",
                "sources."
              ]
            }
          ],
