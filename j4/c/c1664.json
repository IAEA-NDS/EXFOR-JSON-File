          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "144Sm target was isotopically enriched to 88%, its",
                "thickness was of 200 micro g/cm2, and it was",
                "evaporated onto a 20 micro g/cm2 carbon backing."
              ]
            }
          ],
