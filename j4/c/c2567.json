          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "There is an ambiguity in the identification of 212mAt,",
                "215At, and 216mAt based on alpha spectroscopy alone.",
                "HIVAP and similar calculations predict very small",
                "cross section for complete fusion product 216At. For",
                "negligibly small production cross section 216At was",
                "removed from the 212Atm/215At ambiguity."
              ]
            }
          ],
