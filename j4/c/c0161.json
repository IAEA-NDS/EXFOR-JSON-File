          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Incident energy determined by time-of-flight.",
                "Energy resolution was insufficient to allow for the",
                " separation of the low-lying levels in 9Li and 12C."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "CSICR"
              ],
              "free_text": [
                " Tree Si-CsI telescopes, each",
                "telescope consisted of a 300 mu-m thick by 5 cm",
                "square Si dE detector, a 300mu-m thick by 5 cm square",
                "double-sided silicon strip detector having 16 strips",
                "in each direction, and a CsI stopping detector with",
                "photodiode readout. The additional dE detector gave",
                "improved separation of 8Li from 9Li. Beam energy",
                "determined using thin plastic scintillator."
              ]
            }
          ],
