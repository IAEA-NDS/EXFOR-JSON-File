          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The main target was ZnS (178 mu-g/cm2) deposited on a",
                "thin carbon backing (5 mu-g/cm2) ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma rays were detected using Hyperion array,",
                "which consisted of 12 Compton-suppressed high-purity",
                "germanium (HPGe) clover detectors"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " In this experiment Hyperion array",
                "contained also an Si telescope array located 28 mm",
                "downstream of the target, consisting of 150 mu-m",
                "thick dE detector and 1500 mu-m thick E detector.",
                "Both detectors were were standard Micron",
                "Semiconductor S2 design with 24 annular strips, each",
                "with 1 mm pitch, on the junction side and eight 45",
                "deg sectors on the Ohmic side."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " An upstream detector for decay protons was",
                "placed 34 mm upstream from the target. It was the",
                "same S2 design with thickness of 500 mu-m."
              ]
            }
