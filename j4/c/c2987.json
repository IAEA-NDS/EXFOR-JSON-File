          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target of 234U had dimensions 1X5 mm2 and",
                "thickness about of 25 mu-g/cm2 and was deposited on",
                "double 20-mu-g/cm2 carbon backing."
              ]
            }
          ],
