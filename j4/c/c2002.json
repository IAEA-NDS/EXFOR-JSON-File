          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USACLA"
              },
              "free_text": [
                " Experiment performed using deflected",
                "beam of the U.C.L.A. cyclotron,"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stack of spectroscopically pure Nb(2)O(5) samples",
                "with weight of 40 to 50 mg were irradiated in",
                "circulating beam of cyclotron. The desired energy",
                "being selected by position of the target probe."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " Decay curves and absorption curves were",
                "obtained with a thin window Geiger-Mueller tube"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Gamma-ray spectra were measured with the use",
                "of the scintillation gamma-ray spectrometer. Thin",
                "samples were prepared and the particles studied by",
                "means of the helical focusing beta-ray spectrometer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation method was used.The 0.262-MeV",
                "gamma ray of 93Mo is largely converted, while the",
                "other two (0.69 and 1.51 MeV) are not converted to",
                "any appreciable extent. These conversion electrons",
                "are responsible for essentially all of the radiation",
                "detected in the Geiger-Mueller tubes used here, as",
                "was shown by aluminum and lead absorption curves.",
                "These absorption curves were extrapolated to zero",
                "absorber thickness and the total number of",
                "disintegrations of 93Mo calculated"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The paper contains cross section of the reaction",
                "    Nb-93(p,np)Nb-92-(M2)",
                "with half-life of 13 hr. Because this state was never",
                "confirmed, this cross section is not compiled."
              ]
            }
          ],
