          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were prepared by molecular deposition of",
                "4SCa(NO3)2 from isopropanol solvent on a 2.5 cm",
                "diameter and 25 mu-m thick aluminium foil backing. A",
                "centre 1.3 cm diameter circular foil was punched out",
                "as the target to be irradiated. The average thickness",
                "of all deposits used was 94 mu-g/cm2 and each was",
                "within +/- 5% of that thickness. The target package",
                "consisted of four or five target foils and their",
                "respective 25.4 mu-m thick aluminium (99.99% purity)."
              ]
            },
