          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,92,034325,2015",
                "code_unit": [
                  {
                    "unit": "J,PR/C,92,034325,2015",
                    "doi": "10.1103/PhysRevC.92.034325",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
