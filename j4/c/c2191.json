          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                " Proton beam was delivered from the",
                "Holifield Radioactive Ion Beam Facility 25 MV tandem",
                "accelerator through the gas-flow-restricting",
                "apertures of the JENSA system to the jet location."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Jet Experiments in Nuclear Structure and",
                "Astrophysics (JENSA) gas-jet target system was",
                "operated with a recirculating jet of natural N",
                " (99.632% 14N) at 300 psig (pounds per square inch)",
                "gauge pressure. This corresponds to an average",
                "density over the 4-mm jet width of approx. (5-6)E+18",
                "atoms/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Resultant tritons were detected",
                "at forward angles using the highly segmented SIlicon",
                "Detector ARray (SIDAR) covering lab angles from 18",
                "deg to 50 deg. For particle identification, the SIDAR",
                "was arranged into dE-E telescopes with 100 mu-m dE",
                "detectors and 1000 mu-m E detectors. The radial",
                "strips of SIDAR allow detection of the tritons at",
                "several angles simultaneously, with an energy",
                "resolution between 65 and 115 keV. Four SIDAR",
                "telescopes covering laboratory angles of 19-54 deg",
                "were used in present experiment"
              ]
            }
          ],
          "METHOD": [
