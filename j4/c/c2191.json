          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Levels in 12N via the 14N(p,t) reaction using the",
                "JENSA gas-jet target"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
