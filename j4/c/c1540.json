          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute cross section was obtained by",
                " normalizing the forward-angle 42-MeV data to",
                " that published earlier at 34 MeV in short runs."
              ]
            }
          ],
