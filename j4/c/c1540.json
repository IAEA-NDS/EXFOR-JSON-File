          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Tensor analyzing powers and energy dependence of the",
                " 7Li+16O interaction"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1USAFSU"
              },
              "free_text": [
                " The Florida State University (FSU)",
                " optically pumped polarized Li ion source (OPPLIS)"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A polarized 7Li beam, Elab = 42 MeV. The beam",
                " polarizations were t10 = 0.76 +/- 0.07,",
                " t20 = 0.37 +/- 0.07, and t30 = 0.14 +/- 0.07."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 150-microg/cm2 6Li target. The 6Li target was",
                " prepared with vacuum evaporation of lithium on a thin",
                " foil and was transferred under static vacuum",
                " to the scattering chamber to minimize oxidation. The",
                " small amount of oxidation that occurred during the",
                " transfer of the targets to the scattering chamber",
                " was sufficient to extract the angular distribution and",
                " analyzing power data."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier DE-E counter",
                " telescopes"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
