          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton irradiation parameters and chemical separation",
                "procedure for the bulk production of",
                "high-specific-activity 186gRe using WO3 targets"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.E.Fassbender",
