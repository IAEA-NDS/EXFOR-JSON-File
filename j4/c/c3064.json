          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross sections listed were extracted from the",
                "peak areas in the spectrum, the integrated number of",
                "beam particles determined from the ion chamber data,",
                "the target density, and the simulated detection",
                "efficiency for the respective excitation energies.",
                "Here, the resonances are assumed to decay exclusively",
                "by proton emission."
              ]
            }
          ],
