          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam energy spread was less than 3 keV in the range",
                " 3.2 to 5.3 MeV and 2 keV from 1.0 to 3.2 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Free standing Be foil about 11 keV thick for 5 MeV",
                " alpha particles."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sample was mounted in front of a long Faraday Cup",
                " so no scattered particles from the bottom of the cup",
                " can be seen by the detector at 165 degrees. The beam",
                " energy stability was kept to better than 0.1%.",
                " 101 spectra were collected."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Detector of 100 mm2 sensitive area was placed at 60 mm",
                " from the sample.  Detector solid angle is 28 msr, with",
                " angular spead about 5 degrees at low bombarding",
                " energies.  Above 4.6 MeV, a smaller detector was used",
                " with 1.8 degree angular spead."
              ]
            }
          ],
