          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Two Si-detector telescopes, coplanar with,",
                " on opposite sides of, and at equal angles to the beam.",
                " Both telescopes had 1.39 msr defining apertures;",
                " one used a 32 micron deltaE counter followed by a",
                " 1000 micron E-counter, while the other had a 53",
                " micron deltaE and a 2000 micron E-counter."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The counter telescopes were calibrated to an",
                " accurancy of 0.1 MeV over the energy range 10 to 40",
                " MeV using the D(6Li,2alpha) reaction. A 2.2 mg/cm2",
                " thick CD2 target, was bombarded with a 6Li beam whose",
                " energy in the center of the target was 29.2 MeV."
              ]
            }
          ],
