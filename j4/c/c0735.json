          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopically enriched 6Li targets, evaporated onto",
                " 20 mu-g/cm2 carbon backings. Areal density 500",
                " microg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "EDE"
