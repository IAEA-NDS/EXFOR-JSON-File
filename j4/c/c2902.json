          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC",
                "PROPC",
                "SWPC"
              ],
              "free_text": [
                " The outgoing 6Li ions were analyzed",
                "in a split-pole spectrograph and detected in a dual",
                "proportional counter in the focal plane. The front",
                "counter was a single-wire, position-sensitive counter",
                "using charge division readout. The second counter was",
                "operated in coincidence and served to reduce",
                "background events due to the heavy ions (such as 12C",
                "target recoils) which stopped in the front counter and",
                "produced pulses the same size as those of the 6Li."
              ]
            }
          ],
