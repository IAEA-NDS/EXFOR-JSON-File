          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Finite-range distorted-wave Born-approximation study",
                "of the (4He,6Li) reaction on 12C, 24Mg, and 40Ca"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
