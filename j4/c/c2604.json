          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacked foil target consisting of four foils in order",
                "Cu-Cr-Cu-Cr. Natural Cu foil mass was (14.5+-1.5) mg",
                "and mass of Cr foil was 52.7+-8.4 mg. Target foils were",
                "placed in niobium holder. At higher energies (E>17 MeV)",
                "2 mm thick Nb foil was used,at lower energies 1.5 mm",
                "thick Nb foil with 0.5 mm Al degrader was used"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Irradiated foils were analyzed using a",
                "calibrated High-Purity Germanium detector ORTEC"
              ]
            }
          ],
