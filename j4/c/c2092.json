          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The setup consisted of active collimator,",
                "constructed from a 1/8in. plastic scintillator 3in.",
                "in diameter with a 0.511in. diameter hole in the",
                "center. The scintillator was coupled to a fast PMT."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Two segmented n-type silicon detectors with",
                "annular rings on the junction side and pie shaped",
                "sectors on the ohmic side 249 mu-m and 305 mu-m thick",
                "covered the angular region of 11.3 deg - 21.8deg and",
                "3.53deg - 10.8deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " The final detector in the setup was the zero",
                "degree gas ionization chamber (ZDIC) that measured",
                "the energy loss of the beam as well as fusion",
                "residues in the angular region of theta lab less than",
                "3.52 deg."
              ]
            }
          ],
          "METHOD": [
            {
