                "G.F.Peaslee"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ARI,215,111560,2025",
                "code_unit": [
                  {
                    "unit": "J,ARI,215,111560,2025",
