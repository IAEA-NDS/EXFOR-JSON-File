          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-sections for 43Sc, 44mSc, and 44gSc from two",
                "heavy ion reactions"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.M.Miller",
                "J.T.Wilkinson",
                "G.M.Brown",
                "J.Gan",
