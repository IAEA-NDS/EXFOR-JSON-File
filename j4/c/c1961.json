          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation Functions for the Reactions 34S(p,n)34Cl",
                "and 31P(alpha,n)34Cl"
              ]
            }
          ],
          "AUTHOR": [
