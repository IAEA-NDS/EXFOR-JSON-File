              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PGAC",
                "IOCH"
              ],
              "free_text": [
                " The evaporation residues were detected",
                "and identified in the focal plane of the FMA with",
                "detectors of the configuration PGAC1-TIC1-",
                "PGAC2-TIC2-PGAC3-IC, where PGAC stands for an x-y",
                "position-sensitive, parallel-grid avalanche counter,",
                "TIC for a transmission ionization chamber, and IC for",
                "a large volume multi-anode ionization chamber. The",
                "first PGAC1 counter was mounted at the focal-plane of",
                "the FMA,where the evaporation residues are dispersed",
                "according to their mass-to-charge ratio m/q."
              ]
            }
