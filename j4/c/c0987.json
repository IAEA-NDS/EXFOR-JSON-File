          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular Distributions of the Reaction He3(d,p)He4",
                "between 240 keV and 3.56 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
