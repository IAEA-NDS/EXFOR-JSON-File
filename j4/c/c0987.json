              },
              "free_text": [
                " Electrostatic generator."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy calculated assuming energy loss for deuterons",
                "in 3He was the same as that in 4He."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "3He contained in flat cylinder. Gas pressure about 85",
                "mm Hg at  deuteron energies of 0.978-3.56 MeV and 25",
                "mm at deuteron energies  of 0.240-0.978 MeV."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "P"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Four runs taken at each energy and angle.",
                "Since only a few standard cm3 of He3 were available",
                "for this experiment, it was necessary to concentrate",
                "as much as possible of the He3 reaction volume. This",
                "was accomplished by collimating the deuteron beam,",
                "and detecting protons formed in the reaction, outside",
                "the region containing the He3. The NaI crystal was",
                "1/8 in. thick, which was sufficient to stop the",
                "protons and at the same time thin enough that the",
                "background from neutrons and gamma-rays was negligible.",
                "Light pulses from the sodium iodine crystal were",
                "detected in a type 5819 photomultiplier tube and the",
                "resulting electrical pulses were amplified and",
                "recorded on a 10-channel pulse-height analyzer."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Below 1.51 MeV, corrected for effects of multiple",
                "scattering of deuteron beam in entrance window."
              ]
            }
          ],
