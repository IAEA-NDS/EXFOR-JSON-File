          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "C-12(a,g)O-16 Cross Sections at Stellar Energies"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Implanted C-12 targets and alpha beams. The target",
                "backings were square sheets of copper, 0.5 mm thick and",
                "2.5 cm on a side, onto which a thick layer of 99.999%",
                "pure gold (16 to 18 mg/cm**2) had been evaporated."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1CANQU"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " Six large-volume germanium detectors situated",
                " at angles of 28, 60, 90, 90, 120, and 143 degr.",
                " distances of 5.0,5.0,3.8,3.8,6.0, and 8.0 cm. The two",
                " 90 degr. counters were located below and above the",
                " target."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The E1 and E2 contributions were divided by target",
                " thickness and total charge deposited on the target to",
                " produce a relative yield curve."
              ]
            }
          ],
