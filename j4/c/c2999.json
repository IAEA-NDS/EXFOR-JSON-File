          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " The scattered alpha particles were detected",
                "with two 3 mm Si(Li) detectors separated by a 5.5",
                "degrees angle in a single rotatable mount. Angular",
                "acceptance was 0.3 degrees for each detector and",
                "energy resolution was about 150 keV (FWHM) ."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute cross sections were obtained by reducing the",
                "beam energy to 24.2 MeV and measuring differential",
                "cross sections between 5 and 15 degrees (lab) .",
                "Comparing these data which extend into the Rutherford",
                "scattering region to optical model predictions",
                "yielded absolute cross sections for the 79 MeV data",
                "believed accurate to 5%."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 1.0,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " Relative cross section accuracy by",
                "background subtraction errors in the angular",
                "distributions due to statistics."
