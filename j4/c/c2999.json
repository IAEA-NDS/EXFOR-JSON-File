          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative sizes of 40,48Ca from the scattering of 79",
                "MeV alpha particles"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "G.M.Lerner",
