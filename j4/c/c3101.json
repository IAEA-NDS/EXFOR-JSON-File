          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron Spectra from Deuteron and Proton Bombardment",
                "of Thick Lithium Targets"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "C.E.Nelson",
                "F.O.Purser",
                "P.Von Behren",
                "H.W.Newson"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USATNL"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "R,NBSIR-77-1279,1,1977",
                "code_unit": [
                  {
                    "unit": "R,NBSIR-77-1279,1,1977",
                    "doi": null,
                    "field": {
                      "reference_type": "R",
                      "reference": {
                        "code": "NBSIR-",
                        "number": "77-1279",
                        "volume": null,
                        "part": null,
                        "issue": null,
                        "page": "1"
                      },
                      "date": 1977
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " The Triangle Universities Nuclear",
                "Laboratory Model FN Tandem Van de Graaff accelerator",
                "was used in conjunction with the TUNL neutron",
                "time-off light facility."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam currents of 2-5 nA with a time resolution of 1.5",
                "to 2.0 nsec were used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The neutron detector consisted of a 8.89 cm",
                "diameter by 5.04 cm thick NE 218 liquid scintillator",
                "coupled to a 56 DVP photomultiplier."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "3-LI-7",
                "field_identifier": "ENR",
                "value": 0.9999
              },
              "free_text": [
                " The lithium target was enriched",
                "to 99.99% 7Li and was encapsulated in an aluminum",
                "container under a helium atmosphere. The upstream",
                "face of the lithium was covered with a 3.5 pm",
                "molybdenum foil and the target length was 1.9 cm,",
                "sufficient to stop 15 MeV deuterons."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PSD"
              ],
              "free_text": [
                " Neutron energy spectra and yields produced",
                "by the bombardment of thick lithium targets by",
                "deuterons and protons have been measured using the",
                "time-of-flight method. Measurements were made at",
                "angles up to 45 degree for deuteron energies of 8, 12",
                "and 15 MeV and a proton energy of 15 MeV. Pulse shape",
                "discrimination was used to discriminate against gamma",
                "ray events."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20260115,
                "history": "C"
              },
