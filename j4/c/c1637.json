          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 90 degrees differential cross section was",
                "determined at 12 energies between 57 keV and 1.1 MeV.",
                "The normalization for the absolute cross section was",
                "based on a measurement of the 90 degree yield at 644",
                "keV using a 1 cm long deuterium gas target at 150 cm",
                "pressure. Detailed angular distributions were",
                "measured at four energies, and 0/90 degrees",
                "intensity ratios were measured at two other energies."
              ]
