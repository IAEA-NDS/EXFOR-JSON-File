          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The neutron groups leading to the ground state",
                "and the 1.369 MeV state of 24Mg were detected by",
                "means of the neutron time-of-flight technique, using",
                "a plastic scintillator. Twenty-two angular",
                "distributions of the unresolved neutron groups were",
                "obtained, covering the energy range Ecm = 1.5 - 2.57",
                "MeV in 60 keV steps. At most bombarding energies,",
                "differential cross sections for the neutrons were",
                "measured at Theta cm = 27, 58, 78, 99, 119 and 138",
                "degrees."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD"
              ],
              "free_text": [
                " The angular distributions were fitted with",
                "sum of Legendre polynomials."
              ]
            }
          ],
