          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 28Mg beam was produced by fragmentation of an",
                "40Ar primary beam with an energy of 140 MeV/A on a",
                "846 mg/cm2 9Be production target. The desired",
                "fragment with an energy of 93 MeV/u was selected with",
                "the A1900 fragment separator and impinged on a",
                "9mg/cm2 9Be secondary target at the target position",
                "of the S800 high-resolution magnetic",
                "spectrograph.Incoming beam particles were identified",
                "event by event by their time of flight between two",
                "plastic scintillators before the target. The average",
                "rate on target was 5E+5 28Mg/s. The largest",
                "contaminant, 29Al, amounted to only 1.5% of the total",
                "beam intensity."
              ]
            }
