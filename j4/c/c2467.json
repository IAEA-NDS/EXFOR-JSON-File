                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Replicate determinations on the fission",
                "fragment species 93Y indicated that the data was",
                "reliable with a probable error of about +-20 percent."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data were corrected for fission fragments retained by",
                "the lead foil itself since only the catcher foils",
                "were analyzed for resulting fission fragments",
                "escaping the target foil."
              ]
            }
          ],
