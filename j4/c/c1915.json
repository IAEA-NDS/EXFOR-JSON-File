              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " An integrated beam intensity of about 3 x10",
                "16 protons went through the targets, and was probably",
                "known to better than 10%."
              ]
            },
