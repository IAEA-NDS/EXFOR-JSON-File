          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The primary experimental data are cumulative yields,",
                "represented by cumulative cross sections. It was",
                "assumed that the charge distributions of neighboring",
                "isobaric chains are similar and radionuclide yields",
                "from a limited mass region can be used to determine a",
                "single charge distribution curve for that mass",
                "region. Then laws of radioactive decay was used to",
                "iteratively correct the measured cumulative formation",
                "cross sections for precursor decay to obtain",
                "independent cross sections."
              ]
            }
          ],
