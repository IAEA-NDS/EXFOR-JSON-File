          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mass of the lowest T=2 state in 32S: A test of the",
                " isobaric multiplet mass equation"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAWAU"
              },
              "free_text": [
                " University of Washington FN tandem",
                " accelerator, operating in a mode with the ion source",
                " at the terminal"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target bombarded by a 600 nA, 1.912 MeV proton beam"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " Gamma rays were registered with a 50% HPGe",
                " (GMX) detector whose signals were processed by",
                " temperature-controlled electronics to minimize gain",
                " drifts."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "31P target by implanting 55 microAh of 90 keV 31P ions",
                " from a sputter ion source into a 0.5 mm thick tantalum",
                " backing. The 31P beamwas rastered using computer-",
                " controlled magnetic steerers to produce a uniform",
                " target with a cross section of approximately 1.1 cm2",
                " and a measured energy loss of 4 keV for 3 MeV protons."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy calibrationwas based on a 56Co source and",
                " 35Cl(n, g) capture radiation with two HPGe detectors",
                " located about 60 cm from the center of the chamber,",
                " at +/- 90 degree to the beam where the Doppler",
                " shift is minimal.",
                "The energy calibration for this measurement was based",
                " on 56Co and 27Al(p, g) radiation for the detector",
                " aligned at 0 degree and positioned 10.3 cm from the",
                " target."
              ]
            }
          ],
