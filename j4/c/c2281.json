                "field_identifier": "ENR",
                "value": 0.994
              },
              "free_text": [
                " 26Mg foils (99.4% isotopic",
                "abundance, 3.5-3.9 mg/cm2 thick, ~ 1 mg total",
                "material)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
