          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A deuteron tensor polarimeter for low-energy",
                " experiments"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ACCEL"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " the Low Energy Beam Facility at",
                " Triangle Universities Nuclear Laboratory (TUNL)."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "ATOMI"
                ],
                "reaction": null
              },
              "free_text": [
                " A tensor-polarized deuteron beam was obtained",
                "from the TUNL atomic-beam polarized ion source"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The tar ets were 0 005 cm tantalum foils implanted",
                " with 17 keV He Ions with a measured dose of",
                " 2.7 x 10E17 3He/cm2. The mean implant depth of about",
                " 60 nm is reached by 130 keV deuterons after",
                " undergoing an energy loss of about 9 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A 30 cm scattering chamber, contained four",
                " 1000 microm solid-state detectors, symmetrically",
                " placed on either side of the beam. The detectors on",
                " each side were separated by 30 degree and subtended",
                " +/- 2 degree."
              ]
            }
          ],
