          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "99.99% pure natural magnesium evaporated of on 0.02",
                "in. thickcopper backing. Magnesium thickness was",
                "100 - 400 nm,corresponding to target thicknesses of",
                "30.- 120 keV at an Alpha beam energy of 1.53 MeV for",
                "a target orientation of 45. deg with respect to the",
                "beam direction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High-purity germanium clover detector, with",
                "the clover operated in add-back mode placed at a",
                "distance of 2.5 cm behind the target,at 45. with",
                "respect to the beam direction"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Four NaI(Tl) detectors (each 8 in. diameter",
                " and ~6 in. thickness) were mounted in a common stand,",
                "and each was rotated 45. in polar and azimuthal",
                "angles, with respect to the beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between NaI(Tl)",
