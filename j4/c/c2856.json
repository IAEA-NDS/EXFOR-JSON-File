          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "10-NE-20",
                "field_identifier": "NAT",
                "value": 0.909
              },
              "free_text": [
                " Since neon is chemically inert,",
                "it is difficult to prepare a solid target containing",
                "a sufficient amount of neon to make neutron",
                "measurements possible. For this reason, a gas cell",
                "containing natural neon(90.9% Ne20, 0.26% Ne21, and",
                "8.8% Ne22) was employed. The neon gas was",
                "spectroscopically pure. The gas cell was a platinum",
                "tube, 0.5 in. in diameter and 1.5 in. in length. The",
                "entrance aperture, 0.25 in. in diameter, was covered",
                "with a nickel foil, either 0.025 mil or 0.10 mil in",
                "thickness. Gas pressures of 5 in. Hg were used. This",
                "amount of neon is about 135 keV thick to 2-MeV",
                "deuterons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Two paraffin-moderated BF3 counters, one",
                "preferentially sensitive to neutrons with energies up",
                "to about 300 keV and the other sensitive only to",
                "those neutrons whose energy is greater than about 300",
                "keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The counter ratio technique."
              ]
            }
          ],
