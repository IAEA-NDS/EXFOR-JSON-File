          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The mass distribution is interpreted as a",
                "superposition of two main components: (1) products",
                "from high-energy fission processes, (3480+-700) mb,",
                "and (2) products from low-energy fission, (1500+-220)",
