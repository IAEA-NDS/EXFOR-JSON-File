          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation method was used in inverse",
                "kinematics. 34S ions were accelerated and and directed",
                "on gaseous 3He target. Reaction products were recoiled",
                "in forward direction and were implanted into an Al",
                "catcher foil. 99.9% of recoils are caught within the",
                "9cm diameter circular cross section of the catcher foil"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Reaction products were chemically separated",
                "from the Al catcher foil."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "AMS"
              ],
              "free_text": [
                " Accelerator mass spectrometry was used to",
                "identify and measure the amount of 36Cl reaction",
                "products. Measurements were performed at both",
                "NSL and PRIME Lab (Purdue Rare Isotope Measurement",
                "Laboratory) at Purdue University"
              ]
            }
          ],
