          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of 6Li by 39K at 28 and 34 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAFSU"
              },
              "free_text": [
                " the Florida State University Super FN",
                " tandem Van de Graaff accelerator."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 28-37 MeV 6Li beams"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " To avoid systematic errors resulting from the",
                " energy loss in the targets as a result of the",
                " different thicknesses, the bombarding energy was",
                " adjusted so that the beam energy was the same at the",
                " center of the target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " The angular acceptances (plane angle) of",
                " the detectors used were: 0.25 degree for the",
                " detector in the extreme forward position, 0.35 degree",
                " for detectors used in the theta < 40 degree region,",
                " and 0.7 degree for the counter telescopes used for",
                " the angular region beyond 40degree."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were prepared from compounds (KOH, KF)",
                " of natural potassium (93.2% abundance of 39K),",
                " evaporated onto 30-50 microg/cm2 thick carbon",
                " backings. For angles out to 20 degree (lab),",
                " KOH targets 100 microg/cm2 thick were used. Between",
                " 20 degree (lab) and 120 degree (lab) a KF target",
                " of thickness 200 microg/cm2 was used. Beyond 120",
                " degree (lab) the thickness of the targets was",
                " increased to 400 microg/cm2"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "6Li"
              ]
            }
