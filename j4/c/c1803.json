          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                " Experiment was carried out at the",
                "Holifield Radioactive Ion  Beam Facility (HRIBF)",
                "using the Isotope Separator On-Line technique."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " The reaction products were",
                "detected in a stack of three 5 x 5 cm2 silicon strip",
                "detectors. The front and middle detectors were single-",
                "sided with 16 strips each. They were mounted with their",
                "strips oriented perpendicular to each other yielding",
                "256 pixels in the active area. The thickness of the",
                "front detector was 4 mu-m and the middle detector",
                "278 mu-m. They were used for identifying projectile-",
                "like particles by measuring the energy loss dE in the",
                "front detector and the residual energy E in the middle",
                "detector. The breakup protons had sufficiently high",
                "energy to pass through the first two detectors. They",
                "were detected in the back detector which was double-",
                "sided with 16 horizontal strips on one side and",
                "16 vertical strips on the other. The thickness of the",
                "back detector was 295 mu-m."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " The 17F beam was produced by the 16O(d,n)",
                "reaction using the Isotope Separator On-Line technique.",
                "The 17F ions were post-accelerated by the 25 MV tandem.",
                "The analyzing magnet located at the exit of the",
                "accelerator was set to select fully stripped 17F9+ ions"
              ]
            }
          ],
