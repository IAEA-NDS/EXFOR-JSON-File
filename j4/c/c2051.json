              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "Neutron spectra were recorded by two 10cm by 5cm",
                "xylene scintillators, positioned over 20 m from the",
                "target chamber center along separate lines of sight.",
                "A 1.3 cm thick attenuator (95% W, 3% Ni, and 2% Fe)",
                "covered each line of sight to suppress the photon",
                "background created during implosions."
