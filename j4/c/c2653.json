          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets, consisting of approximately 200",
                "microg/cm2 of gold vaporized onto 0.1-mil aluminum",
                "backing foil, were oriented at 45 deg to the beam,",
                "with the gold facing toward or away from the beam",
                "when fragments were observed at backward or forward",
                "angles, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular-distribution experiments were performed in",
                "the vacuum tank. The energy of the carbon ions was",
                "varied by placing aluminum degrading foils in the",
                "beam path ahead of the vacuum tank. A simpler",
                "arrangement, in which a gas scintillation counter was",
                "fixed at 90 deg to the beam, was used for experiments",
                "in which it was necessary to observe fragments only",
                "at 90 deg to the beam."
              ]
            }
          ],
