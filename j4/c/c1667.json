          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement and analysis of energy and angular",
                "distributions of thick target neutron yields from",
                "110 MeV 19F on 27Al"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
