          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                " Silver bombarded with alpha-particles",
                "produces radioactive substances with the following",
                "three half-live's: 65 min., 5.2 hr., and 2.7 d. All of",
                "these activities have been chemically attributed to",
                "indium and have been assigned by mass-spectrograph",
                "separation to In110, In109, and In111, respectively."
              ]
            }
          ],
