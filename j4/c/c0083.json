          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Liquid-hydrogen target contained within flask of",
                " hydrogen gas.  For 492 MeV temperature maintained at",
                " 19.87(+-0.003K) or 20.13(+-0.001K)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " LAMPF beam energy measured using long neutron",
                " time-of-flight path.",
                "A particle-counting method was used to determinate",
                " the beam intensity."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN",
                "MWDC",
                "MWPC"
              ],
              "free_text": [
                " Two identical detector arrays were",
                " placed either side of the beam line to detect both",
                " scattered protons.  Each array contained detectors of",
                " three diferent types: scintillator hodoscopes,",
                " multiwire drift chambers, and multiwire proportional",
                " chambers."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections include:",
