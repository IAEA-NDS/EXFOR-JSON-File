          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USAMSU"
              },
              "free_text": [
                " Experiment performed at ATLAS",
                "facility at Argonne National Laboratory using HELIOS",
                "solenoidal spectrometer"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated polyethylene (CD2)n foil target of areal",
                "density 140 mu-g/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The charged reaction products were separated",
                "in superconducting solenoid with a bore diameter of",
                "920 mm and length of 2350 mm. Polyethylene target was",
                "placed at the solenoid entrance, 550 mm upstream of",
                "the geometric center of the magnet. The 3He particles",
                "emerged in the forward hemisphere with laboratory",
                "angles less than 35 deg. Particles were transported in",
                "helical trajectories to detector array."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PS"
              ],
              "free_text": [
                " An array of 24 position sensitive Si detectors",
                "placed on the beam axis in the downstream end of",
                "HELIOS was used to detect the 3He ions."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Recoil telescope consisted of dE and E",
                "detectors with thicknesses of 500 and 1000 mu-m,",
                "respectively"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A silicon surface-barrier detector was",
                "mounted on the recoil-detector assembly at 0 deg to",
                "monitor incident beam flux. A Ta sheet 0.5 mm thick",
                "with regular holes with diameter of 80 mu-m was used",
                "to attenuate the incident flux to manageable level."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Inverse kinematics was used."
              ]
            }
          ],
