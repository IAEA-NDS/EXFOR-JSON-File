              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties are determined from the",
                "Gaussian fit with the area and the width as free",
                "parameters. In addition, the uncertainty of the",
                "contribution from the background from reactions in",
                "the detectors is added in quadrature."
              ]
            }
