            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The stack consisted of three 500-microm thick",
                "silicon surface barrier detectors followed by three",
                "5000-microm thick lithium-drifted silicon diodes."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " A 110 MeV/nucleon 48Ca19+ primary beam was",
                "fragmented on a beryllium target. The secondary F",
                "beam was directed to a stack of Si detectors. The",
                "oxygen isotopes were identified by their DE-E signals."
              ]
            }
          ],
