          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target used for this work contained about 10**13",
                "atoms of monoisotopic Cf249 in addition to about",
                "2x10**13 atoms of its parent Bk249."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "REC",
                "ACTIV"
              ],
              "free_text": [
                " Immediately after bombardment, the",
                "californium and einsteinium reaction products were",
                "separated by ion-exchange methods and",
                "electrodeposited on platinum foil for examination by",
                "alpha pulse-height analysis."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The approximate cross sections were calculated from",
                "the observed alpha-disintegration rates and branching",
                "ratios, assuming recoil collection yields of 100% in",
                "the bombardments."
              ]
            }
          ],
