          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections were obtained from the charge collected,",
                "target thickness, dead time, and known solid angle."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Multipole-dipole-multipole spectrometer MDM."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC",
                "IOCH",
                "SCIN"
              ],
              "free_text": [
                " The focal-plane detector consisted of",
                "four proportional counters to measure x position at",
                "four points along a ray's path using the method of",
                "charge division, as well as an ionization chamber to",
                "provide dE and a scintillator to measure total energy",
                "and provide a fast timing signal for each ray."
              ]
            }
          ],
