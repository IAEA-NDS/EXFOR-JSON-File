          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Large-angle elastic scattering of alpha particles by",
                " 39K, 40Ca, 42Ca, 44Ca and 50Ti"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAMIT"
              },
              "free_text": [
                "  MIT cyclotron"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Alpha beam at 30.5 MeV"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The scattered alphas were detected in",
                " semiconductor (gold surface barrier) detectors."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 42Ca and 44Ca targets were prepared using natural",
                " Ca. Enriched 42Ca (92.3 % 42Ca, 5.7 % 40Ca, 0.95 %",
                " 43Ca and 1.0 % 44Ca) and enriched 44Ca (98.6 % 44Ca,",
                " 1.3 % 40Ca) were obtained in the carbonate form from",
                " Oak Ridge.",
                "The 50Ti (69.7 %, 50Ti, 2.4 % 47Ti, 22.8 % 48Ti and",
                "2.0 % 49Ti) target was obtained from Oak Ridge as a",
                "self-supporting 1.0 mg/cm 2 foil."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The data were normalized in two ways. The beam was",
                " stopped in a faraday cup and integrated to obtain the",
                " total charge collected during the taking of a data",
                " point. A second method was to scatter the beam from",
                " the target into a monitor counter at a fixed angle."
              ]
            }
          ],
