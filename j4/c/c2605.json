                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors indicated on this curve are",
                "estimated probable errors, arising from counting",
                "statistics, chemical operations, and correction",
                "factors applied."
              ]
            }
