                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Cross sections were determined from analysis",
                "of gamma ray decay curves, followed over period of",
                "several months."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 225Ac, 223,225Ra,and 227Th activities at EOB were",
                "calculated by performing a Markov chain Monte Carlo",
                "analysis of the measured decay curves."
              ]
            }
          ],
