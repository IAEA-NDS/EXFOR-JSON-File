          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Detector assemblies were used. One served as",
                "a monitor at a fixed angle and the other served to",
                "measure differential cross sections.The particle",
                "detector was a silicon, surface-barrier type, having",
                "a sensitive area of 100 mm2 and a maximum depletion",
                "depth of 700 mu-m."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 4He target gas was contained in gas cells",
                "enclosed by 6-mu-m-thick Kapton plastic foil. Most of",
                "the data were obtained using a 2.3-cm-diam",
                "cylindrical brass cell having 1-cm-high windows",
                "separated by two posts. Some forward-angle data were",
                "obtained using a 3.8-cm-diam brass cell having a",
                "3.5-cm-long snout."
              ]
            }
          ],
