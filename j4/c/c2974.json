          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Four thin foils (17 mg/cm2) of natural thorium metal",
                "in a stacked-target configuration. Natural Th foil",
                " (0.0125 mm thickness, 99.5% purity) was purchased",
                "from Goodfellow Corporation, and cut into",
                "approximately 18 mm x 18 mm squares. A stack of four",
                "such Th foils was constructed, along with 0.025 mm",
                "thickness monitor foils of natural Fe (99.5% purity)",
                "and natural Cu (99.95% purity), 0.012 mm thickness Al",
                "foils (99.99% purity) to encapsulate the Th and prevent",
                " loss of target material."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                " After irradiation, the foils were",
                "shipped to Oak Ridge National Laboratory for chemical",
                "separation and analysis. The gamma-ray spectroscopy",
                "measurements were conducted using a well-shielded",
                "CANBERRA GEM series HPGe coaxial detector."
              ]
            }
          ],
