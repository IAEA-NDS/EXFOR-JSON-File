          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "To convert observed yield of alpha-particle-proton",
                "events to a differential cross section for the",
                " (alpha,5Li(g.s.)) reaction has been assumed that the",
                "5Li -> alpha+p breakup angular correlation is isotropic",
                "in the 5Li c.m. system."
              ]
            }
