          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The resonance strength was obtained from the best fit",
                "to the yields data."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The three largest sources of purely systematic",
                "uncertainties in the resonance strength were:",
                "the thickness of the carbon foil used for beam current",
                "normalization (6% arising primarily from the",
                "uncertainty in stopping powers for alpha particles in",
                "carbon), the strength of the alpha source used for",
                "efficiency calibrations (3%), and the stopping power",
                "for 17O in hydrogen gas (2% as determined in this",
                "measurement). Adding each of these uncertainties in",
                "quadrature with the result from the fit to the yield",
                "curve produces a final result."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Carbon foil thickness."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Alpha source strength."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Stopping power of 17O."
              ]
            }
          ],
