                "institute": "1USAORL"
              },
              "free_text": [
                " The Holifield radioactive ion beam",
                "facility (HRIBF) at Oak Ridge national laboratory."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Low-energy beams of 17O from the HRIBF tandem",
                "accelerator with an intensity of about 1 pna."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Windowless gas target. Large scattering chamber",
                "filled with hydrogen gas at a pressure of 4 torr.",
                "Ultrahigh purity gas (>99.999% H2)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Nitrogen recoils from the 1H(17O,alpha)14N",
                "reaction have laboratory angles <21 degree and thus",
                "pass through the center of the annular Silicon",
                "Detector Array (SIDAR) from any point of origin inside",
                "the target chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The alpha and 14N reaction products were",
                "detected in coincidence by an array of silicon strip",
                "detectors operating within the hydrogen gas",
                "environment. The kinematics and relative timing of",
                "the two detected particles allowed the 1H(17O,alpha)",
                "14N reaction to be cleanly distinguished."
              ]
            }
          ],
