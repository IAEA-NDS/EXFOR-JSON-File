          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A strong polonium sample (158 or 280 mc) prepared by",
                "Prestwood by electrolysis on platinum, 210Po alpha",
                "particles. Present day energy values is 5.40753 MeV",
                "compared to 5.3 MeV in the report."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy of the alpha particles impinging on the",
                "target is varied by changing the pressure of the air",
                "contained in the collimator. The neutrons were",
                "counted in BF3 chamber. The background effect was",
                "measured with a brass target, at various air",
                "pressures in the collimator."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected the observed neutron intensities to take",
                "into account some variation in area of the targets",
                "and their chemical composition."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
