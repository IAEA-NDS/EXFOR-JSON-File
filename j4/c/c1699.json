          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "144Sm (94% enriched) targets having thicknesses in",
                "the range of 450-678 mu-g/cm2. These targets were",
                "prepared by electrodeposition on an Al backing of",
                "thickness 2.2 mg/cm2. The thickness of the targets",
                "was measured by the Rutherford backscattering method",
                "using a 60 MeV O-16 beam."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The reaction products were stopped in the",
                "target and Al backing and were identified by their",
                "characteristic gamma rays by off-line counting using",
                "a high-purity Ge detector"
              ]
            }
          ],
