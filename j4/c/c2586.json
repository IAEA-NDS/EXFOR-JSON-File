          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two types of targets were used.",
                "  1.CdS with thickness of (249+-25) mu-g/cm2 evaporate",
                "    onto natural carbon foil with thickness",
                "    of 20 mu-g/cm2. It was used at lab angles of",
                "    10, 20, 22, and 62deg.",
                "  2.Isotopically pure 32S with (10.4+-0.4) mu-g/cm2",
                "    implanted in isotopically pure 12C foil with",
                "    thickness (55.9+-5.6)mu-g/cm2. Implanted target",
                "    was used at lab angles 22, 27.5 and 45deg."
              ]
            }
          ],
