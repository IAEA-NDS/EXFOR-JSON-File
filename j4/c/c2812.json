          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental measurement of 12C+16O fusion at stellar",
                "energies"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
