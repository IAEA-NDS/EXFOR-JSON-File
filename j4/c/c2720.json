          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Radium with its decay products consists of five",
                "alpha-emitting isotopes with energies ranging from",
                "4.8 to 7.7 MeV and an average energy of 5.8 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " An Ilford L4 plate, 2 x gelatine, 7.5 cm x",
                "2.5 cm, of 200-micrometer emulsion thickness."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "4-BE-9",
                "field_identifier": "NAT",
                "value": 1.0
              },
              "free_text": [
                " 2.5 g."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " The neutron energy spectrum of a Ra-Be source",
                "has been measured successfully by the nuclear",
                "emulsion technique without introducing a significant",
                "thickness of lead absorber to reduce the gamma-ray",
                "background. As a validity check on the distribution",
                "of tracks, the number of tracks as a function of the",
                "angle theta between the incoming neutron and outgoing",
                "proton was plotted. Satisfactory agreement with the",
                "expected sin theta cos theta variation was found."
              ]
            }
          ],
