          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The relation used e(theta) = Pb*P(theta) in which",
                "e(theta) = [sigma left (theta) - sigma right (theta)]/",
                "[sigma left (theta) + sigma right (theta)]. Pb is the",
                "polarization of the beam, and P(theta) is the",
                "polarization that would be produced by scattering an",
                "unpolarized beam at angle theta on the substance in",
                "question (in the present experiment, helium or carbon)."
              ]
            }
          ],
