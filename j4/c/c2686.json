            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Secondary beam of 13-O was produced from primary 16-O",
                "beam on Be target at energy of 150 MeV/A. The beam",
                "was purified using the A1900 magnetic spectrometer",
                "and the radio frequency fragment separator and had an",
                "intensity of 10+3 pps with purity of 80%."
              ]
