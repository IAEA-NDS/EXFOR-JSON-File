          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Measurements between 15 and 165 deg. were",
                "taken with an array of four surface-barrier detectors",
                "mounted on the cart assembly with separations of 5",
                "deg.. Measurements at angles beyond 165 deg. were",
                "made using two surface-barrier, position-sensitive",
                "detectors (1x3 cm, 600-mu-m thick) ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting targets, about 1 mg/cm2 thick,",
                "of 45Sc, 65Cu, 90Zr, and 122Sn."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 2.0,
                "maximum_value": 8.0,
                "correlation_property": null
              },
              "free_text": [
                " Estimated absolute accuracies for the",
                "cross sections measured",
                "  with the cart detectors (from 15 to 165 deg.) were",
                "  between +/-2% and +/-5% except for a few points at",
                "  deep minima in the angular distributions;",
                "  with the position sensitive detectors (162-175 deg.)",
                "  were +/-8%."
              ]
            }
