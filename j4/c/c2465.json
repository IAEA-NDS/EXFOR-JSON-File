          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-238",
                "field_identifier": "ENR",
                "value": 0.996
              },
              "free_text": [
                " Depleted (99.6 percent 238U)",
                "uranium foil targets sandwiched between aluminum",
                "catcher foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) spectrometer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Radiochemical separation was used following",
                "dissolution of the target and catcher foils in 1 ml",
                "of concentrated HCl containing a few drops of HNO3 and",
                "H202. A Ge(Li) spectrometer was used to measure the",
                "nuclidic yields. For those measurements in which no",
                "radiochemical separation was performed on the target,",
                "both the target and catcher foils were mounted for",
                "gamma analysis in a manner identical to that used for",
                "the purified samples."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error limits shown for each fractional",
                "chain yield were computed according to the",
                "statistical equation: (A+-a)/(B+-b) =",
                "A/B + (sqrt(a**2*B**2 + b**2*A**2))/B**2, where A and",
                "B stand for the measured cross",
                "sections of shielded and cumulative nuclides",
                "respectively and a and b stand for the computed error",
                "in their respective values, The compound standard",
                "deviation in the measured cross sections was",
                "estimated to be ~6 percent."
              ]
            }
          ],
