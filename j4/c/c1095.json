          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Average ranges, cross sections and isomer ratios for",
                "the 134Ba(alpha,n)137m,gCe reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "D.G.Swanson",
