              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " The beamlike recoils from the scattering",
                "reactions were detected and identified in a gas-filled",
                "ionization counter in coincidence with the protons",
                "detected by the SIDAR."
              ]
            }
