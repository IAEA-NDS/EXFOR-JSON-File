          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAMSU"
              },
              "free_text": [
                " Experiment performed at Coupled",
                "Cyclotron Facility at the  National Superconducting",
                "Cyclotron Laboratory using the A1900 fragment",
                "separator and large acceptance magnetic spectrograph",
                "S800."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "9Be secondary target with thickness of 376 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "PPAC",
                "SCIN"
              ],
              "free_text": [
                " Superconducting fragment separator",
                "A1900, consisting of several quadrupole triplets and",
                "two dipole magnets were used to select desired ions",
                "in the midacceptance position of the separator.",
                "Two parallel plate avalanche counters and plastic",
                "scintillation detectors at the were used for ion",
                "identification at the secondary target position.",
                "Magnetic spectrometer S800 were used for identification",
                "of reaction products"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " SeGA array of 17 segmented HPGe detectors was",
                "placed around secondary 9Be target for gamma ray",
                "detection. Each detector has 32 segments to allow",
                "for correction of Doppler effect."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " A primary beam of 150MeV/nucleon 36Ar beam",
                "impinged on a 9Be  production target at the",
                "midacceptance position of the A1900 fragment",
                "separator. Secondary beams of 26Si and 30S were",
                "selected by the A1900."
              ]
            }
          ],
