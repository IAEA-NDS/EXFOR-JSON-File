          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target foils 15.6 and 24.5 mg/cm2 thick were used.",
                "For the higher energy deuteron data thicker carbon",
                "wafers (287 mg/cm2) were sandwiched between",
                "neighboring foils; spectra from the thin foils were",
                "used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " Stacked carbon foil targets were exposed",
                "to incident particle beams. Subsequently gamma-ray",
                "spectra of individual target foils were measured to",
                "determine the 7Be yields."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": 10.0,
                "maximum_value": 200.0,
                "correlation_property": null
              },
              "free_text": [
                " Errors in the absolute cross",
                "sections are less than 10% in the flat portions of",
                "the excitation functions. In the steep portions of",
                "the curves uncertainties in incident particle energy",
                "due to straggling result in errors as large as a",
                "factor of 2. This is most apparent in the deuteron",
                "data."
              ]
            }
          ],
