            },
            {
              "pointer": "",
              "coded_information": [
                "MISC2"
              ],
              "free_text": [
                " Lower limit of calculated data",
                "Calculated rate carries a large uncertainty;",
                "The upper limit of the rate was calculated using the",
                "upper limit of the measured yield at around 2.4 MeV.",
                "The lower limit of the reaction rate corresponds to",
                "the lower limit of the measured yields without taking",
                "possible higher energy or lower energy resonances",
                "into account."
              ]
            }
