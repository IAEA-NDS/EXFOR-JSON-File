          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reaction rate was obtained from measured data using two",
                "methods, which  gave excellent agreement. In the first",
                "method rate was calculated by integrating the",
                "experimental cross section over Maxwell-Boltzman",
                "distribution of a stellar gas at tempereture T. The",
                "second method for determining the reaction rate was",
                "based on the measurement of the on-resonance yield."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
