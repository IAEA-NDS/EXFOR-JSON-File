          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCTM"
                ],
                "institute": "1USAMSU"
              },
              "free_text": [
                " Experiment was performed at the",
                "National Superconducting Cyclotron Laboratory using",
                "Coupled Cyclotron Facility"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "38-SR-88",
                "field_identifier": "ENR",
                "value": 0.999
              },
              "free_text": [
                " Isotopically enriched 88Sr foil",
                "with a thickness of 19.6 mg/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " 3He ejectiles produced in the reaction were",
                "momentum analyzed using S800 magnetic spectrograph",
                "and identified in its focal plane"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Particle identification was performed by time",
                "of flight method using plastic scintillator with",
                "thickness 5 mm located in focal plane of S800",
                "spectrograph relative to the cyclotron radiofrequency",
                "signal."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DRFTC"
              ],
              "free_text": [
                " Scattering angles and momenta of the",
                "ejectiles at the target location were reconstructed",
                "by ray tracing the angles and positions measured in",
                "two cathode-readout drift chambers on the S800 focal",
                "plane."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma rays emitted from excited 88Rb nuclei",
                "were detected by GRETINA gamma ray array consisting",
                "of thirty-two 36-fold segmented HPGe detectors",
                "mounted on hemisphere around 88Sr target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight together with energy loss dE in",
                "plastic scintillator was used for particle",
                "identification. Excitation energy of the 88Rb nuclei",
                "was calculated using missing mass method with",
                "resolution of 500 keV."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " A primary beam of 16O with an energy of 150",
                "MeV/u, was impinged on a beryllium production target",
                "with a thickness of 3525 mg/cm2. The A1900 fragment",
                "separator was used to select tritons from the",
                "reaction products"
              ]
            }
          ],
