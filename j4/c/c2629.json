          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,103,055801,2021",
                "code_unit": [
                  {
                    "unit": "J,PR/C,103,055801,2021",
                    "doi": "10.1103/PhysRevC.103.055801",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
