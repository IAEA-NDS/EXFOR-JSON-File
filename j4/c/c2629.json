          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton capture on 34S in the astrophysical energy",
                "regime of O-Ne novae"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
