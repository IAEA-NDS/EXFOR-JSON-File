          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The time-of-flight spectrum has been converted to an",
                "energy scale. The neutron energy scale was calibrated",
                "by use of (p,n) transitions in 7Li and 12C targets",
                "which have known Q values."
              ]
            }
          ],
