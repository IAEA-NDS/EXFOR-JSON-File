          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR",
                "TELES",
                "SIBAR"
              ],
              "free_text": [
                " Heavy-ion Si-surface-barrier",
                "detector. Particle telescope consisting of two",
                "totally depleted silicon-surface-barrier transmission",
                "detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Fission-fragment angular-distribution",
                "measurements were performed at alpha-particle",
                "energies of 27.5, 33.5, 43.8, 49.9, 58.9, 70.5,",
                "and 140 MeV for the alpha+233U system and at 69.2 and",
                "140 MeV for the alpha+209Bi system. Measurements were",
                "performed in ten-degree steps from 10 to 170 degrees.",
                "In addition, finer angular steps of 2 to 4 degrees",
                "were taken near 10, 90, and 170 to define the shape",
                "of the angular distribution in these regions. The",
                "fragment angular distributions were measured with a",
                "particle telescope consisting of two totally depleted",
                "silicon-surface-barrier transmission detectors (a 4",
                "microm thick dE and a 25 microm thick E)."
              ]
            }
          ],
