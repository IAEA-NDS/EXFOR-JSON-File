          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reaction mechanism studies with 7-35 MeV/nucleon 4He",
                "ions incident on heavy target nuclei"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
