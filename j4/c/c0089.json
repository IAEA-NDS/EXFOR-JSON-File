          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "3H(p,g)4He cross section"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USACAL"
