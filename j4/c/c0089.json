              "free_text": [
                ""
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "0.4 - 20 microA proton beams, up to 6 MeV",
                " H2+ molecules for 0.2 < Ep > 0.5 MeV proton beam and",
                " H3+ molecules for Ep = 0.1 MeV proton beam.",
                "Energy given is average of incident and exit energy",
                " of the proton beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two Ti-3H targets: one on Ta backing (1.15x10**18",
                " H3 atoms/cm2, 1.35x10**18 Ti atoms/cm2), and one on",
                " Cu backing (3.80xE17 H3 atoms/cm2, 2.16xE17 Ti",
                " atoms/cm2)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Targets mounted at 45 degrees to incident beam.",
                "Detectors placed at opposite sides of the target and",
                " 90 degree to the incident beam.",
                "Detector efficiencies were calculated using EGS4 Monte",
                " Carlo program and tested by using 19F(p,ag)16O",
                " reaction."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainties include errors in:",
                "      detector efficiency           6%",
                "      statistical error             1%",
                "      target stability              3%",
                "      H3 areal density              3%",
                "  At low energy errors due to the energy loss in the",
                "   target are also included.",
                "  For NaI detector errors due to gain shift are",
                "   included."
              ]
            }
          ],
