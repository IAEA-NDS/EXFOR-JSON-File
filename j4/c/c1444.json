          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections for 165 degree backscattering of",
                " 8.0-11.7 MeV a from carbon"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USASC"
              },
              "free_text": [
                " A 6 MV EN tandem Van de Graaff-",
                " Pelletron accelerator"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy range from 8.0 to 11.7 MeV at the 165 degree",
                " backscattering angle. The beam energy has an energy",
                " spread of +/- 1 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " an Ortec (BB-016-050-400), having a about",
                " 16 keV energy resolution and 400 lm depletion depth.",
                " The detector solid angle was 6.888 msr as measured",
                " using a NIST traceable 238Pu-alpha source that had",
                " a certified activity of +/- 1.3 %."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Carbon films were e-beam deposited onto Mo substrates",
                " and analyzed using both 1.5 MeV 1H+ and 4He+",
                " backscattering spectrometry.",
                "The C foils were purchased from ACF-Metals with a",
                " stated thickness of about 42(+/-4) microg/cm2 and were",
                " floated off the glass substrate on which they were",
                " deposited using deionized water and mounted on flat",
                " stainless steel washers."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The uncertainty in the absolute carbon cross section",
                " measurements for the Sandia foils is +/- 10.3%, using",
                " the mean peak yield and +/- 11.4% at the lowest peak",
                " yield."
              ]
            }
          ],
