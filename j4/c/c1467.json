          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton-3He elastic scattering at low energies"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ACCEL"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " the TUNL supersonic gas-jet target, a",
                " refurbished and upgraded version of the target",
                " designed and built at the University of",
                " Erlangen-Nurnberg"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A beam of 3He++ ions was accelerated with the FN",
                " tandem accelerator and then deflected onto the",
                " hydrogen gas-jet target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target thicknesses of about 5 x 10E17 atoms/cm2 were",
                " routinely obtained in a narrow jet (about1 mm) for",
                " the measurements in this work, facilitating very",
                " reasonable counting times for the cross sections",
                " measured."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Each detector was fitted with a pair of",
                " rectangular slits mounted in a cylindrical \"snout\"."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measurements were performed in inverse kinematics",
                " using a 3He beam incident on a hydrogen gas-jet."
              ]
            }
          ],
