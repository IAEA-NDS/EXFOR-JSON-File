          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Excitation functions were measured by",
                "detecting the induced positron activity following a",
                "bombardment, rather than the outgoing neutrons during",
                "bombardment. The absolute cross section was",
                "determined by measuring the positron energy spectrum",
                "in a well counter made of plastic scintillator. 39Ca",
                "activity was identified from its half-life of 0.877",
                "sec."
              ]
            }
