            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                "Reaction products were momentum analysed using",
                "multipole-dipole-multipole spectrometer and detected",
                "in 60 cm long focal plane detector. The horizontal",
                "acceptance of the spectrometer was 4deg and ray",
                "tracing was used to reconstruct the scattering angle.",
                "The vertical acceptance was +-2 deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC",
                "IOCH",
                "SCIN"
              ],
              "free_text": [
                " Focal plane detector consisted of",
                "four resistive wire proportional counters to measure",
                "position. Ionization chamber measured energy loss and",
                "scintillation detector behind the ionization chamber",
                "measured deposited energy and provided time of flight",
                "signal."
              ]
            }
