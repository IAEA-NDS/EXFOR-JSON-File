          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "DRFTC"
              ],
              "free_text": [
                " The 3He particles produced in the",
                "24Mg(t,3He) reaction were detected and identified in",
                "the focal plane detector system of the S800. Two",
                "cathode readout drift chambers determined the",
                "positions and angles in the dispersive and",
                "nondispersive directions in the focal plane of S800."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Triton beam with intensity of appr. 5E+6",
                "ions/sec was achieved by fast fragmentation of a",
                "150A MeV primary 16O beam using A1900 fragment",
                "separator. The secondary triton beam of 115A MeV",
                "was transported to the target located at the entrance",
                "of the S800 spectrometer."
              ]
            }
