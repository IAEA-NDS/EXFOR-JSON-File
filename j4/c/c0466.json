          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of polarized 8Li with the",
                " 7Li(d-pol,8Li-pol)p reaction."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAWIS"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLIS"
                ],
                "reaction": null
              },
              "free_text": [
                " Polarized ion source used to provide a",
                " momentum analyzed,variable energy, beam of",
                " vector polarized deuterons with polarization",
                " py or pz = 0.59 (0.01). The maximum py or pz",
                " for a purely vector polarized beam is  +-2/3.",
                " The tenzor polarization of the beams were",
                " pyy and pzz < 0.05."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were typically 1-mm thick Li metal wafers,",
                " enriched to 99.9 % in 7Li, and held near",
                " liquid-nitrogen temperature (77 K)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Target was activated for 1 s and activity",
                " counted as function of time for 4 s.  The sign of",
                " the deuteron polarization was reversed, and the",
                " cycle repeated."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN"
              ],
              "free_text": [
                " Plastic scintillators or detector",
                " telescopes sufficiently thick to stop 16-MeV",
                " electrons for detecting of beta-particles."
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": {
