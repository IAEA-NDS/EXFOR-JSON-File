          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New energy for the 133-keV resonance in the",
                "23Na(p,gamma)24Mg reaction and its impact on",
                " nucleosynthesis in globular clusters"
              ]
            }
          ],
