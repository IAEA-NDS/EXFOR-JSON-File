          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 30-cm3 Ge(Li) detector."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural uranium, thorium, radium, and bismuth targets",
                "ranging in thickness from 1-2 mg/cm2 of the metal or",
                "its oxide. Each target was covered with an Al catcher",
                "foil that was >99.9999% pure."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "EXTB"
              ],
              "free_text": [
                " Following irradiation, the target foil",
                "and the Al catcher foils were dissolved in acid, and",
                "standard radiochemical techniques were used to",
                "separate the Cd and Cs isotopes from the fission",
                "products. A Ge(Li) detector was used to measure the",
                "gamma-ray spectra of the separated fission products",
                "as a function of time."
              ]
            }
          ],
