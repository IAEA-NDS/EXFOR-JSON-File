          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "54.7 MeV 17F beam produced by 16O(d,n) in-flight",
                "which uses primary 16O beam with energy 79 MeV",
                "bombarding cryogenically cooled deuterium gas cell",
                "with 2 microm-thick havar windows."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI",
                "TELES",
                "IOCH"
              ],
              "free_text": [
                " A telescope of double-sided silicon",
                "detectors of Design S2 fabricated by Micron",
                "Semiconductor. The first dE layer was 65-microm thick,",
                "while the residual particle energy was measured by a",
                "1-mm-thick backing detector. Recoiling heavy ions",
                "were detected in coincidence by a gas ionization",
                "chamber located 25.7 cm downstream from the target.",
                "The ion chamber has a 6.4-cm-diameter window made of",
                "7-microm-thick kapton centered on the beam axis."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Solid polypropylene target of thickness 2.05 mg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "COINC"
              ],
              "free_text": [
                " Inverse kinematics measurement.",
                "Coincidence between scattered protons detected in Si",
                "telescope and 17F detected in ionization chamber was",
                "used. Average CM angle of 146.9 deg used for R-Matrix",
                "analysis of scattered protons, integrating over lab",
                "angles 8 deg to 24 deg i.e. CM angles 134.5 to 164.9",
                "deg."
              ]
            }
