            {
              "pointer": "",
              "coded_information": {
                "nuclide": "82-PB-206",
                "field_identifier": "ENR",
                "value": 0.005
              },
              "free_text": [
                " Targets consisted of metallic",
                "208Pb deposited on 35 +- 5-microg/cm2 natC backings to",
                "a thickness of 470 +- 60 microg/cm2. The Pb layer was",
                "covered with 5 +- 2-microg/cm2 natC to prevent the",
                "loss of target material caused by the beam."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD",
                "MWPC"
              ],
              "free_text": [
                " All detectors consist of 300-microm-thick",
                "Si mounted on 0.15-microm-thick Al. A multiwire",
                "proportional counter (MWPC) was mounted upstream of",
                "the focal plane and used to distinguish implantation",
                "events from radioactive decays. The Berkeley Gas",
                "Separator fill gas was He at 0.5 torr."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASPEC"
              ],
              "free_text": [
                " Cross sections were deduced from the count of",
                "alpha-decay chains. A total of 33 decays chains",
                "originating from 262Bh and 2 decay chains originating",
                "from 261Bh were observed."
              ]
            }
          ],
