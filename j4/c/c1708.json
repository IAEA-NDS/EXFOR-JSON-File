            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Incident beam of 18F ions with energy of 1.750 MeV/A."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two-body kinematics with energy loss estimates, both",
                "of the beam particle to the point of interaction and",
                "of the proton or alpha particle through the remainder",
                "of the target and the dead layer of the silicon",
                "detector was used to determine CMS energy of",
                "interacting 18F ions."
              ]
            }
