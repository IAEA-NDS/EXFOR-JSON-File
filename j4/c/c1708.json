          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "28.0+-1.4 mu-m thick polyethylene ((CH2)n) target with",
                "thin layer of gold with thickness of less than",
                "5 mu-g/cm2 evaporated onto the upstream surface of the",
                "polyethylene target"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " 1 mm thick MSL type YY1 (LEDA) segmented",
                "annular silicon strip detector located downstream to",
                "cover laboratory angles of 7deg - 16.6deg. A further",
                "LEDA detector covered laboratory angles 150deg-170deg,",
                "for normalization through measurement of Rutherford",
                "back-scattering of 18F ions from the gold layer.For",
                "each event, energy and time-of-flight relative to the",
                "accelerator RF were recorded."
              ]
            }
          ],
