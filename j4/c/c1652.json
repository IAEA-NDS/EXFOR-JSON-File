          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "44Ti produced by 45Sc(p,2n)44Ti was mixed with natTiO2,",
                " and pressed into the Cu insert of a negative-ion Cs",
                " sputter source to form 44TiO- beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "4He target consisted of a 5 mm long gas cell with two",
                " 1.3 mg/cm2 Ti windows filled with 600 mbar of 4He and",
                " cooled to liquid nitrogen temperature resulting in an",
                " areal density of about 60 ug/cm2.",
                "The energy of the 44Ti beam in the middle of the",
                " target was 261.5 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " for alpha detection at 8 to 30 deg in lab.",
                " system (120-164 deg in c.m.system).",
                "Two 500 um thick annular silicon strip detectors",
                " segmented into 16 rings and 16 wedges allowing the",
                " determination of polar-theta and azimuthal-phi",
                " angles of the scattered particles."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES"
