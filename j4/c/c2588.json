          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Magnetic Spectrograph Measurements, 5 degrees: In order",
                " obtain an accurate value for the energy of the 20-MeV",
                "state of 4He considerable care was taken to obtain",
                "absolute measurements of the incident and scattered",
                "energies. The angles of observation for the",
                "4He(alpha,alpha)4He* measurements were theta lab=5",
                "degrees and theta lab=13 degrees, chosen to be near",
                "maxima of the angular distribution as determined from",
                "the counter telescope data."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A constant background has been subtracted from the",
                "data by drawing a horizontal line through the data",
                "below the threshold for alpha-particle breakup. This",
                "background was 85% of the peak height at 5 degrees",
                "but only 30% at 13 degrees. A self-consistent analysis",
                "of calibration lines gave the beam energy at the center",
                " of the scattering chamber as 64.12+-0.06 MeV"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
