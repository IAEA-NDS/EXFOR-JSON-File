          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The gas target was provided by filling the entire",
                "scattering chamber with 4He gas at a pressure of 20 cm",
                "Hg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST",
                "SIBAR"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The beam entered the gas through a 0.63-microm,",
                "nickel foil 25 cm from the center of the chamber. The",
                "solid state detectors were in the gas at a distance",
                "of 32 cm from the target volume with no windows in",
                "between. The particles were detected in a dE-E system,",
                "consisting of a 0.10-mm totally depleted Si",
                "surface-barrier detector and a 1.5-mm partially",
                "depleted Si surface barrier detector."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The agreement in shape of our elastic",
                "scattering angular distribution with that of",
                "Darriulat et al. is very good, and we believe our",
                "absolute cross sections are accurate to better than",
                "10%."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "After correction for energy losses in the entrance",
                "foil and gas, the beam energy in the present",
                "experiment was 63.8+-0.4 MeV."
              ]
            }
          ],
