          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ASPEC",
                "GSPEC"
              ],
              "free_text": [
                " Two series of experiments were",
                "performed at Lawrence Berkeley Laboratory (LBL) and",
                "at Gesellschaft fur Schwerionenforschung (GSI) using",
                "radiochemical methods and on-line gas-jet transport",
                "of short-lived reaction products combined with",
                "electronic detection systems."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Chemical yields were assumed to be (35+-9) % on the",
                "basis of yield determinations of the procedures. The",
                "gamma-ray data were analyzed with standard computer",
                "programs to obtain absolute decay rates. Final cross",
                "sections were calculated with a set of programs which",
                "take into account chemical yields; the beam history",
                "to correct for growth and decay during bombardment,",
                "chemical separation times from possible precursors,",
                "target thickness, and beam integral."
              ]
            }
          ],
