          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "~5 pnA, 19-MeV beam of 16O ions, delivered by the",
                "Argonne ATLAS accelerator, was used to bombard 11B",
                "target for ~100 hr, in order to populate excited",
                "states in 26Al via the one-neutron evaporation",
                "channel. The resulting gamma-ray transitions were",
                "detected using the Gammasphere array."
              ]
            }
          ],
