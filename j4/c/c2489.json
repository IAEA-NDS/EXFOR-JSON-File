          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of each of the four enriched lead isotopes",
                "were bombarded with 41.9-MeV helium ions and the",
                "cross-sectional yields for formation of Y93 were",
                "determined radiochemically. From the knowledge of the",
                "isotopic composition of each target it was possible",
                "to solve four simultaneous equations in four unknowns",
                "for the formation cross section of Y93 of each of the",
                "four lead isotopes separately."
              ]
            }
