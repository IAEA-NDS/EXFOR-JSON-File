          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A primary beam of 19F at 117 MeV bombarded",
                "hydrogen-gas target contained between thin Havar",
                "windows and creating a secondary beam of recoiling",
                "19Ne particles by means of the (p,n) reaction. The",
                "RESOLUT radioactive beam facility was used to",
                "separate the recoiling 19Ne particles in flight",
                "before focusing them onto the secondary target",
                "The 19Ne beam of approx. 1700 particles per second at",
                "86 MeV energy constituted 13% of the beam composition."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experiment populated the resonances via the",
                "19Ne(d,n)20Na reaction. Proton resonances in 20Na were",
                "kinematicaly reconstruted from detected protons",
                "and 19Ne ions"
              ]
            }
