          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "From the observed 22(5) counts due to the 151-keV",
                "gamma-ray transition in 85Rb, resulting from the",
                "84Kr(p,gamma) reaction, while 11(4) counts are",
                "observed from the 130-keV transition that dominates",
                "the decay of the 281-keV state. Combining these",
                "yields with the predicted branching ratios in a",
                "weighted average, we infer a total reaction cross",
                "section at Ec.m. = 2.443(22) MeV of 133+91-44 microb."
              ]
            }
          ],
