          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were produced by evaporating WO3 of natural",
                "isotopic constitution onto arrays of 0.5 mm thick",
                "tantalum blanks The mass density deposited was",
                "measured to be 4.0 mg/cm2 by a crystal-oscillator",
                "thickness monitor system."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 7.6 x 7.6 cm NaI(Tl) crystals."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "COINC"
              ],
              "free_text": [
                " The targets were irradiated with the",
                "proton beam for periods comparable to the 13N",
                "half-life. After bombardment, the targets were",
                "transformed to an off-line annihilation spectrometer",
                "which counted coincidence pulses between two NaI(Tl)",
                "crystals."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
