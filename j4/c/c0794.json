              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Deuterons detected at zero degrees in focal",
                " plane of QDDD magnetic spectrometer.  Typical energy",
                " resolution was about 20 keV, sufficient to resolve",
                " most of the levels of interest."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " 3 450-mm*2 silicon surface barrier detectors",
                "  for detecting decay protons and alphas; energy",
                "  resolution about 100 keV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 12.7-cm x 10.2-cm NaI detector for detecting",
                "  decay gammas.  A 3-mm thin lead plate was positioned",
                "  between detector and target to reduce count rate",
                "  from low-energy gamma rays."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
