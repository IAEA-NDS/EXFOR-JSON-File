          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The n-alpha phase shifts of Stammbach and Walters",
                " were used with the program MOCCASINS to calculate the",
                " effective analyzing power below E(n) = 17.6 MeV.",
                "At 17.6 and 20.9, the smoothed set of Niiler phase",
                " shifts were employed.",
                "Between 20.9 and 21.9 MeV, the energy dependence of the",
                " analyzing power was assumed linear and was obtained",
                " from Mutchler and Niiler."
              ]
            }
          ],
