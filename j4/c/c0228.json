                " for alpha and 155 MeV Protons"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCY"
                ],
                "institute": "2ZZZCER"
              },
              "free_text": [
                " for 600 MeV protons"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity graphite pieces: 20*6*1 mm in size."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "INTB"
              ],
