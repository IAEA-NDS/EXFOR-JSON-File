          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production cross sections of lithium and beryllium",
                "isotopes in C-12 by high-energy protons and alpha",
                "particles"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
