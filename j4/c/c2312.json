          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                " After bombardment the foils were",
                "dissolved and cadmium and indium were separated and",
                "decontaminated by conventional radiochemical",
                "procedures. The activity of the samples was",
                "determined with a sodium iodide scintillation counter",
                "and the decay of a particular photopeak was followed",
                "with the aid of a 100-channel pulse-height analyzer."
              ]
            }
          ],
