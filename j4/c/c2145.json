          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sample consisted of stack of natural Cu foils with",
                "diameter of 8.5 mma and thickness of 18.6 mu-m and",
                "natural Cr foils with diameter of 9.8 mms and",
                "thickness of 82 mu-m. Number of foils in a",
                "configuration was 4-5 Cr foils interspersed with 2-4",
                "Cu foils"
              ]
