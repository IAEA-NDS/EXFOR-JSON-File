          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New measurements of low-energy resonances in the",
                "22Ne(p,gamma)23Na reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.J.Kelly",
                "A.E.Champagne",
                "L.N.Downen",
                "J.R.Dermigny",
                "S.Hunt",
                "C.Iliadis",
                "A.L.Cooper"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USANCA",
                "1USATNL"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,95,015806,2017",
                "code_unit": [
                  {
                    "unit": "J,PR/C,95,015806,2017",
                    "doi": "10.1103/PhysRevC.95.015806",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "95",
                        "part": null,
                        "issue": null,
                        "page": "015806"
                      },
                      "date": 2017
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " Measurements at Elab < 200 keV were",
                "carried out using the electron cyclotron resonance",
                "ion source (ECRIS) accelerator, located at Laboratory",
                "for Experimental Nuclear Astrophysics (LENA), TUNL."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " A 1-MV model JN Van deGraaff accelerator",
                "at LENA facility was used to provide higher-energy",
                "beams,"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "10-NE-22",
                "field_identifier": "ENR",
                "value": 1.0
              },
              "free_text": [
                " Singly ionized 22Ne atoms were",
                "implanted into 0.5-mm-thick tantalum target backings.",
                "Prior to implantation, these backings were chemically",
                "etched and resistively heated to remove contaminants.",
                "Ion implantation energies of 25 and 100 keV were used",
                "to produce 6.5- and 21-keV-thick targets Ep(CM)= 458",
                "keV, respectively. A dose of 100 - 140 mu-Ah was",
                "supplied for each target,"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma rays emitted from the target were",
                "analyzed with a 135% relative efficiency coaxial",
                "high-purity germanium  HPGe detector"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " In addition, a 16-segment NaI(Tl) annulus",
                "was used as a part of the LENA gamma-gamma",
                "coincidence spectrometer"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "10-NE-22(P,G),PAR,WID/STR",
                  "code_unit": [
                    {
                      "unit": "10-NE-22(P,G),PAR,WID/STR",
                      "field": {
                        "reaction": "10-NE-22(P,G)",
                        "target": "10-NE-22",
                        "projectile": "P",
                        "process": "G",
                        "product": "",
                        "quantity": "PAR,WID/STR",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": "PAR,WID/STR"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "Absolute cross sections and resonance strengths were",
                "determined relative to the strength of the Er(CM) =",
                "458keV resonance"
              ]
            }
          ],
