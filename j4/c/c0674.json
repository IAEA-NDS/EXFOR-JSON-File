          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Liquid 3He target, 104 mg/cm2 thick."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Monentum of ejected proton or deuteron",
                " measured using QD magnetic spectrometer placed on",
                " the large-angle side of the incident beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " 2 identical counter telescopes used to detect",
                " scattered proton and recoil deuteron on small-angle",
                " side of beam. Telescopes consist of delay-line multi-",
                " wire proportional chamber (MWPC), followed immediately",
                " by a thin DE plastic scintillator, an annular veto",
                " counter, and a thick NaI(Tl) detector preceded by a",
                " copper degrader, if necessary.",
                "Beam position and direction measured using wire",
                " profile monitors.",
                "Beam polarimeter, containing a 5 mg/cm2 thick CH2",
                "  target, calibrated against a Faraday cup."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for",
                ". background,",
                ". accidental coincidences,",
                ". MRS inefficiencies due to events not completing their",
                "  path through the dipole (19-22%),",
                ". MWPC inefficiencies due to missing or nonadjacent",
                "  hits (4-23%),",
                ". NaI(Tl) detector inefficiencies due to reaction",
                "  losses ,",
                ". dead time (1-23%),",
                ". loses due to pileup (1-17%)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical uncertainty given.",
                "Estimated uncertainty in absolute normalization 10%",
                " and includes uncertainties in determination of:",
                " . total number of ncident protons (~5%),",
                " . NaI(Tl) detector efficiency (~1%),",
                " . MWPC efficiency (~1%),",
                " . solid angle (~1%),",
                " . target thickness (3-4%),",
                " . electronics and computer dead time (~1.5%)."
              ]
            }
