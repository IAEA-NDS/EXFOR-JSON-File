              "free_text": [
                "Nuclear Structure Studies in the Neutron-Rich A=30",
                "Mass Region by Direct Nucleon Removal Reactions"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
