              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was 500 mu-g/cm2 of uranium (U238) oxide",
                "deposited by evaporation from a hot 6lament onto a",
                "thin carbon film."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                ""
              ]
