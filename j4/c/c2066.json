          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In-Flight Facility ATLAS was used to produce",
                "a radioactive 17N (T1/2 = 4.17 s) beam via proton",
                "removal from an 18O8+ primary beam at 14.7 MeV/u",
                "impinging on a 15 mg/cm2 Be target. The secondary",
                "beam had an energy of 13.6 MeV/u, a typical rate of",
                "10E+4 particles per second on target, and a purity",
                "ranging between 25 and 75 %. The main contaminants in",
                "the secondary beam were 18O7+ at 12.2 MeV/u and 14C5+",
                "at 14.4 MeV/u as determined by a Si detector",
                "telescope at zero degrees."
              ]
            }
