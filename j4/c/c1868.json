          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of the proton total reaction cross",
                "section for 24Mg, 64,66,68Zn and 140Ce between 17.5",
                "and 48 MeV"
              ]
            }
          ],
