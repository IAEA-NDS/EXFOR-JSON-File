          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN",
                "CSICR"
              ],
              "free_text": [
                " Series of 4 plastic scintillation (two",
                "button + two annular) detectors defined the incident",
                "proton beam. Additional thin plastic scintillator",
                "placed behind the target detected 98% of beam",
                "protons. CsI scintillation detector subtended angle",
                "of 45.5 deg detected elastically scattered protons at",
                "angles less than 45.5 deg."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Transmission method was used, elastically",
                "scattered protons were not included in total cross",
                "section."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " To obtain total reaction cross section, to raw cross",
                "section were applied corrections for",
                " - elastic scattering",
                " - inelastic scattering",
                " - for protons which underwent nuclear reaction in",
                "   detector and did not deposited enough energy"
              ]
            }
          ],
          "ERR-ANALYS": [
