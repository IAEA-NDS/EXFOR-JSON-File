          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of 44Ca were prepared by mixing 44Ca0 enriched",
                "to 98.55% 44Ca with thorium, pressing into pellets, and",
                "evaporating onto 0.50 mm tantalum backings. A",
                "20 mu-g/cm2 layer of gold was deposited on each target",
                "to protect it from exposure during handling and to",
                "better distribute the heat during irradiation. Target",
                "thickness was measured by the crystal oscillator method",
                "with an uncertainty of +/-20% and equal 300 mu-g/cm2",
                "for each from two targets."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "20-CA-44",
