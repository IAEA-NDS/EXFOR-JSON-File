          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The three-dimensional reconstruction of particle",
                "tracks in a time projection chamber based on the",
                "Random Sample Consensus Model (RANSAC). The RANSAC",
                "is used to classify tracks including pile-up, to",
                "remove uncorrelated noise hits, as well as to",
                "reconstruct the vertex of the reaction."
              ]
            }
