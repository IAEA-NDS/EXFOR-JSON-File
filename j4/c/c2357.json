          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " The irradiations were performed at the",
                "Brookhaven Cosmotron and AGS, and at the latter",
                "machine it was necessary to reduce the beam intensity",
                "to prevent the burning of the plastic foils. The",
                "irradiations sometimes lasted as long as 20 min, but",
                "corrections were made for the variation of the beam",
                "intensity during the bombardments. The Mg27 was",
                "separated chemically from the target and catcher",
                "foils, and the main problem was eliminating the",
                "tremendous quantities of C11 activity induced in the",
                "plastic foils. This was accomplished by fuming off",
                "the carbon with perchloric acid. The other",
                "interfering activities, F18 and Na24, were eliminated",
                "with holdback carriers. The samples were mounted on",
                "Al cards of sufficient thickness to stop the beta",
                "particles and assayed on NaI crystals."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data were corrected for the secondary reaction and",
                "scattering."
              ]
            }
          ],
