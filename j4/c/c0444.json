              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDEG",
                "COINC"
              ],
              "free_text": [
                " The Lawrence Berkeley National",
                "Laboratory's 88-Inch Cyclotron delivered 3He beams",
                "with 19 different energies between 21 MeV and 135",
                "MeV. The number of energy points was increased to 26",
                "by using a set of degraders made of aluminum foils",
                "with thicknesses between 186 and 433mm which were",
                "determined by weighing. Both fission fragments",
                "detected in coincidence."
              ]
            }
          ],
