              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "REC"
              ],
              "free_text": [
                " Recoil products from each bombardment",
                "were stopped 2nd collected in a 0.013-mm Be foil that",
                "was then chemically processed in one of three",
                "separation schemes. Each separation scheme was used",
                "to isolate the SHE's from other reaction products and",
                "from any 248Cm that may have reached the recoil",
                "collection foil."
              ]
            }
          ],
