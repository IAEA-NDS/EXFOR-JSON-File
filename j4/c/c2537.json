          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "48Ca-ion bombardments with beam intensities from",
                "3x10**11 to 6x10**11 particles/s and lasting from 10 h",
                "up to 2 d."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "96-CM-248",
                "field_identifier": "ENR",
                "value": 0.97
              },
              "free_text": [
                " The 248Cm target was 6 mm in",
                "diameter and contained 20 microg/mm2 of 248Cm",
                "deposited as CmF, onto 0.013-mm Be by vacuum",
                "sublimation. Thus, the energy spread within the",
                "target was 267 to 243 MeV, corresponding to an",
                "average excitation energy of 40 to 50 MeV for the",
                "compound nucleus."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
