              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam monitored by 6He scattering from Au foils."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for",
                ". background",
                ". solid angle,",
                ". finite counting time,",
                ". time to transfer the targets from the on-line",
                "  scattering chamber to the off-line counting system",
                "  (about 45 min),",
                ". decay of 211At during the irradiation."
              ]
            }
          ],
