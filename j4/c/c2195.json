          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1CANTMF"
              },
              "free_text": [
                " The experiment was carried out using a",
                "postaccelerated 11Li beam from superonducting linear",
                "accelerator ISAC-II at the TRIUMF facility at Vancouver"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two different 208Pb targets with thickness of 1.45",
                "mg/cm2 and 1.9 mg/cm2 were used"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SI"
              ],
              "free_text": [
                " Detector setup was designed to cover",
                "an angular range from 10deg to 140deg. Each telescope",
                "consisted of a thin double side Si strip detector for",
                "dE measurement and a pad detector for E measurement.",
                "Thickness of dE detectors varied between 20 and 40",
                "mu-m. Thickness of E detector varied between 63 at",
                "backward angles and 500 mu-m at forward angles."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " E-dE method was used for particle identification"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The ion beam was produced by a 500 MeV 100 mu-A",
                "proton beam, coming from the cyclotron, impinging on",
                "a Ta primary target. A pure 11Li beam was obtained",
                "after the magnetic separator and postaccelerated by a",
                "SC-LINAC accelerator. Average intensity was around 4300",
                "ions of 11Li per second. Simultaneously a 9 Li beam was",
                "accelerated"
              ]
            }
          ],
