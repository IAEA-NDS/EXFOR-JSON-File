          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energies of the deuterons inducing fission varied",
                "from 8.5 to 9.9 MeV, one-half of the fissions being",
                "produced by deuterons with energies above 9.5 MeV.",
                "Less than 0.5 per cent of the fissions were induced",
                "by neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "2 mil target foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " A flow-type beta-proportional counter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "CHSEP"
              ],
              "free_text": [
                " Uranium with normal isotopic",
                "composition was irradiated in the Los Alamos",
                "Homogeneous Reactor in a thermal flux of 5x10 11",
                "cm-2sec-1, while thorium stacked target foils were",
                "irradiated with a deuteron beam of the Washington",
                "University Cyclotron. Relative yields were determined",
                "by comparison of fission-product radioactivities from",
                "232Th fission induced by 9.5 MeV deuterons with those",
                "from 235U thermal neutron fission, for which fission",
                "yields are known. Irradiated targets were dissolved",
                "in hydrochloric acid, and aliquots of the solutions",
                "were taken for radiochemical analysis."
              ]
            }
          ],
