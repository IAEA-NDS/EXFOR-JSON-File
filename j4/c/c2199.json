          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Obtained yield-mass curve is symmetrical about A=115,",
                "which implies an average loss of 4 neutrons during or",
                "prior to fission. Shifts in the symmetry point of >1",
                "mass unit give curves with appreciable deviations",
                "from the experimental data. We conclude, therefore,",
                "that neutron multiplicity is 4+-1."
              ]
            }
          ],
