          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative values of fission yields for the 232Th(d,f)",
                "reaction were obtained by multiplying the R values by",
                "the known fission yields from the 235U(n,f) reaction.",
                "These relative yields were then used to construct a",
                "smooth, symmetrical yield-mass curve. The curve was",
                "normalized to give a total yield of 200 per cent."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Authors give fission yields in %, which are compiled",
                "in EXFOR as PC/FIS, without change in the numerical",
                "values."
              ]
            }
