          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental deuteron cross section measurements",
                "using single natural  titanium foils from 3 to 9 MeV",
                "with special reference to the production  of 47V and",
                "51Ti"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.Gagnon",
                "M.A.Avila-Rodriguez",
                "J.Wilson",
                "S.A.McQuarrie"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1CANALA",
                "3MEXUMX"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/B,268,1392,2010",
                "code_unit": [
                  {
                    "unit": "J,NIM/B,268,1392,2010",
                    "doi": "10.1016/j.nimb.2010.01.025",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NIM/B",
                        "number": null,
                        "volume": "268",
                        "part": null,
                        "issue": null,
