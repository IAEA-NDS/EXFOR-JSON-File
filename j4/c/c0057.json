          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of 200 MeV polarized protons from",
                " 12,13C and the optical model"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLIS",
                  "ATOMI"
                ],
                "reaction": null
              },
              "free_text": [
                " Beam polarization typically 70%."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mean scattering energy varied between 1299.8 and 200.1",
                " MeV according to target thickness."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Several self-supporting targets ranging in thickness",
                " between 3.7 and 150 mg/cm3.  The targets were of both",
                " natural composition and enriched in 12C or 13C."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "MWPC",
                "SCIN"
              ],
              "free_text": [
                " Magnetic spectrograph, helical wire",
                " chamber in focal plane for position information,",
                " followed by 2 plastic scintillators for particle",
                " identification.",
                "Energy resolution of scattered protons between 100 and",
                " 500 keV FWHM depending on target thickness and",
                " scattering angle.",
                "Scattering angle known to better than 0.05 degrees.",
                " The angular acceptance was 0.55 degrees for angles",
                " of 6-64 degrees, and 0.97 for angles of 68-110",
                " degrees.",
                "Beam monitored using Faraday cup."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for:",
                ". background,",
                ". dead time losses,",
                ". finite geometry of detector system."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Contains cotributions from:",
                ". statistical uncertainty,",
                ". error resulting from uncertainty in background",
                "  subtraction,",
                ". error resulting from uncertainty in scattering angle",
                "  of 0.05 degrees.",
                ". error for incomplete charge collection at scattering",
                "  angles <24 degrees.",
                "Not included is absolute normalization error (5%) due",
                " mainly to uncertainty in measured target thickness."
              ]
            }
          ],
