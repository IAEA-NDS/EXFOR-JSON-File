          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacked target consisting of three natural Ta",
                "degrader foils with thickness of 80.8+-1.5 mu-m,",
                "seven natural Lu foils, each with thickness of 96+-7",
                "mu-m and six natural Ti foils with thickness of",
                "4.9+-0.2 mu-m used as monitor foils. The order,",
                "thickness and mean proton energy in target foils were",
                "Foil      Thickness (mu-m) Mean energy(MeV)",
                "  Ta-1       80.8 +- 1.5     21.3",
                "  Ta-2       80.8 +- 1.5     19.8",
                "  Ta-3       80.8 +- 1.5     18.1",
                "  Lu-1         96 +- 7       16.7",
                "  Ti-1        4.9 +- 0.2     16.0",
                "  Lu-2         96 +- 7       15.3",
                "  Ti-2        4.9 +- 0.2     14.6",
                "  Lu-3         96 +- 7       13.8",
                "  Ti-3        4.9 +- 0.2     13.1",
                "  Lu-4         96 +- 7       12.2",
                "  Ti-4        4.9 +- 0.2     11.5",
                "  Lu-5         96 +- 7       10.6",
                "  Ti-5        4.9 +- 0.2      9.7",
                "  Lu-6         96 +- 7        8.7",
                "  Ti-6        4.9 +- 0.2      6.9",
                "  Lu-7         96 +- 7        5.2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High purity Ge detector with efficiency of 70%"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " Each foil from stacked target was counted",
                "individually. The 343 and 983.5 keV lines were",
                "monitored for 175Hf and 48V, respectively.",
                "Energy loss of the proton beam through each degrader",
                "and target were calculated using SRIM-200"
              ]
            }
          ],
