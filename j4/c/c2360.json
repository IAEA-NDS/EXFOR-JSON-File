          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section for 7Be production from 12C with",
                "protons of 3 - 12.5 GeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
