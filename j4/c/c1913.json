          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC",
                "STTA"
              ],
              "free_text": [
                " All target were activated in the",
                "internal proton beams of LBL. The target stacks as",
                "traversed by the proton beam consisted of a 0.005 cm",
                "aluminum foil, three separate 0.0008 cm aluminum",
                "foils, the enriched target layer on the thin aluminum",
                "backings and a final 0.005 cm aluminum foil. The",
                "desired product nuclei were assayed by gamma counting",
                "the target and monitor foils with Ge(Li) detector."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " All photopeaks were analyzed by the computer",
                "code SAMPO. The resulting decay curves were analyzed",
                "by the standard least squares program CLSQ."
