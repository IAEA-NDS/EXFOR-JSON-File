            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "7Be produced via the 7Li(p,n)7Be reaction.",
                "Final target consisted of 80 mCi of 7Be (0.23 microg)",
                " and 7 microg of solids"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sawtooth-wave voltage applied to two orthogonal sets",
                " of parallel plates (at incommensurate frequencies)",
                " prior to beam collimation in order to ensure a stable,",
                " uniform beam spot."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Silicon surface-barrier detector with 300 mm2",
