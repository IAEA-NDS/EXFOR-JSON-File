              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " Detection of 4He ions was achieved",
                "with a dE-E telescope consisting of two MSL type S2",
                "detectors (65 and 500 mu-m thick, respectively) each",
                "segmented into 48 annular front strips and 16 rear",
                "sectors covering a laboratory angular range of 7deg",
                "to 19deg"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " Detection of 18Ne ions was achieved",
                "with a dE-E telescope using a Si PAD detector",
                "with thickness of 35 mu-m  with four unsegmented",
                "quadrants as dE detector and E detector with thickness",
                "of 1500 mu-m with four quadrants, each segmented into",
                "16 front strips and 24 rear sectors"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
