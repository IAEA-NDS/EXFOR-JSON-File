          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN",
                "MCPLT"
              ],
              "free_text": [
                " Neutrons were detected using scintillator",
                "crystals based on p- terphenyl fabricated by Cryos-Beta",
                "Ltd. Ukraine, coupled to Planacon photomultipliers by",
                "Photonis Inc., which use microchannel plates for",
                "electron multiplication."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " Annular silicon-strip detector",
                "telescope consisting of thin (65 mu-m) and thick",
                " (1000 mu-m) double-sided silicon strip detectors",
                "covering angles from 8deg to 21deg in the laboratory",
                "frame was used for detection of protons"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Position sensitive gas ionization detector",
                "measured the parameters of the reaction-residue heavy",
                "ions in coincidence with the other particles and was",
                "placed 300 mm downstream from the target position."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Array of 20 position-sensitive NaI(Tl)",
                "detectors arranged in a barrel formation around the",
                "vacuum chamber and the target was used for coincident",
                "gamma ray detection"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "PSD",
                "EDE",
                "TOF"
              ],
              "free_text": [
                " Experiment performed in inverse",
                " kinematics."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A beam of 17F was produced in-flight through the",
                "16O(d,n)17F reaction with a beam of 16-O bombarding a",
                "gas cell containing deuterium gas. The beam of 17F",
                "reaction residues was separated by means of the",
                "RESOLUT radioactive ion beam facility. A beam energy",
                "of 95.5 MeV, an average beam intensity of 2.8E+4 17F",
                "per second, and a purity of 60% were obtained",
                "throughout the experiment."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The excitation energies of the p + 17F coincident",
                "events were reconstructed using invariant mass",
                "analysis of the 18Ne compound system from the",
                "detection angles and energies of the charged",
                "particles - protons and 17F reaction residues"
              ]
            }
          ],
