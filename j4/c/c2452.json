          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Long-range particle emission in coincidence with",
                "fission at moderate excitation energies"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.A.Coleman",
                "A.W.Fairhall",
                "I.Halpern"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAWAU"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
