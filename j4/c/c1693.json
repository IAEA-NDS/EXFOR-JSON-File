          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                "Reaction products were identified by second",
                "half of the Fragment separator FRS operated in a",
                "dispersion matched (achromatic) mode."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DRFTC"
              ],
              "free_text": [
                " Outgoing fragments were tracked using two time",
                "projection chambers (TPC) placed downstream of the",
                "reaction  target and two TPC at the final focal point."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The TOF was measured with the plastic",
                "scintillators at FRS focal planes F2 and F4"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                "Two multisampling ionization chambers were",
                "placed at final focal point to identify the charge",
                "of the fragments through energy loss."
              ]
            }
          ],
