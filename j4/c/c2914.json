          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam was focused at the target position to a spot",
                "about 3 mm wide and 9 mm high with an angular",
                "divergence of +/-0.3 degrees."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "NAICR"
              ],
              "free_text": [
                " A conventional deltaE-E telescope",
                "consisting of a 322-mu-m Si passing detector and a",
                "2-cm-thick NaI stopping detector for the 82.1-MeV",
                "alpha-beam data. A 3000-mu-m thick Si detector was",
                "used in place of the NaI for the 64.3- and 49.9-MeV",
                "alpha-beam data. The check run involving a 41.0-MeV",
                "deuteron beam incident upon a 4He target required the",
                "use of an 87-mu-m Si passing detector. The thinner",
                "detector was also required for angles greater than 70",
                "degrees c.m. for the run with a 49.9-MeV alpha-beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of a 7.8-cm-diam gas cell with a",
                "2.5-mg/cm2 Be entrance window and a 2.l-mg/cm2 Havar",
                "exit foil. Most of the data were taken with the gas",
                "cell filled with 300 Torr of 99.9% enriched deuterium",
                "gas cooled to 77 K. Check runs were also made with",
                "the gas cell filled with 300 Torr of deuterium at 294 K",
                "and with 800 Torr of 99.9% helium at 77 K."
              ]
