              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " Heavy ion detection system based on two",
                "micro-channel plate detectors was used for time of",
                "flight measurement"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "SISD"
              ],
              "free_text": [
                " Recoil ions (23Na) were momentum",
                "analyzed by recoil separator and detected using",
                "double sided Si strip detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Prompt gamma rays from neutron capture were",
                "   selected using time of flight. Recoil flight time",
                "   was used to select capture events.",
                "   Inverse kinematics was used"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Delayed coincidence between 23Na recoils",
                "   and capture gamma rays was required"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "500 MeV protons are steered onto a production targets",
                "to produce radioactive isotopes. The isotopes pass",
                "through a heated tube to a source where they are",
                "ionized, accelerated off the source's high-voltage",
                "platform at up to 60 kV and sent through a mass",
                "separator to select the ion beam of choice. Selected",
                "beam of 22Ne was then accelerated in room temperature",
                "linac."
              ]
            }
