          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A windowless, differentially pumped, recirculated gas",
                "target filled with hydrogen. An average gas pressure",
                "of 5Torr was used which corresponds to approx.",
                "3.9E+18 hydrogen atoms/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " Gamma rays were detected by high efficiency",
