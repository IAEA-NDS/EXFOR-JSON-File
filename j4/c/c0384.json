          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular momentum and nuclear shell effects in",
                "reactions of Ni-58 with 46- to 68-MeV He-4 ions"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
