                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy of the incident helium-ion beam was",
                "estimated to be 69+-1 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "28-NI-58",
                "field_identifier": "ENR",
                "value": 0.9995
              },
              "free_text": [
                " Targets were prepared by",
                "electroplating 99.95% enriched Ni-58 onto 0.2-mil gold",
                "foils. The Ni-58 target thicknesses varied between",
                "4.07 and 9.52 mg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
