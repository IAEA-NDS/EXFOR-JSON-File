              ],
              "free_text": [
                " 3He ejectiles produced in the reaction were",
                "momentum analyzed using S800 magnetic spectrograph",
                "and identified in its focal plane"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Particle identification was performed by time",
                "of flight method using plastic scintillator with",
                "thickness 5 mm located in focal plane of S800",
                "spectrograph relative to the cyclotron radiofrequency",
                "signal."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DRFTC"
              ],
              "free_text": [
                " Scattering angles and momenta of the",
                "ejectiles at the target location were reconstructed",
                "by ray tracing the angles and positions measured in",
                "two cathode-readout drift chambers on the S800 focal",
                "plane."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma rays emitted from excited 88Rb nuclei",
                "were detected by GRETINA gamma ray array consisting",
                "of thirty-two 36-fold segmented HPGe detectors",
                "mounted on hemisphere around 88Sr target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gas target filled with 86Kr with purity of 99.952%.",
                "Target cell had 7 cm diameter and 3 cm thickness.",
                "At gas pressure of 1210 torr and a temperature",
                "of 295 K, the target thickness was approximately",
                "20 mg/cm2. The target cell windows were made of",
                "kapton foil with a thickness of 125 mu-m."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Primary 16-O beam from Coupled Cyclotron Facility",
                "impinged with the energy of 150 MeV/A on Be production",
                "target. The A1900 fragment separator was used to",
                "select 3H ions yielding a secondary beam with an",
                "energy of approximately 115MeV/u and a purity of 99%."
              ]
