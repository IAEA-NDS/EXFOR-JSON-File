          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Studies of Plutonium, Neptunium, and Uranium Produced",
                "in the 244Pu + 136Xe Reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "W.M.Jae"
              ],
              "free_text": [
