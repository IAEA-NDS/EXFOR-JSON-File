                  }
                }
              },
              "free_text": [
                " The",
                "identification of the activities present in each foil",
                "and the calculation of cross sections from these",
                "measured activities."
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2SWDSWR",
                "1USAORU",
                "1USAMSU",
