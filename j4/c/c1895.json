              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "0.0935 and 0.1841 g/cm2 gold foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "NAICR",
                "SCIN"
              ],
              "free_text": [
                " The time of flight (TOF) between a",
                "thin plastic scintillator located after the A1200",
                "focal plane and a parallel plate avalanche counter"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PPAC"
              ],
              "free_text": [
                " located in front of the secondary target",
                "provided identification of the fragment before",
                "interacting in the secondary target. A fast-slow",
                "phoswich detector was located at zero degrees with",
                "respect to the beam axis and allowed the",
                "identification of the beam particle after interacting",
                "in the target. Photons were detected in coincidence",
                "with beam particles by the NSCL NaI(Tl) array. Each",
                "NaI(Tl) crystal is cylindrical, 17.1 cm long and 5.0",
                "cm in diameter and encapsulated in a 2 mm thick",
                "aluminum shield. Quartz windows, 0.5 cm thick, are",
                "attached at both ends. A 5 cm diameter",
                "photomultiplier tube (PMT) is optically coupled to",
                "each window. A total of 38 detectors are arranged in",
                "an aluminum frame in 3 concentric rings, of 11",
                " (inner), 17 (middle) and 10 (outer) detectors,",
                "oriented co-axially to the particle beam axis around",
                "a 150 mm diameter beam pipe. The radii of the three",
                "detector rings are 10.8 cm, 16.9 cm and 21.8 cm. As",
                "assembled the full array is 60 cm long, 51 cm wide",
                "and 55 cm high."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "GSPEC",
                "TOF",
                "COINC",
                "EXTB"
              ],
              "free_text": [
