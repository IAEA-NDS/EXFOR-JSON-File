              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "CSICR"
              ],
              "free_text": [
                " Charged particles were detected",
                "using a telescope consisting of a Si-strip detector",
                "array and CsI(Tl) detectors. Recoil protons were",
                "detected by a telescope consisting of 100 mu-m thick",
                "annular Si-strip detectors and annular-CsI(Tl)",
                "detectors. Inelastically scattered 11Li* were",
                "detected by Telescope B, consisting of two layers of",
                "60 mu-m thick and 500 mu-m thick annular Si-strip",
                "detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inverse kinematics was used"
              ]
            }
          ],
