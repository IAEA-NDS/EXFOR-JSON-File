          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of 43Sc and 44gSc from natural CaF2",
                "material using an FN Tandem accelerator"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.D.Nelson",
                "A.M.Clark",
                "Th.L.Bailey",
