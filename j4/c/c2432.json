          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-238",
                "field_identifier": "ENR",
                "value": 0.999
              },
              "free_text": [
                " Circular pieces of uranium foil,",
                "supplied by Nuclear Fuel Services, Inc., Erwin,",
                "Tennessee, of 2-mil (96.8mg/cm2) thickness served as",
                "the target material. Isotopic analysis supplied by",
                "the manufacturer was given as 99.9% 238U. The target",
                "assembly consisted of three pieces of uranium",
                "\"sandwiched\" between l-mil aluminum catcher foils,",
                "i.e. a l-mil aluminum foil followed by a 2-mil",
                "uranium foil, two 1-mil aluminum foils, a uranium",
                "foil, etc."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC",
                "PROPC",
                "NAICR"
              ],
              "free_text": [
                " A calibrated GM counter or a",
                "windowless proportional counter of known geometry",
                " (Canberra Instruments). In some cases these",
                "measurements were supplemented by gamma-counting with",
                "a NaI(Tl) scintillation crystal in conjunction with a",
                "Nuclear Data 512 pulse-height channel analyzer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                " Following irradiation the target",
                "assembly was dismantled and each uranium target",
                "dissolved in HCl and HNO3 together with its forward",
                "and backward recoil catcher foils. Final forms of the",
                "counting samples were solids mounted on small pieces",
                "of filter paper and aluminum discs and covered with",
                "Pliofilm. The final precipitates were generally",
                "counted with multiple detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Decay curves were resolved into their",
                "components and a disintegration rate computed. The",
                "rate was then converted into an absolute cross",
                "section."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data were corrected for chemical yield, intrinsic",
                "counting efficiency, back-scattering, self-absorption,",
                "and self-scattering."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20200110,
