          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USAANL"
              },
              "free_text": [
                "Experiment performed at the In-Flight",
                "facility at the ATLAS accelerator at Argonne",
                "National Laboratory"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated polyethylene [(CD2)n] target with",
                "thickness of 420 mu-g/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Light ejectiles 3He and 3H were detected in a",
                "set of three annular, double-sided, and segmented",
                "silicon strip detectors, subtending laboratory angles",
                "ranging from 9deg to 48deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " The heavier beam-like recoil reaction",
                "products, including 4,6He for the 8Li-induced reactions",
                "and 6Li and 4,6He from the 7Li-induced reactions, were",
                "detected in coincidence with the light ions in an array",
                "of four silicon dE - E telescopes covering laboratory",
                "polar angles from 1.4deg to 7.2deg for 92% of the",
                "azimuthal range."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Beam intensity was monitored using",
                "downstream dE E monitor telescope. A 150 mu-g/cm2",
                "thick gold foil was used to scatter the unreacted",
                "beam into a monitor telescope at a very forward angle."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "EDE"
              ],
              "free_text": [
                " Coincidence between light ejectiles and",
                "beam-like recoil reaction products was required"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "8Li beam was produced via 2H(7Li,p)8Li reaction.",
                "Cryogenic D2 gas cell pressurized to 1400 mbar was",
                "bombarded with a 70 pnA beam of 7Li at an energy of",
                "81 MeV. The secondary beam was focused with a 6T",
                "superconducting solenoid and then passed through a",
                "bunching resonator to optimize its longitudinal",
                "emittance. The 8Li ions were then separated from the",
                "primary beam using a dipole magnet and mechanical slits"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
