          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the A(yy) tensor analyzing power for",
                " the 1H(d(pol),pp)n reaction in the symmetyric",
                " constant relative geometry"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "ATOMI"
                ],
                "reaction": null
              },
              "free_text": [
                " Spin state reversed every 20 sec.",
                " Beam polarization for tensor state",
                "   positive: p(y) = -0.279, p(yy) = 0.827,",
                "   negative: p(y) = -0.263, p(yy) = -0.799.",
                "Energy spread of beam less than 100 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polyethylene targets mounted on a moveable frame.",
                " Target thickness typically 5.78 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Large-area wire chambers and plastic",
                " scintillation detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Symmetric constant relative energy (SCRE) geometry",
                " used, in which all 3 nucleons are emitted, in c.m.",
                " frame, at relative angles of 120 degrees and with",
                " equal kinetic energies.",
                "The final state can be charactarized by the outgoing",
                " neutron direction which (in c.m.) makes and angle",
                " (alpha) with respect to the velocity of the incident",
                " proton."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polarization monitored using 3He gas cell and",
                " plastic scintillators to detect protons from",
                " 3He(d,p)4He reaction at 30 degrees.",
                "Energy resolution determined using elastic scattering",
                " of deuterons from carbon in the polyethylene target."
              ]
            }
          ],
