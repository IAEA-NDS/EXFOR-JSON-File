          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "550 MeV proton beam of the Space Radiation Effects",
                "laboratory synchrocyclotron."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets consisted of a mixture of CsBr (optical grade",
                "- 99.9%) and 99.99% pure fine aluminum powder,",
                "homogeneously mixed and pressed into pellets. The",
                "resulting targets contained 38 to 47%",
                "monoisotopically pure 133Cs and had a surface density",
                "of 59-131 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " High resolution nuclear diodes Ge(Li) detector."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "DG"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "RCHEM",
                "GSPEC",
                "STTA",
                "ACTIV"
              ],
              "free_text": [
                " After irradiation the CsBr",
                "pellets and adjacent guard foils were dissolved and",
                "cesium and barium fractions were chemically separated",
                "and purified by standard radiochemical procedures.",
                "All samples prepared in this fashion were assayed by",
                "gamma detection using a high resolution Nuclear Diodes",
                "Ge(Li) detector."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "PGS"
              ],
              "free_text": [
                " Activity measurements were analyzed using the",
                "Brookhaven decay curve analysis program CLSQ."
              ]
            }
          ],
