          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross Sections and Isomer Ratios for the Sc45(He3,",
                "alpha)Sc44m,44g Reactions from 6-19 MeV: Recoil-Range",
                "Studies for Sc44m and Sc44g in Sc45"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
