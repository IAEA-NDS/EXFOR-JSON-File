          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The number of counts per minute, at the end",
                "of bombardment, was obtained from the decay curve by",
                "resolution of the 10 min N-13 from the other",
                "activities (mainly 20.5-min C-11) detected. This was",
                "done by making the decay curve analysis first by hand",
                "and then with the aid of an IBM-704 least square",
                "program called \"Frenic\". The least square program",
                "gave the number of counts of each component and its",
                "standard deviation."
              ]
            }
          ],
