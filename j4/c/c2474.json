          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In order to derive information concerning the",
                "independent production of Kr isomers, we calculate",
                "the quantity sigmag/(sigmag+sigmam) from the",
                "independent fractional chain yield of 85Kr and the",
                "fraction (f) of the mass-85 chain which directly",
                "populates the 9/2 state: f=(R - b)/(1 - b) , where b",
                "is the branching from the spin 1/2 state (0.219) and",
                "R is the ratio of 85Kr (ten-year) to mass-85 chain",
                "yield."
              ]
            }
          ],
