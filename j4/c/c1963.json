              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Al sample with dimensions of 11.5 x 11.5 cm2",
                "and thickness of 3 mm"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Stack of CR39 polymer track detectors with",
                "dimensions  of 11.5 x 11.5 cm2. In the stack there",
                "were two CR39 detectors upstream and 10 CR39 detectors",
                "downstream of the 3mm Al target. Detectors were covered",
                "during irradiations by a 45 mu-m plastic film to",
                "protect them from exposures to ambient radon and its",
                "progeny"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear track detectors were etched after the",
                "irradiation. Charge of the passing ions was determined",
                "from track diameter. Cross section was determined",
                "from comparison of number of tracks in detectors",
                "placed in front of the Al target with number of tracks",
                "in detectors placed behind the Al target."
              ]
            }
          ],
