          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated polyethylene (CD2)n or polyethylene (CH2)n",
                "of thickness 363 mu-g/cm2 and 387 mu-g/cm2 placed",
                "at the HELIOS axis."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The outgoing protons and deuterons were",
                "analyzed by the HELIOS spectrometer with a magnetic",
                "field strength of 2.5 T."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " The outgoing protons and deuterons were detected",
                "by an Si position sensitive array, consisting of 24",
                "position sensitive detectors. Array was laced on",
                "HELIOS axis and covered the range of 332 mm < z < 682",
                "mm. The array was moved 60 mm closer to the target",
                "for part of the measurement to cover smaller center",
                "of mass angles"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " The 15C recoils were detected by dE-E",
                "telescopes composed of 75 mu-m and 1000 mu-m thick",
                "quadrant silicon detectors. The deuterons and protons",
                "traveling for more than one cyclotron period were",
                "stopped by a cylindrical plastic blocker surrounding",
                "the recoil detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "COINC"
              ],
              "free_text": [
                " Coincidence between scattered deuterons",
                "and recoils was required. Time coincidence of 20 ns",
                "was used"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 15C secondary beam was produced using the neutron",
                "adding reaction on a 14C primary beam at 8 MeV/u,",
                "with an intensity of 200 particle nanoamperes.",
                "The 14C beam bombarded a 37-mm long deuterium",
                "gas cell at a pressure of 1400 mbar and temperature",
                "of 90 K. The resulting 15C beam had a rate of",
                "approximately 1E+6 particles per second."
              ]
            }
          ],
