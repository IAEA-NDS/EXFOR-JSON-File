          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A radioactive 8Li beam was produced using the",
                "2H(7Li,8Li) 1H reaction.Primary 7Li beam was",
                "accelerated and bombarded primary target - a",
                "liquid-nitrogen- cooled, 4 cm long deuterium gas cell",
                "with pressure of 400 Torr. The secondary 8Li beam",
                "produced via 2H(7Li,8Li) 1H reaction was momentum",
                "selected, bunched and separated from other",
                "contaminants by the superconducting resonator, and",
                "the quadrupole and dipole magnets of the RESOLUT",
                "separator. The beam purity was 95% 8Li and typical",
                "intesity 2E+4pps."
              ]
            }
          ],
