          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Two double sided annular silicon strip",
                "detectors of the S2 type installed downstream of the",
                "target were used to detect charged reaction products.",
                "SiSD consist of 48 rings on one sides and 16 segments",
                "on the other side. First SiSD had thicknes of 1000",
                "mu-m and was placed at a distance 7.6 cm downstream",
                "of C2H4 target. The second SiSD had thickness of 500",
                "mu-m and was placed 26.8 cm downstream of the target."
              ]
