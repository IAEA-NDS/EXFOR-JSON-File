          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cryogenic 4He gas target at pressure 550 torr and",
                "temperature 90 deg K. The target cell was 1.5 mm in",
                "length with effective target thickness of 59 mu-g/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " An annular 500 mu-m thick silicon strip",
                "detector was used to identify the protons from the",
                "reaction. It was placed 20 cm downstream from the",
                "target, covering an angular range of theta(lab) from",
                "6.8deg to 13.5deg. An aluminum foil 70 mu-m thick (40",
                "mu-m for the lowest energy point) was used to ensure",
                "that only protons from the ground state and first",
                "excited state of 26Mg reach the detector with",
                "acceptable energy losses."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inverse kinematics with 4He target and 23Na beam",
                " was used"
              ]
            }
          ],
