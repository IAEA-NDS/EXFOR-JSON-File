          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Breakup of 17F on 208Pb near the Coulomb barrier"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                " at the Holifield Radioactive Ion Beam",
                " Facility, where the isotope separator on-line",
                " technique was employed for radioactive ion beam",
                " production."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A 44 MeV deuteron beam from the Oak Ridge isochronous",
                "  cyclotron was incident on a fibrous hafnium oxide",
                "  target to produce short-lived F-17 by the",
                "  O-16(d,n)F-17 reaction"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target used was a self-supporting 208Pb foil with a",
                " nominal thickness of 1.8 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SISD"
              ],
              "free_text": [
                " The reaction products were detected",
                "by a dE-E telescope composed of a 29 mm Si detector",
                "mounted in front of a 1000 mm double-sided silicon",
                "strip detector (DSSD)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two 50 mm2 Si surface barrier detectors placed",
                "at 10. degr. on either side of the beam were used to",
                "monitor the beam position and for normalization",
                "between runs"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "82-PB-208(9-F-17,EL)82-PB-208,,DA,,RTH",
                  "code_unit": [
                    {
                      "unit": "82-PB-208(9-F-17,EL)82-PB-208,,DA,,RTH",
                      "field": {
                        "reaction": "82-PB-208(9-F-17,EL)82-PB-208",
                        "target": "82-PB-208",
                        "projectile": "9-F-17",
                        "process": "EL",
                        "product": "82-PB-208",
                        "quantity": ",DA,,RTH",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA,,RTH"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " -",
                " The absolute cross section was obtained by normalizing",
                "the yields to the 10. degr. Si detectors, where the",
                "elastic scattering was taken as Rutherford scattering."
              ]
            }
          ],
