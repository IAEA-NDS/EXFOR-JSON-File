          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isovector excitations in 100Nb and their decays by",
                "neutron emission studied via the 100Mo(t,3He+n)",
                "reaction at 115 MeV/u"
              ]
            }
          ],
