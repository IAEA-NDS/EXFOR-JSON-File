          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " The detection system consisted of two 7.5 cm",
                "diameter by 7.5 cm thick NaI crystals mounted",
                "face-to-face with the target centered between them.",
                "The decay of 18F was detected by counting 511 keV",
                "annihilation gamma-rays in coincidence. The",
                "separation between the detector faces was 5.7 cm.",
                "Except for the solid angle subtended by the crystals,",
                "the volume between the two faces was filled in with",
                "lead. The efficiency of the system was measured",
                "using a calibrated 22Na source and found to be",
                " (3.13+/-0.15)%."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thick disks, 1.25 cm in diameter and 0.4 cm thick, of",
                "sintered TiN were used as targets. The targets were",
                "air-cooled."
              ]
            }
          ],
