          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beryllium target is embedded in a 3.8-mm-thick",
                "electrically isolated tantalum disk and backed by a",
                "14.5-mm-thick copper cooling assembly. The indium",
                "foils were 5 mm in diameter and 1 mm thick with a",
                "weight 14.34 g. respectively."
              ]
            }
