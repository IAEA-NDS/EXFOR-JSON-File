          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated polyethelyne (C2D4)n target with",
                "thickness of 110 mu-g/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "SI"
              ],
              "free_text": [
                " A large-bore, superconducting solenoid",
                "with its axis aligned with the beam direction",
                "transported the protons emitted at forward angles in",
                "the center-of-mass frame to a position-sensitive",
                "silicon-detector array surrounding the beam axis",
                "upstream of the target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " The recoiling 16C ions were detected in",
                "coincidence with protons in an array of silicon",
                "detector dE - E telescopes that covered 0.5deg - 2.8deg",
                "angular range."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between protons and 16C ions",
                " was required. Inverse kinematics used."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " The 15C beam was produced by bombarding a",
                "cryogenic D2 gas cell with a 100 p nA 14C primary",
                "beam with an energy of 133 MeV. The resulting 15C",
                "beam, from the 14C(d,p)15C reaction, had an energy",
                "of 123 MeV, corresponding to a deuteron energy of",
                "16.4 MeV. The intensity ranged from 1 to 2E+6 15C ions",
                "per second."
              ]
            }
          ],
