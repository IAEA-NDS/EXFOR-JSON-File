          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " 197Au and 238U target assemblies were placed",
                "behind one another in an evacuated beam tube. After",
                "irradiation, each conical catcher foil was cut into",
                "four pieces, corresponding to angular ranges with",
                "respect to the beam direction through the center of",
                "the evaporated target. Catcher foils corresponding to",
                "the same angular range from each of the 17 targets",
                "were combined and counted as a single sample using a",
                "Ge(Li) detector."
              ]
            }
          ],
          "ERR-ANALYS": [
