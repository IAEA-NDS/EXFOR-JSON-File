          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The resulting secondary beam, which exhibited an",
                "approximately 85% purity in 38Ca and a typical rate",
                "of 1.6*10**5 38Ca ions per second. The mid target",
                "energy of the 38Ca projectiles was 60.9 MeV/u,",
                "corresponding to a velocity of v/c ~ 0.345."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "SPEC",
                "SCIN"
              ],
              "free_text": [
                " The high-resolution gamma-ray",
                "tracking array GRETINA, consisting of 12 detector",
                "modules; each of which contains four 36-fold",
                "segmented high-purity germanium crystals. The",
                "particle identification in the entrance and exit",
                "channel was performed on an event-by-event basis",
                "using plastic timing scintillators and the S800",
                "focal-plane detection system."
              ]
            }
          ],
          "SAMPLE": [
