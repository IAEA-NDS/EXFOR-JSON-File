          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polyethylene foil (CD2)n with thickness of 80 mu-g/cm2",
                "The target surface was placed at 30deg with respect to",
                "the beam axis, so the effective areal density was",
                "160 mu-g/cm2. Inverse kinematics was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SISD"
              ],
              "free_text": [
                " The ORRUBA array consisted of ten",
                "1000 mu-m thick position sensitive silicon strip",
                "detectors, plus four thinner dE detectors that were",
                "used to form detector telescopes for the more forward",
                "angles"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD",
                "MCPLT"
              ],
              "free_text": [
                " Annular silicon strip detector, a carbon-",
                "foil-microchannel plate detector, and a",
                "segmented-anode ion counter were placed at forward",
                "angle and used for beam diagnostic."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " E-dE method was used for particle identification."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence signals from particles detected",
                "in the ORRUBA silicon arrays and the beamlike recoils",
                "striking the microchannel plate detector served to",
                "reduce the background from other, non-(d,p) processes",
                "Inverse kinematics was used"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section normalization was achieved by detecting",
                "elastically scattered deuterons with the ORRUBA at",
                "relatively small center-of-mass angles",
                " 33deg-38deg, where the ratio to Rutherford",
                "scattering is in the range 0.92 - 0.99, and comparing",
                "to optical model calculations."
              ]
            }
          ],
