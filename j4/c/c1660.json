          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USATAM"
              },
              "free_text": [
                "The Texas A&M University K500",
                "cyclotron facility was used to produce",
                "primary beam 200 pnA of 10B at E/A = 15.0MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " Charged particles were detected",
                "and identified in four Si E-dE telescopes located in",
                "a plane 14.0 cm downstream of the target. The",
                "telescopes, part of the HiRA array, consisted of a",
                "65-mum-thick, single-sided Si-strip dE detector",
                "followed by a 1.5-mm-thick, double-sided Si strip E",
                "detector. All Si detectors were 6.4 x 6.4 cm in",
                "area with the position-sensitive faces divided into",
                "32 strips."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " A secondary beam of E/A = 10.7 MeV 10C was",
                "produced through the 10B(p,n)10C reaction and separated",
                "from other reaction products using the MARS",
                "spectrometer. This secondary beam, with intensity of",
                "2E+5 ions/sec, purity of 99.5%,energy spread of 3% and",
                "a spot size of 3.5 x 3.5 mm was used for experiment."
              ]
            }
          ],
          "SAMPLE": [
