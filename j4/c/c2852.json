          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The background counting rate was obtained by",
                "substituting for the silver chloride target a foil of",
                "pure silver containing very nearly the same amount of",
                "silver per square centimeter as that of the target.",
                "It was negligible at all angles except 0 degree,",
                "where it accounted for 35 percent of the total",
                "counting rate."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "After subtracting from each point the constant",
                " \"background\" counting rate at 65 degrees."
              ]
            }
          ],
