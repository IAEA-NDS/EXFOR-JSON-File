          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inelastic scattering of 100 MeV protons from 12C",
                "using a Ge(Li) total-absorption proton counter"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Y.S.Horowitz",
                "R.E.Bell"
              ],
              "free_text": [
                ""
              ]
            }
          ],
