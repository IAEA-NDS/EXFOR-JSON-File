          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A guard foil was placed in contact with the foil to",
                "be counted. The guard served as a source of recoil",
                "carbon-11 nuclei, compensating for recoils lost",
                "through the back of the counted foil. The",
                "self-absorption in the foil was investigated and the",
                "correction was found to be less than 1% up to 4mg/cm2,",
                "then increasing by about 0.8% per mg/cm2."
              ]
            }
          ],
