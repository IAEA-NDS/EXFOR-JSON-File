          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross sections have been measured at a laboratory",
                "angle of 138 degrees for bombarding energies from 250",
                "to 1300 keV using a high resolution double-focusing",
                "180 degrees magnetic spectrograph. The energy scale",
                "was calibrated by measurements on the strong",
                "19F(p,alpha gamma) resonance at 873.5 keV."
              ]
            }
          ],
