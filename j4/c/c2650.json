                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "21.4 g/cm2 of CH2."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The charge-exchange cross sections were determined",
                "from the expression: sigma c = (I(AN)/(I(AP)*Ntargt))*",
                "exp(Ntarget*sigma target + Nsc*sigma sc + NPb*sigma Pb)",
                " where sigma c = charge-exchange cross section per",
                "molecule for production of antineutrons into a solid",
                "angle of 0.275 steradian in the forward direction,",
                "I(AP) total number of antiprotons incident on the",
                "target, I(AN) total number of antineutrons observed in",
                "counter D, exp(Ntarget*sigma target), exp(Nsc*sigma sc)",
                ", and exp(NPb*sigma Pb) are the attenuations in the",
                "target, the scintillation counters, and the 1.5-in. Pb",
                "converter, respectively."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
