                    "unit": "6-C-CMP(AP,X)0-AN-1,,SIG",
                    "field": {
                      "reaction": "6-C-CMP(AP,X)0-AN-1",
                      "target": "6-C-CMP",
                      "projectile": "AP",
                      "process": "X",
                      "product": "0-AN-1",
                      "quantity": ",SIG",
                      "data_type": null,
                      "general_quantity_modifier": null,
