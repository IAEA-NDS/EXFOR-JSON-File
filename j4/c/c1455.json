          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "12C, 35Cl and 60Ni beams"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " three CsI scintillators coupled to PIN diodes",
                " were used to detect the LCP's. The CsI scintillators",
                " are 132 cm2 and 1 cm thick. The front surface of the",
                " CsI detector is covered by a 3.5 mg/cm2 Ti foil which",
                " gives the threshold for detecting protons and a",
                " particles of 0.8 and 2.6 MeV, respectively."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target thicknesses are 200, 310, and 1000",
                " microg/cm2 for 144Sm,121Sb, and 96Zr, respectively.",
                " Among those targets, only the 96Zr target is",
                " self-supporting. The other two are mounted on a",
                " 10 - 20 mg/cm 2 carbon foil as a backing."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy calibration of the LCP detectors was",
                " performed by measuring the elastic scattering of",
                " protons and a particles on a 350 microg/cm 2 Au foil."
              ]
            }
          ],
