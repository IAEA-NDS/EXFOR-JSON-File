          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1CANTOR"
              },
              "free_text": [
                " The 1 MV JN Van de Graaff accelerator at",
                "the University of Toronto supplied proton beams in the",
                "energy range of Ep = 350-950 keV. Energy resolution and",
                "calibration were better than 1 and 2 keV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USACAL"
              },
              "free_text": [
                " The 3 MV Pelletron tandem accelerator",
                "at the Kellogg Radiation Laboratory at the California",
                "Institute of Technology supplied proton beams in the",
                "energy range of Ep = 700-2950 keV. Energy resolution",
                "was 2 keV, measured using the 27Al(p,gamma)28Si",
                "resonance at ER = 991.88+/-0.04 keV. The proton energy",
                "was calibrated with this resonance and the",
                "28Si(p,gamma)29P resonance at ER = 1380.2+/-0.8 keV",
                "to better than l.0 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "SiO targets were produced by evaporation of SiO2 on to",
                "a thick Ta backing. The target thicknesses were",
                "50 and 100 mu-g/cm2."
              ]
