          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "AMS"
              ],
              "free_text": [
                " After the aluminium targets were counted for",
                " 24Na, they were analyzed for 26Al at the University",
                " of Pennsylvania's Tandem Accelerator Laboratory mass",
                " analysis facility.",
                " Measurements were made by producing Al-negative",
                " ions, accelerating them through 36 keV and mass",
                " analyzing them through 90-deg before injection into",
                " the tandem accelerator operated at 7.5 MeV. Al27+",
                " ions at 60 MeV were analyzed in a velocity selector,",
                " then a 90-deg bending magnet followed by another",
                " 45-deg magnet before detection."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Targets were completely dissolved with HCl,",
                " precipitated with NH4OH, and converted to Al2O3 by",
                " baking in an 800-deg C oven for several hours.",
                " About 2 mg of the Al2O3 from each target was pressed",
                " into a copper cathode and loaded into a cesium-",
                " sputter ion source."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Combination gas (DE) - Si surface-barrier",
                " (E) detector."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopic ratios normalized by comparison to standard",
                " sample having a ratio of 9.86x10**(-12), made from",
                " NBS-standard 4229-24, and based on 26Al half-life of",
                " 7.03 x 10**5 yr.  Normalization factor 1.1 ."
              ]
            }
          ],
