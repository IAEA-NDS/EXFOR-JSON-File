              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fusion and neutron-transfer cross sections for",
                " 13C + 10B and 13C + 11B reactions at subbarrier",
                " energies"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
