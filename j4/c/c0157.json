          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectral function of p-n pairs in 6Li, from the",
                " 6Li(p,p alpha)pn reaction at 200 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "MESON"
                ],
                "institute": "1CANTMF"
              },
              "free_text": [
                " The TRIUMF facility."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLIS"
                ],
                "reaction": null
              },
              "free_text": [
                " 200-MeV proton beam about 80% polarized and",
                " periodically cycled between up and down polarization",
                " states."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "3-LI-6",
                "field_identifier": "ENR",
                "value": 0.9545
              },
              "free_text": [
                " A 95.45 % enriched 6Li target of",
                " thickness 10.5+-1.0 mg/cm**2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Protons and alpha-particles detected in coincidence",
                " by two telescopes coplanar with, and on opposite",
                " sides of, the beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SCIN",
                "NAICR"
              ],
              "free_text": [
                " Proton detected by system of 2",
                " plastic scintillators (each 0.63 cm thick) and a",
                " NaI(Tl) crystal (12.7-cm-diam x 15.2-cm-thick) 2",
                " meters from the target. One plastic detector provided",
                " time-of-flight information, the other, 1.4 cm ahead",
                " of the NaI detector, defined the 1.14 msr solid angle."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SI",
                "SI"
              ],
              "free_text": [
                " Alpha particles detected using",
                " telescope of two Si detectors (0.1 and 5 mm thick);",
                " solid angle of 1.22 msr defined by brass collimator."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "EDE",
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam intensity and polarization monitored using",
                " elastic scattering in CH-2 polarimeter of analyzing",
                " power 0.285, 11.5 m upstream from the target."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for random coincidences and events from the",
                " 4.55% 7Li in the target (Random coincidences were",
                " always <4% of true coincidences except for most",
                " inelastic event sample for k = 1.53 1/fm (k is the",
                " momentum of each nucleon relative to Q = 0 of the p-n",
                " c.m.) where they were 14%.",
                "Events were subtracted from those in each proton",
                " energy bin to eliminate the remaining reaction tail",
                " from higher energy protons, as determined from the",
                " previously mentioned response function.",
                "A second correction was made to cover the events",
                " which should have appeared in that bin, but were",
                " lost through nuclear reactions in NaI.",
                "Counting losses due to dead time of electronics and",
                " data-acquisition computer were negligible (<0.1%)."
              ]
            }
          ],
