          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ASPEC"
              ],
              "free_text": [
                " In order to verify that the activity",
                "was indeed properly assigned to Lr, extractions with",
                "0.1 M thenoyl trifluoroacetate (TTA) in",
                "methylisobutyl ketone (MIBK) were performed. The KCI",
                "deposit was dissolved in a buffer solution of",
                "monochloroacetic acid or acetic acid adjusted to pH",
                "ranges of 1.86 to 5.5. Extractions with TTA from",
                "buffer solutions of different pH were performed. The",
                "organic phase was dried on a Pt plate and alpha",
                "counted. The entire procedure required about three",
                "minutes."
              ]
            }
          ],
