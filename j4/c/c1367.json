          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of the proton drip-line nucleus 17F"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAORL"
              },
              "free_text": [
                "the Holifield Radioactive Ion Beam",
                " Facility (HRIBF)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopically pure beam of 17F. The 17F was produced by",
                " the 16O(d, n)17F reaction in a thick hafnium-oxide",
                " target and ionized by a kinetic-injection negative",
                " ion source"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Two position-sensitive silicon-strip detector",
                " telescopes (25 cm2 in area), symmetrically positioned",
                " around the beam axis, covering angle-lab = 3-9 degree"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "  The Silicon-strip Detector Array (SIDAR) was",
                " used in these measurements to cover laboratory angles",
                " angle-lab = 7-18 degree in 16 angular bins."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polypropylene (CH2)n and melamine (C3N6H6) targets. A",
                " 2.2-mg /cm2-thick polypropylene target was used to",
                " measure the 12C(17F,17F)12C elastic-scattering cross",
                " section. A somewhat thinner 1.0-mg /cm2 target of",
                " melamine was used to measure the 14N(17F,17F) 14N",
                " cross section,"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "F17 particle"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target thicknesses were determined by measurement",
                " of the energy loss of a particles through the target",
                " and by weighing in the case of the polypropylene",
                " target."
              ]
            }
          ],
