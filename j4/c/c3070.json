          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "0.1 to 1 microA beams of 14.9+-0.12 MeV deuterons",
                "from the University of Pittsburgh cyclotron."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC",
                "NAICR"
              ],
              "free_text": [
                " 4pi methane-flow proportional counter,",
                "and 7.6 cm x 7.6 cm NaI(T1) scintillator and a 512-",
                "channel pulse-height analyser."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " Stacks of targets at the center of",
                "a scattering chamber were bombarded normally with",
                "deuterons. After each bombardment, the targets in the",
                "stack were subjected to radiochemical separations.",
                "The resultant samples of reaction-product nuclides,",
                "mounted as circular precipitates of known area under",
                "mylar coverings, were then counted absolutely."
              ]
            }
          ],
          "ANALYSIS": [
            {
