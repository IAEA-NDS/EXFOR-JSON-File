              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The quoted errors in the cross sections",
                "include the contributions of uncertainties in the",
                "counting efficiencies, chemical yields, decay scheme",
                "parameters, target thicknesses and incident beam",
                "intensities. The errors in the deuteron energies",
                "represent the uncertainty in the incident beam energy,",
                "compounded by the estimated energy spread during",
                "degradation through the target stacks."
              ]
            }
          ],
