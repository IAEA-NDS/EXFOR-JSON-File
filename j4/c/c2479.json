          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Radiochemical separation procedures were",
                "developed and modified from existing techniques for",
                "the isotopes and target materials involved and",
                "purification procedures were repeated until",
                "sufficient decontamination of the ternary and",
                "binary-fission products was obtained. Counting was",
                "carried out in low-background (0.09-0.20-counts/min)",
                "gas-flow Geiger counters fitted with a surrounding",
                "anticoincidence guard counter."
              ]
            }
          ],
          "ANALYSIS": [
