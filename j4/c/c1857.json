          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated polyethylene target with an areal density",
                "of 80 mu- g/cm2. The target was turned 30deg to the",
                "beam axis, resulting in an effective target thickness",
                "of 160 mu-g/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Scattered light ions and protons",
                "emitted from the (d,p) reaction were measured in a",
                "system of silicon detectors incorporating the Silicon",
                "Detector Array (SIDAR) and an early implementation of",
                "the Oak Ridge Rutgers University Barrel Array",
                " (ORRUBA). Four telescopes of ORUBA array covered",
                "polar angles between 69deg and 107deg. Energy loss",
                "detectors with thickness of 140 and 65 mu-m were used",
                "with 1000 mu-m thick E detectors."
              ]
            }
          ],
