          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of 17F scattering by 208Pb with a new type",
                " of large solid angle detector array"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1USAANL"
              },
              "free_text": [
                " ATLAS superconducting linear",
                " accelerator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 17F exotic beam is produced through the inverse",
                "reaction p(O-17,F-17)n with an intensity of about",
                "10**5 pps. The energy of the outcoming F-17 beam,",
                "measured with an Enge split pole magnetic spectrometer,",
                "was 90.4 MeV, with a full width at half maximum (FWHM)",
                "of 1.4 MeV (corresponding to a resolution of",
                "                                         about 1.5%)"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was a self supporting 1-mg/cm2-thick 208Pb",
                " foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " EXODET array consists of 16 solid state",
                " silicon detectors arranged in eight two-stage",
                " telescopes to allow the Z identification of the",
                " particles passing through the first layer, by means",
                " of the usual dE-E technique"
              ]
            }
          ],
          "HISTORY": [
