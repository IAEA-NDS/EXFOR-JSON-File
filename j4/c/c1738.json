          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Influence of projectile neutron number in the",
                "208Pb(48Ti,n)255Rf and 208Pb(50Ti,n)257Rf reactions"
              ]
            }
          ],
          "AUTHOR": [
