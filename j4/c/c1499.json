          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Precision measurements of 2H(d,p)3H and",
                " 2H(d,n)3He total cross sections at Big Bang",
                " nucleosynthesis energies"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " the TUNL Low-Energy Beam Facility",
                " (LEBF): the Atomic Beam Polarized Ion Source and",
                " Mini-Tandem accelerator"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Eight energies, Ed = 120, 180, 240, 320, 390, 480,",
                " 560, and 650 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were produced by plasma deposition of",
                " fully deuterated methane gas and were typically",
                " about 30 microg/cm2 thick, with roughly equal",
                " numbers of carbon and deuterium atoms."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Seven high resolution, ion-implanted",
                " silicon detectors were positioned in the chamber",
                " to observe elastic scattering from deuterium. All",
                " detectors had either 300 or 500 microm depletion",
                " depths and 1.50 cm2 active areas."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties for the normalized data",
                " input into the fits were calculated by first-order",
                " propagation of the uncertainties in the peak sums.",
                " Correlations arising from shared monitor normalization",
                " counts were not taken into account because the",
                " monitor yields generally contributed a relatively",
                " small amount to the overall statistical uncertainties.",
                " The final uncertainties and correlations in the",
                " cross-section results are determined directly from",
                " the error matrix."
              ]
            }
          ],
