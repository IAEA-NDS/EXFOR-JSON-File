          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were produced by evaporating 93.10%",
                "isotopically enriched metallic 113In onto highpurity",
                "thin (d = 2.4 mu-m) aluminum foils. Diameter of",
                "deposited 113In was 12 mm and thickness varying",
                "between 168 mu-g/cm2 and 289 mu-g/cm"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector with relative efficiency of 40%",
                "was used. To reduce the room background, the",
                "detector was shielded with 10-cm-thick lead bricks."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Alpha particles energies of 10.032, 10.565, and",
                "11.111 MeV were obtained from the beam energies",
                "11.000, 11.500, and 12.003 MeV, respectively, using",
                "degrader foils."
              ]
            }
          ],
