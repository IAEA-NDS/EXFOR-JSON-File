          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The bismuth targets used in the proton irradiations",
                "were prepared by one of two techniques. Thin targets"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": null,
                "field_identifier": null,
                "value": null
              },
              "free_text": [
                " were made by the evaporation",
                "of high purity bismuth metal onto aluminum backings.",
                "Thicker selfsupporting targets ( 1g/cm2 ) were",
                "prepared by pressing.Data presented are measured",
                "with target thickness of 32.77 mg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " Activation method was used. Following",
                "the chemical separation, At production cross sections",
                "were determined through the use of alpha and gamma",
                "spectroscopic techniques."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " For gamma counting a Ge(Li) detector was used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Si surface barrier detector was used for alpha",
                "        particle counting"
