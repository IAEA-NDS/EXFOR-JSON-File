          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two targets were used simultaneously. A 9Be target",
                "with thickness of 370 mg/cm and 181Ta target with",
                "thickness of 2158mg/cm2 separated by 25 mm."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G",
                "10-NE-29"
              ],
              "free_text": [
