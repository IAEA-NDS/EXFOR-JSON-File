          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thresholds for the Proton-Neutron Reactions of",
                "Lithium, Beryllium, Boron, and Carbon"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.O.Haxby",
