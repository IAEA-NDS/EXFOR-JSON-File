          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam ions passed through a 1.8 mg/cm2 Havar",
                "isolation window and a 2.3 mg/cm2 beryllium target",
                "backing before encountering the curium target",
                "material. The target backing was cooled by nitrogen",
                "gas. The target had a thickness of 0.485 mg/cm2 248Cm,",
                "present as the oxide. The curium in the target was",
                "97.4% Cm in isotopic composition along with 2.6% Cm",
                "and (1x10**-4) % 244Cm. The target was made by",
                "batchwise electroplating curium from an isopropanol",
                "solution of the nitrate and converting it to the",
                "oxide form by heating to 300 degree Celcium."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "96-CM-244",
                "field_identifier": "ENR",
                "value": 1e-06
              },
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "96-CM-246",
                "field_identifier": "ENR",
                "value": 0.026
              },
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "96-CM-248",
                "field_identifier": "ENR",
                "value": 0.974
              },
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR",
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                " Chemical separation techniques were",
                "used to isolate chemical fractions of Np, Pu, Am, Cm,",
                "Bk, Cf, Es, and Fm from the catcher foil. Surface",
                "barrier detectors were used to count alpha activities",
                "in the Fm, Es, and Cf fractions, while Ge(Li)",
                "detectors were used for counting gamma- and x-ray",
                "activities in the Fm, Es, Cf, and Bk fractions."
              ]
            }
          ],
