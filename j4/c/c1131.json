          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute Cross Sections for 64Cu and 61Cu Produced by",
                "Deuteron-Induced Reactions in Copper"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
