                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors given are total errors calculated",
                "at a 95% level of confidence as the square root of",
                "the sum of squares of total random and systematic",
                "errors."
              ]
