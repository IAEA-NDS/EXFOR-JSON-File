          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                "Sample was positioned at the pivot point of",
                "the S800 spectrograph. The S800 selected the",
                "secondary reaction residue of interest based on",
                "magnetic rigidity and identified on event-by-event",
                "basis in focal plane detector"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " The focal-plane detection system",
                "consisted of two x-y position-sensitive detectors and t",
                "plastic scintillators (5 and 10 cm thickness). The",
                "scintillators provided both an energy loss dE and total",
                "residue energy E measurement and in addition a start",
                "signal for the time-of-flight measurement."
              ]
            }
          ],
