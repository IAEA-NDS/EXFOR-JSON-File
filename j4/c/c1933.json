          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " The proton-rich nucleus 36Ca with t1/2 = 102",
                "ms was produced by fragmenting a 140 MeV/nucleon 40Ca",
                "primary beam on a 9Be target and was filtered using",
                "the A1900 fragment separator. The 36Ca purity was 8%,",
                "and other beam constituents included 35K, 34Ar, 33Cl,",
                "and 32S."
              ]
            }
          ],
