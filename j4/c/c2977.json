          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The neutron detector consisted of a 8.89 cm",
                "diameter by 5.04 cm thick NE 218 liquid scintillator",
                "coupled to a 56 DVP photomultiplier."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "3-LI-7",
                "field_identifier": "ENR",
                "value": 0.9999
              },
              "free_text": [
                " The lithium target was enriched",
                "to 99.99% 7 Li and was encapsulated in an aluminum",
                "container under a helium atmosphere. The upstream",
                "face of the lithium was covered with a 3.5 pm",
                "molybdenum foil and the target length was 1.9 cm,",
                "sufficient to stop 15 MeV deuterons."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PSD"
              ],
              "free_text": [
                " A pulsed beam of protons or deuterons from",
                "the accelerator was used in conjunction with the TUNL",
                "neutron time-of-flight facility. Beam currents of 2-5",
                "nA with a time resolution of 1.5 to 2.0 nsec were used.",
                "Pulse shape discrimination was used to discriminate",
                "against gamma ray events."
              ]
            }
          ],
