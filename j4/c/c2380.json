          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "60-ND-146",
                "field_identifier": "ENR",
                "value": 0.975
              },
              "free_text": [
                " The targets used for this",
                "experiment consisted of Nd2O3 evaporated onto",
                "20-microg/cm2 carbon foils. The evaporated material",
                "had a thickness of 200+-10 microg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "PS",
                "SCIN"
              ],
              "free_text": [
                " A quadrupole-dipole-dipole-dipole",
                " (QDDD) magnetic spectrograph, position-sensitive gas",
                "counter and scintillator focal plane detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectra were obtained at laboratory angles between 21",
                "and 50 degrees."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Gaussian peak-fitting program GELIFT was used for",
                "integrating the observed peaks in the spectrum.",
                "Normalization factors for converting",
                "inelastic-scattering yields to absolute differential",
                "cross sections were determined by comparing elastic",
                "scattering yields at each angle to the differential",
                "cross sections for elastic scattering predicted by",
                "using Becchetti-Greenlees optical model parameters."
              ]
            }
          ],
