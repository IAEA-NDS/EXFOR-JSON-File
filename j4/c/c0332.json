          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " The Cu targets were gamma ray counted using a",
                "45 cm3 PGT Ge(Li) detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "GSPEC"
              ],
              "free_text": [
                " Two copper targets were irradiated with",
                "4.22 GeV (211 MeV/nucleon) and 7.54 GeV (377",
                "MeV/nucleon) 20Ne ions in the external beam of the",
                "Bevalac at the Lawrence Berkeley Laboratory. The",
                "total currents on target were 7.5 x 10**7 and 8.57 x",
                "10**7 20Ne ions/sec for Cu 377 and Cu 211,",
                "respectively. The targets were transported to the",
                "Indiana University Cyclotron Facility (IUCF)",
                "10 days after the irradiation and were gamma",
                "ray counted periodically over a 4 month time interval."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thick-target yields of products near the target",
                "were corrected for secondary production processes.",
                "The corrections amount to a 5% reduction in the thick",
                "target yield of Mn and increase with mass number to",
                "about 20% for Co and 35% for Zn. The error in these",
                "corrections is estimated to be of the order of 20%",
                "for 60Co of the reduction and would amount to",
                "increased errors of a few percent or less for the",
                "thick target error values. The low mass products 7Be",
                "and 24Na were corrected approximately 30% and 15%,",
                "respectively."
              ]
            }
          ],
