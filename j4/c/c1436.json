              },
              "free_text": [
                " the TwinSol radioactive nuclear beam",
                " facility at the University of Notre Dame"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A maximum 6He rate of 10E5 s-1 was produced. The",
                " remaining contaminant ions were identified by",
                " time-of-flight (TOF) techniques, using the time",
                " difference between the occurrence of the secondary",
                " reaction and the RF timing pulse from a beam buncher."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 3.2 mg/cm2 Bi layer evaporated onto a 100 microg/cm2",
                " polyethylene backing."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " The reaction events were detected with five",
                " Si DE-E telescopes placed at various angles on either",
                " side of the beam. Each telescope had an effective",
                " angular resolution of between 9-11 degree (FWHM)"
              ]
            }
