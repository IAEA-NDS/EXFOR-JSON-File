          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polarization transfer in the 23Na(p(pol),23Mg(pol))n,",
                " 31P(p(pol),31S(pol))n, and 35Cl(p(pol),35Ar(pol))n",
                " reactions"
