              "coded_information": {
                "incident_source": [
                  "POLIS"
                ],
                "reaction": null
              },
              "free_text": [
                " Beam polarization reversed each cycle."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillator telescopes coupled to photo-",
                " multiplier tubes."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured asymetries.  Polarization transfer coefficient",
                " calculated using asymmetry parameter A calculated from",
                " ft values."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for deadtime, beam modulation coherent with",
                " spin reversal, and electronic gain shifts."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Includes the following uncertainties.",
                "Overall systematic uncertainty in asymetry &lt; 2.9%,",
                " due to background, accidental coincidences, deadtime,",
                " gain shifts, backscattering, and intensity and",
                " possible beam modulations coherent with spin reversal.",
                "Additional scale uncertainty in polarization transfer",
                " parameter measurements of 1% due to uncertainty in",
                " proton polarimeter calibration."
              ]
            }
          ],
