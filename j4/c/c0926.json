          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The radiative yields calculated from the relation",
                "omega*gamma = (Mt/(Ma+Mt))*(2*S/rho)*(1/lambda)*Y,",
                "where S is alpha particle stopping power in lab.system,",
                " (Mt/(Ma+Mt)) c.m. conversion factor, rho is a number",
                "of 40Ca per gram of target material, lambda is the",
                "wavelength of the incident alpha-particle in the c.m.",
                "system, and Y is the yield of all observed primary",
                "gamma-rays in photons per alpha-particle."
              ]
            }
