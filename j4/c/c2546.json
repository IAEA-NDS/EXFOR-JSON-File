          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A natural uranium foil of thickness 33.5 mg/cm2",
                "surrounded by mylar catcher foils of thickness 35.5",
                "mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
