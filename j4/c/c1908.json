          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MCPLT",
                "IOCH"
              ],
              "free_text": [
                "Two carbon-foil-based microchannel plate",
                "timing detectors were used to monitor",
                "the beam and provide timing references. The",
                "evaporation residues were detected by a downstream",
                "MCP and a zero-degree ionization chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight and energy loss were used to",
                "identify the evaporation residues using inverse",
                "kinematics."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron rich radioactive Sn isotopes were produced by",
                "proton induced uranium fission, ionized, mass selected",
                "and accelerated. Highly enriched Sn beams were",
                "obtained by introducing sulfur to the ion source to",
                "make SnS+ molecular ions that were subsequently broken",
                "up in the charge exchange cell. Beams of 126,127,128Sn",
                "and 132Sn energies were accelerated"
              ]
            }
          ],
