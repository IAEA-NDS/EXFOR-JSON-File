          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The radioactive 10C beam was produced by the charge-",
                "exchange p(10B,10C)n reaction. The primary 10B beam",
                "with energy of 9.6MeV/u was delivered by the K500",
                "superconducting cyclotron and impinged on a cooled H2",
                "gas cell. The produced 10C ions were selected by the",
                "Momentum Achromatic Recoil Spectrometer."
              ]
            }
