          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Lowered fusion cross section in the quadruply magic",
                "heavy-ion system 48Ca + 208Pb"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "D.J.Morrissey",
                "W.Loveland",
                "R.J.Otto",
