              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PL/B,74,35,1978",
                "code_unit": [
                  {
                    "unit": "J,PL/B,74,35,1978",
