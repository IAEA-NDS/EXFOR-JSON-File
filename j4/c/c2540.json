          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Addition of multiple components. Component B(/2) =",
                "200 + 40 mb plus the heavy deep inelastic peak,",
                "component D = 420 + 20 mb, is approximately equal to",
                "component C = 570 -+ 50 mb, as expected. However,",
                "authors main interest is in the value of the complete",
                "fusion cross section, OCF, component A(/2) = 600 + 70",
                "mb. Component E, the quasi-elastic transfer products,",
                "is equal to ~600 mb."
              ]
            }
