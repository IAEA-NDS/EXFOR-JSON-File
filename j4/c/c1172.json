          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The systematic error is approximately 10%,",
                "mainly due to the uncertainty in the target thickness,",
                "while the incident beam particles were counted",
                "individually with a drift chamber placed at the",
                "entrance of the target chamber"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error bars shown are statistical",
                "and take into account the errors on the carbon",
                "target data which have been subtracted"
              ]
            }
