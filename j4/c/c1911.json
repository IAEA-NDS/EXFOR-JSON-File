          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC",
                "BGCT"
              ],
              "free_text": [
                " The 11C activity, which is 100%",
                "beta+ decay to 11B, was measured after bombardment",
                "using the a beta+gamma-gamma coincidence technique.",
                "Each NaI windowed the 0.511 MeV annihilation",
                "photopeak pulses. A gamma-gamma coincidence between",
                "the two indicated a beta+ decay in a scintillator."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The beta+, gamma-gamma, and beta+gamma-gamma",
                "counts were all multiscaled and fitted to a half-life",
                "curve with 11C 1224 sec half-life, and each had a",
                "xi2/(degree of freedom) of approximately one."
              ]
            }
