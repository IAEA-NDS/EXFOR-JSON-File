          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Detailed error analysis given in Table II of J,PR,93,",
                "483,1954. It includes errors for number of incident",
                "particles, number of target atoms, efficiency of",
                "counters, statistics, solid angle, energy. All these",
                "errors are summarized as standard and assigned. The",
                "standard error (the root of the sum of the squares)",
                "which appears at the bottom of each Table II column",
                "was based on the assumption that each of the",
                "individual errors is Gaussian in character. Such was",
                "most probably not the case; therefore, the error",
                "assigned was arbitrarily twice this."
              ]
            }
