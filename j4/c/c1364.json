          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Non-Rutherford backscattering analysis of nitrogen",
                " content in titanium substrates"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USALAS"
              },
              "free_text": [
                " the 3 MV tandem accelerator at the",
                " Ion Beam Materials Laboratory at Los Alamos National",
                " Laboratory."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Standard Si surface barrier detectors were",
                " used. The typical energy resolution was about 20 keV.",
                " The solid angle of the detector was approximately",
                " 2 msr."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets for the cross section measurement were",
                " prepared by implanting nitrogen into a thin zirconium",
                " layer prepared by e-beam evaporation. The surface",
                " layer contained 1.86 x1El7 Zr/cm2."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The resonance at 8.81 MeV was used to measure the",
                " nitrogen content of laser treated titanium. The Ti",
                " samples, Annealed Commercial Pure Ti, were laser",
                " processed using pulsed excimer laser radiation at 248",
                " nm from a KrF laser. The samples were translated in",
                " front of the beam at a calibrated rate to provide",
                " a given number of laser pulses per position on the",
                " sample."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Typical dead time corrections were 3-7%."
              ]
            }
          ],
