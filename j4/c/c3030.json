          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cumulative and independent population of individual",
                "levels via the 58Ni(alpha,pg)61Cu and",
                "58Ni(alpha,2pg)60Ni compound-nucleus reactions: A",
                "correlation between level cross sections and angular",
                "momenta"
