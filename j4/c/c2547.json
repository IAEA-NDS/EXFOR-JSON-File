              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A uniform target of 1.0 mg/cm2 Th was electroplated",
                "in a 7 mm diam spot on a 2.3 mg/cm2 beryllium",
                "substrate."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC",
                "CHSEP"
              ],
              "free_text": [
                " Recoiling reaction products between 0 and",
                "roughly 50 degrees to the beam direction were",
                "collected with a 2 mg/cm2 nickel foil and isolated",
                "chemically, and the cross sections for protactinium,",
                "uranium, and neptunium isotopes were determined. The",
                "decay of the nuclides in the chemical fractions was",
                "followed for about two weeks. Gamma-ray photons were",
                "observed with a Ge(Li) detector."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " No details on sources of uncertainties."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No corrections were made for parent-daughter feeding",
                "during the irradiations or before the chemical",
                "separations; this is a negligible effect except in",
                "the case of the 233Th-233Pa pair, where much of the",
                "observed intensity of 233Pa is due to decay from the",
                "22-min 233Th produced via simple neutron pickup or",
                "stripping reactions."
              ]
            }
          ],
