              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Analyzer magnet."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were self-supporting foils made of a layered",
                " structure of copper, melamine and copper, all",
                " evaporated onto a 20 microg/cm2 carbon foil. The total",
                " target thickness was estimated to be less than",
                " 150 microg/cm2"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 0.872 MeV resonance in the 19F(p, alpha+g) reaction",
