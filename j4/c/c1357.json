          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 14N(d, p5)15N cross section, 0.32-1.45 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ACCEL"
                ],
                "institute": "1USABRL"
              },
              "free_text": [
                " A Cockcroft-Walton accelerator at",
                " the Ballistic Research Laboratory was used to cover",
                " the energy range 0.32 to 0.70 MeV"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                " at Delaware University, 2 MeV Van de Graaf, for",
                " the energy region from 0.40 to 1.45 MeV"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "At the Ballistic Research Laboratory, the system the",
                " Cockcroft-Walton energy accuracy was no better than",
                " +/- 0.005 MeV",
                "At Delaware: beam slits were set so as to give better",
                " than +/-0.002 MeV accuracy to the beam energy at all",
                " points",
                "Typically, 100 to 200 nA of deuterons were used during",
                " the measurements."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                ""
              ]
