          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Titanium hydride foil. Thickness of the Ti foil was",
                "measured by Rutherford Back Scattering, number of",
                "hydrogen nuclei was determined using ERD experiment.",
                "The total measured thickness of the titanium hydride",
                "foil was 232+-14) mu-g/cm2. The determined number of",
                "hydrogen nuclei was (3.58+-0.36)E+18/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Gamma rays were detected with the Summing",
                "NaI(Tl) (SuN) detector from the National",
                "Superconducting Cyclotron Laboratory of Michigan",
                "State University. SuN is a cylindrical detector",
                "16in.in length and 16 in. in diameter with 1.77in.",
                "diameter borehole along its axis. The interior of the",
                "detector is divided into eight large, semi-",
                "cylindrical,NaI(Tl)crystals that are optically",
                "isolated and coupled to three photomultiplier tubes",
                "each."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inverse kinematics was used"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Doppler correction was used to correct the energy of",
                "Doppler broadened sum peak."
              ]
            }
          ],
