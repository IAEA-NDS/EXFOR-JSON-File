              "free_text": [
                "The 25 MV electrostatic tandem",
                "accelerator at the Holifield Radioactive Ion Beam",
                "Facility (HRIBF) was used to accelerate beams of",
                "radioactive 132Sn and stable 130Te"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The isotope separation online (ISOL) technique at the",
                "HRIBF was used to produce the 132Sn radioactive ion",
                "beam (RIB)"
              ]
            }
          ],
          "DETECTOR": [
