          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "2.5x10*10 particles/min."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target array for this experiment consisted of 3",
                "foils of natural uranium separated from each other by",
                "150 mm. The foils, varying in thickness from 33 to 72",
                "mg/cm2 and surrounded by ~15 mg/cm2 Al catcher foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "GSPEC"
              ],
              "free_text": [
                " Foils were irradiated for 162 min at",
                "the BEVALAC. Gamma and X-ray spectroscopic",
                "measurements of the radioactivity induced in the",
                "target and catcher foils began one hour after",
                "bombardment and continued for about three weeks. Over",
                "76 radionuclides were identified in this work on the",
                "basis of their gamma-, X-ray energy, half-life and",
                "radiation intensity."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Based upon the variation of activity with foil",
                "thickness, corrections (of ~10-30%) were made to each",
                "measured activity to account for the effects",
                "of:secondary-induced reactions. The corrections were",
                "roughly independent of A with maximum corrections",
                "being applied to the neutron-rich fission product",
                "activities. Recoil losses from the target were",
                "measured to be negligibly small."
              ]
            }
          ],
          "ERR-ANALYS": [
