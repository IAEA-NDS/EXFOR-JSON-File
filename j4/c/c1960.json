          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stopping natural boron target 3 mm thick and 25 mm in",
                "a diameter.  Stopping sulfur hexafluoride gas cell."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BGO",
                "SCIN"
              ],
              "free_text": [
                " The detector was 4 in. long and 4 in.",
                "diameter cylindrical BGO detector from St. Gobain",
                "with integrally mounted photomultiplier tube fitted",
                "with a Hamamatsu base."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                " The measurements are for only the indicated",
                "gamma-rays. Neutrons are  excluded by time-of-flight",
                "gating in the B(d,gamma 15.1) measurements, and  the",
                "alphas through atmospheric stopping in the F(p,a gamma)",
                " measurements."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD",
                "TOF"
              ],
              "free_text": [
                " The normalization of the pulse height",
                "spectra was completed by comparing the integrated",
                "counts in the energy regions of interest to those in",
                "the associated MCNP5 modeled pulse height spectra. A",
                "pulsed and bunched incident beam allowed for signal",
                "gating on time-of-flight spectra in order to reduce",
                "background in the measurements."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The detector response function for both measurements",
                "was modeled using MCNP5."
              ]
            }
          ],
