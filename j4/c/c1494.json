            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 110 MeV/nucleon 48Ca primary beam was fragmented",
                " on a 376 mg/cm2 9Be primary target at the",
                " midacceptance target position of the A1900 fragment",
                " separator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A secondary beam of 46Ar fragments, with an energy of",
                " 76.4MeV/nucleon, an intensity of 8300 pps, and a",
                " purity of about 99%, was incident on 191 mg/cm2",
                " polypropylene [(C3H6)n] and 211 mg/cm2 graphite",
                " secondary targets at the target position of the S800",
                " magnetic spectrograph, which was used to identify and",
                " determine the scattering angles of beam particles",
                " on an event-by-event basis."
              ]
            }
          ],
          "DETECTOR": [
