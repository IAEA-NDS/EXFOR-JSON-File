          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " Chemical separations were carried out",
                "on all of the targets. The gamma radiations of the",
                "four isotopes of interest were determined with a",
                "calibrated Ge(Li) detector at a low geometry so that",
                "the loss of counting rate in the photopeak due to",
                "summing with coincident radiation was negligible. The",
                "decay of each nuclide was followed for a minimum of",
                "two half-lives."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The decay curves were analyzed by a",
                "least squares computer program in order to obtain the",
                "activities and their standard deviations at end-of-",
                "bombardment time."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error estimates given for the mean",
                "values were obtained by root-mean-square addition of",
                "these individual errors and of the standard deviation",
                "of the mean."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Counting efficiencies."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": 0.7,
                "maximum_value": 1.5,
                "correlation_property": null
              },
              "free_text": [
                " Recoil losses."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Secondary production of 24Na."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Since relatively thin target foils were used in these",
                "experiments (65 to 97 mg/cm2), it was necessary to",
                "correct all measured cross sections for recoil losses."
              ]
            }
          ],
