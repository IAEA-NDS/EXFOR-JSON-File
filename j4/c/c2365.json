            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross Sections for the Production of 84Rb, 86Rb,",
                "132Cs, and 136Cs from Thorium and Uranium by 28.5-GeV",
                "Protons"
              ]
            }
