          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In a recent measurement of 17F(p,p)17F elastic",
                "scattering, acceptable fits were found for both 1-",
                "and 3- spin assignments for the 6.15-MeV level. The",
                "required width, however, for a 3- assignment (~15",
                "keV) was considerably smaller than the observed width",
                "of the resonance in the current inelastic scattering",
                "analysis (Gamma = 54+-2 keV), providing further",
                "evidence that the 6.15-MeV level has Jpi = 1-."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
