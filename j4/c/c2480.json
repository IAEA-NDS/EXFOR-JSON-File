          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The average initial (i.e. before neutron evaporation)",
                "total kinetic energy release in the c.m. system is",
                "found to be 173.3+-5.4 MeV from the gross correlation",
                "events and 170.9 MeV and 173.5 MeV respectively for",
                "the 80 and 82 degrees out-of- plane correlation",
                "measurements."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The absolute errors for the total kinetic",
                "energy release range from +-4.0 MeV for the most",
                "probable angles to about +-6.0 MeV for angles on the",
                "wings of the angular correlation; however, the",
                "relative error between these points is considerably",
                "better than this. It is assumed that on the average",
                "3.5 neutrons per fragment are evaporated from the",
                "fragments for each fission."
              ]
            }
          ],
