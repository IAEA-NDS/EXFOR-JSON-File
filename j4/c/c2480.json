          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The in-plane angular correlations are not symmetric.",
                "Reflection of the low-angle portion of the angular",
                "correlation selects the events which fall under this",
                "symmetrized curve that are assigned to compound",
                "nucleus formation reactions. The remaining events are",
                "attributed to non-compound-nucleus (NCN) fission",
                "events."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors quoted here reflect",
                "experimental errors due to counting statistics and",
                "angular resolution as well as uncertainties",
                "originating in the method of integrating the angular",
                "correlation functions."
              ]
            }
          ],
