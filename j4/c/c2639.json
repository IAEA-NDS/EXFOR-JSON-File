          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation counters. Counter No. 1 in these",
                "experiments was a liquid scintillator with an overall",
                "thickness of 1/4 in., and counter No. 2 was a",
                "plastic scintillator 1/8 in. thick."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " A beam of pions of the desired energy passes",
                "through two scintillation counters and after that",
                "traverses a thin-walled liquid hydrogen Dewar. The",
                "scattered particles are detected by two other",
                "counters No. 3 and No. 4. The double coincidences of",
                "No. 1 and No. 2 give a measure of the number of",
                "primary particles. The, quadruple coincidences of the",
                "four counters give a measure of the number of",
                "scattered particles that are detected by the",
                "detecting counters No. 3 and No.4."
              ]
            }
          ],
