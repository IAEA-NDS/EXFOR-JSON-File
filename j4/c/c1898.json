          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1-11.5 GeV protons in the circulating beam of the",
                "Zero Gradient Synchrotron at Argonne. 0.8-GeV protons",
                "at the area B nuclear chemistry irradiation facility",
                "at Los Alamos."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target stacks consisted of 20 microm thick depleted",
                "uranium foil sandwiched between five 20 microm thick",
                "aluminum foils of high purity (99.999%)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "RCHEM",
                "GSPEC",
                "STTA",
                "ACTIV"
              ],
              "free_text": [
                " Following the irradiation",
                "the target and catcher foils were separately",
                "dissolved in acid and a radiochemically separated.",
                "The disintegration rates of the various nuclides of",
                "interest were determined by gamma-ray spectrometry.",
                "The product cross section were derived from the data",
                "using the relationship between nuclides."
              ]
            }
          ],
