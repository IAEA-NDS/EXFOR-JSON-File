            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Vector and tensor polarized deuteron beams at",
                "Ed = 80 keV, and deuterons from the ABPIS were",
                "accelerated to 130 keVand 160 keVby biasing the target",
                "chamber"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was made in situ in the vacuum chamber.",
                " Enriched 99% 7Li was evaporated directly onto the",
                " 3-mm thick aluminum target chamber face and was",
                " replenished every 8 h."
              ]
            }
          ],
          "DETECTOR": [
