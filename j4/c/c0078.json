          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of protons from 40Ca at 21.0, 23.5,",
                " 26.3, and 48.0 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1CANMNA"
              },
              "free_text": [
                " Momentum-analyzed beam facility of",
                " sector-focused cyclotron."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "20-CA-40",
                "field_identifier": "ENR",
                "value": 0.9997
              },
              "free_text": [
                " Two calcium metal targets with",
                " areal densities of 4.95+-0.05  and 5.09+-0.05 mg/cm2",
                " thick enriched to 99.97% 40Ca. Oxygen contamination",
                " of targets 0.24 and 0.087 mg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Incident beam monitored using Faraday cup.",
                "Cross-over technique used for energy and angle",
                " calibration."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " Two Si(Li) detectors at 3 lower energies."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SILI",
                "SIBAR"
              ],
              "free_text": [
                " At 48 MeV, detector telescope",
                " consisting of a surface-barrier detector and 3 stacked",
                " Si(Li) detectors."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NaI(Tl) detectors placed either side of scatter",
                " chamber to monitor beam and allow adjustments to",
                " ensure particles passed through chamber."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "At angles smaller than 30 degrees, where 40Ca and 16O",
                " elastic scattering peaks merge, Gaussian peak",
                " stripping routine, or, when 2 peaks became",
                " indistinguishable, subtraction of calculated 16O",
                " yield, used to determine 40Ca yield."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No information."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for:",
                ". background,",
                ". dead time",
                ". finite geometry,",
                ". scattering in silicon detectors.",
                ". scattering by contaminants (mainly oxygen),         C",
                ". nominal scattering angle."
              ]
            }
          ],
          "ERR-ANALYS": [
