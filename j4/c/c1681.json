              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The astrophysical S factor and the reaction rate for",
                "the radiative proton capture  12N(p,g)13-O was",
                "obtained from the study of the 14N(12N,13-O)13C",
                "peripheral transfer reaction using the asymptotic",
                "normalization coefficient method."
              ]
            }
          ],
