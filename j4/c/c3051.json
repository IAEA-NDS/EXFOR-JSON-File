          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross sections for the formation of 51Cr",
                "and 52,54Mn in interactions of deuterons with iron"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.M.Hasan",
                "M.S.Uddin",
                "A.K.Chakroborty",
                "M.S.Basunia"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
