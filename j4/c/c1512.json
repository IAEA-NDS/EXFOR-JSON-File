              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative beam energies in the targets were monitored",
                " with two Si p-i-n diode (monitor detectors) mounted at",
                " +/- 27 degree from the beam axis, that detected",
                " Rutherford scattered projectiles"
              ]
            }
          ],
