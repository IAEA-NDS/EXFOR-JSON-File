          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The alpha particles from short-lived",
                "activities (T1/2 < 24 min) were detected between the",
                "beam pulses by a back-angle annular silicon surface",
                "barrier detector. Alpha decays from long-lived",
                "activities were measured using a silicon surface",
                "barrier detector placed below the annular counter,",
                "close to the plane of the target ladder. Two Si",
                "surface barrier detectors, symmetrically placed",
                "about the beam axis at 22.5deg, were used to measure",
                "elastically scattered beam particles for monitoring",
                "purposes."
              ]
            }
