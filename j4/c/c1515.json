          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The gases chosen for these experiments were CO, CO2",
                " and CH3OH, i.e. all contain both carbon and oxygen",
                " atoms. The freezing points at atmospheric pressure",
                " are 74, 195 and 179 K, respectively. The cooling",
                " stage temperature was held at - 56 K, adequate to",
                " maintain the gas layers in the condensed phase."
              ]
            }
          ],
