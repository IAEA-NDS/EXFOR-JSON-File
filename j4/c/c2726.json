          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin windowless solid deuterium D2 reaction target",
                "built on a 4.5 mu-mthick Ag foil backing.The target",
                "cell with the foil was cooled to 4 K before forming",
                "solid D2. AG foil backing was facing upstream of the",
                "D2 layer. The average target thickness was 65 mu-m"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "CSICR"
              ],
              "free_text": [
                " Scattered light recoils p,d,t,He",
                "from reactions were detected using annular array of",
                "100 mu-m thick single-sided silicon strip detectors",
                "followed by a layer of 12 mm thick CsI(Tl) detectors.",
                "The detector telescope covered scattering angles of",
                "30.1 deg to 56.2 deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Scattered beam particles were detected using a",
                "doublesided silicon strip detector placed 33 cm",
                "downstream of the target, covering laboratory angles",
                "of 1.9 deg to 6.1 deg."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Inverse kinematics was used"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The radioactive beam of 20Mg was produced via",
                "fragmentation of a SiC target with 480 MeV",
                "protons.The beam 20Mg was reaccelerated using the",
                "ISAC-II superconducting LINAC to 8.5 MeV/A and then",
                "passed through an ionization chamber, filled with",
                "isobutane gas at 19.5 Torr at room temperature which",
                "provided an event-by-event identification of the 20Mg",
                "incident beam and its contaminant 20Na"
              ]
            }
          ],
