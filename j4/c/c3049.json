          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy, strength, and alpha width measurements of",
                "Ec.m. = 1323 and 1487 keV resonances in",
                "15N(alpha,gamma)19F"
              ]
            }
          ],
          "AUTHOR": [
