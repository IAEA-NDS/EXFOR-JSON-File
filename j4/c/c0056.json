          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements were taken for six separate 5-minute",
                " intervals after the bombardment.  From these six",
                " measurements, three values of the cross section were",
                " calculated for each bombardment.",
                "Seventeen measurements were made using different beam",
                " intensities and target thicknesses.  All measurements",
                " were consistent to within the statistical uncertainty",
                " of 1%.",
                "Activity produced by neutrons from the synchrocyclotron",
                " and collimators was not detectable at the level of",
                " 0.01% of the proton-induced activity."
              ]
            }
          ],
