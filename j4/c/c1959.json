          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct measurement of the 16O(a,g)20Ne reaction at",
                "Ec.m. = 2.43 MeV and 1.69 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "U.Hager",
                "L.Buchmann",
                "B.Davids",
                "J.Fallis",
                "U.Greife",
                "D.A.Hutcheon",
                "D.Irvine",
                "D.Ottewell",
                "A.Rojas",
                "S.Reeve",
                "C.Ruiz"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USACSM",
                "1CANTMF",
                "1CANMCM"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,86,055802,2012",
                "code_unit": [
                  {
                    "unit": "J,PR/C,86,055802,2012",
                    "doi": "10.1103/PhysRevC.86.055802",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "86",
                        "part": null,
                        "issue": null,
                        "page": "055802"
                      },
                      "date": 2012
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1CANTMF"
              },
              "free_text": [
                " Measurements were conducted at the",
                "ISAC facility at TRIUMF, using DRAGON recoil separator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Windowless gas target was filled with 4He maintained",
                "at a central pressure of 7.7 Torr, the effective",
                "target length was 12.3+-5 cm"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " 20Ne ions produced in the reaction were",
                "detected after separation from the beam using a",
                "two-stage electromagnetic separator with an angular",
                "acceptance of 21 mrad for reactions at the center of",
                "the target. The separator was tuned in such a way, that",
                "only the 4+ charge state was transmitted"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " An ionization chamber placed in the focal",
                "plane of the electromagnetic separator was used to",
                "detect 20Ne recoils from the reaction."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " Two microchannel plates upstream of the",
                "ionization chamber were used to measure the",
                "time-of-flight across the 59 cm distance between",
                "them. The transmission through the microchannel",
                "plates setup was 85+-5%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " An array of 30 bismuth germanate gamma-ray",
                "detectors in a tight geometry was used to detect",
                "capture gamma rays"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between recoiling 20Ne ions and",
                "gamma rays was used to reduce background"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight was used to identify the",
                "recoiling nuclei.",
                "Inverse kinematics was used."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Supernanogan off-line ion source was used to",
                "produce 16O beam."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for transmission of 4+ charge state was",
                "made. Distribution of charge states of neon after",
                "passing through helium was measured for this purpose.",
                "20Ne beam was also produced in Supernanogun"
              ]
            }
          ],
          "HISTORY": [
