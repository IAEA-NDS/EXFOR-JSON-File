          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR",
                "SI",
                "SILI"
              ],
              "free_text": [
                " Linear stack consisting of 100, 200,",
                " and 74 microm silicon surface barrier detectors",
                " (SiSB), three 100 microm SiSB detectors, a 200 microm",
                " boron implanted position sensitive silicon detector,",
                " and a 1000 microm lithium drifted silicon Si(Li)",
                " detector.",
                "A calibrated hyperpure germanium HPGe gamma-ray",
                " detector, placed outside the scattering chamber 15 cm",
                " from the center of the silicon detector stack, used",
                " as the primary detector for 18F(162 nsec) gamma rays",
                " and for fine tuning of solenoid current."
              ]
            }
          ],
