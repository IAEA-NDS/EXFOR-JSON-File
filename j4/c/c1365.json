          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Oxygen analysis using energetic ion beams"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USABNW"
              },
              "free_text": [
                " a 3.0 MV electrostatic tandem",
                " accelerator located within the Environmental",
                " Molecular Sciences Laboratory at Pacific Northwest",
                " National Laboratory.",
                " The accelerator generating voltmeter (GVM) was",
                " carefully calibrated using the 7Li(p,n)7Be reaction,",
                " which has a threshold for neutron production of",
                " 1880.6 +/- 0.07keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " There were both fixed and movable surface",
                " barrier detectors in the chamber with an energy",
                " resolution of +/-15 keV for MeV protons and",
                " +/-20 keV for MeV He+ ions. The fixed detector was",
                " located at a scattering angle of 150 degree, while",
                " the movable detector could be positioned at any",
                " angle with a precision of 0.01."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A thin amorphous layer of SiO2 on a <111> oriented Si",
                " wafer was used."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Small dead time of 0-3% during the data acquisition"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Experimental error",
                "Apart from the data calibration, the uncertainty of",
                "the absolute values from this experiment arises",
                "primarily from:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 2.0,
                "maximum_value": 3.0,
                "correlation_property": null
              },
              "free_text": [
                " the counting statistical error (2-3%),"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " the layer thickness (2%) and"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": 1.0,
                "maximum_value": 2.0,
                "correlation_property": null
              },
              "free_text": [
                " its variation (1-2%) after the linear",
                "                   thickness correction.",
                "Other factors, including:",
                "  * charge integration,",
                "  * dead time during data acquisition, and",
                "  * ion energy fluctuation (+-1 keV), can also",
                "                       contribute to the error."
              ]
            }
          ],
