          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton-induced cross sections relevant to production",
                "of 225Ac and 223Ra in natural thorium targets below",
                "200 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.W.Weidner",
