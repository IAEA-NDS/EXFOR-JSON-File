                "1USALAS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ARI,70,2602,2012",
                "code_unit": [
                  {
                    "unit": "J,ARI,70,2602,2012",
                    "doi": "10.1016/j.apradiso.2012.07.006",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "ARI",
                        "number": null,
                        "volume": "70",
