          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of heavy water which was",
                " evaporated onto a liquid nitrogen cooled Cu disk",
                " inside of the target chamber. The thickness of this",
                " ice layer was measured to be more than an order of",
                " magnitude greater than that required to completely",
                " stop the beam."
              ]
            }
          ],
