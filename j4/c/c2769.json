              },
              "free_text": [
                " A 1-MV model JN Van de Graaff",
                "accelerator was used for measurements above 300 keV",
                "incident energy."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "1USATNL"
              },
              "free_text": [
                " Measurements bellow 250 keV incident",
                "energy were carried out with the Electron Cyclotron",
                "Resonance Ion Source (ECRIS) accelerator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Implanted target was used. The 29Si- beam was",
                "produced from natural silicon metalloid and implanted",
                "at 80 keV bombarding energy into a 0.5 mm thick",
                "tantalum sheet. The implantation dose was 200",
                "mC/cm2. The target thickness was (11.4+-0.3) keV. The",
                "stoichiometry of the target layer was",
                "Ta/29Si = (1.2+-0.2)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma rays emitted from the target were",
                "analyzed with a 135% relative efficiency coaxial",
                "high-purity germanium detector. Detector was",
                "surrounded by a 16-segment NaI(Tl) annulus. The",
                "detectors were surrounded on six sides by 1.3 cm",
                "thick lead panels and by five 5 cm thick plastic",
                "scintillator paddles used to veto spurious events",
                "induced by cosmic-ray muons. The HPGe detector itself",
                "was placed at a 1.1 cm distance from the target",
                "at 0 deg relative to the beam direction."
              ]
            }
          ],
