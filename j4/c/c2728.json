          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear structure beyond the neutron drip line: The",
                "lowest energy states in 9He via their T =5/2 isobaric",
                "analogs in 9Li"
              ]
            }
          ],
