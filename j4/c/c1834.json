          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1.16 cm thick Be target"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "NAICR"
              ],
              "free_text": [
                " Protons recoiling from the CH2 were",
                "detected at 15deg from the beam by an E-dE telescope",
                "consisting of a 320 micron silicon DE detector and a",
                "1.6 cm thick Nal scintillator."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron spectrum was measured by proton recoil",
                "method. Neutrons at 0 deg interacted in CH2 target",
                "with thickness of 57.9 mg/cm2 C H 2and recoil protons",
                "were detected at 15 deg by a E-dE telescope."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The detected proton energy spectrum was corrected for",
                "carbon contribution, energy loss in the target and dE",
                "detector and kinematic shift"
              ]
            }
          ],
