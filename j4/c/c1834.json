          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected proton spectrum was divided by the n+p",
                "differential cross section at each energy to obtain",
                "the beam neutron spectrum. n+p cross sections were",
                "obtained from the parameterization of Hopkins and",
                "Breit for the energy range 0-25 MeV, and from",
                "Binstock for energies above 25 MeV."
              ]
            }
