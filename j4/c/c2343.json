          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "13 niobium metal foils, each 21.8 mg/cm2, were stacked."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " For the excitation-function",
                "measurement, niobium metal foils were stacked and",
                "subjected to 2 muAh of 41-MeV alpha particles. The",
                "activity in each foil was then investigated with",
                "Ge(Li) detectors. Niobium foils were dissolved in a",
                "mixture of concentrated nitric and hydrofluoric acids."
              ]
            }
          ],
