              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Telescope and coincidence. Data corrected from",
                " multiple scattering"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A counter telescope technique employing plastic",
                " scintillation counters was used. From the cross",
                " sections measured with poor geometry, the nonelastic",
                " cross section was deduced using an extrapolation to",
                " zero degree."
              ]
            }
          ],
