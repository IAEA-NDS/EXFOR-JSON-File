            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Contributions to relative uncertainty summed",
                " in quadrature, but assigning 3% as a minimum",
                " uncertainty.",
                "Relative uncertainty includes:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 1.0,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " Statistical uncertainty: generally",
                " 1-3%, but ~10% in the micro-b region"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 1.0,
                "maximum_value": 2.0,
                "correlation_property": null
              },
              "free_text": [
                " Errors due to charge integration",
                " efficiency (estimated 1-2%),"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": 0.5,
                "maximum_value": 3.0,
                "correlation_property": null
              },
              "free_text": [
                " Error due to variation of beam position",
                " on target (about 0.5-3%),"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-4",
                "minimum_value": null,
                "maximum_value": 1.0,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty in dead-time correction (<1%),"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-5",
                "minimum_value": null,
                "maximum_value": 8.0,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainty in scattering angle (about",
                " 0.04 degrees) corresponds to cross section errors from",
                " nearly zero to 8%, depending on the slope of the",
                " angular distribution"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-6",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total normaliztion uncertainty due mainly",
                " to target-thickness uncertainty.  Uncertainty from",
                " other sources estimated to be about 1%."
              ]
            }
