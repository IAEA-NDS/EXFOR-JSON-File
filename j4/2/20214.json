          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".GAMMA-RAYS CORRECTED FOR RECOIL LOSSES."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ERRORS IN THE ENERGIES ARE MAINLY DUE TO ERRORS",
                " MADE IN READING-OFF PEAK POSITIONS. THE ERRORS IN THE",
                " INTENSITIES ARE PARTLY DUE TO STATISTICS, PARTLY DUE",
                " TO UNCERTAINTIES IN THE EFFICIENCY CURVES FOR THE",
                " DETECTOR. THE EFFICIENCY CURVES ARE BELIEVED TO BE",
                " TRUE TO WITHIN 15 PERCENT."
              ]
            }
          ],
