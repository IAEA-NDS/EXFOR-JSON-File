          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- THERMAL-NEUTRON CAPTURE GAMMA RAYS FROM NATURAL",
                "  MAGNESIUM AND ENRICHED MG-25 -"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".HIGH FLUX REACTOR IN PETTEN"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "    TARGET PLACED IN A HORIZONTAL RADIAL BEAM",
                " OF THE REACTOR.",
                ".THE NEUTRON FILTER, CONSISTING OF QUARTZ",
                " AND BISMUTH SINGLE CRYSTALS, WAS COOLED TO",
                " 77 KELVIN BY LIQUID NITROGEN.",
                " NEUTRON FLUX = 1.E+7/CM**2/SEC."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".COMPOSITION 6 GRAMM NATURAL MAGNESIUM METAL AND",
                " 2.4 GRAMM MG-O (85 PERCENT ENRICHED IN MG-25)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "    1.6 CM**3 AND 5 CM**3 GE(LI)-DETECTORS FOR",
                " GAMMA-RAYS FROM ENRICHED AND NATURAL SAMPLE",
                " USED RESPECTIVELY."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE INTENSITIES IN THE THREE MG-ISOTOPES",
                " ARE NORMALIZED SUCH THAT THE SUM OF THE",
                " INTENSITIES OF PRIMARY GAMMA-RAYS IS 100.",
                " THE SAME HAS BEEN DONE FOR THE DECAY OF",
                " THE VARIOUS LEVELS.",
                ".THE EFFICIENCY CURVES FOR FULL-ENERGY,",
                " SINGLE-ESCAPE AND PAIR PEAKS WERE OBTAINED",
                " WITH SOURCES OF KNOWN INTENSITIES AND WITH",
                " GAMMA-RAYS FROM CL-35(N,GAMMA) AND",
                " S-32(N,GAMMA) REACTIONS, DETAILS IN",
                " NUCL.PHYS.,A102(1967)209.",
                ".ENERGIES OF GAMMA-RAYS USED FOR CALIBRATION",
                " GIVEN IN TABLE 4 OF NUCL.PHYS.,A102(1967)209",
                " ASSUMING MG(N,GAMMA) = 64 +- 3 MILLIBARN",
                " AND USING THE GAMMA INTENSITIES MEASURED",
                " THE (N,GAMMA)-CROSS-SECTIONS FOR MG-25,",
                " MG-26, AND MG-27 WAS DERIVED."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                "    GAMMAS"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".LEVEL SCHEMES CONSTRUCTED, DETAILS IN PUBLICATION.",
                ".Q-VALUES FOR (N,GAMMA)-REACTIONS FOR THE TARGET",
                " ISOTOPES MG-24, MG-25, MG-26 DETERMINED AS",
                " Q = 7332.8 +- 0.4 KEV, Q = 11096.0 +- 0.5 KEV,",
                " Q = 6446.3 +- 0.9 KEV RESPECTIVELY."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DATA FROM NUCL.PHYS.,A102(1967)209."
              ]
            }
          ],
