          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section for all processes leading to the",
                "destruction of Be-7 was measured to be",
                "SIG=(4.8+-0.9)*10**b by using the ratio of activities",
                "of two Be-7 samples, one of which was irradiated for",
                "28 days ( integrated flux F=(1.36+-0.10)*10**18).",
                "Spectra were studded by NaI scintillator and organic",
                "crystal detector.",
                "Ratio of activities of two samples:",
                "before irradiation Y=1.112+-0.009 ;",
                "after irradiation of stronger sample - Y1=1.043+-0.005.",
                "Used formula: Y1=Y*exp(-SIG*F) ."
              ]
            }
          ],
