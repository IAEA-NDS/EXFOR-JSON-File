          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Be-7 was prepared by bombardment of a block of pile",
                "graphite with the 175 MeV internal proton beam of the",
                "Harwell cyclotron.After chemical separation the Be-7",
                "was deposited on Pt sheet as a \"weightless\" source.",
                "The mass of Be-7 was determined from the counting rate",
                "due to 478 keV gamma-rays detected in an organic",
                "scintillation crystal relative to the rate due to",
                "411 keV gamma-rays from Au-198 source.",
                "Be-7 absolute activity (5.4+-0.1)*10**6 gammas/sec,",
                "corresponding mass (3.76+-0.40)*10**-9 g of Be-7.",
                "Sample was mounted on the source electrode of IOCH .",
                "PHDs were measured at different filling gas pressure."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Parallel plate gridded ionization chamber ."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                " Pulse-height spectra measured.",
                "Cd difference curves .",
                "Intensity of proton group was measured to be of the",
                "expected 53d half-life."
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": {
                "flag": null,
                "nuclide": "4-BE-7",
