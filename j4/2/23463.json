              "free_text": [
                " IGISOL-IV mass separator at the",
                "Cyclotron Laboratory of the University of Jyvaskyla.",
                "The isotope of interest produced by proton-induced",
                "Ep = 25 MeV fission of a U target inside the ion source",
                "and separated by means of a double Penning trap system."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 3 mm thick plastic scintillation detector",
                "placed 6 mm from the tape for counting of the",
                "beta-particles emitted by the implanted ion."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC",
                "HE3SP"
              ],
              "free_text": [
                " The neutron counter BELEN used in this",
                "measurement consists of forty eight 3He proportional",
                "tubes arranged in three concentric rings inside a large",
                "polyethylene block."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector for gamma-ray counting."
              ]
