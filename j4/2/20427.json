          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-The average number of prompt neutrons from neutron",
                " induced fission of U-235 between 0.2 and 1.4 MeV.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                "      3 MV pulsed Van-de-Graaff accelerator.",
                " Pulse width 1 nsec, average beam current 20 microA at",
                " repetition rate 5 MHz."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                "    Li-7(N,P). Collimated neutron beam."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The metallic Li-targets thickness was such, that",
                " neutron energy spread deltaEn was less 4%."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Two uranium acetate layers less than 0.5 millig/cm**2",
                " in fission chamber at 56 and 63 cm flight path",
                " and U-235 metal disk of 0.15 millimeter thick,",
                " 70 millimeter diameter at 74 cm flight path."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " -Gas scintillation fission counter, containing",
                " two thin samples of U-235, divided by samples into",
                " optically decoupled thirds each inspected by 56 DUVP",
                " photomultipliers.",
                "  -Fission neutron detector PM XP 1040, placed at",
                "  12.5 cm distance from sample.",
                " Both detectors and the samples were shielded against",
                " slow, roomscattered neutrons by Cd-sheets to reduce",
                " the time-independent background."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " Li-6-glass detector at 130 cm from target for",
                "neutron spectrum determination and as monitor for",
                "neutron yield.",
                "Calibration procedure was done by strong Am-Be neutron",
                "source located at 3m distance to measure efficiency."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight. Overall time resolution 2.5 nsec."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between two thirds to register",
                " a fission event."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " Pulse shape discrimination against gamma",
                " radiation."
              ]
            }
          ],
