          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-INDEPENDENT ISOMERIC YIELD RATIOS OF RB-90 AND",
                " AND CS-138 IN THE SPONTANEOUS FISSION OF CF-252.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NO FACILITY."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".20 MM DIAM CF-252 SOURCE, COVERED WITH A 2 MICRONS",
                " THICK NICKEL FOIL TO PREVENT SELF-TRANSFER OF CF-252",
                " AND TO REDUCE THE RANGE OF THE FISSION PRODUCTS."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " CHEMICAL SEPARATION. GAS RECOIL TRANSPORT",
                " SYSTEM (DESCRIBED BY MC FARLANE AND MC HARRIS, IN",
                " NUCLEAR REACTIONS AND SPECTROSCOPY, ACADEMIC PRESS,NY",
                " FROM THE RADIOACTIVE DECAY OF THE FISSION PRODUCTS,",
                " ISOMERIC YIELD RATIOS CAN BE DETERMINED FROM THE",
                " DECAY SCHEME."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 50 CC GE(LI) DETECTOR, 2.0 KEV RESOLUTION AT",
                " 1332 KEV, 8.6 PERCENT RELATIVE EFFICIENCY."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
