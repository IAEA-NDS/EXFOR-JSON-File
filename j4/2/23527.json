          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Slow neutrons . Energy < 0.045 eV .",
                " Neutron beam was monitored by counting neutrons",
                "scatterired from lead block at the entrance to the",
                "final collimator tube."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " U-235 metal disc of 3.1 inch diameter, 0.2 inch",
                "thickness, on a Al frame.",
                "U-235 - 92.7%, U-238 - 7.24 %, Al - 0.017%,",
                "Ni - 0.05%, Si - 0.0085%, Fe - 0.032 %, Cr - 0.003 %,",
                "W - 0.01 %, Mo-0.0225%, B - 0.0005% . U-234 (~1.%)",
                "included in U-238 content."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillating plastic detectors, 4.5 cm long,",
                "4.5 cm diameter, viewed by EMI type 6099D",
                "photopultiplier. Datectors were placed on either side",
                "of the sample."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " For transmission measurement. Detection",
                "efficiency proportional to SQRT(E) within 1 % down",
                "to 1.2 eV. 4% deviation at 0.1 eV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " For scattering measurement.",
                "Annual ring of 10-BF(3) counters, sample in the center",
                "of ring. Efficiency is proportional to SQRT(E).",
                "Measuremet with and without B4C sleeve surrounding",
                "the sample."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "COINC"
              ],
              "free_text": [
                " Flight path 7.36 . Fission events as",
                "function of time-of-flight. Coincidences from pair",
                "detectors.Resolution 0.1 microsec.",
                "Fission detection efficiency in calibrated Pu-240",
                "SF source was measured to be ~1%.",
                "Tested by U and Cd samples."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Thransmission was measured by three 10-BF(3)",
                "counters replaced the sample.",
                ".Lead sample was used to count scattered neutrons.",
                "Resolution 0.22microsec/m at scattering measurement,",
                " 0.29 microsec/m at transmission and fission",
                " measurements."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For overlap neutrons from previous pulse < 10.% .",
