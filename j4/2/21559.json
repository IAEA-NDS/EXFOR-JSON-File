          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-RANGE MEASUREMNTS OF PRIMARY FISSION PRODUCTS FORMED",
                " BY SPONTANEOUS FISSION OF CF-252 -."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".SPONTANEOUS CF-252 FISSION SOURCE."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A THIN CF-252 SOURCE OF ABOUT 1 MICRO-GM CF-252",
                " WAS DEPOSITED ON A 20 MM DIAMETER PLATINUM FOIL,",
                " WITH AN ACTIVE AREA OF ABOUT 5MM DIAMETER."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR THE MASS CHAIN 144 THE FRACTIONAL INDEPENDANT",
                " YILEDS WERE DERIVED BY AN ITERATIVE METHOD. AN",
                " EXTRAPOLATION METHOD WAS USED ASSUMING A GAUSSIAN",
                " DISTRIBUTION TO EVALUATE THE INDEPENDANT YIELD OF",
                " CS-144, WHICH COULD NOT BE MEASURED DIRECTLY.",
                " THE ABUNDANCE OF THE 397 KEV GAMMA OF LA-144 WAS",
                " DETERMINED TO BE 0.82+-0.05."
              ]
            }
          ],
          "DETECTOR": [
            {
