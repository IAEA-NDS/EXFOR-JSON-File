          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".BELOW 400 EV NEUTRON ENERGY DATA ARE CORRECTED BY",
                " ASSUMING AN EQUAL CONTRIBUTION OF UNASSIGNED RESONAN-",
                " CES TO EACH SPIN.",
                ".BETWEEN 400 AND 1000 EV NEUTRON ENERGY THE VALUES",
                " WERE CORRECTED FOR SELF-SHIELDING."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".BELOW 400 EV NEUTRON ENERGY THE QUOTED ERRORS WERE",
                " CALCULATED TAKING INTO ACCOUNT THE EXPERIMENTAL ERROR",
                " IN DETERMINING THE NEUTRON WIDTH AS GIVEN BY TELLIER,",
                " CEA-N-1338, AND THE STATISTICAL ERROR IN THE STRENGTH",
                " PARTITION OF THE UNASSIGNED RESONANCES.",
                ".ABOVE 400 EV NEUTRON ENERGY IT WAS ESTIMATED THAT THE",
                " SYSTEMATIC ERROR SHOULD NOT BE LARGER THAN 7 PERCENT,",
                " WHICH OUTWEIGHTS ANY ERROR DERIVING FROM THE MEASURE-",
                " MENTS OF CAPTURE RATES AND NEUTRON FLUX."
              ]
            }
          ],
