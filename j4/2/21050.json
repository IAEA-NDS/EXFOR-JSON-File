          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".BELOW 400 EV NEUTRON ENERGY A DIRECT EVALUATION OF",
                " THE NEUTRON STRENGTH FUNCTION FROM THE NEUTRON WIDTHS",
                " OF TELLIER,CEA-N-1338, AND OWN SPIN ASSIGNMENTS WAS",
                " MADE.",
                ".ABOVE 400 EV NEUTRON ENERGY WHERE THE RESONANCES ARE",
                " COMPLETELY UNRESOLVED, THE AVERAGE-RESONANCE METHOD,",
                " BASED ON THE DETECTION OF CAPTURE GAMMA-RAYS, WAS",
                " APPLIED."
              ]
            }
          ],
