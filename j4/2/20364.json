          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".U or Pu acetate electrosprayed onto 90 micro-g/cm2",
                " VYNS foils (85 pc. Pvc, 15 pc. Polyvinyl acetate),",
                " metallized with 30 micro-g/cm2 Al. Sample diam. 5 cm.",
                ".    U sample masses             Pu sample masses",
                "  2.315 milli-g +- 1.0 pc.    0.438 milli-g +- 1.8 pc.",
                " *2.073 milli-g +- 1.0 pc.   *0.471 milli-g +- 1.8 pc.",
                " *2.002 milli-g +- 1.0 pc.    0.468 milli-g +- 1.8 pc.",
                "                              0.513 milli-g +- 1.8 pc.",
                " * Samples for quantitative measurements (the others",
                "   served only to get data for corrections).",
                ".Isotopic composition",
                "     U samples                   Pu samples",
                "  U-234     0.169  at.-Pc.    Pu-239     1.83   at.-Pc.",
                "  U-235 99.499+-0.05at.-Pc.   Pu-240     7.25   at.-Pc.",
                "  U-236     0.027  at.-Pc.    Pu-241 89.50+-0.08at.-Pc.",
                "  U-238     0.353  at.-Pc.    Pu-242     1.42   at.-Pc.",
                "                              Am-241  6.94+-1.4 at.-Pc.",
                ".Final mass values used. Communication from author."
              ]
            }
          ],
