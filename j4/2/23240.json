          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " N-17 activity was produced in the Li-6(n,a)H-3 and",
                "O-18(t,a)N-17 reactions at Mainz TRIGA reactor using",
                "enriched (Li-6)2(C)(O-18)3 (Li-6 >95%, O-18 83.4%).",
                "Irradiation was performed in a fast pneumatic tube",
                "system using samples of 75 mg .",
                "Counting was started 0.3 sec after irradiation.",
                "Background - 7 counts/min.",
                "Neutron decay curves were recorded with 100 channel",
                "analyzer.",
                "Energy shifts were determined to lie within the",
                "standard deviations of electronic system of +-0.2 keV",
                "over the energy range 0-2 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                " 85 measurements were done to improve counting",
                "statistics. Exp.PHD on Fig.2A of NP/A,274,45,1976."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " High-resolution He-3 spectrometer - eight He-3",
                "proportional counters in circular block of paraffin-",
                "to measure N-17 neutron decay curve.",
                "Dead time 10 microsec."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Two identical He-3 ionization chambers with",
                "He-3+Ar at 10 atm; resolution 12 keV for thermal,",
                "22 keV for 1.0 MeV neutrons - to measure delayed",
                "neutron spectrum.",
                " Detectors resolutions,response functions, efficiencies",
                "were measured with monoenergetic neutrons generated by",
                "Li-7(p,n)Be-7 for neutron energy range 0.019-2.7 MeV.",
                "Absolute calibration accuracy about 0.1% for incident",
                "neutron energy, about 3.5 % for relative efficiency."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For detector efficiency and thermal neutrons."
              ]
            }
          ],
