          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrected for multiple scattering,self shielding,",
                " time spread,time-dependant and constant background,",
                " fission events in the Pu samples,and neutron beam",
                " intensity.",
                ".The assumption that the shape of the capture gamma-",
                " ray spectra of the heavy nuclei from Au-197 to",
                " Am-241 do not differ too much has been shown to",
                " be wrong and the authors have therefor sent new",
                " correction factors as private communication. Data",
                " have been recalculated using these factors."
              ]
            }
          ],
