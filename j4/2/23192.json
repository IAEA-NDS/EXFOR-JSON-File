                ],
                "reaction": null
              },
              "free_text": [
                "  Quasi-monoenergetic neutrons. 300 MeV protons."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron spectra measured by TOF at 0 and 30 degrees",
                "respective to the proton beam are on Fig.2 of",
                "J,KPS,59,(2),1916,2011.",
                "The quasi-monoenergetic neutron spectrum obtained by",
                "subtracting the spectrum on 30deg from the one on 0deg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "1",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Neutron energy spectra were measured by an NE213",
                "liquid scintillator placed at 17.10 or 16.13 m from",
                "Li-target at 0 or 30 degrees, respectively."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector for gamma rays measurement."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "1",
              "coded_information": [
                "N"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples were placed at 8.05 or 7.05 m from Li-target at",
                "0 or 30 degrees, were irradiated 26 hr or 18 hr,",
                "respectively."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation."
              ]
            },
            {
              "pointer": "1",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " For neutron beam."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Gamma-ray spectrometry of irradiated samples."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation reaction rates R were estimated by the peak",
                "counts of gamma-ray spectra, the peak efficiency of",
                "HPGe detector (calculated by EGS4 code), the self-",
                "absorption of gamma-rays in samples, the beam current",
                "fluctuation during irradiation.",
                "Cross-sections were estimates as:",
                "SIG=(R(0deg)- f*R(30deg))/F, where",
                "f- is factor for the correction in subtraction of",
                "   neutron spectrum,",
                "R - reaction rate at given angle,",
                "F- neutron fluence rate per beam current."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For contribution of the low energy tail in the neutron",
                "spectrum by subtracting the activities produced in the",
                "samples placed on 30deg from those on 0deg.",
                "For self-absorption in sample by EGS4 code.",
                "For the beam current fluctuation during the irradiation"
              ]
            }
          ],
