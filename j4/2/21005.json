          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Metallic discs of 8.6cm diam., containing 163g of",
                " natural Ce with a purity of 99.9% and 128g of",
                " natural Tl with a purity of 99.999% resp..",
                ".The thickness was -",
                " 1.207*10-2 nuclei/b for Ce,",
                " 0.650*10-2 nuclei/b for Tl."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
