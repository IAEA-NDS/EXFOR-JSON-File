          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".HELIUM ACCUMULATION METHOD. THE IRRADIATED SAMPLES",
                " WERE EVAPORATED IN AN ELECTRIC FURNACE TO RELEASE",
                " HE ATOMS ACCUMULATED IN IT DURING NEUTRON BOMBARDMENT.",
                " THE GAS RELEASED WAS ANALYSED WITH A QUADRUPOLE MASS",
                " SPECTROMETER."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".QUADRUPOLE MASS SPECTROMETER. THE APPARATUS WAS CALI-",
                " BRATED BY USING HE-ION IMPLANTED AL DISKS WHICH WERE",
                " PREPARED WITH A SMALL ACCELERATOR."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "13-AL-27(N,A)11-NA-24,,SIG",
