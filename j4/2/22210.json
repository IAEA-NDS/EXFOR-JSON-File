          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENTS OF PRODUCTION CROSS SECTIONS OF 14-C AND",
                " 26-AL WITH HIGH-ENERGY NEUTRONS UP TO EN=38 MEV BY",
                " ACCELERATOR MASS SPECTROMETRY."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.IMAMURA",
                "H.NAGAI",
