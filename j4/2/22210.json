              ],
              "free_text": [
                " M.IMAMURA, H.NAGAI, M.TAKABATAKE, S.SHIBATA,",
                " K.KOBAYASHI, K.YOSHIDA, H.OHASHI, Y.UWAMINO. EXPERI-",
                " MENTAL SITE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "2JPNTOH"
              ],
              "free_text": [
                " T.NAKAMURA."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2JPNTOK"
              },
              "free_text": [
                " THE AVF CYCLOTRON OF THE INSTITUTE FOR",
                " NUCLEAR STUDY WAS USED FOR THE NEUTRON IRRADIATION."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "2JPNTOK"
              },
              "free_text": [
                " THE 4 MV TANDEM VAN DE GRAAFF OF THE",
                " RESEARCH CENTER FOR NUCLEAR SCIENCE AND TECHNOLOGY WAS",
                " USED FOR ACCELERATOR MASS SPECTROMETRY."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-BE"
                ],
                "reaction": null
              },
              "free_text": [
                " NEUTRONS WERE PRODUCED BY BOMBARDING A 1 MM",
                " THICK BERYLLIUM TARGET WITH SEVERAL MICROAMP PROTON",
                " BEAMS OF ENERGIES 22.5, 27.5, 30, 32.5 AND 37.5 MEV.",
                " AT 40 MEV THE BE TARGET THICKNESS WAS 2 MM. THE TARGET",
                " WAS BACKED BY A 10 - 11 MM THICK WATER COOLANT, WHICH",
                " FULLY STOPPED THE PROTONS."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " NEUTRONS WERE ALSO PRODUCED WITH 30 AND 35 MEV",
                " PROTONS ON A 2.1 MM THICK LITIUM TARGET ON A STOPPING",
                " GRAPHITE BACKING."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE SEMI-MONOENERGETIC NEUTRON SPECTRA AT 0 DEGREES",
                " WERE MEASURED WITH A NE213 SCINTILLATOR PLACED 1.3 M",
                " FROM THE TARGET."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " TARGET STACKS, INCLUDING AL AND AU MONITOR",
                " FOILS, WERE USED."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " THE 14-C/12-C AND 26-AL/27-AL RATIOS WERE DE-",
                " TERMINED BY ACCELERATOR MASS SEPARATION TECHNIQUES."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A 51 MM DIAMETER BY 51 MM LONG NE213 LIQUID",
                " SCINTILLATOR WITH N-GAMMA DISCRIMINATION WAS USED TO",
                " DETERMINE THE INCOMING NEUTRON SPECTRA."
              ]
            }
          ],
