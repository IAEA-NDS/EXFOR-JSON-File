              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "    Fission neutrons from an uranium slug in the",
                " thermal column of the JEEP reactor.",
                " Thermal neutrons stopped completely by cadmium shield."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The spectrum of the neutrons in the beam",
                " did not correspond accurately to a fission neutron",
                " spectrum because of the influence of epithermal",
                " neutrons generated by slowing down in the collimating",
                " system. This deviation was corrected by measuring the",
                " counting ratio between a Li- and a B-F(3) counter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Counting rate ratio between a"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                "    Fission proportional counter and a"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                "    boron trifluoride counter for B-10(n,alpha)."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For deviation from a true fission neutron spectrum."
              ]
            }
          ],
          "ERR-ANALYS": [
