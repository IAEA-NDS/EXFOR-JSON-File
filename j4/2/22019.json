          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-RECENT EXPERIMENTS ON CF-252 SPECTRUM-AVERAGED",
                " NEUTRON CROSS SECTIONS."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NONE."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "CF252"
                ],
                "reaction": null
              },
              "free_text": [
                " CF-252 SPONTANEOUS FISSION NEUTRON",
                " SOURCE, ENCAPSULATED IN A DOUBLE ZIRCALOY",
                " CYLINDER WITH OUTER DIMENSIONS OF 10 MM IN",
                " DIAMETER AND 10 MM IN HEIGHT. THE WALL",
                " THICKNESS OF THE CYLINDER WAS 1.5 MM.",
                " THE NEUTRON SOURCE STRENGTH WAS APPROXIMATELY",
                " 4.7E+09 N/SEC ON APRIL 1, 1982."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CF-252 NEUTRON SPECTRUM."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".HIGH PURITY METALLIC DISKS, 10 MM IN DIAMETER AND",
                " .125 - .5 MM THICK.",
                ".POWDERS (CU-O, I2-O5, HG-O) WERE PRESSED IN LUCITE",
                " CYLINDERS WITH INNER DIAMETER 10 MM AND LENGTH .8 MM.",
                " WALL THICKNESSES WERE .2 MM AT THE FRONT AND REAR",
                " PLANE AND 1. MM AT THE ENVELOPE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " THE IRRADIATIONS WERE PERFORMED  USING THE",
                " SANDWICH METHOD, I.E. EACH SAMPLE WAS PLACED",
                " BETWEEN TWO FOILS ACTING AS NEUTRON FLUX",
                " DENSITY MONITORS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
