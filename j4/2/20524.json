          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Li impurity in each target material was under 1 ppm",
                " level. A rough estimate showed that the contribution",
                " from this impurity to tritium formation was less than",
                " 1%."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Both random and systematic errors were",
                "taken into account. The possible major sources of",
                "error were the uncertainty in the quantitative",
                "isolation of tritium, the uncertainty in the relative",
                "efficiency of the (beta-)-detector and the uncertainty",
                "in the determination of neutron fluxes.",
                "Combining all the individual errors the overall error",
                "for each cross-section value was obtained."
              ]
            }
