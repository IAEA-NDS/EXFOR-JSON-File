                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "  Neutron flux was monitored.",
                ".Deuteron beam was also measured at the Be-converter",
                " using Faraday cup."
              ]
            }
          ],
