          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Formation cross sections of zirconium-90m and",
                " lead-207m with fast neutrons"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2JPNNAG"
              },
              "free_text": [
                " 2-MeV Van de Graaff of Nagoya University."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "  For 14.8 to 18.2 neutrons a d-t reaction",
                " induced in a tritium target by the deuteron beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "  For 4.1 to 5.2-MeV neutrons a copper disc",
                " coated with a thin layer of titanium served as",
                " target to yield neutrons by the d-d reaction."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Mixtures of pure (99.8%) metallic powders of natural",
                " lead and zirconium in different ratios were used.",
                " For such mixtures were prepared using lead and",
                " zirconium in the ratios, 1:1, 1:1.25, 1:1.5 and 1:2",
                " respectively. Each mixture, having weight of about",
                " 60 mg, was packed in a thin polyethylene bag of",
                " dimensions appropriate to the total volume of about",
                " 28 mm3 of the mixture."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "MOMIX"
              ],
              "free_text": [
                "  The similarity between the",
                " half-lives of the metastable states of Zr-90 and",
                " Pb-207 is exploited in a simultaneous measurement on",
                " samples where both nuclides are mixed. See details",
                " in pp. 2 and 3 of J.Nucl.Sci.Techn.,13(1976)343."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 55-cm3 Ge(Li) detector was used for gamma",
                " ray detection",
                ".Relative efficiency of detector determined from the",
                " results of absolute efficiency measurements.",
                ".Resolution 1.90 keV at 1.33 MeV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A relation between the ratio of the formation cross",
                " sections for both isotopes and the ratio of the",
                " intensities of gamma-rays is established.",
                " Supplementary details in pp. 2 and 3 of",
                "                         J.Nucl.Sci.Techn.,13(1976)343."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The present method allows measurement at energy",
                " ranges which have not been covered by earlier",
                " workers."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "TABLE"
                ],
                "subentry_number": null,
                "author": null,
                "reference": null
              },
              "free_text": [
                " .Data from Tbl.1 of NSE,13,343."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Background and self absorption negligible.",
                ".Corrections of dead time variations in the neutron",
                " flux and irradiation time not necessary.",
                ".Progressive build-up of the activities of the",
                " long lived isotopes of Pb and Zr were negligible",
                " due to short irradiation time."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
