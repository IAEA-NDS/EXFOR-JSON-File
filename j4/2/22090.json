          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Aluminium disc samples of 2 cm diameter and 0.5 cm",
                " thickness were machined from high purity metal ingot.",
                " 21 Samples were divided into 7 groups by three discs",
                " and fixed at a distance of 12 cm from the source,",
                " covering angles from 25 to 85 degrees with respect to",
                " the incident deuteron beam. 21 iron dosimetry foils",
                " were put on the surface of each sample disc to",
                " evaluate the neutron fluence. In addition, 7 sets of",
                " zirconium-niobium foils were attached in front of each",
                " sample set to measure the average energies of the in-",
                " cident 14 MeV neutrons.",
                ".The average neutron fluence was about 5.0E+16 n/cm2."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Data were corrected for fluctuations during irradi-",
                " ation, background from scattered neutrons, sum-coin-",
                " cidence loss effects, gamma-ray self-absorption,",
                " finite solid angle in the gamma-ray measurements and",
                " for the effect of large variation of the energy width",
                " of the source neutrons with the emission angle."
              ]
            }
          ],
