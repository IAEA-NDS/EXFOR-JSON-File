          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "PHOTO"
                ],
                "reaction": null
              },
              "free_text": [
                " Primary neutrons were produced from the water-",
                " cooled photoneutron target made of Ta sheet plates",
                " set at a water tank",
                "For energies above 1 eV a Cd sheet was placed in the",
                " TOF neutron beam to suppress overlap of thermal",
                " neutrons from the previous pulse"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In metal plate (99.8% purity, natural, 0.474 atoms/kb,",
                " 1.8 cmx1.8 cm).",
                "Sm metal plate (99.8% purity, natural, 1.807 atoms/kb,",
                " 1.8 cmx1.8 cm) for determination of absolute neutron",
                " flux at black resonance at the thermal energy.",
                "10B powder (99.999% purity, enriched to 96.98%,",
                " 52.42 atoms/kb, 1.8 cmx1.8 cm) to measure relative",
                " neutron flux from 0.003 eV to 30 keV.",
                "Graphite (99.9% purity, 24.61 atoms/kb, 1.8 cmx1.8 cm)",
                " to investigate background due to neutron scattered by",
                " the In sample."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " 12 scintillation bricks of 5x5x7.5 cm3 (total",
                " volume of 2.25 liters) as a total energy absorption",
                " detector"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Beam intensity monitor"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " 12.7+/-0.02 m between Ta target and In sample.",
                "Energy calibration was done with the well-known",
                " resonance energies: 4.92 eV of Au, 132 eV of Co, 336",
                " and 2.37 keV of Mn."
              ]
            }
          ],
