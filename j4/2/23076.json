              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PHVC"
              ],
              "free_text": [
                " Fission-fragment multidetector consisting of",
                "  15 photovoltaic cells distributed among 5 units,",
                "  each composed of 3 cells placed vertically above",
                "  one another. Four units were located in the forward",
                "  direction with an angular coverage of 14 to 125 deg.",
                "  The fifth was positioned at 180 deg from the",
                "  foremost unit. Geometrical efficiency of the fission",
                "  detector obtained by Monte-Carlo simulation was",
                "  approx. 47%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI"
              ],
              "free_text": [
                " Detection of charged particle ejectiles",
                " (deuteron, triton, alpha) at 130 +/- 4 deg"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Charged particle ejectile and fission fragment"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Identification of charged particles"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SURGT"
              ],
              "free_text": [
                " Compound cross section was obtained with a",
                " Lane-consistent semi-microscopic deformed optical",
                " model potential built using deformed radial nuclear",
                " densities calculated in the Hartree-Fock-Bogoliubov",
                " framework with the Gogny D1S interaction."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
