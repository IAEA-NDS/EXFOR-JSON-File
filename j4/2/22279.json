          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 90Sr/85Sr mixture target. Gamma-ray emitter 85Sr added",
                " as a tracer of 90Sr. Sample prepared by evaporating a",
                " small amount of SrCl2 solution containing 2.8 MBq of",
                " 90Sr and 5.4 kBq of 85Sr in a polyethylene bottle.",
                " The bottle was sealed and housed in a polyethylene",
                " capsule together with flux monitor wires of Co/Al and",
                " Au/Al alloys. The target was irradiated in the reactor",
                " for 10 minutes. After irradiation, it was purified by",
                " a cation exchange method."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma-ray spectrum of the Sr sample measured",
                " with a HPGE detector having 90% efficiency. A 5 mm",
                " thick Lucite sheet was placed between the sample and",
                " detector to absorb beta-rays from 90Y. In addition,",
                " a 4 mm thick lead sheet was inserted to absorb low-",
                " energy Bremsstrahlung."
              ]
            }
          ],
