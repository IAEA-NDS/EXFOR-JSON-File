          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "  D(d,n)He-3 reaction emitted at 47 deg to",
                " the deuteron beam direction.  3 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS"
                ],
                "reaction": null
              },
              "free_text": [
                "  Polarized neutrons with -(13.7+-0.7)%",
                " polarization."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Sample 14mm diam., intercepting completely the well",
                " collimated (7 mm diam.) Neutron beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Small angle scattering measurement."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "    A pair of scintillation detectors made of",
                " 5 mm thick stilbene crystal.",
                ".Neutron flux was monitored and B10-ZnS polyester",
                " scintillator surrounded by a wax moderator was used",
                " to monitor the reaction yield."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Normalized to the H2(d,n)He3 differential cross-",
                " section (J.E.Brolley etc. see REL-REF).",
                ".by He-4 scattering measurements with the same target",
                " assembly the polarization of the incoming neutrons was",
                " determined to be -(13.7+-0.7)%, the n-He4 phase",
                " shifts (G.R.Satchler et al., see REL-REF)."
              ]
            }
