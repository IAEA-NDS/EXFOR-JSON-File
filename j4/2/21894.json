              "free_text": [
                " 3.0 MEV DYNAMITRON AT BIRMINGHAM RADIATION",
                " CENTRE."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2UK BIA"
              },
              "free_text": [
                " 0.5 MEV ACCELERATOR AT ASTON",
                " UNIVERSITY USED FOR DATA FROM REL-REF."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " USING EITHER A 0.3 MEV PARTICLE BEAM OR A",
                " 1.4 MEV MOLECULAR BEAM.",
                ".THE TARGET WAS A 1.08 MG/CM-SQ TRITIATED TITANIUM",
                " TARGET PLACED INSIDE A WATER COOLED TARGET ASSEMBLY.",
                ".DIFFERENT NEUTRON ENERGIES ON THE SAMPLES WERE ASHIEVE",
                " BY VARYING THE ANGLES MADE BY THEIR POSITIONS WITH",
                " RESPECT TO THE INCIDENT DEUTRON BEAM DIRECTION."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".EACH OF THE IRRADIATED SAMPLES CONSISTED OF AN",
                " ANTIMONY DISC SURROUNDED BY COPPER AND ALUMINUM RINGS"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " ACTIVATION.",
                ".THE COPPER AND ALUMINUM RINGS SURROUNDING THE SAMPLE",
                " SERVED AS MONITORS FOR THE FAST NEUTRON FLUX AND",
                " ENERGY. THE RATIO BETWEEN CU-ACTIVITY AND AL-ACTIVITY",
                " IS USED FOR DETERMINATION OF NEUTRON ENERGY AS",
                " OUTLINED IN REL-REF."
              ]
            }
          ],
