          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-BACKWARD SCATTERING OF 14.2 MEV NEUTRONS FROM",
                " CARBON AND SULFUR.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE 150 KEV ELECTROSTATIC ACCELERATOR OF THE",
                " POLITECNICO DI TORINO, ITALY."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " THE H-3(D,N)HE-4 REACTION WITH A 150 KEV",
                " DEUTRON BEAM."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NATURAL MELTED SULFUR FITTED WITHIN A PARALLEL-",
                " EPIPED CONTAINER, (70*70*4)CM3, CONSISTING OF A THIN",
                " ALUMINUM FRAME.",
                ".NATURAL GRAPHITE IN A SIMILAR CONTAINER (70*70*9)CM3.",
                ".THE SAMPLES WERE LOCATED AT 220 CM FROM THE NEUTRON",
                " SOURCE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME OF FLIGHT TECHNIQUES."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A 9 CM TIMES 10 CM NE213 LIQUID SCINTILLATOR",
                " LOCATED AT ABOUT 70 CM FROM THE NEUTRON SCOURCE."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-3(D,N)2-HE-4,,SIG",
