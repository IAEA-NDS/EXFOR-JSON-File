          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples for neutron irradiation consisted of 0.8 gr of",
                " spectroscopically pure scandium oxide in flat",
                " thin-walled Perspex pill boxes about 0.1 cm deep",
                " and 3 cm diam.",
                " The neutron flux through the samples was determined",
                " by sandwiching them between two parallel plate ion",
                " chambers each containing about 3 mg of 235-U extending",
                " over an area similar to that of the scandium samples."
              ]
