          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Comparison of the fission characteristics of thermal-",
                " neutron-induced fission of Pu-239 and the spontaneous",
                " fission of Pu-240"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2BLGMOL"
              },
              "free_text": [
                " BR 1 graphite reactor."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Plutonium acetate, 0.06 mg/cm2, electrosprayed on a",
                " gold-coated vyns film. About 8.3% Pu-239 and",
                " about 90% Pu-240. Exact isotopic composition",
                " given in table 1 in 73ROCH,2,51,1973."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " A two-parameter correlation experiment with",
                " coincident pulse heights were registered event by",
                " event."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two large gold-silicon surface barrier",
                " detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The post-neutron kinetic energy values were",
                " calculated with a time dependent linear equation and",
                " the law of conservation of impulse was applied,",
                " corrected for neutron emission."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                " Fission fragments."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Total energy balance calculated and values given in",
                " table 3 in reference."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
