          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Reaction Si-28(n,alpha)Mg-25 for 14.6 MeV neutrons"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2FR SAC"
              },
              "free_text": [
                " .150 kV electrostatic accelerator."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "   Deuteron-tritium reaction.",
                "   Total neutron flux of 3.15 x 10**9/cm2."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The detector itself serves as sample."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Natural silicon (n-p)-junction, 20 mm*mm cross",
                " section, barrier depth 40 micron, bias 50 V."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "14-SI-0(N,A),,SIG",
                  "code_unit": [
                    {
                      "unit": "14-SI-0(N,A),,SIG",
                      "field": {
                        "reaction": "14-SI-0(N,A)",
                        "target": "14-SI-0",
                        "projectile": "N",
                        "process": "A",
                        "product": "",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " For neutron flux determination.",
                " Calculated from pure isotope cross sections and their",
                " natural abundances."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                "     Alphas, all with energy higher than 7.0 MeV,",
                " protons from (N,P) reactions not detected because",
                " the barrier depth is 40 micron and the energy",
                " discrimination is 7 MeV for the alpha particles."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For counting losses near the boundaries of the",
                " detector. Calculated assuming an isotropic distribu-",
                " tion of the alpha particles and a 40 micron",
                " diffusion zone."
              ]
            }
          ],
