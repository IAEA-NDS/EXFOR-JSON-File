            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ROTATING RESONANCE DETECTOR FOR EPITHERMAL ENERGIES."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " BF3-COUNTERS USED FOR 143 KEV MEASUREMENT.",
