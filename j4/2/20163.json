          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE PRIMARY DIFFERENTIAL ELASTIC SCATTERING DATA WERE",
                " REDUCED TO A STANDARD GEOMETRY AND CORRECTED FOR THE",
                " PROPERTIES OF THE SCINTILLATOR AT THE PERTINENT",
                " NEUTRON ENERGY",
                ".THE RESULTS WERE THEN CORRECTED FOR THE EFFECTS OF",
                " FLUX ATTENUATION IN THE SAMPLE, SCATTERING FROM",
                " HYDROGEN(NON-ZERO CONTRIBUTION ABOVE BIAS ONLY FOR",
                " SMALL ANGLES),MULTIPLE SCATTERING AND ANGULAR RESO-",
                " LUTION BY A MONTE-CARLO TECHNIQUE."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE OVERALL ERROR OF THE DIFFERENTIAL CROSS SECTION",
                " VALUES IS ESTIMATED OF THE ORDER +- 15 PERC.",
                ".BECAUSE OF THE SENSITIVITY TO THE FITTING AND EXTRA-",
                " POLATION NO ERROR LIMITS ARE SUGGESTED FOR THE INTE-",
                " GRATED ELASTIC CROSS SECTIONS."
              ]
            }
          ],
