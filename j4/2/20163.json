          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A RING WITH A CROSS SECTION OF 2 TIMES 2 CM AND A MEAN",
                " DIAMETER OF 10 CM WAS USED FOR THE EXTREME FORWARD",
                " ANGLES.",
                ".FOR THE INTERMEDIATE REGION  20 - 160 DEGR. THE",
                " DIMENSIONS WERE  2 X 2 X 25 CM AND FOR THE BACK ANGLES",
                " 3 X 3 X 26 CM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NEUTRONS DETECTED BY A SMALL PLASTIC SCINTILLATOR,",
                " BIASED ABOVE THE INELASTICALLY SCATTERED NEUTRONS.",
                ".DIFFERENT SCATTERING ANGLES WERE OBTAINED BY CHANGING",
                " THE RELATIVE POSITIONS OF SCATTERER, DETECTOR AND",
                " TARGET"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "    1.5   TIMES 1.5   NE150 PLASTIC SCINTILLATOR",
                " WITH AN RCA 6810 PLACED IN THE 0 DEGREE DIRECTION",
                " RELATIVE TO THE DEUTERON BEAM AND SHIELDED FROM THE",
                " TARGET BY A COPPER SHADOW BAR (20-45 CM)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                "    LONG COUNTER RECORDING THE 90 DEGR. NEUTRON",
                " FLUX,  FOR MONITORING PURPOSES",
                ".K-I SCINTILLATION COUNTER RECORDING THE",
                " RECOIL ALPHA-PARTICLES FROM THE SOURCE REACTION",
                " FOR MONITORING PURPOSES"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ABSOLUTE, ASSOCIATED PARTICLE."
              ]
            }
          ],
          "HISTORY": [
