          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " To derive the relative neutron-capture cross sections",
                "of Pd-107, net TOF component of Pd-107 was extracted",
                "simply by subtracting the TOF spectrum of Pd-105 from",
                "TOF spectrum obtained with the 107Pd sample.",
                "Then the relative cross sections were normalized at",
                "the third resonance peak with the value of JENDL-3.3."
              ]
            }
          ],
