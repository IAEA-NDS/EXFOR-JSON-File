          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pd-107 sample isotope abundance (%):",
                "Pd-102 - 0.0, Pd-104 - 1.6+-0.4, Pd-105 - 48.8+-0.8,",
                "Pd-106 - 23.1+-0.3, Pd-107 - 15.3+-0.4,",
                "Pd-108 - 8.7+-0.3, Pd-109 - 2.6+-0.3."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The neutron capture cross sections involving the",
                "contributions of both 107Pd and other Pd isotopes were",
                "derived in the energy range from 0.01 eV to 300 eV from",
                "the obtained TOF spectra relative to the cross sections",
                "of 10B. The relative cross sections were normalized to",
                "the values calculated by the SAMMY code with JENDL-4.0",
                "at the three energy points: 6.8 eV of 107Pd, 11.8 eV of",
                "105Pd, and 33 eV of 108Pd.",
                "The cross sections of 107Pd in the low energy region",
                "were derived as follows:",
                "- the cross sections of Pd isotopes except for 107Pd",
                "were calculated with the resonance parameters in",
                "JENDL-4.0,",
                "- the cross-section components for those Pd isotopes",
                "were subtracted from the result for sample,",
                "- the remained components were divided by the abundance",
                "of 107Pd in the sample."
              ]
            }
          ],
