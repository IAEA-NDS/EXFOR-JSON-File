          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MECHANISM FOR ELECTRIC DIPOLE TRANSITIONS FROM THE",
                " BROAD P-WAVE NEUTRON RESONANCE IN 24-MG."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "T.UCHIYAMA",
                "M.IGASHIRA",
