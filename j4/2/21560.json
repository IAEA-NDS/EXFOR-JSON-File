          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A samarium filter, O,29 g/cm*2 thick, was used to",
                " remove thermal neutrons below 0.25 eV, giving a",
                " spectrum in which more than 90 percent of fissions",
                " are produced by neutrons in the 0.297 eV resonance.",
                ".Ratios are measured to fission yields in a",
                " maxwellian thermal neutron spectrum."
              ]
            }
          ],
