                "reaction": null
              },
              "free_text": [
                " WATER COOLED TI(T) TARGET, BOMBARDED",
                " WITH 3 MEV DEUTERONS AT 50 MICRO-AMP."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".EACH SAMPLE SEGMENT COVERED A CERTAIN ANGULAR RANGE,",
                " AND A CORRESPONDING PRIMARY NEUTRON ENERGY RANGE.",
                " A MONTE CARLO CALCULATION WAS PERFORMED TO CALCULATE",
                " THE SPECTRUM SEEN BY EACH SEGMENT, TAKING INTO",
                " ACCOUNT SINGLE ( BUT NOT MULTIPLE ) SCATTERING IN",
                " THE TRITIUM TARGET, COOLING WATER AND SURROUNDING",
                " CAPSULE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " VACUUM EXTRACTION AND GAS COUNTING",
                "        OF TRITIUM. ACTIVATION REACTIONS USED",
                "        AS INTERNAL MONITORS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " GAS COUNTING TUBE TO MEASURE TRITIUM ACTIVITY",
                "        USING LOW-LEVEL ANTICOINCIDENCE BETA- COUNTING",
                "        IN THE GAS PHASE.",
                "        PROTON RECOIL TELESCOPE 80 CM FROM THE NEUTRON",
                "        SOURCE IN THE 130 DEGREE DIRECTION, USED AS AN",
                "        EXTERNAL FLUX MONITOR."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " LARGE SIZE GELI DETECTOR TO MEASURE GAMMA",
                "        ACTIVITY INDUCED BY THE MONITOR REACTIONS."
              ]
            }
          ],
