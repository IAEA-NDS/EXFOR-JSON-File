          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The deuteron beams were accelerated to energies",
                "ranging from 1.8 to 2.8 MeV, then they passed through",
                "two molybdenum foils of 5 um thickness each. Thus,",
                "they impinged on the solid Ti-tritiated target with",
                "the desirable(lower) energy."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 234U and 238U samples are thin 5 um disks with a",
                "2.6 cm radius deposited on a 100 um Al-backing.",
                "The impurities were found to be much less than 1 % of",
                "the total active mass.",
                "The samples were placed at a distance of 20 cm from the",
                "tritium target, thus limiting their angular",
                "acceptance to +- 20 degrees."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " A Micromegas detector assembly was used to",
