              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "3-LI-7",
                "field_identifier": "ENR",
                "value": 0.999
              },
              "free_text": [
                " Metallic cylinder, enriched to 99.9%",
                "in 3-Li-7. It was encapsulated in a 0.3 mm thick SUS",
                "container, 3.1 cm diameter and 4 cm high. An empty can",
                "was used for background measurements. A polyethylene",
                "and a carbon sample, 1.1 cm diameter by 5 cm high, were",
                "used to determine the detection efficiency. The samples",
                "were positioned at 12 cm distance in front of the",
                "neutron source."
              ]
            }
          ],
          "CORRECTION": [
