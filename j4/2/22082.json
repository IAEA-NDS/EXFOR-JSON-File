              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NST,25,210,1988",
                "code_unit": [
                  {
                    "unit": "J,NST,25,210,1988",
                    "doi": "10.1080/18811248.1988.9733579",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NST",
                        "number": null,
                        "volume": "25",
                        "part": null,
                        "issue": null,
                        "page": "210"
                      },
                      "date": 1988
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
