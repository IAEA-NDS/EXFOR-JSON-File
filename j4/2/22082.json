          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Measurements of fast neutron scattering cross sections",
                " of Li-7 at 11.0 and 13.0 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Chiba",
                "Y.Yamanouti",
                "M.Mizumoto",
                "M.Hyakutake",
