          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2JPNJAE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "2JPNJAE"
              },
              "free_text": [
                " JAERI tandem accelerator facility.",
                "Deuterons were accelerated to 8.1 and 10.2 MeV with an",
                "average beam current of 1.2 and 6 microAmps,",
                "respectively. The beam was pulsed at a repetition rate",
                "of 2 MHz and with a pulse length of 2.8 ns FWHM."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " A deuterium gas target, made of stainless steel",
                " of 1 cm diameter by 3 cm long, with a 5 microgram/cm2",
                " thick Mo entrance window and a 1.5 mm thick Au beam",
                " stop, produced neutrons of energies 11.0 and 13.0 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight with a flight path of 8 m."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The scattered neutrons were detected by an array",
                " of four NE 213 liquid scintillators, 20 cm diameter by",
                " 35 cm thick, viewed by Pm-tubes at both ends. The",
                " detectors were positioned on a goniometer table with",
                " a massive paraffin shield, collimators and a 50 cm",
                " long Cu shadow bar. The detectors had a bias level of",
                " 500 keV proton equivalent, and could be set in the",
                " angular range 20 - 140 degrees."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Two NE 213 scintillators, 5 cm diameter by 1.27",
                " cm thick, were used as source neutron monitors."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-1(N,EL)1-H-1,,DA",
