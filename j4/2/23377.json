          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  Pure thermal neutron flux of Maxwellian distribution",
                "with a mean temperature 30 deg K, collimated to 2 mm or",
                "3.8 mm diameter by 5mm-thick B4C apertures."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "80 mm diameter, 99.99 % of 209Bi, 2 mm thickness,",
                "87.795 g weight sample was places 1 m upstream of the",
                "collimator.",
                "The sample was oriented at 45 deg relative to the",
                "incident neutron beam axis.",
                "NaCl sample enclosed in 0.4 mm thick, 90 mm diameter Al",
                "container, was used for absolute normalization via",
                "Cl-35(n,gamma)Cl-36 reaction."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " On-line gamma-ray spectroscopy .",
                "Energy spectra were measured during 8 hr ( low  neutron",
                "beam intensity 2.E+6 n/cm2/sec)and 17 hr (high neutron",
                "beam intensity 1.E+9 n/cm2/sec)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " 60 % efficiency Ge detector of EUROBALL with BGO-",
                "anticompton shielding. Placed at 51 cm from the center",
                "of the target. Calibrated by standard 152Eu source and",
                "Cl-35(n,gamma)Cl-36 reaction at the energy range",
                "100-8578 keV ."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Self-attenuation in Bi target was measured as a",
                "function of gamma-energy with a set of Ag and Bi-9%Ag",
                "targets."
              ]
            }
          ],
