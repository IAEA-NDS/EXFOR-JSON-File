                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron-tritium reaction. En(d) = 100 keV.",
                " Titanium-tritium target, 0.05 mg/cm*cm."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Monoenergetic neutrons. Energy spread not given."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Al plates, 10 x 10 x 2 mm. Distance from the neutron",
                " source 150.0 +- 0.1 mm at angles from 32 to 108. degr.",
                " relative to the deuteron beam direction."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "COINC",
                "ASSOP"
              ],
              "free_text": [
                " Irradiation of aluminium samples",
                "under different neutron emission angles relative to",
                "the deuteron beam direction. Measurement of the",
                "induced Na-24 gamma activity by means of two",
                "scintillation counters.",
                ".The absolute activity of the irradiated samples was",
                " determined by the gamma-gamma coincidence method.",
                " The neutron flux was determined by the associated",
                " particle method (simultaneous detection of the alphas",
                " from the H-3(d,n)He-4 reaction)."
              ]
            }
          ],
