          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NEUTRON CAPTURE IN THE 1.15 KEV RESONANCE OF FE-56",
                " USING MOXON-RAE DETECTORS."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "F.CORVI",
                "C.BASTIAN",
                "K.WISSHAK"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
