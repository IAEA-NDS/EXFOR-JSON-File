                "2GERKFK"
              ],
              "free_text": [
                " K.W."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "2ZZZGEL"
              },
              "free_text": [
                " THE GEEL 150 MEV LINAC WAS USED WITH",
                " THE FOLLOWING PARAMETERS. ELECTRON ENERGY = 100 MEV,",
                " FREQUENCY = 100 HZ, PEAK CURRENT = 100 A, PULSE",
                " WIDTH = 1 NS, BEAM POWER = 1 KW."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ROTARY URANIUM TARGET.",
                ".MODERATOR CONSISTING OF A 4 CM SLAB OF WATER CANNED",
                " IN BERYLLIUM. THE FLIGHT PATH WAS AT 9 DEG WITH",
                " RESPECT TO THE NORMAL TO THE MODERATOR FACE.",
                ".A 0.5 MM CADMIUM FILTER ABSOBED NEUTRONS FROM PRE-",
                " VIOUS CYCLES."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE NEUTRON SPECTRUM WAS MEASURED SIMULTANEOUS WITH",
                " CAPTURE MEASUREMENTS USING A DOUBLE-GRIDDED IONIZA-",
                " TION CHAMBER PLACED IN FRONT OF THE CAPTURE SAMPLE.",
                ".THE NEUTRON BEAM WAS COLLIMATED DOWN TO 8 CM DIA-",
                " METER.",
                ".THE EXPERIMENT COVERED THE ENERGY RANGE 2 - 50000 EV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " A FLIGHT PATH OF 28.4 M WAS USED."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MOXR"
              ],
              "free_text": [
                " THREE DIFFERENT MOXON-RAE DETECTORS WERE USED",
                " SIMULTANEOUSLY, WITH BISMUTH, BISMUTH + CARBON, AND",
                " CARBON CONVERTERS, RESPECTIVELY. IN THE FIRST RUN,",
                " THE DETECTORS WERE PLACED AT 120 DEG WITH RESPECT TO",
                " THE NEUTRON BEAM DIRECTION. IN A SECOND RUN THE ANGLE",
                " WAS 90 DEG."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " THE NEUTRON ENERGY SPECTRUM WAS MEASURED BY A",
                " DOUBLE-GRIDDED IONIZATION CHAMBER HAVING AT ITS CENTER",
                " A CATHODE WITH BACK-TO-BACK B-10 DEPOSITS 40 MICRO-",
                " GRAM/CM2 THICK. THE CHAMBER WAS OF THE CONTINOUS GAS",
                " FLOW TYPE, USING A MIXTURE OF 95 PER CENT ARGON AND",
                " 5 PER CENT CARBON-DIOXIDE AT ATMOSPHERIC PRESSURE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A 0.5 MM THICK LI-GLASS DETECTOR WAS USED TO",
                " MAKE AN INDEPENDENT MEASUREMENT OF THE NEUTRON FLUX."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "79-AU-197(N,G),,ARE",
                  "code_unit": [
                    {
                      "unit": "79-AU-197(N,G),,ARE",
                      "field": {
                        "reaction": "79-AU-197(N,G)",
                        "target": "79-AU-197",
                        "projectile": "N",
                        "process": "G",
                        "product": "",
                        "quantity": ",ARE",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",ARE"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " CAPTURE AT THE 4.91 EV RESONANCE,",
                " USING THE SATURATED RESONANCE METHOD."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A 19.47 GRAM, 8 CM DIAMETER BY 0.5 MM THICK METALLIC",
                " IRON SAMPLE, ENRICHED TO 99.87 PER CENT, WERE SAND-",
                " WICHED BETWEEN TWO GOLD FOILS OF THICKNESSES 20 AND",
                " 30 MICROMETERS, RESPECTIVELY."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE DATA WERE CORRECTED FOR",
                " A. THE DIFFERENCE IN NEUTRON FLUX AT 1152 AND 4.91 EV,",
                " B. THE INTENSITY DISTRIBUTION OF THE CAPTURE GAMMA-RAY",
                "    SPECTRUM OF THE 1152 EV RESONANCE IN IRON,",
                " C. THE INTENSITY DISTRIBUTION OF THE CAPTURE GAMMA-RAY",
                "    SPECTRUM OF THE 4.91 EV RESONANCE IN GOLD,",
                " D. THE VARIATION OF THE DETECTOR EFFICIENCY WITH",
                "    GAMMA-RAY ENERGY FOR EACH CONVERTER MATERIAL,",
                " E. MULTIPLE SCATTERING,",
                " F. THE GAMMA-RAY SELF-ABSORPTION IN THE SAMPLE.",
                " THE COMBINATION OF CORRECTIONS B, C AND D AMOUNTS TO",
                " 0.883, 0.964 AND 1.076 FOR THE BI, BI + C AND C CON-",
                " VERTERS, RESPECTIVELY."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "AREA"
              ],
              "free_text": [
                " AFTER SUBTRACTING THE BACKGROUND, THE DATA WERE",
                " ANALYSED WITH THE AREA CODE TACASI, USING GAMMA-GAMMA",
                " = 574 MILLI-EV, EFFECTIVE TEMPERATURE = 326 K, AND",
                " EFFECTIVE SCATTERING RADIUS = 9 FM.",
                ".THE SHAPE OF THE GAUSSIAN RESOLUTION FUNCTION WAS",
                " VARIED IN ORDER TO OBTAIN THE BEST FITS."
              ]
            }
          ],
