          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".No correction was made in detector efficiency for",
                " the difference between the spontaneous fis. spectrum",
                " and the c-13(n,2n) neutron emission spectrum. There",
                " is certainly a large difference but as the C-13",
                " Neutron spectrum is unknown and the correction could",
                " be as large as 50 percent and could depend on the",
                " incident energy the measurement is not considered",
                " as quantitatively reliable."
              ]
            }
