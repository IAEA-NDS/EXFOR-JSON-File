          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-SCATTERING OF 14.6 MEV NEUTRONS BY SULPHUR-",
                " (IN FRENCH)"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": null
              },
              "free_text": [
                " 150 KEV ACCELERATOR."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " 150 KEV DEUTERONS INCIDENT ON A TITANIUM-",
                "        TRITIDE TARGET ON A SILVER SUPPORT. TARGET",
                "        THICKNESS 450 MICRO-GM/CM-SQ, ABOUT 1.2 H-3",
                "        ATOMS PER TI."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".VERTICALLY MOUNTED CYLINDER OF NATURAL SULPHUR, 10 CM",
                " HIGH AND 5 CM IN DIAMETER."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP"
              ],
              "free_text": [
                " TIME-OF-FLIGHT BY THE ASSOCIATED PARTICLE",
                "        METHOD, USING A 2 METRE FLIGHT PATH.",
                "        TIMING RESOLUTION ABOUT 1.5 NS., ABOUT 1 MEV",
                "        FOR 14 MEV NEUTRONS.",
                "        ANGULAR RESOLUTION ABOUT 8 DEGREES."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " PLASTIC SCINTILLATOR, 2.0*1.0*0.02 CM**3,",
                "        MOUNTED ON 56AVP PHOTOMULTIPLIER TO DETECT",
                "        ASSOCIATED ALPHAS.",
                "        PLASTIC SCINTILLATOR, 10 CM IN LENGTH AND 5 CM",
                "        IN DIAMETER MOUNTED VERTICALLY ON A 56AVP",
                "        PHOTOMULTIPLIER, TO DETECT SCATTERED NEUTRONS.",
                "        THIS DETECTOR WAS SHIELDED FROM SOURCE NEUTRONS",
                "        BY A 40*5*5 CM-CU SHADOW BAR OF CU OR W ALLOY.",
                "        SECOND SUCH NEUTRON DETECTOR USED TO REPLACE",
                "        THE SAMPLE TO MEASURE THE RELATIVE DETECTOR",
                "        EFFICIENCY AT VARIOUS NEUTRON ENERGIES TO THAT",
                "        AT 14.6 MEV, AND THE ABSOLUTE EFFICIENCY AT",
                "        14.6 MEV."
              ]
            }
          ],
