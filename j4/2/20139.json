              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NOMINAL RESOLUTION,",
                " FROM   20 EV  TO  210 EV  6.  NANOSEC/M,",
                " FROM  210 EV  TO  310 EV  1.8 NANOSEC/M,",
                " FROM  310 EV  TO  800 EV  0.9 NANOSEC/M,",
