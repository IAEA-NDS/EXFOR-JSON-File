          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total amount of Th-232  was approximately 220 mg",
                "distributed on five plates, while the amount of Cf-252",
                "gave about 80 spontaneous fissions per minute."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "PN",
                "FF"
              ],
              "free_text": [
                "    Prompt neutrons and fission fragments in",
                " coincidence."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The values are in good agreement with earlier accurate",
                " measurements.",
                ".The parameters of the equation",
                " nu-bar(E(n)) = nu-bar(0) + a*E(n), where E(n) is the",
                " neutron energy in MeV have been obtained by fitting a",
                " straight line to the available data using the least",
                " square method yielding nu-bar(En) = 1.87+0.177*En."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "SPSDD"
                ],
                "subentry_number": "20112002",
                "author": null,
                "reference": null
              },
              "free_text": [
                " Data have also been published by",
                "H.Conde and M.Holmberg, Salzburg Conf.,vol.2,(1965)p.57",
                " assuming different corrections. (See Subent 20112.002)",
                " nu-bar = 2.41+-0.10 at 3.6 +-0.3 MeV and",
                " nu-bar = 4.32+-0.13 at 14.9+-0.3 MeV."
              ]
            }
          ],
