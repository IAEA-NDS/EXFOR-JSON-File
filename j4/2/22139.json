          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " 24.5 KEV NEUTRONS WERE PRODUCED BY FILTERING",
                " THE REACTOR NEUTRONS IN ONE OF THE HORIZONTAL BEAM",
                " TUBES. THE 2.4 CM DIAMETER FILTER CONSISTED OF 22.5 CM",
                " IRON, 36 CM ALUMINIUM AND 6.5 CM SULPHUR. THE 24.5 KEV",
                " NEUTRON FLUX WAS 3.6 +/- 0.3 TIMES E+5 NEUTRONS/CM2",
                " AND SECOND."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".QUASIMONOENERGETIC 24.5 KEV NEUTRON BEAM WITH A CON-",
                " TAMINATION OF A FEW PERCENT EPITHERMAL NEUTRONS."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " THE 3-HE TARGET WAS IRRADIATED BY THE FILTERED",
                " 24.5 KEV NEUTRON BEAM."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " ACTIVATION OF GOLD FOILS WERE USED AS NEUTRON",
                " FLUX MONITOR."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " THE CAPTURE GAMMA-RAYS WERE MEASURED WITH A",
                " 3 X 3 INCH NAI/TL/ DETECTOR, PLACED 9.4 CM FROM THE",
                " TARGET AND PERPENDICULAR TO THE BEAM. THE DETECTOR WAS",
                " SHIELDED WITH 10 CM OF LEAD AND WITH HYDROGEN- AND",
                " BORON-CONTAINING MATERIALS."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " ACTIVE SHIELDING AGAINST COSMIC RAYS WAS PRO-",
                " VIDED BY A LARGE DETECTOR, 1000 CM2, WHICH CONSISTED",
                " OF LAYERS OF SCINTILLATING PLASTIC SANDWICHED WITH 5",
                " CM THICK LAYERS OF LEAD. THE RESPONSE OF THE NAI",
                " DETECTOR FOR 20.6 MEV GAMMA-RAYS WAS MEASURED USING",
                " PROTON CAPTURE GAMMA-RAYS AT THE UTRECHT VDG ACCELER-",
                " ATOR. THE EFFICIENCY OF THE DETECTOR WAS CALCULATED",
                " WITH A MONTE CARLO SIMULATION COMPUTER CODE."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
