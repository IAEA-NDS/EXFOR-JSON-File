                " In total 39 sources were used with a wide range of",
                " source thickness, backing thickness and scattering",
                " conditions in order to randomize their influence"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MANGB"
              ],
              "free_text": [
