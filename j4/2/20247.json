          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal neutron capture in Ti-50 and Ni-64"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2SWDCTH"
              },
