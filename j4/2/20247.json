              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "    Thermal neutron flux 3.x 10**12 n/cm2/sec."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Gamma ray detected with Ge(Li)-spectrometer",
                " in pair spectrometer mode and anticoincidence mode."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BPAIR",
                "GELI",
                "NAICR"
              ],
              "free_text": [
                " Staff-shaped Ge(Li) detector,",
                " vol. 3.1 cm3 and NaI annular crystal as pair",
                " spectrometer arrangement, above the pair production",
                " threshold. (An annulus of NaI, 15 cm in diam. and",
                " 10 cm long with a hole 4 cm in diam. surrounded the",
                " Ge(Li)-detector.).",
                ".Relative efficiency of Ge(Li) pair spectrometer was",
                " calculated using composite spectrum.",
                ".For the measurement of low energy gamma-rays, the same",
                " NaI crystals were used in anticoincidence mantle.",
                " Furthermore a NaI-crystal, 12.5 cm in diam. and 10 cm",
                " long with a hole 1.8 cm in diam. was placed in front",
                " of the NaI-annulus to detect backscattered radiation."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrected for recoil."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                "    Gammas."
              ]
            }
          ],
