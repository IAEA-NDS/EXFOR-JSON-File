          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Absolute measurement of the neutron flux density",
                " in the a.E.R.E. Reactor  gleep .-"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "Sample position of the a.E.R.E. Reactor gleep."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Foils with thickness less than 0.002 in.",
                ".The manganese foil contained 11 per cent nickel"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activity measurements of Au-198 and Mn-56,",
                " Cd-filter method."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " For Mn-56 the absolute activity was",
                " determined by 4pi-beta-gamma coincidence technique."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " 4pi-beta gas flow proportional counter"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 1 in. * 1.5 in. NaI(Tl) crystal"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For calculation of the flux density and the  so-",
                " factor of Mn-55 the westcott-formalism has been used"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "79-AU-197(N,G)79-AU-198,,RI",
                  "code_unit": [
                    {
                      "unit": "79-AU-197(N,G)79-AU-198,,RI",
                      "field": {
                        "reaction": "79-AU-197(N,G)79-AU-198",
                        "target": "79-AU-197",
                        "projectile": "N",
                        "process": "G",
                        "product": "79-AU-198",
                        "quantity": ",RI",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",RI"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " Thermal cross section=98.8 B, S0-",
                " factor = 17.3 (it amounts  to a resonance integral",
                " of 1558 B including the 1/V-contribution)",
                ".Assumed thermal cross section of manganese = 13.25B",
                ".Assumed g-factors for neutron temperature of 80 deg.,",
                " Mn-55 = 1.000 and Au-197 = 1.0086."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The 4pi-beta-gamma coincidence technique is shown",
                " to be suitable for absolute measurement of Mn-56."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Taken from j.Nucl. Energy, 17(1963)125."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For the efficiencies of beta and gamma-detectors,",
                " for gamma-gamma coincidences, for decay scheme, for",
                " internal conversion, for flux depression and for",
                " self-shielding effects.",
                ".For Au-197 an additional correction for the deviation",
                " of the cross section from the 1/V-law in maxwellian",
                " region (increase of the so-factor by 0.027)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For flux density standard error +- 3 per cent ,",
                " systematic error +- 1 per cent, accuracy of the mean",
                " flux density +- 2 per cent.",
                ".For the so-factor of Mn-55 no errors is given."
              ]
            }
          ],
