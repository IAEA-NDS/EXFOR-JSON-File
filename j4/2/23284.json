          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Authors use the term \"broad-energy proton beam\" for",
                "protons that impinge on the LiF target after a gold",
                "degrader foil in case of an incident energy of",
                "2096.5 keV before the degrader and use the term",
                " \"narrow-energy proton beam\" for a proton beam of",
                "1912 keV directly from the Van de Graaff accelerator."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For the solid angle subtended by the Au sample.",
                "For the neutron scattering in the Cu target backing.",
                "For the planar geometry of the Au sample.",
                "The photon attenuation correction due to",
                "self-absorption in the target.",
                "Correction factors:",
                "                      for attenuation  for geometry",
                "narrow energy Be7        100.               100.",
                "narrow energy, Au #1      99.1              98.0",
                "narrow energy, Au #2                        97.5",
                "broad energy Be7         100.               100.",
                "broad energy, Au #1                         98.0",
                "broad energy, Au #2                         97.5",
                "                    for activities on planer Au sample",
                "                        narrow energy     broad energy",
