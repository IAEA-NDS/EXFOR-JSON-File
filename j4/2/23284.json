                "Au #2 (angle < 66 deg)   1.16+-0.03         1.10+-0.03"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " kT=28 keV was determined by best fit of measured",
                "neutron spectra at 8 keV < En < 80 keV for broad and",
                "narrow proton energy spectra."
              ]
            }
