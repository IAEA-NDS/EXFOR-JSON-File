          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " 7Li(p,n) reaction on LiF target of 6mm diameter",
                "prepared by evaporation on a 1-mm thick Cu disk of",
                "40.7 mm diameter. Bunched and chopped proton beam,",
                "proton energy 1912 keV.",
                "The LiF layer thickness was determined by weighing to",
                "be 1-2 mg/cm**2.",
                "Proton beam pulse width 1.5-2 ns(FWHM) ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " Two 6Li-glass detectors - for incident neutron",
                "detection."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " Long counter (54cm x 35.6cm diameter) for",
                " neutron monitoring."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NaI detector (4in x 4in diameter) for gamma",
                "monitoring."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector of 100% relative efficiency to",
                "measure induced Be-7 and Au-198 activity.",
                "Efficiency was measured by standard point sources,",
                "estimated uncertainty of absolute efficiencies ~2% ."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
