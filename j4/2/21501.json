              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Spherical layer, 20 mm thick, i.e. 35% of the",
                " free path for the case of beryllium, for other",
                " elements no details given."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Transmission measurement gives total cross",
                " section, scattering measurement gives elastic cross",
                " section, non-elastic cross section obtained as the",
                " difference."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Plastic scintillator of special form, 15 mm",
                " diam, coupled to a photo-multiplier 56 AVP, with a",
                " 40 mm long light guide."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "CSICR",
                "SCIN"
              ],
              "free_text": [
                " For the measurement of the incoming",
                " neutron flux a CsI(Tl)-crystal detecting the",
                " associated alpha particles of the d-t reaction,",
                " in coincidence with a plastic scintillator,",
                " detecting the neutrons by their recoil protons."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The measurement is repeated for different levels",
                " of the discrimination."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For finite size of the detector, multiple scattering",
                " in the sample, angular correlation between alphas",
                " and neutrons in the d-t reaction, and energy loss in",
                " elastic scattering reactions."
              ]
            }
          ],
