            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " 450 mm2, 100 microns thick Si(Au)",
                " surface barrier detector at 45 mm from target,",
                " outside the neutron beam. 35 keV resolution FWHM."
              ]
            }
          ],
