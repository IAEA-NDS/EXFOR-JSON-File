          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal neutron induced charged particle reactions",
                " in radioactive targets of 37-Ar, 109-Cd, 125-Xe,",
                " and 132-Cs"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2FR ILL"
              },
              "free_text": [
                " 87 m curved neutron guide of",
                " the HFR. Thermal flux about 10.**9 n/cm2*sec,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2ZZZCER"
              },
              "free_text": [
                " CERN synchro-cyclotron producing",
                " 600 MeV protons. These protons induce spallation",
                " reactions, which produce the nuclides for the",
                " targets."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Prepared by ion implantation using the ISOLDE",
                " mass-separator (CERN). 60 keV ions implanted",
                " into a 10 microns thick foil, in an area of 0.2 cm2.",
                ".Number of atoms for all but one of the targets",
                " was determined by absolute gamma spectroscopy.",
                " Ar-37 was counted by Cl-37 X-rays."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal Maxwellian neutron spectrum from HFR."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
