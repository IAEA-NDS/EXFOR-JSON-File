              ],
              "free_text": [
                " Institut de Physique, Nantes."
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,JPR,37,651,1976",
                "code_unit": [
                  {
                    "unit": "J,JPR,37,651,1976",
                    "doi": "10.1051/jphys:01976003706065100",
                    "field": {
                      "reference_type": "J",
                      "reference": {
