          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Elastic scattering of 6.4 MeV neutrons by P-31,",
                " Co-59,As-75,I-127, and Bi-209"
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
