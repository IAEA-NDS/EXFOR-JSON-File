          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "B.Ramstein",
                "C.Jeanperrin",
                "L.H.Rosier"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2FR PAR"
              },
              "free_text": [
                " 4 MeV Van de Graaff of IPN, Orsay,",
                " used at 5 MHz, pulse width 4. ns."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " 4 MeV deuterons impinging on a spherical",
                " cell, diam=2.5 cm, made of gold (0.2 mm thick)",
                " containing D(2) under pressure of about 1 kg/cm2,",
                " with a Ni-window, 9.6 mg/cm2, causing an energy",
                " loss of 820 keV for the deuterons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Monoisotopic, chemical purity greater than 99%,",
                " cylindrical, diam 25 mm, height 40 mm. and a",
                " polyethylene sample for the monitor reaction, at",
                " 35 degr. C and H scattered neutrons are well",
                " separated."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PSD"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Stilbene monocrystal, 44.5 mm * 50. mm,",
                " connected with a Pm (56DVP), and"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " transtilbene monocrystal (Pm=56AVP) as",
                " neutron flux monitor."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD"
              ],
              "free_text": [
                " Cross sections obtained by integration",
                " of angular distributions."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-1(N,EL)1-H-1,,DA",
                  "code_unit": [
                    {
                      "unit": "1-H-1(N,EL)1-H-1,,DA",
                      "field": {
                        "reaction": "1-H-1(N,EL)1-H-1",
                        "target": "1-H-1",
                        "projectile": "N",
                        "process": "EL",
                        "product": "1-H-1",
                        "quantity": ",DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " Derived from sigma,",
                " assuming an isotropic angular distribution.",
                " Value not given. (at 35. degr.)"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Results analysed using the optical model. Parameters",
                " derived in table 4 of ref.",
                " No numerical values for differential cross sections",
                " given. Instead Legendre polynomials are given."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Neutron flux attenuation in the sample.",
                " Multiple scattering.",
                " Asymmetry of the scatterer with respect to the",
                " beam axis. All corrections are done with the",
                " program ANANKE."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total error. In the article only example for",
                " bismuth is given:",
                ".a) for angular distributions -",
                " ------------------------------",
                "    1.) bismuth at 5 degr.",
                "    ----------------------",
                "     -Integral of scattered ray    -    4.5%",
                "     -Solid angle of detector      -    2.0%",
                "     -Correction by ananke-program -    0.1%",
                "                                        ---------",
                "     Total                         -    5.0%",
                "    2.) Bismuth at 25 degr.",
                "    -----------------------",
                "     -Integral of scattered ray    -    3.0%",
                "     -Solid angle of detector      -    2.0%",
                "     -Correction by ananke-program -    0.1%",
                "     -Different position scatterer -    4.7%",
                "                                        ---------",
                "     Total                         -    6.0%",
                ".B) for total elastic cross section-",
                " ------------------------------------",
                "    (bismuth)",
                "     -statistics a0                -    4.4%",
                "     -Normalization                -    4.5%",
                "                                        ---------",
                "     Total                         -    6.3%"
              ]
            }
          ],
