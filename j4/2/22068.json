          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " B-10 sample, enrichment 94.35%, chemical",
                " purity 99.998%, grain size less than 420 um.",
                " Nominal dimensions 15 milli-m diameter by",
                " 6 milli-m thick. Distance between gas target beam",
                " stop and sample front end 6.5 milli-m. Sample weight",
                " about 1 g.",
                " Boron carbide (B4C), natural isotopic composition,",
                " technical grade, grain size less than 250 um.",
                " Nominal dimensions 24.5 milli-m diameter by 21.2",
                " milli-m thick. Distance between gas target beam stop",
                " and sample front end 10 milli-m. Sample weight about",
                " 12 g.",
                " Two monitor foils, iron and nickel, each 250 um",
                " thick, were placed on either side of each sample."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " In the tritium counting measurements were corrected",
                " for tritium loss during heating, for residual tritium",
                " content in the samples and for neutron background.",
                " In the monitor foil measurements, corrections were",
                " applied for dead time, pile up, coincidence losses,",
                " decay and gamma-ray abundance, as well as for back-",
                " ground neutrons."
              ]
            }
