          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " He-8 was produced through fragmentation reactions",
                "induced by either 600 MeV proton or 910 MeV He-3 beans.",
                "The production target consisted of 47.0 g/cm2 uranium",
                "carbide matrix."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
