              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 24x16 mm plastic scintillator NE102.",
                "Beta-detection efficiency was determined on-line to be",
                " 40+-3 % in beta-gamma coincidence measurement on",
                "nuclide Ne-23 ( HL=38 s) ."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Coaxial Ge(Li) crystal with 17% standard",
                "efficiency was used as gamma detector. The shape of the",
                "efficiency curve was determined to ~5% accuracy by",
                "calibrated sources and Ne-23 measurement."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "D4PI"
              ],
              "free_text": [
                " 4PI neutron counter consisting of 12 He-3",
                "proportional counters imbedded in paraffin wax, was",
                "slid over beta-detector. Neutron detection efficiency",
                "was determined to be 20+-1 % with a 48 g U sample."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " Neutron energy spectrum was measured with He-3",
                "filled high-resolution spectrometer."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " For CP measurement the He-8 ions were collected",
                "on a thin Ni foil in front of 100-microm-thick surface-",
                "barrier Si detector."
              ]
            }
          ],
