          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-INVESTIGATION OF RESONANCE CAPTURE GAMMA RAY SPECTRA",
                " IN THE 93NB(N,GAMMA)94NB REACTION-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                " HARWELL 45MEV ELECTRON LINAC."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NEUTRON BOOSTER TARGET.",
                ".NEUTRON PULSE WIDTH WAS ABOUT 0.2MICROS WITH A",
                " REPETITION FREQUENCY OF 192HZ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".30G OF NIOBIUM PENTOXIDE IN A 95MM DIAMETER",
                " ALUMINIUM SAMPLE CAN FOR LOW ENERGY GAMMA-RUN,",
                " 75MM DIAMETER METALLIC DISC OF THICKNESS 3MM (MASS",
                " 114G) AND A 12MM THICK NIOBIUM METAL SAMPLE FOR",
                " STUDIES UP TO 6KEV NEUTRON ENERGY."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME-OF-FLIGHT AND GAMMA-PULSE-HEIGHT IN",
                " COINCIDENCE.",
                ".RUNNING PERIOD WAS 6 WEEKS ON A 10M FLIGHT PATH."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 30CM3 FOR LOW ENERGY GAMMA-RAYS,",
                "         9CM3 PLANAR FOR HIGH ENERGY GAMMA-RAYS."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NO DETAILS GIVEN."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE LOW ENERGY GAMMA-RAY ENERGY CALIBRATION WAS",
                " DETERMINED RELATIVE TO THERMAL CAPTURE FROM NATURAL",
                " CHROMIUM AND TITANIUM TOGETHER WITH GAMMA-RAYS FROM",
                " Y-88 AND NA-24 SOURCES.",
                ".FOR THE HIGH ENERGIES THERMAL CAPTURE GAMMA-RAYS",
                " FROM IRON,CALCIUM,SILICON AND HYDROGEN WERE USED FOR",
                " CALIBRATION."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CORRECTIONS WERE MADE FOR TANTALUM AND GERMANIUM",
                " RESONANCE CONTAMINATION."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR THE MEASUREMENT WITH THE 12MM THICK SAMPLE A",
                " MULTIPLE SCATTERING CORRECTION OF ABOUT 40PC WAS",
                " MADE.",
                ".THE ESTIMATED STANDARD ERROR FOR ANY RESONANCE LINE",
                " IS +-2KEV DUE TO UNCERTAINTY IN PEAK POSITION."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".EXTENSIVE THEORETICAL WORK WAS CARRIED OUT COMPARING",
                " THE EXPERIMENTAL FINDINGS WITH STATISTICAL THEORY.",
                ".THE AUTHORS CONCLUDE THAT THERE IS STRONG EVIDENCE",
                " FOR NON-STATISTICAL PROCESSES ON THE 93NB(N,GAMMA)",
                " 94NB REACTION."
              ]
            }
          ],
