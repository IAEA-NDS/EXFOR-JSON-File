          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " Spallation reaction in a mercury target",
                "irradiated with 3-GeV protons. Produced neutrons were",
                "slowed down in a supercritical para hydrogen",
                "moderator.",
                "The proton beams were supplied at a repetition rate of",
                "25 Hz and under a proton beam power of 200 kW.",
                "By controlling the opening window, the frame overlap",
                "chopper facilitated expansion of the neutron energy",
                "down to 0.2 meV.",
                "-1st frame: 0.8 meV < En < 1 eV,",
                "-2nd frame: 0.2 meV < En < 0.6 meV)"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nano diamond powder. (natural carbon)",
                "The powder was shaped into a plate by pressing.",
                "-Sample weight: 37.5 mg",
                "-Sample shape: 10 mm x 10 mm x 0.57 mmt",
                "-Average size of nano diamond powder: 5.1 nm",
                "Homogeneity of the sample was measured with",
                "neutron transmission imaging method.",
                "Homogeneity uncertainty was estimated to be 1.8%.",
                "The plate was stored in a pure aluminum capsule",
                "with thickness of 0.3 mm.",
                "A 0.3-mm thick cadmium plate with an 8-mm hole",
                "at its center was placed on the aluminum capsule."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " The 3He detector was covered with boron",
                "carbide resin and equipped with an opening slit of",
                "10 mm x 20 mm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Cross sections are deduced from neutron",
                "transmission ratio measured with the nano diamond",
                "sample to that measured without the sample."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Flight length = 14.665 m"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The incident neutrons were normalized against incident",
                "protons to the facility."
              ]
            }
