          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".MONOCHROMATIC BEAM OBTAINED FROM BRAGG-REFLECTION ON",
                " CU(111) PLANES."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".EVAPORATED INDIUM METAL ON ALUMINIUM",
                " BACKING OF 10 MICROMETERS. THREE DIFFERENT",
                " SAMPLES USED WITH DIAMETER OF 30 MILLIM.",
                " AND THICKNESSES OF 2.08E18 ATOMS/CM*CM,",
                " 1.06E19 ATOMS/CM*CM, 1.31E19 ATOMS/CM*CM.",
                ".SCATTERING SAMPLE AT RIGHT ANGLE TO NEUTRON BEAM,",
                " SURROUNDED BY PROPORTIONAL COUNTERS IN CYLINDRICAL",
                " GEOMETRY."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".MEASURING THE RATIO OF SCATTERING CROSS-",
                " SECTION TO THE TOTAL CROSS-SECTION AT",
                " RESONANCE ENERGY."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                "    EIGHT PROPORTIONAL COUNTERS FILLED WITH",
                " BORON-TRIFLUORIDE ENRICHED IN BORON-10,",
                " DETECTORS ARE 40 CM LONG, 5 CM IN DIAMETER,",
                " WITH 700 TORR PRESSURE."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE QUANTITY MEASURED IN THIS EXPERIMENT IS THE RATIO",
                " BETWEEN NEUTRON-WIDTH TO TOTAL WIDTH. THE STATISTICAL",
                " WEIGHT FACTOR AND THEREFORE THE SPIN OF THE COMPOUND",
                " NUCLEUS ARE OBTAINED USING RESONANCE PARAMETERS",
                " FROM BNL-325."
              ]
            }
          ],
