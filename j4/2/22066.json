          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ABOUT 4 G OF DIOXIDE OF THE FISSILE ISOTOPE, (EN-",
                " RICHMENT 92 PER-CENT FOR U-235 AND 94 PER-CENT",
                " FOR PU-239), SEALED IN STAINLESS-STEEL CONTAINERS,",
                " WERE USED FOR THE DAVIES MEASUREMENTS. IRRADIATION",
                " FOR A PERIOD OF 18 MONTHS.",
                ".ABOUT 12 MILLI-G OF ENRICHED U-235 DIOXIDE WERE",
                " IRRADIATED IN SEALED COPPER CONTAINERS FOR ABOUT",
                " 11 HOURS IN A LOW FLUX, IN THE MEASUREMENTS OF",
                " BOWLES AND WILLIS."
              ]
            }
