          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron spectra measured by TOF at 0 and 30 degrees",
                "respective to the proton beam are on Fig.2 of",
                "J,NSTP,1,89,2011.",
                "Quasi-monoenergetic neutron spectrum was obtained by",
                "subtracting the spectrum at 30 degrees from the",
                "spectrum at 0 degrees."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "1",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Intensity and energy spectrum of source neutrons",
                "produced from the 7Li(p,n) reaction were measured by an",
                "NE213 liquid scintillator placed at 17.10 or 16.13 m",
                "Li-target at 0 or 30 degrees, respectively."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector for gamma rays measurement"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "1",
              "coded_information": [
                "N"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples were placed at 8.05 or 7.05 m from the lithium",
                "target at 0 or 30 degrees, were irradiated 26 hr or",
                "18 hr, respectively."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "1",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " For neutron beam."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Gamma-ray spectrometry of irradiated samples."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation reaction rates R were estimated by the peak",
                "counts of gamma-ray spectra, the peak efficiency of",
                "HPGe detector (calculated by EGS4 code), the self-",
                "absorption of gamma-rays in samples, the beam current",
                "fluctuation during irradiation.",
                "Cross-sections were estimates as:",
                "SIG=(R(0deg)- f*R(30deg))/F, where",
                "f- is correction factor,",
                "F- neutron fluence rate per beam current."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " No description of the uncertainties"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For self-absorption in sample by EGS4 code.",
                "f - correction in subtraction of neutron spectrum due",
                "to variation of distances :",
                "- 17.10 to 16.13 m between Li-target and NE213,",
                "- 8.05 to 7.05 m between Li-target and samples."
              ]
            }
          ],
