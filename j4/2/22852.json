          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*. The Maxwellian average neutron capture",
                "cross section of Pb-208 has been reinvestigated.",
                "*By authors*. Cross section at thermonuclear energy",
                "equal 25-keV is in good agreement with a previous",
                "activation measurement of U.Ratzel (diplomaarbeit 1998,",
                "unpublished) and the respective recommended MAC cross",
                "section, but at kT=52-keV MAC-cross section value is",
                "lower than the recommended cross section curve. The",
                "recommended MAC-cross section at kT=30 keV was",
                "confirmed.",
                "    Gold standard for quasi-Maxwellian spectrum at",
                "kT=25 keV: not given, estimated as 586+-10 mb."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "CURVE"
                ],
                "subentry_number": null,
                "author": null,
                "reference": null
              },
              "free_text": [
                " fig.2 from Nucl.Phys.,A718(2003)518 (cr.sect.",
                "values). kT values from the text of the article."
              ]
