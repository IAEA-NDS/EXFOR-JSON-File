              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For backgrounds - ~10%.",
                " For neutron beam variation.",
                " For spread of incident neutrons to obtain monoenergy",
                " cross section - maximally 6% for Be.",
                " For finite size of samples and ionization chamber <1%."
              ]
            }
