              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Be samples - cylinders of 3.8 cm diameter, placed at",
                "27 cm distance from the neutron source.",
                ". Be (75.4%) - Al(24.6%) alloy .",
                ". Separate Al sample.",
                ". Pure Be samples."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Ionization chamber of 2.5 cm diameter, filled",
                " with 3 atm of argon and 0.7 atm of hydrogen, placed",
                " at 27 cm from Be sample.",
                ". Similar ionization chamber - to monitor the primary",
                "neutron density.",
                "Arrangement of sample and ionization chamber moves in",
                "horizontal plane and was fixed at angle between 0 and",
                "150 deg angle."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
