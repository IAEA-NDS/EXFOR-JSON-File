          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Pa-231 of 7.25 g as Pa(2)O(5).",
                " Th-232 as metal powder (8 to 10 g).",
                " U-238 as UO(3) depleted in U-235 ( 8 to 10 g).",
                " Packed in separate capsules.",
                " The capsule was irradiated in a standard position",
                " close to the neutron source."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Semi-conductor detector for counting of",
                "alpha-particles from H-3(d,n)He-4 reaction to monitor",
                "neutron flux."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Array of 20 proportional counters filled with",
                "B-10 enriched BF3 for delay neutrons counting.",
                "Standard source of ~8 mg RaBeF(4) was used to check",
                "efficiency of delayed neutron counting set.",
                "The delayed neutron counting set was checked by",
                "V-51(p,n)Cr-51 and Fe(P,n)Co-57 reactions (irradiation",
                "at VDG of AERE) and standard source of Cr-51 or Co-57.",
                "Detection efficiency dependence from neutron energy is",
                "presented on Fig.1 of Radiochimica Acta,v.15,p.109,1971"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Irradiation time 12.1 or 60 sec.",
                "Pneumatic transfer system moved the capsule between",
                "irradiation position and the counting position within",
                "the ring of neutron counters."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
