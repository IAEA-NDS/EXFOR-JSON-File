          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Delay neutron decay curves were resolved into four",
                " groups.",
                " Formula (1) of Radiochimica Acta,v.15,p.109,1971 was",
                "used to determine the yield of the particular group.",
                "Mean counting efficiency for each group was determined",
                "by neutron spectra from rel.ref. of R.Batchelor+ for",
                "groups 1 -4  from U-235 thermal neutron fission:",
                " Group        1     2     3     4",
                "Efficiency,%  6.31  6.49  6.44  6.40"
              ]
            }
