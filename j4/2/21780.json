          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutron beam from channel H-2 or H-12",
                "        monochromatic by diffraction from a",
                "        lead or copper crystal."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Samples of metallic natural boron, U-235 and",
                " Pu-239 on vinyl or aluminum backing. Isotopic",
                " composition measured with a mass spectrometer.",
                " Mass of boron sample measured with an",
                " electrodynamic balance."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "DIFFR"
              ],
              "free_text": [
                "",
                " Boron and fissile samples aligned along the same",
                " neutron beam from diffraction crystal.",
                " Time integrated neutron flux measured using the",
                " B-10(n,alpha) reaction as standard, and counting",
                " alphas.",
                " Ratio of neutron induced fission events to",
                " spontaneous alpha decay of the fissile sample.",
                " Fission  cross section calculated taking into",
                " account the corrections detailed below."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "1",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " 95% argon, 5% carbon dioxide at 580 mmHg",
                " pressure. Used for alphas from B-10(n,alpha) standard."
              ]
            },
            {
              "pointer": "1",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Xenon gas scintillator and"
