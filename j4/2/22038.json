              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2GERMNZ"
              },
              "free_text": [
                " Cockroft-Walton accelerator at the",
                " Gutenberg University in Mainz."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " A deuteron beam current of 4 milli-A at 550",
                " keV produced a 14 MeV neutron flux of 1.5E+11",
                " neutrons/cm2 on target. The samples was located",
                " 5 mm from the tritium target. Irradiation time",
                " between 1 and 8 min."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " The Xe gas fission products were separated",
                " by means of fast chemistry before gamma counting."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Two different Ge-Li detectors were used for",
                " gamma spectroscopy of the Xe fission products."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " No details given."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Only rms error for repeated measurements.",
                " The total errors are estimated to be at minimum 10 to",
                " 30%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " With the ISIS-2 fitting program,the experimental",
                " counting data were analysed. The program determines",
                " the parameters ZP and W (the FWHM value) which",
                " characterize the Gaussian charge distribution"
              ]
            }
          ],
