          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Independent yields of Xe-133,135 in the fission of",
                " U-235,238 and Pu-239 by 14 MeV neutrons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "P.Alexander"
              ],
              "free_text": [
                ""
              ]
