                "                           Sample 1 Sample 2 Total sum",
                " Weight of powder (g)       1.240    0.376     1.616",
                " Chemical purity (%)        99.96    99.97     99.96",
                " Isotopic composition (%)",
                "             90Zr             19.8     5.0      16.4",
                "             91Zr              5.3     1.88      4.5",
                "             92Zr              8.2     2.69      6.9",
                "             94Zr              8.4     4.03      7.4",
                "             96Zr             58.3     86.4     64.8",
                " Net weight of sample (g)     0.550   0.245    0.795",
                " Thickness of sample (mm)      3.9      1.3     5.2",
                "   ( x 10**(-3) atoms/barn)    1.95     0.870   2.82",
                " Diameter of sample (mm)      15.      15."
              ]
