          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " The evaluated cross sections of JENDL-4.0,",
                " JENDL-3.3, ENDF/B-VII.0, and ENDF/B-VI.8 disagreed",
                " with the experimental cross section in the high-energy",
                " region. All the evaluations are smaller by a factor of",
                " three to four at energies of 35-100 keV. Reevaluation",
                " of the capture cross section of 96Zr, including the",
                " present results, is desired."
              ]
            }
          ],
