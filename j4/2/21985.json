          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A 0.1 MM THICK PLASTIC SCINTILLATOR JUST IN",
                " FRONT OF THE SAMPLE TO VETO CHARGE PARTICLES CON-",
                " TAMINATING THE NEUTRON BEAM."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A 0.1 MM THICK PLASTIC SCINTILLATOR JUST BEHIND",
                " THE SAMPLE WAS USED BOTH TO MEASURE THE NEUTRON ENERGY",
                " BY TIME OF FLIGHT AGAINST A CAPACITIVE BEAM PICKOFF AN",
                " TO MEASURE THE RECOIL CHARGED PARTICLES BY TIME OF",
                " FLIGHT AGAINST TO STOP DETECTORS AT 7 AND 45 DEGREES."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " THE TWO STOP DECTECTORS EACH CONSISTED",
                " OF ONE 3 CM DIAMETER AND 1 MM THICK PLASTIC SCINTLLATO",
                " FOLLOWED BY A COPPER ABSORBER AND THEN A 4 CM DIAMETER",
                " AND 1 MM THICK PLASTIC SCINTILLATOR IN COINCIDENCE WIT",
                " THE FIRST PLASTIC SCINTILLATOR."
              ]
            }
          ],
          "ANALYSIS": [
