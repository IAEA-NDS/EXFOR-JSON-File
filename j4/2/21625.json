          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Sandwiches consist of Ag-107 enriched (99.6%) foils",
                " and small Al-Co alloy foils (monitor),encased in the",
                " Cd-boxes of 1 mm thick. The Co-Al alloy contains",
                " 99.240% Al and 0.760% Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation of sample and monitor foils",
                " both bare and encased in cadmium boxes.",
                " Cooling time - 13 years (to remove most of 252.6-day",
                " Ag-110m).",
                " Counting over period of 5 years."
              ]
            }
          ],
