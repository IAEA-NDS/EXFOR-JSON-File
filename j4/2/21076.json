          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The (n,alpha) reaction in Al-27 at 15 MeV using a",
                " counter telescope technique"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2UK GLS"
              },
              "free_text": [
                " Cockcroft-Walton.",
                "The neutron flux of 3 x 10**7 neutrons/sec"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Water-cooled tritium target"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "thin (1.56 mg/cm2) target foil of aluminium"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP",
                "EDE"
              ],
              "free_text": [
                " Alpha detection."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "CSICR"
              ],
              "free_text": [
                " Alpha particles from the",
                "aluminium foil pass through a shallow dE/dx the",
                "proportional counter gas filled and are stopped in a",
                "thin CsI(Tl) crystal, the thickness of which(38 mg/cm2)",
                "is just greater than the range of the highest energy",
                "alpha particles detected."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-1(N,EL)1-H-1,,SIG",
                  "code_unit": [
                    {
                      "unit": "1-H-1(N,EL)1-H-1,,SIG",
                      "field": {
                        "reaction": "1-H-1(N,EL)1-H-1",
                        "target": "1-H-1",
                        "projectile": "N",
                        "process": "EL",
                        "product": "1-H-1",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " Proton recoil counter.",
                "The neutron flux was monitored by a proton recoil",
                "counter"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections applied included:",
                " (i) correction for the non-linear luminescent response",
                "of CsI(Tl); this necessitated a slight correction to",
                "the channel width at low energies,",
                " (ii) correction for the varying energy loss of the",
                " alpha particles in the target foil and the counter",
                "                                         windows.",
                " (iii) conversion to the centre-of-mass system."
              ]
            }
          ],
