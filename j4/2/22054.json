          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".PLATE SECTIONS OF MTR-FUEL ELEMENTS. MEASURMENTS",
                " WERE PERFORMED ON AN INTERMEDIATE LAYER WITH THE",
                " DIMENSIONS 40 * 20 * 0.6 MM, CONTAINING A URANIUM",
                " ALUMINIUM ALLOY WITH ABOUT 300 MILLI-G URANIUM,",
                " ENRICHED TO 90 PER CENT U-235. IRRADIATION TIMES",
                " WERE BETWEEN 40 SEC AND 109 DAYS."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CORRECTIONS WERE APPLIED FOR SELF ABSORPTION AND",
                " MEASURING GEOMETRY.",
                ".A SMALL CORRECTION DUE TO FAST FISSION YIELDS",
                " WERE APPLIED FOR RU-106."
              ]
            }
          ],
