          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THERMAL REACTOR SPECTRUM. FLUX DENSITIES WERE",
                " BETWEEN 0.02E+12 AND 70.0E+12 NEUTRONS/CM2 SEC."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DIRECT GAMMA-RAY SPECTROMETRIC METHODS.",
                " SIMULTANEOUS MEASUREMENT OF ACTIVITIES FROM SEVERAL",
                " FISSION PRODUCTS. CALIBRATION WITH STANDARD SOURCES",
                " OF THE SAME NUCLIDES."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " GELI SPECTROMETER, WITH 2.8 KEV RESOLUTION",
                " AT 1333 KEV. DISTANCE BETWEEN SAMPLE AND DETECTOR",
                " WAS 10 TO 90 CM, DEPENDING ON ACTIVITY."
              ]
            }
          ],
