          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                "",
                ".Same geometry was used for both Cf and Cm source",
                ".Energy calibration by the method of Schmitt et al.",
                ".For the Cm-244 data the pulse-height defect was",
                " not considered. The energy calibration is based",
                " on the U-235(N-Th,F) experiment of Fraser et al,",
                " Can.J.Phys.41,2080,1963."
              ]
