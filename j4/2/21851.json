          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Cf-252, made by self-transfer onto a",
                "         220 microgram/cm**2 Ni foil",
                ".Cm-244, on a similar backing",
                ".Isotopic composition of Cm-244 source",
                " isotope / abundance / contribut.To S.F.",
                "           (Per cent)    (per cent)",
                "  Cm-243    <=  0.4           -",
                "  Cm-244    >= 91           >= 87",
                "  Cm-245        1.7           -",
                "  Cm-246        6               5",
                "  Cm-247        0.13          -",
                "  Cm-248        0.08            0.3",
                "  Cm-249    <=  0.01          -",
                "  Cm-250    <=  0.01        <=  7"
              ]
            }
          ],
