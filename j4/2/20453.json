          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                "    ABOVE 300 KEV, T(P,N)-REACTION, T-GAS TARGET"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                "    BELOW 300 KEV, LI7(P,N)-REACTION, DEPOSITS",
                " WERE OF LITHIUM NITRIDE ON 1 CM DIA PT DISCS."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE GAS PRESSURE OF TRITIUM GAVE 100 KEV NEUTRON",
                " ENERGY SPREAD AT EACH ENERGY (CALCULATED VALUE),",
                " AND THE EXPECTED ENERGY LOSS IN THE MO WINDOW FOIL",
                " FROM 260 TO 210 KEV.  THE ABSOLUTE VALUE OF THE MEAN",
                " NEUTRON ENERGIES WERE EXPECT TO LIE WITHIN +- 30 KEV",
                " OF THE CALCULATED VALUES.",
                ".FOR LI7(P,N)-REACTION, 2 TARGET THICKNESSES WERE USED",
                " FOR COMPLETELY SEPARATE MEASUREMENTS IN THE 120 - 300",
                " KEV BAND.  THIS WAS BECAUSE DIFFICULTY IN GETTING A",
                " UNIFORM NEUTRON YIELD ACROSS THE BAND WAS PREDICTED."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A CONTINUOUS-FLOW FISSION CHAMBER CONTAINING",
                " 45 MG OF PU (0.38 PERC OF PU-240) WAS USED."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " DIRECT DETECTION OF FISSION NEUTRONS BY A",
                " LARGE LIQUID SCINTILLATOR."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "   LARGE LIQUID SCINTILLATION COUNTER USED FOR",
                " PREVIOUS PROMPT NU BAR MEASUREMENTS (MATHER ET AL.,",
                " PHYS.REV.133(1964)B1403 AND NUCL.PHYS.66(1965)149),",
                " BUT WITH NEW ELECTRONICS. THE EFFICIENCY ABOUT 83 PC."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A LEAST SQUARE FIT GIVES THE FORMULA,",
                "  R = (0.7660 +- 0.0053) + (0.0396 +- 0.0074) * E(N)."
              ]
            }
          ],
          "HISTORY": [
            {
