              "coded_information": null,
              "free_text": [
                "-MEASUREMENTS OF PROMPT NU-BAR FOR 94-PU-239 BETWEEN",
                " 40 KEV AND 1.2 MEV.-"
              ]
            }
          ],
          "FACILITY": [
            {
