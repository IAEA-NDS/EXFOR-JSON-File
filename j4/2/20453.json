            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE RAW NEUTRON MULTIPLICITY DATA WERE PROCESSED TO",
                " SUBTRACT BACKGROUND AND CORRECT FOR DEAD TIME EFFECTS.",
                ".CORRECTION FOR THE ENERGY RESPONSE OF THE NEUTRON",
                " DETECTOR.",
                ".THE CORRECTION FOR RANDOM COINCIDENCES BETWEEN THE",
                " FISSION CHAMBER AND LARGE SCINTILLATOR WERE LESS 3 PC."
              ]
            }
          ],
          "ERR-ANALYS": [
