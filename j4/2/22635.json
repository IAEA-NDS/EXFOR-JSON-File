          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The angles of irradiation positions were 0, 45, 70,",
                " 95, 120 and 155 degrees which covered the neutron",
                " energy from 14.9 to 13.4 MeV. The average neutron",
                " flux at irradiation position was about 1.E+8 n/cm2/s.",
                " The effective incident neutron energy was determined",
                " by the ratio of the 90Zr(n,2n)89Zr and",
                " 93Nb(n,2n)92m-Nb reactions rates"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrections were Made for time fluctuations of",
                " neutron flux, contribution of low-energy neutrons",
                " below 10 MeV, thickness of sample, self-absorption",
                " Of gamma-rays and for sum-peak effect of gamma-rays"
              ]
            }
          ],
