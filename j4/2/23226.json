            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The following samples were in an Al cylindrical box",
                " (8 mm OD, 46 mm long):",
                " - Encapsulated enriched (93.0%) boron-10",
                " - Bare natural (19.8%) boron crystal",
                " - Encapsulated enriched (99.1%) 6LiF",
                " - Bare enriched (99.1%) 6LiF crystals",
