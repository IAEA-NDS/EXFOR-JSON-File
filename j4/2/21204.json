          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR MEASUREMENTS BETWEEN 0.07 AND 10 EV-",
                " 1.HIGHER ORDER CONTAMINATION OF THE NEUTRON BEAM,",
                "   MEASURED WITH 1 MM THICK CD SHEET AND CALCULATED,",
                "   ABOUT 3 PERCENT AT 0.07 AND 0.4 EV, DECREASING TO",
                "   1 PERCENT AT 0.11 EV AND ABOVE 1 EV.",
                " 2.OXYGEN CONTAMINATION, CORRECTION OF -5.7 B.",
                " 3.OTHER ELEMENT CONTAMINATION, LESS THAN 0.1 B.",
                " 4.OTHER ND ISOTOPES, - 4 B AT 0.025 EV, -2 B ABOVE",
                "   1 EV.",
                " 5.ND-145 RESONANCE AT 4.4 EV, -9 B AT 4.4 EV.",
                " 6.EFFECT OF SMALL ANGLE SCATTERING WAS SMALL.",
                ".FOR MEASUREMENTS BELOW 0.1 EV-",
                " CORRECTION FOR SM-149, 10 B AT 0.025 EV."
              ]
            }
