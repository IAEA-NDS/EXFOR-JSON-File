              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ENRICHED DY-164 SAMPLE. A TYPICAL SAMPLE SIZE WAS",
                " 30 X 5 X 0.05 MM, CONTAINING 30 - 50 MG OF TARGET",
                " MATERIAL."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " IN-BEAM GAMMA SPECTROSCOPY."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE GAMMA-RAY SPECTRA WERE DETECTED IN THE 230 - 1600",
                " KEV RANGE WITH THE FIXED-SOURCE DU MOND TYPE TRANS-",
                " MISSION BENT CRYSTAL DIFFRACTION SPECTROMETER AT MOL.",
                " THE SPECTROMETER MAKES USE OF A PURE SILICON CRYSTAL,",
                " 82 X 60 X 3.5 MM, MOUNTED AT A DISTANCE OF 10.65 M",
                " FROM THE SOURCE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " THE DIFFRACTED GAMMA-RAYS WERE DETECTED IN A",
                " SHIELDED 7.6 CM DIAMETER BY 7.6 CM THICK NA(I) DETEC-",
                " TOR.",
                ".THE RESOLUTION OF THIS INSTRUMENT WAS",
                " 2.6E-06/E**2/N**1 1/KEV, WHERE N IS THE DIFFRACTION",
                " ORDER, OR 1.7 ARCSECONDS.",
                ".THE ENERGY INTERVAL 230 - 1100 KEV WAS MEASURED IN",
                " STEPS OF 1 ARCSECOND AND A COUNTING TIME OF 200",
                " SEC./STEP. THE INTERVAL 400 - 1600 KEV WAS MEASURED",
                " DURING 20 DAYS IN STEPS OF 0.5 ARCSECONDS AND A",
                " COUNTING TIME OF 1000 SEC./STEP."
              ]
            }
          ],
