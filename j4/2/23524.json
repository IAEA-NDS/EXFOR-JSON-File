              "pointer": "",
              "coded_information": null,
              "free_text": [
                " GLEEP:",
                "Cd ratio for Au was determined to be 2.17+-0.03.",
                "Ratio of thermal to total neutron density 0.942 was",
                "determined; using value 0.974 of Littler, the mean",
                "average is 0.958 .",
                ". Neutron spectra in GLEEP and BEPO are probaly",
                "sufficiently similar ( authors comment on page 20 )."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ". GLEEP:",
                "Four Au foils of ~1.8 mg/cm2 thickness, ~1 cm2 area.",
                "Samples 1 and 2 were irradiated without Cd,",
                "3 and 4 - with 1 mm thick Cd cover at the same",
                "position."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
