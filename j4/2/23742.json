          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal-neutron capture cross-section measurement of",
                "Tantalum-181 using graphite thermal column at KUR"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
