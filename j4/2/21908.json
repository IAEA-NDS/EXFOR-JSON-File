          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-THE GIANT ISOVECTOR E2 RESONANCE IN CALCIUM OBSERVED",
                " IN RADIATIVE NEUTRON CAPTURE-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
