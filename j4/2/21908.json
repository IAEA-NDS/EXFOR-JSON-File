              },
              "free_text": [
                " 7 MV TANDEM ACCELERATOR. PULSED BEAM",
                " WITH A PULSE WIDTH OF 3 NSEC AND A FREQUENCY OF 2 MHZ."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " TO PRODUCE NEUTRONS WITH ENERGIES ABOVE 20 MEV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " TO PRODUCE NEUTRONS WITH ENERGIES BETWEEN 7",
                "        AND 14 MEV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CYLINDRICAL IN SHAPE, WEIGHING 573 GRAMS. THE SAMPLE",
                " WAS PLACED 14 CM FROM THE GAS CELL WITH ITS AXIS",
                " PERPENDICULAR TO THE (HORISONTAL) REACTION PLANE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".GAMMA-RAY SPECTRA RECORDED."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME-OF-FLIGHT TECHNIQUES WERE USED TO REDUCE",
                " NEUTRON-INDUCED BACKGROUND IN SPECTRA. THE NEUTRON",
                " INTENSITY FROM THE TARGET WAS ROUTINELY CHECKED BY A",
                " TIME-OF-FLIGHT PLASTIC SCINTILLATOR WHICH WAS",
                " CALIBRATED WITH THE AID OF A POLYETHYLENE TELESCOPE."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " A NAI SCINTILLATOR, 23 CM IN DIAMETER AND 21",
                " CM LONG."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".GAMMA-RAY SPECTRA WERE ENERGY CALIBRATED USING GAMMA",
                " LINES FROM RADIOACTIVE SOURCES AND E.G. THE C-12(N,EL)",
                " REACTION WHICH PRODUCES A 15.11 MEV LINE."
              ]
            }
          ],
