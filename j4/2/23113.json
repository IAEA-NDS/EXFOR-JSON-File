              "pointer": "",
              "coded_information": null,
              "free_text": [
                " (48-CD-112,ENR=0.9827)",
                " (48-CD-114,ENR=0.0052)",
                " Two sets of enriched (98.27%) 112Cd foils",
                "  (163.97 and 160.88 mg, ~0.2 mm thick, 9 mm x 9 mm),",
                "  one set is with Cd cover and the other without Cd",
                "  cover.",
