              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 20% relative to 3'x3' NaI detector efficiency",
                " and resolution of about 2.1 keV at 1.3 MeV.",
                "Efficiency curve was calibrated with standard sources",
                " of 152Eu and 133Ba sources.",
                "Distance between samples and end cap of HPGe detector",
                " was about 2 cm."
              ]
            }
          ],
