          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of neutron capture cross-section for",
                "nuclides of interest in decommissioning (III) :",
                "170Er(n,gamma)171Er and 180Hf(n,gamma) 181Hf reactions"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Nakamura",
                "Y.Shibahara",
