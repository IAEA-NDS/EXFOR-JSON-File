              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NST,62,617,2025",
                "code_unit": [
                  {
                    "unit": "J,NST,62,617,2025",
                    "doi": "10.1080/00223131.2025.2457589",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NST",
                        "number": null,
