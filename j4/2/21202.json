                  "SELVE"
                ],
                "institute": "2UK HAR"
              },
              "free_text": [
                " Mechanical velocity selector in",
                "conjunction with the crystal spectrometer for neutron",
                "energies below 0.05 eV to eliminate higher order",
                "neutrons from the diffracted beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Disc of fissile material of sufficient thickness to",
                " almost totally absorb the incident beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Detection of fission neutrons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " 16 BF-3 counters embedded in paraffin wax",
                "placed symmetrically around the sample. Efficiency",
                "for fast neutrons about 0.3% inside of detector coated",
                "with B2-O3 to absorb slow neutrons scattered from the",
                "sample. BF-3 counter to monitor flux above 0.05 eV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " B-10 foil proportional counter to monitor",
                "flux below 0.05 eV."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections for-",
                " departure of monitor counter response from 1/V law.",
                " Scattering and absorption by canning material and",
                " isotopic impurities in the sample.",
                " Transmission of fissile samples.",
                " Counting losses due to scaler dead time.",
                " Higher order contamination of the neutron beam.",
                " Cross-sections from BNL-325 used to make the",
                " corrections."
              ]
            }
