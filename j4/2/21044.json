          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ROOM BACKGROUND MEASURED USING 25 CM IRON ROD",
                " BETWEEN TARGET AND 0 DEGREE COUNTER. RESIDUAL",
                " FLUX WITHOUT GAS IN THE CELL WAS EXAMINED AND",
                " THE SAMPLE WAS FOUND TO HAVE CLOSELY SIMILAR",
                " TRANSMISSION FOR THESE NEUTRONS SO THAT NO",
                " CORRECTION WAS MADE.",
                ".CORRECTION FOR INSCATTERING FROM SAMPLE TO",
                " DETECTOR, LESS THAN 1 PERCENT FOR C AND CA,",
                " LESS THAN 1.6 PERCENT FOR FE.",
                ".NO CORRECTION FOR INELASTICALLY SCATTERED NEUTRONS",
                " FROM SAMPLE REACHING THE DETECTOR."
              ]
            }
          ],
