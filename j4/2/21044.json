              },
              "free_text": [
                " TANDEM VAN DE GRAAFF."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " DEUTERON BEAM COLLIMATED TO 0.3 CM DIAMETER",
                "        INCIDENT THROUGH A 2.5 MICRO-M NI WINDOW ON",
                "        A DEUTERIUM GAS CELL, 0.63 CM LONG AND 5 CM",
                "        IN DIAMETER.",
                ".NEUTRON ENERGY SPREAD FROM VARIATION IN DEUTERON",
                " ENERGY OVER THE LENGTH OF THE TARGET, STRAGGLING",
                " IN THE NI WINDOW AND FINITE ANGLE OF THE DETECTOR",
                " FROM THE NEUTRON SOURCE (1.7 DEGREES) ESTIMATED",
                " TO VARY FROM 50 KEV AT 7 MEV TO 20 KEV AT 14 MEV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " TRANSMISSION METHOD USING PULSE SHAPE",
                "        DISCRIMINATION TO SEPARATE NEUTRONS AND",
                "        GAMMAS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " STILBENE SCINTILLATOR, 5 CM IN DIAMETER AND",
                "        5 CM LONG, AND EMI 6097 PHOTOMULTIPLIER",
                "        PLACED BEHIND SAMPLE AT 0 DEGREES TO THE",
                "        DEUTERON BEAM TO COUNT TRANSMITTED NEUTRONS.",
                "        IDENTICAL SCINTILLATOR AT 20 DEGREES TO THE",
                "        DEUTERON BEAM TO MONITOR NEUTRON FLUX."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
