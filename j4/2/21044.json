              "coded_information": null,
              "free_text": [
                "-TOTAL NEUTRON CROSS SECTIONS OF C, CA AND FE",
                " BETWEEN 8 AND 14 MEV-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
