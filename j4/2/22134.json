          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2GERMNZ"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2GERMNZ"
              },
              "free_text": [
                " The Mainz triga reactor was used for the",
                " irradiations."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " The irradiation position was in the center of",
                " the reactor, where the fast, epi-cadmium neutron flux",
                " is of the order of 1.0E+11 neutrons/cm2 and sec."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Fast reactor spectrum with a cadmium ratio of about",
                " 30."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "OLMS"
              ],
              "free_text": [
                " The fission fragments recoiling out of the",
                " sample foil were stopped in a layer of magnesium",
                " stearate from which only the rare gases diffused into",
                " an adjacent evacuated space where they decayed to",
                " longer lived descendents that deposited on the walls."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ABSFY"
              ],
              "free_text": [
                " by measuring the activity of the descendents,",
                " the fractional cumulative yield could Be determined",
                " directly."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " After radiochemical separation of the",
                "descendents in the stearate and on the walls, the",
                "activity of the samples were counted in a fixed",
                "geometry on a 154 cm3 intrinsic germanium detector,",
                "having a resolution of 1.8 keV at 1332 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The sample was a 232-Th metal foil with a thickness",
                "of 10 um and a weight of 1 mg. The sample was mounted",
                "in an irradiation setup made of polyethylene in order",
                "to minimize the dose from neutron activation. The",
                "sample was irradiated for 60 min."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The activities were corrected for chemical yield, for",
                " the gas volume between the Th-target and stearate, and",
                " for the non negligible gas volume within the stearate",
                " grains."
              ]
            }
          ],
