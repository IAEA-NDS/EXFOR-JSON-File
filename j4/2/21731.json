          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The 14 MeV cross section was derived from the",
                " product of the ratios...",
                " - Mo-99 activity from Pa-231 and U-238 at 14 MeV;",
                " - Mo-99 activity from Pa-231 and U-238 at 3 MeV;",
                " - 99 mass chain yield at 14 MeV",
                "  from U-238 (5.6%) and Pa-231 (3.2%);",
                " - 99 mass chain yield at 3 MeV",
                "  from Pa-231 (2.6%,this work) and U-238 (6.3%);",
                " - U-238 fission cross section at 14 (1.25b) and",
                "     at 3 MeV (0.540b);",
                " - Pa-231 fission cross section at 3 MeV (1.12 b).",
                " Average value of 4 measurements -",
                "      1.75, 1.19, 1.47, 1.33 b."
              ]
            }
          ],
