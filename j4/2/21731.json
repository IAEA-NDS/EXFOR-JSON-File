          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Thin sample of Pa-231, details given in RCA,6,16,66."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Measurement of activity of selected fission",
                " products.",
                ".The fission fragments were collected on an aluminum",
                " foil, 7 mg/cm2 thick, following recoil from the",
                " fissionable target sample."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Well-established radiochemical methods of",
                " separation were used to isolate the elements of",
                " interest after dissolution of the catcher foil",
                " in hydrochloric acid. Recovery yields were determined",
                " by weighing or by titrometry (Pr) or by",
                " spectrophotometry (Ru)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " End-window gas flow proportional counter",
                " of the Sugarman type. To reduce background the",
                " counter was shielded with Geiger-Muller counters",
                " operated in anti-coincidence."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrections for independent yields of nuclides",
                " succeeding that isolated were made on the basis",
                " of the equal charge displacement hypothesis."
              ]
