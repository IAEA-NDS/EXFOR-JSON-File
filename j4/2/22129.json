          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": null
              },
              "free_text": [
                " THE UPPSALA EN TANDEM VAN DE GRAAFF ACCELERATOR",
                " DELIVERED 2 NS BUNCHES OF 7.8, 9.3 AND 10.8 MEV DEUTE-",
                " RONS AT A REPETITION RATE OF 2 MHZ."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " NEUTRONS WERE PRODUCED USING A STAINLESS STEEL",
                " DEUTERIUM GAS TARGET, 2.5 CM LONG AND WITH A 6 MG/CM2",
                " THICK NICKEL ENTRANCE FOIL, FILLED TO A PRESSURE OF",
                " 1.7 ATM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " NEUTRON-GAMMA SEPARATION WAS OBTAINED WITH",
                " TIME-OF-FLIGHT TECHNIQUES."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " THE GAMMA-RAY SPECTROMETER CONSISTED OF A",
                " NAI/TL/ CRYSTAL, 24 CM IN DIAMETER AND 36 CM LONG,"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " SUURROUNDED BY A PLASTIC ANTICOINCIDENCE",
                " SHIELD, CONSISTING OF AN ANNULUS DETECTOR AND A FRONT",
                " DETECTOR. BORATED PARAFFIN WAS USED TO SHIELD THE DE-",
                " TECTOR FROM ROOM-SCATTERED NEUTRONS, WHILE A LAYER OF",
                " LEAD SERVED AS A SHIELD FOR BACKGROUND GAMMA-RAYS. A",
                " HEVIMET SHADOW BAR ATTENUATED THE DIRECT TARGET NEU-",
                " TRON FLUX. A PLUG OF LITHIUM HYDRIDE WAS INSERTED IN",
                " THE COLLIMATOR TO REDUCE THE EFFECT OF SCATTERED NEU-",
                " TRONS. THE DETECTOR RESPONSE FUNCTIONS WERE DETERMINED",
                " BY MEANS OF PROTON CAPTURE GAMMA-RAYS FROM 11-B. THE",
                " DETECTOR EFFICIENCY WAS CALCULATED WITH A MONTE CARLO",
                " COMPUTER CODE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " NORMALIZATION OF DIFFERENT RUNS WAS ACCOMP-",
                " LISHED WITH A PLASTIC NEUTRON MONITOR OPERATING IN TOF",
                " MODE, WHICH VIEWED THE NEUTRON PRODUCTION TARGET AT A",
                " DISTANCE OF 4 M AND AT AN ANGLE OF 60 DEG."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "20-CA-40(N,G)20-CA-41,PAR,DA",
