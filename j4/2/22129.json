              },
              "free_text": [
                " GROUND STATE TRANSITION."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CYLINDRICAL SAMPLES OF CARBON AND CALCIUM, 3.1 CM IN",
                " DIAMETER AND 3.8 CM IN HEIGHT, ORIENTED WITH THE",
                " SYMMETRY AXIS PERPENDICULAR TO THE REACTION PLANE AND",
                " AT A DISTANCE OF 11 CM FROM THE TARGET CELL. THE CAR-",
                " BON AND CALCIUM SAMPLE MASSES WERE 51.24 G AND 46.21",
                " G, RESPECTIVELY, BOTH BEING OF NATURAL ISOTOPIC COM-",
                " POSITION."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
