          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "CSICR"
              ],
              "free_text": [
                " Eight detector telescopes,each can",
                " be equipped with one or two silicon detectors and one",
                " CsI detector. For light ion detection in energy range",
                " 3-130 MeV.Telescopes were placed in forward hemisphere",
                " at various angles. Energy resolution from 3 to 15 MeV",
                " (FWHM) varying from telescope to telescope.",
                " CsI detection efficiency between 0.92 and 1.00 with",
                " uncertainty up to 2%."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Polyethylene C-D2 of 280 microm thickness,",
