          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-.Kinetic energy and fragment mass distribution",
                " for the spontaneous and photo-induced",
                " fission of Pu-244.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2BLGMOL"
              },
              "free_text": [
                " For Pu-241(N-Th,F) calibration runs",
                "               a collimated N-beam of the reactor BR1",
                "               of SCK/CEN was used"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Pu-244, enrichment 88 per cent,consisting of a",
                "         layer of 29 microgram/cm**2 Pu sandwiched",
                "         between two 30 microgram/cm**2 thick",
                "         polyimide backings with 20 microgram/cm**2 Au",
                ".Pu-241, enrichment 91 per cent,used for calibration,",
                "         thickness 40 microgram/cm**2",
                ".Targets were prepared by electrospraying",
                " of Pu-acetate."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                "",
                ".Two heavy ion detectors were mounted symmetrically",
                " on both sides of the fission target at 90 degrees",
                ".Schmitt et Al. Calibration method (j,Pr,137,B837,65)",
                ".Detector calibration constants of neiler et Al.",
                " (J,Pr,149,894,66)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Surface barrier detectors"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The number of fission events was 7990",
                ".For the calculation of the average total preneutron",
                " kin.Energy the measured value of 2.30+-0.19",
                " (C.J.Orth,j,nse,43,54,71) for the aver.Number",
                " of emitted neutrons was used."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Each measurement was accompanied by a calibration",
                " run with 20-MeV bremsstrahlung. These runs were",
                " calibrated with Pu-241(N-Th,F) data."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Photo-fission data of Pu-244 with 12,15,20 and",
                " 30 MeV bremsstrahlung.",
                ".Comparison with the fissioning system Pu-240."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For the contamination of Pu-244(sf) with Pu-240(sf)",
                " and Pu-242(sf) data,",
                ".Calculated to be 0.5% and 3.4%, respectively."
              ]
            }
          ],
          "ERR-ANALYS": [
