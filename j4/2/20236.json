              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "    TARGET PLACED IN A HORIZONTAL RADIAL BEAM",
                " OF THE REACTOR.",
                ".THE NEUTRON FILTER, CONSISTING OF QUARTZ",
