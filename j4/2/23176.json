              },
              "free_text": [
                "",
                "In J,ANE,10,601 - Al-27 data were used also as monitor."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Nb+Zr rabbit irradiated for a period of 7008s.",
                "Second set of Nb+Zr foils was irradiated for a",
                "period of 6660 s with a flux of about 3.E+11 n/cm**2/s.",
                "Third set of Nb, Ni and Zr foils encapsulated in a",
                "polyethylene container was irradiated at the centre of",
                "the cylindrical neutron target for 1000s."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nb and Zr foils were placed together at five positions",
                "on the axis of an aluminum rabbit.",
                " Ni foils - 68.27 % of Ni-58;",
                " Zr foils - 51.45% of Zr-90;",
                " Nb foils - 100% Nb-93."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detector to measure produced activity of",
                "samples. At distance 56.5 mm. Efficiency 17%.",
                "Calibrated to an absolute accuracy of 2% using standard",
                "radioactive solutions."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Long counter BF3 - to monitor neutron flux."
              ]
            }
          ],
