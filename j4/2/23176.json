                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                " Main reference."
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2GERKIG"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "2GERKIG"
              },
              "free_text": [
                " Cylindrical acceleration structure",
                " KORONA as 14 MeV generator."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron flux during the irradiation is monitored by",
                "multichannel scaling with a time resolution smaller",
                "than the shortest half-life investigated. The long",
                "counter BF3 is calibrated via the reaction",
                "Al-27(n,a)Na-24 using the known cross section. Because",
                "the neutron flux varies within the irradiation volume,",
                "this calibration factor is changed for different",
                "sample geometries."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "13-AL-27(N,A)11-NA-24,,SIG",
                  "code_unit": [
                    {
                      "unit": "13-AL-27(N,A)11-NA-24,,SIG",
                      "field": {
                        "reaction": "13-AL-27(N,A)11-NA-24",
                        "target": "13-AL-27",
                        "projectile": "N",
