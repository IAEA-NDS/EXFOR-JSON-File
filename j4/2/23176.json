          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of the mean neutron energy using the",
                "Zr/Nb and the Ni method."
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/A,366,349,1995",
                "code_unit": [
                  {
