                        "product": "11-NA-24",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " For BF3 counter",
                "                             calibration."
              ]
            }
          ],
          "MONIT-REF": [
            {
              "pointer": "",
              "coded_information": {
