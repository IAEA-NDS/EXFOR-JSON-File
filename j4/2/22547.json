          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 1. Natural copper samples of 10mm diameter and 0.2mm",
                " thick were deployed at 100mm radius at angles of 0.deg",
                " to 165.deg to incident d+ beam.",
                " 2. Pneumatic sample transfer system was used. Eight",
                " tubes were set around d-t source from 0deg to 165deg."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " 1.Irradiation time 3 m.Each sample was measured",
                "at least three times at different cooling times.",
                " 2.Irradiation and cooling time was 1min,and 2 to 3 min",
                " respectively."
              ]
            }
          ],
