          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The hard neutron-proton bremsstrahlung at 76 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "C.Dupont",
