              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Cosi Fan Tutte time-of-flight spectrometer of"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " two transmission time-pick-of detectors (start",
                "and stop), high-resolution coaxial ionization chamber.",
                "For fission fragment detection.",
                "Spectrometer was calibrated with 30ug/cm2 thick U-233",
                "sample using known kinetic energy and mass yields.",
                " Time resolution < 100 psec,",
                " energy resolution <500 keV,",
                " mass resolution < 0.7 amu for light fragment,",
                "                 < 1.2 amu for heavy fragment."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " 16 silicon surface barrier detectors of 400 um",
                "thickness, 600 mm2 area each - to detect LRA particles.",
                "Energy resolution < 40 keV for 5.4 MeV alpha particles.",
                "These detectors were arranged in 4 rows centered at",
                "angles 74, 82, 90 , 98 deg relative to the fission",
                "fragment path."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " 107 cm distance from start to stop detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Masses were evaluated from kinetic energy and velocity",
                "of the fission fragments taking into account energy",
                "losses in time-pick-of detectors and in the entrance",
                "window of the ionization chamber."
              ]
            }
          ],
