                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "  Polythene sample (NE102A),",
                "     2.3 cm diam.* 5 cm."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The aim of this study is to determine the absolute",
                " value of the angular correlation function.",
                ".The energy dependence of the neutron-detection",
                " efficiency is determined by measuring the yield of",
                " neutrons scattered by hydrogen up to 15 MeV,",
                " A flight path of 120 cm was used."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The experimental data of the angular",
                "correlation function"
              ]
            }
          ],
