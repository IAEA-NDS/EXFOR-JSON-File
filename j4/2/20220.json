          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Angular correlations in inelastic neutron scattering",
                " by carbon at 15.0 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2NEDAMS"
              },
              "free_text": [
                "   Cockcroft-Walton Accelerator."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "    H3(d,n)He4 reaction, Ti-H3 target.",
                ".To minimize the background of neutrons and gamma-rays,",
                " a target holder with relatively little material is",
                " constructed, and all massive objects in the vicinity",
                " of the target are removed.  The detectors are shielded",
                " from the target by iron cones only."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Dimensions of 2.3 cm diam. and 5.0 cm length"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "    Time of flight, flight path = 35 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "    10 cm diam, 10 cm deep NE213 encased liquid",
                " scintillator viewed by XP 1040 photomultiplier. (for",
                " neutron)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                "    10 cm diam, 10 cm deep NaI(Tl) crystal",
                " attached to XP 1040 photomultiplier. (for gamma-rays).",
                ".NE102A plastic, 50 micro-m thick attached",
                " to RCA 7265 photomultiplier. (for 2.8 MeV alpha-",
                " particles from H3(d,n)He4 reaction to define a cone of",
                " associated neutrons)."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-1(N,EL)1-H-1,,SIG",
