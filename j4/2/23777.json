          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "94-PU-239",
                "field_identifier": "ENR",
                "value": 0.97941
              },
              "free_text": [
                " Pu(NO3)4 solution, enriched at",
                "97.94% in 239Pu. The number of isotopes present in",
                "the deposits relative to 239Pu:",
                "238Pu/239Pu = (1.96 +- 0.03)E-5",
                "240Pu/239Pu = (2.15 +- 0.02)E-2 and",
                "241Am/239Pu =( 4.95 +- 0.03)E-6.",
                "The sample consists of compact stack of 10 deposits of",
                "4 ug/cm2 239Pu on 200 ug/cm2 titanium backing and",
                "48 mg/cm2 carbon collector each."
              ]
            }
          ],
          "DETECTOR": [
