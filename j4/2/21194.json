                ],
                "reaction": null
              },
              "free_text": [
                " Pulsed beam of protons bunched to 1 ns width",
                "        and collimated to 9 mm diameter incident on",
                "        thick Li-F target evaporated onto Cu backing",
                "        and coated with a layer of aluminium. Proton",
                "        energy 2 keV above threshold giving forward",
                "        collimated neutrons with mean energy 30 keV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                "   10 ns bursts of protons with energy of 4 keV",
                "        above P-t threshold incident on tritium to",
                "        generate kinematically collimated neutrons",
                "        with a mean energy of 64 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".23.63+-0.03 mg U3-O8 (99.5 percent U-235) electro-",
                " sprayed onto a 0.5 mm thick platinum backing.",
                ".Effective thickness of the sample 1.022 mg/cm-sq."
              ]
            }
