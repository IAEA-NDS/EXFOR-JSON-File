              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".OFF BEAM GAMMA SPECTRUM BETWEEN CHOPPER PULSES IS",
                " CONSIDERED TO BE DELAYED SPECTRUM.",
                ".FISSION PRODUCT (DELAYED) GAMMAS WITH HALF-LIVES",
                " BETWEEN THE COINCIDENCE RESOLVING TIME OF 25 N-SEC",
                " AND THE CHOPPER PERIOD OF 200 M-SEC ARE TAKEN",
                " PARTLY BY CAREFUL COMPARISON WITH CORRESPONDING",
                " SPECTRA OF DIFFERENT ISOTOPES."
              ]
            }
