          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-THE MEAN FISSION NEUTRON CROSS-SECTIONS FOR THE",
                " REACTIONS NB-93(N,A)Y-90G, NB-93(N,A)Y-90M AND",
                " NB-93(N,2N)NB-92M.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THETIS REACTOR OF THE GHENT UNIVERSITY",
                " INSTITUTE FOR NUCLEAR SCIENCE."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NEUTRON DISTRIBUTION AT THE IRRADIATION SITE IS",
                " APPROXIMATELY A PURE FISSION NEUTRON DISTRIBUTION",
                " (DEVIATION FROM A PURE FISSION SPECTRUM IS LESS 10",
                " PERCENT).  FISSION FLUX IS ABOUT 3.E+10 N/CM2/SEC.",
                ".FAST NEUTRON FLUX WAS DETERMINED USING THRESHOLD",
                " REACTIONS WITH DIFFERENT EFFECTIVE THRESHOLDS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ABOUT 500 MG  SPEC PURE  NB(2)-O(5) SEALED IN SMALL",
                " PLASTIC CONTAINER,",
                " TOGETHER WITH 25 MG ALUMINIUM SPIRALS AS FLUX MONITOR"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "    ACTIVATION, A SEPARATION METHOD FOR YTTRIUM",
                " FROM NIOBIUM WAS DEVELOPED USING FLUORIDE AND OXALATE",
                " PRECIPITATIONS."
              ]
            }
          ],
