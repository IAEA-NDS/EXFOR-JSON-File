          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Cross section measurements of the Ni-58(n,p)Co-58 and",
                " Si-29(n,alpha)Mg-26 reactions in the energy",
                " range 2.2 to 3.8 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Konijn",
                "A.Lauber"
              ],
