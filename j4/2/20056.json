              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2SWDAE"
              },
              "free_text": [
                "    5.5 MeV van de Graaff."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                "    Li-7(p,n) reaction.",
                ".Above 2.37 MeV a second neutron group about 0.45 MeV",
                " below the main group and with about 10% of its",
                " intensity is present."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Direct charged particle detection."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-1(N,EL)1-H-1,,SIG",
                  "code_unit": [
                    {
                      "unit": "1-H-1(N,EL)1-H-1,,SIG",
                      "field": {
                        "reaction": "1-H-1(N,EL)1-H-1",
                        "target": "1-H-1",
                        "projectile": "N",
                        "process": "EL",
                        "product": "1-H-1",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " Polyethylene film 19 microm. thick.",
                " There are 3 runs made, two relative measurements and",
                " one measurement with the n,p cross-section as a",
                " standard, each run at a different series of energies.",
                " The relative measurements were normalized at 3.33 MeV",
                " to the third measurement.",
                " The result is all points of the different measurements",
                " eventually averaged where the energy is the same."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "    Solid state of surface-barrier type, n-type",
                " silicon for charged particle detection. The detectors",
                "had a sensitive area of 12 mm in diam., lined with",
                "approximately 50. mu-g/cm2 gold."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                "    Long counter for neutron detection.",
                "           Proton-recoil counter viewing the",
                " polyethylene sample used as standard."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Systematic error mainly includes:",
                "  * the error in the neutron-proton",
                "            scattering cross section           < 1%",
                "  * uncertainty in the neutron monitoring with",
                "                             the proton recoil   2%",
                "  * uncertainty in the solid angle estimation  < 3%"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " uncertainty in possible shift in",
                " pulse-height spectra when subtracting the background",
                " in the measurements"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Estimations of the level densities of the intermediate",
                " nuclei from the relative fluctuations of the cross",
                " section curves are in good agreement with those",
                " expected on theoretical grounds."
              ]
            }
          ],
