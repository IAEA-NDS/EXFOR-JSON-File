          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NEUTRON RESONANCE PARAMETERS OF BA-135, BA-137 AND",
                " BA-138."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.MIZUMOTO"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2JPNJAE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                " THE 120 MEV JAERI LINAC, OPERATED WITH 300",
                " PULSES/SECOND WITH A PULSE WIDTH OF 30 NS AND A PEAK",
                " CURRENT OF 3.5 AMPERE, WAS USED FOR THE MEASUREMENTS."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".120 MEV ELECTRONS ON A LAMINATED WATER-COOLED TANTALUM",
                " TARGET. THE NEUTRON BEAM WAS MODERATED BY A 5 CM THICK",
                " BORON LOADED POLYETHYLENE PLATE. THE TARGET WAS SHIEL-",
                " DED BY A LEAD AND COPPER SHADOW BAR OF 4 CM BY 6 CM",
                " AREA AND 60 CM LONG TO REDUCE THE DIRECT GAMMA-FLASH."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".WHITE SPECTRUM. A 5 CM BORON-NITRIDE FILTER WAS USED",
                " ELIMINATE LOW ENERGY NEUTRONS IN THE 56.32 M MEASURE-",
                " MENT, WHILE A 6 MM BORAL FILTER WAS USED IN THE 191.49",
                " M MEASUREMENT. IN THE LATTER CASE, THE NEUTRON BEAM",
                " WAS COLLIMATED TO 3.5 CM AT A DISTANCE OF 100 FROM THE",
                " TARGET."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME-OF-FLIGHT TRANSMISSION MEASUREMENTS WITH",
                " A FLIGHT PATH OF 56.32 M FOR ENERGIES BELOW 2 KEV AND",
                " A FLIGHT PATH OF 191.49 M FOR ENERGIES ABOVE 2 KEV.",
                " THE FLIGHT PATH WAS EVACUATED, USING IN THE FIRST CASE",
                " THIN MYLAR WINDOWS AND IN THE SECOND CASE ALUMINUM",
                " WINDOWS WITH A TOTAL THICKNESS OF 5.5 MM.",
                ".THE ENERGY CALIBRATION WAS MADE USING THE 5.9035 KEV",
                " RESONANCE IN AL AND THE 3.360 KEV AND 71.191 KEV",
                " RESONANCES IN PB."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " A 11.1 CM DIAMETER BY 0.635 CM THICK 6-LITHIUM-",
                " GLASS DETECTOR WAS USED AT THE 56.32 M MEASUREMENT.",
                ".FIVE 11.1 CM DIAMETER BY 1.27 CM THICK 6-LITHIUM-GLASS",
                " DETECTORS WERE USED AT THE 191.49 M MEASUREMENT.",
                ".AN ADDITIONAL 5 CM DIAMETER BY 0.635 CM THICK",
                " 6-LITHIUM-GLASS DETECTOR AT A 47 M STATION WAS USED",
                " FOR MONITORING THE NEUTRON INTENSITIES."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ENRICHED SAMPLES OF 135-BA, 137-BA AND 138-BA IN THE",
                " FORM OF CARBONATE OR NITRATE POWDER WERE USED. EACH",
                " SAMPLE WAS CONTAINED IN A 4 CM DIAMETER BY 1 CM THICK",
                " ALUMINUM CASE WITH 0.2 CM ALUMINUM WINDOWS. THE ISO-",
                " TOPIC ABUNDANCES AND THICKNESSES OF THE SAMPLES ARE",
                " LISTED BELOW.",
                ".",
                " ------------------------------------------------------",
                "  ISOTOPE                     ABUNDANCE, PERCENT",
                "                    135-BA        137-BA        138-BA",
                " ------------------------------------------------------",
                "   130-BA       L.T.  0.05    L.T.  0.03    L.T.  0.01",
                "   132-BA       L.T.  0.05    L.T.  0.03    L.T.  0.01",
                "   134-BA             2.41    L.T.  0.05    L.T.  0.01",
                "   135-BA            79.04    L.T.  0.1     L.T.  0.02",
                "   136-BA             9.35          0.63          0.03",
                "   137-BA             2.91         81.9           0.25",
                "   138-BA             6.29         17.4          99.67",
                " ------------------------------------------------------",
                "   THICKNESS,",
                "   ATOMS/BARN       0.0066        0.0064         0.125",
                " ------------------------------------------------------",
                "."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE RAW DATA WERE CORRECTED FOR DEAD-TIME LOSSES AND",
                " FOR BACKGROUND. THE BACKGROUND WAS DETERMINED BY USING",
                " BLACK RESONANCE FILTERS CONSISTING OF NA, AL AND CO."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " THE ERRORS GIVEN INCLUDE ONLY STATISTICAL",
                " AND FITTING ERRORS. THE SYSTEMATICAL ERRORS ARE ESTI-",
                " MATED TO BE ABOUT 5 PERCENT."
              ]
            }
          ],
          "ANALYSIS": [
