          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENT OF THE SE-76(N,G) CAPTURE CROSS SECTION",
                " AND PHENOMENOLOGICAL S-PROCESS STUDIES. THE WEAK COM-",
                " PONENT."
              ]
            }
          ],
          "FACILITY": [
            {
