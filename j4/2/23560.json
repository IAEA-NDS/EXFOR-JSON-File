          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Independent yield of Xe-134 is considered as quite low",
                " Te-134 fractional yield was determined from measured",
                "cumulative yield and average chain yield to be",
                "0.74+-0.07. I-134 fractional independent yield was",
                "calculated 1.0-(0.74+-0.07)=0.26+-0.07 and",
                "independent yield (4.2+-0.1)*(0.26+-0.07)=1.1+-0.3.",
                "See also formulas in the article for details."
              ]
            }
