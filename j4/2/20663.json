            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR CALIBRATION MEASUREMENTS",
                " DELAYED FISSION GAMMAS,",
                " NATURAL ACTIVITY OF THE URANIUM,",
