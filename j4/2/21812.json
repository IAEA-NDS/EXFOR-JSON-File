              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".MODULE 'EVOGENE' OF THE 'KAFKA' SYSTEM WAS USED TO",
                " CALCULATE COORECTION FACTORS FOR THE GAMMA AND ALPHA",
                " ACTIVITIES OF HEAVY ISOTOPES AND CERTAIN FISSION",
                " PODUCTS PRESENT IN THEIRRADIATED SAMPLES. 'EVOGENE'",
                " USES 1-GROUP CROSS SECTIONS BASED ON THE RESULTS",
                " OF THE NEUTRONICS CODE 'APOLLO'."
              ]
            }
          ],
