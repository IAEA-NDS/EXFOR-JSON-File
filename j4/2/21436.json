          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Mass spectrometer."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Irradiation in the flux scanning tube of the",
                " B2 fuel element of the PLUTO reactor for 47 days."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The neutron spectrum in PLUTO has a temperature of",
                " 106 degrees and a large epithermal component ranging",
                " from 0.046 to 0.066 for the epithermal index."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Sample were prepared by mixing highly enriched",
                " U-233 with 99.995% enriched U-238. Aliquots",
                " of approx 100 micro-gr U-233 were dispersed in about",
                " 10 mg magnesium oxide for irradiation."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " Isotopic mass separation using an A.E.I.",
                " Type M.S.5 mass spectrometer. 10 Micro-g uranium",
                " on tungsten filament surface ionization source."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Alpha derived from changes in isotopic composition",
                " of uranium mixtures from neutron capture",
                " and fission."
              ]
            }
          ],
