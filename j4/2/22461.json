          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Darmstadt-Heidelberg crystal ball spectro-",
                "        meter as high efficiency detector for",
                "        gamma-rays and neutrons. Experimental setup",
                "        consisted of a compact detection system",
                "        (CODIS) placed inside crystal ball for",
                "        ternary particles and fission fragments"
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "ANGD"
              ],
              "free_text": [
                "  Multiplicity and angular distribution",
                "        of gamma-rays and neutrons"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "N-SPC"
              ],
              "free_text": [
                " Neutron multiplicity"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "G-SPC"
              ],
              "free_text": [
                " Gamma-ray spectra"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "A-DIS"
              ],
              "free_text": [
                " Registered are 7.E+7 binary fission events,",
                "  1.2E+6 ternary fission events accompanied with alpha-",
                "  emission, 2.5E+4 tern. fiss. events accompanied with",
                "  He-6 and He-8, 5.E+3 events with emission of heavier",
                "  light charged particles (LCP) from Li to carbon.",
                "  Measured are energy, charge-and-mass distribution",
                "  of LCP in ternary fission",
                " * angular correlation parameters (A2 and A4) for",
                " binary fission of 252Cf and ternary fission with",
                " emission of various LCPs were measured."
              ]
            }
          ],
