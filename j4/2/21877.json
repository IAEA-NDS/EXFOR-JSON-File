          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-The fission cross-section of Th-228 near threshold-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2UK HAR"
              },
              "free_text": [
                " 6 MeV accelerator."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " Proton beam with a diameter of 2 mm on",
                " a LiF target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The fissionable deposit is spread uniformly over",
                " a circular area of 20 mm diam. The deposit is of",
                " 20 micro-g Th-228. the wall of the vacuum chamber,",
                " on which the fission foil is attached, is 0.7 mm thick",
                " over an inner diameter of 100 mm to reduce scattering",
                " corrections."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The fission fragments were detected in a cylindrical",
                " arrangement of 'Makrofol KG', which enabled their",
                " spatial distribution to be determined after etching",
                " and sparking under carefully controlled conditions."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Consists of a cylindrical surface, 100 mm long and",
                " 200 mm diam, and a disc, 200 mm diam, of 'Makrofol KG'",
                " the axis of the Makrofol cylinder is set along the",
                " proton beam direction. The detector and the fission",
                " foil are housed in a cylindrical steel vacuum chamber.",
                ".The method to process the Makrofol sheets is",
                " described in (J,NIM,205,151,1983)"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Experimental runs are normalised to equal numbers of",
                " incident neutrons by means of a long counter.",
                ".An absolute determination of the fission cross",
                " section of (370+-32) mb was determined at 1635 keV.",
                " The rest of the cross section data are normalisations",
                " to that value."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "TABLE"
                ],
                "subentry_number": null,
                "author": null,
                "reference": null
              },
              "free_text": [
                ".Data taken from table 2 in NP/A,419,497,1984"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For",
                " - hole overlap on etched foils",
                " - background",
                " - fragment detection efficiency of foils",
                ".in the determination of the absolute fission cross",
                " section at 1.635 MeV corrections are made for",
                " - presence of a low-energy component in the",
                "   Li-7(p,n) reaction.",
                " - Neutrons scattered from parts of the experimental",
                "   equipment.",
                " - Angular dependence of neutrons",
                " - non-uniformity due to the plane geometry of the foil",
                " - the nominal angle (81 to 90 adeg) for which data are",
                "   not recorded on assumption of fragment isotropy",
                " - neutron scattered in the air between the n-source",
                "   and the long counter"
              ]
            }
          ],
