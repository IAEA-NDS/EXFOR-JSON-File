          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Natural Pd sample, thickness 1.5E-3 to 240.E-3",
                " atoms/b.",
                " The data from the Antwerp conference were obtained",
                " with pure monoisotopic samples."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "TRN"
              ],
              "free_text": [
                " Transmission measurements for the neutron",
                " widths, gamma spectroscopy for the gamma widths."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " 4 Lithium glass detectors, 38 mm diam, 3 mm",
                " thick used in the transmission measurements."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "NAICR",
                "NAICR"
              ],
              "free_text": [
                " 2 Na-I(Tl) crystals, 6 in * 6 in,",
                " in coincidence. Both coincidences from cascade gammas",
                " and singles are used in the analysis."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The spins have been assigned according to the ratio",
                " of the area in the gamma coincidences spectrum to the",
                " corresponding area in the singles spectrum. The",
                " spin was assumed to be 3 when this ratio was 1.00",
                " +- 0.02, and 2 when it was 0.87 +- 0.03.(ratios are",
                " normalized with respect to the former ratio). This",
                " assignment was checked with a Monte Carlo program",
                " for gamma ray cascades."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                " Neutrons in the transmission measurements."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                " Capture gammas, 0.51,0.62,0.72,1.13 and 1.28",
                " MeV for the compound nucleus Pd-106, 0.158,0.250, and",
                " 0.334 MeV for the compound nucleus Pd-109,",
                " in the other measurements."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The background is 0.5 to 0.7% of the open beam",
                " counts in the transmission measurements. In the",
                " recorded gamma spectra the peak/background ratio",
                " is 100. for the coincidence spectra, 35.0 in the",
                " singles above 2.0 MeV, and 25.0 in the singles above",
                " 0.6 MeV. No other corrections mentioned."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The shape analysis of each resonance has been",
                " repeated for different widths of the resolution",
                " (leaving its shape unchanged) and for various",
                " thicknesses of the sample. The values of the",
                " parameters and their errors have been obtained by a",
                " Chi Square Analysis of all these data."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Data taken from main reference."
              ]
            }
          ],
