          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The experimental (n,n') cross sections for the levels",
                " at 668 and 961 keV in Cu-63 and 764 and 1114 keV in",
                " Cu-65 have been compared to a modified Hauser-Feshbach",
                " theory for inelastic neutron scattering."
              ]
            }
          ],
