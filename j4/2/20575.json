          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                "    A Li-6 glass detector was used for",
                "  detector efficiency measurement of the neutrons",
                "  70 keV to 1.1 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "    Liquid scintillation detector NE102A",
                "    were used for neutron spectra measurement from",
                "    70 keV to 6 MeV.",
                ".Efficiencies of neutron detectors were determined",
                " using the known efficiencies Li-6 glass detector and",
                " long counter detectors using neutrons from T(P,N)",
                " and D(D,N) reactions on 5.5 MV Van de Graaff accelera-",
                " tor of Studsvik laboratory. Details are given in",
                " journal AF, vol.29, #23, page 307 (1965)"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                "      Fission neutrons"
              ]
            }
          ],
          "EN-SEC": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Satisfactory maxwellian fits in the high energy",
                " part of the spectra."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Maxwellian temperatures given in Table 1 of",
                " reference ark.Fys.29 (1965) 313.",
                ".Numerical data for neutron spectra taken from",
                " private communication of G.During.",
                ".Data below 0.3 MeV are missing."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrections are made for neutron background, for",
                " high energy gamma spectra subtraction. Corrections",
                " for elastic,inelastic scattering and secondary fission",
                " effects considered negligible except for the",
                " measurements on U-235 and Pu-239."
              ]
            }
          ],
