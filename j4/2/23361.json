              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Beta-neutron detector array.",
                "5cm diameter, 0.3 mm thickness NE102A plastic",
                "scintillator, beta detection efficiency 20% ."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " Eight He-3 proportional counters in paraffin",
                "moderator, shielded by Cd sheet and paraffin layer.",
                "an counters for beta rays . Absolute neutron detection",
                "probability ~10% (measured with Am-Li standard source)."
              ]
            },
