          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The reactions N-14(n,alpha)B-11 and N-14(n,t)C-12",
                " observed with a gridded ionization chamber"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2GERHAM"
              },
              "free_text": [
                " Van de Graaff generator used between",
                "        1.1 MeV and 3.3 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2GERHAM"
              },
              "free_text": [
                " Small 150 kV generator used to calibrate",
                "         flux by providing a source with very low gamma",
                "        background."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuterium gas target. Neutrons produced with",
                "        energies between 4.0 MeV and 6.4 MeV at 0 deg."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Ionization chamber gas also used as sample."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Direct detection of emitted alphas."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Gridded ionization chamber filled with argon-",
                "        nitrogen mixture placed at 0 degrees to the",
                "        deuteron beam 50 cm from the gas cell."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " Long counter positioned 4.6 m behind the gas",
                "        target in the beam direction, and-"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " two organic scintillators were used to monitor",
                "        the neutron flux."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "3-LI-6(N,T)2-HE-4,,SIG",
                  "code_unit": [
                    {
                      "unit": "3-LI-6(N,T)2-HE-4,,SIG",
                      "field": {
                        "reaction": "3-LI-6(N,T)2-HE-4",
