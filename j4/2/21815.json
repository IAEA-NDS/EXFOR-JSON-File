          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Neutron-proton scattering in the energy range",
                " 70 to 170 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "T.C.Griffith",
                "A.P.Banford",
                "M.Y.Uppal",
                "W.S.C.Williams"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2UK LON"
              ],
              "free_text": [
                " Physics Department, University",
                " College London."
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PPS,71,305,1958",
                "code_unit": [
                  {
                    "unit": "J,PPS,71,305,1958",
                    "doi": "10.1088/0370-1328/71/3/302",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PPS",
                        "number": null,
                        "volume": "71",
                        "part": null,
                        "issue": null,
