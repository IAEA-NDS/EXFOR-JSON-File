              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total neutron production rate of 1.4 x 10**17/sec"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Shell shaped natural iron sample."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Flight paths 30 cm (for the gammas) and",
                " 130 cm (for the neutrons). This allows a",
                " considerable background reduction."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "PHD",
                "PSD"
              ],
              "free_text": [
                " A neutron-gamma coincidence is",
                " recorded only if a 4-fold coincidence takes place.",
                " -The neutrons are identified in the neutron detector",
                "  by pulse shape discrimination.",
                " -The neutron pulse is only accepted if it",
                "  exceeds the threshold corresponding to a proton",
                "  energy of 350 keV.",
                " -The gamma event is checked against its time-of-",
                "  flight and against coincidence with a neutron.",
                " -The gamma pulse height should Be within the",
                "  range selected for the measurement.",
                " -The neutron T.O.F. may not exceed the value for",
                "  a 1.4 MeV neutron."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SCIN",
                "NAICR"
              ],
              "free_text": [
                " 12.5*2.5 cm**2 NE213 liquid",
                " scintillator (neutrons) in coincidence with a",
                " 7.5*7.5 cm**2 Na-I-crystal (gammas)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " plastic scintillator to monitor the",
                " neutron flux. It is calibrated using the",
                " Al(n,alpha) reaction."
              ]
            }
          ],
