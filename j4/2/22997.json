          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Extrapolation of the obtained spectra for energies",
                "below 800 keV down to zero energy was carried out with",
                "an evaporation spectrum to estimate the total n,2n",
                "reaction cross section. Extrapolation fitting was done",
                "with the nuclear temperatures of 0.65 MeV (JENDL-3.3),",
                "1.0 MeV (RIPL-2) and 1.73 MeV (ENDF).",
                "Value of 1.0 MeV was selected in this study as",
                "recommended."
              ]
            }
          ],
          "FLAG": [
            {
              "pointer": "",
              "coded_information": [
                1.0
              ],
              "free_text": [
                " Nuclear temperature 0.65 MeV from JENDL-3.3 was",
                "     used in analysis."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                2.0
              ],
              "free_text": [
                " Nuclear temperature 1. MeV from RIPL-2 was used",
                "     in analysis.",
                "     Recommended value (by authors), agrees with",
                "     measurement of Frehaut+ (946+-67 mb at 14.3 MeV)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                3.0
              ],
              "free_text": [
                " Nuclear temperature 1.73 MeV from ENDF/B-VI was",
                "     used in analysis."
              ]
            }
          ],
