          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "4PI1A"
              ],
              "free_text": [
                " Integrated cross sections sig(E,Eg)=4.x Pi x",
                "a0 obtained from a Legendre-polynomial fit to the",
                "experimental values."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "26-FE-56(N,INL)26-FE-56,PAR,DA",
