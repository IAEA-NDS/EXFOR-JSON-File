          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A study of the 75-As(n,n'gamma)75-As reaction"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2ITYPAD"
              },
