              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Pu samples as Pu(SO(4))(2) in dilute D(2)SO(4).",
                "Pu-240 - 91.5 % , Pu-239 - 6.87+-0.07 %,",
                "Pu-241 - 1.54+-0.05 %, Pu-242 - 0.069 %.",
                " Number of atoms:",
                " Pu-240 - 1.722E+21 (+-0.5%), Pu-239 - 1.296E+20,",
                " Pu-2141 - 2.900E+19, Pu-242 - 1.298E+18,",
                " S - 3.763E+21 .",
                ". Boron samples as solution B(2)O(3) in D(2)O.",
                ". All samples in polyethylene bottles of ~ 2.5 cm",
                "diameter, 30 cm long, 140 ml volume."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Effective CS SIG=SIGabsorption*(1-W*ETA),",
                "where W was determined at measurements with U-233,",
                "U-235, Pu-239 and using data from rel.refs. of",
                "C.H.Westcott and BNL-325 to be",
                "1.074+-0.008 for thermal spectrum,",
                "0.75+-0.1 for pile spectrum."
              ]
            }
