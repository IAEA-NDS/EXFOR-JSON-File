          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Two Cd-112 enriched (98.27+-0.01%) foil with thickness",
                " 50 micro-m was used for the irradiation sample. Two",
                " pieces of a Cd foils (about 8*8mm in size) were prepa-",
                " rated, and their weight were 22.46 mg and 25.82 mg,",
                " respectively."
              ]
            },
