          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Measurement of the cross section for the reaction",
                " Nb-93(n,inl)Nb-93-m at 2.8 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.Wagner",
                "G.Winkler",
                "H.Vonach",
                "G.Petoe"
              ],
