          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Au-Al-alloys with 0.37% Au.",
                " Ir-Al-alloys with 2.51% Ir.",
                " For Rh evaporation on small pieces of polyethylene."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Cadmium ratio measurements.",
                " For wire-thickness of 0.15 mm the following",
                " resonance  self-shielding factors are determined,",
                " Au = 0.24 , Rh = 0.43 and Ir = 0.44.",
                " The calculation of 1/V-contribution was made with",
                " Cd-cut-off-energy of 0.56 eV."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "79-AU-197(N,G)79-AU-198,,RI",
                  "code_unit": [
                    {
                      "unit": "79-AU-197(N,G)79-AU-198,,RI",
                      "field": {
                        "reaction": "79-AU-197(N,G)79-AU-198",
                        "target": "79-AU-197",
                        "projectile": "N",
                        "process": "G",
                        "product": "79-AU-198",
                        "quantity": ",RI",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",RI"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " Resonance integral including the",
                " 1/V-contribution = 1549+-20 barns.",
                " Assumed values for thermal cross sections,",
                " Mo-98 = 0.18+-0.02 b ,Rh-103(to metastable state) =",
                " 11+-1b, Rh-103(to ground state)= 135+-3b, Ir-191(to",
                " 1.4 m metastable state) =314+-50 b, Ir-191(to ground",
                " state) = 610 +- 60 b."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Self-shielding;",
                " The neutron spectrum of the irradiation position is",
                " proportional to 1/E in the resonance region."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
