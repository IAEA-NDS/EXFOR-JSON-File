          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Search for Be-7 and Si-32 as products of ternary",
                " fission of U-235 by thermal neutrons"
              ]
            }
          ],
          "AUTHOR": [
            {
