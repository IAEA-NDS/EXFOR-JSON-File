          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Cumulative yield of 1.6E+07 I-129 from thermal-",
                " neutron induced fission of U-235-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2GERMUN"
              },
              "free_text": [
                " The Munich research reactor"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " The samples were irradiated in the",
                " graphite replector of the Munich research reactor"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The thermal neutron flux in the irradiation position",
                " was 1.2E+13    neutrons/cm-sq*sec"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A chip of 118.5 mg uranium metal enriched to 90",
                " per cent in U-235 was enclosed in a small ampoule",
                " of high purity quartz which itself was sealed in",
                " an aluminum can. The space between the ampoule and",
                " the aluminum can was filled with coarse-grained",
                " aluminum powder"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "INTB"
              ],
              "free_text": [
                " Irradiation time 80 min"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Chemical separation of produced I-129 after a",
                " decay time of about 5 months"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation of separated iodine for 2 hr."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Coaxial Ge(Li) with a resolution of 2.1 MeV",
                " for the 1.33 MeV gamma ray of Co-60 used for",
                " detection of gamma rays from the decay of I-130 and",
                " of gamma rays from the decay of the fission product",
                " Ce-144 used for determination of the number of",
                " fissions"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The number of produced I-129 atoms was estimated from",
                " the number of I-130 atoms produced in an irradiation",
                " of the chemically separated Pb-I2. The cross section",
                " used for the reaction 53-I-129(N,g)53-I-130 was",
                " 30.4+-1.7 barns.",
                ".The number of fissions induced in the irradiated",
                " U-235 sample was determined by an absolute",
                " measurement of the Ce-144 content. An absolute yield",
                " of 5.37 per cent for Ce-144 in thermal-neutron",
                " induced fission was used."
              ]
            }
          ],
