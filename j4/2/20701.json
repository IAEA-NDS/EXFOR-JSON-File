          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NEUTRON TOTAL CROSS SECTION MEASUREMENT OF THORIUM",
                " AVERAGED NEAR 24 KEV WITH AN FE-FILTERED BEAM-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
