              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "PHOTO"
                ],
                "reaction": null
              },
              "free_text": [
                "   WATER COOLED PHOTONEUTRON TARGET MADE OF",
                " TANTALUM PLATES WITH A 5 CM THICK POLYETHYLENE",
                " MODERATOR.",
                ".A PURE IRON FILTER OF 30 CM THICKNESS WAS USED FOR",
                " FILTERING THE NEUTRON BEAM."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".IRON FILTERED NEUTRON SPECTRUM PEAKED AT 24.3 KEV",
                " WITH AN ENERGY WIDTH OF ABOUT 2 KEV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".SIX THORIUM METALIC PLATES OF DIFFERENT THICKNES",
                " WERE USED RANGING FROM 0.0273 TO 0.1551 ATOMS/BARN."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "  22.2 M FLIGHT PATH.",
                ".IRON FILTERED BEAM.",
                ".TRANSMISSION MEASUREMENT."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                "    FOR NEUTRON DETECTION A BARE 12.7 CM",
                " DIAM. BY 5.08 CM THICK NAI(TL) CRYSTAL WAS USED."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                "    A LI-6 GLASS SCINTILLATOR WAS USED FOR",
                " DETERMINING INTERFERENCE EFFECTS IN RESONANCE CROSS",
                " SECTIONS BETWEEN IODINE IN DETECTOR AND THORIUM",
                " SAMPLE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                "   A BF3 PROPORTIONAL COUNTER WAS USED FOR",
                " MONITORING THE NEUTRON INTENSITY."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CROSS SECTION OBTAINED BY EXTRAPOLATIONS OF",
                " TRANSMISSION FACTOR TO ZERO SAMPLE THICKNESS."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
