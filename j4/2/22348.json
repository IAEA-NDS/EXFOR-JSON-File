              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutron source was obtained by bombarding",
                "        titanium-tritium target mounted in a rotating",
                "        device"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Neutrons with energies ranging from 14.9 to 13.7 MeV",
                " were obtained by irradiating samples at the angles",
                " 0, 55, 75, 105, 125, 155 adeg relative to the incident",
                " deuterium beam. Effective neutron energy was",
                " determined by Nb/Zr method"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Samples were sandwiched between two aluminium foils",
                " 10*10 mm 0.2 mm thickness. Mass separated isotopes",
                " and those of natural abundance from Oak-Ridge were",
                " used.",
                ".Powder samples were wrapped in powder paper, each",
                " sample of rectangular form, size 10*10 mm, thickness",
                " 0.1-0.2 mm, masses 20-70 milligram"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "       Activation"
              ]
            }
          ],
          "DETECTOR": [
            {
