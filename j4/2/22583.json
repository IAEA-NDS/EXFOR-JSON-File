          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "By comparing with a standard of known 59Ni/58Ni ratio",
                "of (1.04+-0.21) x 10**(-8) it was derived a ratio of",
                "59Ni/60Ni= (8.1+-2.0) x 10**(-9) in the sample (the",
                "relative uncertainties of current measurement, standard",
                "and statistics were added quadratically).",
                "After correcting for the dilution factor, a cross-",
                "section for the reaction 60Ni(n,2n)59Ni was deduced."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
