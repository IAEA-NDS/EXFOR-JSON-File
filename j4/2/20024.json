                        "product": "",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " Individual runs were normalized with a current",
                " integrator and the neutron yield monitored by means",
                " of a long counter."
              ]
            }
          ],
          "MONIT-REF": [
            {
              "pointer": "",
