          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Fast neutron capture cross sections in Ag, Ta,W, Au,",
                " Hg and U"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
