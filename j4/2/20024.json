          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The results are in fair agreement, except in the case",
                " of uranium, with previous measurements based on the",
                " detection of the gamma-rays resulting from the neutron",
                " capture."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Capture of multiply scattered neutrons in the samples",
                " corrected by a Monte Carlo technique",
                " Resonance self-protection",
                " scattering of gamma-rays in the samples"
              ]
            }
          ],
          "ERR-ANALYS": [
