              },
              "free_text": [
                " Van de Graaff accelerator, pulsed beam"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " Proton-lithium-7, target thickness is 10 keV",
                " at 2 MeV proton energy."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "    Time of flight technique"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                "    5 inch NaI scintillation spectrometer"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                "    by means of a long counter the relative",
                " neutron yield as a function of proton energy was",
                " measured at the angles of 95 and 120 deg. to the",
                " proton beam."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "47-AG-0(N,G),,SIG",
                  "code_unit": [
                    {
                      "unit": "47-AG-0(N,G),,SIG",
