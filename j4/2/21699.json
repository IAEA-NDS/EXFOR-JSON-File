              },
              "free_text": [
                "  Main reference"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,359,377,1981",
                "code_unit": [
                  {
                    "unit": "J,NP/A,359,377,1981",
