          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A multiparameter investigation of the H-3 and He-4",
                " emission in the fission of Cf-252"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "D.E.Cumpstey",
                "D.G.Vass"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "C,79JUELICH,2,223,1979",
                "code_unit": [
                  {
