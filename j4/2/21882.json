          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NEUTRON CAPTURE IN S-WAVE RESONANCES OF FE-56,NI-58",
                " AND NI-60-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
