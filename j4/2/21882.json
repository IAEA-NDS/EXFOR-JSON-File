              },
              "free_text": [
                " 3 MV ACCELERATOR,PULSED BEAM"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                "PROTON ENERGY 6,13,20 KEV ABOVE REACTION",
                " THRESHOLD IMPLIES NEUTRON ENERGIES RANGES BETWEEN 10-",
                " 60 KEV,7-75 KEV,5-90 KEV IN A NARROW CONE"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " .METALLIC, ENRICHED, DIAMETER 38.2 CM,",
                " FOR FE-56 2 SAMPLES THICKNESS=0.3,2.0 MM",
                " FOR EACH NI-58,NI-60 3 SAMPLES THICKNESS=0.15,0.3,0.45",
                " MM"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "NEUTRON FLIGHT PATH 9 CM, GAMMA FLIGHT",
                " PATH 16 CM, TIME RESOLUTION 1.2 NS.",
                ".TOF SPECTRUM OBTAINED AT 0 DEGREE",
                ".PULSE HEIGHT SPECTRUM FROM N-MONITOR AT 20 DEGREE",
                ".GOLD SAMPLE AS A CROSS SECTION STANDARD",
                ".GRAPHITE SAMPLE AS A PURE SCATTERER",
                ".EMPTY SAMPLE FRAME FOR BACKGROUND DETERMINATION"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MOXR"
              ],
              "free_text": [
                " 3 DETECTORS WITH GRAPHITE, BISMUTH-GRAPHITE",
                " AND PURE BISMUTH CONVERTERS, RESPECTIVELY.",
                "DISTANCE SAMPLE-DETECTOR=16 CM"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " 2 LI-6 GLASS DETECTORS TO SEE IF THE SAME",
                "N-FLUENCE"
              ]
            }
          ],
          "ANALYSIS": [
