          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A standardized Am-243 solution, equivalent to 3.7E+4",
                " Bq was dropped into a high-purity quartz tube. After",
                " drying up of the solution, the quartz tube was sealed",
                " under evacuation. The monitor wires Co/AL (0.46+-",
                " 0.01 wt%,1.6939+-0.0002 mg weight) and Au/AL (0.112+-",
                " 0.001 wt%,0.4967+-0.0002 mg weight) and Am243 tube",
                " were wrapped with a thin high-purity aluminium foil,",
                " and housed in an inner Al capsule which was in turn",
                " housed in an outer irradiation capsule"
              ]
            }
          ],
