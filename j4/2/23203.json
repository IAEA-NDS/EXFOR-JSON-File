          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Normalization factor K=36.6+-7.3 b is used to calculate",
                "the absolute UCN production and up-scattering",
                "cross-sections :  K*integral((dSIG/dE)dE)=SIG-sct,",
                "where SIG-sct -total scattering cross section per",
                "molecule; dSIG/dE - in arbitrary normalization."
              ]
            }
          ],
