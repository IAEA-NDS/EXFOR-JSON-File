              "free_text": [
                " Experimental error includes:",
                " - counting statistics                         (4-77%)",
                " - sample mass including purity                 (0.1%)",
                " - neutron flux fluctuation                    (<0.6%)",
                " - gamma peak area evaluation                   (0.5%)",
                " - detector efficiency:      Eg >300 keV        (1.5%)",
                "                             Eg 80-300 keV        (3%)",
                "                             Eg <80 keV           (5%)",
                " - efficiency calibration at 0.5 and 5 cm       (2.0%)",
                " - correction for true coincidence sum         (<0.5%)",
                " - correction for random coincidence sum      (0.2-4%)",
                " - correction for sample thickness            (0-0.5%)",
                " - correction for self-absorption of gammas   (0-0.7%)",
                " - correction for low energy neutrons         (0-0.7%)",
                " - 27Al(n,p)27Mg counting statistics            (0.5%)"
              ]
            },
