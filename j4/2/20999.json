          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS",
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " 140 keV deuterons (0.5 uA) with",
                " a vector polarization of about 50% emerging from",
                " a conventional 'atomic beam' source impinged on",
                " a T-Ti target. Outgoing neutrons at different angles",
                " are used to get differently polarized neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Same as detector 3, for the case of the",
                " backward angles. In the other case a cylinder",
                " of graphite, diam. 3.15 cm, length 6.3 cm, at 16. cm",
                " from the neutron source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "ASSOP",
                "COINC"
              ],
              "free_text": [
                "",
                " To obtain the energy spectrum of the scattered",
                " neutrons, the time-of-flight difference between the",
                " scattered neutron and the associated alpha-particle",
                " from the neutron production is measured.",
                " To reduce the background, a coincidence was required",
                " between the two phototubes (see detector 3) to",
                " separate the carbon recoils from the noise."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Thin plastic scintillator to detect the",
                " associated alpha particles at 90 degrees with respect",
                " to the deuteron beam. The solid angle subtended by the",
                " detector is defined by a 1.5cm x 3.0cm rectangular",
                "  slit at 8.0 cm from the target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Liquid scintillator NE213, 12.7 cm diam.,",
                " length 5.1 cm to detect the scattered neutrons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " For backward scattering angles, a NE 102",
                " scintillator, diam. 4.5 cm, length 4.5 cm, at 17.8 cm",
                " from the neutron source, viewed by from both ends",
                " by 56 DVP photomultipliers."
              ]
            }
          ],
