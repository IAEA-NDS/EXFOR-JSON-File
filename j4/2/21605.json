          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".URANIUM ENRICHED TO 93 PERCENT U-235, NO DETAILS."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " ON LINE MASS SEPARATION OF FISSION PRODUCTS",
                " USING THE RECOIL SEPARATOR LOHENGRIN, MASS",
                " RESOLUTION OF 1/800, ENERGY RESOLUTION OF 1/300.",
                ".CHARGE DISTRIBUTIONS DETERMINED BY SIGNAL FROM",
                " PRODUCTS PASSING THROUGH A DELTA-E SILICON SURFACE",
                " BARRIER DETECTOR, 8 MICRO-M THICK, CHARGE RESOLVING",
                " POWER OF 43 FWHM AT 90 MEV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " SILICON SUFACE BARRIER DETECTORS FOR E AND",
                " DELTA-E."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".YIELDS ARE AVERAGED FOR EACH ISOBAR OVER THE KINETIC",
                " ENERGIES AND IONIC CHARGES, WITH THE ISOBARIC YIELDS",
                " AND IONIC CHARGES BEING USED AS WEIGHTING FACTORS."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THERE IS PARTIAL AGREEMENT BETWEEN THIS DATA AND THAT",
                " FOR FISSION PRODUCTS FOR SPECIFIC KINETIC ENERGY AND",
                " IONIC CHARGE GIVEN IN ZP/A,274,203,1975."
              ]
            }
          ],
