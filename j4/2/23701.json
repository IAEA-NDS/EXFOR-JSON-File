          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thin uniform layers of Pa-231 and U-238 (oxide) on",
                "Pt discs, covered with 0.5 mg/cm2 layer of evaporated",
                "Au Disc of 2 cm diameter and 0.005 cm thickness.",
                "Layer thickness 1 mg/cm2 on either side of backing.",
                "Some U-238 deposits are prepared by electrolysis of",
                "uranyl nitrate solution containing ammonium oxalate.",
                "Total 24 targets were interleaved with square",
                "catcher-foils of 4 cm2 area, stack was compressed and",
                "placed in metal holder, then in thin-walled",
                "polyethylene bag and second outer polythene bag.",
                " Catcher foils - 13 mg/cm2 polystyrene or",
                "44 mg/cm2 Cu or 7 mg/cm2 Al."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Proton-recoil scintillation counter to",
                "monitor variation of neutron flux."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Sugarman type gas-flow (90% Ar + 10 % methane)",
                "end-window (metallized Melinex film of 1 mg/cm2)",
                "beta-proportional counter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " Recoiling fission fragments were collected in",
                "catcher foils."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Polystyrene foils were dissolved in benzene,",
                "Cu foils - in nitric acid.",
                " Chemical yields were determined by weighting, except",
                " for yttrium.",
                "Details are given in the article."
              ]
            }
          ],
