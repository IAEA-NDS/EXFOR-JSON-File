          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The experimental results show that the structure in",
                " the fission cross section of Th-232 near the fission",
                " threshold cannot be adequately interpreted in terms of",
                " competition between fission and neutron emission."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Background subtraction,  correction for the difference",
                " in detector efficiencies for the inelastic neutron",
                " group and for the neutrons elastically scattered",
                " against carbon",
                " Correction for multiple scattering in the sample using",
                " a Monte Carlo technique  (11+-2%)"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The errors in the measured cross-sections",
                "are partly statistical, but the largest contribution",
                "is due to the uncertainty caused by the background",
                "subtraction"
              ]
            },
