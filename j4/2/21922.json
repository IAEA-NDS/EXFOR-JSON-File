              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DIFFERENT SAMPLES OF",
                "  -LANTHANUM AND",
                "  -CERIUM COMPOUNDS",
                " WITH PURITIES OF 99.99 PERCENT."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHRFL"
              ],
              "free_text": [
                " CHRISTIANSEN FILTER.",
                "        MIXTURE OF PULVERIZED SOLID SUBSTANCES WITH",
                "        A LIQUID. THE SCATTERING LENGTH OF THE SOLID",
                "        IS DETERMINED BY MEASURING THE RATE OF THE",
                "        SMALL ANGLE SCATTERING OF SLOW NEUTRONS AS",
                "        FUNCTION OF THE KNOWN SCATTERING DENSITY OF",
                "        THE LIQUID PHASE.",
                ".CROSS SECTION MEASUREMENTS AT 0.57 MILLI-EV,",
                " AND 1.26 AND 5.19 EV."
              ]
            }
