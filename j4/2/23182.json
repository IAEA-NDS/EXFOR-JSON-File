          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " Protons impinging on a neutron production",
                "target consisting of 99.98% Li-7."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron spectrum consists of a peak at 96+-0.5 MeV",
                " (1.2 MeV FWHM) and a low-energy neutron tail that can",
                "be suppressed by time-of-flight techniques."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ACCEL"
                ],
                "institute": "2SWDUPP"
              },
              "free_text": [
                " Neutron beam facility at The Svedberg",
                "Laboratory (TSL) in Uppsala before the neutron facility",
                "was upgraded in 2004."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "CSICR"
              ],
              "free_text": [
                " SCANDAL consists of two identical",
                "arms positioned on each side of the neutron beam and",
                "covering the angles 10-50 deg and 30-70 deg.",
                "Detection of scattered neutrons is based on conversion",
                "to protons in an active plastic scintillator and",
                "measurement of the full energy of the outgoing protons",
                "in an array of CsI detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The spectrum obtained at 96 MeV (the incident energy)",
                "was shifted downwards in steps of 1 MeV in the",
                "analysis. This strategy was based on studies of the",
                "ratio between the np scattering and the 12C(n,p)",
                "reaction, which was found to be fairly constant over",
                "the relevant energy interval."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For background.",
                " For the energy dependence of the np cross section and",
                "for variations in proton detection efficiencies in",
                "different CsI crystals."
              ]
            }
          ],
