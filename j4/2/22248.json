                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " THIS RECTION AND A",
                " PROTON RECOIL TELESCOPE WERE USED TO DETERMINE THE",
                " NEUTRON FLUX DENSITY. THE TOTAL FLUENCE UNCERTAINTY",
                " IS ABOUT 3 PERCENT (PC)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
