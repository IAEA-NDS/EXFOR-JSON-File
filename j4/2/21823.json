          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Differential cross sections of the C-12(n,alpha)Be-9",
                " reaction in the energy range from 8 to 10 MeV",
                " extracted from the NE213 scintillator response",
                " functions"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2GERPTB"
              },
              "free_text": [
                " Compact cyclotron."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " NS-pulsed deuteron beam of the compact",
                " cyclotron focussed into a deuterium gas target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Detector = sample."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Is used to select the neutron energy",
                " interval of interest.",
                " The neutron response functions of a NE213 liquid",
                " scintillator are calculated by a Monte Carlo",
                " code (NRESP4). Starting from Legendre polynomials",
                " the differential cross sections are transferred",
                " into a pulse height distribution of the NE213",
                " scintillator detector. By fitting these pulse",
                " height spectra the coefficients can be determined."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " NE213 scintillation detector, 5.07 cm",
                " in height, 5.06 cm in diameter, encapsulated",
                " by BA1 type aluminium housing and coupled via",
                " a light pipe to a fast photomultiplier XP2020.",
                " It was positioned at a distance of about 12 m."
              ]
            }
          ],
