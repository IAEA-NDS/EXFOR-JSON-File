          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Activation cross-sections related to nuclear heating",
                " of high Tc superconductors"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3HUNKOS"
              },
              "free_text": [
                " .KORONA generator at GKSS, Geesthacht."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "   The total neutron yields were 1.04-1.23E+14",
                " neutrons/cm2 in about 2 hr irradiation times."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The neutron energy varied in the energy range 14.42 -",
                " 14.47 MeV in the thick target stack. The average ener-",
                " gy 14.44 MeV is consistent with the measured energy",
                " 14.5+/-0.3 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Rectangular and disc-shaped high-purity metallic sam-",
                " ples of natural Cu, Zr, Nb and ag as well as ceramic",
                " Tl2Ca1Ba2Cu2O8 were used. The metallic samples were",
                " typically 12 mm by 13 mm by 0.2-0.7 mm thick. The ce-",
                " ramic samples were 15.3 mm diameter by 2.3 mm thick.",
                " The concentrations of Ba and Tl in the ceramic samples",
                " were checked by x-ray fluorescence methods. The sam-",
                " ples were sandwiched between two Nb monitor foils and",
                " stacked together."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Calibrated GeLi detectors were used for activi-",
                " ty measurements at both GKSS and Debrecen."
              ]
            }
          ],
