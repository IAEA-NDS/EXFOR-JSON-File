          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENT OF (N,A) CROSS SECTIONS ON CHROMIUM, IRON",
                " AND NICKEL IN THE 5 TO 10 MEV NEUTRON ENERGY RANGE.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2ZZZGEL"
              },
              "free_text": [
                " VAN DE GRAAFF ACCELERATOR, 7 MV,",
                " DEUTERON ENERGY 2-7 MEV, DEUTERON CURRENT 3-5",
                " MICRO-AMPERES."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "  DEUTERON-DEUTERIUM REACTION. THE TARGET",
                " GASS CELL HAD A LENGTH OF 4. CM, A HAVAR ENTRANCE",
                " WINDOW OF 3.3 MG/CM**2, A 1MM THICK TANTALUM BEAM",
                " STOP, AND WAS FILLED TO 1.5 BAR WITH D(2). IT WAS",
                " COOLED BY A JET OF COMPRESSED AIR."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NATURAL CR VACUUM DEPOSITED ON TA.",
                ".NATURAL FE AND NATURAL NI FOILS.",
                ".ALL ABOUT 3 MG/CM**2, 25 MM DIAM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " ALPHA PARTICLES MEASURED AT 5 ANGLES WITH",
                " TELESCOPE DETECTORS IN A REACTION CHAMBER."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " THE BEAM CHARGE INTEGRATOR SERVED AS NEUTRON",
                " MONITOR LINKING THE DIFFERENT RUNS SINCE THE",
                " DEUTERIUM GAS TARGET FOR THE D-D SOURCE WAS VERY",
                " STABLE."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SOLST"
              ],
              "free_text": [
                " MEASUREMENTS ARE DONE AT 5 ANGLES.",
                " AT EACH ANGLE A TELESCOPE IS MOUNTED CONSISTING",
                " OF 2 PROPORTIONAL COUNTERS AND 1 SI SURFACE BARRIER",
                " DETECTOR IN A TRIPLE COINCIDENCE ARRANGEMENT. THE",
                " PROPORTIONAL COUNTERS ARE OF THE SINGLE WIRE TYPE",
                " (0.05 MM DIAM TUNGSTEN, GOLD-PLATED) WITH A GAS",
                " FILLING OF 80 MBAR OF C-H(4). THE SOLID STATE",
                " DETECTORS HAD A DIAMETER OF 25 MM. ONLY 2 PAIRS",
                " OF PROPORTIONAL COUNTERS ARE USED. PAIR 1 IS USED",
                " IN CONJUNCTION WITH THE SOLID STATE DETECTORS AT",
                " 109.43, 52.50, AND 16.07 DEFREES AT THE SAME TIME.",
                " PAIR 2 IS USED FOR THE SOLID STATE DETECTORS AT",
                " 141.03 AND 79.82 DEGREES."
              ]
            }
          ],
          "PART-DET": [
