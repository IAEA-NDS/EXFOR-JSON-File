          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2BLGMOL"
              },
              "free_text": [
                " The BR1 reactor at Mol, Belgium,",
                " was used in the calibration measurements.",
                "   Thermal neutrons, used for the calibration."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MOMIX"
              ],
              "free_text": [
                " The energy and mass characteristics were deter-",
                " mined with the double-energy method."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Fission fragments were detected with two",
                " collinear surface barrier detectors. The detector",
                " constants were determined from the pulse-height",
                " spectra of thermal neutron-induced fission of 239-Pu."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A homogeneous mixture of the spontaneously fissioning",
                " Pu-isotope and 239-Pu, were evaporated on a very thin",
                " transparent backing. The 239-Pu was used for",
                " calibration."
              ]
            }
          ],
          "CORRECTION": [
