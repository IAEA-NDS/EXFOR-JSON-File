          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For thermal energy region - Maxwell energy distr.",
                " For resonance energy region - energy area near the",
                " single strong low-energy resonance. Second Energy",
                " point (energy of first main resonance) was not",
                " present in the main reference and  was taken from",
                " ENDF/B-6.8 (MF=2,MT=151).",
                "*Aprx 2.x 10**11 neutrons per second  source intensity",
                "  was defined by MCNP code calculations and",
                "  irradiation of gold and tungsten samples. Flux of",
                "  1.x 10**8 n/cm2/sec in 0.1 eV - 10 keV energy range."
              ]
            }
