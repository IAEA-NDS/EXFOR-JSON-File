                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " cross section=98.8 b,res.",
                " Integral = 1535 b, g-factor (temper.= 20 C) = 1.005",
                " assumed values for thermal cross sections,Mn-55 =",
                " 13.3 b, Sb-121 = 6.3 b, Sb-123 = 4.0 b, La-139 =",
                " 8.7 b and In-115 = 160 b.",
                " Assumed values for g-factors(temper.= 20 C), In-115=",
                " 1.019 and for all others nuclides = 1."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For the deviation of the cross section of In-115",
                " from the 1/V-law in Maxwellian region (between",
                " 0.12 eV and 0.55 eV)",
                " Resonance self-shielding for gold and indium alloys."
              ]
            }
