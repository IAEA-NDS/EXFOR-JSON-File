          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-SCATTERING OF SLOW NEUTRONS BY THE ISOTOPES OF",
                " CHLORINE-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FRM RESEARCH REACTOR,AT 4 MW THERMAL POWER."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " NEUTRON BEAM COMING OUT OF A NEUTRON GUIDE",
                " TUBE OF FRM REACTOR.",
                ".FOR TOTAL C.S. MEASUREMENTS,NEUTRONS WERE SELECTED",
                " FROM THE REACTOR BEAM ENERGY SPECTRUM BY MEANS OF",
                " SPECIAL CONTINUOUSLY OPERATING RESONANCE DETECTORS",
                " BUILD UP WITH ROTATING FOILS.NEUTRON RESONANCE MEAN",
                " ENERGY WAS ASSUMED TO BE 1.257 EV FOR RHODIUM FOILS,",
                " AND 5.19 EV FOR SILVER FOILS."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "        NOT EXPLICITLY STATED BY AUTHORS,WHO JUST GAVE",
                " THE MEAN NEUTRON WAVE LENGTH,THAT WAS 13 ANGSTROMS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR COH.SCT.LENGTH MEAS.,CHRISTIANSEN FILTERS",
                " CONSISTED OF A GRAINED POWDER COLUMN OF DRIED AND",
                " CHEMICALLY PURE NACL.MIXED WITH LIQUIDS (C6D6,C7H16,",
                " C8H10)IN DIFFERENT PROPORTIONS.ISOTOPIC ANALYSIS WAS",
                " FOR THE FIRST SAMPLE,99.73 PC OF CL-35 AND 0.27 PC",
                " OF CL-37,",
                " FOR THE SECOND ONE,1.79 PC OF CL-35 AND 98.21 PC OF",
                " CL-37,",
                " FOR BOTH OF THEM DEUTERIUM WAS 99PC IN BENZENE(C6D6),",
                " AND THE WEIGHT OF NA-CL WAS 0.16 GRAM.",
                ".AT 20 DEGREES C.,MEASURED DENSITIES WERE IN G/CM3",
                " 2.147 FOR NA-CL35,",
                " 2.219 FOR NA-CL37,",
                " 0.94835 FOR C6-D6,",
                " 1.59403 FOR C-CL4,",
                " 1.62264 FOR C2-CL4,",
                " 0.86154 FOR C8-H10(CHEMICAL PURITY 99.95 PC),",
                " 0.68372 FOR C7-H16.",
                ".FOR TOTAL C.S. MEAS.,SAMPLES OF PURE(99.92 AND 99.98",
                " PC) C-CL4(1.2455E+22 MOLECULES/CM2) AND C2-CL4",
                " (1.176E+22 MOLE./CM2),OF WHICH MEASURED SCATTERING",
                " DENSITIES WERE RESPECTIVELY 28.071E+9 1/CM2 AND",
                " 30.414E+9 1/CM2.",
                " SAMPLE TEMPERATURE WAS 20 DEGREES CELSIUS."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MOMIX"
              ],
              "free_text": [
                " FOR THE COHERENT SCATTERING LENGTH MEASUREMENTS",
                " FOR BOUND ATOMS OF CHLORINE ISOTOPES CL-35 AND CL-37,",
                " METHOD OF SMALL ANGLE SCATTERING OF VERY SLOW NEUTRON",
                " BEAM BY MEANS OF CHRISTIANSEN FILTERS WAS USED.",
                ".FOR EXPERIMENTAL ARRANGEMENT AND DETAILS SEE ZN/A,26,",
                " 391,1971."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDEG"
              ],
              "free_text": [
                " ROTATING RHODIUM FOILS(NEUTRON RESONANCE MEAN",
                " ENERGY FOR RH,E=1.257 EV),OR SILVER FOILS(E=5.19EV).",
                ".FOR EXPERIMENTAL ARRANGEMENT,DETAILED DESCRIPTION OF",
                " THIS METHOD,AND EVALUATION PROCEDURE REFER TO ZN/A31."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR COHERENT SCATTERING LENGTH MEASUREMENTS,SEE",
                " Z.NATURFORSCH.26A,391(1971).",
                ".FOR TOTAL C.S. MEAS. SEE Z.NATURFORSCH.31A,115(1976)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE DENSITIES WERE MEASURED PYCNOMETRICALLY AND FOR",
                " THE ISOTOPICALLY ENRICHED COMPOUNDS THEY WERE",
                " CALCULATED FROM THE DENSITY OF NATURAL COMPOUND.",
                ".AUTHORS ASSUMED FOR SCATTERING LENGTH OF SODIUM",
                " 3.63+-0.02 FERMI."
              ]
            }
          ],
