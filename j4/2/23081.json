          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                "  Anti-Compton NaI(TL) spectrometer located",
                " 86 cm from the sample at an angle of 125 degrees with",
                " respect to the proton beam's direction. The main",
                " detector of the spectrometer was a 15.2-cm-diameter",
                " 20.3-cm-long NaI(TL) detector and was centered in a",
                " large hollow Compton-suppression NaI(TL) detector",
                " with an outer diameter of 33.0 cm and a length of",
                " 35.6 cm. The energy resolution of the main detector",
                " was 7.0 % (FWHM) at 0.662 MeV, and the time resolution",
                " was 4.0 ns (FWHM) for 0.511-MeV gamma-rays."
              ]
            }
