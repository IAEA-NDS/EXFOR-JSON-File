          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".EXPERIMENT WAS A MEASUREMENT OF THE RATIO BETWEEN THE",
                " N-D AND N-P ELASTIC DIFFERENTIAL CROSS SECTION WHERE",
                " WHERE THE N-P CROSS SECTION WAS CALCULATED FROM THE",
                " FORMULA BY LOMON AND WILSON, PHYS.REV,C9,(1974) 1329.",
                ".MEAN SCATTERING ANGLE IN THE 180 DEGREE DATA WERE",
                " ABOUT 170 DEGREES AND THE DATA WERE TRANSFERED TO 180",
                " DEGREE USING DIFFERENT ASSUMED SHAPES OF THE ANGULAR",
                " DISTRIBUTION."
              ]
            }
          ],
