                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "The number of fission in the U-235 source was monitored",
                " by measuring the activity of La-140 relative to a",
                " calibration foil in an absolute ionisation chamber.",
                "No value given."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
