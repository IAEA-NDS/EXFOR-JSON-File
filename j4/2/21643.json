              },
              "free_text": [
                "",
                " Metal foils of 7.5 mm diameter, 35 mg in weight."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples transferred pneumatically to and from the",
                " irradiation position where a constant thermal flux",
                " was maintained.",
                "After each irradiation the delayed neutron emission",
                " rate was measured in a detector consisting of a water",
                " bath containing BF3 counters."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Water bath containing BF3 counters in cylindrical",
                " aluminium tubes of O.D. 26 mm, active length 310 mm",
                " filled with 96% B-10.",
                "The efficiency was calibrated with a standard Am/Li",
                " source from National Physical Laboratory which was",
                " itself calibrated to 0.5% using a manganese sulphate",
                " bath."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured neutron decay curve was fitted to the sum of",
                " five exponential decaying groups by a least square",
                " method."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "92-U-235(N,F)57-LA-140,CUM,FY,,MXW",
