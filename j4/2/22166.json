          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THERMAL REACTOR SPECTRUM."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THREE TARGETS, EACH HOUSED IN CYLINDERS OF REACTOR",
                " GRAPHITE, WERE USED IN THE EXPERIMENT:"
              ]
            },
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                ". 290 MG ENRICHED 24-MG2P2O7, 24-MG ENRICHMENT 99.5%",
                " AND 31-P MONOISOTOPIC, AND APPROX. 0.2 MG NACL OF",
                " NATURAL COMPOSITION."
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
                ". 298 MG OF 99.5% ENRICHED 24-MGO AND APPROX. 0.2 MG OF",
                " NACL. THIS WAS USED TO IDENTIFY CONTAMINATION LINES",
                " FROM 25-MG AND BACKGROUND."
              ]
            },
            {
              "pointer": "3",
              "coded_information": null,
              "free_text": [
                ". TARGET WITH SAME COMPOSITION AS TARGET 1."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "1",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " 30% EFFICIENT, RESOLUTION 2.3 KEV FWHM AT",
                " 1.33 MEV, WAS USED TO SCAN THE LOW ENERGY (50 KEV -",
                " 3 MEV) AND FULL SPECTRA (50 KEV - 9 MEV) OF TARGET 1.",
                " DIFFICULT ENERGY AND EFFICIENCY CALIBRATION USING",
                " VARIOUS LINES FROM 208-PB, 13-C, 25-MG, 36-CL, 28-AL,",
                " 32-P."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                " AS ABOVE, FOR TARGET 2."
              ]
            },
            {
              "pointer": "3",
              "coded_information": [
                "BPAIR"
              ],
              "free_text": [
                " USED FOR THE HIGH ENERGY (ABOVE 1.5 MEV) PART",
                " OF THE SPECTRUM FROM TARGET 3 , RESOLUTION BETWEEN",
                " 3.1 KEV FWHM AT 2 MEV AND 6.5 KEV AT 8 MEV. THE ENERGY",
                " AND EFFICIENCY CALIBRATION USED THE LINES FROM THE",
                " 35-CL(N,G) REACTION."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " MEASUREMENT OF GAMMAS FROM THERMAL CAPTURE."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE TRANSITION ENERGIES HAVE NOT BEEN CORRECTED FOR",
                " RECOIL."
              ]
            }
          ],
