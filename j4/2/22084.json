              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NB-93(N,XP), AG-NAT(N,XP), AND IN-NAT(N,XP) REACTIONS",
                " AT 14.1 MEV."
              ]
            }
          ],
          "AUTHOR": [
