          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " ThO2 powder in an alminum can. Sample thickness",
                " was about 2.2 g/cm**2.",
                " Chemical separation was done to remove radioactive",
                " daughters, and the sample was heated to remove water.",
                " B-10 powder in an alminum can, enriched to 93%"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A pair of C6D6 liquid scintilators (NE230)",
                " 11 cm in dia. and 5 cm thick, located at 12 m on",
                " flight path."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " After dead time correction, data in each channel were",
                " added in energy interval of 0.1 lethergy unit. The",
                " capture cross section was measured relatively to the",
                " B-10(n,alpha,gamma) cross section and the Th-232(n,g)",
                " cross section at 24 keV. See MONITOR."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
