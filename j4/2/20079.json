          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " thermal neutrons",
                " blocked off by a cadmium absorber of 1.5 mm thick."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Collimated neutron beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Tin-indium alloy, 2.5% indium alloyed with the tin",
                " backing material, discs of 20 mm in diam. and",
                " 50 micron thickness.",
                " Cadmium absorber for thermal neutrons 1.5 mm thick.",
                " The In-content was determined as having a value of",
                " 0.9688 +- 0.002 mg/cm2 at 293.degr.Kelvin.",
                " At 4.2 degr.Kelvin, a minor deviation of the surface",
                " density of 0.9815 +- 0.002 mg/cm2 was noted."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Two discs stuck to each other and thereby formed",
                "a foil sandwich.",
                " Self-indication by variation of the  temperature."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Ratio of saturation for the foil",
                " without absorber and the foil with absorber,",
                " measurements at two different temperatures",
                " (4.2 and 239 degrees Kelvin) yield the",
                " two resonance parameters gamma and sigma(r)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The activities of both discs were measured",
                " simultaneously in two counters of 2Pi geometry, where",
                " one counter was calibrated in relation to the other."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For side resonances, 1/V contribution and",
                " influence of the cadmium wing, computer evaluation."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
