          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Prompt nu-bar values of U-235 and Pu-239 in some",
                " fast reactor spectra"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2SWDFOA"
              },
              "free_text": [
                " Fast zero-power reactor(FRO) at Studsvik",
                "The cylindrical reactor core consisting of uranium",
                "                               (20% enrichment)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "     The neutron beam from the interior or the",
                "  critical assembly. Moderator materials (graphite and",
                "  polyethylene), a copper reflector.",
                ".The neutrons were extracted through a narrow hole from",
                " the centre of the core region and entered a 13 meter",
                " long evacuated beam tube through aluminium windows.",
                " Two collimators of borated paraffin were placed inside",
                " the beam tube to give a well-defined beam which",
                " entered the fission chambers (U-235 and Pu-239).",
                " These were placed in the middle of the scintillator",
                " tank."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The fissionable materials were electrodeposited",
                " onto 3 thin concentric cylinders and housed in",
                " thin-walled (0.2 mm of aluminium) ionization chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                "    Coincidences between fission fragments and",
                "           prompt neutrons."
              ]
            }
          ],
