          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal Maxwellian neutron spectrum from HFR."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                "   Alpha particles selected by telescope",
                " detector.",
                " In the case of U-233 and U-238 no aluminium absorber",
                " was placed in between sample and detector. In the case",
                " of U-235 an aluminium foil was used to protect the",
                " de-detector against the fission fragments and the",
                " LRA's.",
                " In the case of Th-232 and Pu-239 it was not specified",
                " if there was such an absorber."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " Telescope detector, consisting of",
                " two Si(Au) surface barrier detectors.",
                " The dE-detector was fully depleted, with a thickness",
                " of 26.7 microns, an active area of 300 mm**2, an",
                " energy resolution of 35 keV for 5.5 MeV alphas.",
                " The E-detector had a thickness of 700 microns, an",
                " active area of 450 mm**2, and a resolution of 25 keV",
                " for 5.5 MeV alphas.",
                " The detectors were calibrated with the alpha lines of",
                " the spontaneous decay of the U-isotopes, the 2.055 MeV",
                " alpha line from Li-6(n,t) and the 9.43 MeV alpha line",
                " from the Nd-143(n,alpha) reaction."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For the energy losses in the aluminium absorber."
              ]
            }
          ],
