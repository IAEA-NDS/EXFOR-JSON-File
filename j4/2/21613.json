          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "GELI",
                "NAICR"
              ],
              "free_text": [
                " Ge(Li) detector equipped with",
                " a compton suppression system. The coaxial Ge(Li)",
                " had an efficiency of 15% and a resolution",
                " of 2.1 keV FWHM at 1.33 MeV.",
                " The Compton suppression system consists of an",
                " 8 in diam.*8 in annular NaI(Tl) detector",
                " surrounding the Ge(Li) and a 2.5 in diam*2.5",
                " in NaI(Tl) detector on the top hole of the",
                " annular crystal, both in anticoincidence with the",
                " Ge(Li) detector."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "DG"
              ],
              "free_text": [
                " Decay gammas."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For losses under the gamma peak by coincidences",
                " with annihilation gammas.",
                ".For accidental coincidences."
              ]
            }
          ],
