          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENTS OF NEUTRON ACTIVATION CROSS SECTIONS AT",
                " 14.4 MEV FOR ZN-68 AND ZR-90-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NEUTRON GENERATOR IN A FACILITY CALLED 'KORONA',",
                " KOMBINIERTE ROHRPOST-NEUTRONENGENERATOR-ANLAGE,",
                " DESCRIBED IN GKSS-81-E-53."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " THE NEUTRON FLUX AT THE IRRADIATION POSITION",
                " WAS ESTIMATED TO BE 5*10E+10 N/CM-SQ*SEC."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE SAMPLES WERE PREPARED FROM POWDER OXIDE,99.0 PER",
                " CENT PURITY. THE IRRADIATION CAPSULES WERE MADE OF",
                " POLYETHYLENE WITH A DIAMETER OF 1.40 CM AND A HEIGHT",
                " OF 0.90 CM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " ACTIVATION OF THE SAMPLES WHICH AFTER THE",
                " IRRADIATION WERE TRANSPORTED FROM THE INTERIOR OF THE",
                " OF THE NEUTRON TUBE TO A 16 M DISTANT DETECTOR WITH A",
                " PNEUMATIC RABBIT SYSTEM. FOR PRODUCTS WITH SHORT HALF-",
                " LIVES SO CALLED CYCLIC ACTIVATION WAS USED."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " GELI DETECTOR."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE EFFICIENCY OF THE DETECTION SYSTEM WAS MADE WITH A",
                " STANDARD RADIOACTIV SOLUTION IN A SAMPLE CAPSULE."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE NEUTRON FLUX WAS MONITORED BY MEANS OF A BF3 TUBE",
                " IN A LONG COUNTER WHICH WAS CALIBRATED WITH THE REACT."
              ]
            },
