          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of thermal-neutron capture cross-section",
                "of Cesium-135 by applying mass spectrometry"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Nakamura",
                "Y.Shibahara",
                "A.Kimura",
