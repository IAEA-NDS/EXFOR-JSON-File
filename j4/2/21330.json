                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Tritium gas cell through a 2 mg/cm2 nickel",
                "window which was supported on a gold grid."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": [
                "EN-RSL-HW"
              ],
              "free_text": [
                " Energy spread value"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The germanium crystal used as both target and detector",
                "had. an area of ~ 1.5 cm2 and a thickness of ~1 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Detection of inelastic gammas. The cross section for",
                " inelastic scattering to the pair of levels near 5",
                " 80 keV using a neutron detection method."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " The neutron flux at each energy was measured",
                "with a fission counter containing a known mass of 237Np"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " A long counter 1.5 m from the target monitored",
                "neutrons from the reaction at 45. degr."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made to the neutron flux deduced at",
                "the detector position to allow for neutron attenuation",
                "and scattering. The attenuation of neutrons in the",
                "aluminium vacuum container was calculated to be 4.5%",
                "scattering from the cold finger materials 4%."
              ]
            }
          ],
