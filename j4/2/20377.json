          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Cross-section measurement for the threshold reactions",
                "Fe56(N,P)Mn56,Co59(N,a)Mn56 and Cu63(N,2N)Cu62 between",
                "12.6 and 19.6 MeV neutron energy -."
              ]
            }
          ],
          "FACILITY": [
