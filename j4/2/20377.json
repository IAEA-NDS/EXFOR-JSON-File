          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-1(N,EL)1-H-1,,SIG",
                  "code_unit": [
                    {
                      "unit": "1-H-1(N,EL)1-H-1,,SIG",
                      "field": {
                        "reaction": "1-H-1(N,EL)1-H-1",
                        "target": "1-H-1",
                        "projectile": "N",
