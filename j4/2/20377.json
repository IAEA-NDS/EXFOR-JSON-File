              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "   T(d,N)He4-reaction at 1 and 3 MeV deuteron",
                " energy using various emission angles"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Metallic",
                ".Discs 20 mm diameter, 5 mm thickness"
