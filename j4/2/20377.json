                        "product": "1-H-1",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " Absolute measurement of the",
                " neutron flux was preformed with a proton recoil",
                " telescope of the Los Alamos type. The semi-empirical",
                " formula of gammel in fast neutron physics was used",
                " for the total N-P scattering cross section.",
                ".The relative excitation functions were normalised",
                " at 14.05 MeV for Co-59 and Cu-63, and at 14.80 MeV",
                " for Fe-56. The reproducibility of the absoute",
                " measurements was better than 0.7 percent."
              ]
            }
          ],
