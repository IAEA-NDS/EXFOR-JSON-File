              "free_text": [
                "",
                " = 1.64 ON THE PEAK OF THE",
                " 56.3 EV RESONANCE, TAKEN FROM",
                " DE SAUSSURE+, ORNL-TM-1804(1976)."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                "  NEUTRONS."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " AS A CONCLUSION, THE FISSION CROSS-SECTION OF U-235",
                " SHOWS A PRONOUNCED STRUCTURE OF MAGNITUDE VARYING",
                " FROM UP TO 30 PER CENT IN THE REGION OF 20 KEV TO AT",
                " LEAST 5-10 PERC. NEAR 100 KEV AND THE",
                " ASSUMPTIONS THAT THE CROSS-SECTION IS SMOOTH ARE",
                " CERTAINLY NOT VALID."
              ]
            }
          ],
