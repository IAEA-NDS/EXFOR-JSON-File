          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-STRUCTURE IN THE FISSION CROSS-SECTION OF U-235.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                "    THE 45 MEV HARWELL LINEAR ACCELERATOR."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "PHOTO"
                ],
                "reaction": null
              },
              "free_text": [
                ")   PHOTO-NEUTRON WITH BOOSTER, TAKING DECAY",
                " TIME OF THE BOOSTER INTO ACCOUNT, THE NOMINAL",
                " RESOLUTION WAS 2 NSEC/M."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A DISC OF 93 PERCENT U-235, 7.9 CM DIAMETER",
                " AND A THICKNESS OF 1.086 * E-3 ATOMS U-235/BARN."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "    TIME OF FLIGHT, FLIGHT PATH = 97.5 M."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "     THE LIQUID SCINTILLATION COUNTERS USING",
                " PULSE SHAPE DISCRIMINATION TO REJECT GAMMA RAY EVENTS.",
                " THE INCIDENT NEUTRON SPECTRUM WAS MEASURED WITH A"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "  0.32 CM THICK LI GLASS SCINTILLATOR, A",
                " NE 905, AND A PHOTOMULTIPLIER MOUNTED DIRECTLY BEHIND",
                " IT BUT SEPARATED FROM THE SCINTILLATOR BY 5.25 CM AIR",
                " TO REDUCE THE EFFCT OF SCATTERED NEUTRONS FROM PHOTO-",
                " MULTIPLIER."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " AT LOWER ENERGIES, WHERE THE PEAK  X-SECTS. ARE HIGH,",
                " N*SIGMA IS MUCH LARGER THAN 1 AND THE FISS.NEUT.YIELD",
                " IS ROUGHLY PROPORTIONAL TO ETA.",
                " AT HIGHER ENERGIES, N*SIGMA IS MUCH LESS THAN 1 AND",
                " THE FISS.NEUT.YIELD IS PROPORTIONAL TO THE FISSION",
                " X-SECT. WHICH IS THEREFORE MEASURED DIRECTLY.",
                " THE FISSION X-SECT. IS THUS FOUND FROM A COMBINATION",
                " OF TRANSMISSION, YIELD AND SPECTRUM MEASUREMENTS.",
                ".SINCE THE RATIO GAMMA-N/GAMMA IS VERY SMALL IN U-235,",
                " THE SCATTERING X-SECT. IS ASSUMED TO BE EQUAL TO",
                " THE POTENTIAL SCATTERING CROSS SECTION OF 11.70 BARNS",
                " DEDUCED BY UTTLEY, AERE-M 1272 (1963).",
                ".(PROMPT NU-BAR) IS ASSUMED TO HAVE CONSTANT VALUE OF",
                " 2.430."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "92-U-235(N,ABS),,ETA",
                  "code_unit": [
                    {
                      "unit": "92-U-235(N,ABS),,ETA",
