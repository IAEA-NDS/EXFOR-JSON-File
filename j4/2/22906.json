          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SHAPE"
              ],
              "free_text": [
                "   The resonance parameters for Rh-103 were",
                " obtained from a simultaneous shape analysis of the",
                " capture (from 300 eV to 10millieV) and transmission",
                " (from 300 eV to 0.5 eV) data using the REFIT-code.",
                "  The resonance energy and neutron width for each",
                "  resonance were determined in the  simultaneous fit,",
                "  as well as an average radiation width average",
                "  =161.0+-0.2 milli-eV for all resonances,",
                "  independent of the resonance spin."
              ]
            }
          ],
