          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-ELASTIC SCATTERING OF 28 MEV NEUTRONS BY DEUTERONS.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": null
              },
              "free_text": [
                "  SYNCHROCYCLOTRON, 27 MEV DEUTERONS WITH",
                " A MEAN CURRENT OF 10 MICRO-A OF AN EXTERNAL BEAM."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "    H2(D,N)HE3 REACTION, LIQUID DEUTERIUM COOLED",
                " WITH LIQUID HYDROGEN."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " THE MEAN ENERGY OF THE NEUTRON WAS 28 MEV WITH A FWHM",
                " OF 1.6 MEV. THE INTENSITY WAS 0.5E+8 NEUTRON/SR."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " (14*21) MM**2 C-D(2) FOILS, OF FOUR DIFFERENT",
                " THICKNESS WERE USED, 0.11, 0.25, 0.49 AND 1 MM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "    TIME OF FLIGHT, FLIGHT PATH = 4 M."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "  FOUR PLASTIC NE 102A SCINTILLATORS,",
                " 10 * 10 * 70 CM FOR DETECTING THE SCATTERED NEUTRONS,",
                " THE LARGE SIZE OF DETECTOR PROVIDED A HIGH EFFICIENCY",
                " OF THE ORDER OF 25 PERCENT.",
                ".THIN PLASTIC NE 102A SCINTILLATOR FOR DEUTERON",
                " DETECTION,  THE THICKNESS WAS ADJUSTED TO THE NEUTRON",
                " ENERGY (FROM 0.5 MM TO 1.3 MM).  THIS DETECTOR WAS",
                " PLACED 10 CM BEHIND THE SCATTERER.",
                ".THE INCIDENT NEUTRON WAS MONITORED BY A CURRENT",
                " INTEGRATOR AND A LIQUID SCINTILLATOR."
              ]
            }
          ],
