          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Combining proton energy and target thicknesses",
                " different energy spectra were obtained.",
                " (i) For proton energy close to reaction threshold",
                "     1881 keV one obtains a quasi-Maxwellian spectrum",
                "     with kT=25 keV.",
                " (ii) Very close to reaction threshold a narrow spec-",
                "      trum between 12 and 52 keV was obtained.",
                " (iii) Using four higher proton energies one obtains",
                "       four different neutron energy spectra with",
                "       energy widths 20-50 keV"
              ]
            }
          ],
