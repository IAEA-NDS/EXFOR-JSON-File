          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Measurement of the Co-59(n,alpha)Mn-56,",
                " Co-59(n,p)Fe-59 and Co-59(n,2n)Co-58m+g cross",
                " sections between 8 and 14 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "W.Mannhart",
                "D.Schmidt",
                "X.Haihong"
