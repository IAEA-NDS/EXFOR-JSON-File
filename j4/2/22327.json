              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2GERPTB"
              },
              "free_text": [
                " The compact cyclotron CV-28 at PTB,",
                " Braunschweig, Germany."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " The deuterium gas cell was 3 cm long",
                " with a gas pressure of 0.2 MPa."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The neutron energy was determined by time-of-flight",
                " measurements. The mean neutron energy was obtained to",
                " within +- 20 keV and the energy resolution varied",
                " between 134 keV at 8.1 MeV and 106 keV at 14.3 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The cobalt samples were attached to the",
                " entrance window of a low-mass fission chamber",
                " and were irradiated at zero degrees at a distance",
                " of 6 cm from the gas target. The activity of the",
                " irradiated samples was measured with a HPGe",
                " detector."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A 300 cm3 HPGe detector was used."
              ]
            }
          ],
          "PART-DET": [
