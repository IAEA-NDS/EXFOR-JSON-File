          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Thickness chosen to give an average transmission of",
                " about 0.5. rare elements in form of 'Specpure' oxides,",
                " which were heated to 900. degr. approximately for",
                " 10 hours to remove water, which may be present in the",
                " samples. Afterwards these oxides were loaded into",
                " Al containers and then compressed to ensure a uniform",
                " sample. The other elements were in the form of pure",
                " metal."
              ]
            }
          ],
