          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Absolute determination of activation cross-sections",
                " for 14.7 and 14.8 MeV neutrons"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
