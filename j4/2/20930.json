                  "VDG"
                ],
                "institute": "2UK BIA"
              },
              "free_text": [
                " Van de Graaff producing 300 keV deuterons",
                "        SAMES accelerator giving 140 keV deuterons."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "   Deuterium-tritium, target thickness large",
                "        compared with range of incident deuterons."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Neutron energy spectra from target computed by the",
                " method of J.Benveniste and J.Zenger, report number",
                " UCRL 4266. Mean neutron energy was 14.7 MeV at 140",
                " keV deuteron energy and 14.8 MeV at 300 keV."
              ]
            }
          ],
