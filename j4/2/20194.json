          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-FAST NEUTRON RADIATIVE CAPTURE CROSS-SECTIONS FOR SOME",
                " IMPORTANT STANDARDS FROM 30 KEV TO 1.5 MEV.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                "    5.5 MV VAN DE GRAAFF AT STUDSVIK."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                "    PROTON-LITHIUM 7."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NEUTRON ENERGY RESOLUTIONS ARE 1 PERC. AT 30 KEV AND",
                " 7.5 PERC. AT 1.5 MEV. (= 4.5 NS/M)"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DISCS OF 5 CM DIA. AND 0.1 CM THICK.  PURITY BETTER",
                " THAN 99.9 PERCENT."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "    TIME OF FLIGHT, FLIGHT PATH  APPROX. 1.5 M."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                "    LIQUID SCINTILLATOR TANK OF APPROXIMATELY",
                " 200 LITRE VOLUME.  NE218 SCINTILLATOR.",
                " INSIDE THE DETECTOR IS OPTICALLY DIVIDED INTO TWO",
                " HALVES WHICH ARE IN COINCIDENCE. (TO IMPROVE SIGNAL TO",
                " NOISE RATIO)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                "    LONG COUNTER FOR NEUTRON FLUX MEASUREMENT.",
                ".NEUTRON ENERGY CALIBRATION OF THE SPECTRA WAS OBTAINED",
                " FROM KNOWN RESONANCES IN FLUORINE."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".IT MUST BE EMPHASISED THAT CROSS-SECTIONS GIVEN IN",
                " ABSOLUTE UNITS MUST BE CONSIDERED WITH CARE. BECAUSE,",
                " EVEN THE STANDARD LIKE GOLD, AT 30KEV (AS ONE EXAMPLE)",
                " THE CROSS-SECTIONS AS 596 MB (KOMPE, NUCL.PHYS.A133",
                " (1969)513) AND 515 MB (GIBBONS ET AL.,PHYS.REV.122",
                " (1961)182) ARE PRESENTED. SO THE CROSS-SECTIONS FOR",
                " MATERIALS MEASURED RELATIVE TO A STANDARD ARE STRONGLY",
                " DEPENDENT ON THE STANDARD USED. IT SEEMS RESONABLE",
                " TO EXPRESS CROSS-SECTIONS IN TERMS OF RELATIVE",
                " DIMENSION-LESS NUMBER."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".TAKEN FROM J.NUCL.EN.,27(1973)71."
              ]
            }
          ],
