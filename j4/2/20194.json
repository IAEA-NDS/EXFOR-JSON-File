          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NATURAL SELF SCREENING AND MULTIPLE SCATTERING",
                " CORRECTIONS VARY BETWEEN 6 AND 9 PERCENT."
              ]
            }
          ],
