          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-excitation functions of (n,t) reactions on",
                " Al-27, Co-59, and Nb-93."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
