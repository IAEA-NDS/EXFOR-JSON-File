          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A BROAD NEUTRON SPECTRUM WITH ENERGIES FROM 5 TO 70",
                " KEV. THE NEUTRONS PRODUCED IN THIS ENERGY RANGE ARE",
                " COLLIMATED KINEMATICALLY WITHIN ABOUT +- 30 DEG ,SO",
                " NEITHER BEAM COLLIMATION NOR DETECTOR SHIELDING WAS",
                " NECESSARY."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ALL SAMPLES USED (PU, U AND PB) ARE 4 CM",
                " DIAMETER METAL DISCS, 0.035 TO 0.05 ATOMS/BARN THICK,",
                " AND PACKAGED IDENTICALLY IN 0.2 MM THICK COPPER."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "    TIME OF FLIGHT FOR DETERMINATION OF INCIDENT",
                " NEUTRON ENERGY,",
                ".THE ESSENCE OF THIS EXPERIMENT IS APPLICATION OF",
                " A NEW TECHNIQUE TO DETERMINE THE ALPHA-VALUES,",
                " BASED SOLELY ON NEUTRON DETECTION.  IT CONSISTS OF",
                " SCATTERING, TRANSMISSION AND PROMPT FISSION NEUTRON",
                " MEASUREMENTS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
