          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "    Deuteron-tritium",
                " The circular zirconium layer of a diameter of 25 mm",
                "and a thickness corresponding with 200 mu-g/cm2",
                "contained 0.158 cm3 of tritium measured at standard",
                "temperature and pressure (0.42 Curie). The atomic",
                " ratio Zr/T was 1/1."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The scatterers were rings of different size, two of",
                "each element, in order to cover the range of angles",
                "from 15.degr. to 1.25 degr. Two lead rings of 2cm",
                "thickness, diameters 9.6 cm and 20 cm, two mercury",
                "rings of 1.6 cm thickness in thin plastic containers,",
                "diam. 11.2 cm and 17.6 cm and two zinc rings of 1.8 cm",
                "thickness, diam. 8.0 cm and 20 cm were used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "  Elastically scattered neutrons detected by a",
                "liquid scintillation counter with a liquid scintillator",
                "consisting of a  carbon-hydrogen compound. The pulses",
                "caused by the fast recoil protons measured."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " The production of neutrons during the",
                " experiments was monitored by a B-F(3)-counter."
              ]
            }
          ],
