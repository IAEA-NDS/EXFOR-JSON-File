          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NUCLEAR CHARGE DISTRIBUTIONS IN THE ISOBARS 92 TO",
                " 100 RESULTING FROM THERMAL NEUTRON FISSION OF",
                " URANIUM-235 -."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
