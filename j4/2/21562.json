              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " THERMAL NEUTRONS FROM HIGH FLUX REACTOR."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "MAXWELLIAN THERMAL NEUTRON SPECTRUM."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THIN U-235, ENRICHED TO 93 PERCENT U-235."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FISSION PRODUCTS ARE SEPERATED BY MASS AND KINETIC",
                " ENERGY WITH THE ON-LINE MASS SEPERATOR LOHENGRIN.",
                " THE ENERGY LOSS OF THESE SEPERATED PRODUCTS IN A",
                " DELTA-E DETECTOR DEPENDS ON THEIR NUCLEAR CHARGE.",
                " THE RESOLUTION AND PARTICLE INTENSITY ARE SUFFICIENT",
                " TO DETERMINE FRACTIONAL INDEPENDANT YIELDS IN THE",
                " LIGHT FISSION GROUP."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " SOLID STATE SILICON DETECTORS FOR BOTH",
                " DELTA-E AND E. AN 8 MICRO-M THICK DELTA-E SILICON",
                " DETECTOR ACHIEVED NUCLEAR CHARGE RESOLUTION",
                " OF 1/43."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DATA ARE WEIGHTED AVERAGES OF FROM FIVE TO EIGHT",
                " INDEPENDANT MEASUREMENTS. DATA IS BASED ON MEASUREMEN",
                " OF PRODUCTS COVERING ONLY ONE KINETIC ENERGY AND IONI",
                " CHARGE. ABOUT THREE QUARTERS OF THE ENERGY",
                " DISTRIBUTION AND ONE HALF OF THE IONIC CHARGE",
                " DISTRIBUTION CONTRIBUTE TO THE AVERAGE VALUES",
                " QUOTED."
              ]
            }
          ],
          "STATUS": [
