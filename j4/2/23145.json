          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " Spectrometer VERDI.",
                "19 large area silicon (PIPS) detectors to measure",
                "energy of the fission fragments;",
                "contemplated geometrical efficiency of 0.5 %.",
                "Start-detector (made from artificial poly-crystalline",
                "diamond -pCVDD) closely placed at the fission sample.",
                "Configuration consisting of one pCVD and a small PIPS",
                "detector of size 25 mm**2 separated by only 33 cm was",
                "used.",
                "Timing resolution was around 500 ps with conventional",
                "analogue electronics."
              ]
            }
          ],
