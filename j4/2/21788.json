          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The main goal of the experiment was   intercomparison",
                " of the thermal and the spontaneous fission data. The",
                " s.f. results are very similar, but strongly different",
                " from the n-th. data.",
                " Results are interpreted using the scission point",
                " model of Wilkins+ (PR/C,14,1832,1976)."
              ]
