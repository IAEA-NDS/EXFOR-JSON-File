          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Th-232 100%, Th(NO3)4.x H2O, 50 mg",
                ".U-235, 99.61%, UO2(NO3)2, 14.4 mu-g.",
                " The sources were wrapped in thin (~4 mg/cm2) aluminum",
