          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Precise measurement of cross sections for the",
                " Zr-90(N,2N)Zr-89 reaction from threshold to 20 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "1",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2AUSIRK"
              },
              "free_text": [
                " IRK accelerator. For the energy range 14",
                "        13.4 to energy steps 0.04 to 0.15 MeV."
              ]
            },
            {
              "pointer": "2",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2ZZZGEL"
              },
              "free_text": [
                " 7 MV Van de Graaff accelerator of Geel.",
                "                For the energy range 12.3 to 19.5 MeV.",
                "                Energy steps 0.2 to 0.8 MeV."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " T(d,N)He-4 reaction."
              ]
            },
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                "        Air-jet-cooled solid state Ti-t target."
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
                "        Solid state target of tritium occluded in",
                "        a 3.9 mg/cm**2 Y-layer on a 0.5 mm Cu-backing."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Natural Zr, purity gt. 99.8 per cent, 1 mm thick",
                ".Samples were fastened to the inner side",
                " of a 1 mm thick aluminium ring 20 cm in",
                " diameter with the target in the centre, arranged in",
                " steps of 6 and 12 degrees symmetric to the direction",
                " of the deuteron beam.",
                ".Each sample was packed together either with two or",
                " at least one aluminium foil for monitoring."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                ".Measurements were done relative to Al-27(N,a)Na-24."
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
                ".Neutron fluences were determined by means of a",
                " proton-recoil telescope at 0 degree, and",
                " differential neutron production cross sections.",
                ".Zr-89 activity measurements  started about 60 hours",
                " after the end of the irradiation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 12.7 cm * 12.7 cm NaI(Tl)  detector to",
                "        measure Zr-98-g,Na-24 gamma activities."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "CSICR"
              ],
              "free_text": [
                " To detect the recoil protons."
              ]
            }
          ],
