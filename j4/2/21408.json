          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Irradiation in the flux scanning tube of the",
                " B2 fuel element of the pluto reactor for 47 days."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The neutron spectrum in pluto has a temperature of",
                " 106 degrees and a large epithermal component ranging",
                " from 0.049 to 0.070 for the epithermal index."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Sample of three highly enriched plutonium isotopes,",
                " Pu-239 (99.9%), Pu-240 (99.4%) and Pu-242 (98.1%)",
                " were blended to give mixtures of known",
                " isotopic composition. For irradiation the plutonium",
                " mixtures were mixed with silica and evaporated to",
                " dryness as nitrate. Afer irradiation plutonium was",
                " chemically seperated then mass seperated."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ASEP"
              ],
              "free_text": [
                " Isotopic mass seperation using an A.E.I.",
                " Type M.S.5 mass spectrometer. 0.1 ug plutonium",
                " on tungsten filament surface ionisation source."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Alpha derived from changes in isotopic composition",
                " of plutonium mixtures from neutron capture",
                " and fission."
              ]
            }
          ],
