          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Photo-peak yields ratio of Sb-125 to Sb-124 was used",
                " to estimate the effective thermal neutron capture",
                " cross section of Sb-124. Values of detector efficiency",
                " 3.4E-03 and 8.6E-4 were used for 428-keV and 1.691-MeV",
                " gamma-rays, respectively.Photo-peak yields in spectrum",
                " were 121824 and 18695 counts for 428 keV and 1.691 MeV",
                " gammas, respectively."
              ]
            }
          ],
