          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-EXCITATION FUNCTIONS AND ISOMERIC CROSS-SECTION",
                " RATIOS FOR THE 90-ZR(N,P)90-Y-M,G AND",
                " 91-ZR(N,P)91-Y-M,G PROCESSES."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.M.QAIM",
                "M.IBN MAJAH",
                "R.WOELFLE",
                "B.STROHMAIER"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
