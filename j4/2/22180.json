                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "2AUSIRK"
              ],
              "free_text": [
                " B.S."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE ACTIVATION CROSS SECTIONS TO THE METASTABLE STATES",
                " 90-Y-M AND 91-Y-M WERE MEASURED PREVIOUSLY AND ENTERED",
                " UNDER EXFOR 22144."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2GERJUL"
              },
              "free_text": [
                " VARIABLE ENERGY COMPACT CYCLOTRON CV28."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " DEUTERON ENERGY VARIED TO PRODUCE QUASI-",
                " MONOENERGETIC NEUTRONS IN THE RANGE 6.5 TO 10.6 MEV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".HIGH PURITY NATURAL ZRO2 PACKED IN A POLYVINYL",
                " CHLORIDE CAPSULE OF 1.1 CM DIAM, 2.6 CM LENGTH AND",
                " 0.1 CM WALL THICKNESS. THE AL OR FE 200 MICRON MONITOR",
                " FOILS WERE ATTACHED AT THE FRONT AND BACK. THE SAMPLE",
                " WAS IRRADIATED IN THE 0 DEG DIRECTION.",
                ".MONITORED NEUTRON FLUX DENSITIES AT THE SAMPLE",
                " POSITION RANGED BETWEEN 8.2E+6 AND 2.7E+7 N/CM2/SEC."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " COUNTING WAS STARTED SEVERAL DAYS AFTER",
                " IRRADIATION TO ALLOW THE COMPLETE DECAY OF 90-Y-M AND",
                " 91-Y-M TO THE RESPECTIVE GROUND STATES."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " CHEMICAL SEPARATION OF YTTRIUM. THE CHEMICAL",
                " YIELD WAS ABOUT 80%, DETERMINED GRAVIMETRICALLY AND",
                " ALSO BY NEUTRON ACTIVATION ANALYSIS; THE TWO RESULTS",
                " AGREED WITHIN 5%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " LOW LEVEL B- COUNTING, PERFORMED OVER A PERIOD",
                " OF ABOUT ONE YEAR."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "DG"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".COUNT RATES CORRECTED FOR CHEMICAL YIELD, ABSORPTION",
                " IN THE COUNTER WINDOW, FINITE-SIZE GEOMETRY, DETECTOR",
                " EFFICIENCY.",
                ".DECAY RATES OF 90-Y-G AND 91-Y-G WERE CORRECTED FOR",
                " CONTRIBUTIONS FROM BACKGROUND NEUTRONS (GAS-OUT/GAS-IN",
                " RESULTS AND DEUTERON BREAKUP ON H-2 GAS)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ENERGY RESOLUTION (+- HWHM) FROM ENERGY SPREADS DUE TO",
                " ANGLE OF EMISSION."
              ]
            },
