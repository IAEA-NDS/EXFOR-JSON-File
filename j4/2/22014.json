            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Parallel plate type ionization chamber",
                " containing 90% Ar and 10% CH4"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " NE213 scintillation detector (15 m from the",
                " target) to measure mean energies and spread of source",
                " neutrons at an angle of 0 deg."
              ]
            }
          ],
