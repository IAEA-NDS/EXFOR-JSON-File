          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Electroplated on Pt plates (36 mm diam. 0.3 mm thick)",
                " sintered into oxides to fix on the plates.",
                "The deposition diameter was 25 mm.",
                "Each sample was placed back to back to a 235U sample",
                " in the fission chamber.",
                "The number of fissionable nuclei in the samples was",
                " determined by",
                " - 2pi alpha counting /Th-232/,",
                " - low geometry alpha counting /U-233,U-234/",
                " - thermal neutron irradiation /U-235/",
                "The samples were placed perpendicular to the beam at",
                " distances of 3 to 8 cm from the target."
              ]
            }
          ],
