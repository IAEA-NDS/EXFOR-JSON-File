              ],
              "free_text": [
                "",
                " The 439 keV level is considerably interfered",
                " with by the elastic peak. But a shape for elastic peak",
                " can be subtracted from the full spectrum to leave the",
                " inelastic spectrum."
              ]
            }
          ],
          "ERR-ANALYS": [
