          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".VARIOUS SHIELDINGS AROUND THE INTERFEROMETER PART",
                " INHIBITED TEMPERATURE INHOMOGENEITIES WITHIN THE",
                " CRYSTAL.",
                ".FINITE WAVE LENGTH RESOLUTION,ERRORS FROM DENSITY",
                " AND THICKNESS DETERMINATION,INDEX OF REFRACTION OF",
                " AIR AND LONG TERM DRIFTS WERE TAKEN INTO ACCOUNT."
              ]
            }
