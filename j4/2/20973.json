            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-TOTAL CROSS SECTIONS OF NA, MG AND SI FOR 2.8-5.2 MEV",
                " NEUTRONS-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2GERKFK"
              },
              "free_text": [
                "  VAN DE GRAAFF PRODUCING A 2 MEV BEAM OF",
                "        DEUTERONS. BEAM CURRENT MEASURED WITH NUCLEAR",
                "        RESONANCE GAUSSMETER TO 0.1 PERCENT PRECISION,",
                "        ENERGY STABILIZED TO 0.1 PERCENT."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "   HEAVY ICE TARGET CONDENSED ONTO A COPPER",
                "        BACKING. NEUTRON ENERGY VARIED BY USING",
                "        DIFFERENT ANGLES."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".TRANSMISSION METHOD USING TWO DIFFERENT EXPERIMENTAL",
                " ARRANGEMENTS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "  TRANSMITTED NEUTRONS DETECTED IN TWO DIFFERENT",
                "        WAYS-",
                "        1.EMMERICH SCINTILLATOR, 25 MM IN DIAMETER AND",
                "          20 MM THICK, COUPLED TO A DUMONT 6342 PHOTO-",
                "          MULTIPLIER TUBE. GAMMA RAYS ELIMINATED BY A",
                "          SUITABLE CHOICE OF DISCRIMINATOR BIAS.",
                "        2.STILBENE ORGANIC SCINTILLATOR COUPLED TO A",
                "          56AVP PHILIPS PHOTOMULTIPLIER WITH PULSE",
                "          SHAPE DISCRIMINATION TO ELIMINATE GAMMAS."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE FLUCTUATIONS IN THE TOTAL CROSS SECTIONS ARE",
                " INTERPRETED AS BEING DUE TO FLUCTUATIONS IN THE",
                " LEVEL DENSITY OF THE INTERMEDIATE NUCLEUS."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CORRECTION FOR SMALL BACKGROUND EFFECT BY REPLACING",
                " THE D2-O TARGET BY THE SAME THICKNESS OF H2-O. THIS",
                " CORRECTION HAS A MAXIMUM VALUE OF 3 PERCENT AT THE",
                " HIGHER NEUTRON ENERGIES.",
                ".NO CORRECTION FOR INSCATTERING WHICH WAS ESTIMATED TO",
                " BE LESS THAN 0.8 PERCENT AT ANY ENERGY."
              ]
            }
          ],
