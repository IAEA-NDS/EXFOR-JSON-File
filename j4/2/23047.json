              "pointer": "",
              "coded_information": [
                "AMS"
              ],
              "free_text": [
                "    accelerator mass spectrometry.",
                " Detection of Fe-55 atoms directly via AMS.",
                " Subsequent AMS measurements were done at Vienna",
                " Environmental Research Accelerator (VERA).",
                " Isotopic ratio Z(Fe55)/N(Fe54) was measured."
              ]
            }
          ],
