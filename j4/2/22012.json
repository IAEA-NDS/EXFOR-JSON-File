          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of cross sections for the reactions",
                "27Al(n,p)27Mg, 27Al(n,alpha)24Na and 27Al(n,alpha)24mNa",
                "in the energy region between 43 MeV and 8.3 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "W.Enz",
                "D.Kollewe",
