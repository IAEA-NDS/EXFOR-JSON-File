                "2GERTHS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ADP,42,(3),283,1985",
                "code_unit": [
                  {
                    "unit": "J,ADP,42,(3),283,1985",
                    "doi": null,
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "ADP",
                        "number": null,
