              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "DYNAM"
                ],
                "institute": "2GERTHS"
              },
              "free_text": [
                " Stuttgart University 4 MV dynamitron."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "A-BE"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons in the energy range 6.3 to 8.3 MeV",
                " were produced via the Be-9(alpha,n) reaction, using",
                " 1.86 to 2.76 MeV 200 uAmp alpha beams upon 0.52 um",
                " thick Be-layers on high-pressure water-cooled copper",
                " backings."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Two monoenergetic neutron groups were present, but",
                " the lower were always below the thresholds of the",
                " reactions studied."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Pure Al samples with 36 mm diameter and 20 mm",
                " thickness."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " For the short-lived Na-24-m product, a cyclic",
                " milli-second pulsed irradiation-activity measurement",
                " technique was utilized."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 40 cm3 Ge-Li detector were used for",
                " activity measurements."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A 5 cm diameter by 5 cm thick NE213 liquid",
                " scintillator with n-gamma discrimination,",
                " positioned at 90 degrees with respect to the neutron",
                " beam direction, was used for neutron flux",
                " measurements. The efficiency of this detector,",
                " with a threshold of 2.9 MeV, was determined to",
                " be 16.5% in the enrgy region considered."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections were applied for neutron attenuation",
                " and gamma self-absorption in the samples."
              ]
            }
          ],
