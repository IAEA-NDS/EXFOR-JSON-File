          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Measurement of the neutron-proton spin correlation",
                " coefficient Ayy at 90 degrees C.M. by elastic",
                " scattering of 13.7 MeV polarized neutrons from a",
                " polarized proton target."
              ]
            }
          ],
          "AUTHOR": [
