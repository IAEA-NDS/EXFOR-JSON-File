          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectrum linearization was performed using the 28Al",
                " level scheme and using cubic polynomials for the",
                " channel-energy dependence.",
                "The energy scale was normalised to the following gamma",
                " rays:",
                "  4945.319 +0.020 -0.004 keV gamma from 13C decay,",
                "  1690.980 +0.004 -0.006 keV gamma from 124Te decay,",
                " and these energies were measured relative to the",
                "  411.80441 +/- 0.00108 keV gamma from 198Au decay.",
                "The gamma intensities were calculated from an inner",
                " calibration using the data of Ishaq et al., 1972."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
