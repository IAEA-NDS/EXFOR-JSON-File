          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-GAMMA-RAY STRENGTH FUNCTIONS FOR RH-104,TM-170,",
                " AND AU-198.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2FR BRC"
              },
              "free_text": [
                " 4 MEV VAN DE GRAAFF, 10 NSEC PULSE",
                " WIDTH, 1 MHZ REPETITION RATE. THE PULSES WERE",
                " COMPRESSED TO A WIDTH OF ABOUT 1 NS BY A MOBLEY-",
                " TYPE BUNCHING SYSTEM. THE AVERAGE CURRENT ON THE",
                " COOLED TARGETS WAS ABOUT 4 MICRO-AMPERE."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " FOR THE 500 KEV NEUTRON PRODUCTION OR,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " AT HIGHER ENERGIES. METALLIC LI OR T",
                " ABSORBED IN TI ON TA OR AU BACKINGS. THE NEUTRON",
                " ENERGY SPREAD AMOUNTED TO 60-80 KEV, DEPENDING ON",
                " THE ENERGY."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".60 MM DIAM, 1.5 MM THICK (RH+AU) OR 3 MM THICK (TM),",
                " AT 73 MM FROM TARGET."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " CAPTURE GAMMA-RAY SPECTRA RECORDED AS A",
                " FUNCTION OF THE TIME OF FLIGHT. SPECTRA ARE",
                " RECORDED IN ANTI-COMPTON AND SINGLE ESCAPE MODE",
                " SIMULTANEOUSLY."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "NAICR",
                "NAICR"
              ],
              "free_text": [
                " 76 MM DIAM * 152 MM LONG NA-I-(TL)",
                " CRYSTAL (10 PERC RESOLUTION FOR THE 662 KEV CS-137",
                " GAMMA LINE) CENTERED IN AN ANNULAR NA-I-(TL)-CRYSTAL,",
                " 304 MM LONG, OUTER DIAM 279 MM, INNER DIAM 89 MM,",
                " (30 PERC RESOLUTION FOR 511 KEV GAMMA-LINE FROM",
                " NA-22).THESE DETECTORS ARE USED IN ANTI-COMPTON-MODE",
                " AND IN SINGLE-ESCAPE-MODE SIMULTANEOUSLY."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " PLASTIC TOF SCINTILLATOR FOR NEUTRON FLUX",
                " DETERMINATION."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " CALIBRATED LONG COUNTER FOR NEUTRON FLUX",
                " DETERMINATION."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".TIME-OF-FLIGHT INDEPENDENT GAMMA RAYS.",
                ".BACKGROUND.",
                ".TOF SLEWING FOR THE LOWER PULSE HEIGHTS.",
                ".ANISOTROPY OF THE NEUTRON FLUX.",
                ".TRANSMISSION OF NEUTRONS TRHOUGH THE SAMPLE AND THE",
                " AIR BETWEEN THE SAMPLE AND THE FLUX MONITOR.",
                ".MULTIPLE SCATTERING AND NEUTRON FLUX ATTENUATION IN",
                " THE SAMPLE.",
                ".GAMMA-EFFICIENCY.",
                ".GAMMA-ABSORPTION."
              ]
            }
          ],
