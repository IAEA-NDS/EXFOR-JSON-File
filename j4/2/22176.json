                ],
                "institute": "2GERMNZ"
              },
              "free_text": [
                " THE FAST PNEUMATIC TUBE FACILITY OF THE",
                " MAINZ TRIGA REACTOR."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " THE IRRADIATION POSITION IN THE REACTOR WAS",
                " WRAPPED IN A CD SHEET TO REDUCE GAMMA DOSE FROM",
                " 232-TH(N,G) AND WAS CHARACTERISED BY AN INTEGRATED",
                " FAST, EPI-CADMIUM NEUTRON FLUX OF THE ORDER OF",
                " 1.5E+12 NEUTRONS/CM2 (100 MILLI-SEC NEUTRON PULSE)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FAST REACTOR EPI-CADMIUM SPECTRUM WITH AN ESTIMATED",
                " MEAN EFFECTIVE NEUTRON ENERGY FOR 232-TH(N,F) OF 3 MEV"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".POLYSTYRENE CAPSULES FILLED WITH A SOLUTION OF 0.5 G",
                " 232-TH AS NITRATE IN 1.5 ML OF 2 M HNO3, CONTAINING",
                " 0.1 ML OF SATURATED SOLUTION OF NA2SO3, PLUS SUITABLE",
                " ADDED AMOUNTS OF IODINE CARRIER AND HOLD-BACK CARRIERS",
                " TE(6+), SN(2+) AND SB(3+). IRRADIATION TIMES WERE",
                " 100 MILLI-SEC."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " FAST AUTOMATED RADIOCHEMICAL SEPARATION USING",
                " PNEUMATIC TRANSPORT AND COMPUTER CONTROL. THE I AND BR",
                " WERE COLLECTED ON A PREFORMED AGCL FILTER LAYER BY",
                " ION EXCHANGE WITH A CHEMICAL YIELD OF ABOUT 90 %."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "RELFY"
              ],
              "free_text": [
                " THE HIGH SPIN ISOTOPES OF 134-,136-I USED AS",
                " INTERNAL STANDARDS TO MONITOR FISSION EVENTS AND",
                " CHEMICAL YIELD SINCE THEY HAVE NO BETA PRECURSORS.",
                " THE COMPLEX DECAY CURVE OF THE 1313 KEV GAMMA FROM",
                " 136H-I AND 136L-I WAS RESOLVED MATHEMATICALLY IN EACH",
                " EXPERIMENT."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " GROWTH AND DECAY CURVES AS A FUNCTION OF",
                " WAITING TIME BETWEEN END OF IRRADIATION AND CHEMICAL",
                " SEPARATION WERE ANALYSED TO EVALUATE THE FRACTIONAL",
                " INDEPENDENT YIELDS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " FIXED GEOMETRY COUNTING WITH AN EFFICIENCY",
                " CALIBRATED 155 CM3 HPGE DETECTOR, RESOLUTION 1.9 KEV",
                " AT 1333 KEV. INITIAL HIGH DEAD-TIMES CONTINUOUSLY",
                " CORRECTED USING A LOSS-FREE COUNTING MODULE."
              ]
            }
          ],
