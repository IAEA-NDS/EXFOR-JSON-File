              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Irradiations were in the flux scanning tube",
                " of the B2 fuel element for 48.35 days."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The PLUTO spectrum is Maxwellian with a temperature",
                " of 106 degrees and with a high epi-thermal index,",
                " ranging from 0.041 to 0.087"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Nitric acid solutions of mixtures of four highly",
                " enriched isotopes of plutonium, precipitated onto",
                " silica and sealed in silica phials under pressure."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ASEP"
              ],
              "free_text": [
                " Mass spectroscopy using an A.E.I. Type",
                " M.S.5 Spectrometer, with about 0.1 micro-g plutonium",
                " on a tungsten filament surface ionisation source.",
                " After irradiation samples were allowed to cool for",
                " six months, then plutonium was chemically seperated",
                " and used for the isotopic composition changes."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Value derived from changes in isotopic composition",
                " arising from neutron capture and fission.",
                " All measured ratios involving Pu-241 were corrected",
                " for radio-active decay using a half life",
                " of 13.29 +- 0.06 years.",
                "      - Note that this differs considerably from",
                " later acceped values but was not considered in the",
                " Re-analysis of 66PARIS. -"
              ]
            }
          ],
