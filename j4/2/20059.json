          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A relative measurement of the Li6(n,alpha)H3 reaction",
                " cross section in the range 1 < En < 600 keV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2SWDFOA"
              },
              "free_text": [
                " A pulsed van de Graaff accelerator,",
                "beam pulse =about 15 nanosec, repetition rate = 2 MHz,",
                "average beam current = 3 to 5 microA."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " Li-7(p,n)Be-7-reaction. Metallic lithium and",
                "Li-F targets evaporated onto silver backings. The",
                "proton beam was monitored by means of gamma rays from",
                "the F-19(p,alpha)O-16 reaction. The amount of LiF",
                "evaporated onto the backing was determined",
                "approximately by weighing on a microbalance. As a rule",
                "targets with 5-10 mu-g/cm2 were used."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Li-6 glass scintillator."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Flight path varied between 30 and 100 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Monitoring of the beam was also performed",
                "with a current integrator"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Li6 glass scintillator = sample,",
                " diameter = 1.9 and 3.8 cm, thickness = 0.9 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Na-I-(Tl) detector to monitor the proton",
                " beam."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Experimental data corrected for multiple scattering",
                " in the scintillator according to the Monte-Carlo",
                " calculations."
              ]
            }
          ],
