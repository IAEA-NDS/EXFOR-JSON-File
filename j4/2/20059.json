          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".In the low energy range (E(n)= 1 to 90 keV), the",
                " results are based on the assumption that the neutrons",
                " from the Li-7(p,n)Be-7 reaction are isotropically",
                " distributed in the centre-of-mass system for proton",
                " energies close to the neutron threshold."
              ]
            }
