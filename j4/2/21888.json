          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENTS OF THE ANALYSING POWER OF LI-6",
                " FOR LOW-ENERGY NEUTRON SCATTERING-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2ITYPAD"
              },
              "free_text": [
                " 7.5 MEV ACCELERATOR AT THE NATIONAL",
                " LABORATORY IN LEGNARO."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS",
                  "D-C12"
                ],
                "reaction": null
              },
              "free_text": [
                " REACTION ANGLES 20 ADEG AND 25 ADEG.",
                " THE REACTION PRODUCES A SECOND GROUP OF NEUTRONS",
                " CORRESPONDING TO THE FIRST EXCITED LEVEL (2.37 MEV)",
                " OF THE N-13 NUCLEUS MAKING POSSIBLE TO MEASURE",
                " AT TWO NEUTRON ENERGIES SIMULTANEOUSLY.",
                ".THE CARBON TARGET WAS OBTAINED BY DEPOSITION",
                " OF A COLLODIAL GRAPHITE SUSPENSION ON A TANTALUM",
                " BACKING. THE CARBON THICKNESS WAS ABOUT 1 MG/CM-SQ.",
                "REFERENCES FOR NEUTRON POLARIZATION",
                " VALUES GIVEN IN 'ANALYSIS'."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".LITHIUM METAL (95 PER CENT OF LI-6) CONTAINED IN A",
                " THIN-WALLED ALUMINUM CAN. THE SHAPE OF THE SAMPLE WAS",
                " CYLINDRICAL WITH A DIAMETER OG 5.5 CM AND A HIGHT OF",
                " 15 CM. THE DISTANCE BETWEEN THE NEUTRON SOURCE AND",
                " THE LITHIUM SAMPLE WAS 110 CM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " FOR DETAILS SEE (J,NP/A,181,1,177,7212).",
                " THE EXPERIMENTAL APPARATUS MADE IT POSSIBLE TO",
                " MEASURE AT SIX ANGLES BETWEEN 25 ADEG AND 135 ADEG",
                " AT THE SAME TIME.",
                " FOR EACH ENERGY THE MEASUREMENT CONSISTED OF SEVERAL",
                " RUNS ALTERNATIVELY ON THE RIGHT AND ON THE LEFT OF",
                " THE PRIMARY NEUTRON BEAM. FOR EACH RUN A BACKGROUND",
                " COUNTING WAS PERFORMED WITH AN EMPTY ALUMINUM CAN."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 12 NE213 SCINTILLATORS."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ANALYSIS OF TIME-OF-FLIGHT SPECTRA WAS ACCOMPLISHED",
                " WITH A HP1000 COMPUTER SYSTEM.",
                " THE NEUTRON POLARISATION VALUES USED IN EVALUATION OF",
                " ANALYSING POWERS ARE LISTED IN TABLE I IN THE MAIN",
                " REFERENCE AND WERE TAKEN FROM THE FOLLOWING REFERENCES",
                " (J,PR,141,825,66) EN - 2.80 AND 3.19 MEV",
                " (J,PR,150,830,66) EN - 1.48,1.88,3.99,4.38 MEV",
                " (J,PR,173,952,68) EN - 3.50 MEV",
                " (B,R.L.WALTER,PHENOM.IN NUCL.PHYS.,P317,1971)EN - 2.43"
              ]
            }
