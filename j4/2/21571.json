                  "REAC"
                ],
                "institute": "2GERMUN"
              },
              "free_text": [
                " FRM-reactor of Munich."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The samples of U-233 and Pu-239 as thick as",
                " 10-30 mg/cm**2 are prepared by molecular electoplating",
                " techniques from organic solutions on Al-foils.",
                " The effective surface of the fissile material on",
                " the target was about 80 mm**2."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron flux was about 2 x 10**7 n/cm2/s"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP"
              ],
              "free_text": [
                " Counting of alpha particles and fission",
                " fragments."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Surface barrier counter with 100 micro-",
                " meters depleted depth and 100 mm diameter. The",
                " detector was placing in a home made vacuum chamber."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " By measurements of the relative alpha desintegra-",
                " tion rate and fission reaction rate of the target",
                " and monitor nuclide with the fission counter, the",
                " effective cross section of the Pu-239(n,f)-reaction",
                " was determined by using the Westcott convention."
              ]
            }
          ],
