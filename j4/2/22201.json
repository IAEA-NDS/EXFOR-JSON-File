          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The work was undertaken to investigate the breakup",
                " neutron spektrum from the D(d,n) reaction. The",
                " activation cross section ratios were determined to",
                " check the reliability in the brakup contribution",
                " correction."
              ]
            }
