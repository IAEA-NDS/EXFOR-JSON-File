                ],
                "institute": "2GERPTB"
              },
              "free_text": [
                " The PTB compact cyclotron."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "   A 500 nA pulsed deuteron beam from the cyclo-",
                " tron, with pulse widths of 1.5 - 2 ns at a repetition",
                " rate of 0.7 - 1.0 MHz, was incident upon a deuterium",
                " gas target. the gas target was 3 cm long, with a mo-",
                " lybdenum entrance window of 0.556 mg/cm2 and a gold",
                " beam stop of 0.5 mm thickness, filled with deuterium",
                " gas to a pressure of 1840 hPa."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A full energy peak plus a continous breakup",
                " background."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Stacks of iron, aluminum and nickel disks, each 10 mm",
                " in diameter and 1 mm thick, were irradiated at a",
                " distance of 45 mm from the center of the gas target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
