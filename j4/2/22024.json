          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Continuous beams were used, except in the case of",
                " Am-243, where pulsed neutrons were used in order to",
                " reduce the uncertainty caused by subtracting the",
                " spontaneous fission counts of the impurity Cm-244."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Reaction with absorbed tritium-titanium targets",
                " were used to produce neutrons in the energy range",
                " 0.7 - 3 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Reaction with a deuterium gas target was used",
                " to produce neutrons in the energy range 4.2 - 7 MeV."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Source neutron spectra were measured with tof by using",
                " a NE213 scintillation detector, placed at a distance",
                " of 14 m from the target in the 0 degree direction.",
                "Mean neutron energies and spreads at the sample",
                " position were then calculated by a Monte Carlo method."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " A fission chamber of the parallel plate",
                " ionization type was used.",
                "The U-235 sample and another sample were mounted back",
                " to back in the chamber 2 cm from the collector",
                " electrode."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
