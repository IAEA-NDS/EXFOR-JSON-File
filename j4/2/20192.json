          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Enriched boron with an isotopic composition in B-10",
                " measured in 1962 as 96.515+-0.013%, and revised",
                " in 1967 to a value of 96.525+-0.006%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " These data are derived from measurements of the total",
                " cross section of enriched B2O3, in two separate runs,",
                " K from 0.006 to 0.027 eV and l from 0.013 to 0.082 eV",
                " The total cross section for B-10 is derived assuming",
                " a total cross section for oxygen of 4.24+-0.02 b",
                " and scattering cross sections for B-10 and B-11 of",
                " 4.0 and 4.4 b, respectively. The data are derived from",
                " the total cross section given in table IV of EUR-12E",
                " using the formula ...",
                "   Sigma (n,alpha) = 1/2( (B2O3)total - 21b ) * 1/0.965",
                " the final term is the correction for the isotopic",
                " composition of the sample."
              ]
            }
          ],
