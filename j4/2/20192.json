          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Natural boron, the isotopic composition of B-10",
                " was measured in 1962 as 19.81+-0.02%, revised to",
                " a value of 19.838+-0.030 in 1967 (JNE,21,373)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The total cross section of B2O3 was measured in two",
                " separate runs, K-from 0.006 to 0.027 eV, L-from 0.013",
                " to 0.082 eV. The (n,alpha) cross section of this boron",
                " is derived from these measurements assuming a value",
                " for oxygen total cross section of 4.24+-0.02 b, and",
                " for the B-10 and B-11 scattering cross sections 4.0",
                " and 4.4 b. The values correspond to those derived from",
                " table IV using the formula ...",
                "     Sigma (n,alpha) = 1/2( (B2O3)total - 21b)"
              ]
            }
          ],
