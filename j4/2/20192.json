          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Two samples of deuterated boric acid used, supplied",
                " by ornl. The boron content of the samples was determ.",
                " By titration against sodium hydroxide of calibrated",
                " strength,and the isotopic composition of the boron was",
                " determined by mass spectrometry. A small mass",
                " discrimination was suspected in the 1962 measurements,",
                " revised isotopic compositions were published in 1967.",
                " The measuring cells were made of fused quartz, diam.",
                " of 52 mm and length of 20 mm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "TRN"
              ],
              "free_text": [
                " Transmission measurement of deuterated boric",
                " acid solution. The neutron beam was monitored with a",
                " parallel plate fission flow counter with a low",
                " efficiency U-235 layer.",
                " The length of the flight path was 194.70+-0.02 cm."
              ]
            }
          ],
