          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The average cross sections in the MeV energy range",
                " is found to be 12% larger than was deduced  from",
                " earlier measurements.",
                ".The experimental results are discussed in view of",
                " the fission barrier parameters of Pu-245."
              ]
