          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Neutron inelastic cross sections between 55 and 140",
                " MeV -."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": null
              },
              "free_text": [
