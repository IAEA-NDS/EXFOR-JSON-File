              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-BE"
                ],
                "reaction": null
              },
              "free_text": [
                "  Bombardment of a thin beryllium target with",
                " the internal proton beam of the synchrocylotron",
                " giving neutron beams of energy 55.,81.,105., and 140",
                " MeV with an energy spread of about 10 %.",
                " Well-collimated neutron beam of about 3cm diameter."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Effective energy of neutron beam was determined by",
                " measurement of neutron total c-s for carbon in good",
                " geometry.Energy resolution about 10% full width at",
                " half-maximum."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Sample absorbers were cylindrical,of diameter not less",
                " 25cm and of a length to give significant attenuation",
                " of the neutron beam.",
                " Cylinder length:",
                " Al - 22cm for 140 and 105 MeV and",
                "      10cm for 81 and 55 MeV neutrons measurement,",
                " Cu - 25cm for 140 and 105 MeV and",
                "       9cm for 81 and 55 MeV neutrons measurement,",
                " Pb - 9.0cm , Cd - 8.2cm , Cu - 8.0cm .",
                " Chemical purity at least 99.99 %.",
                " Absorbers were weighed to accuracy better than 0.1%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Detection of scattered neutrons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                " Pulse-height distributions were determined."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Large liquid scintillator, brass cylinder of",
                " 25cm long and 25cm diameter, benzene with 4 g/l of",
                " p-terphenyl and 10 mg/l of diphenyl hexatrine.",
                " Copper sheet in front of scintillator to prevent",
                " protons."
              ]
            },
            {
