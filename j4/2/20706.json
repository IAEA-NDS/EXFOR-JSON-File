          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Neutron capture and total cross-section measurements",
                " on fast reactor structural materials"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "2UK HAR"
              },
              "free_text": [
                " 45 MeV electron Linac with an electron",
                " burst length of 150 ns and a repetition frequency of",
                " 192Hz for the capture experiment."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCY"
                ],
                "institute": "2UK HAR"
              },
              "free_text": [
                " 160MeV synchrocyclotron (75Kiev) at",
                " 3-10ns pulse width for the total cross-section",
                " experiment."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "EVAP"
                ],
                "reaction": null
              },
              "free_text": [
                " The synchrocyclotron protons were fired into",
                " a thick tungsten target. The fast neutrons were",
                " moderated in an adjacent volume of water 25mm in",
                " thickness.",
                ".For the Linac measurements a neutron booster source",
                " was employed. See M.J.Poole and E.R.Wiblin,proc.",
                " Second Conf. on Peaceful uses of Atomic Energy 14",
                " (1958) 266."
              ]
            }
          ],
