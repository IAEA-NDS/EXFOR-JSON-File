              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Correction for the high energy part of the Cf-252",
                " neutrons above 10 MeV applied.",
                ".No gamma discrimination applied, since the lower",
