          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The IAEA Cf-252 neutron source consists of",
                " a cylindrical capsule with an outer length of 22.0",
                " mm and an external diameter of 2.80 mm, strength",
                " calibrated against a standard Cf-252 source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                "   Measuring proton-recoils in the gas filled",
                " proportional counter spectrometers."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " A gas filled proportional counter filled",
                " with 200 kPa C-H4 gas, 200 kPa kripton gas and 0.1%",
                " He-3, energy calibrated with a Na-Be neutron source",
                " and the He-3(N,P)-reaction using thermal neutrons."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The response functions for the detector were calcu-",
                " lated using the Monte-Carlo code MATRI, which is a",
                " modified version of the code SPEC-4."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
