          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SHAPE"
              ],
              "free_text": [
                " Pulse height spectrum analysis."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SLA"
              ],
              "free_text": [
                "",
                " The partial off-resonance cross sections for the",
                " 153 keV resonance contributions in the energy bin",
                " containing the 153 keV peak itself were calculated",
                " using the computer code HIKARI, based on the DWBA,",
                " and the results normalised to those measured and",
                " deduced for the energy bin immediately below the peak.",
                " This enabled the total number of off-resonance counts",
                " to be calculated, the difference with the total counts",
                " recorded in the energy bin of the resonance gave the",
                " on-resonance counts, from which the resonance width",
                " was deduced."
              ]
            }
          ],
