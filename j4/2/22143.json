            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " AN IONIZATION CHAMBER RUNNING IN 'DELTA E - E'",
                " MODE WAS USED TO DETECT THE FISSION PRODUCTS. THE",
                " ENERGY SPREAD OF THE ION BEAM ENTERING THE CHAMBER IS",
                " AROUND 1 MEV, WHICH IS LOW ENOUGH TO SEPARATE UNAMBIG-",
                " UOUSLY THE A/Q COMPONENTS (MASS OVER IONIC CHARGE",
                " RATIOS)."
              ]
            }
          ],
