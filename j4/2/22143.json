          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE NUCLEAR CHARGE YIELDS Y(A,Q,E,Z) WERE OBTAINED FOR",
                " A GIVEN MASS, ENERGY AND IONIC CHARGE STATE BY A LEAST",
                " SQUARE ANALYSIS OF THE 'DELTA E' SPECTRUM, ASSUMING A",
                " GAUSSIAN RESPONSE OF THE IONIZATION CHAMBER TO A",
                " SINGLE NUCLEAR CHARGE COMPONENT. THE CONTRIBUTIONS OF",
                " ALL IONIC CHARGE STATES MUST BE SUMMED AT THE DIFF-",
                " ERENT KINETIC ENERGIES, WITH UNMEASURED CHARGE STATES",
                " BEING INTERPOLATED BY FITTING GAUSSIAN SHAPES TO THE",
                " MEASURED YIELDS. THE INDEPENDENT YIELDS Y(A,Z) ARE",
                " THEN OBTAINED BY INTEGRATING OVER THE KINETIC ENERGY",
                " DISTRIBUTION BY MEANS OF A GAUSSIAN FIT."
              ]
            }
