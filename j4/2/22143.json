            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE SAMPLE CONSISTED OF A 50 MICRO-G/CM2 ELECTRO-",
                " DEPOSITED LAYER OF 229-TH ON A THICK TITANIUM BACKING.",
                " A 40 X 3 MM2 DIAPHRAGM WAS PLACED IN FRONT TO OBTAIN",
                " THE REQUIRED MASS RESOLUTION. THE CHANGE OF FISSION",
                " RATE WITH TIME WAS MONITORED."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
