          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Scattering of 14.1 MeV neutrons from B-11.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Neutron generator of the institut de physique",
                " nucleaire de l'universite de lausanne."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "      Deuterium-tritium reaction. Ed = 145 KeV.",
                " Thin titanium-tritium target."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Mono-energetic neutrons. En = 14.15 +- 0.10 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Natural boron powder (81.17 pc B-11, 18.83 pc B-10)",
                " in copper-canning (0.05 mm thick). Height 72 mm,",
                " width 18 mm, thickness 50 mm. Distance from neutron-",
                " source 18 cm.",
                " B-10-enriched boron powder (91.35 pc B-10, 8.65 pc",
                " B-11). Impurities 1.9 pc C, 1.2 pc O. Same geometry."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP"
              ],
              "free_text": [
                "    Measurement of scattered neutron TOF-",
                " spectra by means of a fast TOF-spectrometer employing",
                " the associated alpha particles from the H-3(d,N)He-4",
                " reaction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                "    Liquid scintillator, type NE-213, as",
                " neutron detector. Area 19.6*20.1 cm*cm, thickness",
                " 3.6 cm. Threshold 3 MeV proton energy. Elimination",
                " of gamma-counting by pulse-shape discrimination.",
                " Shielding against the neutron-source by a pyramidal",
                " iron shadow bar, 25 cm long, close to the target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "     Plastic scintillator, type Ne 102a, as",
                " alpha detector. Area 30*11.4 mm*mm, thickness 12.5 mu.",
                " Distance from neutron-source 71 mm."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "1-H-1(N,EL)1-H-1,,DA",
