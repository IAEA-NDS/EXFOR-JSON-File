          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Measurement of the mass and charge distributions",
                " in neutron induced fission at medium energy by",
                " an emanation method (In French)"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2FR GRE"
              },
              "free_text": [
                " 300 keV deuteron accelerator S.A.M.E.S."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron-tritium reaction. 300 keV",
                " deuterons onto tritiated target of 30 mm diam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Uranylstearate or thorium stearate. Emanation",
                " tests were done on each sample."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Chemical separation. Rare gases are",
                " extracted from the fission target by pumping",
                " in vacuum after or during irradiation. In",
                " some cases the irradiated material was passed",
                " over a resin as to reduce Compton background",
                " and peak interferences in their gamma-counting.",
                " Using the formulas -",
                "       F = (Y-cum(elem) - Y-cum(rare gas))/",
                "           (Y-cum(elem)   and",
                "       F = n1*n4/(n2*n3) where",
                "       n1= counting rate during irradiation,",
                "       n2= counting rate after irradiation,",
                "       n3= counting rate during irradiation for",
                "           a reference material.",
                "       N4= counting rate after irradiation for",
                "           a reference material.",
                "       Fractional yields can be derived."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Coaxial Ge(Li)-detector, 43 cc, FWNM-resol at",
                " the 1332 keV-line of Co-60 is 2.35 keV, peak/Compton",
                " ratio 26., efficiency with respect to a Na-I",
                " of 76*76 mm*mm at 25 cm from source is 7.%"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 52 cc Ge(Li) detector, resolution less than",
                " 2.1 keV, p/c ratio better than 32."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Decay data from private comm., J.Blachot and C.Chauvin",
                " Two other experimental methods are described."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Quadratic error propagation used in the",
                " formula F=n1*n4/(n2*n3)."
              ]
            }
          ],
