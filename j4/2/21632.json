          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NEUTRON-NEUTRON EFFECTIVE RANGE FROM A COMPARISON",
                " OF N-N AND N-P QUASI-FREE SCATTERING AT 24. MEV.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ISOCY"
                ],
                "institute": "2GERBON"
              },
              "free_text": [
                " ISOCHRONOUS CYCLOTRON."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " 27 MEV DEUTERON BEAM (3 MICRO-AMPERES)",
                " ONTO A LIQUID NITROGEN COOLED HIGH PRESSURE",
                " (25 BAR) DEUTERIUM GAS TARGET.",
                " NEUTRONS EMITTED IN FORWARD DIRECTION WERE",
                " COLLIMATED TO PRODUCE A BEAM WITH",
                " AN INTENSITY OF 5.6E+06 NEUTRONS/S",
                " ON THE TARGET."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".C-D(2) TARGET, 50 MG/CM*CM THICK IN THE FIRST,",
                " 22. MM LONG * 20. MM DIAM IN THE 2ND EXPERIMENT."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TO DETERMINE THE PROTON ENERGY (DISCRIMINATION",
                " AGAINST DEUTERONS AND OTHER CHARGED PARTICLES)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                " PULSE-HEIGHT DISCRIMINATION TO DO THIS",
                " REJECTION OF OTHER CHARGED PARTICLES ON THE",
                " BASIS OF THEIR TOF."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " PROTON RECOILS ARE MEASURED TO MONITOR",
                " THE INCOMING NEUTRON FLUX."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " PULSE SHAPE DISCRIMINATION IS USED TO",
                " DISTINGUISH NEUTRONS FROM GAMMA-RAYS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " PROTON RECOIL TELESCOPE TO MONITOR THE",
                " INCOMING NEUTRON FLUX."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " BREAK-UP NEUTRONS ARE DETECTED AT",
                " 50 DEGREES WITH A WELL SHIELDED NE213 SCINTILLATOR",
                " IN COINCIDENCE WITH BREAK UP PROTONS EMITTED AT",
                " -34.1 DEGREES WITH RESPECT TO THE BEAM. THESE",
                " PROTONS ARE DETECTED IN A NE104 PLASTIC",
                " SCINTILLATOR (1ST EXP. - N-P QUASI FREE SCATTERING)",
                " IN THE 2ND EXPERIMENT (N-N QUASI-FREE SCATTERING)",
                " THE NE104 IS REPLACED WITH A NE213 SCINTILLATOR."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " THE PROTONS PASS THROUGH A SCINTILLATION",
                " FOIL OF 1.5 MG/CM*CM TO PRODUCE THE TOF START",
                " SIGNALS FOR THE PROTON ENERGY MEASUREMENT."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".IS DONE BY FITTING THE RESULTS OF MONTE CARLO",
                " CALCULATIONS OF THE PROCESS",
                " FOR DIFFERENT POSSIBLE VALUES OF THE SCATTERING",
                " LENGTH AND THE EFFECTIVE RANGE TO THE",
                " EXPERIMENTAL DATA."
              ]
            }
          ],
