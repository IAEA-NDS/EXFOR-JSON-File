              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " The array of Ge detectors is composed of 22 Ge",
                "crystals and located on the flight length of 21.5 m"
              ]
            }
          ],
