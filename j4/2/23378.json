                "Co-60 . Accuracy 2 % for the relative efficiency and",
                "5 % for absolute measurements."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Westcott convention formula was used:",
                "<SIG>=SIG0*(g+r*sqrt(T/T0)*S0), where",
                "<SIG> - effective cross section,",
                "SIG0 - thermal cross section,",
                "g - factor related to deviation of SIG0 from 1/v law",
                "in thermal region,",
                "r*sqrt(T/T0) - epithermal index,",
                "S0 - representative of deviation of SIG0 from 1/v law i",
                "epithermal energy .",
                " For Ac-227 g=1. was assumed."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "MONIT1",
                "reaction": {
                  "code": "79-AU-197(N,G)79-AU-198,,SIG",
                  "code_unit": [
                    {
