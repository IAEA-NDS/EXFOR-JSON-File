                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " Thermal cross section = 98.8 b ,",
                " g-factor 1.005, S0 17.0 for Au ;",
                " epithermal index was calculated as:",
                " g/(Cd*(S0+1/k)-S0), where k=2.393, Cd- cadmium ratio",
                "for Au."
              ]
            }
