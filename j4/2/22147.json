          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-A STUDY OF MONOENERGETIC, FAST NEUTRON-INDUCED TERNARY",
                " FISSION IN 238-U."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.RANDLE",
                "H.AFARIDEH"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
