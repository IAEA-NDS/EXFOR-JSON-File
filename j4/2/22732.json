          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The major uncertainties and their estimated values in",
                "cross section measurements are similar to those given",
                "in rel-ref."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ".The total error in cross section values was",
                "obtained by combining the individual errors in",
                "quadrature. See table 1."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  The peak area determination was achieved with",
                " 2% uncertainty for both gamma lines, 271 and 1157-KeV,",
                " due to good counting statistics."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  The uncertainties in the determination of the",
                " effective neutron flux and the photopeak efficiency of",
                " the gamma detector, including self-absorption and",
                " counting geometry, were 3%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  The error in the decay data used was less than",
                " 1%."
              ]
            }
