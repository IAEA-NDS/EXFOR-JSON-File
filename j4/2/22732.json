          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A 82 cc. Hpge-detector.",
                " The full energy peak efficiency of this detector is",
                "known to be better than 2% overall inaccuracy from 60",
                "to 1800-KeV gamma rays."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The neutron source strength is monitored by",
                "means of an Ne-213 liquid scintillation counter with",
                "pulse shape discrimination against gamma rays."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The samples were placed at different neutron emission",
                " angles O, 30, 60, 90, 120, 130-degrees and irradiated",
                " for approximately 1-hr at irradiation position,",
                " depending on the target conditions, covering the",
                " neutron energies from 13.6 to 14.9-MeV. The neutron",
                " energy was  determined by the technique based on the",
                " activation ratio of Zr-90(N,2N)Zr-89 and",
                " Nb-93(N,2N)Nb-92-m reaction products."
              ]
            }
          ],
          "ADD-RES": [
