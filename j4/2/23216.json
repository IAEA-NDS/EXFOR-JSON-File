          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The effect of the scattered neutron from the sample,",
                "the sample folder and the atmosphere was taken into",
                "account - calculated by the MCNP-4C:",
                "the neutron fluence rate at the HPGe detector surface",
                "was 4.0E-4 times against the sample position."
