          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Tritiated titanium (Ti-T) target was bombarded",
                "with a 350 keV d+ beam at the 0 degree beam line of",
                "the Fusion Neutronics Source (FNS) at the JAEA.",
                "To reduce the background at the measuring position,",
                "the neutron collimator (2 cm diameter) at the 0 degree",
                "beam line was used. The angle between the d+ beam and",
                "the axis of the collimated neutron beam was 80 degree,",
                "which resulted in a 14.2 MeV neutron energy.",
                "The distance between an exit of the collimator and the",
                "sample was 15 cm."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The typical value of neutron fluence at the sample",
                "position was 6.5E+5 n/cm**2/s."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 36% HPGe detector - to measure induced activity.",
                "The distance between the sample and the HPGe detector",
                "surface was 5 cm."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples were 1 mm thick rectangular (10 mm x 20 mm) or",
                "disk-shape (15 mm diameter).",
                "Nuclei          Chemical form  Weight,mg  Abundance",
                "Al-27,natural   Al             949.6      Al-27 100%",
                "Sm-144,enriched Sm(2)O(3)      45.01      Sm-144 96.47%",
                "Pb-206,enriched Pb             138.0      Pb-206 99.56%",
                "Pb-208,enriched Pb             123.1      Pb-208 99.86%"
              ]
            }
          ],
          "MONITOR": [
