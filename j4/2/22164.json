          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".GAMS1,2,3 BENT CRYSTAL SPECTROMETERS:",
                "   GAMS1, RANGE 30-500 KEV, RESOLUTION 40 EV AT 100 KEV",
                "      IN THE 3RD ORDER OF DIFFRACTION (FWHM)",
                "   GAMS2/3, RANGE 150-1200 KEV, RESOLUTION 400 EV AT",
                "      500 KEV IN THE 3RD ORDER OF DIFFRACTION (FWHM).",
                " ENERGIES CALIBRATED RELATIVE TO THE NP K-ALPHA1 X-RAY",
                " ENERGY; A VALUE OF 101.057(3) KEV WAS ASSUMED FROM",
                " RENORMALISING TO THE 198-AU ABSOLUTE GAMMA RAY",
                " STANDARD OF 411.8040(2) KEV."
              ]
            }
          ],
