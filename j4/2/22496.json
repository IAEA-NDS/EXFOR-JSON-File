          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal neutron flux at the sample position is near",
                " 5.E+8 n/cm2/sec, energy distribution of neutron",
                " approaches Maxwellian with T=210K, mean energy",
                " 18 milli-eV. The energy calibration was done by means",
                " of 10B(n,alpha)7Li and 6Li(n,alpha)3H reactions"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "  Two silicon surface barrier detectors. First",
                "         one is 29 micro-m thick, has surface 150 mm2,",
                " 40 keV resolution. Second one is 60 micro-m thick,",
                " surface 150 mm2, 25 keV resolution."
              ]
            }
          ],
          "ASSUMED": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ASSUM",
                "reaction": {
                  "code": "5-B-10(N,A)3-LI-7,,SIG",
