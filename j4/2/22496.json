                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "  Transition to first",
                "   and second energy levels of 7Li"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A variety of 14n samples was used - adenine C5-H5-N5",
                " containing 51.6% of 14N evaporated on thin aluminium",
                " backing, and polyimide C22-H10-O5-N2 foils containing",
                " 7.30% of 14N."
              ]
            }
          ],
