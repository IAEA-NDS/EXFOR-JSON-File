              "free_text": [
                " Horizontal graphite thermal column.",
                "The thermal neutron flux is ~3.5E+08 n/cm2/s at",
                " reactor power level of 400 kW.",
                "The thermal neutron field is perfectly well",
                " thermalized.",
                "235U (93% enriched) and 239Pu (94% enriched) disc",
                " shape (0.1 mm thick and 19 mm diam.) fission sources."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Ratio in Numerator:   239Pu(n-th,f) neutron field,",
                "Ratio in denominator: 235U(n-th,f)neutron field."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stack sandwiched by two fission source discs in the",
                " following order:",
                " Fission source",
                " Cd (<1 mm)",
                " In (0.13 mm)",
                " Rh (0.1 mm)",
                " Al (0.5 mm)",
                " Rh (0.1 mm)",
                " Al (0.5 mm)",
                " Rh (0.1 mm)",
                " In (0.13 mm)",
                " Cd (<1 mm)",
                " Fission source",
                "into a Cd box coaxial with the fission sources."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
