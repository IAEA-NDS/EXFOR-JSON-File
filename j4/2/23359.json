          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "        Neutron flux  3.E+8 n/cm2/sec."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 10g of UO(2) powder (U235 enrichment 93.%) mixed with",
                "30 g of Ba stearate."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "OLMS"
              ],
              "free_text": [
                " Produced Kr and Xe were transported as",
                "molecular flow through a transport line (19mm diameter,",
                " ~1m long) to the ion source of the separator. After",
                "ionization the desired mass activity ( ~1 to 8",
                "microCurie was brought out of separator and collected",
                "on 3.0cm Al-tape ( 70 mu thick), which was moved to",
                "the center of beta-counter.",
                " Exp.conditions:",
                "Mass                     92   93   141  142",
                "                neutrons",
                "Time channel width,sec   0.1  0.1  0.4  0.1",
                "Number of channels       400  400  400  400",
                "Irradiation time,sec     50   50   243  25",
                "Total counting time,sec  27   17   24   36",
                "                betas",
                "Irradiation time,sec     50   50   243  25",
                "Transfer and delay,sec   18   8    70   8",
                "Counting time,sec        2    2    1    2",
                "Time channel width,sec   0.5  0.5  0.5  0.5",
                "Number of channels,first 200  200  100  100",
                "Time channel width,sec   5    5    5    5",
                "Number of channels,last  200  200  300  300"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Two 1-mm-thick NE102 plastic scintillators,",
                "viewed by two 154 AVP photomultipliers.",
                "As 4PI-beta-detector ."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Neutron detector - 12 BF3 (2.5cm diameter, 30cm",
                "long) proportional counters in a block of polyethylene",
                " (44cm diameter, 50cm long).",
                "Neutron detection efficiency 15.8+-0.6 % was determined",
                "by an Am-Li ( En ~400keV) source (neutron source",
                "strength uncertainty 3%).",
                "The neutron multiscaling was started a fixed time",
                "before the deflection of the ion beam ~4m away from",
                "the point of irradiation."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  - Beta activity corrections:",
                " Solid angle - 95.5+-1.% of 4PI",
                "Mass                          92    93    141   142",
                "Detector threshold,%          0.7   0.6   1.    0.9",
                "Contaminating masses and      90    91    140   140",
                "                              91    92          141",
                "multiplicative correction",
                "factor with                   0.735 0.865 0.553 0.154",
                "error, %                      3.    5.    2.    7.",
                "Beta absorption in tape and window,%  - 1.+-0.1",
                "Prompt and delayed conversion electrons and gammas,% -",
                " < or = 0.6",
                "     Corrected beta activity at t=0 for mass :",
                " 92 - 205332.5 +- 3.2%,  93 - 29768.5 +- 5.1%,",
                "141 - 64751 +- 2.2%,  142 - 6462.4 +- 7.1% .",
                "  - Neutron activities corrections:",
                " photo-neutrons -0.14 % ;",
                "Mass                          92    93     141   142",
                "Contaminating mass and        93    92     142   141",
                "multiplicative correction",
                "factor with                   0.81  0.98   0.95  0.97",
                "error, %                      5.    1.     1.    1.",
                "Corrected neutron",
                "activity at t=0 and           91.83 919.71 64.78 48.88",
                "its error,%                   6.4   4.1    4.1   4.1",
                "Total isobaric emission,% and 0.044 3.09   0.100 0.691",
                "its relative error,%          8.    7.     5.5   9."
              ]
            }
