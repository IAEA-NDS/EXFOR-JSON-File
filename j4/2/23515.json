          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal neutrons.",
                " Neutron flux was measured by Au foils of 2.2 cm",
                "diameter, 10 mg/cm2 thickness irradiated in 2 cm",
                "position simultaneously with U to be",
                " (4.46+-0.40%) x10**7 n/sec/cm2 in position 2,",
                " (3.98+-0.55%) x10**7 n/cm2/sec in position 22."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "D4PI"
              ],
              "free_text": [
                " 4PI beta proportional counter.",
                "Efficiency of 1.21 MeV beta decay branch was determined",
                "by counting coincidences between beta and 75 keV gamma.",
                "Stability of beta counter was checked by standard Co-60",
                "source. 75 keV gamma-ray gate was checked and reset",
                "daily by gamma-ray spectrum of irradiated natural U ."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Two fission chambers for further monitoring of",
                "the flux variation."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation in 22 cm position, with foils and",
                "under 1 mm Cd ."
              ]
            },
