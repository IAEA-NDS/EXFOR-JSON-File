              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " NE 102A plastic scintillator (0.5 mm thick)",
                " for detection of alpha particles associated with",
                " produced neutrons."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The incident neutron flux was estimated from the",
                " integrated counts in the alpha monitor. Energy",
                " calibration and gamma-ray efficiency at various",
                " energies were obtained using standard sources."
              ]
            }
          ],
