          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The gamma rays associated with the inelastic",
                " scattering of 14 MeV neutrons in large samples of",
                " iron and concrete"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "DYNAM"
                ],
                "institute": null
              },
              "free_text": [
                " The 3 MeV dynamitron accelerator at the Joint",
                " Aston and Birmingham Universities' Radiation Centre.",
                ".SAMES type J accelerator."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
