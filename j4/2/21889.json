                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Rotating watercooled tritiated titanium target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP"
              ],
              "free_text": [
                " Alpha particles, resulting from the neutron-",
                " production reaction, were used for neutron flux",
                " determination and to produce a zero time signal."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight techniques were used to reduce",
                " background in gamma-ray spectra."
              ]
            }
          ],
