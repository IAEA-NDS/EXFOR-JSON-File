          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHRFL"
              ],
              "free_text": [
                " THE MEASUREMENT OF THE COHERENT SCATTERING",
                " LENGTH WAS PERFORMED USING CHRISTIANSEN FILTERS WITH",
                " WELL COLLIMATED NEUTRONS OF 0.55 MILLI-EV.",
                ".THE TOTAL CROSS SECTION TRANSMISSION MEASUREMENTS AT",
                " 1.26 AND 5.2 EV WERE PERFORMED WITH RESONANCE ACTI-",
                " VATION TECHNIQUES, WHILE THE MEASUREMENTS AT 18.6 AND",
                " 128 EV UTILIZED RESONANCE SCATTERING TECHNIQUES.",
                ".THE MEASUREMENTS AT 143 KEV WERE MADE BY USING A",
                " SILICON FILTERED NEUTRON BEAM."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THREE DIFFERENT POWDER SAMPLES OF THORIUM-OXIDE, THO2,",
                " HAVING CHEMICAL PURITIES OF 99.9, 99.93 AND 99.999",
                " PERCENT, RESPECTIVELY, WERE USED IN THE CHRISTIANSEN",
                " FILTER MEASUREMENTS.",
                ".FOR THE TRANSMISSION MEASUREMENTS, BOTH POWDER THO2",
                " SAMPLES AS WELL AS METALLIC TH SAMPLES, WERE USED."
              ]
            }
          ],
