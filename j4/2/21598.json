          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " 7 sets of Li-6 glass scintillators (NE908, 4",
                "3/4 inch diameter x 1/2 inch thick)",
                "The neutron flux was monitored with a 6Li-glass",
                "scintillator (NE 905, 1/2 inch diam. x 1/8 inch thick)"
              ]
            }
          ],
          "ANALYSIS": [
            {
