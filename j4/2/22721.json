          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.For each observable activity in a given",
                "mass chain, peak area were corrected for detection",
                "efficiency and decay branching of the corresponding",
                "transitions in order to obtain the number of decay."
              ]
            }
