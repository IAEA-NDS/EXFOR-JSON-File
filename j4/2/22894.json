          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Nickel oxide sample enriched to 96.3% in Ni-62,",
                " weight of 2.52 gram placed in a carbon case 20 mm",
                " diameter, depth 4 mm, surface thickness 1 mm, bottom",
                " thickness 1.4 mm. Impurities content is: Ni-58 - 0.4%,",
                " Ni-60 - 0.4%, Ni-61 - 1.8%, Ni-64 - 1.1%.",
                ".A gold monitor sample with a diameter of 20-mm and",
                " thickness of 1 mm was used for normalization of the",
                " absolute capture cross section."
              ]
            }
          ],
