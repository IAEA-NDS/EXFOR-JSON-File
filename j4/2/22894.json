          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Using JENDL-3.3 data for total, elastic and (n,gamma)",
                " cross sections as a first approximation, subsequent",
                " approximations for Ni-62(N,G)Ni-63 cross section were",
                " calculated with the help of TIME-MULTI code,",
                " see REL-REF of K.Senoo+."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
