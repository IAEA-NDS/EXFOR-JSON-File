          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of capture cross-section of 93Nb by",
                "activation method and half-life of 94Nb by mass",
                "analysis"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
