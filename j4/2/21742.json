          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-An absolute measurement of the Li-7(N,N'at)",
                " reaction cross section between 5 and 14 MeV",
                " by tritium assaying.-"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Lithium samples 99.8 percent Li-7, in a lithium",
                " hydroxide compressed pellet, enclosed in a 1 mm thick",
                " cadmium case."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The tritium produced is counted using a liquid",
                " scintillation technique. The counting efficiency",
                " of each vial was determined using the external",
                " standards channels ratio technique, with a quench",
                " curve obtained by using standard tritiated water",
                " added to solutions made with unirradiated pellets.",
                " The background was also found using unirradiated",
                " pellets."
              ]
            }
          ],
