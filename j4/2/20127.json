          "REACTION": [
            {
              "pointer": "",
              "coded_information": {
                "code": "92-U-235(N,F)2-HE-4,TER,FY,,RES/REL",
                "code_unit": [
                  {
                    "unit": "92-U-235(N,F)2-HE-4,TER,FY,,RES/REL",
                    "field": {
                      "reaction": "92-U-235(N,F)2-HE-4",
                      "target": "92-U-235",
                      "projectile": "N",
                      "process": "F",
                      "product": "2-HE-4",
                      "quantity": "TER,FY,,RES",
                      "data_type": null,
                      "general_quantity_modifier": "REL",
                      "quantity_236": "TER,FY,,RES"
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                " ratios ternary/binary fission at resonance energy,",
                "normalized to the value for the 8.78 eV resonance."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF",
                "A"
              ],
              "free_text": [
                "     Fission fragments, alpha's."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Average of two runs with different detector geometries",
                " which agree within experimental errors.",
                " Two groups of resonances energies, 8.78 and 12.3 eV",
                " with low ter/bin ratio and 19.3 and 22.1 eV with",
                " about 15% higher ter/bin ratio.",
                " Correlation with other measurements show,",
                " agreement with scattering experiments (spin values)",
                " and fission fragment anisotropy,",
                " disagreement with gamma-ray multiplicity experiments",
                " (spin values) and",
                " no contradiction with experiments on kinetic energy",
                " and mass symmetry of fission fragments.",
                " Earlier measurements of the ratio did not",
                " significantly show this effect probably due to a too",
                " low ternary-alpha detection level."
              ]
            }
          ],
