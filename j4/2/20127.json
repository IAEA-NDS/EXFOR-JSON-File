          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Large gold-silicon surface barrier detectors",
                " (four 6 cm2 detectors), on both sides of the back-to-",
                " back target.",
                " Detection of long range alpha (absorber in) and of",
                " fission fragments (absorber out). The absorber is",
                " 20 micron thick aluminium."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Ternary to binary fission ratios were normalized",
                " to the value at the 8.78 eV resonance."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The lower detection level for ternary alpha particles",
                " was about 10 MeV. As a change in the ratios may be",
                " expected depending on the ternary-alpha detection",
                " level, a measurement with a level of about 15 MeV has",
                " now been done (see status)."
              ]
            }
          ],
