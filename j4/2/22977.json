          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "237Np standardized HCl solution (2.5 micro-liter,",
                " ~130 Bq) on a quartz plate (30 mm x 10 mm x 2 mm)",
                " covered with an acrylic capsule and wrapped with",
                " a pure Al foil with neutron flux monitor (Au/Al and",
                " Co/Al).",
