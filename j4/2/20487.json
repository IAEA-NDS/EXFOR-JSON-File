          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-The total cross-section of natural uranium for fast",
                " neutrons in the energy range 0.8 - 9.0 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                "    Electron linear accelerator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "PHOTO"
                ],
                "reaction": null
              },
              "free_text": [
                "    3.5 nanos. Bursts of 100 MeV electrons",
                " incident on a natural uranium target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".2.54 cm thick, 2.54 cm diam. Cylinder, natural."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "      100 meter time-of-flight facility."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                "    12 cm diam. And 5 cm thick cell of Ne211",
                " liquid scintillator."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The use of nuclear model calculations has shown that",
                " coupled channel calculations fit well the U-238",
                " X-sect. The optical model with spherical potential",
                " is less successful."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Transmission measurement."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " In comparing the results with those of other workers",
                " and with theory, the differences in isotopic purity",
                " between uranium (used in this experiment),  depleted",
                " uranium and pure U-238 were ignored."
              ]
            }
          ],
