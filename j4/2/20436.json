          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  COMPARING TOTAL ACTIVATIONS OF NB-93(N,N )(METAST.)",
                "  AND RH-103(N,N )(METAST.) MEASURED AT DIFFERENT",
                "  POSITION IN THE REACTOR SAPHIR SHOWED THAT THE",
                "  ACTIVATIONS OF BOTH ELEMENTS ARE PROPORTIONAL(SEE",
                "  FIG.II.6 AND FIG.II.7 IN PUBLICATION) AND THE",
                " RELATION-",
                "  NB-93-(N,N )(METAST.)=R*RH-103(N,N )(METASTABLE),",
                "  WHERE R IS A CONSTANT FACTOR, CAN BE USED TO",
                "  CALCULATE THE NB-93(N,N )(METAST.) CROSS-SECTIONS.",
                "  R=0.163+-0.014 AND THE RH-103(N,N )(METAST.) CROSS-",
                "  SECTION BY J.P.BUTLER AND D.C.SANTRY, PROC. WASH.",
                "  CONF. ON NEUTRON CROSS-SECTION AND TECHNOLOGY,",
                "  VOL.2, 803(1968) MULTIPLIED BY 0.852 (THE RATIO OF",
                "  CONVERSION COEFFICIENTS ALPHA(K)/ALPHA OF RH-103(M)",
                "  TAKEN BY THESE AUTHORS WAS TOO LOW, = 0.099 INSTEAD",
                "  OF 0.131) WERE USED."
              ]
            }
          ],
