          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-DETERMINATION OF THE 237NP(N,2N)236NP CROSS SECTION",
                " AT 15 MEV NEUTRON ENERGY-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                " TYPE K 3000 VAN DE GRAAFF GENERATOR OF THE",
                " GESELLSCHAFT FUER STRAHLEN-UND UMWELTFORSCHUNG,",
                " NEUHERBERG."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " THE ACCELERATED DEUTERON BEAM OF THE VAN DE",
                " GRAAFF BOMBARDED A TRITIUM TARGET TO PRODUCE 15 MEV",
                " NEUTRONS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE 237-NP CONTAINED 236-PU,THE ACTIVITY OF WHICH",
                " WAS LESS THEN 1PC OF THE RESULTANT ACTIVITY OF THE",
                " PU-236, PRODUCED AFTER IRRADIATION.",
                ".THE SAMPLE WAS IRRADIATED AS NPO2 IN A POLYETHYLENE",
                " CAPSULE SURROUNDED BY CD."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " TWO INDEPENDENT METHODS WERE EMPLOYED.",
                ".THE DIRECT MEASUREMENT OF GAMMA RAYS FOLLOWING",
                " ELECTRON CAPTURE OF 236-NP TO 236-U.",
                ".THE MEASUREMENT OF ALPHA PARTICLES OF THE 236-PU",
                " (FROM BETA-DECAY OF 236-NP) AFTER CHEMICAL",
                " SEPARATION."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " THE GE(LI) WAS USED IN THE GAMMA MEASUREMENT."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " A SI SURFACE BARRIER DETECTOR WAS USED FOR",
                " ALPHA COUNTING."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "       .THE REACTION 27AL(N,ALPHA)24NA WAS USED",
                " AS A NORMALIZING STANDARD FOR THE INCIDENT FLUX.",
                "  SEE H.VONACH ET AL.,Z.PHYS.,237,155(1970),THE DECAY",
                " -GAMMAS OF THE 24-NA WERE MEASURED BY A GE(LI)",
                " DETECTOR (FLUX-6.77+-0.24X10E+13 NEUTRONS PER CM2).",
                ".A SECOND STANDARD WAS PROVIDED BY THE DETERMINATION",
                " OF THE ACTIVITY OF THE FISSION PRODUCT 97-ZR.",
                "  FLUX-6.40+-0.73X10E+13 NEUTRONS PER CM2."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DATA FOR THE CROSS SECTION OF THE REACTION",
                " 237NP(N,2N)236NP TAKEN FROM REFERENCE."
              ]
            }
          ],
