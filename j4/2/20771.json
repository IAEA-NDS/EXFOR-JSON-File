          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".PU-239 METAL DISC IN CADMIUM BOX ON THE 0 DEGREE",
                " AXIS OF THE BEAM.",
                ".DISCS WERE 15 MM IN DIAM AND 0.125 MM THICK.",
                ".ISOTOPIC COMPOSITION WAS FOUND BY MASS-SPECTROMETRY",
                " TO BE",
                "   PU-238       0.016    ATOM PERCENT",
                "   PU-239      96.328    ATOM PERCENT",
                "   PU-240       3.461    ATOM PERCENT",
                "   PU-241       0.187    ATOM PERCENT",
                "   PU-242       0.008    ATOM PERCENT.",
                ".ABOUT 2 GRAMS WERE USED FOR EACH IRRADIATION.",
                ".THE PU DISCS WERE SPACED BY THREE GOLD DISCS."
              ]
            }
          ],
