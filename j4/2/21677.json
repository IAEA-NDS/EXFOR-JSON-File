          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Detection of gammas in coincidence with alphas",
                " from the d-t reaction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 20 cm3 Ge(Li) detector, placed 30 cm from",
                " the sample at 90 degrees to the axis of the neutron",
                " beam.",
                " Discrimination between prompt gammas and scattered",
                " neutrons was made by time of flight selection.",
                " For low energy gammas the photopeak was integrated,",
                " while for high energy gammas the double escape peak",
                " was integrated."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Relative excitation functions are normalized to",
                " absolute values using a Ra-226 source and the",
                " reaction Mg-26(p,gamma)Al-27."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                " Prompt inelastic gammas."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
