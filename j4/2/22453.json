          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The target material of the 178-Hf-m2 was produced at",
                " the irradiation of highly enriched isotope 176Yb",
                " (99.998%) on the dubna U-200 cyclotron at the end of",
                " 1991. To the moment of neutron irradiation the 25-day",
                " activity of 179Hf was fully decayed. High chemical",
                " purification was achieved. About 10.E12 atoms of",
                " 178-Hf-m2 were put on each of every 4 samples. Every",
                " sample was placed between neutron filters together",
                " with gold standard sample"
              ]
            }
          ],
