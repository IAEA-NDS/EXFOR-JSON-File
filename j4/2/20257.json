          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal neutron flux 1.5E+13 n/cm2/sec,",
                " fast neutron 1.0E+12 n/cm2/sec,",
                " Measured K-factor (K = (phi(F))/(nv0), nv0 is thermal",
                " n-flux and phi(F) is the equivalent fast n-flux) shows",
                " that incoming spectrum is close in a pure fission one",
                " for the reactions under consideration."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " About 500 mg of spec. pure nickel metal sealed in",
                " polyethylene ampoules."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " radio-chemical method based on anion exchange",
                "in strong hydrochloric acid and subsequent",
                "precipitation with alpha-nitroso-beta naphthol was",
                "used for the isolation of cobalt reaction product."
              ]
            }
          ],
