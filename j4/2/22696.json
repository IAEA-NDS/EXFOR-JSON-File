          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " .Twelve samples of 241Am oxide containing each near",
                "  30 microgram 241Am oxide sealed in quartz ampule",
                " .Sample irradiation -",
                "  241Am mass    irradiation duration  neutron flux",
                "  microgram     days                  n/cm2/sec",
                "  ------------  --------------------  --------------",
                "   29.52+-0.53      2.08E-2=30 min.     6.E+14",
                "   29.94+-0.47      0.95                6.E+14",
                "   30.21+-0.54      2.01                6.E+14",
                "   27.89+-0.50      5.02                6.E+14",
                "   31.52+-0.57     10.98                6.E+14",
                "   25.24+-0.45     10.98                6.E+14",
                "   25.32+-0.46     19.03                6.E+14",
                "   38.14+-0.69     19.03                6.E+14",
                "   37.92+-0.68      5.01                2.E+13",
                "   27.95+-0.50     11.01                2.E+13",
                "   29.81+-0.54     24.0                 2.E+13",
                "   29.85+-0.54     24.0                 2.E+13",
                ".Initial composition of samples is -",
                " Np-237/Am-241 = (25.3 +- 0.8)E-3",
                " Pu-239/Am-241 = (3.63 +- 0.04)E-3",
                " Pu-238/Pu-239 = (11.32 +- 0.20)E-3",
                " Pu-240/Pu-239 = (371.9 +- 1.5 )E-3",
                " Pu-241/Pu-239 = (42.42 +- 0.20)E-3",
                " Pu-242/Pu-239 = (44.58 +- 0.25)E-3"
              ]
            }
