          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Metallic natural Ti strips (3 mm *20 mm *0.075 mm)",
                " (NH4)2SO4 used as monitor sample, 120 mg",
                " melted into small glassampoules (6 cm long, 0.5 cm",
                " diam). 90 samples were used. About 45 of them were",
                " covered with Cd, 0.5 mm thick to estimate the",
                " contributions from Sc and P impurities in sample",
                " and monitor."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "COINC"
              ],
              "free_text": [
                " Activation measurements with and without",
                " Cd cover for the sample. The yields of the reaction",
                " are isolated by the determination of the beta",
                " absorption curves."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Beta-gamma and 4*Pi beta-gamma coincidence apparatus."
