          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron-tritium, 14 MeV neutrons."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Measurement of recoil proton spectra. 15 hr",
                " measuring time per spectrum, both direct and",
                " background, n flux 3.E+8 n/second +- 8%.",
                ".Energy scale of proton spectra calibrated with",
                " (n,p) reactions on Si of the solid state detector."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SIBAR"
              ],
              "free_text": [
                " Telescope arrangement consisting",
                " of 3 proportional counter operated with C-O(2) gas",
                " flow and a surface barrier detector. Energy resol.",
                " 400 keV FWHM at 14 MeV, i.e. 2.8%, total",
                " efficiency 3.0E-7."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Fitting of expressions from statistical model to",
                " the proton evaporation spectra. Occurrence of",
                " deuterons neglected. At higher energies there is some",
                " evidence for direct reactions.",
                ".Level density parameter given for n=2, since this",
                " gave the best fits."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Proton spectra corrected for background (30.-60.%)",
                " energy loss in the detector windows and in",
                " the C-O(2) gas."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
