          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Spectroscopy of protons from 14 MeV neutron induced",
                " nuclear reactions with a counter telescope"
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2GERUEN"
              ],
              "free_text": [
                ""
              ]
            }
          ],
