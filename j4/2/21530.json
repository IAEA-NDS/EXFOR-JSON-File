          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Aqueous solution containing 250mg U-235 as uranyl",
                " nitrate and ruthenium tracer irradiated. Ru fission",
                " products seperated by oxidation to volatile RuO4",
                " by Cl gas. Irradiation times of 5 to 250 secs, with",
                " gamma counting starting 10 secs after irradiation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detector for gamma counting of",
                " seperated Ru isotopes."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Gamma decay lines are assigned to various Ru",
                " isotopes from a=107 to 110, or to their daughter",
                " products on the basis of half lives, intensity",
                " ratios and known level properties. Ru-111 is",
                " identified with a half-life of 1.5+-0.3 secs."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
