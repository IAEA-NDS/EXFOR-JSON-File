          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal neutron induced alpha-particle reaction",
                " on Zn-64,65,67 and Se-77"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2FR ILL"
              },
              "free_text": [
                " Grenoble high flux reactor."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "THCOL"
                ],
                "reaction": null
              },
              "free_text": [
                " Curved neutron guide-tube from the reactor.",
                " Neutron flux about 10**9 neutrons/cm2/sec."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Thermal Maxwellian spectrum with a",
                " thermal to epithermal ratio of 10**6."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Natural Zn and Se evaporated onto an aluminum",
                " backing, Zn thicknesses 0.287 mg/cm2 and 0.056 mg/cm2",
                " and Se thickness of 0.260 mg/cm2.",
                ".Enriched isotopes were implanted using the isotope",
                " -separator in Lyon,",
                "   isotope     isotopic purity       thickness",
                "                  percent             mg/cm2",
                "     Zn-64          99.               0.010",
                "     Zn-67          90.               0.0053",
                "     Se-77          99.               0.0195",
                " The Lyon isotope separator was extensively used to",
                "produce highly pure 64Zn, 67Zn and 77Se isotopes and",
                "implant them into very pure 20 mu-m A1 backings; this",
                "resulted in extremely good quality targets."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Direct detection of emitted particles."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A 450 mm2 area surface barrier detector with",
                " an active depth of 0.1 mm."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "3-LI-6(N,T)2-HE-4,,SIG,,MXW",
                  "code_unit": [
                    {
