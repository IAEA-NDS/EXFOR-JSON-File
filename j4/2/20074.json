          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " An absolute measurement of nu-bar of Cf-252"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                "    Measurement of coincidences between fission",
                " and capture gamma rays",
                "  Neutron detection efficiency = 0.6905+-0.0053"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                "    Fission chamber mounted in centre of axial",
                " tube through scintillation tank, which is a"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                "    60 cm glass bulb, filled with p-terphenyl",
                " and 'POPOP' in tri-ethylbenzene, loaded with cadmium",
                " octoate.  Cadmium/hydrogen atomic ratio about 0.002.",
                " 12 photomultipliers uniformly distributed over sphere",
                " surface"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  n-detection efficiency determined by n-p scattering",
                " in anthracene crystal replacing the fission chamber",
                " nu-bar=1.",
                " Adding the number of delayed neutrons per fission",
                " 0.86E-2,  a total nu-bar of 3.778 +- 0.038 is obtained",
                " (error given in 72VIENNA,,277,7211 is wrong according",
                " to private communication with author)."
              ]
            }
          ],
