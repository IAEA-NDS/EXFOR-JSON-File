          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Because exact energy spectrum is not necessary an",
                " assumption of flat spectrum in each energy bin was",
                " made. Two measurement runs were made, final results",
                " represent arithmetic average of both runs"
              ]
            }
          ],
          "DETECTOR": [
