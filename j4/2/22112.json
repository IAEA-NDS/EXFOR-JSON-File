          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "  Big NE213 liquid scintillator 14 cm diameter by",
                " 10 cm thick, and small NE213 liquid scintillator for",
                " monitor. The detectors were equipped with pulse-shape",
                " discrimination for gamma-ray rejection.",
                "The relative efficiency of the detector was determined",
                "on the basis of Monte-Carlo calculation, and",
                "measurements of fission neutrons from 252Cf and of",
                "hydrogen-scattered neutron yields at 14 and 18 MeV"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Cylinders of elemental uranium or thorium, 2 cm in",
                " diameter and 5 cm long. The samples were placed about",
                " 10 cm from the neutron-producing target.",
                ".Lead sample for elastic scattering corrections"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The data were corrected for:",
                "  * backgrounds and detector efficiency,",
                "  * neutron multiple-scattering in the sample,",
                "  * tail of elastically-scattered neutrons,",
                "  * finite time-resolution of the T-O-F spectrometer,",
                "  * time-shift due to detector thickness,",
                "  * elastic scattering."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " Experimental data compared with ENDF/B-IV and",
                "       JENDL-2 evaluations"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "N-SPC"
              ],
              "free_text": [
                " Neutron spectra are fitted to Maxwell and Watt",
                "        type distributions:",
                "   Nmaxw(E) = Cm*SQRT(E)*exp(-E/Tm); and",
                "   Nwatt(E) = Cw*exp(-E/A)*sinh(B*E), where",
                " for Th-232 Tm=1.26, A=0.96, B=2.17;",
                " for U-238  Tm=1.25, A=0.97, B=2.17.",
                ".Graphs of DDX spectra for 14.1 MeV neutrons on Th232",
                " and U238, angles 30, 90, 150 degree, are given"
              ]
            }
          ],
