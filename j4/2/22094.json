            {
              "pointer": "",
              "coded_information": [
                "D4PI"
              ],
              "free_text": [
                " A 4PI-BETA-GAMMA SPECTROMETER."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ALUMINIUM FOILS OF PURITY EXCEEDING 99.99 PERCENT AND",
                " WITH THICKNESSES RANGING FROM 0.05 TO 0.5 MM WITH THE",
                " DIAMETER 25.4 MM WERE USED. THE SAMPLES WERE",
                " IRRADIATED FOR ABOUT 30 MIN WITH A DEUTERIUM BEAM",
                " CURRENT OF 3 - 10 MICROAMPS. FOR THE MEASUREMENTS AT",
                " 14.6 MEV THE SAMPLES WERE PLACED AT AN ANGLE OF 45",
                " DEGREES WITH RESPECT TO THE DEUTERON BEAM, WHILE AT",
                " THE OTHER ENERGIES THE SAMPLES WERE PLACED AT 0",
                " DEGREES. THE DISTANCE FROM THE SOURCE TO THE SAMPLES",
                " WAS 50 TO 100 MM."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE DATA WERE CORRECTED FOR CONTRIBUTIONS FROM THE",
                " D+D NEUTRONS IN THE D+T NEUTRON FIELD, AND FOR BACK-",
                " GROUND NEUTRONS FROM THE TARGET ASSEMBLY AND THE ROOM."
              ]
            }
