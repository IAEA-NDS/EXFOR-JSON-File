              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 2.E+8 n/sec in 4PI sr."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Semiconductor coaxial 1000cm3 gamma ray detector",
                "Ge(HP) of N type, 8x1024 channel pulse height analyzer.",
                "Resolution 3.3 keV at 1332 keV 60Co line.",
                "Detector was protected by W, Pb, borated PE shielding.",
                "Half-lives of short-lived nuclei were measured with the",
                "fast multiscaler ORTEC MCS PLUS controlled by a single",
                "channel analyzer (ORTEC SCA 550) allowing the",
                "identification of the wanted gamma line.",
                "Detection efficiency was determined by 152-Eu source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Cyclic activation .",
                " Neutron flux at the sample position was determined by",
                " Cu-63(n,2n)Cu-62 reaction."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
