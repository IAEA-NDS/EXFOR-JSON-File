              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": null
              },
              "free_text": [
                " SODERN sealed tube neutron generator.",
                "100 muA current, 125 kV voltage.",
                "Pulse width 5musec - 10msec.",
                "Frequency from 1 Hz to 10 kHz ."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron beam on tritiated target.",
