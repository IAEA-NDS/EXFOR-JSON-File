          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Pu-240 fission isomers were produced by the",
                "reaction U-238(alpha,2n) using a 25 MeV alpha beam from",
                "Munich MP tandem accelerator 50 micro-g/cm2 U-238,",
                "evaporated on 20 micro-g/cm2 carbon."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The U-238 sample was located in a 4 mm diameter",
                " hole of a 4 cm2 surface barrier annular detector. The",
                " recoil nuclei fission in flight in front of two addi-",
                " tional surface barrier detectors, placed at about 50",
                " degrees with respect to the beam axis. The detectors",
                " were calibrated with a Cf-252 source."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                "    Fission fragments."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections were applied for Doppler effects."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
