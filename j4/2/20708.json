          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-NON-STATISTICAL ASPECTS OF RESONANCE NEUTRON CAPTURE",
                " IN 103RH-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                " HARWELL 45MEV ELECTRON LINAC."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NEUTRON BOOSTER TARGET.",
                ".NEUTRON PULSE WIDTH WAS ABOUT 0.15 MICROS WITH A",
                " REPETITION FREQUENCY OF 192HZ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".100G RHODIUM METAL POWDER IN A 62.5MM DIAMETER THIN-",
                " WALLED ALUMINIUM SAMPLE CAN FOR THE HIGH ENERGY",
                " GAMMA RAY SPECTRA.",
                ".6.7G RHODIUM METAL IN THE FORM OF A 50MM SQUARE FOIL",
                " FOR THE LOW ENERGY SPECTRA."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME-OF-FLIGHT AND GAMMA-PULSE-HEIGHT IN",
                " COINCIDENCE.",
                ".RUNNING PERIOD WAS 4 WEEKS ON A 10M FLIGHT PATH."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 9CM3 PLANAR GE(LI) DETECTOR."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE 1EV RUN WAS ANALYSED SEPARATELY."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR THE 1EV RESONANCE THE GAMMA ENERGY-SCALE WAS",
                " ESTABLISHED USING A BA-133 SOURCE AND THE 511KEV",
                " ANNIHILATION PEAK.",
                ".THE SCALE FOR THE HIGHER ENERGY GAMMA RAYS WAS",
                " ESTABLISHED USING THERMAL CAPTURE GAMMA RAYS OF",
                " HYDROGEN, SILICON, CALCIUM AND IRON."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE ERRORS ARE THOSE DERIVED FROM STATISTICAL",
                " UNCERTAINTIES IN THE GAMMA RAY PEAK AREAS.",
                ".THE UNCERTAINTIES IN PEAK POSITION WAS AT MAXIMUM",
                " +-2KEV.",
                ".THE GAMMA RAY RESOLUTION WAS ABOUT 9KEV AT 7.6MEV."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CORRELATIONAL ANALYSIS WAS CARRIED OUT TO",
                " INVESTIGATE THE REACTION MECHANISM."
              ]
            }
          ],
