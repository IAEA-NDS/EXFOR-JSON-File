                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Fluctuations of measured values were mainly",
                " statistical, it was established by analysis of",
                " measurement on gold."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
