          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Sample irradiated in the reflector surrounding the",
                " core of the reactor, giving a thermal N-flux 5.0E+11",
                " n/cm2/s and an epithermal index in the Westcott con-",
                " vention of 0.033."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation time 2 min. irradiations were per-",
                " formed with and without cadmium shielding. the delay",
                " time from end of irradiation to start of activity",
                " measurement was typically 1 min.",
                ".the monitor wires were irradiated for 10 min."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activities were measured with a HPGE detec-",
                " tor, having a relative efficiency of 90 percent and a",
                " resolution of 2.1 keV FWHM at 1.33 MeV. the distance",
                " from the centre of the sample to the front end of the",
                " detector was 100 mm. The peak efficiency was measured",
                " with a calibrated multi-gamma source, containing",
                " Sn-118, Sr-85, Cs-137, Y-88 and Co-60."
              ]
            }
          ],
