          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The energy distribution of the cold neutron beam  is",
                "presented on Fig.2 of J,NDS,119,69,2014.",
                "The neutron flux was determined using the count rate",
                "of the 412 keV peak and the counting efficiency of the",
                "detector.",
                "Thermal equivalent flux of 2.5*10**10 1/cm2/s ."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Samples were irradiated for 5 to 12 h at a",
                "thermal equivalent flux of 2.5*10**10 1/cm2/s .",
                "The decay radiation was counted for 1 hr."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-ray spectra were measured using a",
                "DSPEC 50 MCA and a 60-% n-type Poptop HPGe detector.",
                "152Eu and 133Ba calibration sources with a given",
                "uncertainty of 1.5% were measured in order to calculate",
                "the detector efficiency."
              ]
            }
          ],
