          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections for photon absorption in the quartz glass,",
                "for the neutron absorption in the gold foil (0.3 %) and",
                "the decay corrections were applied to obtain the",
                "saturation activity.",
                "The contribution of influence of the 241Am gamma-rays",
                " (98.97 keV, 102.98 keV) in the order of 5-10% was also",
                "subtracted."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The region of peaks was integrated channel by channel a",
                "the baseline subtracted. After corrections the",
                "Am-242(n,Gamma)Am-242g cross-section was determined fro",
                "the amount of Am-242, the saturation activity and the",
                "measured neutron flux."
              ]
            }
