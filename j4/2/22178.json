              },
              "free_text": [
                " 4 MV VAN DE GRAAFF ACCELERATOR, DEUTERON",
                " BEAM ENERGY 1.8 - 4.0 MEV, BEAM CURRENT 15 - 25 MUA."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SPECM"
                ],
                "institute": "2FR GRA"
              },
              "free_text": [
                " 60 DEG AND 12 CM RADIUS MASS",
                " SPECTROMETER."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D",
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " CYLINDRICAL GAS TARGET 100 MM LONG AND 15 MM",
                " IN DIAM FILLED WITH GASEOUS 2-H OR 3-H AT A PRESSURE",
                " OF 1.5 BAR. TARGET COOLED BY REFRIGERATED HE CIRCULAT-",
                " ING BETWEEN TWO 2.4 MICRON THICK HAVAR FOILS SEPARATED",
                " BY 5 MM AND ISOLATING THE NEUTRON PRODUCING TARGET",
                " FROM THE EVACUATED EXTENSION.",
                "   EN = 5 - 7 MEV: 2-H TARGET WITH ED = 2.4 - 4 MEV",
                "   EN = 16 - 19 MEV: 3-H TARGET WITH ED = 1.8 - 3.2 MEV"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ENERGY RESOLUTION (+- HWHM) CALCULATED TAKING INTO",
                " ACCOUNT KINEMATICS AND ENERGY LOSS AND STRAGGLING IN",
                " APPARATUS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NATURAL MG, 99.99% PURE, IN A DISC 16.5 MM IN DIAM AND",
                " 2 MM THICK, PLACED WITH ITS AXIS ALONG THE DEUTERON",
                " BEAM AXIS AND 50 MM FROM THE END OF THE GAS TARGET",
                " CYLINDER."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " 'E DELTA-E' PROTON RECOIL TELESCOPE TO MONITOR",
                " NEUTRON BEAM, PLACED 100 CM FROM CENTRE OF GAS TARGET",
                " AT AN ANGLE OF 20 DEG TO BEAM AXIS. ABSOLUTE CALI-",
                " BRATION PERFORMED USING A SECOND SIMILAR TELESCOPE AND",
                " ABSOLUTE EFFICIENCY CALCULATED USING A PRECISE SIMU-",
                " LATION CODE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " MASS SPECTROMETER USED TO MEASURE NE",
                " CONCENTRATIONS IN MG SAMPLES. THE SAMPLES WERE",
                " OUTGASSED AT 85 DEG-C UNDER VACUUM FOR SEVERAL DAYS,",
                " AND THE RELEASED NE WAS CLEANSED USING TI SPONGES,",
                " HEATED CU-O-PD POWDER AND ACTIVATED CHARCOAL TRAP.",
                " ABSOLUTE NEON CALIBRATION WAS OBTAINED WITH A GAS",
                " PIPET OF AIR COMPOSITION."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NEUTRON FLUENCE IS NOT CORRECTED FOR ATTENUATION AND",
                " MULTIPLE NEUTRON SCATTERING IN MG SINCE THESE EFFECTS",
                " ARE NEGLIGIBLE IN A 2 MM THICK SAMPLE."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " QUADRATIC SUM OF OVERALL ERRORS IN FOLLOWING",
                " QUANTITIES:",
                "    NO. OF MG ATOMS IN THE TARGET",
                "    INTEGRATED NEUTRON FLUX (INCLUDING TELESCOPE EFFI-",
                "      CIENCY CALIBRATION, TELESCOPE-GAS TARGET DISTANCE",
                "      AND COUNTING STATISTICS)",
                "    MEASURED NE CONCENTRATIONS (INCLUDING CORRECTIONS",
                "      FOR CALIBRATION, TARGET/SYSTEM BLANKS, AND",
                "      THE CONTAMINANTS 40-AR(2+), WATER AND CO2(2+))."
              ]
            }
          ],
