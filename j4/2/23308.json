          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " CS ratio was defined as",
                "SIG13/SIG12= (I13/I12)*(N12/N13), where",
                "I13 - C-13 net peak area,",
                "I12 - C-12 net peak area,",
                "N12 -  fraction of C-12 in the diamond,",
                "N13 -  fraction of C-13 in the diamond.",
                "      Alpha-0 energy for C-12(n,alpha-0) - 11.3 MeV",
                "                     for C-13(n,alpha-0) - 13.2 MeV",
                "              at En= 17.0meV",
                " 8.6 MeV and 10.5 MeV for 14.3 MeV ."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
