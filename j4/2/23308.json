              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Quasi-monoenergetic neutron beam.",
                " The incident neutron spectra were determined using",
                "the TARGET code [12].",
                " 14.3 MeV ( 182 keV FWHM) at 98 deg.",
                " 17.0 MeV (379 keV FWHM) at 45 deg."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  Diamond detector was served also as carbon sample.",
                "  Isotopic composition:",
                " C-12 - 98.892+-0.003 %, C-13 - 1.108+-0.003 % ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A CIVIDEC B1 Single-Crystal Diamond Detector (sCVD)",
                "of thickness of 500 mum, with electrodes of 4mm x 4mm",
                "area. Installed at 50mm distance from the target.",
                "Measurements were performed at two angles 98 deg and",
                "45 deg relative to the deuteron beam direction.",
                "Coupled to a CIVIDEC C2 Broadband Amplifier with 2 GHz",
                "analogue bandwidth, 40 dB gain, an equivalent input",
                "current noise of 0.4 muA."
              ]
            }
          ],
