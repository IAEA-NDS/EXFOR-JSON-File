          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "           TONNERRE was installed at the final focus",
                "of the LISE3 spectrometer ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A primary beam of 18-O, 77 A MeV, and a thick (4000",
                "microm) Be target were employed to produce secondary",
                "beams of 15-B, 16-C and 17-N."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 32 plastic scintillator (BC400) modules, each",
                "provides for time-of-fight (energy) and position",
                "measurements. The intrinsic detection efficiency is 30%",
                "at En=2 MeV and the resolution dE/E = 10% (FWHM). The",
                "array can cover a total solid angle up to 50% of 4PI.",
                "The 32-detector modules were arranged in two layers,",
                "23 in the 1st layer and nine in the 2nd."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "PS",
                "SCIN",
                "SIBAR"
              ],
              "free_text": [
                " A detector telescope",
                "which provided for ion identification, collection and",
                "beta-detection was located at the centre of the array.",
                "Consists of Al degrader and four active elements :",
                " -surface barrier detector of 5x5 cm2, 300 microm",
                "thick as dE detector;",
                "- Si XY position-sensitive detector of 5x5 cm2,",
                "300 microm thick;",
                "- NE102A plastic scintillator block , 3x3x1 cm3, viewed",
                "by two XP2972 photomultipliers, for Beta decay",
                "detection;",
                "- Si surface barrier veto detector, 5x5 cm2, 500 microm",
                "thick."
              ]
            }
          ],
          "EN-SEC": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "E",
                "particle": "N"
              },
              "free_text": [
                " Energy of delayed neutrons.",
                "Experimental energy resolution ( Table 2):",
                " Energy,MeV     1      2      3     4     5",
                " dE/E, %        10.3   10.6   10.8  11.1  11.3",
                " FWHM,keV       103    212    318   444   565"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " dE-TOF method"
              ]
            }
          ],
