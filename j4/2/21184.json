          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Data derived from cross-section for natural Sm by",
                " attributing all absorption to Sm-149 at thermal",
                " energies. This assumption was verified by irradiating",
                " samarium sulphate in the NRX pile at Chalk River and",
                " analysing with a mass spectrometer to confirm that",
                " the only significant change was the conversion of",
                " mass 149 to mass 150.",
                ".Sm-149 content of natural sample 13.82+-0.04%."
              ]
            }
          ],
