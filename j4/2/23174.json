          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Flight path 6m, 3m, 1.5 m - geometry 1,2,3.",
                "Time resolution about 6 ns FWHM.",
                "At distance of 1.5 m measurements were also made with",
                "lead shield between Cf source and NaI(Tl) detector -",
                "geometry 4.",
                "For measurement in nano and subnanosecond region -",
                "recoil distance method was used - NaI(Tl) detector at",
                "50 cm distance from Cf source,  40 cm long lead",
                "collimator; two series of measurements were made - with",
                "collimator widths of about 8mm and 2 mm in geometries 5",
                "and 6 (data set 5 and 6), respectively."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data were normalized to gamma-rays per prompt gamma-ray",
                "per channel(0.57ns) by setting the area of prompt",
                "gamma-ray peak ( from -10 to 12.5 ns) to unity.",
                "Data obtained with path 6m ( in range 45-120 ns) and",
                "3 m ( in range 30-54 ns) were accepted for analysis",
                " -data set 1 and 2, respectively."
              ]
            }
          ],
