          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Angular distribution and polarization of scattered",
                " neutrons of 3.3 MeV on copper, tantalum, lead and",
                " bismuth"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2SWTETH"
              },
              "free_text": [
                " Cockcroft-Walton accelerator (800 kV)."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " D-D-neutrons, heavy ice target, energy",
                " spread of neutrons 40 keV, D(+) current 15 muAmp/cm2"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Detection of scattered neutrons by two equal",
                " detectors at azimuth-angles of 0 and 180 degrees,",
                " scattering angles from 30 to 150 degrees, scattering",
                " samples in collimated neutron beam."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation detectors, anthracene crystals",
                " cross section 14*20 mm2, length 25 mm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation detector with anthracene",
                " crystal, cross section 25*25 mm2, thickness 2.5 mm,",
                " as neutron flux monitor.",
                ".Position of neutron monitor 160 mm from target",
                "within the collimator. The lead collimator consists of",
                "a conical channel with quadratic cross section (wall",
                "thickness 25 mm, length 530 mm) surrounded by blocks",
                "containing 75% weight paraffin and 25% weight boric",
                "acid. Total thickness of the shielding 45 cm all around"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrections were applied for multiple scattering of",
                " neutrons in samples, finite geometry (sample -",
                " detector), background-scattering, dependence of",
                " detector efficiency on neutron energy, anisotropy",
                " of the neutron source, attenuation of neutron",
                " intensity in samples, influence of strange nuclei",
                " in samples, inelastic scattering."
              ]
            }
          ],
