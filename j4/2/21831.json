          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ALL SAMPLES WERE CONTAINED IN IDENTICAL 0.2 MILLI-M",
                " THICK ALUMINIUM CANS.",
                "  FE-56  NATURAL METALLIC FE. WEIGHT 9.901 G,",
                "         THICKNESS 8.495E-03 ATOMS/BARN.",
                "  FE-58  ENRICHED FE2-O3 OXIDE WITH THE FOLLOWING",
                "         ISOTOPIC COMPOSITION - 1.14 PER CENT FE-54",
                "         23.74 PER CENT FE-56,  1.86 PER CENT FE-57",
                "         73.26 PER CENT FE-58.  WEIGHT 19.619 G,",
                "         THICKNESS 1.155E-02 ATOMS/BARN.",
                "  AU-197 NATURAL METALLIC AU. WEIGHT 23.525 G,",
                "         THICKNESS 5.722E-03 ATOMS/BARN.",
                "  C      NATURAL GRAPHITE. WEIGHT 15.034 G,",
                "         THICKNESS 5.997E-02 ATOMS/BARN."
              ]
            }
          ],
