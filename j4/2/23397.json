          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "RA-BE"
                ],
                "reaction": null
              },
              "free_text": [
                " 50 mg Ra+Be in a cylindrical case filled by",
                " paraffin (20 cm diam.)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fraction of thermalized neutrons is about 90%.",
                " Epithermal neutrons were removed by Cd foil."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "U3O8 (1762 g) and Pb (2000 g) in an iron case (0.5 mm",
                " thick). 529 cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " BCl3 gas (848 cm3) for detection of thermal",
                " neutrons at 70 cm from the front of the neutron",
                " source case"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Transmissions were measured for U3O8 and Pb",
                " samples irradiated at two locations -",
                " (1) 30 cm upstream side from the ionization chamber,",
                " (2) just before the ionization chamber."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measured effective total cross section at samle",
                " position 1 (sig1) and 2 (sig2) were related with the",
                " capture cross section (sigc) and scattering cross",
                " section (sigs) as follows:",
                "  sig1(U3O8)=sigc(U3O8)+k1*sigs(U3O8),",
                "  sig2(U3O8)=sigc(U3O8)+k2*sigs(U3O8),",
                "  sig1(Pb)=k*k1*sigs(Pb),",
                "  sig2(Pb)=k*k2*sigs(Pb),",
                " with k=k1=1 assumed according to the the experimental",
                " geometrical condition (sigc(Pb)~0 assumed).",
                " From these equations, sigc(U3O8), sigs(U3O8), sigs(Pb)",
                "  as well as k2 were determined."
              ]
            }
          ],
