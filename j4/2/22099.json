          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Renormalization of kT=25 keV Maxwellian averaged",
                " cross section by Macklin (655 mb).",
                "The measured spectrum averaged cross section (586 mb)",
                " was",
                " 1. multiplied by the Macklin's excitation function",
                "    folded by true Maxwellian shape (557 mb),",
                " 2. divided by the Macklin's excitation function",
                "    folded by the 7Li(p,n) neutron spectrum (568 mb),",
                "    and then",
                " 3. multiplied by 2/sqrt(pi)~1.13."
              ]
            }
          ],
