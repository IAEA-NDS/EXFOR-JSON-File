          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thermal flux (n*v0) and the epithermal index",
                " r*sqrt(T/T0) determined from 197Au(n,g)198Au and",
                " 59Co(n,g)60Co are",
                " -----------------------------------------------",
                "             n*v0 (n/s/cm2)     r*sqrt(T/T0)",
                " -----------------------------------------------",
                " Slant(1st)  (1.07+/-0.03)E+13  0.0129+/-0.0009",
                " Slant(2nd)  (9.90+/-0.03)E+12  0.0118+/-0.0008",
                " Slant(3rd)  (1.20+/-0.04)E+13  0.0133+/-0.0009",
                " Hyd         (1.08+/-0.03)E+14  0.0322+/-0.0023",
                " Pn-2        (1.97+/-0.06)E+13  0.0401+/-0.0028",
                " -----------------------------------------------"
              ]
            }
          ],
          "ASSUMED": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 59Co(n,g)60Co   sigma0 = 37.18 b, RI=   74   b",
                " 197Au(n,g)198Au sigma0 = 98.65 b, RI= 1550   b",
                " 232Th(n,g)233Th sigma0 =  7.4  b, RI=   84.4 b"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Approximately 100 or 200 mg of solid thorium (IV)",
                " nitrate tetrahydrate Th(NO3)4*4H2O irradiated with",
                " 0.1143% Au-Al and 0.483% Co-Al alloy foils"
              ]
            }
          ],
