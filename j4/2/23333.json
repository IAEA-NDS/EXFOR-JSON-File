            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "    30 m flight path."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Capture gamma spectra were collected as a",
                "function of neutron time of flight. Spectra were",
                "divided into three gamma-ray energy intervals:",
                "1.5 - 3.5 MeV ( LOW BIAS, transitions from resonances",
                "of both parities),",
                "4.3 - 5.2 MeV ( HIGH BIAS, transitions from p-wave",
                "structure),",
                " > 5.2 MeV ( Background data, to give the scattered",
                "neutron contribution, found to be featureless and was",
                "ignored)."
              ]
            }
          ],
