          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Pitchblende from Eldorado Mines, Great Bear Lake,",
                "Canada, ~50% U(3)O(8) - for long-lived nuclides.",
                "300 g - for Sr.",
                ".Pure UO(2)(NO(3))2*6H(2)O .",
                "900 g for Cs, 2.3 kg for Ba."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "     Phillips low-background assembly of pancake type",
                "G.M.Sonde 18516 Sample counter with a Fe-Cr window of",
                "10 mg/cm2 thickness. A stainless steel dome shaped",
                "anti-coincidence umbrella, filled with Ar and halogen",
                "quencher - as ring counter.",
                "Counting efficiency was determined by Sr-90, Y-90,",
                "P-32, Na-22 samples of various thickness with",
                "uncertainty 10-15 %."
              ]
            }
          ],
