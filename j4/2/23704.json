          "ANALYSIS": [
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                ".  Yield was calculated as",
                "  (NiLAMBLAi/(N238*LAMBLAsf))*100, where",
                "NiLAMBLAi - equilibrium activity of the fission product",
                "with mass number i,",
                "N238 - number 0f U-238 atoms,",
                "LAMBDAsf - U-238 spontaneous fission decay constant,",
                " (7.8+-0.9)*10**17 1/yr.",
                "2nd run - (3.96+-0.4)*10**-4 dis/sec per g U-238."
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
