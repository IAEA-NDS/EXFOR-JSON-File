          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The samples were prepared by vacuum evaporation onto",
                " a 0.2 mm stainless steel backing using planetary",
                " rotation during evaporation to obtain a good homo-",
                " geneity. The samples were 80 mm in diameter, and had",
                " thicknesses of 1.6 and 0.1 mg per cm2 for Bi-209 and",
                " U-238, respectively. The accuracy of the sample",
                " thickness was about 2%, and the inhomogeneity",
                " of the samples was less than 2%. It was found",
                " that the relative abundance of heavy fissile",
                " admixtures (like uranium) in the bismuth sample was",
                " less than 5 ppm."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrections for anisotropy of fission and linear",
                " momentum transfer from the incident particle to the",
                " fissioning nucleus were included when the fission",
                " cross sections were computed. Some correction factors",
                " were estimated using proton-induced fission data."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total error includes:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
