              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " detector calibration (3%),"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": 1.0,
                "maximum_value": 2.0,
                "correlation_property": null
              },
              "free_text": [
                " target thickness (1-2%),"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 3.0,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " counting statistics (3-5%)",
                " and an uncertainty of the relation of",
                " fission events induced by neutrons from the high",
                " energy peak in contrast to the low-energy tail of the",
                " neutron spectrum. The uncertainty is much larger for",
                " the 135 MeV data because no monitor was available,",
                " and hence the fluxes are less accurate."
              ]
            }
