          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Quasi-monoenergetic neutrons produced in the 7Li(p,n)",
                " reaction at zero degrees. About half of the neutrons",
                " have the quoted energy, with a spread of less than",
                " 2 MeV FWHM, and the rest of the neutrons form a tail",
                " extending from the maximum energy and down to zero,",
                " with a virtually flat spectrum shape. The intensity",
                " was about 100 000 maximum-energy neutrons per second",
                " over the entire detector area. Time-of-flight",
                " techniques allowed separation of maximum-energy and",
                " tail neutron events for the 160 MeV data."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ABSFY",
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Thin film breakdown counters were placed close",
                " to the fissile targets in the neutron beam."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                " Fission fragments were detected."
              ]
            }
          ],
