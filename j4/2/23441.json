          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "First determination of beta-delayed multiple neutron",
                "emission beyond A = 100 through direct neutron",
                "measurement: The P2n value of 136Sb"
              ]
            }
          ],
