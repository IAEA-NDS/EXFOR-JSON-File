          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "OLMS"
                ],
                "institute": "2SF JYV"
              },
              "free_text": [
                " Penning trap mass spectrometer JYFLTRAP",
                "at the Ion Guide Isotope Separator On-Line (IGISOL)",
                "facility, located in the Accelerator Laboratory of the",
                "University of Jyvaskyla, Finland (JYFL)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pure ion beams of the isotopes of interest without",
                "isobaric contaminations were produced in nuclear",
                "fission induced by a 25 MeV proton beam with an",
                "intensity of around 7-10 uA on a natural uranium",
                "target. The JYFLTRAP double Penning trap was",
                "used for mass selection of the different isobars",
                "based on their cyclotron resonance frequences."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 3 mm thick plastic scintillator for beta",
                "counting"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " 48 3He counter tubes of 2.54 cm diameter",
                "distributed in three concentric rings, and embedded",
                "in a high-density polyethylene (HDPE) matrix to",
                "moderate the neutrons.",
                "One-neutron event detection efficiency in the 0.1-2 MeV",
                "energy range is 60% and constant.",
                "Two-neutron event detection efficiency: 36%",
                "The detectors' response were simulated by GEANT4 for",
                "BELEN detector and MCNPX for beta-counter and",
                "experimentally validated at En = 2.13 MeV using a 252Cf",
                "source and with beams of isotopes with well-known P1n",
                "values, such as 95Rb and 137I."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "B-",
                "DN"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " This system integrates all signals from the",
                "beta- and the 3He neutron counters recording their",
                "energy, and a time stamp with a clock of 10 ns",
                "resolution to be able to build the beta-neutron time",
                "correlations over a certain time window.",
                "For 136Sb P2n measurement beta-2n correlation events",
                "were determined."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The beta and neutron integrals were determined",
                "from the growth-and decay curves using the Bateman",
                "equations."
              ]
            }
          ],
