          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENT OF TOTAL NEUTRON CROSS SECTION FOR SM, GD",
                " AND DY IN THE THERMAL ENERGY REGION."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
