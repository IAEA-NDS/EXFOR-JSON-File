          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "     Large liquid scintillator using pulse shape",
                "      discrimination, with large shielding of lithium,",
                "      paraffin, iron and lead."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                "    Direction sensitive long counter as flux",
                "            monitoring of incident neutron.",
                ".Relative detector efficiency was determined by N-P",
                " scattering at 0.9 to 15 MeV and T(P,N)He3 reaction",
                " for low energy up to 0.5 MeV.",
                ".Energy calibration of the neutron spectrometer was",
                " done with the T(P,N)He-3, the T(D,N)He-4 and the",
                " Be-9(D,N)B-10 reactions.",
                ".Detection angle for fission neutron was 90 degree",
                " relative to incident neutron beam."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Contributions to fission spectra caused by high-energy",
                " tail of elastic peak were subtracted by neutron",
                " scattering spectra recorded with Ta-181 sample,",
                ".Corrections for flux attenuation in U-sample were done",
                " by MONTE CARLO technique,",
                ".Effect of neutron multiple scattering was to be small",
                " and neglected."
              ]
            }
          ],
