          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Measurement of fission neutron spectrum averaged",
                " cross-sections of some (n,p), (n,n'p) and (n,alpha)",
                " reactions on nickel and chromium."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2GERJUL"
              },
              "free_text": [
                "  Light water (MERLIN) and",
                "                                heavy water (DIDO)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "  Fission neutrons from U-235(n,fiss)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " U-235 fission neutron spectrum."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Sealed in quartz tube (diam. - 3-5 mm), surrounded by",
                " neutron flux standards. The whole wrapped in aluminium",
                " foil and irradiated in the core.",
                " Sample details-",
                " 0.6 gr Ni-powder, 99.999% purity, 10 hr typical irrad.",
                " .04 gr Ni-60    , 99.9%   purity, 12 hr typical irrad.",
                " .01 gr Ni-61    , 99.9%   purity,  3 hr typical irrad.",
                " 1.5 gr Cr-granules, 99.999% purity, 10 hr typ. irrad."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                "  For soft radiation-emitters and low-yield",
                "         reaction products."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Resolut. 1.90 keV at 1332 keV, coax. 32 cm2.",
                "  Ge detector used for Co-61 decay, ( 200 mm2,",
                "  resolution 300 eV at 14.4 keV and 522 eV at 122 keV,",
                "  with thin Be window.",
                "  Si(Li) detector used for X-rays from Fe-55 and V-49",
                "  decays, (30 mm2, resol. 170 eV at 5.9 keV) identif.",
                " of charact. X- and gamma-ray peaks used as check"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Use of K-factor concept of measuring spectrum deviat.",
                "  by selecting a set of flux standard reactions of",
                "  varying threshold energies."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For fast flux many threshold reactions were used",
                " as monitors, see table 2 of RadioChim.Acta,27,65.",
                ".for thermal flux measurements the Co-59(n,g)",
                " cross section was used."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Decay, gamma-ray branchings, fluorescence yield of",
                "    X-rays efficiency of detector, geometry of",
                "    counting, self absorption in source."
              ]
            }
          ],
