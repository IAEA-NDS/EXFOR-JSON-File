          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "C-13-enriched material,amorphous graphite powder,",
                "stable isotope ratios C-14/C-13 = (9.5+-0.5)*10**-15",
                "for unirradiated graphite. The irradiated material was",
                "directly pressed into sputter sample holders. Most of",
                "the samples showed C-13/C-12 values around 70;",
                "contamination with natural carbon would directly be",
                "reflected in a lower C-13/C-12 value."
              ]
            }
          ],
