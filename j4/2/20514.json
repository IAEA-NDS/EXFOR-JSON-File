          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " (n,2n) cross-sections and isomer cross-section",
                " ratios of Ge-76 and Ho-165 in the energy range from",
                " 12.5 to 18.5 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2SWTBAS"
              },
              "free_text": [
                " 3 MV cascade generator,",
                "              University of Basel."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "    Deuteron-tritium reaction. Gas-target",
                " (length 2 cm, dia. 1 cm). Deuteron energy from 0.9",
                " to 2 MeV."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Mono-energetic neutrons, energy spread +- 50 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "    Activation of mixed samples by irradiation",
                " in a constant neutron flux. Evaluation of the cross",
                " sections by comparison of the photo-peak intensities",
                " due to the activity of the sample-material and the",
                " admixed monitor-material, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                "    Ge-pin-diode (1.5 cm3),  Fet-preamplifier.",
                " Gamma-resolution 1.3 keV(FWHM) at 100 keV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The interpretation of the results is performed in",
                " terms of the statistical model. See ANL-6662(1962)."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections were applied for background, gamma-self-",
                " absorption in the sample and energy dependence of",
                " the detector efficiency."
