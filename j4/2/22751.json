          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "   T(d,n)He-4 reaction by bombarding 2.9 MeV",
                "        deuteron beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Measurement of residual activities of samples.",
                " 1 year cooling time after irradiations."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                "  80 cc high purity germanium detector at normal",
                " distance of 100 mm and short distance of 20 mm for",
                " weak activities"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Reaction rates of each sample were derived from",
                " measured gamma-ray spectra."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Nickel samples: Ni-58 -68.3%, Ni-60 -26.1% abundance.",
                " Impurity content of Mn, Co less 0.2%, of Fe less 0.1%,",
                " of Cu less 0.05%.",
                " Gold sample of 0.2 mm thickness, abundance 100.0%."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For:",
                "  - Contribution of D+d neutrons due to built-up",
                " deuterium in target to reactions having low threshold",
                " energies, such as Ni-58(n,p) and Ni-60(n,p).",
                " TOF data of source neutron angular distribution and",
                " JENDL Dosimetry File data were used.",
                "  - Contribution of interference reactions, produced",
                " the same activities to be observed due to various",
                " impurities in nickel samples. Main impurity",
                " contributions were due to Co and Mn, correction",
                " factors for these reactions turned out to be about",
                " few % and 10%, respectively. Other contributions were",
                " neglected. In case of Co-57, the contribution from",
                " decay of Ni-57 was taken into account by subtraction",
                " of n,2n cross section from total one using data from",
                "  REL-REF, Sakuma+.",
                "  - Coincidence summing loss effects;",
                "  - Self-absorption effect in the sample in particular",
                "  for gold gamma rays by simple calculation in the slab",
                "  geometry approximation."
              ]
            }
          ],
