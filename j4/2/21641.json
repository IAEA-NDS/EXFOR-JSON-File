          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " THERMAL NEUTRONS FROM HIGH FLUX REACTOR."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "THERMAL MAXWELLIAN NEUTRON SPECTRUM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " THE U-235 SOURCE WAS IMPREGNATED INTO SLABS",
                " OF GRAPHITE, 0.7MM BY 20 MM SQUARE, ENCLOSED IN RE",
                " FOIL AND HEATED TO 1370 TO 1610 DEG C. FISSION",
                " PRODUCT IONS ESCAPING THROUGH THE RENIUM COLLIMATOR",
                " WERE MASS ANALYSED IN MAGNETIC DIPOLE AND ELECTRIC",
                " QUADRUPOLE DEFLECTORS. THE MASS SEPERATED BEAM WAS",
                " FOCUSED ONTO AN OPEN ELECTRON MULTIPLIER.",
                ".THE NEUTRON BEAM WAS PULSED BY A FAST LI6F SHUTTER",
                " AND TIME OF FLIGHT USED TO CORRECT FOR BACKGROUND",
                " AND TO IDENTIFY PRODUCTS BY HALF-LIFE."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FISSION FRAGMENT BEAM FALLS DIRECTLY ONTO AN OPEN",
                " ELECTRON MULTIPLIER."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                "    FISSION FRAGMENTS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".TWO GRAMS OF URANIUM, ENRICHED TO 89 PERCENT U-235."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CORRECTED FOR PRECURSOR DECAYS."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".QUOTED ERRORS INCLUDE STATISTICAL COUNTING ERRORS",
                " ON RELATIVE MEASUREMENTS AND 0.24 PERCENT FROM",
                " NORMALISATION."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".RELATIVE INDEPENDENT YIELDS WERE NORMALISED TO THE",
                " TOTAL ELEMENT YIELD DERIVED FROM FRACTIONAL",
                " INDEPENDANT YIELDS AND MASS CHAIN YIELDS."
              ]
            }
          ],
