              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Well thermalised neutron spectrum.",
                "Oscillator work in GLEEP is carried out with a central",
                "flux of about 10**9 n/cm2/sec, whilst in DIMPLE the",
                "corresponding flux is around 10**7 n/cm2/sec."
              ]
            }
          ],
