          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Fission cross section SIG was defined:",
                " SIG=R(En)/(N*F(En)), where",
                " N - the number of 242Pu nuclei in the sample,",
                " F(En) - the neutron fluence,",
                " R(En)=(Y(En)-Ysf)/EPS(En), where",
                " Y(En) - the observed number of counts,",
                " Ysf - counts due to spontaneous fission,",
                " EPS(Evn) - the detection efficiency.",
                "The derivation of the neutron fluence was performed",
                "with the use of a dedicated NPL computer program FLUCAL"
              ]
            }
          ],
