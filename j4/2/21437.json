          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-BE"
                ],
                "reaction": null
              },
              "free_text": [
                " Proton beam of cyclotron strikes beryllium",
                " target, 1 in. Long in the direction of the p-beam,",
                " and 0.25 in. High."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Accurately machined cylinders of graphite, Al, Cu, Sn",
                " and Pb. Length chosen so that approximately 10%",
                " of the incoming neutrons are scattered. Diam. chosen",
                " so that surface is infinite for multiple scattering",
                " correction calculations. Surface densities known to",
                " better than 0.1%. Impurity less than 0.1%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP"
              ],
              "free_text": [
                " Scattered neutrons detected by converting them",
                " with polyethylene to recoil protons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " Triple coincidence scintillation",
                " counter telescope, with a copper absorber between the",
                " last two counters to set the energy threshold. A 4th",
                " anticoincidence counter was placed in front of the",
                " polyethylene converter to eliminate counts due to",
                " charged particles ejected from the scatterer.",
                " Different arrangements are used (at 10 degr. to the",
                " direction of the scattered neutrons for the small",
                " angle scattering measurements, and at 0 degr. For",
                " the large angle scattering measurements.)",
                " All scintillators from polystyrene containing",
                " tetraphenyl butadiene. Thickness Cu-absorber",
                " 78.8 mg/cm2 in small angle scattering arrangement and",
                " 84 mg/cm2 in the large angle scattering arrangement"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " double coincidence scintillation",
                " counter telescope, with a copper absorber of the same",
                " thickness as in the small angle scattering arrange-",
                " ment.",
                " Dimensions of the scintillators and polythene",
                "  converters (in.) :",
                " N    Thickness   Diameter      Width       Height",
                "  1     0.25      2.375 (LAS)  1.25(SAD)   2.375 (SAD)",
                " CH2    1.25      2.25  (LAS)  1.25(SAD)   2.5   (SAD)",
                "  2     0.25      2.    (LAS)  1.  (SAD)   2.    (SAD)",
                "  3     0.25      2.",
                "  4     0.125     5.",
                "  M CH2 1.25      2.5",
                "  M1    0.25      1.",
                "  M2    0.125     1.625",
                "  where: LAS - Large Angle Detector;",
                "         SAD - Small Angle Detector",
                "         M   - Monitor."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for double scattering.",
                " Higher orders multiple scattering can be ignored."
              ]
            }
          ],
