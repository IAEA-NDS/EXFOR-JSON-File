          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Lu-177m obtained by thermal neutron irradiation of",
                " enriched (99.993%) two Lu-176 powder sample (1.25 mg",
                " and 0.31 mg) at ILL high flux reactor (HFR) and",
                " produced by mass separator PARSIFAL.",
                "Hf-177 (after beta-decay of Lu-177g) was chemically",
                " removed after cooling."
              ]
            }
          ],
