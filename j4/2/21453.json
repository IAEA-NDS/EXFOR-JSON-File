          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Difference in efficiency between the monitor",
                " measurement and the main measurement (smaller than 1%)",
                " fission fragment anisotropy effects resulting",
                " in a 2.5 +- 2% lowering of the efficiency, and",
                " incoming neutron spectrum degradation due to",
                " inelastic scattering of the neutrons with the",
                " collimator walls (+0.15+-0.01 correction)"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " .Uncertainty includes statistics and",
                " uncertainties of the random coincidences determination",
                " caused by neutron flux fluctuations and coincidence",
                " time fluctuations. The value given is a weighted mean",
                " of the results of the two independent measurements",
                " described above."
              ]
            }
          ],
