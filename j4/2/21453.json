          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Mean number of prompt neutrons emitted in the fission",
                " of U-238, Pu-239, Th-232"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Fission fragments detected in coincidence",
                " with prompt fission neutrons.",
                " The quantity detector-efficiency*nu-bar was measured",
                " in all the experiments. by comparison of this quantity",
                " with its value obtained with the same apparatus for a",
                " reference nucleus, the nu-bar can be determined,",
                " from the nu-bar value of the reference nucleus, if",
                " one assumes that the efficiency remains the same."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "FISCH",
                "BF3"
              ],
              "free_text": [
                " A number of BF3 counters surrounding",
                " the fission chamber in coincidence."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                " Fission fragments, and"
