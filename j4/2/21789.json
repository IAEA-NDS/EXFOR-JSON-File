                "COINC"
              ],
              "free_text": [
                "",
                ".RECOIL PROTONS EMERGING FROM A POLYTHENE SCATTERER",
                " WERE DETECTED BY A TRIPLE COINCIDENCE COUNTER",
                " TELESCOPE.",
                ".AN AL-ABSORBER WAS PLACED BETWEEN THE TWO LAST",
                " DETECTORS TO SET A LOW ENERGY LIMIT TO THE",
                " RECOIL PROTONS DETECTED."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " COUNTER TELESCOPE CONSISTING OF",
                " 3 POLYSTYRENE CRYSTALS, EACH 7 MM THICK,",
                " MOUNTED ON TOP OF A PHOTOMULTIPLIER TUBE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                "  BF3 DETECTOR TO MONITOR THE NEUTRON BEAM."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".AN EFFECTIVE NEUTRON ENERGY WAS CALCULATED.",
                ".THE ENERGY BAND WIDTH VARIED BETWEEN 19 AND",
                " 31 MEV DEPENDING ON THE ABSORBER THICKNESS IN",
                " THE DETECTOR TELESCOPE."
              ]
            }
          ],
