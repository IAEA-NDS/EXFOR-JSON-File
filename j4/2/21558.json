            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-SIMULTANEOUS DETERMINATION OF U-235 AND PU-239",
                " TRACES BY GAMMA SPECTROMETRIC ANALYSIS OF NOBLE",
                " GASES FOLLOWING NEUTRON ACTIVATION -."
              ]
            }
          ],
