              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".TRACE SAMPLES OF ENRICHED U-235 AND PU-239."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NOBLE GAS FISSION PRODUCTS ARE SORBED ONTO ACTIVATED",
                " CHARCOAL, THEN AFTER A SHORT DELAY ARE DESORBED AND",
                " THE NON-VOLATILE DAUGHTERS RB-88 AND CS-139 ARE",
                " MEASURED BY GAMMA SPECTROSCOPY."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
