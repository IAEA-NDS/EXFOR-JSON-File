              ],
              "free_text": [
                " CALIBRATED GE(LI) DETECTOR."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THIS MEASUREMENT IS A BY-PRODUCT OF THE DEVELOPMENT",
                " OF THIS TECHNIQUE FOR MEASUREMENT OF TRACE  AMOUNTS",
                " OF U-235 AND PU-239."
              ]
            }
          ],
