                "reaction": null
              },
              "free_text": [
                "  JRR-1 water-boiler type reactor,operated",
                "with output 40 kW. Several exp.holes(1,2,3,9,12) used."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "       Thermal and fast neutron fluxes:",
                " Hole          (n/cm**2/sec)",
                " 1      1.3E+12      1.5E+12",
                " 2      6.7E+11      8.0E+10",
                " 3      3.9E+11      5.5E+10",
                " 9      2.7E+11      1.6E+10",
                "12      2.2E+11      8.3E+09 .",
                "Fast neutron flux was estimated by Ni-58(n,p)Co-58",
                "reaction assuming cross-section for fission neutrons",
                "to be 90 mb."
              ]
            }
          ],
