              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target is a miniaturized fission chamber. The",
                "fissile material, 210 ug of 235U has been",
                "electroplated on a titanium support of 8 mm in",
                "diameter."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " The LOENIE long counter is made of two blocks",
                "of polyethylene with a central hole to host the",
                "target and 16 smaller holes to host the 3He",
                "proportional counters. LOENIE has been designed to",
                "have a flat efficiency as a function of the neutron",
                "energy in the energy range 100keV - 1MeV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Average delayed-neutron yield as a function of time",
                "after irradiation.",
                "Irradiation time = 50 s",
                "Average delayed-neutron yields measurement time = 200s",
                "A veto time interval was added after the end of the",
                "irradiation.",
                "The fit of the first 500 ms of decay curve was",
                "performed with the CONRAD code."
              ]
            }
