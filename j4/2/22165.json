                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " MAGNETIC SPECTROGRAPH 'RAIDEN' WITH A MOMENTUM",
                " RESOLUTION DELTA-P/P OF BETTER THAN 1.0E-4 ALONG THE",
                " FOCAL PLANE, SET AT 0.0 DEG. THE SOLID ANGLE WAS",
                " 6.0 MILLI-SR WHICH CORRESPONDED TO AN ANGULAR SPREAD",
                " OF 3.6 DEG FWHM, THE MEAN ANGLE OF RECOIL PROTONS",
                " BEING 2.66 DEG. THE RESULTING KINEMATIC SPREADING DUE",
                " TO THIS FINITE GEOMETRY EFFECT WAS 365 KEV FWHM."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " THE FOCAL PLANE DETECTOR CONSISTED OF A 2-D"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                "  POSITION SENSITIVE GAS COUNTER, TWO DELTA-E"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "   PROPORTIONAL DETECTORS AND A PLASTIC SCIN-",
                "           TILLATION COUNTER, TOTAL LENGTH 1.5 M. THE",
                "           RESOLUTION WAS SUFFICIENTLY HIGH FOR ITS",
                "           EFFECT ON THE MEASUREMENTS TO BE IGNORED."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A 17.1 MG/CM-SQ DEUTERATED POLYETHYLENE TARGET BACKED",
                " WITH A 3 MM THICK GRAPHITE PLATE AND LOCATED 65 MM",
                " FROM THE NEUTRON SOURCE POINT. ENERGY LOSS IN SAMPLE",
                " WAS 173 KEV."
              ]
            }
          ],
