          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-BE"
                ],
                "reaction": null
              },
              "free_text": [
                " A 17.0 MG/CM-SQ THICK TARGET WAS BOMBARDED WITH",
                " A 64.94 MEV PROTON BEAM, RESOLUTION 170 KEV FWHM, PRO-",
                " DUCING NEUTRONS OF 62.8 MEV FROM THE 9-BE(P,N)9-B-GND",
                " REACTION. THE PROTON BEAM WAS STOPPED BY STACKED SI",
                " CRYSTALS OF TOTAL THICKNESS 25 MM WHICH ALSO SERVED AS",
                " A FARADAY CUP. THE NEUTRON YIELD WAS 3.3E+6 N/S/CM-SQ",
                " FOR A 1 MICRO-AMP PROTON BEAM, AND THE ENERGY LOSS IN",
                " THE TARGET WAS 145 KEV. THE ESTIMATED NEUTRON BEAM",
                " RESOLUTION WAS 223 KEV FWHM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
