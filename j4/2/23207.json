          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Relative intensities of prompt gamma-rays from the",
                "35Cl(n,gamma)36Cl reaction with thermal neutrons as",
                "secondary gamma-ray intensity standards."
              ]
            }
          ],
          "AUTHOR": [
            {
