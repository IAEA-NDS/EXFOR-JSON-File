          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THERMAL REACTOR SPECTRUM WITH THERMAL AND EPITHERMAL",
                " FLUXES OF 1.35E+14 AND 0.12E+14 NEUTRONS/CM-2/S, RES-",
                " PECTIVELY."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".TWO DISKS OF A SILICON CRYSTAL, 6 MM IN DIAMETER AND",
                " 1 MM THICK, WITH NATURAL ISOTOPIC ABUNDANCE, WERE",
                " USED. COBALT FLUX MONITORS WERE IRRADIATED SIMUL-",
                " TANEOUSLY."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " THE CROSS SECTION OF THE SI-31(N,G) REACTION",
                " WAS MEASURED BY DOUBLE NEUTRON CAPTURE IN SI-30, I.E.",
                " BY THE REACTION CHAIN",
                " SI-30(N,G)SI-31(2.622H)(N,G)SI-32. THE FRACTION OF",
                " SI-32 TO SI-30 IONS WAS DETERMINED BY ACCELERATOR MASS",
                " SEPARATION TECHNIQUES TO (4.57+/-0.27)E-12."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A CALIBRATED GELI DETECTOR WAS USED TO DETER-",
                " MINE THE ACTIVITY OF THE CO MONITOR SAMPLES."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE CROSS SECTION WAS DETERMINED BY USING THE WELL",
                " ESTABLISHED HALF-LIFE OF SI-31 OF 2.622 H AND A THER-",
                " MAL NEUTRON-CAPTURE CROSS SECTION IN SI-30 OF",
                " 0.107+/-0.002 B."
              ]
            }
          ],
