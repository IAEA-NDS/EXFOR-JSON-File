          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "   Time of flight. Transmission measurements were",
                " carried out at 30 m and 50 m flight paths.",
                " The capture measurements were performed at a 30 m",
                " and 60 m flight path"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                "   The sample dependent pulse height weighting",
                "  function applied to ensure that the efficiency for",
                "  a neutron capture event was independent from the",
                "  gamma-ray cascade"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                "   B-10 ionization chamber was used to determine",
                "         the shape of the neutron flux."
              ]
            }
          ],
