          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-SILVER CROSS SECTIONS FOR 14 MEV NEUTRONS."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "T.B.RYVES",
                "P.KOLKOWSKI",
                "V.E.LEWIS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2UK NPL"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NPL SAMES ACCELERATOR. ANALYSED BEAM OF 150 KEV",
                " DEUTERONS."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " AN AIR-COOLED TI-T TARGET OF THICKNESS 2 MG/CM2",
                " TITANIUM, EVAPORATED ONTO A 0.5 MM THICK VERY PURE",
                " ALUMINIUM BACKING, WAS USED TO PRODUCE NEUTRONS OF",
                " ABOUT 14 MEV ENERGY."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".IN SOME IRRADIATIONS THE SAMPLE WAS PLACED IN CONTACT",
                " WITH THE TARGET, RESULTING IN A SKEW NEUTRON ENERGY",
                " DISTRIBUTION RANGING FROM 14.0 TO 14.8 MEV, WITH A",
                " MEAN ENERGY OF 14.3 MEV. IN OTHER IRRADIATIONS THE",
                " SAMPLE WAS PLACED AT A DISTANCE OF 50 MM IN FRONT OF",
                " THE TARGET, GIVING A DISTRIBUTION FROM 14.5 TO 14.8",
                " MEV WITH A MEAN OF 14.67 MEV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " IRRADIATIONS WERE PERFORMED FROM 4 MIN TO 2",
                " HOURS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " A 4-PI-BETA GAS-FLOW PROPORTIONAL COUNTER,",
                " EMPLOYING PURE METHANE GAS, WAS USED FOR BETA ACTIVITY",
                " MEASUREMENTS. THE COUNTING EFFICIENCIES WERE",
                " CALCULATED."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 40 CM3 COAXIAL GE(LI) DETECTOR WAS USED TO",
                " MEASURE THE POSITRON ANNIHILATION RADIATION FROM",
                " AG-106-G. THE EFFICIENCY OF THIS DETECTOR WAS DETER-",
                " MINED WITH A CALIBRATED NA-22 SOURCE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " A LONGCOUNTER WAS USED TO MONITOR THE NEUTRON",
                " FLUENCE RATE."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "26-FE-56(N,P)25-MN-56,,SIG",
                  "code_unit": [
                    {
                      "unit": "26-FE-56(N,P)25-MN-56,,SIG",
                      "field": {
                        "reaction": "26-FE-56(N,P)25-MN-56",
                        "target": "26-FE-56",
                        "projectile": "N",
                        "process": "P",
                        "product": "25-MN-56",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE SAMPLES CONSISTED OF NATURAL SILVER WITH ISOTOPIC",
                " COMPOSITION 51.83 PERCENT AG-107 AND 48.17 PERCENT",
                " AG-109. THEY WERE SHAPED AS DISCS WITH THICKNESSES",
                " VARYING FROM 3 TO 85 MG/CM2 AND DIAMETERS OF 22.0 OR",
                " 25.4 MM. FOR ABSOLUTE MEASUREMENTS THE SILVER FOIL WAS",
                " SANDWICHED BETWEEN TWO IRON FOILS OF EQUAL DIAMETER.",
                " BOTH METALS HAD A CHEMICAL PURITY OF BETTER THAN",
                " 99.99 PERCENT."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE DATA WERE CORRECTED FOR TIME VARIATIONS OF THE",
                " NEUTRON FLUX, DETECTOR EFFICIENCIES, INTERNAL CON-",
                " VERSION AND ELECTRON CAPTURE EFFECTS, POSITRON ANNI-",
                " HILATION IN FLIGHT, GEOMETRY AND ATTENUATION IN THE",
                " FOILS."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " THE TOTAL ERRORS WERE COMPOSED OF RANDOM",
                " (0.5 - 7.5 PERCENT), NON-STATISTICAL (0.2 PERCENT FOR",
                " ISOMERIC RATIO, 2.1 - 4.6 PERCENT FOR CROSS SECTIONS)",
                " AND DECAY-SCHEME (1 - 3 PERCENT) ERROR CONTRIBUTIONS."
              ]
            }
          ],
