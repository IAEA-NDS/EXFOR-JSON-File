              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FITS WITH A LEGENDRE POLYNOMIAL EXPANSION TO",
                " THE TERM WITH L=2. COEFFICIENTS WERE NORMALIZED",
                " WITH THE L=0 COEFFICIENT.",
                ".BY INCLUDING ALSO L=3 ONLY A MARGINAL IMPROVEMENT",
                " TO THE ANG.DISTR. AT THE HIGHEST NEUTRON ENERGIES",
                " WAS POSSIBLE."
              ]
            }
          ],
