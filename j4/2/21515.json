                ],
                "reaction": null
              },
              "free_text": [
                " Proton energy dispersion about 0.5%",
                " for a current of 8 micro-Ampere. Li-layer prepared",
                " by thermal evaporation on a tantalum carrier, 0.3 mm",
                " thick, 200 ug/cm2."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 2 mg Pu containing 1% impurities (uranium)",
                " 20 mg U-235 enriched uranium obtained with an",
                " isotope separator, U-238/U-235 = 6.72+-0.10.",
                " 0.7 mg U-233 target containing 50 % natural",
                " uranium. Also a 20 mg natural U-target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                "  Back-to-back foils used to compare two",
                "         cross sections."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Fission chamber for the comparison of",
                " U-235 and U-233 with Pu-239,"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " Long counter as a monitor for the",
                " measurement of the Pu-239 cross section shape",
                " between 1500 and 2000 keV. The efficiency of this",
                " counter as a function of the energy has been",
                " measured with a recoil proton counter."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
