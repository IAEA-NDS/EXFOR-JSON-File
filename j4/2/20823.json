          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2GERMUN"
              },
              "free_text": [
                " Three synchronized choppers,",
                "consisting of Al cylinders (350mm diam., 160mm high)",
                "with vertical axes, inner walls coated with 0.5mm Cd,",
                "two vertical slits 30mm in width, driven by",
                "synchronous motor with 200-8500 rpm. For measurements",
                "between 0.03 and 0.4 milli-eV the duty cycle was",
                "1050 rpm."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Garching FMR.",
                " Total flux at end of 150m flight tube - 2.5*10**6",
                " neutrons/(cm**2, sec)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Guide tube of 150m with x-sec. of 14cm*2.5cm",
                " and radius of curvature of 35000m, coated with Ni",
                " inside.",
                " Energy calibration by Bragg cutoff breaks in",
                " transmission on Pb, Si, Be, Fe and Mg.",
                " Accuracy in calibration overall +-2*10-3 angstrom.",
                " For the low energy part of the experiment the flight",
                " path (vertical) was 10.96+-0.01m."
              ]
            }
          ],
