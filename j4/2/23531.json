          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "VESUVIO spectrometer:"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "",
                "6Li-doped glass scintillator transmission monitor",
                "6Li scintillator beam monitor",
                "Deep Inelastic Neutron Scattering (DINS) detectors with",
                "64 and 132 detectors in forward- and back-scattering",
                "directions, respectively. The forward scattering",
                "detectors are yttrium aluminum perovskite scintillators",
                "covered with a gold foil to perform the (n,gamma)",
                "conversion, while the backscattering detectors are",
                "6Li-doped glass scintillators. TOSCA spectrometer",
                "employed for vibrational frequency spectra",
                "measurements at temperature of about 10 K."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples prepared from calcium carbonate (CaCO3)",
                "The sample is highly hygroscopic and the effective",
                "molecules are mixtures of (1-x)*CaCO3 + x*H2O where x",
                "is the water concentration.",
                "The sample powder is placed into aluminum flat cell of",
                "square section of 64 mm inner side, 90 mm outer side",
                "and thickness of 10.05 mm.",
                "Effective density 0.71 g/cm3",
                "The calcium oxide sample used for the determination of",
                "the water content in the sample.",
                "Sample thickness 0.71 g/cm2"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "TRN"
              ],
              "free_text": [
                "",
                "Flight path from neutron moderator to:",
                " - sample: 11 m",
                " - transmission monitor: 13.43 m",
                " - beam monitor: 8.60 m."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections applied for:",
                " - cell contribution",
                " - background",
                " - beam attenuation, multiple scattering and detector",
                "efficiency using Monte Carlo simulations",
                " - hydrogen content in the samples",
                " - quantification the amount of water by analysis of",
                "the scattered neutrons at forward direction and the",
                "multiple scattering corrections by study of the",
                "dynamics of the system by means of the Density",
                "Functional Theory technique along with measurements of",
                "the vibrational spectra at the TOSCA spectrometer.",
                " - cross sections per atom based on frequency spectra",
                "calculated with Synthetic Model."
              ]
            }
          ],
