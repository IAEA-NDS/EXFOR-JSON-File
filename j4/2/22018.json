          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-LI-7(N,N-PRIME)LI-7-*(478) NEUTRON ANGULAR DISTRI-",
                " BUTION DERIVED FROM DOPPLER-BROADENED GAMMA-ENERGY",
                " DISTRIBUTIONS."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.LISKIEN",
                "S.BAO"
              ],
              "free_text": [
