              ],
              "free_text": [
                " S.B."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2ZZZGEL"
              },
              "free_text": [
                " GEEL VAN DE GRAFF WITH PULSED DEUTERON",
                " BEAMS /2 NS PULSE WIDTH, 400 NS PULSE DISTANCE,",
                " 2.5 MICRO-AMP/."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " 36 MM LONG GAS TARGET CELL, FILLED WITH 0.15",
                " MPA D2 GAS. 3.3 MG/CM2 HAVAR ENTRANCE FOIL. TA BEAM",
                " STOP."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".QUASI-MONOENERGETIC NEUTRONS IN THE RANGE 4 - 8.5",
                " MEV.",
                ".BACKGROUND FROM STRUCTURAL MATERIAL WAS NEGLIGIBLE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DOPPLER-BROADENED GAMMA-ENERGY DISTRIBUTIONS WERE",
                " MEASURED TO DETERMINE THE ANGULAR DISTRIBUTION OF",
                " LI-7 RECOILS, AND THEREBY DETERMINE THE NEUTRON",
                " ANGULAR DISTRIBUTION."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME-OF-FLIGHT TECHNIQUE WAS USED TO SUPPRESS",
                " BACKGROUND FROM NEUTRONS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A 70 CM3 PURE GERMANIUM DETECTOR AT A DISTANCE",
                " OF 1.2 M WAS USED FOR GAMMA DETECTION. THE DETECTOR",
                " WAS WELL SHIELDED IN A COLLIMATOR, CONSISTING OF",
                " PARAFFIN, LITHIUM CARBONATE AND LEAD. A BRASS SHADOW",
                " BAR SHIELDED THE DETECTOR FROM DIRECT TARGET",
                " NEUTRONS."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".METALLIC LITHIUM CYLINDER, 36.8 MM DIAMETER BY",
                " 29.9 MM HIGH, HOUSED IN AN ALUMINIUM CONTAINER",
                " WITH 0.2 MM THICK WALLS. THE LITHIUM WAS ENRICHED",
                " TO 99.98 PER CENT IN LI-7. THE SAMPLE WAS MOUNTED",
                " 10 CM FROM THE NEUTRON TARGET."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".SEVERAL CORRECTIONS WERE TAKEN INTO ACCOUNT, I.E.",
                " A.  THE ENERGY/ANGLE DISTRIBUTION OF THE PRIMARY",
                "     NEUTRONS,",
                " B.  THE SCATTERING IN THE SAMPLE,",
                " C.  THE COMBINED EFFECT OF HALF-LIFE AND STOPPING",
                "     POWER,",
                " D.  GAMMA DETECTOR RESOLUTION.",
                " THESE CORRECTIONS WERE CALCULATED WITH MONTE-CARLO",
                " TECHNIQUES."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " NO DETAILS GIVEN."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".IT WAS ASSUMED THAT THE C.M. ANGULAR DISTRIBUTIONS",
                " COULD BE EXPRESSED AS A SUM OF LEGENDRE PLYNOMIALS.",
                " LEAST-SQUARES FITTING TO THE EXPERIMENTAL DATA THEN",
                " DIRECTLY GAVE THE 4 RELATIVE LEGENDRE COEFFICIENTS."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".GAMMA SPECTRA WERE CALIBRATED WITH A BE-7 SOURCE,",
                " WICH EMITS THE SAME GAMMA-LINE.",
                ".MEASUREMENTS WERE PERFORMED AT 44, 68, 91, 111 AND",
                " 139 DEGREES WITH RESPECT TO THE BEAM DIRECTION."
              ]
            }
          ],
          "STATUS": [
