                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " DEUTERON-DEUTERIUM REACTION, AL-D TARGET.",
                " 1.E+6 NEUTRONS/SEC PRODUCED."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DETECTOR IS SAMPLE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SCIN",
                "PROPC"
              ],
              "free_text": [
                " COINCIDENCE. 2-HE-3 PARTICLES FROM",
                " THE D-D NEUTRON PRODUCTION ARE DETECTED WITH A",
                " PROPORTIONAL COUNTER. THE PRODUCED NEUTRONS IMPINGE",
                " ONTO A K-I-(TL) SCINTILLATION DETECTOR (25 MM DIAM",
                " * 20 MM) WHICH IS ALSO THE TARGET. THE PROTONS AND",
                " ALPHA PARTICLES PRODUCED IN THE NEUTRON INDUCED",
                " REACTIONS IN THIS DETECTOR ARE DETECTED IN",
                " COINCIDENCE WITH THE 2-HE-3 PARTICLES."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "NAICR",
                "PROPC"
              ],
              "free_text": [
                " THIS SAME MEASUREMENT IS REPEATED",
                " WITH A NA-I-(TL) INSTEAD OF A K-I-(TL) TO PROVE THAT",
                " THE OBSERVED REACTIONS ARE DUE K AND NOT TO I."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".COMPARED WITH CALCULATIONS BASED ON COMPOUND NUCLEUS",
                " MODEL."
              ]
            }
