              "coded_information": null,
              "free_text": [
                "-ABSOLUTE CROSS SECTIONS OF THE REACTIONS K-39(N,P)",
                " AND K-39(N,A) FOR 2.6 MEV NEUTRONS.- (IN GERMAN)."
              ]
            }
          ],
          "FACILITY": [
