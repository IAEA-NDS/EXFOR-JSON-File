          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Fe(2)-O(3) canned in Al tubes with windows of 0.3 mm",
                " thick, diam=35 mm.  Thicknesses and enrichments",
                " are : 54-Fe - 97.68%,     6.98e-02 Fe atoms/b",
                "       56-Fe - 99.93%,     7.81e-02 Fe atoms/b",
                "       57-Fe - 91.69%,     5.11e-02 Fe atoms/b."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight method, transmission",
                " measurement with sample at 100 m and detector at",
                " 197.85 m."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                " Pulse-height discrimination. Time-of-flight",
                " events are only stored if the pulse-height is within",
                " a required window."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Plastic scintillator NE-110, 6*6*1 inch,",
                " viewed side on by 4 pm type RCA4516 (diam=0.75 in)"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " R-matrix formalism is used to analyze the resonances.",
                " The FANAL-code modified to include single level",
                " Breit-Wigner formula for (l greater than 0)-resonances",
                "  is used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MLA"
              ],
              "free_text": [
                " Multi-level Breit-Wigner analysis is also",
                " done, using the SIOB-code. The results of the two",
                " methods were in good agreement."
              ]
            }
          ],
