          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-CROSS SECTION OF RB AT 14 MEV NEUTRON ENERGY AND",
                " THE DECAY OF RB."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                " 500 KV VAN DE GRAAF ACCELERATOR,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "BETAT"
                ],
                "institute": null
              },
              "free_text": [
                " USED FOR THE DECAY ANALYSIS."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " DEUTERON BEAM OF 360 KEV ON A TRITIUM TARGET",
                "      (0.021 MM THICK WITH AL-BACKING) 2 MM DIAMETER",
                "      BEAM ALLOWED THE ASSUMPTION THAT NEUTRONS CAME",
                "      FROM A POINT SOURCE. THE NEUTRON BEAM HAD",
                "      HALF ANGLE OF 71 DEG FOR THE RB2CO3 SAMPLE AND",
                "      53 DEG FOR THE AL-SHEET WITH RESPECT TO",
                "      THE DEUTERON BEAM DIRECTION."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".NATURAL RB2CO3 POWDER PLACED IN SMALL PLEXI-GLASS",
                " BOX (72.15 PC RB-85 AND 27.85 PC RB-87).",
                " THE SAMPLE WAS 1.33 CM-SQ IN AREA AND 2.65 MM",
                " THICK. ONE HOUR IRRADIATION WITH GAMMA-RAY",
                " MEASUREMENTS STARTED 7-15 MIN AFTER IRRADIATION.",
                " IN ONE METHOD THE SAMPLE WAS SANDWICHED WITH A THIN",
                " AL FOIL AND PLACED AT 42 MM OF THE DETECTOR TO",
                " PREVENT SUMMING. IN THE OTHER METHOD AL-POWDER",
                " OR AL2O3 WAS MIXED IN KNOWN PROPORTIONS WITH RB2CO3."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " ACTIVATION METHOD COMBINED WITH THE MIXED",
                "        POWDER METHOD TO FIND SYSTEMATIC FAULTS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " RESOLUTION OF 2.8 KEV FOR 1.33 MEV GAMMA-RAYS.",
                "       EFFICIENCY DETERMINED WITH THE AID OF A",
                "       88-RA-226 SOURCE."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".SPECTRA RESULTING FROM IRRADIATION WITH THE",
                " BETATRON ALLOWED TO RULE OUT THE FORMATION OF",
                " BR-84 IN THIS EXPERIMENT."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "13-AL-27(N,A)11-NA-24,,SIG",
                  "code_unit": [
                    {
                      "unit": "13-AL-27(N,A)11-NA-24,,SIG",
                      "field": {
                        "reaction": "13-AL-27(N,A)11-NA-24",
                        "target": "13-AL-27",
                        "projectile": "N",
                        "process": "A",
                        "product": "11-NA-24",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " 0.2 MM THICK",
                " AL SHEET, 15.0 MM IN DIAMETER PLACED AT ONE END",
                " OF THE PLEXI-GLASS BOX HOLDING THE SAMPLE.",
                " THE NEUTRON ENERGY REACHING THE AL WAS DETERMINED",
                " BY AN INTEGRATION METHOD TO BE E=14.9 MEV WITH AN",
                " ERROR OF 0.2 MEV."
              ]
            }
          ],
