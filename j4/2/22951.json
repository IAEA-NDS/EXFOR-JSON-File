          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Neutron-neutron final state interaction in the",
                " H-2(n,p)2n reaction at En = 17.4-MeV."
              ]
            }
          ],
          "AUTHOR": [
