          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A LAYER OF 400 MICRO-GM/CM*2 URANIUM DIOXIDE, ENRICHED",
                " TO 93 PERCENT U-235 ON A COPPER BACKING, TOPPED BY",
                " A LAYER OF 40 MICRO-GM/CM*2 ANTISPUTTERING TANTALUM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " ON LINE MASS SEPERATION OF FISSION PRODUCTS,",
                " RESOLUTION OF 1/800, TAPE TRANSFER SYSTEM FROM RESOLVI",
                " SLITS TO DETECTORS.",
                ".BETA ACTIVITY MEASURED AS A FUNCTION OF TAPE SPEED FOR",
                " EACH MASS CHAIN. THIS CURVE IS THEN UNFOLDED INTO",
                " COMPONENTS CORRESPONDING TO EACH ISOBAR A, GIVING THE",
                " FRACTIONAL INDEPENDANT YIELDS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
