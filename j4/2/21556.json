              ],
              "free_text": [
                " TWO 1 MM THICK NE102 PLASTIC SCINTILLATORS",
                " COVERED WITH 15 MICRO-M THICK ALUMINIUM FOIL WITH",
                " A SOLID ANGLE OF 0.955 4-PI."
              ]
            }
          ],
