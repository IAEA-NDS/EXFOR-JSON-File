          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CROSS-SECTIONS OBTAINED BY SUBTRACTING THE",
                " CONTRIBUTION OF CARBON AND OXYGEN FROM THE CROSS-",
                " SECTIONS OF PARAFFIN AND WATER RESPECTIVELY."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE ASSUMPTION WAS MADE THAT THE IONIZATION",
                " CURRENT IN THE IONIZATION CHAMBER PRODUCED",
                " BY NEUTRONS WHICH LOST THEIR ENERGY THROUGH",
                " THE COLLISION WITH PROTONS, WAS PROPORTIONAL",
                " TO THE PRODUCT OF THE ENERGY AFTER COLLISION",
                " AND THE TOTAL SCATTERING CROSS SECTION OF",
                " NEUTRONS AT THAT ENERGY. THE TOTAL",
                " SCATTERING CROSS  SECTION = 2.224 +- 0.113",
                " BARN WAS USED, C.L.BAILEY ET AL., PHYS. REV.",
                " 70(1946)583"
              ]
            }
          ],
