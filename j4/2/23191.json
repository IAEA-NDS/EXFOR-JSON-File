          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " Matrix of polyethylene with 20 3He counters",
                "arranged in two concentric rings around the detector",
                "cavity. The detection of the neutrons is achieved via",
                "the detection of the charged particles produced in the",
                "reaction 3He + n -> 3H + p + 763.7 keV.",
                "According to MCNPX simulations, the neutron detection",
                "efficiency 30% in the neutron energy range 1keV-1MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Si detector (27 mm diameter and 910 microm thick",
                "to detect beta-particles)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                "  Ge detector for  gamma-ray detection.",
                "BELEN-20 detection efficiency obtained using 88Br and",
                "95Rb as calibration:",
                "Isotope    Pn(%)       Efficiency",
                "88Br       6.58+-0.18  27.6+-0.7",
                "95Rb       8.73+-0.20  26.6+-0.8",
                "Average efficiency for BELEN-20 is (27.1+-0.8)%."
              ]
            }
          ],
