          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "FRS"
                ],
                "institute": "2SF JYV"
              },
              "free_text": [
                " Ion Guide Isotope Separator On-Line",
                "  (IGISOL) facility with a 30 MeV deuteron beam",
                "impinging on a natural uranium target - to produce",
                "88Br, 94,95Rb and 138I isotopes. Subsequently, the",
                "double Penning trap setup JYFLTRAP was used to prepare",
                "a monoisotopic beam which was implanted on a movable",
                "tape placed inside the neutron detector. The",
                "radioactivity was accumulated during a period of",
                "3 T1/2, the measurement was extended up to 10 T1/2."
              ]
            }
          ],
