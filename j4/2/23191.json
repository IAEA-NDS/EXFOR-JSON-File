          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron emission rate (Pn) is obtained with the",
                "formula  Pn=Nbn/(EPSn*Nb), where",
                "Nb - the number of beta counts due to the decay of the",
                "mother nucleus,",
                "Nbn - the number of beta-neutron coincidences,",
                "EPSn - the detector efficiency."
              ]
            }
          ],
