          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the total neutron-scattering",
                "cross-section ratios of noble gases of natural",
                "isotopic composition using a pulsed neutron beam."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "C.C.Haddock",
                "M.Hiromoto",
