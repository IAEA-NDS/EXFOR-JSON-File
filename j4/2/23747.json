                "T.Shima",
                "H.M.Shimizu",
                "W.M.Snow",
                "T.Yoshioka"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USANIS",
                "2JPNOSA",
                "2JPNNAG",
                "2JPNKEK",
                "1USAINU",
                "2JPNKYU"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,100,064002,2019",
                "code_unit": [
                  {
                    "unit": "J,PR/C,100,064002,2019",
                    "doi": "10.1103/PhysRevC.100.064002",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
