          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-STUDY OF THE REACTIONS BE-9(N,A)HE-6 AND",
                " BE-9(N,2A)2N AT 14.1 MEV-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2JPNYOK"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " NEUTRON FLUX MONITORED AND DETERMINED WITH AN",
                " UNCERTAINTY OF +-1 PER CENT BY MEASURING ALPHA",
                " PARTICLES ASSOCIATED WITH THE D-T REACTION."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".WITH TELESCOPE NR 1 A BE-9 TARGET OF 1.44 MG/CM-SQ",
                " BACKED ON A 1 MM THICK CARBON PLATE WAS USED AND WITH",
                " TELESCOPE NR 2 THE SAMPLE WAS A SELFSUPPORTING",
                " 1.79 MG/CM-SQ BE-9 FOIL. THE BE-9 WAS NATURAL",
                " BERYLLIUM METAL WITH 99.5 PER CENT PURITY."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".PARTICLE IDENTIFICATION USING A DELTA-E- AND AN",
                " E-DETECTOR."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SOLST"
              ],
              "free_text": [
                " TWO KINDS OF COUNTER TELESCOPES",
                " 1. A LARGE-SIZED COUNTER TELESCOPE CONSISTING OF",
                "    THREE GAS-PROPORTINAL DELTA-E DETECTORS FOLLOWED",
                "    BY A SILICON E DETECTOR. SOLID ANGLE 6.2 MSR,",
                "    ANGULAR SPREAD 6.2 ADEG IN FWHM AT 0 ADEG",
                " 2. TWO SMALL-SIZED ONES CONSISTING OF TWO GAS-",
                "    PROPORTIONAL DELTA-E DETECTORS FOLLOWED BY A",
                "    SILICON E DETECTOR USED IN CLOSER GEOMETRY. SOLID",
                "    ANGLES WERE 31.4 AND 38.8 MSR, RESPECTIVELY."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".LINEAR SPECTRA SORTED OUT FROM THE TWO-DIMENSIONAL",
                " DELTA-E--E SPECTRA.",
                ". THE REACTION 14-SI-28(N,A)12-MG-25 WAS USED FOR",
                " ENERGY CALIBRATION OF THE E-DETECTOR AND FOR",
                " MEASURING THE ENERGY RESOLUTION OF THE INCIDENT",
                " NEUTRON SPECTRUM."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DATA TAKEN FROM MAIN REFERENCE."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 840430,
                "history": "C"
              },
              "free_text": [
                " A.L."
