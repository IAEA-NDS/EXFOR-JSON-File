          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE MEASURED ACTIVITIES WERE CORRECTED FOR A",
                " CONTRIBUTION FROM INTERFERING REACTIONS WITH ADMIXED",
                " ISOTOPES, CREATING THE SAME PRODUCT NUCLEUS."
              ]
            }
          ],
          "ERR-ANALYS": [
