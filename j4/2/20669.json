          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-INVESTIGATION OF (N,T) REACTIONS AT 14.6 MEV AND AN",
                " ANALYSIS OF SOME SYSTEMATIC TRENDS IN THE CROSS-",
                " SECTION DATA-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DYNAGEN NEUTRON GENERATOR OF JUELICH."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "",
                ".14.6 MEV NEUTRONS WERE PRODUCED AT FLUX DENSITIES OF",
                " (3-5X10E+09 CM-2 SEC-1)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".46TI-NATURAL ISOTOPIC COMPOSITION,TI-SPONGE,10G,",
                " 99.99PC CHEMICAL PURITY.",
                ".56FE-ENRICHED TO 99.93PC,FE2O3,0.7G,99.9PC PURITY.",
                ".58NI-NATURAL,NI-SPONGE,3G,99.995PC PURITY.",
                ".60NI-ENRICHED TO 99.79PC,NI-POWDER,0.5G,99.8PC",
                " PURITY.",
                ".88SR-ENRICHED TO 99.84PC,SR(NO3)2,1G,99.95PC PURITY.",
                ".90ZR-NATURAL,ZRO2,12G,99.8PC PURITY.",
                ".141PR-NATURAL,PR6O11,2G,99.999PC PURITY.",
                ".204PB-NATURAL,PB-SHEET,100G,99.999PC PURITY."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " THE PRODUCTS WERE SEPARATED CHEMICALLY,",
                "  EXCEPT FOR THE REACTION 56FE(N,T)54MN, AND THEIR",
                " GAMMA-ACTIVITY MEASURED.",
                ".FOR THE REACTION 88SR(N,T)86RB LOW-LEVEL BETA-",
                " COUNTING WAS USED.",
                ".FOR DETAILS SEE S.M.QAIM ET AL.,J.RADIONANALYT.",
                " CHEM.21(1974),395,J.RADIOANALYT.CHEM.,IN PRESS AND",
                " S.M.QAIM,NUCL.PHYS.A185(1972),614,NUCL.PHYS.A224",
                " (1974),319."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FOR 46TI(N,T)44(M)SC THE STANDARD USED WAS",
                " 48TI(N,P)48SC WITH A CROSS SECTION OF 61+-6 MB AT",
                " 14.6 MEV.",
                ".FOR 46TI(N,T)44(G)SC THE SAME.",
                ".FOR 56FE(N,T)54MN 54FE(N,P)54MN WITH 310+-25 MB.",
                ".FOR 58NI(N,T)56CO 58NI(N,P)58CO WITH 370+-40 MB.",
                ".FOR 60NI(N,T)58CO THE SAME.",
                ".FOR 88SR(N,T)86RB 75AS(N,2N)74AS WITH 970+-80 MB.",
                ".FOR 90ZR(N,T)88Y 91ZR(N,P)91Y WITH 45+-4 MB.",
                ".FOR 141PR(N,T)139CE 141PR(N,P)141CE WITH 4.5+-0.5MB.",
                ".FOR 204PB(N,T)202TL 75AS(N,2N)74AS WITH 970+-80 MB.",
                ".ALL AT 14.6 MEV."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE DATA OF 141PR AND 204PB ARE LIKELY TO CONTAIN",
                " CONTRIBUTIONS FROM THE ACTIVITY DUE TO COMPETING",
                " REACTION CHANNELS OTHER THAN (N,T)."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".(N,T)-CROSS-SECTION DATA TAKEN FROM MAIN REFERENCE."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 761026,
                "history": "C"
              },
