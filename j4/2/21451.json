              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Measurement of the decay of the fundamental mode",
                " (Fourier analysis) of the thermal neutron density",
                " distribution in a cylinder of water after therma-",
                " lization of an injected burst of fast neutrons.",
                " Measurement of this decay for a range of water",
                " depths enables determination, by extrapolation, of",
                " the decay constant V*sigma(absorption) of an",
                " infinitely large system."
              ]
            }
          ],
