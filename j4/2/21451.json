          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Cylindrical water tank, radius 10.03+-0.3 cm, height",
                " 20 cm, covered with 0.04 in. Cd to prevent re-entry",
                " of room-reflected thermal neutrons. Water with",
                " conductivity of 7 micro-ohm/cm, total dissolved",
