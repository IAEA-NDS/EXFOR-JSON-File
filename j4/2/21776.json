          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Fission fragment energy correlation",
                " measurements for Th-229(n,f)."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2FR ILL"
              },
              "free_text": [
                "  ILL high flux reactor."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "THCOL"
                ],
                "reaction": null
              },
              "free_text": [
                " Cold neutron beam hole IH1."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The equivalent thermal neutron flux at target was",
                "        5.x 10**9 neutrons per cm2 per second, with",
                "        a thermal to fast ratio of 5.x 10**4 ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".0.914 micro-g/cm2 thorium dioxide or",
                " 20.2 micro-g/cm2 natural uranium oxide",
                " evaporated onto nickel backing.",
                ".Uranium sample used for calibration data."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Fast and slow coincidence combined with"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "   Time of flight difference between fission",
                "        fragments, used as a coherence test to",
                "        reject badly measured data."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two gold-silicon surface barrier detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Pulse heights converted to kinetic energies and",
                " masses via an iterative procedure using the",
                " calibration method of Schmidt+ C,65SALZBURG,1,531,65 ."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Differences between energy loss in backings of",
                " thorium and uranium samples.",
                ".No corrections made for the effect of neutron",
                " emission, except when indicated by a flag."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "From the author:\"As regards the issue thermal-cold it",
                "is correctly said in the paper by Asghar that the IH1",
                "beam of the ILL is cold. However, the beam IH1 has a",
                "wavelength peak at 3.2 A corresponding to a neutron",
                "energy of 8 meV, while thermal neutrons have 1.8 A",
                "with the energy being 25 meV. The beam IH1 is hence",
                "only \"slightly cold\". \""
              ]
            }
          ],
          "STATUS": [
