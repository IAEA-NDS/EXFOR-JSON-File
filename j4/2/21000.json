              "free_text": [
                " No mention of machine, vector polarized",
                " 140keV deuterons with a mean degree of polarization",
                "of 0.5 at 0.5 uA."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS",
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " 140 keV deuterons (0.5 uA) with",
                " a vector polarization of about 50% emerging from",
                " a conventional 'atomic beam' source impinged on",
                " a T-Ti target. Outgoing neutrons at different angles",
                " are used to get differently polarized neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Same as detector 3."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "ASSOP",
                "COINC"
              ],
              "free_text": [
                " Flight paths 16 and 30 cm.",
                " To obtain the energy spectrum of the scattered",
                " neutrons, the time-of-flight difference between the",
                " scattered neutron and the associated alpha-particle",
                " from the neutron production is measured.",
                " To reduce the background, a coincidence was required",
                " between the associated alpha particle (production)",
                " and the recoil deuteron ( elastic scattering).",
                " For the asymmetry measurements the whole set-up",
                " remained fixed and only the incident neutron",
                " polarization was reversed."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Thin plastic scintillator to detect the",
                " associated alpha particles at 90 degrees with respect",
                " to the deuteron beam. The solid angle subtended by the",
                " detector is defined by a 1.5 cm x 3.0 cm rectangular",
                " slit at 8.0 cm from the target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Liquid scintillator NE213, 12.7 cm diam.,",
                " length 5.1 cm to detect the scattered neutrons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Deuterated scintillator, cylindrical, 3.81 cm in",
                " diam., 7.62 cm long, model NE230 (liq. scint)."
              ]
            }
          ],
          "CORRECTION": [
