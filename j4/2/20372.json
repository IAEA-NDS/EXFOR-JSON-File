          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENT OF GAMMA-RAY SPECTRA FROM THERMAL NEUTRON",
                " INTERACTION WITH U-235.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".REACTOR FR2, KARLSRUHE."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SELVE"
                ],
                "institute": null
              },
              "free_text": [
                "    MECHANICAL CHOPPER, FOR SEPARATION OF",
                " FISSION PRODUCT GAMMA RAYS, PERIOD T IS 20 MILLISEC."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".U(3)-O(8) 1000 MG, U-235 99.6 PERCENT ENRICHED."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ANTICOINCIDENCE BETWEEN 4PI FISSION NEUTRON DETECTOR",
                " AND GAMMA RAY SPECTROMETER (NEUTRON CAPTURE AND",
                " FISSION PRODUCT GAMMA RAYS ARE DETECTED).",
                ".ON-BEAM SPECTRUM BY MECHANICAL CHOPPER IS CONSIDERED",
                " AS MAINLY DUE TO CAPTURE EVENT.",
                ".FISSION PRODUCT (DELAYED) GAMMA RAY WITH HALF LIVES",
                " BETWEEN THE COINCIDENCE RESOLVING TIME 25 NSEC AND THE",
                " CHOPPER PERIOD IN THE PROMPT ANTI-COINCIDENCE SPECTRUM",
                " IS REMOVED PARTLY BY CAREFUL COMPARISON OF CORRESPOND-",
                " ING SPECTRA FROM DIFFERENT ISOTOPES, PARTLY BY USING",
                " ANOTHER SECOND DEVICE.",
                ".2ND DEVICE CONSISTS OF A THIN U-FOIL SURROUNDED BY A",
                " GAS SCINTILLATOR (FISSION PRODUCT) AND A PLASTIC",
                " SCINTILLATOR (BETA PARTICLE) IN COINCIDENCE WITH A",
                " LARGE GE(LI) DIODE."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "    GE-LI DETECTOR,",
                ".FISSION-CHAMBER (FISSION NEUTRON),"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "    NITROGEN-ARGON GAS SCINTILLATOR (FOR FISSION",
                " FRAGMENT) AND THIN PLASTIC SCINTILLATOR (FOR BETA)."
              ]
            }
          ],
