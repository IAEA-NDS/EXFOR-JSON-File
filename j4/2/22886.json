            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "CSICR"
              ],
              "free_text": [
                "  SCANDAL set-up:",
                " - proton detection with 35 MeV energy threshold in",
                "   the angular range 10-140 degrees",
                " - particle identification using E-DE technique",
                " - proton energy measured using 24 CsI(Na) detectors",
                " - proton trajectory calculated with drift chambers",
                " - count rate increased using a sandwiched multitarget",
                "   system",
                " - events associated with 96 MeV neutrons from the",
                "   beam are selected using a time-of-flight technique",
                " - neutron energy resolution ~3.7 MeV for CsI crystals",
                " - angular resolution  aprx. 10 degree"
              ]
            },
