          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons from the reactor."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The Tc-99 was mixed with aluminum oxide and filled",
                " into two stainless steel sample holders to a sample",
                " thickness of 0.00078 and 0.00034 Tc-99 atoms/barn.",
                ".To check the homogeneity of the two samples,",
                " neutron radiographs were taken before and after the",
                " individual measurements.",
                ".Chemical purity of the material was tested with",
                " neutron activation and no essential impurities were",
                " found."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of Flight techniques using a flight",
                " path of 40 meters.",
                ".Resolution width was 17 milli-eV at E= 5.6 eV and",
                "                      50 milli-eV at E=20.3 eV.",
                ".Doppler width at room temperature was",
                "                      80 milli-eV at E= 5.6 eV and",
                "                     150 milli-eV at E=20.3 eV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Li-6 glass-scintillator detectors."
              ]
            }
          ],
