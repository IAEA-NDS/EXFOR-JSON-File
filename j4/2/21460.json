          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".MEASUREMENT OF THE SPATIAL DISTRIBUTION OF NEUTRONS",
                " IN A LARGE WATER TANK AS A FUNCTION OF TIME BY",
                " DETECTING THE CAPTURE GAMMA RAYS. THE TANK WAS AN",
                " OPEN CUBOID OF 1.8 M DEEP AND 2.5 M SQUARE.",
                " THE INITIAL NEUTRON DISTRIBUTION IS CREATED BY A",
                " PULSED NEUTRON BEAM COMING INTO THE WATER TANK."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " PLASTIC SCINTILLATOR, TYPE NE102 (NUCLEAR",
                " ENTERPRISES LTD. EDINBURGH) WITH THERMAL NEUTRON",
                " DIFFUSION PROPERTIES SIMULAR TO THOSE OF WATER."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " AS INCOMING NEUTRON FLUX MONITOR."
              ]
            }
          ],
          "ANALYSIS": [
