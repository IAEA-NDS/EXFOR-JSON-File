              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Multiplate ionization chamber containing Pu-239 oxide.",
                " Cf-252 was deposited for normalization."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
