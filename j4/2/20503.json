          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Gamma-ray multiplicity in Pu-239 fission induced by",
                " resonance neutrons. Experimental evidence for the",
                " (n,gamma fiss) reaction."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
