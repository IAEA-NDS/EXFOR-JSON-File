          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "STANK",
                "IOCH"
              ],
              "free_text": [
                " 520 Litre gadolinium loaded liquid",
                "scintillator. The fission events were identified by a",
                "coincidence between an ionization chamber pulse and a",
                "prompt fission gamma-ray pulse from liquid",
                "scintillator (to eliminate alpha pile-up), counting",
                "of fission neutrons, during 30 micro-sec after each",
                "fission event."
              ]
            }
          ],
