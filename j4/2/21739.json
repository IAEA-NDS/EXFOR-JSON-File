          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".BORAX SOLUTIONS, B2O3, ANALAR BORAX, TOTAL WEIGHT",
                " VARIED FROM ZERO TO 11.5 KG IN A TANK OF 600 GALS",
                " VOLUME. THE TANK WAS LINED WITH PARAFIN WAX AND WAS",
                " FILLED WITH DEMINERALISED WATER.",
                ".THE VALUME OF THE TANK WAS MEASURED BY A CALIBRATED",
                " WATER FLOW METER AND BY DIRECT WEIGHING OF THE CONTEN",
                ".THE MEAN TEMPERATURE WAS 18 DEG CENTIGRADE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DYNAMIC METHOD, IN WHICH THE DECAY CONSTANT OF NEUTRO",
                " IN A WATER TANK IS PLOTTED AGAINST THE CONCENTRATION",
                " OF ADDED BORAX.",
                ".THE DECAY CONSTANT OF DECAY GAMMAS FROM THE B(N,A)",
                " REACTION WAS MEASURED AS A FUNCTION OF CONCENTRATION",
                " OF BORAX FOR SEVERAL DISTANCES OF THE SCINTILLATION",
                " COUNTER FROM THE NEUTRON SOURCE."
              ]
            }
          ],
