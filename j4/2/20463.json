          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " THE INDICATED ERRORS ARE A COMBINATION OF COUNTING",
                " STATISTICS, BACKGROUND NORMALISATION, ANGULAR",
                " UNCERTAINTY OF THE DETECTOR, THE TOTAL CROSS SECTION",
                " OF B10 (+- 2 PC) AND MULTIPLE SCATTERING (+- 30 PC OF",
                " CORRECTION), WHILE CONTRIBUTION FROM THE UNCERTAINTIES",
                " IN THE TOTAL CROSS SECTIONS OF OTHER COMPONENTS IN THE",
                " SAMPLES ARE NEGLIGIBLE.  SEE COMMENT."
              ]
