              "free_text": [
                "   5 MV VAN DER GRAAF."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                "   5 MEV PROTON BEAM ON ZIRCONIUM TRITIDE."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".RING OF SODIUM METAL, 5.5CM I.D., 13 CM O.D., AND",
                " THICKNESS 3.7 CM. ENCASED IN A THIN STAINLESS STEEL",
                " CAN. A RING OF SODIUM PEROXIDE IN A BRASS CAN WAS",
                " ALSO USED. THE SAMPLE HAD ITS AXIS PARALLEL TO THE",
                " PROTON BEAM AT 37 CM FROM THE NEUTRON SOURCE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASSOP"
              ],
              "free_text": [
                " RING GEOMETRY."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NAI(TL) CRYSTAL, 4.5 CM DIAMETER, 5 CM LONG",
                " SHIELDED FROM NEUTRON SOURCE WITH 16 CM POLYTHENE",
                " AND 8 CM LEAD. DETECTOR CALIBRATED WITH STANDARD",
                " RADIOACTIVE SOURCES."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".GAMMA PRODUCTION CROSS SECTIONS WERE REDUCED TO",
                " INELASTIC EXCITATION CROSS SECTIONS WITH DATA",
                " FROM COINCIDENCE MEASUREMENTS AND A KNOWLEDGE OF",
                " THE NA-23 LEVEL SCHEME."
              ]
            }
          ],
