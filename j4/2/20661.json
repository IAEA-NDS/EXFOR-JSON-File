                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "Gives details on the 14.1 MeV",
                " measurement."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "code": "W,BENZI,1969",
                "code_unit": [
                  {
