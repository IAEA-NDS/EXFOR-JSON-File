          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Dimple: T=20 deg-C and virtually a pure Maxwellian",
                " (epithermal index r<0.001)",
                "Gleep: T=66+/-5 deg-C and epithermal index",
                " r=0.042+/-0.002 (the latter being measured by Cd",
                " ratio of thin Au foils)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Solution in D2O in polythene bottles (~2.5 cm diam,",
                " 30 cm long, ~150 ml).",
                "Impurity contributions were calculated from the",
                " chemical and mass analyses of the solutions."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "<eta(x)/eta(y)>=[1-sig(eff,x)/sig(abs,x)]/",
                "                [1-sig(eff,y)/sig(abs,y)],",
                " where x and y are 233U, 235U or 239Pu, and the",
                " absorption cross sections are taken from BNL-325.",
                " <...> means ratio in the reactor., which is converted",
                " to the 2200 m/s ratio:",
                "eta(x)/eta(y)=<eta(x)/eta(y)>*",
                "         [(g(abs,x)+r*s(abs,x))/(g(fis,x)+r*s(fis,x))]/",
                "         [(g(abs,y)+r*s(abs,y))/(g(fis,y)+r*s(fis,y))],",
                " where g and r are the Westcott's g-factor and",
                " epithermal index, respectively."
              ]
            }
          ],
