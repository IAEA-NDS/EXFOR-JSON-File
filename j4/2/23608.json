          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SHAPE"
              ],
              "free_text": [
                " The 0.758-eV p-wave resonance was fitted with",
                "the Breit-Wigner function including the background",
                "and the s- wave component (1/v term) . The effects of",
                "the Doppler broadening (free gas at 295 K) and the",
                "resolution function of ANNRI were convolved with the",
                "Breit-Wigner function. In the fitting, the total",
                "width of the 0.758-eV p-wave resonance was used as",
                "the gamma width, because the neutron width of the",
                "p-wave resonance is negligibly smaller than the gamma",
                "width."
              ]
            }
          ],
