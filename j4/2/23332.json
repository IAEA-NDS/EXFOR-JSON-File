          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A scalled modified R-matrix calculation was used to fit",
                "the THM resonances and allowed to determine the neutron",
                "and alpha reduced widths.",
                "The reduced widths extracted from R-matrix fit on the",
                "THM can be inserted in Eq.(8) to reproduce the availabl",
                "direct data cross section.",
                "Reduced widths for the two highest levels were",
                "determined to reproduce the partial widths of",
                "J.Wagemans+ and Avila+ ."
              ]
            }
          ],
