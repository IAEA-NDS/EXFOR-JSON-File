          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The neutron flux was generated by electron bursts of",
                "  100-MeV average energy, 1-ns width, at a repetition",
                " rate of 800-Hz and average beam current of 75-muA,",
                " hitting a mercury-cooled rotary uranium target."
              ]
            }
          ],
