          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                ".Gamma rays were detected by C(6)D(6)-based",
                " liquid scintillators."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                "  For the total cross section measurement, the",
                " moderated neutrons, were detected by a 1/4-inch thick",
                " Li-glass (NE912)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " three BF(3) proportional counters were used as",
                " neutron-flux monitors during the measuring time."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The Maxwell averaged calculations were performed",
                "  using new resonance parameters up to 5-keV.",
                ".Resonance parameters deduced from the measured total",
                " Krypton isotopes cross sections"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Maxwell energy distribution"
              ]
            }
          ],
