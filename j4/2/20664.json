              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " The Li(p,n) reaction was used in a lithium-",
                " fluoride-tantalum-backed target (1 mg/cm2 thick),to",
                " produce the 2.45 MeV neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The scatterers were 40mm long cylinders of natural",
                " isotopic composition."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight technique plus additional",
