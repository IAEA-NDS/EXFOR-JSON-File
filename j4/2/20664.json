              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Two NE213 liquid scintillators (3.7cm in",
                " diameter and 4.2cm in length) on 56AVP",
                " photomultipliers.",
                ".For monitoring purposes were used-",
                ".A stilbene-crystal(1.3cm in length x 3.8cm diameter)",
                " on a 56AVP photomultiplier served as monitor for the",
                " neutron yield."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " A BF3 counter in a plexiglas moderator was used,",
