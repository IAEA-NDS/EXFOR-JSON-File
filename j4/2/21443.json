          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-EXPERIMENTS INVOLVING THE EMISSION OF PARTICLES FROM",
                " COMPOUND NUCLEI.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": null
              },
              "free_text": [
                " COCKCROFT-WALTON, BEAM CURRENT ABOUT 100 MICRO",
                " -AMPERE."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " FOR THE MEASUREMENTS AT 14.1 MEV INCOMING",
                " NEUTRON ENERGY, A 160 KEV DEUTERON BEAM WAS USED AND",
                " THE NEUTRONS OBTAINED AT AN ANGLE OF 90 DEG., AT 12.9",
                " AND 15.7 MEV INCOMING NEUTRON ENERGY A 600 KEV",
                " DEUTERON BEAM WAS USED, AND ANGLES OF 0 AND 180 DEGR.",
                " THE TRITIUM TARGET WAS ABOUT 70 KEV THICK, AND 1 IN.",
                " DIAM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".FITS BASED ON THE STATISTICAL MODEL PREDICTED SHAPES",
                " TO THE SPECTRA ARE USED TO REJECT (N,NP) REACTIONS,",
                " DIRECT REACTIONS ARE AVOIDED BY NOT MEASURING AT",
                " FORWARD ANGLES, EXTENSION TO 4*PI IS DONE ASSUMING AN",
                " ISOTROPIC ANGULAR DISTRIBUTION FOR THE COMPOUND",
                " NUCLEUS PART OF THE REACTION."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "CSICR"
              ],
              "free_text": [
                " CS-I(TL)-CRYSTALS FROM HARSHAW CHEMICAL CO.,",
                " 0.035 IN. THICK FOR 14.1 MEV EXPERIMENTS, 0.045 IN.",
                " THICK IN THE OTHER EXPERIMENTS."
              ]
            }
          ],
