          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuterated titanium target. Energy of incoming",
                " deuterons 2 MeV. The neutron energy was varied by",
                " varying the angle subtended by the sample at the targe",
                " with respect to the incident beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thin discs either 1 or 2 cm in diameter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 3 * 3 Inch NaI-detector for measuring gamma",
                " rays from the activated samples."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Silicon surface detector for proton detections",
                " of the neutron flux monitoring reaction D(d,p)H-3."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The neutron flux was estimated by detecting protons",
                " from the d(d,p)H-3 reaction with a surface barrier",
                " detector placed at right angles with the incoming",
                " beam.",
                " The photopeak efficiency of the gamma detector was",
                " estimated from (crosjean+,table of absolute detection",
                " efficiencies of cylindrical scintillation gamma-ray",
                " detectors, univ. Of ghent,1965) and (heath, A.E.C.",
                " Research and Development report Physics,2nd edn.,",
                " Vol 1, IDO-16880-1, Phillips Petroleum Company,",
                " Atomic Energy Division, 1964)"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For",
                " - attenuation of incident neutrons",
                " - self absorption of the emitted gamma rays",
                " - different angular distributions of the reactions",
                "   D(d,n)He-3 and D(d,p)H-3."
              ]
            }
          ],
