              "pointer": "",
              "coded_information": null,
              "free_text": [
                " -Neutron total cross sections of Pu-239 from transmis-",
                " sion measurements in the energy range of 1 to 500 keV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.Derrien"
              ],
