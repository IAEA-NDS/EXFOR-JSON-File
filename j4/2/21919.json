          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inclined cold-neutron beam hole (IH1). The equivalent",
                "thermal flux at the fission target positions was",
                "  5. x 10**9 n/cm2/sec."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " ThO2 2.2 ug",
                " U3O8 1.2 ug both evaporated on platinum disc 0.1 mm",
                " thick and 50 mm in diam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
