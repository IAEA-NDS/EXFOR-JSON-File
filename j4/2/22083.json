          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-FAST NEUTRON SCATTERING CROSS SECTIONS OF SN-118",
                " AT 14.9 AND 18.0 MEV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.CHIBA",
                "Y.YAMANOUTI",
                "M.SUGIMOTO",
                "M.MIZUMOTO",
                "Y.FURUTA",
                "M.HYAKUTAKE",
                "S.IWASAKI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2JPNJAE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": null
              },
              "free_text": [
                " JAERI TANDEM ACCELERATOR FACILITY. DEUTERONS",
                " WERE ACCELERATED TO 12.2 AND 15.5 MEV, RESPECTIVELY,",
                " WITH AN AVERAGE BEAM CURRENT OF 2 MICROAMPS. THE BEAM",
                " WAS PULSED AT A REPETITION RATE OF 2 MHZ."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " A DEUTERIUM GAS TARGET, FILLED TO A PRESSURE OF",
                " 2 ATM, WAS USED TO PRODUCE NEUTRONS OF ENERGIES 14.9",
                " AND 18.0 MEV, RESPECTIVELY."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME-OF-FLIGHT WITH A FLIGHT PATH OF 8 M. OVER-",
                " ALL TIME RESOLUTION WAS 4 NS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " THE SCATTERED NEUTRONS WERE DETECTED BY AN ARRAY",
                " OF FOUR NE 213 LIQUID SCINTILLATORS, 20 CM DIAMETER BY",
                " 35 CM THICK, VIEWED BY PM-TUBES AT BOTH ENDS. TIME",
                " COMPENSATION TECHNIQUES WERE USED. THE COVERED ANGULAR",
                " RANGE WAS 20 - 140 DEGREES."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " TWO NE 213 SCINTILLATORS, 5 CM DIAMETER BY 1.26",
                " CM THICK, WERE USED AS MONITOR DETECTORS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE SAMPLE WAS OF CYLINDRICAL SHAPE, 1.6 CM IN",
                " DIAMETER AND 3.0 CM IN HEIGHT. THE ISOTOPIC PURITY OF",
                " THE SAMPLE WAS 97.15 PERCENT. THE CHEMICAL PURITY WAS",
                " 99.9 PERCENT."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE DATA WERE CORRECTED FOR DEAD TIME, SOURCE NEUTRON",
                " ANISOTROPY, FLUX ATTENUATION, MULTIPLE SCATTERING AND",
                " ANGULAR RESOLUTION."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " THE DATA CONTAIN ERRORS DUE TO COUNTING",
                " STATISTICS, 0.9 - 12 PERCENT IN ELASTIC AND 5.4 - 80",
                " PERCENT IN INELASTIC SCATTERING. THE NORMALIZATION",
                " ERRORS WERE 4.9 AND 3.5 PERCENT FOR THE 14.9 AND 18.0",
                " MEV RESULTS, RESPECTIVELY."
              ]
            }
          ],
