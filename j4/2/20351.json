          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Ac-227 was produced by irradiation of Ra-226 in the",
                " Br-2 reactor and purified to better than 99.95 percent",
                " to eliminate its descendant, mostly Th-227, further",
                " purification was carried out a few hours before",
                " measurement."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Experimental error is larger than value itself,",
                " only upper limit of value is given.",
                ".Two results were obtained, they are",
                " 125 +- 164 micro-B  and  335 +- 68 micro-B.",
                " 50 micro-barn should be subtracted as a slight",
                " contribution from Th-227."
              ]
            }
          ],
