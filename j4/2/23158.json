            {
              "pointer": "",
              "coded_information": [
                "SURGT"
              ],
              "free_text": [
                "           The quasi-free break-up of deuteron",
                " was used to study the neutron-induced 6Li + n reaction",
                " via the 2H(6Li,alpha+3H)p."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "COINC"
              ],
              "free_text": [
                " The quasi-free break-up of deuteron",
                " events produced by the quasi-free break-up of a",
                " deuteron were selected and the two-body cross section",
                " for the 6Li+n->t+alpha reaction was reconstructed"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PS",
                "SI"
              ],
              "free_text": [
                "  Position sensitive solid state detectors",
