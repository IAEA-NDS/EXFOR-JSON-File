          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The amount of 135Cs was estimated by the activity",
                " measurement of the 136Cs induced from 135Cs(n,g)136Cs",
                " reaction, since 135Cs decays by a beta-transition,",
                " it does not emit gamma-rays",
                " Gamma-rays with energies of  796, 802, 819, 1039,",
                " 1048, 1168 and 1235 originated from 134Cs and 136Cs",
                " nuclides induced by one- and triple-neutron capture",
                " of 133Cs were used in this experiment"
              ]
            }
          ],
