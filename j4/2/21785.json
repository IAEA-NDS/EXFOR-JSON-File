          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Measurement of prompt nu-bar and prompt E-gamma",
                " in the fission of Th-232,U-235, and Np-237 induced",
                " by neutrons in the energy range between 1 and 15 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2FR BRC"
              },
              "free_text": [
                " Tandem Van de Graaff accelerator, 7 MV."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The T(p,n)He-3 reaction and"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " the D(d,n)He-3 reaction using gas targets",
                " in both cases.",
                " They were 7.5 cm long and had a pressure between",
                " 1 and 2 bars."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight techniques in order to",
                " discriminate against fissions induced by",
                " secondary neutrons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Fission chamber associated with"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                " a big Gd-loaded liquid scintillator.",
                " In the first experiment (Np+U) the fission",
                " chamber was filled with argon mixed with 20%",
                " methane under a pressure of 3 bars.",
                " In the second experiment (Th) it was filled",
                " argon with 2% nitrogen under a pressure of 7.5 bars."
              ]
            }
          ],
