          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three similar fission chambers with plane parallel",
                "plates were used.",
                "  - One contained a 252Cf sample giving",
                "about 10 spontaneous fissions per second.",
                "   - The fission chambers with 239Pu and 24lPu",
                "contained 20 mg of active material deposited on three",
                "platinum plates with a coating thickness of 0.5 mg/cm2."
              ]
            }
          ],
