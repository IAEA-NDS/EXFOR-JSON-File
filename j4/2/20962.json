          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-CROSS SECTIONS FOR THE PRODUCTION OF GAMMA-RAYS BY",
                " THE INELASTIC SCATTERING OF NEUTRONS FROM IRON-."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                " ELECTROSTATIC GENERATOR, 5 MV."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " TITANIUM TRITIDE TARGET BOMBARDED BY 5 MEV",
                " PROTONS. NEUTRON ENERGY SPREAD OF 50 KEV, DUE TO",
                " TARGET THICKNESS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".ANNULAR IRON RING PLACED AT 38.7 CM FROM THE NEUTRON",
                " SOURCE WITH AXIS COLINEAR TO THE PROTON BEAM."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".RING GEOMETRY."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NAI(TL) CRYSTAL, 4.5 CM DIAMETER, 5 CM LONG,",
                " AT THE CENTRE OF THE IRON SAMPLE RING, IN OPTICAL",
                " CONTACT WITH AN EMI PHOTOMULTIPLIER.",
                ".DETECTOR SHIELDED FROM NEUTRON SOURCE WITH 16 CM OF",
                " POLYTHENE AND LEAD."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CROSS SECTIONS DERIVED FROM THE GAMMA YIELD, WITH",
                " THE ASSUMPTION THAT THE DETECTED GAMMAS BETWEEN 45",
                " AND 150 DEGREES REPRESENTS THE YIELD OVER 4 PI.",
                "  WITH PREDICTED ANGULAR DISTRIBUTIONS THE CROSS",
                " SECTIONS FOR THE 0.845 MEV GAMMA SHOULD BE INCREASED",
                " BY 15 PERCENT NEAR NEUTRON THRESHOLD.",
                " VARIOUS SIZES, 6.4 CM I.D, 11.5 CM O.D, 3.8 CM THICK.",
                "               7.6 CM I.D, 11.4 CM O.D, 2.5 CM THICK."
              ]
            }
          ],
