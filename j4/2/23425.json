              },
              "free_text": [
                " High flux reactor in Grenoble",
                " Mechanical velocity selector"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Multidetector of gas-amplification type filled",
                "with BF3, around 3800 elements each of 1 cm2 area,",
                "detection efficiency 45-90 % for neutron wavelength",
                "0.7 -1 nm .",
                "Distance detector-sample 10.5 m for transmission ,",
                " 2.53 m for scattering experiments.",
                "Solid angle 4.7E-3 times of the full solid angle 4PI."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Typical measuring time 5min for transmission,",
                " 20 min for scattering experiment."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  Beam cross section was determined by sample aperture",
                "to be 8.5 x 9.5 mm .",
                "For transmission - primary beam was attenuated by",
                "Cd plate of 1 mm thickness, 3 x 5 cm size, with 15",
                "small holes. Fraction of 1.0 nm neutrons transmitted",
                "1/1100 +-4% ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " H(2)O/D(2)O in quartz cells (HELLMA type 100-QS)",
                "surrounded by Cd. Neutron pathway within cells was",
                "1.00mm+-0.5% . For D(2)O rich - cells of 2.00 mm",
                "thickness.Cylindrical cells of 0.50 mm thickness -for",
                "few measurements on samples rich in H(2)O and neutrons",
                "of 1.0 nm wavelength.",
                "Molecular density (1/30)*10**24 water molecules per cm3"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For scattering experiment:",
                "for background via diaphragm and cell windows by",
                "subtracting weighted spectrum taken with an empty cell.",
                "Other - checked with Cd in sample position -negligible"
              ]
            }
          ],
