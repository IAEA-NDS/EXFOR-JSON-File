              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST",
                "SIBAR"
              ],
              "free_text": [
                " Thin plastic scintillators ( NE102A,",
                "25 ug/cm2 thickness, sandwiched with 2 lucite half",
