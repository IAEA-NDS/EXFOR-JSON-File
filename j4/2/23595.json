              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Double-velocity and double-energy measurement.",
                "Number of events about 18000 in 140 hr for U-233,",
                "                       16000 in 110 hr for U-235,",
                "                       8500 in 140 hr for Pu-299."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Type-I - deformed both light and heavy fragments,",
                " Type-II - deformed light fragment and spherical heavy",
                "fragment.",
                ". Table 1 - population of configuration grout for",
                "two types:",
                "          U-233    U-235   Pu-239",
