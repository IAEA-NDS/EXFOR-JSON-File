          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutrons reactor neutron spectrum with a",
                "Maxwell-Boltzmann energy distribution at kT = 25.3 meV.",
                "The epithermal neutron flux approximated by 1/E.",
                "              Neutron fluence (/cm2)",
                "                    without Cd",
                "thermal(xE14)        9.89 +- 0.25stat +- 0.20sys",
                "epithermal(xE13)     4.46 +- 0.14stat +- 0.14sys",
                "                     with Cd",
                "thermal(xE14)        1.16 +- 0.11stat +- 0.15sys",
                "epithermal(xE13)     4.31 +- 0.06stat +- 0.11sys"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The radioactive 171Tm sample produced via irradiation",
                "of a 170Er sample at the research reactor at ILL,",
                "Grenoble for 55 days. The induced 171Er decay with",
                "T1/2=7.52 h to 171Tm. The 171Tm extracted by a chemical",
                "separation was performed at the Paul-Scherrer-Institut.",
                "the number of 171Tm nuclei determined by 67 keV",
                "gamma-ray measurements considering T1/2(171Tm)=1.92 yr",
                "and Ig(67 keV)=0.155",
                "Number of 171Tm nuclei on 20 March 2017 =",
                "    (2.68 +- 0.01st +- 0.09sys)E15"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cadmium difference method using 1 mm Cd shielding."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Two 10 minute irradiations. The first run with",
                "and the second one without shielding. Time between",
                "irradiations 43 days."
              ]
            },
