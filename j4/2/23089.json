          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Neutron capture cross sections of 88Sr were obtained",
                " by applying a pulse height (PH) weighting technique",
                " on the net PH spectra and by determining the number",
                " of the incident neutrons from well-known 197Au neutron",
                " capture cross sections"
