          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THREE CONCENTRATIONS OF URANYL NITRATE SOLUTION",
                " IN HEAVY WATER WITH THICKNESSES 0.0761E-3 ATOMS/BARN,",
                " 0.1500E-3 ATOMS/BARN AND 0.3037E-3 ATOMS/BARN.",
                ".ONE URANIUM METAL SAMPLE OF THICKNESS 0.4245",
                " ATOMS/BARN.",
                ".URANIUM DIOXIDE SAMPLES WHERE THE THICKNESSES RANGED",
                " FROM 0.0238 TO 0.1416 ATOMS U-238/BARN, (DEPLETED",
                " URANIUM SAMPLES)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " TIME OF FLIGHT AT THE 14 METER AND THE 40",
                " METER FLIGHT PATH. THE ENERGY SCALE WAS ESTABLISHED",
                " USING RESONANCES PRESENT IN THE FILTER MATERIALS OF",
                " TANTALUM, MANGANESE AND ALUMINIUM, WHOSE RESONANCE",
                " ENERGIES WERE ASSUMED FROM THE EVALUATION OF BNL-325",
                " (1973)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " LITHIUM GLASS SCINTILLATOR DETECTORS."
              ]
            }
          ],
