          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Ratio of the ternary to binary fission induced by",
                " thermal and resonance neutrons in Pu-239.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "2ZZZGEL"
              },
              "free_text": [
                " Electron linear accelerator of CBNM."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "PHOTO"
                ],
                "reaction": null
              },
              "free_text": [
                "    Photo-neutron"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Neutrons from LINAC were slowed down by 4 cm thick",
                " polyethylene sheet placed above the mercury-cooled",
                " uranium target.",
                ".Several concentric Pb rings(50 mm thick) were mounted",
                " around the target to reduce gamma-flash and very fast",
                " neutrons in the spectrum."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Electro-spraying of highly enriched plutonium acetate",
                " on both sides of a 0.2 mm thick aluminum  disk.",
                ".Isotopic composition is (in atomic percent).",
                " Pu-238 less 0.005, Pu-239 99.956 +- 0.010,",
                " Pu-240 0.044 +- 0.010, Pu-241 less 0.005."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "      Time of flight, path = 8.1 m.",
                " 3 series of measurements were done, run I and II",
                " cover the energy region 0.1 to 50 eV using cadmium as",
                " overlap filter, and run III for n-energy of 0.01 to",
                " 15 eV without filter."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                "    4 large Si(Au) solid-state detectors(30 mm",
                " diam.) on both sides of evacuated cylindrical chamber.",
                " In the center of this chamber a double-faced Pu-239",
                " layer is mounted  (back-to-back)",
                ".Neutron spectrum were checked with Si(Au) surface-",
                " barrier detectors and a B-10 layer."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF",
                "A"
              ],
              "free_text": [
                "    Fission fragments, alphas."
              ]
            }
          ],
