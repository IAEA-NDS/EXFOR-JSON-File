          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The angular distributions of two gamma-rays measured at",
                "1.10 MeV and 1.80 MeV at seven angles are isotropic or",
                "show only slight departures from isotropy (shown at",
                "fig.6 of EANDC-50-S,(1),(24)). Values for the integral",
                "cross sections (not given here) can be obtained from",
                "the corresponding differential cross sections assuming",
                "that the angular distributions are isotropic throughout",
                "the whole energy range."
              ]
            }
