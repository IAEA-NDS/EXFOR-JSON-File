                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " neutron energies 13.0 MeV to 16.7 MeV",
                " solid targets of lithium fluoride, deuterium, or",
                " tritium occluded in titanium or yttrium layers,",
                "  on a 0.3 mm thick silver or molybdenum backing."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Metallic rhodium-103, 99.9% pure, 20 mm diam.,",
                " 5 mm thick used for relative activity",
                " measurements. 0.1 mm thick samples used for",
                " absolute cross section measurement."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " A pair of samples at each neutron emission",
                " angle ( corresponding to nominal neutron energies",
                " in 100 keV steps ) was irradiated for about 1 hour.",
                " 1000 sec delay after irradiation allowed for decay",
                " of any Rh-104 present. X-rays then counted for",
                " about 30 periods of 5 minutes. This allowed the",
                " half-life to be checked against the standard used.",
                " Relative cross sections calculated from relative",
                " activities.",
                " For absolute cross section measurement three pairs",
                " of rhodium samples irradiated with 1.80 MeV neutrons",
                " from p-t source. Activation of samples measured with",
                " Si-Li counters for at least 5 periods of 1000 to",
                " 2000 sec during a period 0.2 to 2 hours after",
                " irradiation. Activities checked after 20 hours to",
                " confirm the absence of long term activity.",
                " Si-Li detectors calibrated against thin 99.9%",
                " pure Rh-103m sources whose activities had been",
                " determined by liquid scintillation counting.",
                " Neutron flux from source measured by a recoil proton",
                " telescope counter 25 m away. Time dependence of",
                " neutron flux during sample irradiation was monitored",
                " with a directional long counter."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Na-I(Tl) scintillation crystals used to",
                "        measure relative activities of samples",
                "        irradiated by neutrons of different energy."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " Si-Li detectors with full-width-half-maximum",
                "        resolution of 600 eV at 20 keV used to measure",
                "        activity of samples for absolute cross",
                "        section measurement."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SOLST",
                "SOLST"
              ],
              "free_text": [
                " Recoil proton telescope counter and"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " long counter used to measure neutron flux",
                "        for absolute cross section measurement"
              ]
            }
          ],
