          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".By means of Christiansen filter it is possible",
                " to make use of the high accuracy achieved for the",
                " scattering amplitudes of liquids and for solids in",
                " the form of powders. Using powders of several",
                " elements the authors could measure scattering",
                " amplitudes with an uncertainly within +-0.2% to 1%."
              ]
            }
          ],
