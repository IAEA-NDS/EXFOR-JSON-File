          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For the threshold reactions the aver. fis. spectrum",
                " cross section (acs) was determined from the relation",
                " acs = R/F where R is the absolute reaction rate and",
                " F the equivalent fission flux.",
                " R was measured with a calibrated Ge(Li)-detector.",
                " F was determined using the standard threshold",
                " reactions 58-Ni(n,p) , 24-Mg(n,p) and 27-Al(n,alpha)."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Because of the thin samples no correction for self",
                " shielding and self absorption is needed.",
                " For the distinction of the fission spectrum of the",
                " irradiation positions from the theoretical fission",
                " spectrum (Watt-spectrum)."
              ]
            }
          ],
