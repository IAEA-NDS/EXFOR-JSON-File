          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Ten kg of uranium oxide powder , mixed with a small",
                "portion of ammonium carbonate, placed in a glass",
                "container, surrounded by a few cm of paraffin.",
                "Container was inserted as close as possible to",
                "neutron source. Irradiation time ~3 hr."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ASEP"
              ],
              "free_text": [
                " Inert gases from U were pumped off by a",
                "Toepler pump, using the gas given off by the ammonium",
                "carbonate (NH(3), CO(2), H(2)O) as carrier of activity.",
                "Isotopes separation was started in mass-spectrograph",
                " ~1/2 hr after stopping of cyclotron.",
                "Mass-spectrograph run time ~1 hr."
              ]
            }
          ],
