          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Total neutron cross section in heavy ice  at 77 and",
                " 15K for neutron energies between 0.3 and 100 milli-eV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "2JPNKTO"
              },
              "free_text": [
                " 46 MeV electron Linac of Kyoto Univ."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "PHOTO"
                ],
                "reaction": null
              },
              "free_text": [
                " Using a tantalum target.",
                " Fast neutrons produced in 3 micro-sec bursts",
                " with repetition frequency 50 Hertz, and",
                " moderated by a slab of solid mesitylene at a",
                " temperature of 15 K. Mean emission time of cold",
                " neutrons = 160+-20 micro-sec."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Maxwellian, approximate neutron temperature = 40K"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".20 mm thick heavy ice ,isotopic purity greater than",
                " 99.8%, kept at 77K by liquid nitrogen cooling, or at",
                " 15K by liquid nitrogen and helium cooling.",
                ".Sample in aluminum container."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight neutron spectrum measured",
                " with the heavy ice sample in position, and",
                " with an empty container in place of the sample.",
                ".Experiment performed for two sample temperatures.",
                ".Calculated cross section normalized, at high",
                " neutron energies, to the heavy water free atom",
                " total cross section."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                "  10 cm thick"
              ]
            }
          ],
