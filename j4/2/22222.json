              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENT OF THE LONG-LIVED 26-AL PRODUCTION CROSS",
                " SECTION IN THE 27-AL(N,2N) REACTION."
              ]
            }
          ],
