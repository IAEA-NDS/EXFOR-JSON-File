          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS"
                ],
                "reaction": null
              },
              "free_text": [
                " DEUTERIUM-TRITIUM REACTION USING 5.72 MEV",
                "        DEUTERONS TO PRODUCE 21.9 MEV POLARISED",
                "        NEUTRONS AT A REACTION ANGLE OF 30 DEGREES.",
                "        SOURCE POLARIZATION OF 0.44+-0.02 AT 5.72",
                "        MEV DEUTERON ENERGY OBTAINED BY LINEAR",
                "        INTERPOLATION BETWEEN THE VALUES OF MUTCHLER",
                "        ET AL,PHYS.REV.,C3,(1971),1031."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".10 MM DIAMETER, 3 CM HIGH GAS CELL FILLED WITH 25",
                " ATMOSPHERES HE-3 LOCATED 10 CM FROM NEUTRON SOURCE."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".LEFT-RIGHT ASYMMETRY IN THE YIELD OF THE SCATTERED",
                " HE-3 PARTICLES USED TO MEASURE FINAL POLARIZATION."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " COUNTER TELESCOPE CONSISTING OF THREE SILICON",
                "        SURFACE-BARRIER DETECTORS TO SEPARATE HE-3",
                "        FROM THE OTHER REACTION PRODUCTS. TWO OF THE",
                "        DETECTORS WERE DELTA-E COUNTERS, 25 MICRONS",
                "        THICK, THE THIRD A POSITION SENSITIVE TOTAL",
                "        ENERGY DETECTOR, 250 MICRONS THICK.",
                "        FOUR-DIMENSIONAL DELTA-E1 X DELTA-E2 X ENERGY",
                "        X POSITION ANALYSIS WITH 1024 ANALYSER CHA-",
                "        NNELS IN EACH DIMENSION."
              ]
            }
          ],
