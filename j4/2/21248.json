          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Aluminium can containing cylinders of sample material",
                " (metallic) plus monitor foils both with and without",
                " cadmium screen (1 mm sheet)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Determination of the absolute quantity of",
                " tritium produced by irradiation of sample targets."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " Geiger-Mueller counter filled with 90%",
                " counting gas (3 parts argon plus 1 part ethylene)",
                " and 10% H(2)-HT-mixture, the latter containing the",
                " tritium, extracted by heating the irradiated samples,",
                " plus hydrogen carrier gas."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "THRES"
              ],
              "free_text": [
                " Al and Ni foils were used as threshold",
                " detectors for the determination of the absolute fast",
                " neutron flux and the variations of the flux within",
                " the sample packets.",
                ".The tritium counter is surrounded by an annular",
                " anticoincidence counter as well as by a massive",
                " shielding against neutrons, cosmic rays and",
                " environmental activities."
              ]
            }
          ],
