              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2GERKFK"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                " THE KARLSRUHE VAN DE GRAAFF ACCELERATOR,",
                " DELIVERED A PULSED BEAM (1 MHZ REPETITION RATE, 1 NS",
                " PULSE WIDTH) OF PROTONS WITH ABOUT 2 - 3 MEV ENERGY",
                " AND AN AVERAGE CURRENT OF ABOUT 5 MICROAMPS,",
                " DEFOCUSSED TO A BEAM SPOT OF 8 MM DIAMETER."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS",
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " TRITIUM TARGET CONSISTED OF A 1.9 MG/CM2",
                " THICK TITANIUM-TRITIUM LAYER ON AN ALUMINIUM BACKING.",
                " POLARIZED NEUTRONS WERE PRODUCED AT AN ANGLE OF",
                " 33.9 DEGREES. THE NEUTRONS WERE COLLIMATED BY A 1 M",
                " LONG BORON-LOADED POLYETHYLENE COLLIMATOR TO A NARROW",
                " CONE WITH A SOLID ANGLE OF 1.5E-04 SR. A 45 CM LONG",
                " SUPERCONDUCTING SOLENOID WAS USED BETWEEN THE TARGET",
                " AND COLLIMATOR TO REVERSE PERIODICALLY THE NEUTRON",
                " SPIN DIRECTION. THE POLARIZATION OBTAINED WERE IN THE",
                " INTERVAL 0.28 TO 0.44."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " EVENTS IN THE SAMPLE WERE DETECTED BY OBSERVING",
                " THE SCINTILLATION LIGHT THROUGH QUARTZ WINDOWS WITH A",
                " PM-TUBE."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " THE SCATTERED NEUTRONS WERE DETECTED BY SIX",
                " PAIRS OF SCINTILLATION DETECTORS, HAVING DIMENSIONS",
                " OF TYPICALLY 4.5 CM DIAMETER BY 4.5 CM LENGTH, PLACED",
                " AT A DISTANCE OF 50 CM FROM THE SCATTERING SAMPLE.",
                " DIFFERENT SCINTILLATOR TYPES WERE USED, SUCH AS NE213,",
                " NE102A AND STILBENE.",
                ".TO SUPPRESS BACKGROUND, THE SAMPLE AND NEUTRON DETEC-",
                " TOR EVENTS WERE MEASURED IN COINCIDENCE."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".A LIQUID HE-3 SCATTERING SAMPLE WITH THE DIMENSIONS",
                " 40 MM DIAMTER BY 47 MM HEIGHT, PLACED AT A DISTANCE OF",
                " 2.8 M FROM THE TRITIUM TARGET, WAS USED. THE SAMPLE",
                " WAS RUNNING AT A TEMPERATURE OF ABOUT 2.3 K."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CORRECTIONS WERE APPLIED FOR TIME-DEPENDENT CHANGES IN",
                " THE HE-3 DETECTOR, UNCORRELATED BACKGROUND, MULTIPLE",
                " SCATTERING AND FINITE SCATTERING GEOMETRY."
              ]
            }
          ],
