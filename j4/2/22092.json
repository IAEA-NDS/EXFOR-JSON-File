          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-ANALYZING POWER OF N-3HE ELASTIC SCATTERING FROM 1 TO",
                " 2 MEV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "P.JANY",
                "W.HEERINGA",
                "H.O.KLAGES",
                "B.ZEITNITZ",
