          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Kinetic energy and fragment mass distributions for",
                " Pu-240(0,f),Pu-239(n,f) and Pu-240(g,f)"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2BLGMOL"
              },
              "free_text": [
                " The reactor BR1 of the SCK/CEN MOL,",
                " Belgium."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                " Bremsstrahlung produced by electron beam",
                " from a linear accelerator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The Pu-240 sample consisted of a 109 micro-g/cm-sq",
                " PuF3 layer on a 40 micro-g/cm-sq polyimide backing",
                " with 10 micro-g/cm-sq gold. The isotopic composition",
                " was 0.68% Pu-239, 98.47% Pu-240,",
                " 0.48% Pu-241 and 0.37% Pu-242.",
                " The Pu-239 sample consisted of a 118 micro-g/cm-sq",
                " PuF3 layer on the same backing as Pu-240. The",
                " isotopic abundance of Pu-239 was 99.98%.",
                " The diameter of the active layer was 25 mm in both",
                " cases"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Each spontaneous fission experiment was accompanied",
                " by a calibration Pu-240(g,f) run with 20-MeV",
                " bremsstrahlung. The Pu-240 photofission runs were",
                " calibrated by Pu-239(n,f) with thermal neutrons",
                " using a calibration procedure according to (PR,",
                " 137,B837,1965) and parameters from (PR,149,894,1966).",
                " These Pu-239(n,f) measurements were done with a",
                " well-thermalized and collimated neutron beam",
                " from the reactor."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "M",
                "subentry_number": "13081001",
                "author": "H.W.Schmitt+",
                "reference": {
                  "code": "J,PR,137,B837,1965",
                  "field": {
                    "reference_type": "J",
                    "reference": {
                      "code": "PR",
                      "number": null,
                      "volume": "137",
                      "part": null,
                      "issue": null,
                      "page": "B837"
                    },
                    "date": 1965
                  }
                }
              },
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "code": "R",
                "subentry_number": null,
                "author": "J.N.Neiler+",
                "reference": {
                  "code": "J,PR,149,894,1966",
                  "field": {
                    "reference_type": "J",
                    "reference": {
                      "code": "PR",
                      "number": null,
                      "volume": "149",
                      "part": null,
                      "issue": null,
                      "page": "894"
                    },
                    "date": 1966
                  }
                }
              },
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                "2 Ortec F-series heavy ion detectors (CF090-600",
                " -60) mounted symmetrically on both sides of the",
                " fission sample at a distance of 7 cm from the sample",
                " and at the angle of 90 degrees to the bremsstrahlung",
                " or neutron beam axis."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Off line, the data were sorted in two-dimensional",
                " provisional mass (My) and total kinetic (Ek) arrays,",
                " 120 * 120 channels."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The reference also contains data on Pu-240(g,f)",
                " using gammas from bremsstrahlung."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For",
                " - spontaneous fission of other Pu-isotopes",
                " - drift in the measuring system"
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "COREL"
                ],
                "subentry_number": "L0105001",
                "author": null,
                "reference": null
              },
              "free_text": [
                " Pu-240(g,f) using gammas from",
                "                  bremsstrahlung."
              ]
            }
          ],
