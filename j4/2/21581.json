          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal Maxwellian neutron spectrum from reactor.",
                " Flux density 1.7E+11 n/sec/cm2."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Surface ionization source. Thin sheets of",
                " graphite coated with about 200 mg of U-235 at",
                " 1700 degr Kelvin in a W-oven where the alkaline",
                " ions are accelerated at 6 kV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "OLMS"
              ],
              "free_text": [
                " Isotope separator using a surface ionization",
                "source, mass resolution delta(A)/A = 700., maximum",
                "efficiency is 6% for Rb-90.",
                " Measurement of the decay curve by delayed neutron",
                " emission after collection of the fission products",
                " in a 25 microns thick window of aluminized capton",
                " in the well shielded detector position."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " 8 He-3 proportional counters circularly",
                " embedded in paraffin and shielded by a Cd-sheet and",
                " boron paraffin.  Neutron detection efficiency",
                " measured with a Am-Li standard source, 13.8 +- 0.5%",
                "  (Delayed neutron detection)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "  Plastic scintillator (detection of beta",
                " particles) 0.5 mm long * 20 mm in diam., efficiency",
                " about 30.%"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "  Ge(Li) detector, 18% efficiency",
                " relative to a 3 in * 3 in Na-I-(Tl) crystal.",
                " Energy resolution = 1.95 keV at 1332. keV. For",
                " detection of the fission product decay gammas."
              ]
            }
          ],
