                "reaction": null
              },
              "free_text": [
                " SB-BE PHOTONEUTRON SOURCE CALIBRATED ABSOLUTELY",
                "        IN A MANGANESE BATH TO +-0.5 PC. HALF-LIFE OF S",
                "        124 TAKEN TO BE 60.2+-0.03 D TO COMPUTE CHANGES",
                "        OF SOURCE STRENGTH WITH TIME. SOURCE STRENGTH A",
                "        THE TIME OF IRRADIATION WAS 7.37X10**6 N/SEC."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CSI CRYSTAL OF DIAMETER 2.54 CM AND THICKNESS 0.38 CM."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CROSS SECTION EXTRACTED BY FITTING A STRAIGHT LINE TO",
                " THE VARIATION OF I-128 ACTIVITY WITH INVERSE SQUARE OF",
                " THE DISTANCE FROM THE SOURCE."
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": {
                "flag": null,
                "nuclide": "51-SB-124",
