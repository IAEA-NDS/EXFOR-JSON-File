          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": "2JPNLEP"
              },
              "free_text": [
                " The KENS (KEK spallation neutron",
                " source) facility was used."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS"
                ],
                "reaction": null
              },
              "free_text": [
                " A pulsed (20 Hz) 500 MeV proton beam",
                " bombarded U target to produce neutrons by spallation.",
                " A dynamically polarized proton filter was placed at",
                " 5.2 m from the neutron source. Incident neutrons were",
                " transversely polarized (70% at En=1 eV) upon",
                " transmission through filter. The neutron polarization",
                " was determined by measuring the neutron transmittance",
                " of the filter. The neutron spin was reversed every",
                " 4 sec by reversing the magnetic field. The neutron",
                " beam was collimated to 1.8 cm diam. The intensity was",
                " monitored by counting the capture gamma-rays from an",
                " annular indium foil. The neutron energy was determined",
                " by TOF technique."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " La-139 target was a metal column 2.5 cm in diam.",
                " and 3 cm in height. As the bromine target, carbon",
                " tetrabromide of the same size was used. All Cd-111,",
                " Nb-93, Pd-108 and Sn-124 targets were metal disks with",
                " thickness 1.15,2.5,0.7 and 3 cm respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " For the 1st type of measurements (see method)",
                " 3 sets of BaF2 gamma-ray counters were used",
                " covering 85% of 4pi steradians.",
                " B4C was used to absorb neutrons scattered from target.",
                " In the 2nd and 3rd types of measurements, BGO scin.",
                " crystals were used.",
                " In all measurements, the neutron energy spectrum was",
                " measured using a B-10 loaded liquid scin. placed at",
                " 9.4 m from the neutron source (0 degree angle)"
              ]
            }
          ],
