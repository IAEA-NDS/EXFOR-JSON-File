          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Longitudinal asymmetry and gamma-ray angular distribu-",
                " tion in neutron radiative capture reactions"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
