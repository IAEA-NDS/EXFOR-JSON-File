          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-INVESTIGATION OF THE SI-29(N,G)SI-30 REACTION WITH",
                " NON-POLARIZED AND POLARIZED THERMAL NEUTRONS.-"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "    REACTOR, AT PETTEN."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".EPITHERMAL AND FAST NEUTRONS ARE FILTERED OUT OF THE",
                " BEAM FROM THE REACTOR BY MEANS OF QUARTZ AND BISMITH",
                " BEAM FROM THE REACTOR BY MEANS OF QUARTZ-BISMUTH",
                ".THERMAL NEUTRON FLUX DENSITY AT THE TARGET WAS",
                " (2.9 +- 0.2)*E+7 /CM2/S."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 0.3 G OF SI-DIOXIDE ENRICHED TO 95.28+-0.10 PERC IN",
                " SI-29, WITH SI-28 AND SI-30 ABUNDANCES OF",
                " 4.36 +- 0.10 AND 0.36 +- 0.05 PERCENT, RESPECTIVELY."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CAPTURE GAMMA SPECTRA WITH GE(LI) DETECTOR."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "     23 CM3 ORTEC GE(LI)DETECTOR."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " PEAK POSITIONS AND AREAS DETERMINED BY A COMPUTER",
                " PROGRAMME WHICH FITS A SUPERPOSITION OF UP TO SIX",
                " GAUSSIANS ON A LINEAR BACKGROUND TO SMALL SECTIONS",
                " OF THE SPECTRUM."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                "    GAMMAS."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " POLARIZED-NEUTRON CAPTURE GAMMA-RADIATION WAS ALSO",
                " MEASURED. SEE TEXT."
              ]
            }
          ],
