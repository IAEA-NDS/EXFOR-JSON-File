          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- THERMAL NEUTRON CAPTURE GAMMA-RAYS FROM NATURAL",
                "  CALCIUM -"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".HIGH FLUX REACTOR AT PETTEN."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "    TARGET PLACED IN A HORIZONTAL RADIAL BEAM",
                " OF THE REACTOR.",
                ".THE NEUTRON FILTER, CONSISTING OF QUARTZ",
                " AND BISMUTH SINGLE CRYSTALS, WAS COOLED TO",
                " 77 KELVIN BY LIQUID NITROGEN.",
                " NEUTRON FLUX = 1.E+7/CM**2/SEC."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".COMPOSITION 3 GRAMM CA-O AND 2.5 GRAMM CA40-O",
                " (99.97 PERCENT CA-40 ENRICHMENT)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "    5 CM**3 GE(LI) DETECTOR."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE INTENSITIES ARE NORMALIZED SUCH THAT THE",
                " SUM OF THE INTENSITIES OF THE 1943 AND 2010",
                " KEV GAMMA-RAY LINES IN CA-41 IS 100.",
                ".THE EFFICIENCY CURVES FOR FULL-ENERGY,",
                " SINGLE-ESCAPE AND PAIR PEAKS WERE OBTAINED",
                " WITH SOURCES OF KNOWN INTENSITIES AND WITH",
                " GAMMA-RAYS FROM CL-35(N,GAMMA) AND",
                " S-32(N,GAMMA) REACTIONS, DETAILS IN",
                " NUCL.PHYS.,A102(1967)226.",
                ".USING THE THERMAL-NEUTRON CAPTURE CROSS-",
                " SECTION FOR NATURAL CA (= 0.44 BARN, BNL-325",
                " (1958)6 AND THE RELATIVE GAMMA-INTENSITIES",
                " THE (N,GAMMA) CROSS-SECTIONS FOR CA-40,",
                " CA-42, CA-43, CA-44 COULD BE DERIVED."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                "    GAMMAS"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".DECAY SCHEME OF CA-41 AND A PARTIAL DECAY SCHEME OF",
                " CA-45 CONSTRUCTED, DETAILS GIVEN IN NUCL.PHYS.,",
                " A102(1967)226.",
                ".THE Q-VALUES FOR THE REACTIONS CA-40(N,GAMMA)CA-41",
                " AND CA-44(N,GAMMA)CA-45 WERE DETERMINED AS",
                " Q = 8363.4 +- 1.0 AND Q = 7418.1 +- 3.0 KEV,",
                " RESPECTIVELY."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
