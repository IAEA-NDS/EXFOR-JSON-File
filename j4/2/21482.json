              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".CORRECTED FOR THERMAL NEUTRON INDUCED FISSION IN",
                " PU-239 AND PU-241. FISSION PRODUCT SOURCE ACTIVITY",
                " CORRECTED FOR SELF ABSORPTION AND SELF SCATTERING."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".QUOTED VALUES ARE THE MEDIAN OF INDEPENDANT",
                " DETERMINATIONS, ERRORS ARE STANDARD DEVIATIONS",
                " CALCULATED FROM THE SPREAD OF MEASUREMENTS."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE INDEPENDANT FISSION YIELDS ARE CALCULATED BY",
                " THE METHOD OF GLENDENIN, ASSUMING THE EQUAL CHARGE",
                " DISPLACEMENT POSTULATE OF CHARGE DISTRIBUTION",
                " HOLDS FOR SPONTANEOUS FISSION.",
                ".TOTAL CHAIN YIELDS ARE THE SUMMATION OF INDEPENDANT",
                " DAUGHTER YIELDS AND THE OBSERVED YIELDS."
              ]
            }
          ],
