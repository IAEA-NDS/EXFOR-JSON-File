          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thermal cross-section was derived from the effective",
                " cross-section ( = (1.7 +- 0.1) * e-4 barn), using the",
                " following parameters which were experimentally",
                " determined,",
                " the spectral index r = (1.51 +- 0.08) * e-2,",
                " the Westcott value s = 5.31,",
                " and the correction factor for deviation from the 1/V",
                " law was set equal to 1."
              ]
            }
          ],
