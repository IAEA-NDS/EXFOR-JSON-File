          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THERMAL NEUTRONS. THE SAMPLE WAS IRRADIATED WITH A",
                " THERMAL NEUTRON FLUX OF 5.5E+14 NEUTRONS/CM2/SEC NEAR",
                " THE CORE OF THE REACTOR."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE METALLIC NICKEL POWDER TARGET, ENRICHED TO 97.5",
                " PERCENT IN NI-62, HAD A WEIGHT OF 784 MG. IT WAS",
                " IRRADIATED DURING A FULL BREEDING PERIOD OF 170 DAYS.",
                " AFTER THIS BREEDING TIME THE CONTENT OF NI-62 AND",
                " NI-63 WAS 681 AND 77 MG, RESPECTIVELY. FOR CALIBRATION",
                " PURPOSES 200 MG OF NACL WAS ADDED TO THE TARGET DURING",
                " THE LAST 7 DAYS OF IRRADIATION."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " THE SAMPLE WAS ACTIVATED IN THE THERMAL NEUTRON",
                " FLUX FOR 170 DAYS. MEASUREMENTS WERE PERFORMED AFTER",
                " ONE DAY DURING 30 HOURS, AND AFTER 170 DAYS FOR 175",
                " HOURS. AFTER THIS LONG TIME THE BUILD-UP OF NI-63 WAS",
                " SUFFICIENT TO MEASURE GAMMA-RAYS FROM NEUTRON CAPTURE",
                " IN THIS NUCLEUS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " IN THE MEASUREMENT AFTER ONE DAY OF IRRADIA-",
                " TION, THE GAMMA-RAYS IN THE ENERGY RANGE 0.1 - 2.5 MEV",
                " WERE DETECTED WITH AN INTRINSIC GE DETECTOR, HAVING",
                " 2.1 KEV RESOLUTION AT 1.33 MEV. THE 1.5 - 11.0 MEV",
                " GAMMA-RAYS WERE DETECTED WITH A GE PAIR SPECTROMETER",
                " HAVING AN ENERGY RESOLUTION OF 3.0 KEV AT 2 MEV AND",
                " 6.2 KEV AT 8 MEV.",
                ".THE SPECTRA AFTER 170 AND 177 DAYS OF IRRADIATION WERE",
                " TAKEN WITH THE PAIR SPECTROMETER ONLY, WHICH WAS",
                " OPERATED SIMULTANEOUSLY IN THE COMPTON SUPPRESSED AND",
                " PAIR SPECTROMETER MODES. IN THE COMPTON SUPPRESSED",
                " MODE THE ENERGY REGION 0.3 - 3.3 MEV WAS COVERED, AND",
                " THE ENERGY RESOLUTION WAS 2.1 KEV AT 1.33 MEV. WITH",
                " THE DETECTOR OPERATING IN PAIR SPECTROMETER MODE THE",
                " ENERGY RANGE 1.5 - 11.0 MEV WAS COVERED, AND THE RESO-",
                " LUTION WAS 2.2 KEV AT 2 MEV AND 4.9 KEV AT 8 MEV."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
