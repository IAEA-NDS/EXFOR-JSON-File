          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An extra calibration point at low energy was provided",
                "by the 455.490keV line following the decay of 137Xe.",
                "This decay reaches equilibrium with the neutron",
                "capture rate within a few minutes of irradiation. The",
                "intensities of the neutron capture lines could thus",
                "be normalized using the known intensity of 32%/decay",
                "for the 455.490 keV line."
              ]
            }
          ],
