          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Polarization of 0.3 to 1.4 MeV neutrons scattered",
                " by copper, zinc, molybdenum and cadmium"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
