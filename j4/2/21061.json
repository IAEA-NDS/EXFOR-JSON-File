              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutron emitted at 50 degrees from the",
                " reaction of protons on Li-7, collimated to scatter",
                " from rectangular samples"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": [
                "EN-RSL-FW"
              ],
              "free_text": [
                " energy spread about 40 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Rectangular samples, 1.9 cm by 3.2 cm by 7.5 cm.",
                " Natural metal samples."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 4 cm by 2.5 cm stilbene scintillators."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The sign of the polarization follows the Basel",
                " convention, magnitudes are calculated using the",
                " Li-7(p,n) polarizations from a fit to various",
                " experimental data shown as a curve in fig 2."
              ]
            }
          ],
