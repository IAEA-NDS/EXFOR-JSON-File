          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "THCOL"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutron beam IH1 collimated to 1 cm diameter.",
                " Thermal flux 5.E9 per cm2 per barn."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Pulse heights of coincident fragments and"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "   Time of flight difference between signals",
                "        recorded.",
                ".Pulse heights converted to kinetic energies and",
                " masses via an iterative procedure using the",
                " calibration method of schmidt+(C,65salzburg,1,531,65)",
                ".Time of flight data used as a coherence test to",
                " eliminate badly measured data."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " Two collinear 300 mm2 ortec",
                " surface barrier detectors 7 cm apart either",
                " side of fission target. Coincidence window of",
                " 20 nano-sec used."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Thermal reactor spectrum."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Samples manufactured by spraying Pu or U acetate",
                " onto a backing of 32 micro-g per cm2 polyimide",
                " coated with 21 micro-g Au per cm2.",
                ".Sample densities  2.3 micro-g Pu-241 per cm2 and",
