          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Fission neutron spectrum data were fitted to a",
                " maxwellian and to a watt-spectrum,giving a maxwellian",
                " temperature of 1.330 +- 0.009 MeV and watt parameters",
                " a=(1.077 +- 0.012) and B=(2.949 +- 0.146) using the",
                " watt distribution N(e)= K(exp(-ae)sinh(sqrt(be)))."
              ]
            }
          ],
