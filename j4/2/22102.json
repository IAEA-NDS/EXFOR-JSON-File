          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Tritium counting techniques.",
                " Tritium was separated from the irradiated samples",
                " by vacuum extraction and measured in the gas phase",
                " using anticoincidence proportional counting."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " A 31 mm diameter cylindrical gas-filled counter",
                " (FZ35) was used for absolute tritium activity measure-",
                " ments. The counter had an effective counting volume of",
                " 85 cm3 and a dead volume of 15 cm3. Low level counting",
                " was performed by placing the counter inside a ring",
                " type gas counting tube (RZ/500) housed within a lead",
                " shield. The two detectors were used in an anticoinci-",
                " dence mode."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Geli detector used for measurement of gamma-",
                " rays from the monitor foils."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections were applied for background neutrons from",
                " the target construction material and from the d-d",
                " breakup reaction. Corrections were also applied for",
                " tritium loss due to residual tritium in the sample."
              ]
            }
          ],
