          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The nitrogen samples consisted of between 9 and 15 g",
                "of degassed aluminium-nitride (ALN) powder (chemical",
                "purity greater than 98%, grain size less than 10 um)",
                "pressed in a polyethylene capsule, 24.5 mm diameter",
                "and up to 25.0 mm long. Lithium and boron impurities",
                "in the sample was determined with neutron activation",
                "analysis."
              ]
