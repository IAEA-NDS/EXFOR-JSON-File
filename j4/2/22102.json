          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons in the energy range 2.5 to 10.6 MeV were",
                " produced with a deuterium gas target, having an",
                " entrance havar foil of 7 um thickness.",
                " The gas cell had  a length of 3.7 cm and a diameter",
                " of 4.0 cm, with wall thicknesses of 0.1 cm, or a",
                " niobium entrance foil of 6.5, 20.0 or 50.0 um",
                " thickness and a molybdenum beam stop. The gas cell had",
                " a length of 3.7 cm and a diameter of 4.0 cm, with wall",
                " thicknesses of 0.1 cm made of brass.",
                " The mean neutron flux densities were of the",
                " order of 1.0E+07 n/cm2sec."
              ]
            }
          ],
