          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " THERMAL FLUX OF 1.76 10**14 N/CM2/SEC",
                " DETEMINED BY COBALT AND SILVER MONITORS."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE EQUIVALENT FISSION SPECTRUM FLUX WAS",
                " MEASURED USING THE FOLLOWING THRESHOLD REACTIONS..",
                " S-32(N,P),NI-58(N,P),FE-54(N,P),AL-27(N,A) AND",
                " NI-58(N,2N). THE RATIO OF THERMAL TO EPITHERMAL FLUXE",
                " WAS FOUND TO BE 23.7 . EQUIVALENT FISSION FLUXES",
                " DERIVED FROM MEASUREMENTS WITH THE FIVE THRESHOLD",
                " REACTION MONITORS VARIED BY 17 PERCENT, BUT WITHOUT",
                " ANY SYSTEMATIC TREND WITH THRESHOLD ENERGY."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".TWO SPEC PURE MN3 O4 SAMPLES OF 11.52 AND 12.20 GM",
                " WERE IRRADIATED IN A STANDARD GRAPHITE CONTAINER, 5.4",
                " CM HIGH AND 1.9 CM DIAMETER. ALL SAMPLES WERE PACKED",
                " IN QUARTZ TUBES AND IRRADIATED FOR 15 HOURS.",
                " THE MANGANESE CONTENT OF THE SAMPLES WAS DETERMINED BY",
                " POTENTIOMETRIC TITRATION IN A PYROPHOSPHATE SOLUTION",
                " AND BY PRECISION SPECTROPHOTOMETRY. THE MEAN VALUE WAS",
                " 71.3 PERCENT COMPARED WITH A THEORETICAL VALUE OF 72.0",
                " PERCENT."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " ACTIVATION. MEASUREMENT OF THE 303 DAY MN-54",
                " ACTIVITY."
              ]
            }
          ],
