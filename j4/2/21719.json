              "coded_information": null,
              "free_text": [
                "-THE AVERAGE CROSS SECTION OF THE MN-55(N,2N) REACTION",
                " IN A FISSION NEUTRON SPECTRUM -."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
