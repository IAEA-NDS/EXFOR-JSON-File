          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Polarization of 14 MeV neutrons in forward angle",
                " scattering by Cu and Pb"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2UK EDG"
              },
              "free_text": [
                " Van de Graaff accelerator providing a",
                " 350 keV deuteron beam."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The T(d,n)He-4 reaction using a water cooled",
                " T-Ti target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Two natural Cu and two natural Pb samples, the first",
                " scattering sample was 25 mm in diameter by 46 mm",
                " high and the second scattering sample 50 mm in diam.",
                " by 150 mm high, the second placed 92 cm from the",
                " first."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time-of-flight techniques.",
                ".As the T(d,n)He-4 reaction gives unpolarized neutrons",
                " the experiment was done as a double scattering expe-",
                " riment, where the first sample scattered the neutrons",
                " 20 degrees and the second sample scattered the neu-",
                " trons 20 or 34 degrees."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DSCAT"
              ],
              "free_text": [
                " scattering to 20 deg"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LRASY"
              ],
              "free_text": [
                " scattering to 20 or 34 deg"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Four NE213 liquid scintillators, efficiency",
                " calibrated with a Co-60 source and with an energy",
                " discrimination level of 10 MeV to reduce the in-",
                " fluence of inelastically scattered neutrons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Three plastic scintillators to monitor the",
                " neutron flux, one to measure the alpha particles",
                " in the neutron producing reaction, one to monitor",
                " the singly scattered collimated neutron beam, and",
                " one below the neutron producing target served to",
                " monitor the neutron yield directly from the target."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " .The measured data were compared with polarization",
                " values obtained from optical model calculations,",
                " using the computer program RAROMP."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For-",
                " - instrumental asymmetry due to differences in detec-",
                "  tor efficiencies,",
                " - background,",
                " - multiple scattering, using a Monte-Carlo program."
              ]
            }
          ],
          "FLAG": [
