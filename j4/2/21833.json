          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-MEASUREMENTS OF PROMPT NU-BAR AND VARIANCE FOR",
                " THE SPONTANEOUS FISSION OF CF-252 AND PU-242."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".OIL MODERATED ASSEMBLY OF BF3 COUNTERS."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".SPONTANEOUS FISSION EVENTS AND FISSION NEUTRONS",
                " WERE COUNTED OVER A PERIOD OF MONTHS."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " THE SPONTANEOUS FISSIONING SAMPLE WAS"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " INCORPORATED IN AN IONISATION CHAMBER",
                "        PLACED AT THE CENTRE OF A HIGH EFFICIENCY",
                "        NEUTRON DETECTOR CONSISTING OF 56 BF3",
                "        COUNTERS CONNECTED IN 5 RINGS AND",
                "        IMMERSED IN AN OIL MODERATOR."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".THE EFFICIENCY OF THE NEUTRON DETECTOR",
                " ASSEMBLY WAS DETERMINED USING AM-241/LI,",
                " /F,/B AND /BE SOURCES CALIBRATED AT THE",
                " MANGANESE BATH OF THE NATIONAL PHYSICAL",
                " LABORATORY, TEDDINGTON, ENGLAND."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                "    FISSION FRAGMENTS."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                "     NEUTRONS."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
              "coded_information": [
                "MISC"
              ],
              "free_text": [
                " THE VARIANCE OF THE PROMPT NEUTRON",
                "       MULTIPLICITY DISTRIBUTION."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".BACKGROUND AND DEAD TIME CORRECTIONS.",
                ".CHEMICAL IMPURITIES IN THE MANGANESE BATH",
                " USED TO CALIBRATE THE STANDARD SOURCES.",
                ".ABSORPTION OF NEUTRONS IN THE STRUCTURAL",
                " MATERIALS OF THE FISSION CHAMBERS. THESE",
                " CORRECTIONS TO THE BF3 COUNTER EFFICIENCY",
                " WERE COMPUTED USING THE MONTE CARLO CODE",
                " 'MONK',AND WERE FOUND TO BE -",
                "  (0.59 +/- 0.11) PER CENT FOR THE CF-252 CHAMBER",
                "  (1.01 +/- 0.14) PER CENT FOR THE PU-242 CHAMBER",
                ".VARIATION OF DETECTOR EFFICIENCY DURING THE",
                " EXPERIMENT. ( A PERIOD OF ABOUT 13 MONTHS )."
              ]
            }
          ],
