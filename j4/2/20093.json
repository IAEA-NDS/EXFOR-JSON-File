          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutron capture cross section and resonance",
                "capture integral of the lanthanide nuclei IV, 162Er,",
                "164Er, 168Er, and 170Er"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2NORKJL"
              },
              "free_text": [
                "    JEEP 2 Heavy Water Reactor."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "    Irradiated both in a thermal column (2 hours",
                " to 3 days) with a flux density of about",
                " 1.0E+10 neutrons/cm-sq/sec  and in the centre of the",
                " core with a flux density of about",
                " 2.0E+12 neutrons/cm-sq/sec."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Thermal, and neutrons with temperatures 400+-20 deg-K."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "                 Lanthanides as oxide powders",
                " in polyethylene ampoules or",
                "           solutions in quartz ampoules."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "    Activation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "           4PI-beta-gamma coincidence counter."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The results from the core irradiations were reduced to",
                " thermal values.",
                ".The result given is the average over all the",
                " measurements."
              ]
            }
          ],
