          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Backward angle np differential cross sections from",
                " 22 to 50 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2GERKFK"
              },
              "free_text": [
                " The Karlsruhe cyclotron and the",
                " polarized neutron facility POLKA. The beam was pulsed",
                " at a rate of 11 MHz."
              ]
            }
          ],
