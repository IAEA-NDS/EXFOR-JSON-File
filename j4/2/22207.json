          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLNS"
                ],
                "reaction": null
              },
              "free_text": [
                " Polarized neutron facility POLKA."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Continuous neutron spectrum, distributed from 20 to",
                " 50 MeV. The neutron flux was monitored by a set of",
                " proton recoil telescopes."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The sample was a 30 mg/cm2 polyethylene foil. The",
                " background was measured using a carbon target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The neutron energy bins were determined by TOF",
                " techniques."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The recoil protons were detected with delta-E-E",
                " detectors."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "NAICR"
              ],
              "free_text": [
                " The np scattering took place at the",
                " center of an evacuated 80 cm diameter scattering cham-",
                " ber, placed at about 6 m from the neutron source. The",
                " collimated 20 mm diameter neutron beam entered and",
                " left the chamber through 25 micrometer thick stainless",
                " steel windows. The recoil protons were detected with 5",
                " delta-E-E telescopes at various angles. The 12 mm by",
                " 42 mm delta-E detectors, 500 micrometers thick, were",
                " of the passivated ion implanted silicon type. The E",
                " detectors were 2.5 cm thick NaI crystals. The protons",
                " were measured in the lab angle range 7.5 to 52.5 deg."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "P"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The measured relative np scattering cross sections",
                " were normalized by an iterative procedure, involving",
                " phase-shift analyses and predictions from the Paris",
                " potential."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".The data were corrected for cyclotron phase instabili-",
                " ties, gain changes in the electronics and various",
                " background effects."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total  errors given include uncertainties",
                " from the corrections, systematic differences of the",
                " detectors and statistical uncertainties, which are",
                " dominating."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " In addition, there is a 1% normalization",
                "  uncertainty for the absolute cross section scale."
              ]
            }
          ],
          "CRITIQUE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Manfred Drosg (2014-12-03): The measurements of all",
                "energies were done at the same angle (white spectrum)",
                "and the center-of-mass angles are the same for all",
                "energies. This is not possible at these energies, in",
                "particular for this light target nucleus."
              ]
            }
          ],
