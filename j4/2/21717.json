          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Two irradiation positions at a reactor power",
                " of 15 kW. Thermal and epithermal neutron fluxes at",
                " both positions was monitored with Co and Au flux",
                " monitors."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Samples contained 1 milligram of spectroscopically",
                " pure In2-O3 mixed with one gram of spec. pure Al2-O3.",
                " Samples were irradiated with and without a 0.75 mm",
                " cadmium foil. After dissolution of In2-O3in HCl and",
                " filtering Al2-O3, gamma counting was started one week",
                " after irradiation to allow decay of the 54 min In-116",
                " and 15 hr Na-24 activities, the latter formed by the",
                " (N,A) reaction on Al-27."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Triple comparator method with analysis of the",
                " K ratios of the three elements irradiated for",
                " correction for each thermal to epithermal ratio.",
                " After irradiation each element was dissolved and",
                " gamma activity measured in 20 ml glass tubes in a well",
                " type NaI(Tl) scintillation counter."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Well type NaI(Tl) scintillation counter with",
                " efficiency determined by the liquid scintillator",
                " method."
              ]
            }
          ],
          "MONIT-REF": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
