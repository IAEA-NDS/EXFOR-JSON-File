          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA",
                "BCINT"
              ],
              "free_text": [
                "",
                "The data were obtained mainly by measuring in-beam",
                " singles gamma-ray spectra, as well as spectra prompt",
                " and delayed with respect to the beam Bursts.",
                "Additionally, long-lived residual activities of the",
                " targets were counted also off line but not specified.",
                "Specifications of the used gamma-rays or decay-data",
                " are missing for all cases."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                " Any Information about the used gamma transitions",
                " is missing."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The yields for a particular product nucleus were",
                " obtained by summing the intensities of transitions",
                " feeding the ground-state or a low-lying isomeric",
                " level.",
                "Product nuclei were identified by the presence of",
                " at least three known gamma-ray transitions and by",
                " the relative intensities of these transitions."
              ]
            }
          ],
