          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Oxide of Isotopically Enriched Fe-54. No Further",
                "Information is Given."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Cross Section Given was Determined by Comparing",
                "The Activity of Co-55 with That of Mn-51 Produced by",
                "The Reaction Fe-54(P,A). Due to the Content of Fe-56",
                "In the Target, this Measurement was Possible Only",
                "Below 15 MeV, the Threshold of the Fe-56(P,2N)Co-55",
                "Reaction. Absolute Cross Sections For Mn-51",
                "Were Obtained by Bombarding Stacks of Natural Fe-Foils",
                "And Comparing Mn-51 Activities at Low Energies with",
                "Co-55 Activities at High Energies Where the Cross",
                "Sections For Fe-56(P,2N)Co-55 are Known and the",
                "Contribution from Fe-54(P,G)Co-55 is Negligible."
              ]
            }
          ],
