                  }
                }
              },
              "free_text": [
                " Cross section for",
                "cumulative production of Na-24."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
