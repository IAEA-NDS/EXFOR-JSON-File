          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of neon-24 and sodium-24 in the 1-3 GeV",
                "proton bombardment of copper, silver, gold, and",
                "uranium targets"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Hudis"
