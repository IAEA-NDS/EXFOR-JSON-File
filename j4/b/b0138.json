          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Due to the Large Range of the High-Energy Positrons",
                "The Determination of the Effective Solid Angle was",
                "Difficult. Thus, the Absolute Cross Sections are",
                "Assumed by the Authors to be Less Precise Than the",
                "Relative Ones."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "To Avoid Activities Created by Activation of Very",
                "Small Contaminations (ABOUT 1%% EACH) Of Al, Si and  Ca",
                "Present in the Target, Only Those Sections of the B+",
                "Spectrum were Analysed, Where the Product Nuclei were",
                "Strongly Dominating."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                "",
                "Three New Mirror Nuclei, Cr-47, Fe-51, Ni-55 have Been",
                "Identified in (HE-3,2N) Reactions. Half-Lives, Log-Ft",
                "Values and Gamow-Teller Matrix Elements For the Mirror",
                "Beta-Decays were Deduced.",
                "For Cr-47, However, No Cross Sections were Published."
              ]
            }
          ],
