            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR,117,1532,1960",
                "code_unit": [
                  {
                    "unit": "J,PR,117,1532,1960",
                    "doi": "10.1103/PhysRev.117.1532",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR",
                        "number": null,
                        "volume": "117",
                        "part": null,
                        "issue": null,
