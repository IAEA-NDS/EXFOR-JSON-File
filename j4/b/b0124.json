          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Total Errors in the Cross Sections Range Between",
                "10 and 15%.  They were Obtained by Summing Up in",
                "Quadrature the Following Individual Errors, As Given in",
                "An Earlier Paper of the Authors - Error in Foil",
                "Thickness (2%), Fluctuations, Spread and Basic",
                "Uncertainty of the Degraded Beam Energy (5%), Beam",
                "Current Determination (5%), Angular Straggling in the",
                "Thick Stack (1%), and Statistical and Spectrum Analysis",
                "Error (VARYING).  The Relative Photopeak Detection",
                "Efficiency of the Detector was Known Within an Error of",
                "+-3% and was Based on Standard Sources Calibrated to",
                "+-1%."
              ]
            }
          ],
