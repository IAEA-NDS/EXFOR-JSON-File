            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation Functions For the Formation of Neutron",
                "Deficient Isotopes of Bromine and Krypton Via",
                "High-Energy Deuteron Induced Reactions on Bromine.",
                "Production of Br-77, Br-76 and Kr-79"
              ]
            }
