            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA",
                "BCINT"
              ],
              "free_text": [
                "",
                "Absolute Differential Cross Sections were Measured",
                "At Angles from 10 to 150 Degrees in the Laboratory",
                "System in Steps of 10 Degrees.",
                "The Solid Angles of the Detectors were Determined",
                "By Both the Detector Geometry and Counting a Standard",
                "Alpha-Source."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD"
              ],
              "free_text": [
                "",
                "The Angular Distributions were Fitted with Legendre",
                "Polynomials by the Method of Least Squares. The Total",
                "Cross Section was Extracted from the Zero Order",
                "Coefficients of these Fits."
              ]
            }
          ],
