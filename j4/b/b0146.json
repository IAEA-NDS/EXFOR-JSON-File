          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute Cross Sections are Determined by Normalizing",
                "The (2P) Cross Section Determined by the 862 KeV Yield,",
                "See Subent 146.005, at 44 MeV to the Corresponding",
                "Activation  Cross Section Measured by R.L.Robinson,",
                "Phys.Rev.C9,1402,1974. The Normalizing Constant",
                "Determined from this has Been Used For All Given",
                "Cross Sections. It was Assumed That the Ground-State",
                "Cross Section Relative to the Total Cross Section in a",
                "Channel Remains Constant Over the Region of Bombarding",
                "Energy."
              ]
            }
