          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Electrochemically purified Mn (25 mg/cm2 thick) on",
                " thin Al (4.5 mg/cm2 thick, 99.99% purity).",
                "Another Al foil was placed on the face of the target",
                " to collect recoils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
