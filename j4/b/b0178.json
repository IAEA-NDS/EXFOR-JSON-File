              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " Initial 3He energy at 40 MeV, 1.0-1.5 uA."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "EDEG"
              ],
              "free_text": [
                " 12 to 15 target-catcher pairs were",
                " inserted. Range-energy data of Williamson et al.",
                " (1966) was used to evaluate the incident energy at",
                "  each foil."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Monitored by Faraday cup connected to a",
                " current integrator."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for 30 to 60 min"
              ]
            },
