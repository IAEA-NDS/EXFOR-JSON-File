              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The Quoted errors represent only the",
                "statistical uncertainties, arising from peak-area",
                "determination, fitting procedure, counter efficiencies,",
                "target  weighing and  Na-24 Decay-Data.  Not Included",
                "are systematic errors, e.g.  from determination of  the",
                "beam intensity, estimated to be about 1%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The Errors in the Determination of the",
                "absolute value of the beam energy, estimated to be",
                "about 0.5% at all Energies.  The energy spread of the",
                "degraded beam decreases from about 2 MeV at 50 MeV of",
                "incident energy to about 0.5 MeV at 100 MeV."
              ]
            }
          ],
          "ADD-RES": [
