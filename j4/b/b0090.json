          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Iodine-123 Production For Radiopharmaceuticals",
                "Excitation Functions of the Te-124(P,2N)I-123 and",
                "Te-124(P,N)I-124 Reactions and the Effect of Target",
                "Enrichment on Radionuclidic Purity"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.KONDO",
                "R.M.LAMBRECHT",
