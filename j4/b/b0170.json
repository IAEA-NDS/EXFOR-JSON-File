          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Carbon, Thickness 228 +- 16 Microgram/Cm**2.",
                "The Thickness was Determined by Weighing. The",
                "Uniformity was Found to be Typically +- 5%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SOLST",
                "SOLST"
              ],
              "free_text": [
                "",
                "Two Detector Telescopes were Used. The Thicknesses of",
                "The Delta-E Detector and the E-Detector were",
                "50 Micrometer and 2 mm, Respectively.",
                "In a Later Experiment a 3-Element Telescope was Used",
                " (8.4 AND 36 MICROMETER, AND 1 MM)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA",
                "EDE",
                "BCINT"
              ],
              "free_text": [
                "",
                "Reaction Products were Recorded Simultaneously at Two",
                "Angles by Two Independent Semiconductor Telescopes."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD",
                "INTED"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Error of the Absolute Differential Cross Sections",
                "Is +- 10 % Arising from Uncertainties in the Target",
                "Thickness, the Beam Current Integration and Detector",
                "Solid Angle."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "ANGD",
                "COMP",
                "THEO"
              ],
              "free_text": [
                "",
                "Statistical Model Calculations are Compared with the",
                "Experimental Data in Order to Determine the Reaction",
                "Mechanism For the Particle Production.",
                "The Most Likely Production Mechanism For Li and be at",
                "Higher Incident Energies Seems to be the Decay of a",
                "Projectile-Like Fragment Excited in a Peripheral",
                "Collision."
              ]
            }
          ],
