          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Au-197 foils, thickness 250 micrometer. Significant",
                "impurities were 30 ppm Si, 10 ppm Fe and 100 ppm Ag."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The given cross sections represent a weighted average",
                "of two or three determinations at each energy."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The given errors are the larger of the",
                "standard deviation and the estimated uncertainty of the",
                "individual determinations.  Included is an 50%",
                "uncertainty of the corrections to the cross sections",
                "due to target impurities.  Further INFORMATIONS about",
                "the errors are missing."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "MONIT-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ". Any information is absent."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The contribution to the measured cross section",
                "from light element impurities was taken into account,",
                "and  found to decrease from approximately 8% at 200 MeV",
                "to 0.6% at 400 MeV.  The only important contributing",
                "impurity was Si."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions for the formation of Na-24",
                "from Au-197 for incident positive and negative PIONS."
              ]
            }
