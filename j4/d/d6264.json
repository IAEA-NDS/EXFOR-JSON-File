          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "206Pb isotopically enriched (>99%) target of",
                "thickness 250 ug/cm2 which was evaporated on 12C foil",
                "of thickness 30 ug/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " Three silicon surface barrier",
                "detector telescopes were used for detection of",
                "reaction products in dE - E configuration mounted on",
                "two movable arms inside the 1.5 diameter. Thickness",
                "of dE detectors was ~40 um while E detectors were",
                "about 1 mm thick."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two monitor detectors, each consisting of a",
                "single SSB of thickness 1 mm, were fixed at the",
                "foward angle +- 20 degree with respect to the beam",
                "direction and at 75 cm far from the target for",
                "absolute normalization of cross sections. The angular",
                "resolution of the telescopes were less than 1.5 degree."
              ]
            }
          ],
