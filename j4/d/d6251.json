          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In the first experiment, the stack was irradiated by",
                "using a 39.5-MeV alpha beam, 120 nA beam current",
                "collimated to 10 mm in diameter in the external beam",
                "line of the VECC, Kolkata, India. In the second",
                "experiment, the beam energy and diameter were exactly",
                "the same; however, the beam current was 60 nA."
              ]
            }
          ],
