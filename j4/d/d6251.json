          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " In the first experiment, the stack",
                "was composed of 8 sets of Nb-Cu foils followed by one",
                "set of Nb-Nb-Nb foils was irradiated for 45 minutes.",
                "In the 2nd experiment, the foil sequence was exactly",
                "the same except for the addition of a 25",
                "micrometer thick Al foil that was positioned in the",
                "front of the stack and the removal of one of the",
                "three Nb foils at the end, which was irradiated for",
                "90 minutes."
              ]
            },
            {
              "pointer": "",
