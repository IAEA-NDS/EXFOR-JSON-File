          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Titanium-tritium and a pure Ti target. It",
                "was a Ti film 4.9 mg/cm2 in thickness, saturated by",
                "tritium to an activity of 7.57 Cu. The equivalent",
                "thickness of tritium in the titanium matrix was",
                "0.30+-0.04 mg/cm2."
              ]
            }
          ],
