          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beams of 11Li and 14Be were produced in fragmentation",
                " reactions with 18O beams (308 MeV/u and 360 MeV/u)",
                "from the heavy-ion synchrotron SIS. The production",
                "target consisted  of natural beryllium. The secondary",
                "11Li and 14Be beams,  with energies of 280 MeV/u and",
                "304 MeV/u, respectively.",
                "The beam intensities on the proton target were",
                "50 ion/s and 40 ion/s for 11Li and 14Be, respectively."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A liquid-hydrogen target placed in front of  the",
                "ALADIN-LAND setup. The liquid-hydrogen was kept  in a",
                "cylindrical container (28 mm in diameter and 50 mm",
                "long) with thin Mylar windows inside a vacuum",
                "chamber. The effective target thickness was 350 mg/cm2.",
                "Background measurements were performed with",
                "an empty container."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "LONGC"
              ],
              "free_text": [
                " large-gap dipole magnet spectrometer",
                "ALADIN and the large area  neutron detector LAND"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The nuclear charge of the fragments was obtained from",
                "the  energy losses, dE, in silicon pin-diodes, placed",
                "directly after the  target, and in organic",
                "scintillators in a time-of-flight wall (TOFW)  which",
                "was placed 5.29 m downstream from the center of the",
                "ALADIN  magnet. The masses of the fragments were then",
                "determined  through their magnetic rigidity in",
                "ALADIN."
              ]
            }
          ],
