          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Study of the excitation functions for 43K, 43,44,44mSc",
                "and 44Ti by proton irradiation on 45Sc up to 37 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
