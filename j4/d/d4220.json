          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC",
                "STTA"
              ],
              "free_text": [
                "The cross-sections were measured by",
                "using the activation method and the standard stacked",
                "foil irradiation technique combined with",
                "high-resolution gamma-ray spectroscopy. The Pd and",
                "Cd target foils with Al and Cu monitor foils were",
                "stacked and irradiated with protons at Ep=70MeV,",
                "Ip=140nA for 6 min. The Rh target foils and Al",
                "monitor foils were stacked and irradiated with",
                "deuterons Ed=40, Id=24nA for 30 min."
              ]
            }
          ],
