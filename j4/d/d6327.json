          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 51V (pure 99.97%) target of thickness ~ 250 ug/cm2",
                "evaporated onto an Al support of thickness ~ 200 ug/cm2",
                "was used.",
                "The thickness of Al-catcher foil ranges from 100 to",
                "150 ug/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-ray activities induced in each Al-",
                "catcher foil were recorded by 60 cc HPGe detector",
                "coupled to a PC based data acquisition system.",
                "The resolution of the HPGe detector was found to be",
                "1.9 keV for 1.33 MeV gamma-ray from the 60Co source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The beam was collimated to a spot of diameter",
                "8 mm and the stack was irradiated with beam current",
                "varying between 15 to 20 nA for ~11 hours."
              ]
            }
          ],
