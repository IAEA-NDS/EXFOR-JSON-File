          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Carbon targets were prepared by electron beam",
                "evaporation of graphite onto 0.5mm thick tantalum",
                "backings. Target thicknesses were measured with Nuclear",
                "Resonant Reaction Analysis (NRRA) utilizing the narrow",
                "resonance in the 13C(p,g)14N reaction at",
                "Ep=1747.6+-0.9 keV. Thickness of 1.03E+18 and 1.52E+18",
                "atoms/cm2 were obtained."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "",
                "Proton stopping power in carbon was taken from the",
                "SRIM code.",
                "The maximum collected proton beam charge on one target",
                "was about 0.2C."
              ]
            }
          ],
