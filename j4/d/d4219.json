          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "54-XE-131",
                "field_identifier": "ENR",
                "value": 0.996
              },
              "free_text": [
                "",
                "Highly enriched 131Xe gas up to a pressure of 0.9 bar"
              ]
            }
          ],
          "DETECTOR": [
