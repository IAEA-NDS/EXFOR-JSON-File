          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Selenium targets were prepared by evaporation.",
                "The isotopic enrichments of the material used were",
                "86%, 98%, 94% and 97% for the 76Se, 78Se, 80Se and",
                "82Se isotopes, respectively. In order to prevent",
                "sublimation of selenium under beam bombardment,",
                "targets were coated on both sides with carbon films",
                "aproximately 20. mu-m/cm2 thick. The thickness of",
                "selenium was about 1.2 mg/cm2."
              ]
            }
          ],
