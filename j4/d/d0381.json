          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The data were obtained from a standard spectrum of",
                "Si3N4 using 2.0 MeV deuterons by comparison with a",
                "simulated spectrum corresponding to a uniform",
                "cross-section.",
                "The cross-section extracted only gives a rough guide",
                "to the shape over the energy range because, by the",
                "nature of the analysis, the energy resolution is not",
                "sufficient to reproduce resonance structure."
              ]
            }
          ],
