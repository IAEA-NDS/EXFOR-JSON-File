          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Pd/TiTx/Al sample was prepared by a conventional",
                "hydrogenation method, using however an apparatus",
                "which enables tritium gas to be handled. A uniform",
                "Ti film of 2.44x10**17 atoms/cm2 was first sputtered",
                "onto a 3mm Al foil, and then a Pd overlayer of",
                "4.4x10**16 atoms/cm2 was deposited onto the Ti film."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The Au/Si surface barrier detector was",
                "placed at the laboratory backward angle of 165.",
                "degr., set by a defining slit of 3x4 mm."
              ]
            }
          ],
