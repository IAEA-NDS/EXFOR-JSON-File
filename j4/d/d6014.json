          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "84% enriched 29Si target (SiO2 deposited on a",
                "250 mu-m tantalum backing)was used."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measurements described in text gave about 5 keV as",
                "total target thickness for 3.5 MeV a particles and",
                "6.29 x 10**16 atoms of 29Si per cm2 of the target.",
                "From this the absolute total cross sections were",
                "obtained, which agree well with reported measurements",
                "of Glbbons and Macklin (Phys.Rev.,114,571,1959)"
              ]
            }
          ],
          "DETECTOR": [
            {
