          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target was of natural isotopic composition, i.e.",
                "79% 24Mg, 10% 25Mg and 11 % 26Mg.  The contribution to",
                "the peak width at half maximum from straggling in the",
                "0.329 g/cm2 thick Mg target was approximately 360 KeV.",
                "The targets were fixed on the axis of rotation of",
                "the spectrometer."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " The polarimeter is used in detection.",
                "Left and right scattering from the 5 g/cm2 thick carbon",
                "scatterer was detected in double coincidence telescopes",
                "divided into an inner and an outer angular channel and",
                "consisting of the scintillators.",
                "The scattered protons were analysed in energy by the",
                "magnetic spectrometer.",
                "The beam was monitored by a scintillator telescope",
                "directed towards the target."
              ]
            }
          ],
