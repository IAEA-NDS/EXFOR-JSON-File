          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Evaluated activation cross sections of longer-lived",
                " radionuclides  produced by deuteron induced reactions",
                " on natural iron up to 10 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "B.Kiraly",
                "S.Takacs",
                "F.Ditroi",
