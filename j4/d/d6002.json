          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Threshold Anomaly in 12C+209Bi Scattering"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.SANTRA",
                "P.SINGH",
                "S.KAILAS",
                "A.CHATTERJEE",
                "A.NAVIN",
                "A.SHRIVASTAVA",
                "A.M.SAMANT",
                "K.MAHATA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- By Authors    :Abstract",
                "Elastic, inelastic, and transfer angular distributions",
                "measured for the system 12+209Bi at ten energies",
                "between 58.9 to 87.4 MeV. The CRC calculations,",
                "including inelastic and transfer channels, reproduce",
                "simultaneously the elastic, inelastic, and transfer",
                "angular distributions measured at 61.9, 63.9, and 87.4",
                "MeV. Comparison of threshold anomaly results for 4He,",
                "11B, 16O+209Bi systems along with the present case",
                "indicates that the degree of anomaly inreases with the",
                "projectile mass."
              ]
            }
          ],
