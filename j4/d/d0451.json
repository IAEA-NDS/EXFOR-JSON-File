            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The NaCl(> 99%, Merck) target discs had thicknesses of",
                "nominally 870, 540 and 425 mg/cm2, respectively, in",
                "the 200, 100 and 66 MeV stacks. The individual NaCl",
                "discs were separated by relatively thin monitor foils",
                " (99.9%, Goodfellow, U.K.): 65 mg/cm2 Al in the 200",
                "and 100 MeV stacks and 44 mg/cm2 Cu in the 66 MeV",
                "stack."
              ]
            }
