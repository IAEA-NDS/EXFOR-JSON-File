              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH",
                "CSICR",
                "SI"
              ],
              "free_text": [
                " Fission fragments were detected using",
                " position sensitive gridded gas ionization chamber",
                " consisting of Delta-E-gas and E-gas elements.",
                "Its solid angle is ~97 msr with an angular opening of",
                " ~30 deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CSICR",
                "SI"
              ],
              "free_text": [
                " Alpha particles were detected by three",
                " collimated CsI(Tl)-Si(PIN) detectors placed at",
                " angles (ANG1) of 75 deg, 100 deg and 135 deg with",
                " respect to the beam direction.",
                "Each of these detectors had a solid angle of ~18 msr",
                " and angular opening of +/- 3.5 deg."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 30 degree opening of the fission detector is",
                " divided into 4 equal parts during the off-line data",
                " analysis.",
                "Thus a total of 12 combinations of alpha particle",
                " spectra, each having different relative angles with",
                " respect to the fission fragments theta(alpha-fis.frag)",
                " and the beam theta(alpha) are obtained.",
                "After correcting for random coincidence, the",
                " normalized alpha particle multiplicity spectra are",
                " obtained by dividing the coincidence spectra by the",
                " total number of fission single events."
              ]
            }
          ],
