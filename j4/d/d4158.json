          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity 99.9% 10 microns thick Co metallic foils.",
                "High purity 99.9% 12.5 microns thick Ti metallic foils",
                "and Cu foils for beam monitoring."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Stacked targets containing Co target and Ti foils for",
                "monitoring. Irradiation was done in Faraday-cup target",
                "holder with 26 MeV He-3 beam at ATOMKI MGC 20E",
                "cyclotron. two stack were irradiated for 1 hour with",
                "100 nA beam.",
                "HPGe detector was used.",
                "Nuclear data were taken from NUDAT.",
                "Stopping and energy degradation were calculated using",
                "the Andersen-Ziegler polynomial approximation."
              ]
            }
          ],
