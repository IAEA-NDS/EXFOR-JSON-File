          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets for (a,a) scattering experiments were",
                "produced by evaporation of metallic natural",
                "In (95 ug/cm2) onto thin carbon foil (~40 microg/cm2)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " for (a,a) scattering measurements",
                "7 ion-implanted silicon detectors with active",
                "areas of 50 mm2 and 500 microm thickness were used to",
                "measure the angular distributions on two independently",
                "rotated turntables."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA",
                "EXTB"
              ],
              "free_text": [
                "",
                "The energy of the alpha beam provided by the cyclotron",
                "accelerator of ATOMKI was Elab=16.15 and 19.50 MeV.",
                "Complete angular distributions between 20 and 175",
                "degrees were measured.",
                "The energy of the scattered alpha particles were",
                "monitored by two detectors at +-15 degree."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The count rates have been normalized to the",
                "yield of the monitor detectors at 15 degree.",
                "The relative measurement eliminates the typical",
                "uncertainties of absolute measurements, coming mainly",
                "from changes in the absolute target thickness and from",
                "the beam current integration. Total uncertainty was",
                "between 4% and 5%."
              ]
            }
          ],
