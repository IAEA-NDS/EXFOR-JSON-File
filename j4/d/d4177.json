          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Te targets prepared with electrolytic",
                "deposition onto 22-28 micron Ti backings. Typical",
                "thickness of Te layer: around 10 micron."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Three stacks were irradiated.",
                "The energies of the proton beams: 18, 14.5 and 8 MeV,",
                "the beam intensity: 200-300 nA,",
                "the irradiation times: 1-1.5 h.",
                "Faraday-cup type target holder was used.",
                "Nondestructive measurement without chemical separation.",
                "Stopping and energy degradation were calculated using",
                "the Andersen-Ziegler polynomial approximation."
              ]
            }
          ],
