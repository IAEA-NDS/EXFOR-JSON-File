          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Effect of Li6 + Li6 reactions in a fusion reactor",
                "Operating on Li-6(p,a)He-3."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
