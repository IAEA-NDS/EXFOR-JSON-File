          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting ~99 % enriched 64Ni foil of thickness",
                "507 +/- 10 ug/cm2.",
                "The beam current during the experiment was maintained",
                "in the range of 1 to 7 pnA."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " The outgoing backscattered",
                "particles were detected using two deltaE-E telescopes",
                "with silicon surface barrier detectors placed at",
                " +/- 170 degree with respect to the beam direction.",
                "Both the telescopes had 15-um-thick deltaE detectors",
                "which were followed by 300-um and 1-mm-thick E",
                "detectors, respectively.",
                "The solid angle subtended by each telescope at the",
                "target center was estimated to be around 1.22 msr."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two single surface barrier detectors of",
                "thickness 500 um and 3 mm, respectively, were",
                "positioned at +/- 20 degree about the beam axis to",
                "monitor the beam position during experiment."
              ]
            }
          ],
