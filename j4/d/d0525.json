          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "144Sm-alpha optical potential at astrophysically",
                " relevant energies derived from 144Sm(a,a)144Sm",
                " elastic scattering"
              ]
            }
          ],
