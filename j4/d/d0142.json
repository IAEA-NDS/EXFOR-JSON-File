          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples were made from spectroscopic iridium having",
                "purity better than 99.99% by the vacuum evaporation",
                "technique. The target foils were squares of side,",
                "1.5 cm, and of the thickness, 150 mu-g/cm2. The foils",
                "were fixed on aluminium sheets having a circular hole",
                "with a diameter of 1.2 cm in its center. The aluminium",
                "degraders of the different thickness were also inserted",
                "in the target stack so that the alpha beam of 55 MeV",
                "energy might be degraded considerably."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
