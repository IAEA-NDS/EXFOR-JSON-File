          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New measurement of cross sections of evaporation",
                " residues from the natPr + 12C reaction: A comparative",
                "study on the production of 149Tb"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Moumita Maiti"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3INDSAH"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,84,(4),044615,2011",
                "code_unit": [
                  {
                    "unit": "J,PR/C,84,(4),044615,2011",
                    "doi": "10.1103/PhysRevC.84.044615",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "84",
                        "part": null,
                        "issue": "4",
                        "page": "044615"
                      },
                      "date": 2011
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " BARC-TIFR Pelletron Accelerator facility"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nonhygroscopic praseodymium oxide, Pr(6)O(11), was used",
                " as the target material.",
                "Targets of 2.5-3.0 mg/cm2 thickness were prepared by",
                " centrifugation technique on Al foil backing",
                " 1.5 mg/cm2 thick was used.",
                "The target assembly was prepared by placing three such",
                " Pr(6)O(11) targets each time and was bombarded with",
                " 12C beams."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " resolution of 2.13 keV at 1332 keV"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " A total of six target stacks were irradiated",
                " separately, varying the incident energy, with an",
                " overlap between them."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Integrated charge recorded for each",
                " irradiation by an electron-suppressed Faraday cup"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " At the end of bombardment (EOB), an off-line",
                " gamma spectrometric study was carried out in each foil",
                " at a regular time interval up to 7 days"
              ]
            }
          ],
          "ERR-ANALYS": [
