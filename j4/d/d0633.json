              "free_text": [
                "The total uncertainties in the measured cross",
                "sections were obtained by summing all the contributing",
                "uncertainties in quadrature:",
                "  * the uncertainty due to counting statistics and",
                "    photo-peak integration"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The systematic uncertainty is estimated to",
                "          be 7%, including:",
                "  * the uncertainty in beam current integration (3-5%),",
                "  * target thickness (1-2%),",
                "  * statistical error on the net peak counts (1-5%),",
                "  * calibration source uncertainties (between 2% and",
                "       3%) and",
                "  * fitting of the detector efficiency curves (<1%)"
              ]
            },
