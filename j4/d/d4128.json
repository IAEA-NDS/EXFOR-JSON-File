          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target was high purity natural N2 gas filled in gas",
                " cells at pressure of 2 bars.",
                "Also solid boron nitride BN samples 0.2 mm thick were",
                " prepared.",
                "Al foils 50-700 micron thick were used as energy",
                " degrader."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Individual gas cells and several gas cells stacked",
                " together were irradiated with 30-170 nA beam at 12,",
                " 16 and 20 MeV for 3 minutes.",
                "Additionaly six BN samples were irradiated with the",
                " same beam parameters.",
                "The beam current was measured in Faraday cup and was",
                " also monitored with Cu foils.",
                "Decay was followed for several half life to identify",
                " the produced radioisotopes.",
                "The energy degradation was calculated by the method of",
                " Williamson (1966)."
              ]
            }
          ],
