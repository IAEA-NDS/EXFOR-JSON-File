          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting 169Tm target foil of thickness",
                " ~900 ug/cm2 prepared by rolling technique.",
                "An Al catcher foil of sufficient thickness was placed",
                " behind the target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Two pre-calibrated HPGe detectors were coupled",
                " to a computer aided system and CAMAC based",
                " acquisition system to measure the gamma-ray",
                " activities.",
                "The resolution of detector was ~1.8 keV at 1332 keV",
                " gamma-ray of the 60Co source.",
                "The deadtime of the detector was kept to less than 10%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " The target facing the beam, and",
                " irradiated for time span of ~6-8 hours depends upon",
                " the half-lives with the beam current at 25-34 nA."
              ]
            }
          ],
