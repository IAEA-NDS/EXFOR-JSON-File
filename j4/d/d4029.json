          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "EXTB",
                "GSPEC",
                "BCINT",
                "EDEG"
              ],
              "free_text": [
                " only one cell was",
                "irradiated at a time one or several Cu foils were",
                "place in front and one Cu foil placed at the back of",
                "each cell to monitor the beam and to degrade the",
                "energy. The primary incident proton energies were 45,",
                "30,3, 24, 22.5 and 20 MeV. The cells were irradiated",
                "for 5min at 200 nAmp beam current. The beam intensity",
                "was measured by using Faraday-cup as well as monitor",
                "reactions. The radiocesium was separated for a few",
                "cells filled with 20% enriched Xe-124. The radioiodine",
                "was separated for a few cells filled with 99.9%",
                "enriched Xe-124."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy degradation was calculated according",
                "to C.F. Williamson et al.(see REL-REF). To calculate",
                "the independent formation cross section of Xe-123 the",
                "contribution from the decay of Cs-123 was taken into",
                "account."
              ]
            }
          ],
