          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "99.9% Enriched Xe-124 and 20% enriched Xe-124 gas. Gas",
                "cells (2.cm diam. and 2.5 cm length) having 200 microns",
                "of Al windows were used as targets. In the case of",
                "99.9% enriched Xe-124 5 target cells were filled",
                "simultaneously up to 0.48 bar. In the case of 20%",
                "enrichment the irradiated gas was transferred into an",
                "evacuated gas container via cryogenic technics."
              ]
            }
          ],
