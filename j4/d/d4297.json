          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High precision 113In(a,a)113In elastic scattering at",
                "energies near the Coulomb barrier for the",
                "astrophysical gamma-process"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
