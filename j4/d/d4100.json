              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                " used.",
                "Stacks containing 16 Mo foils were irradiated with 10,",
