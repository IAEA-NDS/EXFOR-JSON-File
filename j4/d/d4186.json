          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Application of Au + p nuclear reactions for proton",
                "beam monitoring up to 70MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
