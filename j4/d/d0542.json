          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 1.9 mg/cm2 CH2 target was rotated to an angle of",
                "34.degr. with respect to the beam direction, thus",
                "providing an effective in beam target thickness of",
                "4.6 mg/cm2, while limiting the energy loss and",
                "angular straggling of low energy protons recoiling",
                "towards the detectors."
              ]
            }
          ],
