          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "CSICR"
              ],
              "free_text": [
                " A group of 5 telescopes, 5 x 5 cm",
                "active area, consisting of a 300 mu-m thick Si strip",
                "detector followed by a second 300 mu-m or 500 mu-m",
                "thick Si detector and a 1 cm thick stopping CsI,",
                "were positioned 29 cm from the target to measure",
                "recoiling protons."
              ]
            }
          ],
