          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was a foil of 28Si (approx. 800. mu-g/cm2)",
                "supported by a thin film (approx.150 mu-g/cm2) of",
                "carbon."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3INDVEC"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA"
              ],
              "free_text": [
                "",
                "The numer of incident alpa-particles was normalized",
                "through measurement of the integrated charge collected",
                "on a Faraday cup fixed at the rear end of the chamber."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Six silicon surface barrier detectors of",
                "different thicknesses ranging from 1000 to 2000 mu-m",
                "were placed on two movable arms on either side of the",
                "beam direction. The detectors on each arm were placed",
                "15. degr. apart. Two monitor detectors were placed at",
                "30. degr. on either side of the beam direction for",
                "relative normalization."
              ]
            }
          ],
