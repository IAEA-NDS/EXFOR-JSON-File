          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two stacks, each consists of ten self-supporting",
                "metallic foils of purity 99.99% and of thickness",
                "0.0079g/cm2 were used as a target. The samples were cut",
                "into pieces of 1.2x1.2cm2 each and glued on an",
                "aluminium frame of size 3.0x2.5cm2 having a circular",
                "hole of diam. 8 mm in its center. The aluminium foils",
                "were also inserted in the stack, which acts as",
                "energy degraders"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
