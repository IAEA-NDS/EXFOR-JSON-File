                "field_identifier": "NAT",
                "value": 0.999
              },
              "free_text": [
                "",
                "The Al-catcher foils of thickness ~50-100 ug/cm2 were",
                "prepared by vacuum evaporation technique.",
                "The thickness of 159Tb targets determined by alpha",
                "transmission method and weighing method  were",
                "1.23 mg/cm2 and 1.31 mg/cm2  respectively.",
                "The target backed by Al degraders of thickness",
                "~1.2 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The detector resolution was 2 KeV for 1408 KeV",
                "       gamma-ray of 152Eu source"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "BCINT"
              ],
              "free_text": [
                " Two stacks of targets were",
                "irradiated by 20Ne+6 at energy 164 and 130 MeV.",
                "The beam currents for stack-I and stack-II were 50 and",
                "33 nA.",
                "The irradiations time for stack-I and stack-II were",
                "6 hr: 30 min and 4 hrs."
              ]
            }
          ],
