          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross sections for deuteron-induced",
                "reactions on some elements of the first transition",
                "series, up to 5.5 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "P.P.Coetzee",
                "M.Peisach"
              ],
