          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Al discs,0.5mm thick, 3cm in diameter, attached to",
                " both sides of the other target samples, were used as",
                " beam monitors."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2SWTSWT"
              },
              "free_text": [
                "",
                " Cyclotron in Schweizerisches Inst.Fuer Nuklearforshung",
                " 595MeV proton beam, beam current was app. 1 micro-a,",
                " the duration of irradiation was 5 min."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "STTA",
                "MOSEP"
              ],
              "free_text": [
                "",
                " using  relatively thin target samples with a minimum",
                "of secondary effects.  2 targets containing different",
                "target materials, being spaced 5cm apart, were",
                "irradiated simultaneously."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "monitor reactions for other reactions with As(2)-S(3),",
                "Na-Br, Rb-Cl and Y(2)-O(3).",
                ".the results from 6 experiments without and 4 experi-",
                "ments with carbon degraders were considered.  however,",
                " front monitors which were not placed in contact with",
                "the degrader, were considered in this reaction, in",
                "order to minimize the secondary particle effect."
              ]
            }
          ],
