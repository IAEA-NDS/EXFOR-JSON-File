          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples are thin Zn foils with natural isotopic comp.",
                "from Goodfellow, Uk. and enriched 66Zn rolled targets.",
                " 66Zn  60 micron (44mg/cm2)",
                "       Isotopic Composition:",
                "       64Zn  0.4 %",
                "       66Zn  99.0 +-0.1  %",
                "       67Zn  0.17  %",
                "       68Zn  0.43  %",
                "       70Zn  0.03  %",
                " natZn 20, 26, 50 micron",
                " natAl  9, 1200 micron",
                " natTi  20, 25, 30 micron",
                " natCo  265 micron",
                " natCu  9 micron",
                " Al served as energy degrader and catcher (9 micron)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                "used. 2 stacks were irradiated at 66.07 and 67.12 MeV",
                "in Faure, and 2 stacks at 70 and 40 MeV in Chiba. Beam",
                "current was measured in Faraday-Cup.",
                "Decay data were taken from E.Browne, R.Firestone, Table",
                "of Radioactive Isotopes, V.S.Shirley [Ed], Wiley,",
                "London, 1986.",
                "Recoil effect was corrected.",
                "No chemical separation was applied."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High purity Ge gamma detector"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "   The energy attenuation was calculated by",
                "using the polynomial approximation of Andersen and",
                "Ziegler The uncertainty ranges 0.4-2.0 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "Total error of the data is around 13%.",
                "Main contributing error components are:",
                "    Beam intensity                    8-10%",
                "    Detector efficiency                  5%",
                "    Peak area                          3-5%",
                "    Number of target nuclei            2-3%",
                "    Nuclear data                         1%"
              ]
