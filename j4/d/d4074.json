          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "the target used were natural Cu 71 mg/cm2 thick",
                "and Ni 88 mg/cm2 thick."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
