          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The enriched 61Ni layers (4E-04 to 1.2E-03 g/cm2 thick",
                "and 12 mm diam.) were electroplated onto",
                "3.9-4.01E-02 g/cm2 thick gold foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "EXTB"
              ],
              "free_text": [
                "7 stacks each containing 5 to 7 Ni-61",
                "samples, 5 stacks each containing 5 Ni-64 samples were",
                "irradiated using the same 18.7 MeV primary proton",
                "energy/ Al foils were used for energy degradation and",
                "Cu foils for beam monitoring. The beam current was",
                "measured also by using a Faraday cup. The degradation",
                "of the particle energy was calculated according to",
                "C.F.Williamson et al. Report CEA-R-3042(1966)."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "TTY-C"
              ],
              "free_text": [
                " determination of optimum energy range for",
                "production of 61Cu and 64Cu.",
                "review of common production routes for 64Cu.",
                "development of an anion-exchange chromatographic",
                "technique for the separation of radio-copper from Ni",
                "target."
              ]
            }
          ],
