          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Prompt gamma yields were normalized by using the 279",
                " and 536 keV gamma production cross sections due to",
                " Coulomb excitation of 197Au and 100 Mo calculated by",
                " FRESCO at each incident energy and summed.",
                "Finally the summed cross sections were normalized to",
                " the coupled-channel fusion cross sections at the",
                " highest energy."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "By author: The 1779 keV gamma line could not be used",
                " due to overlapping with the 1808 keV gamma line from",
                " 26Mg from 12C+16O reaction. Therefore data published",
                " in J.Thomas et al (1986) were adopted."
              ]
            }
          ],
