          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacked foil technique has been used with manganese",
                " element (spectroscopic purity better than 99.9%) as",
                " sample.",
                "The samples (1 mg/cm2 thickness) were prepared by",
                " vacuum evaporation technique on Al backing of",
                " thickness 6.75 mg/cm2.",
                "The Al backing of samples served as the heat",
                " conductors as well as energy degraders. Additional",
                " degraders of aluminium have also been used in some",
                " cases."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC",
                "STTA",
                "EDEG"
              ],
              "free_text": [
                "",
                "Two irradiations were done with alpha beam of energy",
                " 29.93+/-0.57 MeV and 59.96+/-0.54 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Beam flux (~10E+12/s/cm2) was determined by",
                " charge collected in Faraday cup."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Energy resolution 2 KeV for 1.33 MeV gamma ray"
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " Excitation functions have also been calculated",
                " theoretically using two different computer codes, viz.",
                " ALICE/LIVERMORE-82 and ACT"
              ]
            }
          ],
