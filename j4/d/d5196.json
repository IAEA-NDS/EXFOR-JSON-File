          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The studies of the excitation functions of reactions",
                "with emission of gamma-quanta induced by protons with",
                "energy 200...1800 keV on nuclei of 10B and 11B"
              ]
            }
          ],
          "AUTHOR": [
