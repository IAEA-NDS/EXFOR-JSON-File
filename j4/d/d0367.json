          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The high-purity (99.9%) self-supported natural carbon",
                "foils (98.9% 12C - 1.1% 13C) used as targets had a",
                "nominal thickness of approx. 1x10**18 at/cm2 and were",
                "placed at a distance of approx. 27 cm from the",
                "detectors."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " The detection system consisted of five",
                " (300-2000 mu-m thickness) Si surface barrier",
                "detectors (4 rotating, set at 10. degr. intervals,",
                "and 1 fixed at 160. degr. as monitor)"
              ]
            }
          ],
