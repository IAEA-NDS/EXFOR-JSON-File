          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pure 181Ta sample of thickness 150 microgram/cm2 has",
                " been deposited by the electro-deposition technique on",
                " Al foils of thickness 1.1-1.5 mg/cm2.",
                "The samples have been pasted on rectangular Al holders",
                " having concentric holes of 1.0 cm diameter."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activities produced in each Al catcher",
                " foils of the stacks were counted separately using a",
                " high-purity germanium spectrometer of 100 cc active",
                " volume coupled with the CAMAC based FREEDOM software."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC",
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " The evaporation residues populated via CF and/or",
                " ICF are trapped at different catcher foil thicknesses."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The gamma ray spectra of each foil have been",
                " recorded so that the decay curve analysis can be done",
                " to verify the half-lives and the identification of",
                " the residues."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
              "coded_information": [
                "MISC"
              ],
              "free_text": [
