          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two oxygen-containing targets were prepared by",
                "anodizing 0.25 mm tantalum blanks with distilled water.",
                "One target, a so-called' thick' target, was used as a",
                "standard against which the oxygen content of the other",
                "thin oxygen target and the chrome blacks could be",
                "compared. The two oxygen targets and several chrome",
                "black samples were mounted on a target ladder in a",
                "stainless steel vacuum chamber maintained at a",
                "pressure near 5x 10-8 Torr by an ion pump."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Reaction gamma-rays were detected with a 60 cm3",
                "Ge(Li) detector placed at 55 degr."
              ]
            }
          ],
