          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions of deuteron induced nuclear",
                " reactions on natMo and 100Mo(90%) up to 50 MeV:",
                " An alternative route for the production of 99Mo"
              ]
            }
          ],
