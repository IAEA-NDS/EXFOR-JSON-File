          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High Purity, >99.9%, natMo 12micron and enriched 100Mo",
                "in oxide form."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                "used. Beam current was measured in Faraday-cup and also",
                "was monitored by natAl(D,X)22Na and 24Na reactions.",
                "Recoil effect was found to be less than 1%.",
                "Decay data were taken from E.Browne, R.Firestone, Table",
                "of Radioactive Isotopes, V.S.Shirley [Ed], Wiley,",
                "London, 1986. Six stacks were irradiated at 30 and 50",
                "MeV primary beam energies for about half an hour with",
                "about 40nA beam current. Stacks contained Al, Ti, Fe,",
                "Ni, Cu, Zn, Zr and W Foils besides the Mo target foils."
              ]
            }
          ],
