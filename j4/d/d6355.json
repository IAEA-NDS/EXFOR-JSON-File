          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting natural thin foils of Ta, having",
                "thickness of 1.8-3.3 mg/cm2, and Al foils of",
                "2-2.3 mg/cm2.",
                "These foils were mounted on Al rings having 12 mm inner",
                "and 22 mm outer diameters."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The energy and efficiency calibration of the",
                "detector was done using a standard 152Eu source.",
                "The energy resolution of the detector was 2.0 keV at",
                "1332 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " A target stack prepared by placing three Ta",
                "foils, each of which was backed by an Al foil, was",
                "irradiated with the 7Li3+ beam having energy between",
                "27 and 45 MeV."
              ]
            }
          ],
