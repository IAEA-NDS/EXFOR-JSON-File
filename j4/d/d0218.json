          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was a helium gas cell of a thickness and",
                "diameter of 10 and 20 mm, respectively. Being cooled",
                "down to 35 K by a crygenerator it contained",
                "2.4 x 10**21/cm2 8He at a gas pressure of 11 atm."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The secondary beam of 8He was obtained via the",
                "bombardment of a beryllium target of a thickness of",
                "255 mg/cm2 by a 32 MeV/n primary beam of 11B."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "2-HE-8"
              ],
              "free_text": [
