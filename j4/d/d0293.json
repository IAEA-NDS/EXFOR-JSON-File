          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two self-supporting metallic foils of 24Mg were used",
                "as a targets. They were mounted in a target wheel at",
                "the centre of the scattering chamber and could be",
                "selected and rotated remotely. A 12 mg/cm2 target was",
                "used to give larger counting rates when energy",
                "resolution was not a limiting factor; otherwise a",
                "6 mg/cm2 target was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " The wedge-shaped scintillator was",
                "preceded by a thin dE/dx scintillator to form a",
                "telescope which enabled the elimination of events",
                "due to particles other than protons."
              ]
            }
          ],
