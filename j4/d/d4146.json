          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were 7.5 micron thick high purity Nb foils from",
                "Goodfellow."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                "applied. Beam current was measured in a Faraday-like",
                "target holder. 9 microns of Al foils were used to",
                "separate the Nb target foils. Al foils served as energy",
                "degraders and catcher foils. A Nb foil and the",
                "following Al foil were measured together.",
                "Irradiation was done at 10 MeV for 1 hour with 300-500",
                "nA deuteron beam."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
