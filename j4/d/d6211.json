          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self supporting Tb-159 foil of thickness 1.39",
                "mg/cm2 having purity 99.9%"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " The lab angular distribution of PLFs",
                "was measured using two silicon detectors based",
                "Delta-E-E telescopes in the angular range of 30 - 100",
                "degrees. The thickness of the Delta-E and E detectors",
                "was about 20 and 1000 um, respectively. Elastic",
                "scattering measurements were carried out in steps of 2",
                "degree. The telescope detectors were energy calibrated",
                "using elastically scattered F-19 and Li-7 ions of",
                "different energy on Tb-159 and Nb-93 targets. A",
                "monitor detector was kept at 20 degree with respect to",
                "the beam direction to detect the elastically scattered",
                "beam particles."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "100 MeV 19F beam. The average lab energy at the centre",
                "of the target was 98 MeV due to the energy loss in the",
                "target."
              ]
            }
          ],
