          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections for production of the therapeutic",
                "radioisotopes 198Au and 199Au in proton and deuteron",
                "induced reactions on 198Pt"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
