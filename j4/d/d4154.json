          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were high purity natural Pt foils of 26.6 and",
                "29.7 microns for protons and 12.05 microns for deuteron",
                "from GoodFellow."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Stacked target technique was used. Initial energies:",
                "37.9 and 22.5 MeV for protons and 21.0 and 15.1 MeV for",
                "deuterons.",
                "Al, Ti, Cu and Ni were used as monitor and energy",
                "degrader foils.",
                "Beam intensity was 200nA and was also measured in",
                "Faraday cup.  The bombarding energy was determined by",
                "TOF method. Irradiation time was 10-30 min.",
                "High resolution gamma spectrometry was applied without",
                "chemical separation. Spectra were measured after few",
                "hours of EOB.",
                "Energy scale and beam intensity along the stacks were",
                "corrected according to the applied monitor reactions."
              ]
            }
          ],
          "REL-REF": [
            {
