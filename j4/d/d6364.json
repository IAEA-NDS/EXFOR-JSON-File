            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopically pure (~99.9%) tantalum foil of thickness",
                "1.3-1.9 mg/cm2.",
                "The 181Ta samples and Al catchers were cut into",
                "1.2 X 1.2 cm2 size and pasted on Al holders having",
                "concentric holes of 1.0 cm diameter."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High purity germanium detector coupled to CAMAC",
                "based data acquisition system.",
                "The resolution of the detector was 2.2 keV at 1408 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "BCINT"
              ],
              "free_text": [
                " The irradiations were carried out",
                "in general purpose scattering chamber of 1.5 m",
                "diameter for 10-12 hours.",
                "The beam current on the target was measured by a",
                "Faraday cup and was in the range of 20-25 pnA."
