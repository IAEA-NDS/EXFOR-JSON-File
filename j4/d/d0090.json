          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Copper stack was made with 99.99% SPECTURE copper foil",
                "of thickness 10.68 mg/cm2. Copper foil was cut into",
                "pieces of size 1.5cm x 1.5cm and each of them was",
                "glued to an aluminium frame, having a circular hole",
                "of diam. 1.2cm in the centre. The stack was comprised",
                "of 12 such foils. Energy-degrading aluminium foils",
                "of thickness 6.75 mg/cm2 were sandwiched between",
                "the copper foils."
              ]
            }
          ],
