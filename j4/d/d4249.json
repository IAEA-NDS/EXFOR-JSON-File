                "value": 0.7048
              },
              "free_text": [
                "",
                "High quality thallium targets 0.01mm were prepared by",
                " electrodeposition on thin, 0.012 mm, copper foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
