          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets (95 mg/cm2 thick) of natural isotopic",
                "composition (46Ti - 7.93%; 47Ti - 7.28%, 48Ti-73.94%,",
                "49Ti - 5.51%, 50Ti - 5.34%).",
                "Every irradiated stock consisted of three Ti targets",
                "separated aluminium foils so as to degrade the proton",
                "energy ranging from 2 to 2.5 MeV in every successive",
                "target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Activated targets were measured inside the iron",
                "containers using a 50 cm3 coaxial detector coupled to",
                "a 4096 multichannel analyzer."
              ]
            }
          ],
