          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "232Th and 237Np targets of thicknesses 1.8 mg/cm2 and",
                " 300 ug/cm2 respectively on aluminium backing."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier detectors of",
                " thickness 12 micrometer at 110 and 160 degree with",
                " respect to the beam direction to detect the fission",
                " fragments"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Two NE213 neutron detectors (5 cm thick and 5 cm",
                " in diameter) at a distance of 50 cm from the target",
                " each subtending angles of 0 or 180 degree, and 90",
                " degree with respect to the direction of fragment",
                " detection."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The time of flight signal of each neutron",
                " detector was obtained with reference to the start",
                " pulse derived from either of the 2 fission detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The laboratory neutron energy spectra were determined",
                " from the observed time-of-flight spectra after",
                " correcting for the neutron detection efficiency for",
                " each neutron detector."
              ]
            }
          ],
