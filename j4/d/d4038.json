          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Bi powder (99.999% Metal content) pressed to pellets",
                " and high purity Bi metal discs (99.999%).",
                "Light element impurities (in ppm):",
                "--------------------------------------------------",
                "                C         N         O",
                "--------------------------------------------------",
                " Bi-pellet   910+/-290    106+/-7   12400+/-1100",
                " Bi-disc      40+/- 20      3+/-1      31+/-   4",
                "--------------------------------------------------",
                "Samples were sandwiched between two catcher foils of",
                " the same material."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "EDEG"
              ],
              "free_text": [
                " Several Al and Cu foils were inserted in",
                " the stack as energy degrader and monitor foils.",
                "The beam current were measured in faraday cup and via",
                " monitor reactions on natural Cu and Al, and more",
                " reliance was attached to measurements through monitor",
                " reactions."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " The [7Be]BeO and the [203Hg]HgS were obtained",
                " after a multi step chemical separation.",
                "The radiochemical yield was determined gravimetrically.",
                "The Be and Hg content of the samples were determined",
                " by using AES-ICP and AAFS respectively.",
                "The [7Be]Be0 samples were directly measured on a gamma",
                " detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The decay was followed for five hours.",
                "The [203Hg]HgS was measured on a low background",
                " shielded detector.",
                "The Tl-208 background peak was separated from the peak",
                " of 203Hg."
              ]
            },
            {
              "pointer": "1",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " PSI, Villigen",
                " - Primary proton energy 72 MeV and 46 MeV",
                " - Irradiated for 6 hr with beam current of 50 - 70 nA."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " KFA, Juelich",
                " - Primary energy 22 MeV",
                " - Irradiated for 8 hr with beam current of 70 nA."
              ]
            }
          ],
