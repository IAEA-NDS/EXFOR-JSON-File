          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total error in the experimental cross-section",
                "is contributed by",
                " (i) 1-4% error in the photopeak areas of",
                "     characteristic gamma-rays,",
                " (ii) 1-8% error in their absolute abundances,",
                " (iii) 3% error in the photopeak efficiency of",
                "       gamma-rays,",
                " (iv) 1-2% error due to the nonuniformity of the foil",
                "      thickness and",
                " (v) 6% error in the standard monitor reaction",
                "     cross-section assumed in the flux determination.",
                "The overall projected error is thus between 8-12% for",
                "various reactions."
              ]
            }
          ],
