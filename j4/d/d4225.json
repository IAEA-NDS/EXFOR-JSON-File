          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting metallic foils, purity greater",
                "than 99.99%:  silver, 21 mg/cm2;",
                "              holmium, 23 mg/cm2.",
                "Interspersed with aluminum foils as energy degraders",
                "and monitors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "EXTB",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Primary energy of alpha-beam: 70-75 MeV,",
                "beam current: 200-250 nA.",
                "The beam spot on the foil stack was restricted to 5 mm",
                "by a central hole in a tantalum collimator.",
                "A Faraday cup was used for flux determination."
              ]
            }
          ],
