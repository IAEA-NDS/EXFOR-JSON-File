          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was made by vacuum evaporation of silicon of",
                "natural isotopic composition (92% Si28) in a carbon",
                "crucible on a polished stainless steel backing. The",
                "silicon film is separated from the backing to yield a",
                "free silicon target.",
                "The target thickness was 0.2 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "CSICR"
              ],
              "free_text": [
                " Protons scattered on target nuclei in the solid",
                "angle 4.e-4 sr, were detected by CsJ crystal (thickness",
                "of 0.5 mm) and photomultiplier."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Primary beam current was measured using a",
                "Faraday cup and current integrator."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thickness of the target was evaluated from the",
                "results of an experiment on small angle proton",
                "scattering. Since the target thickness was not",
                "determined independently the scattering cross sections",
                "are given in relative units."
