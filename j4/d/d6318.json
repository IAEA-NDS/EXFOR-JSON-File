              "pointer": "",
              "coded_information": [
                "MAGSP",
                "MWPC",
                "SISD"
              ],
              "free_text": [
                " Evaporation residues (ERs) have been",
                "detected using a position-sensitive multiwire",
                "proportional counter (MWPC) of active area 15 cm X 5",
                "cm followed by a silicon strip detector of active area",
                "5 cm X 5 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Two silicon detector have been used inside the",
                "target chamber, placed at an angle +-25 degree with",
                "respect to the beam direction for detecting the",
                "elastically scattered beam particles for absolute",
                "normalization of the evaporation residue cross sections"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
