              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " The low-intensity evaporation residues formed",
                "were separated from the intense beam background using",
                "the gas-filled mode of hybrid recoil mass analyzer",
                " (HYRA)."
              ]
            }
