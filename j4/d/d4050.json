          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for 0.5 to 2 hours with the beam",
                " current was 100 to 200 nA.",
                "The beam energy was measured directly by measuring the",
                " time between the beam bunches in Juelich, and was",
                " determined from the extraction radius and the",
                " cyclotron frequency in Debrecen."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MOSEP"
              ],
              "free_text": [
                " Ti and Cu foils used for monitoring the beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Six stacks were irradiated at 16.0, 20.7 and",
                " 26.6 MeV.",
                "Ziegler's stopping power table (Pergamon, NY, 1977)",
                " was used to calculate the particles energies",
                " in the foils."
              ]
            },
