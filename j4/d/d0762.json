          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "6 thin natural Zn targets (99.95% of purity), of which",
                " 5 were evaporated onto an Al backing (5 mm thick)",
                " while 1 is a self supporting target.",
                "Temperature was well below melting point (420 deg-C).",
                "Target thickness determined by Rutherford",
                " Backscattering Spectrometry (RBS) varies from",
                " 2.38+/-0.12 um to 2.68+/-0.13 um."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
