            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pr2O3 and CeO2 oxide in powder form.",
                "Samples were prepared by sedimentation onto Cu backing",
                " (25 um) then were covered by Al foil (10 um)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Detector-sample distance was about 10 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA",
                "EDEG"
              ],
              "free_text": [
                "",
                "For 141Ndm production, a single target with Cu monitor",
                " foil was irradiated by protons (primary energies:",
                " 12.16 and 20 MeV) and by helions (primary energies:",
                " 25 and 36 MeV) with Al absorbers."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                "",
                "For 139mNd production, five samples, absorbers and",
                " monitor foils were stacked and irradiated by protons",
                " (primary energy: 44 MeV at COSY, and 20 MeV at CV28)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Gamma-spectara were recorded several times to check",
                " the half life and follow the decay."
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Decay data were taken from R.B. Firestone, Table of",
                " Isotopes, CD-ROM version 1.0, 1996."
              ]
            }
          ],
