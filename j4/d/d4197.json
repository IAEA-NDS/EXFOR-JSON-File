          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Formation of the isomeric pairs 139Ndm,g and 141Ndm,g",
                " in proton and 3He-particle induced nuclear reactions"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.Hilgers",
