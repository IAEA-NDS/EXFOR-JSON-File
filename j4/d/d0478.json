          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2NEDKVI"
              },
              "free_text": [
                " the ESN-BBS setup of the Accelerateur",
                "Groningen-Orsay (AGOR) facility at KVI, Groningen.",
                "Deuterons of 183 MeV were delivered by the",
                "superconducting cyclotron AGOR."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting 64Zn foil (99.7%) with a thickness",
                "of 2 mg/cm2 was used as target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Beam line and Big-Bite magnetic spectrometer",
                " (BBS) were set up in dispersion-matched mode to",
                "ensure optimum energy resolution. The spectrometer",
                "was set to 0., 2.5., and 5. angles to be able to",
                "extract angular distributions.The outgoing 2He were",
                "momentum analyzed by the BBS through coincident",
                "detection of the two protons in the EuroSuperNova",
                "detector (ESN detector)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DRFTC",
                "MWPC"
              ],
              "free_text": [
                "The ESN detector is a focal-plane",
                "detection system consisting of two vertical drift",
                "chambers and a set of four multiwire proportional",
                "chambers acting as an additional tracking detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Beam currents were measured with a Faraday cup",
                "inside the spectrometer and ranged between 0.5 and",
                "1.5 nA."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " systematic error due to the procedure of",
                "counting rate extraction"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
