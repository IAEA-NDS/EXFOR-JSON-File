          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN",
                "GELI"
              ],
              "free_text": [
                "The x-rays were detected in intrinsic Ge",
                "detectors of 1-1.5cm thickness and gamma-rays in a",
                "50-cm3 Ge(Li) detector. The energy resolution",
                "of the primary X-ray detector was 550 eV(FWHM) at 100",
                "keV , while the coincidence Ge detectors has ~ 2.0 keV",
                "resolution."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The measurements were made via two",
                "independent techniques, involving detection of",
                "coincidences between (1) K x rays and gamma-rays or",
                " (2) two (or three) K x rays, from the xn products (of",
                "atomic number Zt+3)."
              ]
            }
          ],
