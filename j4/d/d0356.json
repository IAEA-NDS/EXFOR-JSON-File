          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3SAFITH"
              },
              "free_text": [
                " iThemba Separated Sector Cyclotron.",
                "A series of target-in and target-out",
                "measurements, was performed for each target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA",
                "EXTB"
              ],
              "free_text": [
                " The experimental method is based on a",
                "modified transmission technique, where a proton beam",
                "is incident on a target and the outgoing particles are",
                "energy analyzed in order to separate transmitted and",
                "elastically scattered protons from reaction products."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "N",
                "subentry_number": null,
                "author": "CARLSON+",
                "reference": {
                  "code": "J,NIM,123,509,1975",
                  "field": {
                    "reference_type": "J",
                    "reference": {
                      "code": "NIM",
                      "number": null,
                      "volume": "123",
                      "part": null,
                      "issue": null,
                      "page": "509"
                    },
                    "date": 1975
                  }
                }
              },
              "free_text": [
                " Details of Apparatus",
                " And Experimental Technique."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets, all significantly larger",
                "than the size of the beam, have thicknesses",
                "of the order of 100 mg/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " plastic scintillators in a passing",
                "detector telescope, containing two passing detectors",
                "and two annular detectors. The passing detectors are",
                "used for the selection of protons with proper energy,",
                "while the annular detectors serve as active collimators",
                "ensuring that the identified protons are correctly",
                "directed on the target"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "CSICR",
                "SCIN"
              ],
              "free_text": [
                " Behind the target, the outgoing",
                "particles are energy analyzed in a CsI energy detector,",
                "thick enough to stop 200 MeV protons, in order to",
                "identify  all unaffected or elastically scattered",
                "protons. In front of the energy detector is a small",
                "transmission detector that consists of an array of",
                "three overlapping plastic scintillators, one circular",
                "and two ring shaped."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
