                "code_unit": [
                  {
                    "unit": "J,PR,120,2114,1960",
                    "doi": "10.1103/PhysRev.120.2114",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR",
                        "number": null,
                        "volume": "120",
