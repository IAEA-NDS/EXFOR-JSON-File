            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "BCINT"
              ],
              "free_text": [
                " An optimum irradiation time of",
                "about ~12 hr.",
                "The beam current was 25 nA to 30 nA during the",
                "irradiation."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Integration over the range."
              ]
            }
          ],
