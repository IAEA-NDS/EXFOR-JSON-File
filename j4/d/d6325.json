          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting natural 169Tm (abundance 100%) target",
                "foils of thicknesses 1.2 to 1.7 mg/cm2 were prepared",
                "by rolling technique."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The detectors were precalibrated for",
                "efficiency and energy using standard gamma sources at",
                "various source-detector separations to avoid",
                "solid-angle effects during the offline counting."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "EDEG"
              ],
              "free_text": [
                " Irradiations were performed in the",
                "General Purpose Scattering Chamber (GPSC) for",
                "duration of ~8-12 hours for each stack. The beam",
                "current was 25 to 30 nA. In order to trap recoiling",
                "products during the irradiations, Al catcher foils of",
                "thicknesses 1.1 to 2.0 mg/cm2 were placed downstream",
                "from the target foil."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The total charge collected in the Faraday cup",
                "has been used to calculate the flux of the beam."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The overall errors including errors due to",
                "non uniform thickness of target foils, beam current",
                "fluctuation, HPGe detector efficiency and dead time,",
                "and statistical errors, but excluding the uncertainty",
                "in branching ratio, decay constants, etc (<=15%)."
              ]
            }
          ],
