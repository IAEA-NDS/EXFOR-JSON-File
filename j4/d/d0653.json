          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Incident deuteron beam energy was determined within",
                " 1.0%, its FWHM was up to 1.8%.",
                "Mean deuteron energy and energy thickness were",
                " determined using SRIM2003."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Two HPGe detectors were used.",
                "  Efficiencies were 23% and 50% at 1.3 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "11Al (50 um) and 11Cu (25 um) foils placed alternately"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Two irradiations were carried out:",
                " 1. initial Ed=19.95 MeV (90 nA) for 15 min;",
                " 2. initial Ed=20.18 MeV (330 nA) for 5 min.",
                "Additionally 3 extra runs were carried out for",
                " short lived 63Zn (38.47 min) and 66Cu (5.12 min)",
                " 3. initial Ed=19.79 MeV (0.24 uA) for 6 min;",
                " 4. initial Ed=20.09 MeV (0.36 uA) for 5 min;",
                " 5. initial Ed=19.79 MeV (0.17 uA) for 9.3 min;"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Cooling up to 100 days after irradiations for",
                " the 90 nA and 330 nA irradiations (i.e. irradiation",
                " for long lived radionuclide products)"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Comment by E.Simeckova (2011-08-05):",
                " Data published in 2007 (EXFOR D0453) have been",
                " superseded by data sets in this EXFOR entry (D0653).",
                " Main revisions are in",
                " - initial deuteron beam energy in connection with",
                "   measurement of the beam-orbit position in the",
                "   accelerating procedure;",
                " - inclusion of uncertainty in current measurement to",
                "   the total uncertainty;",
                " - target isotope for 64Cu production (63Cu -> natCu),",
                "   considering 65Cu(n,t) threshold",
                " - newly added 66Cu and 63Zn production data sets"
              ]
            }
          ],
