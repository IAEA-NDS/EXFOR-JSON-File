                "correlation_property": null
              },
              "free_text": [
                " The systematic error includes the  error due",
                "to the uncertainty in beam position, the  choice of",
                "the fitting procedure and the subtracted air",
                "background."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
