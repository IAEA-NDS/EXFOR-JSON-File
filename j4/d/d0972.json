          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two 99.9% isotopically enriched 28Si foils (Si only,",
                " for clear identification of 1 neutron transfer),",
                " and two other 28Si foils with a thin backing layer",
                " of 197Au (Si-Au, for cross section normalization).",
                "Thickness of 28Si layers measured by RBS were",
                " approximately 40 ug/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " 9 surface barrier Si detectors mounted 30 cm",
                " away from the target"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "NTRTH"
              ],
              "free_text": [
                " Ratio between Au and Si foil thicknesses was",
                " determined from measurements at Elab=25 MeV and at",
                " 25, 30 and 35 deg, and the theoretical curve."
              ]
            }
          ],
