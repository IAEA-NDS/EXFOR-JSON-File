          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  The uncertainties quoted on the formation",
                "cross-section are the standard deviation of the",
                "multiple counting reflecting the uncertainty due to",
                "counting statistics. However, the overall uncertainty",
                "on the formation cross-sections of evaporation residues",
                "will be higher due to the contribution from systematic",
                "errors, mainly:",
                "  * the error in the detection efficiency (2-7%)",
                "  * uncertainty in the target thickness (5%);",
                "  * the efficiency error at the energies of the",
                "    gamma-rays which have been used for the residue",
                "    measurement, is within 2-4%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " uncertainty in the target thickness"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The yield of a mass chain is calculated using the",
                " experimentally determined independent yield or",
                " cumulative yield of the fission products."
              ]
            }
