          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section of alpha-induced reactions on iridium",
                "isotopes obtained from thick target yield measurement",
                "for the astrophysical gamma-process"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
