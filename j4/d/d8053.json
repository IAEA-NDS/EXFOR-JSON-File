          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An artificial separation of the total number of events",
                " in each unresolved peak (normalized to the integral",
                " of the 10B ion beam at each angle of measurement) can",
                " be carried out in proportion to the calculated",
                " (within the DWBA approach) single-particle DCS values",
                " of proton transfer to the considered states of 17F."
              ]
            }
          ],
