          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two target assemblies were irradiated with a deuteron",
                "beam of initial energy 11.7 and 16.4 MeV,",
                "respectively. The accelerated deuteron beam was",
                "focused to the size 5x5 mm. The energy of deuterons",
                "was determined with a magnetic monochromator. The",
                "initial energy spread of the beam was less than 100",
                "keV. The mean energy of incident deuterons and their",
                "energy spread in each foil were calculated using the",
                "SRIM 2011 code and the LISE++ program."
              ]
            }
          ],
          "METHOD": [
