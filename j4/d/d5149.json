          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Evaporation of AlF3 on Pt disks, weighed on a",
                " microbalance to 0.179, 0.200, 0.211 and 0.280 mg/cm2.",
                "Al foil (0.67 mg/cm2) which weights were checked by",
                " relative neutron yield per unit weight."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " Long proportional boron counter rotated on a",
                " circle of 1 m radius around a vertical axis passing",
                " through the center of the target.",
                "The neutron counter was calibrated against a standard",
                " Ra+Be neutron source yielding 4.8x10**5 neutrons/sec.",
                "Counter efficiency was 1.008x10**4 neutrons/sr per",
                " count.",
                "The sensitivity of the neutron counter was within 3%",
                " for neutrons from 25 keV to 5 MeV and dropped 11% for",
                " 14-MeV neutrons."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Errors in neutron yields were determined",
                " by taking into account",
                " . number of nuclei in AlF3            (3%)",
                " . number of AI nuclei                 (1%)",
                " . number of tritons irradiated target (1%)",
                " . Ra+Be source source strength        (3%)"
              ]
            }
          ],
          "CORRECTION": [
