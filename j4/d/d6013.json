          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Most of the elastic scattering",
                "measurements were carried out using silicon",
                "detectors - two single E detectors and one DE-E",
                "telescope. At a few energies, E = 51.13, 55.8, 59.8",
                "and 74.8 MeV detailed angular distribution data for",
                "not only elastic scattering, but also inelastic and",
                "transfer channels were measured employing four DE-E",
                "telescopes (dE = 20-45 mu-m, E = 300-2000 mu-m).",
                "Typical energy resolutions were of the order of 700 keV"
              ]
            }
          ],
