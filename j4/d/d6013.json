          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets used were in the form of self-supporting",
                "foils of natural Bi metal with a thickness ~250",
                "mu-g/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
