          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions of proton-induced reactions on",
                "natFe and natZr targets for the production of cobalt",
                "and niobium isotopes"
              ]
            }
          ],
          "AUTHOR": [
