          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In the first stack, high-purity (> 99.99%) natural iron",
                "and copper metals of thickness 100 um and 103 um,",
                "respectively.",
                "In second stack, high purity (> 99.99%) natural",
                "zirconium and copper metals foils thicknesses of 95 um",
                "and 99 um, respectively.",
                "The sizes of iron and zirconium foils were",
                "0.7 X 0.7 cm2 whereas, those of copper foils were",
                "0.8 X 0.8 cm2.",
                "The foil was wrapped with an aluminum foil of 25 um",
                "thick to avoid contamination from other samples in the",
                "stack."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector connected to a PC-based 4K channel",
                "analyzer without chemical separation.",
                "The energy resolutions of the detectors were 1.8 keV at",
                "the 1332.5 keV gamma-line of 60Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " Two separate stacks of iron and",
                "zirconium were irradiated with 22 and 20 MeV proton",
                "energies, respectively.",
                "The first stack was irradiated for 40 minutes with a",
                "proton beam of 22 MeV and beam current of 28 nA.",
                "The second stack was irradiated for 10 minutes with",
                "proton beam energy 20 MeV and beam current of 100 nA."
              ]
            }
          ],
