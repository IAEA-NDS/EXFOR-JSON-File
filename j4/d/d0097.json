          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "SiC layer. Three samples with thicknesses: 53, 7 and",
                "2.3 mu-g/cm2 with dilution ratio (H2/C3H8): 2000,",
                "200 and 500, respectively.",
                "The wafers were p-type Si(100) sigle crystals of",
                "600-mu-m thickness. The sample preparation included",
                "methanol/ultrasonic cleaning and deoxydation in",
                "HF (5%) for 30 sec. without any subsequent contact",
                "with water."
              ]
            }
          ],
