          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity 0.01 mm Co foils (Goodfellow) were used",
                " interleaved with Al 0.012,and 0.1 mm monitor foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
