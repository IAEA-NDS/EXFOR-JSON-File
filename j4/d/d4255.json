              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties of the mean proton energies",
                " in the individual foils were estimated from",
                " - the energy uncertainty of the primary beam,",
                " - the uncertainty of the thickness and uniformity of",
                "   the foils in the irradiated stack,",
                " - energy straggling and from increasing energy spread."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainties of the following linearly",
                " contributing sources:",
                " - peak areas,",
                " - detector efficiency,",
                " - gamma abundances,",
                " - number of target nuclei,",
                " - beam intensity",
                " and amounts to about 10%.",
                "Nonlinear contributions like waiting or measuring time,",
                " half-life, are not considered here."
              ]
            }
