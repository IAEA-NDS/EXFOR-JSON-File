          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "194Pt, 196Pt and 198Pt rolled foils (enrichment > 95%)",
                "and thicknesses 1.75, 1.75 and 2.15 mg/cm2,",
                "respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " The fission fragments were",
                "detected using three hybrid telescope detectors",
                " (delta E) followed by a silicon surface barrier",
                "detector (E).",
                "These detectors were positioned 28 cm away from the",
                "target on a moveable arm of the scattering chamber,",
                "with a collimator diameter of 10 mm and an angular",
                "separation of 12 degrees between two adjacent detectors"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two Si surface barrier detectors were used to",
                "detect elastically scattered beam particles at",
                "+/- 10 degree with respect to the beam direction for",
                "monitoring and normalization purpose."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measured fission fragment angular distributions",
                "were transformed to the center-of-mass system assuming",
