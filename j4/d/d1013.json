          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pairing of thorium with selected primary target",
                " materials in tandem configurations: Co-production of",
                " 225Ac/213Bi and 230U/226Th generators with a 70 MeV",
                " H- cyclotron"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "G.F.Steyn",
                "M.A.Motetshwane",
                "F.Szelecsenyi",
                "J.W.Bruemmer"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3SAFITH",
                "3HUNDEB"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "3BWABWA"
              ],
              "free_text": [
                " Botswana International University of Science",
                " and Technology, Palapye"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ARI,168,109514,2021",
                "code_unit": [
                  {
                    "unit": "J,ARI,168,109514,2021",
                    "doi": "10.1016/j.apradiso.2020.109514",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "ARI",
                        "number": null,
                        "volume": "168",
