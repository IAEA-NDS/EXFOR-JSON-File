                      },
                      "date": 2021
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3SAFITH"
              },
              "free_text": [
                " Separated-sector cyclotron (SSC)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The primary proton beam energies determined with",
                " monitor reactions were 40.3+/-0.3 and 67.0+/-0.5 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- Th foils (25 um nominal thickness, 99.7% purity)",
                "- Kapton foils (25 um thickness)",
                "- natMg foils (50 um nominal thickness, 99.9% purity)",
                "- Cu, Ti and Al foils as monitors and degraders"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Relative efficiency of 15%, resolution of",
                " 1.8 keV FWHM at 1.33 MeV"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Each stack contained 13 Th foils sandwiched",
                " between Kapton foils served as catchers.",
                "Behind of each Th sandwich was placed a Mg foil and",
                " a series of",
                " - Cu and Ti monitor foils interspersed with Al",
                "   degrader foils for 40 MeV irradiation,",
                " - Al monitor/degrader foils for 66 MeV irradiation."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated by primary proton beams at 40 and",
                " 66 MeV (average current of 50 nA) for 5 hours per",
                " stack"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Current and charge values logged in 1-sec",
                " intervals",
                "Deon Steyn (2021-02-15):",
                " The directly measured proton flux agrees with the",
                " flux measured via the monitor foils quite well."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Counting started a couple of days after the",
                " end of bombardment and continued for several months"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "MCNP calculation was performed to determine the",
                " average energy, FWHM energy spread and correction",
                " factor for beam intensities loss due to non-elastic",
                " nuclear interactions."
              ]
            }
          ],
          "ERR-ANALYS": [
