          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The proton irradiation current was around 50 nA and",
                "the beam size was about 3 mm."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisting of about 260 mu-g/cm2 CaF2",
                "evaporated on a 0.1 mm Ta backing"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The detector system consisted in a",
                "reverse-electrode closed-end coaxial HPGe detector,",
                "CANBERRA model GR6024, measuring 72.5 mm in diameter",
                "and 60.5 mm in length, and conventional electronics."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thirteen measurements were done with incident proton",
                "energies varying from 1.362 MeV to 1.416 MeV, where",
                "the live counting time for each spectrum was 600 s."
              ]
            }
          ],
          "ERR-ANALYS": [
