          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Cd (106Cd 1.25%, 108Cd 0.89%, 110Cd 12.49%,",
                "111Cd 12.80%, 112Cd 24.13%, 113Cd 12.22%, 114Cd 28.73%",
                "and 116Cd 7.49%). Thin layers of cadmium on backing",
                "material were prepared by sedimentation of cadmium",
                "oxide powder (CdO), purity (99.5%) on a high purity",
                "aluminum backing of thickness 250 mu-m.",
                "The thickness of the prepared CdO layers ranged between",
                "2.5-14.1 mg/cm2. Each target was covered by a 10 mu-m",
                "thick and 15 mm in diameter aluminum foil for protectio",
                "One stack was used for measuring the excitation",
                "function, it contained 8 Al-Cd-Al sandwiches"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV"
              ],
              "free_text": [
                " stacked-foil technique"
