          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "13 experimental works have been reviewed. Individual",
                "data sets were fitted separatelly by using a cubic",
                "spline method. The weighted average values of the",
                "excitation functions and their corresponding",
                "uncertainties were calculated, in the final step the",
                "weighted average was fitted and the errors were",
                "calculated."
              ]
            }
