          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fusion and direct reactions around the barrier for the",
                "systems 7,9Be,7Li + 238U"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
