          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,74,044606,2006",
                "code_unit": [
                  {
                    "unit": "J,PR/C,74,044606,2006",
                    "doi": "10.1103/PhysRevC.74.044606",
                    "field": {
                      "reference_type": "J",
                      "reference": {
