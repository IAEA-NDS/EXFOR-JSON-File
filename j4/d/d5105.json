          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was produced by firing argon ions into a",
                "tantalum substrate directly in an electromagnetic",
                "separator."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                "  The excitation function was measured using an",
                "NaI(T1) detector with dimensions of diameter",
                "150x100 mm, located at a distance of 5 cm from the",
                "target at 55 degrees relative to the direction of the",
                "proton beam to eliminate the effect of the angular",
                "distribution of gamma quanta on the measured results."
              ]
            }
          ],
