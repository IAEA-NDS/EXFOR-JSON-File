          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2FR GAN"
              },
              "free_text": [
                " The experiment was performed at the",
                "GANIL facility with a 40.9A MeV 6He radioac. ion beam"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "PRJFS"
                ],
                "institute": "2FR GAN"
              },
              "free_text": [
                " fragmentation of a primary 75A MeV",
                "13C beam on a 8.45 mm thick C target located in the",
                "SISSI device. The secondary beam was purified with",
                "a 0.9 mm thick Al degrader situated between the",
                "dipoles of the aplha-spectrometer. The beam intensity",
                "on the polypropylene (CH2)3 reaction target was",
                "105 particles per second with a 2% total",
                "contamination of 8Li and 9Be."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 1.48 mg/cm2 thick polypropylene target (density,",
                "0.896 g/cm3) was used. Good statistics at larger",
                "angles was obtained by using a 8.25mg/cm2 thick",
                "target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " The recoiling protons were detected",
                "in MUST, an array of 8 three-stage telescopes",
                "6 cm x 6 cm each. The first stages consist in",
                "double-sided Si-strip detectors (300 mu-m)."
              ]
            }
          ],
