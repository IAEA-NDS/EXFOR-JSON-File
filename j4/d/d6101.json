          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self supporting 1.8 mg/cm2 thick 232Th target"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PS"
              ],
              "free_text": [
                " Two X-Y position sensitive large area low",
                "  pressure Breskin detectors having active dimensions",
                "  of 6.5 cm x 5.0 cm and 15.0 cm x 3.5 cm were used.",
                " The smaller detector was kept at 20.0 cm from the",
                "  target subtending an angle of 18 deg. and was moved",
                "  in overlapping steps to cover 10 to 100 deg in the",
                "  reaction plane.",
                " The other detector was placed at a distance of",
                "  14.5 cm in the opposite side of the target with an",
                "  opening angle of about 60 deg to detect the",
                "  complementary fission fragments."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " A 300 micrometer thick solid-state detector was",
                "  placed at +-25 deg. to monitor elastically scattered",
                "  particles."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Two fission fragments detected in coincidence"
