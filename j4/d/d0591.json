          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting bilayer films (Be/Al,Be/Au,Be/Mn).",
                "Also examined were single-crystal (0001) hcp-Be films",
                "grown on (lll)Si and (0001)alfa-Al2O3 substrates",
                " by molecular beam epitaxy.",
                "TABLE (film characteristics)",
                "FILM       ELEMENT    (Nt([X10-15ATOMS/CM2]",
                "BeAu1      Au                    14.7+-0.4",
                "BeAu1      Be                    1560+-50",
                "BeAl6      Al                    820+-25",
                "BeAl6      Be                    1780+-60",
                "Bei18      Be                    1990+-120"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " detector (Ortec BA-14-25-100) resolution =",
                "14 keV for 4He, 5keV for 1H; solid angle subtended by",
                "the detector was 0.78+-0.02) msr; backscattering angle",
                "was 170.5+-0.5 degr., with BS angles in the range",
                "170.5+-0.9 degr. accepted by the detector. The beam",
                "energy was uncertain by less than 0.08%; the beam",
                "energy spread was less than 2 keV."
              ]
            }
