          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The isotopic target of 40Ar is produced by hammering",
                "of 40Ar+ ions in tantalum backing directly in",
                "electromagnetic separator. The target thickness was",
                "about 4 keV at proton energy at Ep=2.0 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                "  NaI(Tl) detector was used for  excitation",
                "function measurements. The gamma-rays were detected  at",
                "angle of 55 degrees concerning proton beam direction.",
                "The dimensions of the crystal was diameter 15 x 10 cm."
              ]
            }
          ],
