          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target for cross section measurements were",
                "produced by evaporation of In with natural isotopic",
                "composition onto Al backing (2 - 2.5 um). The target",
                "thickness was between 4.48e17 - 2.28e18 atoms/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " for gamma detection"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LEGE"
              ],
              "free_text": [
                " for low energy photon detection"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC",
                "SITA",
                "EXTB"
              ],
              "free_text": [
                "",
                "The energy of the alpha beam provided by the cyclotron",
                "accelerator of ATOMKI was Elab=16.15 and 19.50 MeV."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainty is due to energy calibration of",
                "the alpha beam and to the uncertainty of the energy",
                "loss in the target calculated using SRIM code."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The count rates have been normalized to the",
                "yield of the monitor detectors at 15 degree.",
                "The relative measurement eliminates the typical",
                "uncertainties of absolute measurements, coming mainly",
                "from changes in the absolute target thickness and from",
                "the beam current integration. Total uncertainty was",
                "between 4% and 5%."
              ]
            },
