          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAWAU"
              },
              "free_text": [
                " The measurements were carried out at",
                "9Be energies of 50 and 53 MeV using Tandem/booster",
                "accelerator facility at Seattle."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Six silicon surface-barrier detectors ranging",
                "in thickness from 20 to 60 micrometre were positioned",
                "suitably to cover the angular range from 80 deg to 170",
                "deg. A relative solid-angle calibration of the",
                "detectors was obtained using 252Cf source placed at",
                "the target site. A monitor detector was positioned at",
                "theta ~ 26.5 deg to detect the elastically scattered",
                "9Be."
              ]
            }
          ],
