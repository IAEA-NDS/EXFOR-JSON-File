              ]
            },
            {
              "pointer": "2",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " BARC-TIFR Pelletron-LINAC facility for",
                "off-line measurement."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                "The 176Yb an electrodeposited target of thickness",
                "~150 ug/cm2 on a thin aluminum backing of thickness",
                "540 ug/cm2 of 9-mm diameter was used for on-line",
                "measurement."
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
                "For off-line measurements, 176Yb targets of",
                "~300 ug/cm electrodeposited on aluminum foil of",
                "thickness 2.5",
                "mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "1",
              "coded_information": [
                "MAGSP",
                "MWPC"
              ],
              "free_text": [
                " For on-line measurements, evaporation",
                "residues were separated from beam particles by the",
                "HYRA, operated in a gas-filled mode and detected by",
                "multiwire proportional counter at the focal plane."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " For off-line measurements, evaporation",
                "residues were stopped in the aluminum backing and",
                "were assayed using off-line gamma ray spectrometry",
                "with a high-purity germanium detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "1",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " Evaporation residue production cross sections",
                "were measured by using hybrid recoil mass analyzer."
              ]
            },
            {
              "pointer": "1",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The time of flight of the evaporation residues",
                "was recorded with respect to the beam pulse for clear",
                "evaporation residues."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for 2 to 3 hrs."
              ]
            }
          ],
          "ERR-ANALYS": [
