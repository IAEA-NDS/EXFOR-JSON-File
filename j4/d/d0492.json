          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Bi metal (3.56 mg/cm2 thick) deposited onto an Al",
                " backing of thickness 6.75 mg/cm2 by vacuum",
                " evaporation technique.",
                "Bi foil was cut into pieces of 1.5 x 1.5 cm and each",
                " glued to an Al frame, having a circular hole of",
                " diameter 1.2 cm in its center.",
                "Energy-degrading Al foils of different thickness were",
                " sandwiched between the Bi foils whenever required,",
                " s0 as to get the desired alpha-particle energy",
                " incident on each foil."
              ]
            }
          ],
