          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "Three E-DE silicon surface barrier telescopes",
                "and one DE gas common to three silicon surface",
                "barrier E detectors were used to detect fission",
                "fragments. The depletion depths of the three silicon",
                "DE detectors were 11 mm, 12 mm, and 17 mm the silicon",
                "E detectors were 2 mm in thickness. A surface barrier",
                " detector at an angle of 30 degree with respect to the",
                " beam  direction detected the elastically scattered",
                "events."
              ]
            }
