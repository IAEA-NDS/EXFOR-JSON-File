          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "52-TE-128",
                "field_identifier": "ENR",
                "value": 0.87
              },
              "free_text": [
                " The samples of enriched isotopes",
                "of 128Te (87%) were prepared by vacuum evap. technique.",
                "The 128Te material was deposited on the aluminium (Al)",
                "foils of thickness 6.75 mg/cm2. The measured thickness",
                "of the 128Te deposition was found to be ~92 mg/cm2.",
                "A stack of four samples was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                "detector of 100 c.c. active volume coupled to a",
                "PC through CAMAC based FREEDOM software."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "BCINT"
              ],
              "free_text": [
                " The stack of samples was",
                "irradiated for nearly six hours keeping in view the",
                "half-lives of interest. Beam current of %10 pnA",
                "behind the target assembly was measured with an",
                "electron suppressed Faraday cup. The total beam",
                "fluence was found to be 1253 mC."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total uncertainty includes statistical",
                "        uncertainty and:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": 6.0,
                "correlation_property": null
              },
              "free_text": [
                " error in the efficiency on account of",
                "        solid angle effect is <6%"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": 1.0,
                "correlation_property": null
              },
              "free_text": [
                " error due to non uniform deposition",
                "            is expected to be <1%"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": 3.0,
                "correlation_property": null
              },
              "free_text": [
                " error in beam fluctuations  <3%"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-4",
                "minimum_value": null,
                "maximum_value": 2.0,
                "correlation_property": null
              },
              "free_text": [
                " error due to decrease in beam intensity",
                "            is expected to be <2%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-5",
                "minimum_value": null,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " error in dead time is kept less than 10%",
                "Further, the uncertainties in the:",
                "                 * branching ratio,",
