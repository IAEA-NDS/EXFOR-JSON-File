          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Complete and incomplete fusion: measurement and",
                "analysis of excitation functions in 12C+128Te System",
                "at energies near and above the Coulomb barrier."
              ]
            }
