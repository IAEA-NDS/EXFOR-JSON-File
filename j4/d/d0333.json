          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The data of the Rutherford scattering were used for",
                "the normalization to obtain the absolute fission",
                "cross sections. (see DETECTOR)"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting target of Au having a thickness",
                "around 500 mu-g/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Two Si-detector telescopes. The",
                "thickness of the dE detectors was about 10 and 14 mu-m.",
                "The dE detectors were backed by 300 mu-m thick",
                "E detectors.",
                "A Si-detector was kept at 40 degr. with respect to the",
                "beam at a distance of about 25 cm form the target to",
                "monitor the Rutherford scattering."
              ]
            }
          ],
