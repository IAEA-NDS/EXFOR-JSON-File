          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Simple production of 77Br- and 123I- and their use",
                "in the labelling of [77Br]BrUdR and [123I]IUdR"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.Lundqvist",
                "P.Malborg",
                "B.Langstrom",
