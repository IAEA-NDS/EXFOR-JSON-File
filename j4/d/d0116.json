          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCY"
                ],
                "institute": "2SWDUPP"
              },
              "free_text": [
                " 230 cm synchrocyclotron"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "400 mg of dried target material, NaBr and NaI was",
                "ground pressed to cylindrical pellets (diam. = 13.0 mm,",
                "height approx.1 mm) at a pressure of 8000 kp/cm2.",
                "Al-foils, 0.10 mm thick, were placed on each side of",
                "the target in such a way that the irradiating protons",
                "had to penetrate both the pellet and the Al-foils, a",
                "10 mm straight, vertical edge facing the cyclotron",
                "centrum."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 70 cm3 GeLi detector",
                "All the measurements were made at least three times,",
                "compensation being made for the chemical composition",
                "and nuclide abundance of the target, irradiation and",
                "measuring times and the decay in between photon",
                "abundance and detector efficiency."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
