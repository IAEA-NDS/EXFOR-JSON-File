              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2SWDUPP"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ARI,30,39,1979",
                "code_unit": [
                  {
                    "unit": "J,ARI,30,39,1979",
                    "doi": "10.1016/0020-708X(79)90095-4",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "ARI",
                        "number": null,
