          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples are sandwiched between two thin carbon",
                "layers of thickness 25 and 7 ug/cm2. Evaporation",
                "residue cross-section measurements were carried out",
                "using pulsed 48Ti beam with 1 us pulse separation at",
                "energies in the center of mass from 140 to 205 MeV,",
                "including energy loss from 650 ug/cm2 carbon window",
                "foil, carbon backing, and a half thickness of target",
                "~17 MeV. The average current is 0.5 pnA."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier detectors were",
                "placed inside the target chamber at a distance of 45",
                "mm from the target ladder subtended an angle of +-25",
                "degree with respect to the beam direction. The",
                "detector was used for detection of elastically",
                "scattered particles for normalization."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "MWPC"
              ],
              "free_text": [
                " Position-sensitive multiwire proportional",
                "counter of dimensions 6 X 6 in2 followed by a strip",
                "detector of dimensions 6 X 6 cm2 kept in the focal",
                "plane chamber. The MWPC counts were used for the",
                "measurement of the ER cross section."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " The heavy evaporation residues formed were",
                "separated from the enormous beam background using the",
                "gas-filled mode of hybrid recoil mass analyzer (HYRA)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Evaporation residue events were selected by the",
                "combination of TOF and delta-E."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The estimated error constituting the",
                "systematic error and statistical error is 15% of the",
                "cross section."
              ]
            }
          ],
