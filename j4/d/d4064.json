          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "natural Cd foils of 25.6 mg/cm2 thickness were used",
                "as target foils. 16.56 mg/cm2 Al foils were inserted",
                "into the stack for monitoring the deuteron beam",
                "trough the Al-27(d,ap)Na-24 reaction."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "relative excitation function was measured via the",
                "activation technique using stacked foil targets.",
                "the beam flux was determined via the Al-27(d,ap)Na-24",
                "reaction monitor reaction."
              ]
            }
          ],
