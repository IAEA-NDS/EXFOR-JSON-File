          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "AREA",
                "DECAY"
              ],
              "free_text": [
                "",
                "the primary deuteron energy was 27.5 MeV with an",
                "uncertainty estimated below 1%. The energy",
                "degradation was calculated according to williamson",
                "et Al. (Tables of range and stopping power of chemical",
                "elements for charged particles of energy 0.5 To 500 MeV",
                ",rapport CEA-R-3042 1966).",
                "the usual gamma-spectrometry was applied to measure the",
                "radioactivity.",
                "nuclear data were taken from Nucl. Data Sheets, B5,no5",
                "1971 and Erdtmann-Soyka Jul-1003-AC,1973"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "en-err. The energy straggling and the uncertainty due",
                "to the thickness of the foils were included in the",
                "error of the energy scale. The nonuniformity of the",
                "foils were neglected."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " the over-all error was estimated on",
                "the basis of the following possible errors:",
                " -counting statistics",
                " -peak area analysis",
                " -detector efficiency",
                " -foil thickness",
                " -error of the nuclear data and timing",
                "the uncertainty in cross section varied from 5% to",
                "40%"
              ]
            }
          ],
