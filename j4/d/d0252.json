          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 13C target. The target thickness was carefully",
                "measured to be 236 mu-g/cm2 by scanning with",
                "wellcollimated alpha particles from 241Am, 238Pu,",
                "and 244Cm sources and by continuous calibration",
                "during the experiment."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
