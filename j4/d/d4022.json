          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation function of proton induced nuclear",
                "reactions on highly enriched Kr-78: relevant to the",
                "production of Br-75 and Br-77 at a small cyclotron"
              ]
            }
          ],
          "AUTHOR": [
