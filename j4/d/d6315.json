          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target of 206Pb of thickness 250 ug/cm2 on 20",
                "ug/cm2 thick carbon backing. The self-supporting",
                "209Bi target of thickness 440 ug/cm2. Both targets",
                "were prepared by evaporation technique and set at",
                "angle 45 degree to the beam axis."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Position sensitive multiwire proportional",
                "chambers of active area 20 cm X 6 cm centered at 60",
                "degree forward angle and 114 degree backward angle to",
                "the beam axis were used to detect fission fragments.",
                "The detectors were operated at a pressure of 3 torr",
                "of isobutane gas."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The time of flight differences of the",
                "coincident fission fragments were used to directly",
                "extract the fission fragment mass distribution."
              ]
            }
          ],
