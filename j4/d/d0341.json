          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "After passing through the target, the beam was",
                "collected in a Faraday cup and the total charge was",
                "measured by a standard current integrator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The potassium target of the thickness of 0.37 mg/cm2",
                "was prepared by vacuum evaporation of natural metallic",
                "potassium onto a thin carbon backing (40 mu-g/cm2)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " A broad-range magnetic spectrograph with",
                "photographic emulsion as detector the measurements of",
                "the angular distributions of the deuterons elastically",
                "and inelastically scattered from the target.",
                "Ilford K2 plates 25 mu-m thick and overed by aluminium",
                "foils were used as detectors."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " The thickness of the target was checked",
                "continuously during the irradiation by means of a",
                "semiconductor detector viewing the target at a fixed",
                "scattering angle of around 65 degr."
              ]
            }
          ],
