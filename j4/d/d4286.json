          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "EDEG",
                "GSPEC",
                "MOSEP",
                "STTA"
              ],
              "free_text": [
                " Cu(86%)-Mn(12%)-",
                "Ni(2%) alloy (25 micro-m) and pure Mn foils (10 micro-",
                "m) were used as target material. Irradiations of Mn",
                "targets was performed through stacked foil",
                "irradiation followed by high resolution gamma",
                "spectrometry. Stacks were irradiated at cyclotron of",
                "the Vrije Universiteit Brussel, VUB with proton beam",
                "of incident energy of 37 MeV, 61 nA, 71 min and the",
                "accelerator of Tohuku University, Sendai, nominal",
                "incident energy 70 MeV, 26 nA, 20 min and 100 nA, 60",
                "min. The stacks were interleaved with Al and Ti",
                "monitor/degrader foils. The beam current was kept",
                "constant. Activated foils were measured 3 times to",
                "follow the decay of the reaction products. Decay data",
                "were taken from NUDAT."
              ]
            }
          ],
