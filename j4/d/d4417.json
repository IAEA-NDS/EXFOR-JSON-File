          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the 91Zr(p,g)92mNb cross section",
                "motivated by type Ia supernova nucleosynthesis"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
