          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Study of excitation functions and insights into the",
                "reaction mechanisms of 6Li fusion in Cu"
              ]
            }
          ],
          "AUTHOR": [
