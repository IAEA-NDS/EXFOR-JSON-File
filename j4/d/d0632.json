          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental studies and nuclear model calculations",
                "on proton induced reactions on manganese up to 45 MeV",
                "with reference to production of 55Fe, 54Mn and 51Cr"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.Al-Abyad",
                "I.Spahn",
                "S.M.Qaim"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2GERJUL",
                "3EGYCAI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ARI,68,2393,2010",
                "code_unit": [
                  {
                    "unit": "J,ARI,68,2393,2010",
                    "doi": "10.1016/j.apradiso.2010.06.013",
                    "field": {
                      "reference_type": "J",
