          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural lithium targets, with thicknesses ranging from",
                "20 to 230 micro-g/cm2, prepared by vacuum evaporation",
                "onto tantalum cups.  these targets were 8 to 95 keV",
                "thick to 800 keV deuterons."
              ]
            }
          ],
