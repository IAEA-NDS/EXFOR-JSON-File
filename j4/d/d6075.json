          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of the 233-Pa (n, f) reaction cross",
                "section from 11.5 to 16.5 MeV neutron energy by the",
                "hybrid surrogate ratio approach"
              ]
            }
          ],
