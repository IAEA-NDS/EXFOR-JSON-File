              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New cross section data on 68Zn(p,2n)67Ga and",
                "natZn(p,xn)67Ga nuclear reactions for the development",
                "of a reference data base"
              ]
            }
          ],
