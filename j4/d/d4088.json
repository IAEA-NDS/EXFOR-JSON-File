          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Zn foils (51.83 micrometer) with natural isotopic",
                "composition and enriched 68Zn targets made by constant",
                "current electrolysis on high purity 49.4 micrometer Cu",
                "backing. Target thickness was 47.8-48.8 micrometer.",
                "Isotopic composition of the target material:",
                "       64Zn      0.65 +/-0.02 %",
                "       66Zn      0.54 +/-0.01 %",
                "       67Zn      0.32 +/-0.01 %",
                "       68Zn      96.95 +/-0.05 %",
                "       70Zn      1.54 +/- 0.02 %"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Stacks containing several 68Zn target foils and",
                "natural Zn, Cu, Al, W foils as energy degrader were",
                "irradiated by 33.7 and 35 MeV proton beams for abot",
                "half an hour."
              ]
            }
          ],
