          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural silver target, thicknesses:",
                "0.0524 g/cm2 (Sendai) and 0.0084 g/cm2 (Brussels)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Two stacks were irradiated.",
                "Composition of the stacks: several identical groups",
                "of Al-Cd-Ag-Pt-Ir-Cu foils (Sendai) and",
                "of Ag-Ti foils (Brussels).",
                "Primary energies of the deuteron beams: 40, 21 MeV,",
                "beam intensities: 140, 200 nA,",
                "irradiation times: 27 min, 1 h,",
                "measurements started: 20 and 0.5 h after the end of",
                "bombardment in Sendai and Brussels, respectively.",
                "Each sample was measured three times after the",
                "irradiation.",
                "Nondestructive measurement without chemical separation.",
                "Energy losses in the sample foils and stopping powers",
                "were calculated using the SRIM-2003 code."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The data were corrected for the coincidence summing",
                "effect caused by the coincidental detection of two or",
                "more gamma-rays in cascade by using the SUMECC code.",
                "The beam losses along the foils in stack due to",
                "multiple scattering are negligibly small."
              ]
            }
          ],
          "DECAY-DATA": [
