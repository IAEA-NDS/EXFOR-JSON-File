          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 89Y target foil of thickness 200 ug/cm2,",
                "evaporated on Al backing of thickness 1.92 mg/cm2,",
                "was used for irradiation.",
                "The thickness of the Al-catcher foils ranged from",
                "93 to 144 ug/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The evaporated residues trapped in different",
                "catcher foils was carried out using a pre-calibrated",
                "high purity germanium (HPGe) detector having active",
                "volume 100 cc coupled to a computer-automated",
                "measurement and control (CAMAC) based data",
                "acquisition system.",
                "The resolution of the HPGe detector was found to be",
                "2.5 keV for 1408 keV gamma-ray from the 152Eu source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The beam was collimated to a spot of diameter",
                "8 mm and the stack was irradiated with beam current",
                "varying between ~ 25 and 30 nA for ~ 9 hours."
              ]
            }
          ],
