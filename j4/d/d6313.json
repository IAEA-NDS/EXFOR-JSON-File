          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting 93Nb target foils of thickness ~ 1.6",
                "mg/cm2.",
                "Aluminum catcher foils of thickness ~1 mg/cm2 were used",
                "with each target foil to stop the recoiling residues."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " Three Si surface barrier telescopes",
                "of thicknesses delta E ~ 15-30 um, E ~ 300-5000 um,",
                "were placed inside the scattering chamber at 35, 45",
                "and 70 degree for the detection of charged particle",
                "around the grazing angle."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " One Si surface barrier detector of thickness",
                "~ 300 um was fixed at 20 degree to monitor Rutherford",
                "scattering for absolute normalization purposes."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The off-line gamma ray counting was done using",
                "an efficiency calibrated HPGe detector. The in-beam",
                "gamma counting was done using the Indian National Gamma",
                "Array (INGA) consisting 18 Compton suppressed HPGe",
                "clover detectors."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Sources of error on data points were due",
                "to statistics, gamma-ray detection efficiency, and",
                "spectroscopic information of the residues.",
                "For off-beam measurements, uncertainty in the target",
                "thickness was also included."
              ]
            }
          ],
