          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "53-I-127",
                "field_identifier": "NAT",
                "value": 1.0
              },
              "free_text": [
                " For target production a KI",
                "compound was used. The targets were made by vacuum",
                "evaporation from  a Mo boat onto 2 micron thick",
                "aluminum foils. The thickness of the KI targets was",
                "between 106 and 507 micro-g/cm2, corresponding to about",
                "5.3 E17 and 24.0E 17 I atoms/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "LEGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA",
                "ACTIV",
                "EXTB",
                "GSPEC"
              ],
              "free_text": [
                " The KI targets were irradiated",
                "with alpha beams from the MGC20 cyclotron of ATOMKI.",
                "Energies were in the range of 9.81 <= Ea<=15.5 MeV,",
                "covered in steps of about 0.5 MeV.",
                "The typical beam current was between 0.1 and 0.6 microA",
                "The length of each irradiation was between 0.92 and",
                "24 h, corresponding to about 2.7 E15 and 2.7 E17 total",
                "incident alpha particles.",
                "The current integrator counts were recorded in",
                "multichannel scaling mode, stepping the channel every",
                "minute to take into account the changes in the beam",
                "current."
              ]
            }
          ],
          "ERR-ANALYS": [
