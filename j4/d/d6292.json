          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Indium samples of thickness 13 mg/cm2 were",
                "prepared by the rolling method."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
