          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "EXTB",
                "GSPEC"
              ],
              "free_text": [
                " A stack of four samples of",
                "Indium, along with aluminium degraders were irradiated",
                "using proton beam, of energy 22 MeV and an average",
                "current of 23 nA, for 1.28 h. Mean energy incident on",
                "each sample was 21.82, 17.68, 12.68 and 8.61 MeV",
                "respectively."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The beam current was monitored continuously",
                "through current integrator connected to the Faraday",
                "cup kept behind the target stack, and used to",
                "determine the proton flux."
              ]
            }
          ],
