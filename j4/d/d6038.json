          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For the excitation function measurements,",
                "self-supporting metal foils of thulium having",
                "thickness around 0.6 mg/cm2 backed by 1.5 mg/cm2",
                "thick aluminium catcher foils were bombarded with",
                "16-O beam."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "3INDNSD"
              },
              "free_text": [
                " Pelletron accelerator"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " The irradiations were carried out in the",
                "General Purpose Scattering Chamber (GPSC) of 1.5 m",
                "diameter having an in-vacuum transfer facility.",
                "The beam current was 30-50 nA. The targets of 169Tm",
                "backed by an Al-catcher were placed normal to the beam",
                "direction so that the recoiling nuclei coming out of",
                "the target may be trapped in the catcher foil. Keeping",
                "in view the half lives of interest, the irradiations",
                "were carried out for <8 hours duration each."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The total charge collected in the Faraday cup",
                "has been used to calculate the flux of the beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The activities induced in various samples were",
                "recorded by counting the target and catcher foils",
                "together using a HPGe g-ray spectrometer coupled to the",
                "PC based multichannel analyzer."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "RANGE"
              ],
              "free_text": [
                "",
                "Complete and incomplete fusion cross sections for some",
