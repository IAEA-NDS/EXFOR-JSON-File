          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Complete and incomplete fusion reactions in the",
                "16O+169Tm system:Excitation functions and recoil",
                "range distributions"
              ]
            }
          ],
          "AUTHOR": [
