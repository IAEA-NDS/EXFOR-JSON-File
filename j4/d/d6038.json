              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,70,044606,2004",
                "code_unit": [
                  {
                    "unit": "J,PR/C,70,044606,2004",
                    "doi": "10.1103/PhysRevC.70.044606",
                    "field": {
