          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Solid-state TiN targets were prepared by reactive",
                "sputtering onto thick Ta backings.",
                "Targets with thicknesses of 100, 200, and 300 nm",
                "were used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The targets were irradiated by proton beams of",
                "about 5 uA on target. The energy range between 600 and",
                "1500 keV was covered with 50-100 keV energy steps."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                " Single target irradiation was performed with",
                "with a cyclic activation. Each irradiation lated for",
                "5 min which was followed by a 10- or 20-min beam-off",
                "period used for decay counting."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The 511-keV positron-annihilation gamma",
                "radiation following the 15O decay was measured."
              ]
            }
          ],
