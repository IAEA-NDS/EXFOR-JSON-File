          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1st run (Ep=34.41 MeV):",
                " Four natLi foils (550 um declared thickness, 92.67%",
                " of 7Li) interleaved by natCu foils (25 um declared",
                " thickness, 99.9% pure) serving as monitors of proton",
                " flux and energy, and natTa foils (50 um declared",
                " thickness, 99.9% pure) serving as proton energy",
                " degraders.",
                "2nd run (Ep=25.08 MeV):",
                " 7Li foil (~500 um thick) followed by the stack",
                " identical to the one used in the 1st run.",
                "3rd run (Ep=19.16 MeV):",
                " 7Li foil (~500 um thick) followed by the stack",
                " identical to the one used in the 1st run but without",
                " Ta foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " The energy of reaction in subsequent foils was",
                " calculated by using SRIM 2008 code."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for",
                " 1st run: 2860.9 sec with Imean=0.0986 uA;",
                " 2nd run: 2963.9 sec with Imean=0.101 uA;",
                " 3rd run: 2310.0 sec with Imean=0.109 uA."
              ]
            }
          ],
