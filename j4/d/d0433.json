          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three stacks containing high purity natural Ti foils",
                " (> 99.9% pure). The stacks were irradiated in a",
                "Faraday cup with a secondary electron suppressor,",
                "which served also as target holder."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "STTA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The produced activity was measured with a",
                "HpGe-spectrometer about 30 min after the end of the",
                "irradiations without chemical separation. The detector",
                "relative efficiency was about 42%while its resolution",
                "was 1.9 keV at 1.33 MeV alpha-line of 60Co."
              ]
            }
          ],
