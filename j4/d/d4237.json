          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,JRN,285,491,2010",
                "code_unit": [
                  {
                    "unit": "J,JRN,285,491,2010",
                    "doi": "10.1007/s10967-010-0613-6",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "JRN",
