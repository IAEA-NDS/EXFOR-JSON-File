          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The isolation of 133Ba produced by proton-induced",
                " reactions on Cs using cation exchange chromatography"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
