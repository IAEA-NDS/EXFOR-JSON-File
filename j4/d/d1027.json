          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "52-TE-130",
                "field_identifier": "ENR",
                "value": 0.98
              },
              "free_text": [
                "",
                "Powdered Te added to a few-% solution of polyethylene",
                " in toluene, and poured in an Al cylinder placed on",
                " an Al foil."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "EDEG"
              ],
              "free_text": [
                " Targets in 30 mm diam. were compressed to",
                " a stack, consisting of 8 target and Al degraders",
                " between them."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for 5 hours"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two types of cross section calculations:",
                " 1) From the initial number of product nuclei at the",
                "    end of irradiation determined by fitting the decay",
                "    curve; or",
                " 2) From the area of one gamma line and the number of",
                "    decays during the measurment time.",
                "The ground and total excitation functions were",
                " obtained from the isomeric ratio and metastable state",
                " excitation functions."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for",
                " - current time variation for products with half-lives",
                "   smaller or comparable to the irradiation time",
                "   (132mI, 130gI, 131mTe)",
                " - sample thickness non-uniformity (correction factor",
                "   +10+/-11% determined experimentally)"
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "133mXe and 133gXe production cross sections in figures"
