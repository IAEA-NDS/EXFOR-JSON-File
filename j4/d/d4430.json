          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "100 mbar high purity (99.999%) 3He gas in a 41.9 mm",
                " long target chamber, closed by a 10 um Al entrance",
                " window and 10, 15, 20 1nd 25 um of exit windows",
                " depending on the energy of the produced 7Be."
              ]
            }
          ],
