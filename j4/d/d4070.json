          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "EXcitation function and yields for 11In production",
                "using 113-114-nat-Cd(p,xn)111In reactions with 65 MeV",
                "protons"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
