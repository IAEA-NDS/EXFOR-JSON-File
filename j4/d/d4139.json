          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New experimental data on excitation functions for",
                "practical applications of alpha induced nuclear",
                "reactions on Ta up to 30 MeV."
              ]
            }
          ],
