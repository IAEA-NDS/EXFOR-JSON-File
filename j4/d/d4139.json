          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Ta foils (8.6 microns)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked targets were irradiated",
                "with alpha beam of 20 and 36 MeV primary energy.",
                "Stacks contained Ta (8.6 microns) and Cu (7.6 microns)",
                "foils. Gamma spectrometry was used without chemical",
                "separation. Beam current was measured in Faraday cup",
                "and also monitored with reactions on Cu. Incident beam",
                "energy was determined by magnetic deflection and time",
                "of flight. Foils thickness was determined by measuring",
                "the weight and area of the samples. Nuclear data were",
                "taken from the Lund database",
                "http://nucleardata.nuclear.lu.se/",
                "Experimental data were assigned to the mid energy point",
                "in the target foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " GeLi and HpGe  gamma detectors"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Ziegler's stopping formula was used to",
                "estimate the energy and its uncertainty."
              ]
            },
