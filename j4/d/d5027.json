          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 100. mu-g/cm2 LiF target with a 99%enrichment of 6Li,",
                "evaporated onto a 40 mu-g/cm2 nicel foil was used ."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "EDE"
              ],
              "free_text": [
