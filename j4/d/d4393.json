          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity natural Sb and enriched (99.59%) 121Sb was",
                "was vacuum-evaporated onto 1.8 and 2.5 um Al backing.",
                "Target thickness was measured by RBS and PIXE methods."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                "  For gamma-ray counting"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LEGE"
              ],
              "free_text": [
                "  For X-ray counting"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "GSPEC",
                "SITA"
              ],
              "free_text": [
                "The targets were irradiated at",
                "11 different alpha-beam energies between 10.09 and",
                "16.00 MeV. For the 121Sb(a,g)125I reaction the energy",
                "range of 10.09-14.00 MeV was covered in 0.5 MeV steps.",
                "For few cases Al foil was used as an energy degrader.",
                "The irradiations was 24 h long and the beam current was",
                "limited to 1uA."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "Includes the energy calibration of the",
                "alpha beam and to the uncertainty of the energy loss",
                "in the target, which was calculated using the",
                "SRIM code."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The uncertainty on the cross-section was",
                "estimated by taking the square root of the sum in",
                "quadrature of all individual contributions, supposing",
                "equal sensitivities for the different parameters."
              ]
            },
