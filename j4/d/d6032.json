          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 235-U target of thickness 200-300 micro gram/cm*2",
                " deposited on thin aluminum backing was placed at the",
                " center of the general purpose scattering chamber."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The fission fragments were detected by two",
                " DeltaE(10-15 microns)-E(300-500 microns)surface",
                " barrier detector telescopes each of solid angle 0.7",
                " msr."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The fission cross section were obtained by integrating",
                " the measured  angular distribution. The fission cross",
                " section assumed to be same as the fusion cross",
                " section for this high fissility system as the",
                " evaporation residue cross section are negligible. The",
                " fusion excitation function thus obtain for the",
                " present reaction was compared with the theoretical",
                " values based on coupled-channels code CCDEF."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error bar include both statistical and",
                " least squares fit errors."
              ]
            }
          ],
