          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Titanium and lead foils (each 99.9% pure) of natural",
                " isotopic composition and thicknesses between 10 and",
                " 100 um were used as target materials.",
                "Aluminium and copper foils, employed as beam monitors",
                " and/or absorbers were also of 99.9% purity.",
                "Their thicknesses ranged between 20 and 500 um.",
                "The exact thickness of each foil was obtained by",
                " determining its area and mass.",
                "A total of six stacks were irradiated.",
                "Besides monitors and absorbers, three stacks contained",
                " only Ti foils, and one only Pb foils.",
                "The rest two stacks contained a mixture of Ti and Pb",
                " foils."
              ]
            }
          ],
