          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets used in the experiment were 50Ti (2%",
                "46Ti, 1.8% 47Ti, 17.8% 48Ti, 2% 49Ti, 76.4% 50Ti in",
                "the form of TiO2), 54Cr (0.11% 50Cr, 4.01% 52Cr,",
                "1.79% 53Cr, 94.1% 54Cr in the form of Cr2O3), and",
                "59Co (100% natural). They were prepared by",
                "evaporating these materials in vacuum on to thick Ta",
                "backing. The target thickness in all the three cases",
                "was 2 to 4 keV for 4-MeV protons"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR",
