              ],
              "free_text": [
                "",
                " Isobaric Analog Resonance"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fine structure measurement, Optical model and",
                "Hauser-Fesbach analysis, Srength function analysis"
              ]
            }
          ],
