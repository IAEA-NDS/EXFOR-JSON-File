          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BAF2"
              ],
              "free_text": [
                "Gamma-rays were detected in two arrays of BaF2",
                "detectors each consisting of a close-packed group of",
                "seven elements and surrounded by a plastic",
                "anticoincidence shield. Each detector element was 20",
                "cm long with a hexagonal cross section. The energy",
                "calibration of the detectors was done using the 4.44",
                "MeV, 6.13 MeV, and 15.1 MeV gamma-rays from the",
                "241Am-Be, 239Pu-13C sources and the 12C(p,p')",
                "reaction, respectively."
              ]
            }
          ],
