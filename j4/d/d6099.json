          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Some important aspects of fragment angular momentum",
                " in medium energy fission of 238-U"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.Naik",
                "S.P.Dange",
                "R.J.Singh",
                "S.K.Das",
                "R.Guin"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3INDTRM"
              ],
              "free_text": [
                " Radiochemistry Division"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,648,45,1999",
                "code_unit": [
                  {
                    "unit": "J,NP/A,648,45,1999",
                    "doi": "10.1016/S0375-9474(98)00639-3",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NP/A",
                        "number": null,
                        "volume": "648",
                        "part": null,
                        "issue": null,
                        "page": "45"
                      },
                      "date": 1999
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3INDVEC"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacks of natural uranium target foils (75 um thick)",
                " and aluminium catcher foil (25 um) thick"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for 5-15 minutes using an external",
                "  alpha particle beam in the energy range of 25-44 MeV.",
                " The beam current of 1-2 uA during irradiation was",
                "  measured using a Faraday cup."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "RCHEM",
                "REC"
              ],
              "free_text": [
                " After the irradiation, the aluminium",
                "  catcher foil for each uranium foil facing the beam",
                "  was dissolved.",
                " Tellurium and iodine were separated radiochemically",
                "  from the dissolved solution within 5-15 min from the",
                "  end of the irradiation."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Standard aliquots of purified tellurium and",
                "  iodine samples were counted for optimum durations as",
                "  a function of time at a fixed geometry on an energy",
                "  and efficiency calibrated 90 cc HPGe detector",
                "  coupled to a 4 K multichannel analyser in live time",
                "  mode.",
                " Counting was carried out over a period of three half-",
                "  lives to confirm the purity of the individual",
                "  photopeak of the concerned radionuclide."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The resolution of the detector system was 2.0",
                "  keV at 1332.0 keV and the dead time during the",
                "  counting was always less than 10% to avoid the pile-",
                "  up effect."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
              "coded_information": [
                "MISC"
              ],
              "free_text": [
                " fission fragment angular momenta (Jrms)"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photopeaks were corrected for the Compton background."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Including the errors due to",
                "  - counting statistics",
                "  - absolute abundances of the gamma lines",
                "  - detector efficiencies",
                " (as well as those associated with the cumulative",
                "  yield of the precursor.)"
              ]
            }
          ],
