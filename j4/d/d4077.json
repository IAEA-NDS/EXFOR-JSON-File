          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Normal high resolution gamma-spectrometry was applied.",
                "Counting periods between two hours and seven days were",
                " applied."
              ]
            }
          ],
