          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural 159Tb targets of thickness ~ 1.2-2.5",
                "mg/cm2 and aluminium-catcher foils of thickness ~",
                "1.5-2.5 mg/cm2 were prepared by using the rolling",
                "technique. The Al foils of suitable thickness have",
                "been used for degrading the energy of incident beam",
                "and for catching the recoiling residues."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The radioactivity induced in the target-",
                "catcher foil assemblies were recorded by a",
                "pre-calibrated high resolution HPGe detector coupled",
                "to a CAMAC-based data acquisition system."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "BCINT",
                "EDEG"
              ],
              "free_text": [
                " The irradiations were carried",
                "out for ~8-10 h for each stack."
              ]
            }
          ],
