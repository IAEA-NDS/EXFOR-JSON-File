          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of excitation functions for production of",
                "cerium radioisotopes by deuteron induced reactions on",
                "natural cerium for nanobioscience applications"
              ]
            }
          ],
          "AUTHOR": [
            {
