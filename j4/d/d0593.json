          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The experimental cross sections were determined from",
                "the gamma-ray spectra using the activation formula",
                "for thin foils/disks"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The cross section uncertainty was deduced",
                "by considering the uncertainty of:",
                "   * the disk thickness,",
                "   * the deuteron current and the activity measurement",
                "and by including the uncertainty in the intensities of",
                "the different gamma-ray peaks"
              ]
            }
