          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting Niobium foils of purity 99.99% and",
                "2.3 to 3.2 mg/cm2 thickness. The niobium and 27Al",
                "foils of thickness 1.5 mg/cm2 were mounted on an",
                "aluminum ring of 12 mm inner and 22 mm outer diameter",
                "with 0.5 mm thickness. Niobium targets backed by Al",
                "foils were arranged in a stack, and six such Nb-Al",
                "foil stacks were irradiated individually."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Falcon 5000 broad energy germanium based",
                "detector. The energy resolution of the detector was",
                "less than equal to 2.0 keV at 1332 keV energy."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " A total of six target stacks were irradiated",
                "separately, varying the incident energy, with an",
                "overlap between them."
              ]
            }
          ],
