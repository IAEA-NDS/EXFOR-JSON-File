            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "47-AG-107",
                "field_identifier": "ENR",
                "value": 0.995
              },
              "free_text": [
                " Natural silver and isotopically",
                "enriched 107Ag targets were produced by vacuum",
                "evaporation onto high purity thin aluminum foils",
                "  (from 1.8 to 2.5 micron). The thickness of the",
                "targets varied between 0.410 mg/cm2 and 1.042",
                "mg/cm2, determined by weight measurement."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC",
                "EDEG",
                "SITA",
                "EXTB"
              ],
              "free_text": [
                " The reaction cross",
                "sections of 107Ag(a,g)111In and 107Ag(a,n)110In were",
                "determined in energy ranges Ecm=7.79-12.50MeV and",
                "Ecm=8.57-12.50MeV respectively by using activation",
                "technique. Some beam energies could not be produced",
                "by the cyclotron, therefore, aluminum and nickel",
                "energy degrader foils were used. During the",
                "irradiation the target stability was monitored by an",
                "ion-implanted Si detector, placed at 165deg relative",
                "to the beam direction. Typical beam current was",
                "150-800nA. After each irradiation the target was",
                "transported to a low-background counting setup. The",
                "activity of targets was measured with a HPGE detector",
                "equipped with 4pi, 10 cm thick lead shielding."
              ]
            }
          ],
