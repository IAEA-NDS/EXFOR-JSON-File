          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "68-ER-162",
                "field_identifier": "ENR",
                "value": 0.258
              },
              "free_text": [
                "The targets were made by",
                "reductive vacuum evaporation of Er2O3 powder enriched",
                "to 25.8% in 162Er onto 2 mm thick, high purity Al",
                "foils. The Er2O3 powder was mixed with Zr powder and",
                "placed into a C crucible heated by electron beam. The",
                "target thicknesses were between 114 and 188 mg/cm2.",
                "The Zr contamination was always below 4 atom%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "LEGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC",
                "SITA",
                "EXTB"
              ],
              "free_text": [
                " The reaction cross sections",
                "of 162Er(a,g)166Yb and 162Er(a,n)165Yb were",
                "determined in energy ranges Ecm=11.21-16.09MeV and",
                "Ecm=12.19-16.09MeV respectively. In both cases",
                "activation technique was used. After the irradiation,",
                "a waiting time of 0.25 h was used. The activity of",
                "targets was measured with a Low Energy Photon",
                "Spectrometer (LEPS). Typical duration of the counting",
                "was about 150-160 h. Due to the short half-life of",
                "165Yb, the (a,n) cross section was determined from",
                "the decay of its daughter (165Tm)."
              ]
            }
          ],
