          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "BCINT",
                "EDEG",
                "EXTB",
                "GSPEC",
                "MOSEP",
                "STTA"
              ],
              "free_text": [
                "",
                "High purity Au foils (99.95%), electroplated with",
                "enriched 64Ni layers, were stacked together with",
                "natural titanium (12.5 micron +- 5%) monitor foils.",
                "Irradiations for 1 hour using a proton beam with an",
                "intensity of 100 nA, in a faraday cup like target",
                "holder was done. The initial estimations of the",
                "incident beam energy for the three irradiations were,",
                "based on accelerator parameters settings, 16 MeV,",
                "15.3 MeV (same beam, 100 micron Al degrader foil)",
                "and 25 MeV, respectively.",
                "The SRIM 2006 code was used for estimation of the",
                "energy degradation in each foil of the stacks."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "22-TI-0(P,X)23-V-48,,SIG",
                  "code_unit": [
                    {
                      "unit": "22-TI-0(P,X)23-V-48,,SIG",
                      "field": {
                        "reaction": "22-TI-0(P,X)23-V-48",
                        "target": "22-TI-0",
                        "projectile": "P",
                        "process": "X",
                        "product": "23-V-48",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "A down shift of 0.5 MeV in the nominal incident",
                "energy and a 5% correction in the particle flux were",
                "necessary to be applied."
              ]
            }
          ],
