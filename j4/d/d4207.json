          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The incident energies were estimated at",
                "15.5 MeV, 14.8 MeV and 24.5 MeV, respectively, with",
                "an uncertainty of +-0.1 MeV. Due to the variations",
                "in foil thickness and energy spread, the uncertainty",
                "in the median energy estimation is increasing along",
                "the stack, reaching at a maximum of 2.2 MeV in the",
                "last foil of the longest stack."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
