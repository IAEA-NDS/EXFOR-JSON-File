          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mass distribution in 12C induced fission of 232Th"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.B.Manohar",
                "A.Goswami",
