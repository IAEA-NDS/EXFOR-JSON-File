          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples of l44Sm isotopically enriched to 94.5 % were",
                "obtained as oxides and reduced by lanthanum to",
                "samarium metal. The 144Sm metal was then evaporated",
                "in vacuum thin carbon foils. The target thickness was",
                "approximately 200 mu-g/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SOLST",
                "SOLST"
              ],
              "free_text": [
                " Solid state counter telescope",
                "consisting of a 50 mu-m thick dE counter and",
                "200 mu-m thick E counter."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The measurements were continued in a single",
                "gap magnetic spectrograph with photographic plate",
                "recording. The magnetic spectrograph was used for more",
                "precise Q-value and cross-section determinations and",
                "also to check the counter telescope measurements."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam current was measured by a Faraday cup",
                "behind the target."
              ]
            }
          ],
