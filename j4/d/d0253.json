          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A melamine (C3H6N6) target. The initial thickness of",
                "the target was measured to be 260+-68 mg/cm2 by",
                "scanning with well collimated alpha-particle sources of",
                "241Am, 238Pu, and 244Cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "EDE",
                "SITA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SILI"
              ],
              "free_text": [
                " Reaction products were observed by",
                "a pair of dE-E telescopes consisting of 250-mu-m-thick",
                "surface barrier detectors and 3000-mu-m-thick Si(Li)",
                "surface detectors. One telescope was fixed at 19 degr.",
                "for monitoring purposes, while the other was rotated",
                "around the target and measured the reaction products",
                "at lab. angles between 6.5 and 70 degr.",
                "The target thickness was monitored continuously during",
                "the experiment by a Si detector telescope placed at a",
                "fixed angle 19 degr."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " By accounting for the target thickness",
                "changes, it was possible to maintain a precision of",
                "+-4.4% for the measured absolute diff. cross sections."
              ]
            }
          ],
