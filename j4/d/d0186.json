          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New Results for reaction cross sections of intermediate",
                "energy alpha-particles on targets from 9Be to 208Pb"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
