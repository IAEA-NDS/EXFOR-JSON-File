          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2SWDUPP"
              },
              "free_text": [
                " A well-collimated, momentum analyzed",
                "alpha-particle beam from the Gustaf Werner cyclotron"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "INTB"
              ],
              "free_text": [
                " A series of target-in and target-out",
                "measurements, each consisting of about 5 x 10**6",
                "incident alpha-particles, was performed."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " Two thin passing scintillator",
                "detectors worked in coincidence; two annular",
                "scintillator detectors."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "CSICR"
              ],
              "free_text": [
                " Beyond the target wheel was the",
                "stopping detector telescope consisted:",
                " - a set of three plastic scintillator detectors.",
                "The first was circular with a diameter of 5.24 mm,",
                "while the second and third detectors were ring shaped",
                "with inner and outer diameters of 4.30-7.35 mm and",
                "6.65-8.77 mm, respectively.",
                "- a CsI-detector of a specific thickness at each",
                "energy."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " * Various corrections were made on elastic",
                "scattering that did not registed by detectors used",
                "in the experiment (see the text of the paper).",
                " * The results were also corrected for the limited",
                "angular acceptance of the detector system.",
                " * Corrections due to finite target thickness and",
                "finite beam size were estimated to be negligible."
              ]
            }
          ],
          "ERR-ANALYS": [
