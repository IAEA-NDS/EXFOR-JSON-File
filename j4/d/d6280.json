              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supported 27Al target of thickness ~100 ug/cm2",
                " was used for the measurement at 8, 10, 12, 14 and",
                " 16 MeV, and ~220 ug/cm2 for the measurement at 9 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " Three telescopes (delta E-E) of",
                " Si surface barrier detectors of thicknesses 22 um +",
                " 1.5 mm, 17 um + 1 mm and 15 um + 300 um respectively",
                " with a separation of 10 degree have been used.",
                "The solid angle subtended by each telescope was about",
                " 0.5 msr."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two Si surface barrier detectors of thickness",
                " 300 um were kept at +-20 degree with respect to beam",
                " direction to measure Rutherford scattering for the",
                " purpose of normalization."
              ]
            }
          ],
