          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity, nominally 27 micron thick Ho target foils."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "67-HO-165",
                "field_identifier": "NAT",
                "value": 1.0
              },
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "EDEG",
                "GSPEC",
                "MOSEP",
                "STTA"
              ],
              "free_text": [
                " Two stacks",
                "containing Ho target and Ti monitor foils were",
                "irradiated with 40 MeV alpha beam.",
                "Beam intensity: 85 and 110 nA",
                "Irradiation time: 1.0 hour",
                "No chemical separation was done. HPGe",
                "gamma-spectrometers were used to determine the",
                "activities of the irradiated foils. The energy",
                "degradation in the stack was calculated from the",
                "incident energy and foil thicknesses using a polynomial",
                "approximation of the stopping power."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "22-TI-0(A,X)24-CR-51,,SIG",
