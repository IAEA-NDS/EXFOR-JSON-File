          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The cumulated uncertainties of mean energy in",
                "the stacks were estimated taking into account the",
                "uncertainties on incident alpha-particle energy and on",
                "foil thicknesses as well as beam straggling.",
                "The uncertainties change from 0.2 to 1.1MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The uncertainties were estimated in the",
                "standard way: the relative uncertainties of the",
                "linearly contributing processes were quadratically",
                "summed and its square root was taken."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "THEO"
              ],
              "free_text": [
                " The experimental data were compared to the",
                "results of the theoretical model codes",
                "ALICE-IPPE and EMPIRE-II."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
