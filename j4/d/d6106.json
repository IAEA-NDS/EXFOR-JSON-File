                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self supporting natural indium was bombarded with",
                "energetic 12-C ions of energies 66, 72, 80 and 84 MeV",
                "from Pelletron accelerator"
              ]
            }
          ],
