          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self supporting natural indium (115In = 95.7%). The",
                "target thickness was measured by the energy-loss method",
                "to be 220 microgram/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                "Three surface barrier silicon",
                "detector telescopes were set up on movable arms inside",
                "a 1 m diameter scattering chamber for the determination",
                "of charge, mass and energy of the ejectiles. The",
                "telescopes employed 15-30 micrometer-delta E detectors",
                "and 300 micrometer-E detectors. A monitor detector was",
                "mounted at 15 degree with respect to the beam direction",
                "for obtaining absolute cross sections."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
