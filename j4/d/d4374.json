          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross-section data for alpha-particle",
                "induced nuclear reactions on natural ytterbium for",
                "some longer lived radioisotopes"
              ]
            }
          ],
