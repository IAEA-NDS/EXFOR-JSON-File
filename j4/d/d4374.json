          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "EDEG",
                "GSPEC",
                "MOSEP",
                "STTA"
              ],
              "free_text": [
                "",
                "Stack1 and stack2 contained ten and eight high purity",
                "ytterbium foils, respectively, interloaded with Ti",
                "monitor foils.",
                "An Al degrader was placed at the front of stack2 to",
                "ensure a small energy shift in the successive Yb foils",
                "of the two stacks.",
                "Incident alpha energy: 39 MeV,",
                "beam currents: 137 and 128 nA,",
                "irradiation times: 90 min in both cases.",
                "No chemical separation.",
                "The data acquisition started 1 year after the end of",
                "bombardment."
              ]
            }
          ],
