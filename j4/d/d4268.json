          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "EDEG",
                "GSPEC",
                "MOSEP",
                "STTA"
              ],
              "free_text": [
                " The first Si",
                "target was 233 mg/cm2 while the rest of the Si",
                "targets were 66.4 mg/cm2 thick, interleaved with 26.9",
                "micron thick high purity Al foils for monitoring. The",
                "drawback of using Al in this experiment is that the",
                "three nuclides of interest (7Be, 22Na and 24Na) are",
                "formed in both Al and Si and that mutual recoil",
                "exists between all the foils present. Careful",
                "correction for recoiled nuclei was taken. The",
                "irradiation took place under vacuum, the beam current",
                "was kept constant at about 100 nA during 5100 s. The",
                "decay data taken from the on-line database NuDat 2."
              ]
            }
          ],
