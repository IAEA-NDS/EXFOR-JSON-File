          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The uncertainty on  the median energy in the",
                "foils is increasing along the stack and includes  the",
                "cumulative effects of incident beam energy (+-0.2 MeV),",
                "uncertainty on stopping in each foil due to thickness",
                " (5%) and  straggling effects. The overall estimation",
                "is an uncertainty of  0.2 MeV for the first foils",
                "increasing to +-2 MeV in the last foil where",
                "significant cross section values could be calculated."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The uncertainty on the cross section values",
                "are estimated in the  standard way following the",
                "recommendations of the ISO-guide [8],  and amount to",
                "10-12% taking into account the slightly higher"
              ]
            },
