          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute Resonance Strengths in the",
                "20,21,22Ne(p,g)21,22,23Na and 21Ne(p,p'g)21Ne Reactions"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Keinonen",
                "M.Riihonen",
                "A.Anttila"
