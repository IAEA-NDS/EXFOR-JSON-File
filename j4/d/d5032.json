              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,15,(2),579,1977",
                "code_unit": [
                  {
                    "unit": "J,PR/C,15,(2),579,1977",
                    "doi": "10.1103/PhysRevC.15.579",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "15",
                        "part": null,
