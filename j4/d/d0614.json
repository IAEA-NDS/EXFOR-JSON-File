          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For the main experiment,  a 500A MeV 86Kr primary",
                " beam with an intensity of up  to 10**9 particles per",
                " second was fragmented in a 1625 mg/cm2 9Be",
                " production target at the entrance of the FRS. The",
                " fragments of interest  were identified on an",
                " event-by-event basis and transported  to the",
                " intermediate focal plane of the FRS."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "R.Gernhaeuser (2010-09-15):",
                " 390 MeV/A was given as a good average energy.",
                " Note that,",
                " 48Ca before target: 410 MeV/A;",
                " 47Ca after target: 373.6 MeV/A;",
                " 56Ti before target: 405 MeV/A;",
                " 55Ti after target: 365.5 MeV/A."
              ]
            }
          ],
