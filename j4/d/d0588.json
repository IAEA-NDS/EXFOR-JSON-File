          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The enriched 192Os (99%) targets were prepared via",
                "electro-deposition onto 50 mu-m thick Cu foils. The",
                "thickness of the deposited layers varied between 2.94",
                "and 6.78 mg/cm2. The diameter of the osmium samples",
                "was 10 mm. One stack containing 15 pieces of 192Os",
                "foils together with thick Al degraders.",
                "The Cu backings and the Al degraders served",
                "also as monitors"
              ]
            }
          ],
