          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting Si target of thickness",
                "42.2+-1.3 mu-g/cm2. The target was prepared by",
                "evaporation onto a glass slide. The target thickness",
                "was measured by observing the yield of scattered",
                "alpha-particles at low bombarding energy (4.0 MeV and",
                "5.0 MeV) and at forward angles (15.-50.degr.) when the",
                "cross section is expected to be described by the",
                "Rutherford formula (report ANU-P/532)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The absolute error of the cross sections.",
                "The errors considered were due to statistics,",
                "background subtractions and the errors involved in the",
                "measurement of the target thickness, the solid angle",
                "and the collected charge."
              ]
            }
          ],
