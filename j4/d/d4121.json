          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets for cross section measurements were prepared",
                "by electrolytic deposition of 99.0% enriched 120Te on",
                "25 micron Ti foils. The target homogeneity was checked",
                "under microscope. The deposited Te (1.8-3.8 mg) was",
                "covered by 40 microg/cm2 Levaprene and 10 micron Al",
                "foil. Nine stacks were irradiated each containing 4",
                "or 5 Te samples and several Cu and Ti foils as energy",
                "degrader and monitor foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                "used. Stacks were irradiated at 20.5, 16.1 and 12.0 MeV",
                "with 100 nA for 20 min at the CV 28 cyclotron and at",
                "45.6 MeV at the injector of the COSY Cooler Synchrotron",
                "Beam current was determined by using natCu(p,x)62,63Zn",
                "and natTi(p,x)48V monitor reactions.",
                "No numerical monitor values are given.",
                "The energy degradation was calculated by the method of",
                "Williamson (1966). Decay data were taken from Browne",
                "and Firestone (1986)."
              ]
            }
          ],
