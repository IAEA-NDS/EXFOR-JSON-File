          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production cross-sections of residual radionuclides",
                "from proton induced reactions on natAg up to 40 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
