          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The products of the reaction were momentum",
                "analyzed by the the spectrograph and detected by a",
                "500-mu-m-thick surface barrier position-sensitive",
                "detector (PSD), with an area of 47 x 8 mm2, positioned",
                "on the focal plane.",
                "During the experiment, elastically scattered ions of",
                "6Li were continuously monitored by a surface barrier",
                "detector fixed at 27.5 degree."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative normalization of the inelastic cross sections",
                "was obtained from the number of elastically scattered",
                "particles detected by the monitor during each run.",
                "The absolute normalization, for each isotope, was",
                "obtained from the fit of optical model predictions to",
                "the experimental elastic angular distributions,",
                "measured on the same target and under similar",
                "conditions."
              ]
            }
          ],
