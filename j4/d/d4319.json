          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "30-ZN-64",
                "field_identifier": "ENR",
                "value": 0.9971
              },
              "free_text": [
                "",
                "The targets were prepared by vacuum evaporation onto",
                " 2 um thick Al foils and their thicknesses were",
                " determined by weighing and Rutherford backscattering",
                " spectrometry."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "SITA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "The irradiations were done with proton beams in the",
                " energy between 3.5 and 8 MeV with typical beam",
                " intensities of about 1 uA.",
                "The lengths of the irradiations varied between 0.5 and",
                " 12 h."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections were calculated from the well known",
                " activation formula with measured activity, particle",
                " flux and number of target nuclei as input parameters."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainty of the c.m. energies comes",
                " mainly from the beam energy calibration of the",
                " cyclotron."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The most important sources of cross section",
                " uncertainty are the normalization uncertainty of the",
                " relative gamma intensities 18.0% for 61Cu and 18.5%",
                " for 65Ga."
