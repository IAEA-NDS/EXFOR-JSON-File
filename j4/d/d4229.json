          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of the therapeutic radioisotope 114mIn",
                "through the 116Cd(p,3n)114mIn reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
