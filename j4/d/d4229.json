          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched 116Cd (97.4% 116Cd, 1.5% 114Cd,rest other",
                "stable Cd isotopes)"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
