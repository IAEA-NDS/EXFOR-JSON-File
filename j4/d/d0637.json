          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "2UK OXF"
              },
              "free_text": [
                " The experiment was carried out with a",
                "beam of 18 MeV  3He particles from the Tandem",
                "generator of the  Nuclear Physics Laboratory, Oxford."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target material was prepared by burning tungsten",
                "filament in  an atmosphere of oxygen enriched in 180.",
                "The oxide was then vacuum  deposited onto about",
                "10 mu-g/cm2 thick carbon foil and the target  was",
                "placed at the center of the Oxford multichannel",
                "magnetic spectrograph."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                "The reaction products were momentum analyzed",
                "under a magnetic field of  strength 10.83 kHz and",
                "recorded simultaneously in Ilford L4 plates 25 mu-m",
                "thick over the angles 11.25-86.25 degr. in steps of",
                "7.5 degr. Particles other than protons were stopped in",
                "approximately 0.34-mm-thick Mylar foil placed on top",
                "of each plate. The total beam charge was 3530 mu-C.",
                "The plates were scanned  at the Nuclear Physics",
                "Laboratory of the University of Dhaka, Dhaka and the",
                "energy spectrum is obtained at each angle."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "8-O-18(HE3,EL)8-O-18,,DA",
                  "code_unit": [
                    {
                      "unit": "8-O-18(HE3,EL)8-O-18,,DA",
                      "field": {
                        "reaction": "8-O-18(HE3,EL)8-O-18",
                        "target": "8-O-18",
                        "projectile": "HE3",
                        "process": "EL",
                        "product": "8-O-18",
                        "quantity": ",DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "8-O-16(HE3,EL)8-O-16,,DA",
                  "code_unit": [
                    {
                      "unit": "8-O-16(HE3,EL)8-O-16,,DA",
                      "field": {
                        "reaction": "8-O-16(HE3,EL)8-O-16",
                        "target": "8-O-16",
                        "projectile": "HE3",
                        "process": "EL",
                        "product": "8-O-16",
                        "quantity": ",DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " The target gas used in this",
                "experiment was an old sample and the abundance of 18O",
                "in the gas was rather uncertain. To obtain the",
                "absolute cross section scale, subsidiary short",
                "exposures were taken on the elastic scattering of 6",
                "MeV 3He particles from the same target as used in the",
                "main experiment. The yields of the elastic groups from",
                "16,18O at 78.75 and 86.25 degr. (lab.system) were",
                "measured and were assumed to be in the ratio of the",
                "abundances of the two isotopes. The yields of the",
                "levels leading to 18F at E-x =0.0, 0.937, and 1.120 MeV",
                "arising from the (3He,p) reaction on 160 in the",
                "main experiment were measured at several angles. The",
                "absolute cross sections for these levels are already",
                "known from a previous experiment at the same beam",
                "energy. Hence the absolute cross section was obtained",
                "for the 18O(3He,p)20F reaction."
              ]
            }
          ],
