          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,46,(6),2273,1992",
                "code_unit": [
                  {
                    "unit": "J,PR/C,46,(6),2273,1992",
                    "doi": "10.1103/PhysRevC.46.2273",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
