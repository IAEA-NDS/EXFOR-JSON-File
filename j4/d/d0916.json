                "institute": "3IRNNRT"
              },
              "free_text": [
                " Particle Induced Gamma-ray Emission, PIGE",
                " beamline (45 degree right) of the 3 MV Van de Graaff",
                " electrostatic accelerator"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " p-type HPGe detector with crystal size of 6.58",
                "cm x 6.58 cm active volume of 213 cm**3 positioned",
                "perpendicular to the beamline direction 5.2 cm from the",
                "the target center."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Ion-implanted silicon detector of 25 mm**2 active",
                "area, 300 um thickness, 13 keV energy resolution,",
                "positioned at the scattering angle of 165 degree."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The incident beam current was varied within 2 - 20 nA",
                "depending on the deuteron energy.",
                "The beam energy calibration of the accelerator was",
                "performed through the 27Al(p,g)28Si reaction at the",
                "991.88 keV resonance, and through the 7Li(p,n)7Be",
                "reaction at the threshold at 1880.44 keV.",
                "The spot size of the deuteron beam on the target",
                "was kept around 4 mm in diameter."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "NTRTH"
              ],
              "free_text": [
                " Deuteron Rutherford cross section from Au"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thick target: Sulfur powder pressed into 1 mm thick",
                "pellets with a diameter of 10 mm using a hydraulic",
                "press.",
                "Thin Au film: Vacuum deposited on the surface of",
                "the sulfur pellets.",
                "Thickness was about (50+/-3)x10**15 atom/cm**2",
                "determined by simulation of the collected RBS spectra."
              ]
            }
          ],
