          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity Pb foils (10 micron) as target material,",
                "Al (25 micron) and Cu (10 micron) monitor foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                "High purity Ge gamma spectrometer"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "BCINT",
                "EDEG",
                "EXTB",
                "GSPEC",
                "MOSEP",
                "STTA"
              ],
              "free_text": [
                "",
                "Stack containing Pb target and Al, Cu monitor foils",
                "with other metal foils used as energy degrader and",
                "target material in a parallel experiments was",
                "irradiated in a Faraday cup like target holder for",
                "half an hour at 100-130 nA with 40 MeV deuteron beam.",
                "HPGe spectrometers at large source-detector distances",
                "were used to assess the activity of the foils.",
                "No chemical separation was used.",
                "Measurement started 20 h after EOB and decay was",
                "followed for about one month.",
                "Elemental excitation functions were determined",
                "relative to the simultaneously re-measured",
                "natAl(d,x)22,24Na and natCu(d,x)65Zn monitor reactions."
              ]
            }
          ],
