          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,JRN,203,67,1996",
                "code_unit": [
                  {
                    "unit": "J,JRN,203,67,1996",
                    "doi": "10.1007/BF02060381",
                    "field": {
                      "reference_type": "J",
