          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "3He Induced Nuclear Reactions on 237Np Targets"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Aaltonen",
