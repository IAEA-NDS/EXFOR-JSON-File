          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The B-10 and F-19 targets were obtained by evaporating",
                "B-10 and CaF2 respectively onto a 100 mu-g/cm**2 thick",
                "Ni backing; the thickness of CaF2 was about",
                "120 mu-g/cm**2.",
                "The N-14, N-15 targets were obtained by evaporating Ti",
                "in atmosphere of N-14 and N-15 respectively on NaCl",
                "backing. This backing was dissolved in warm water and",
                "Ti-N foils were obtained; their thickness was about",
                "250 mu-g/cm**2."
              ]
            }
          ],
          "ADD-RES": [
