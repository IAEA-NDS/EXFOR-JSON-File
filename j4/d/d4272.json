          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "69-TM-169",
                "field_identifier": "NAT",
                "value": 100.0
              },
              "free_text": [
                "",
                "The thicknesses of the thulium targets, produced via",
                " vacuum evaporation onto 2 um thick high-purity Al",
                " backings, were 331 and 377 ug/cm2, corresponding to",
                " 1.18 E18  and 1.34 E18 atom/cm2, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "LEGE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "EXTB",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Primary beam energy was 13.0 MeV. An Al energy",
                " degrader foil was placed between the two thulium",
                " targets; the degrader foil thickness was determined",
                " by measuring the energy loss of alpha particles",
                " emitted by a 241Am radioactive source and by",
                " weighing. The energy losses in the thulium layer,",
                " in the backing, and in the energy degrader foil were",
                " calculated using the SRIM code."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The uncertainties given for the averaged values are",
                " the variances of the weighted means."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainty of the cross section is the",
                " quadratic sum of the following partial errors:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " HPGE detector efficiency    (6%);"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
