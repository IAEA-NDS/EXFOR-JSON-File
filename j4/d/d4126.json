          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets for cross section measurements were prepared by",
                "electrolytic deposition of 99.0% enriched 120Te on 25",
                "micron Ti foils. The target homogenety was checked",
                "under microscope. The deposited Te (1.8-3.8mg) was",
                "covered by 40microg/cm2 Levaprene and 10micron Al foil.",
                "Targets were same that were used in experiment 1998",
                "Exfor entry: D4121 (J,ARI,49,1493,1998)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Five stacks were irradiated",
                "each containing 4 or 5 Te samples with 100nA deuteron",
                "beam at 13.5+-0.2MeV primary particle energy. The",
                "natTi(d,x)48V reaction in the backing was used to",
                "monitor the beam. Stacks were irradiated for 20min at",
                "the Cv28 cyclotron.",
                "No numerical monitor values are given.",
                "The energy degradation was calculated by the method of",
                "Williamson (1966). Decay data were taken from Browne",
                "and Firestone (1986)."
              ]
            }
          ],
