          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions of 120Te(d,xn)121,120m,gI",
                "reactions from threshold up to 13.5MeV: comparative",
                "studies on the production of 120gI."
              ]
            }
          ],
