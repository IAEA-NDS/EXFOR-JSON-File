          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity natural foils, thicknesses:  Er 32.,",
                "Al 25.5, Ti 12. micron."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "EXTB",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Two stacks of 7 natural Er foils, interleaved with",
                "7 natural Ti monitor foils. In front of one of the",
                "two stacks an Al degrader foil was placed to ensure",
                "a small energy shift.",
                "Incident alpha energy: 38 MeV,",
                "beam currents: 119.5, 108.8 nA,",
                "irradiation times:  2.0, 2.6 h, respectively.",
                "No chemical separation.",
                "The spectra were registered on a PC-coupled HPGe gamma",
                "spectrometer. The acquisition started within 15 min",
                "after the end of bombardment. Each target foil was",
                "measured three times over a period of a month which",
                "rendered possible getting information about short and",
                "long half lived radionuclei and to follow cumulative",
                "processes as well."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                "",
                "The samples were placed at a proper distance from the",
                "detector to avoid pile-up effects and coincidence",
                "losses. The detector efficiency was determined",
                "carefully by using standard sources."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
