          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "25 micron of Cr/Ni alloy (73.1% Ni, 20.1% Cr, 2.6% Al,",
                " 2.0% Cu), 25 micron of Ni foils, and 9-29 mg/cm**2",
                " pure chromium samples prepared by electrolytic",
                " deposition on 20 micron gold foils.",
                "Several 50 and 100 micron thick Al foils and 12.5 and",
                " 20 microns of Ti foils were used as energy absorber",
                " and beam monitor."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "TABLE"
                ],
                "subentry_number": null,
                "author": null,
                "reference": null
              },
              "free_text": [
                " Table 2 of Radiochim.Acta 65(1994)207"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "EXTB",
                "GSPEC"
              ],
              "free_text": [
                "",
                " 25 MeV and 36 MeV primary He-3 particle energy.",
                " 4-8 Cr/Ni foils and some Ti foils were irradiated for",
                "  30 min and for 1-3 min at 100 nA.",
                " Pure Ni foils were irradiated to substract the",
                "  contribution of the reactions induced by He-3 beam",
                "  on nickel in the Cr/Ni alloy samples.",
                " 10 Stacks consisted of electroplated foil (Cr on Al),",
                "  Al absorbers and two monitor foils were irradiated",
                "  for 1 min at 200 nanoa to measure Fe-53 near the",
                "  threshold energy."
              ]
            }
          ],
