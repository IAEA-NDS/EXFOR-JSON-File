              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation function of He-3 particle induced nuclear",
                " reactions on natural chromium: Possibilities of",
                " production of Fe-52, Fe-53 and Mn-52 for medical use"
              ]
            }
          ],
