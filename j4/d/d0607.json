          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "By authors (received through S.Babykina, 2010-11-29):",
                " The uncertainties reported in the graphs made for the",
                " paper are large, due to the reduced statistics and",
                " some oversized systematic errors, increased to take",
                " into account the possible mismatch in the experimental",
                " acceptance assessment. These systematics are going to",
                " be reduced as soon as the complete data set, with",
                " improved acceptance for different settings, will be",
                " completely analysed.  We are working on that now."
              ]
