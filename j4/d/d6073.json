          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was enriched 208Pb (>98%) of thickness",
                "175 micro-gm/cm2. The 208Pb was evaporated on carbon",
                "backing with a backing thickness of about",
                "40 microgram/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                "Si surface barrier in",
                "delta-E(25 to 30 micrometer)-E(500 to 1000 micrometer)",
                "telescope configuration. Two such identical telescopes",
                "were placed symmetrically to the left and right of the",
                "incident beam at +-40.degr. and +-160.degr. to",
                "eliminate, in the first order, the effect due to",
                "possible beam wandering  and consequent changes",
                "in scattering."
              ]
            }
