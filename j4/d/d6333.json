          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Niobium foils (high purity >99.99%) of thickness 91",
                "um.",
                "Copper foils (high purity >99.99%) of thickness",
                "103 um.",
                "The size of the niobium foils were 0.7 X 0.7 cm2,",
                "whereas the copper foils were 0.8 X 0.8 cm2.",
                "The thickness of Al foil was ~108 um."
              ]
            }
          ],
