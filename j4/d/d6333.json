            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector connected to a PC-based 4K channel",
                "analyzer.",
                "The energy resolutions of the detectors were 1.8 keV at",
                "the 1332.5 keV gamma-ray of 60Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " The stack of the foils was irradiated",
                "with proton beam of 20 MeV for 30 minutes at beam",
                "current of 50 nA.",
                "The cooling time for niobium foil was 7.88 hours and",
                "for copper foils was 8.35 hours."
              ]
            }
