          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets in the form of Self-supporting foils of",
                "natural Bismuth metal were replaced by vacuum",
                "evaporation. The thickness of the two targets used,",
                "determined by the energy shift of Am-241 alpha peaks,",
                "where 1.00 and 2.33 mg/cm2. The target was located",
                "at the centre of the 90cm diameter scattering chamber."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier detectors of",
                "thickness 2mm and 3mm, subtending solid angles",
                "of 0.149 and 0.229 msr, respectively were used. The",
                "overall resolution was 200 keV."
              ]
            }
          ],
