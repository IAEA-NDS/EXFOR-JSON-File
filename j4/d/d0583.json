          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Five 88.6% enriched 144Sm targets, with thicknesses",
                "from 170 mu-g/cm2 to 220 mu-g/cm2 on carbon backings",
                "of 20 mu-g/cm2 were used. An aluminum catcher foil was",
                "placed a few mm behind target. Its thickness of",
                " 1.6-mg/cm**2 was chosen, such that it should stop the",
                "fusion residues but let the elastically scattered beam",
                "particles pass through."
              ]
            }
          ],
