          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Large pre-equilibrium contribution in A + nat.Ni",
                "interactions at ~ 8-40 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Abhishek Yadav",
                "Pushpendra P.Singh",
