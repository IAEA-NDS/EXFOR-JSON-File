              "coded_information": [
                "3INDMUA",
                "3INDCAU"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,78,044606,2008",
                "code_unit": [
                  {
                    "unit": "J,PR/C,78,044606,2008",
                    "doi": "10.1103/PhysRevC.78.044606",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "78",
                        "part": null,
                        "issue": null,
                        "page": "044606"
                      },
