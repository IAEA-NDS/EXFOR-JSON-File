          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nickel foils (purity ~99.99%) of thickness 101 um and",
                "dimensions 0.7 X 0.7 cm2.",
                "Copper foils (purity 99.99%) of thickness 99 um were",
                "sandwiched between the nickel foils.",
                "Each foil was wrapped with Al foil of 25 um thick to",
                "avoid contamination."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A high resolution HPGe detector connected to a",
                "PC based 4K channel analyser.",
                "The energy and efficiency calibration of detector was",
                "done using the 152Eu source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " The stack of foils was irradiated with a",
                "proton beam of 20 MeV in the main line at 6 m above",
                "the analyzing magnet of the Pelletron facility.",
                "The irradiation lasted for 10 min and the cooling time",
                "was 1.05-1.58 hours.",
                "The beam current is 100 nA."
              ]
            }
          ],
