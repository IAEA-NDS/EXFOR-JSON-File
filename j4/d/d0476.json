          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Failure of theWoods-Saxon nuclear potential to",
                "simultaneously reproduce precise fusion and elastic",
                "scattering measurements"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.Mukherjee",
                "D.J.Hinde",
