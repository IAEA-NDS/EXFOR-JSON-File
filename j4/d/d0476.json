              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,75,044608,2007",
                "code_unit": [
                  {
                    "unit": "J,PR/C,75,044608,2007",
                    "doi": "10.1103/PhysRevC.75.044608",
                    "field": {
