          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Cadmium is first electrodeposited on copper",
                " backing target.",
                "Copper is chosen as the substrate due to its suitable",
                " heat conduction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No information on detector"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "GSPEC"
              ],
              "free_text": [
                " Faraday cup"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In gamma spectroscopy spectroscopy the relative",
                " method is chosen.",
                "Taking into account the measured efficiencies for",
                " standard sources at different positions of the same",
                " geometry, the activities of radioisotopes for the",
                " prepared samples were measured by calculating the",
                " peak area in the recorded spectrum and using detector",
                " efficiencies and branching ratio values."
              ]
            }
          ],
