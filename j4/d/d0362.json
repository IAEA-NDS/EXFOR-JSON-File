          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uranium targets were prepared on 10 mu-m thick aluminum",
                "backings by multiple thermal decomposition of uranium",
                "nitrate. The isotopic composition of 234U, 235U, 236U",
                "and 238U in the uranium targets was approx. 0.001%,",
                "0.047%, 99.845% and 0.107%, respectively. The average",
                "thickness of the 236U layer was 100 mu-g/ cm2 and the",
                "variations in the thickness were within 3%. Seven",
                "uranium targets were placed in the multiple target",
                "system"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
