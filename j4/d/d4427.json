          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sm2O3 with natural isotopic abundances evaporated",
                "by an electron beam onto 6um Al backing.",
                "The areal density of the Sm atoms was measured with",
                "Rutherford backscattering spectrometry (RBS).",
                "Thickness of the five targets was in the range of",
                " (0.5-1.0)E+18 atoms/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "LEGE"
              ],
              "free_text": [
                " A thin crystal high-purity germanium detector",
                "optimal for the detection of low-energy g-radiation."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation was done in vacuum with 1 euA beam",
                "of alpha particles. The lengths of irradiations",
                "varied between 2 and 24hours."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                " Targets were irradiated one by one.",
                "Decay data were taken from the latest nuclear data",
                "compilation.",
                "The effective energy calculation is based on the",
                "energy loss of the beam in the target layer."
              ]
            }
          ],
