          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ". The total error of the cross sections was",
                "derived as the square root of the sum of square of the",
                "individual errors.",
                "-absolute activity 7 %",
                "-decay data: 3%",
                "-beam intensity: 8-20%",
                "total error was  about 11% in the experiments on",
                "isocyc, and 22% in the experiment on the  injector",
                "cyclotron."
              ]
            },
