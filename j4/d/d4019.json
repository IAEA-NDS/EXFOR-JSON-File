          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "EXTB"
              ],
              "free_text": [
                "incident primary proton energies:",
                "18 MeV at mgc-20e cyclotron debrecen",
                "21,17,12 MeV at cv28 cyclotron of kfa julich",
                "76.4 Mev H2+ ion beam of injector cyclotron of the",
                "cosy of kfa julich was converted to 32.2 Mev proton",
                "beam."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "electroplated highly enriched (99.51%) Tellurium-124",
                "on 20 microns of Ti backing foils. The 5-10 mg/cm**2",
                "tellurium-124 layer was covered by 10 micron Al foil.",
                "five stacks each consist of four or five samples and",
                "Cu monitor foils were irradiated for 0.75 To 3.0 Hour",
                "with 50 namp beam current. The degradation of the",
                "proton energy in the stacks was calculated according",
                "to C.F. Williamson et Al.,The decay data for the",
                "isotopes considered were taken from e. Browne and r.B.",
                "firestone, table of radioactive isotopes (ed. Shirley",
                "V.S.) Wiley, New York 1986, and U. Schotzig and H.",
                "schrader, ptb report, ra-16/4. The beam current was",
                "measured by using a Faraday cup. The beam current and",
                "the energy degradation along the stack were controlled",
                "by monitor reactions on Cu and Ti."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "evaluation of the various production routes for I-124"
              ]
            }
          ],
