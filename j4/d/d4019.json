          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions of Te-124(p,xn)I-123,124",
                "reactions from 6 to 31 MeV with special reference to",
                "the production of I-124 at a small cyclotron"
              ]
            }
