          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "self supporting targets were prepared by electron gun",
                "evaporation technique from 99% enriched metallic",
                "64-Ni isotope. Two different targets of thickness 61",
                "mu-g/cm2 and 376 mu-g/cm2 respectively, were used for",
                "the experiment."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                "The telescopes were set with 25 mu",
                "and 15 mu thick deltaE detectors and 300 mu thick",
                "E detectors to detect the scattered particles.In",
                "the second part the deltaE detectors of thickness",
                "15 mu and 10 mu were used and these were followed",
                "by 3 mm and 500 mu E detectors, respectively.",
                "Two monitor detectors of thickness 3 mm were",
                "mounted at + - 15 deg about the beam",
                "axis at a distance of 41.7 cm in a 1m diameter",
                "scattering chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "BCINT"
              ],
              "free_text": [
                " The current was measured using a Current",
                "Integrator, the output of which was fed into a CAMAC",
                "Scaler to obtain the integrated charge."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "6-Li"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "WSP"
              ],
              "free_text": [
                "Optical model analysis was carried out using",
                "three different model potentials using parametric",
                "Woods-Saxon and folded M3Y forms, forms for both the",
                "real and imaginary potentials."
              ]
            }
          ],
