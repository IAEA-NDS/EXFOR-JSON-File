                "3EGYCAI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RCA,94,391,2006",
                "code_unit": [
                  {
                    "unit": "J,RCA,94,391,2006",
                    "doi": "10.1524/ract.2006.94.8.391",
                    "field": {
