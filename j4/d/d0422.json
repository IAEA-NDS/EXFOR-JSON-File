          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3SARRIY"
              },
              "free_text": [
                " TCC CS-30 cyclotron of King Faisal",
                "Specialist Hospital and Research Centre (KFSH&RC) in",
                "Riyadh, Kingdom of Saudi Arabia."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin natural copper foils were used in a stacked form",
                "for the excitation function measurements. They were",
                "about 99.99% pure and each foil was 10 mm in diameter.",
                "Three stacks each with 10-13 copper foils and some",
                "aluminum degraders were irradiated separately.",
                " The thickness of the foils was 10 mu-m for Cu",
                "and 50 or 127 mu-m for Al."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activity of the produced radionuclides was",
                "measured with a HpGe- spectrometer (with an absolute",
                "efficiency of about 42%)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "STTA"
              ],
              "free_text": [
                " used Faraday cup.",
                "The measured cross-sections for all the contributing",
                "reactions derived from the three separate irradiations",
                " (with some energy overlapping points) were then",
                "compared to each other and gave satisfactory",
                "coinciding values."
              ]
            }
          ],
