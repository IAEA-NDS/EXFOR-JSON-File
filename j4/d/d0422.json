          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions of proton induced nuclear",
                "reactions on natural copper using a medium-sized",
                "cyclotron"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "F.S.Al-Saleh",
                "A.A.Al-Harbi",
                "A.Azzam"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
