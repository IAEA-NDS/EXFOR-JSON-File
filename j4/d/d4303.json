          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross sections for production of 7Be by",
                "proton and deuteron induced reactions on 9Be: Protons",
                "up to 65 MeV and deuterons up to 50 MeV"
              ]
            }
          ],
