          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin Be target, thickness 116-285 um."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "4-BE-9",
                "field_identifier": "NAT",
