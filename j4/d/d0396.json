          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Asymptotic normalization coefficients from the",
                "20Ne(3He,d)21Na  reaction and astrophysical factor",
                "for 20Ne(p,gamma)21Na"
              ]
            }
          ],
