          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " An array of eight silicon surface barrier",
                "detectors placed inside a 30-inch-diam. scattering",
                "chamber was used to measure the angular",
                "distributions, which were taken in steps of 2. or",
                "5.degr., depending on the bombarding energy and angular",
                "range. The angular resolution of all the detectors was",
                "better than 0.5 degr. and their energy resolution",
                "ranged from 0.5 to 1.3%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " Typical beam currents were below 50 nA."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " An electron suppressed Faraday cup and a"
              ]
            }
          ],
