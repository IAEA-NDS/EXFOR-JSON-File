          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were prepared by cutting a 1 cm x 1 cm",
                "piece of high purity (99,99%) bismuth foil supplied by",
                "Goodfellow, with a thickness of 0.25 mm, which",
                "corresponds to a thick target. The target was enveloped",
                "in  aluminum foil (14 mu-m thickness) to avoid loss of",
                "activity by recoil or evaporation, due to the fact",
                "that astatine is very volatile."
              ]
            }
          ],
