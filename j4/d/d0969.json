          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterons implanted into two Ti sheets, and their",
                " depth profiles were studied by 2H(3He,p)4He reactions.",
                " - Thick sample irradiated by proton beam at 260 keV",
                "    for cross section below 163 keV.",
                " - Thin sample irradiated by proton beam at 260 to",
                "    321 keV for cross section above 163 keV.",
                "The cross sections from both measurements were",
                " normalized at 163 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Two HPGe detector at",
                " - 135+/-12.3 deg and 57 mm from the target, relative",
                "   efficiency of 53% at 1.33 MeV.",
                " - 90+/-10.2 deg and 122 mm from the target,  relative",
                "   efficiency of 40% at 1.33 MeV.",
                "The relative efficiencies were obtained with 152Eu",
                " decay gamma and 19F(p,ag)16O 6.1 MeV gamma-ray."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Electrically insulated target chamber acted",
                " as a Faraday cup."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Incident energy of proton at reaction was determined",
                " was determined from the outgoing gamma energy."
              ]
            }
          ],
