              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Two delta E-E solid state silicon",
                "detector telescopes were used for particle",
                "identification and angular distribution measurements.",
                "The delta E for both telescopes was 150 um and 5 mm for",
                "the E detector. Circular collimators of diameter 5 mm",
                "were used for both telescopes and their distance from",
                "the target was 130 mm. The solid angle subtended by the",
                "detector was about 1.2 msr."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " For particle identification and measurement of",
                "angular distribution at various angles."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Normalized to the elastic scattering cross section",
                "calculated from the optical potential."
              ]
