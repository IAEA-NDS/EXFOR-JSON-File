          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "3.3 and 3.5 mg/cm2 thin 238U layers evaporated onto",
                " 280 mg/cm2 Be disks"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross sections were determined by observing",
                " characteristic gamma-ray transitions and/or alpha",
                " particle energies. In a few cases, spontaneous",
                " fission decay of the product or its daughter was also",
                " used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for 3 hr up to 2 days"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                ""
              ]
            }
