            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reexamining the heavy-ion reactions 238U+238U and",
                "238U+248Cm and actinide production close to the",
                "barrier"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
