          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3EGYCAI"
              },
              "free_text": [
                " MGC-20 cyclotron"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Very high-purity natural Y2O3 (99.9999%) and high-",
                " purity Al and Cu foils (99.999%) were used in stacks.",
                "Each stack contained several properly prepared samples",
                " of natural Y2O3 (89Y = 100%) as well as aluminum and",
                " copper foils as absorbers and monitors, respectively.",
                "The thickness of the prepared Y2O3 layers ranged",
                " between 2 and 5 mg/cm2. They were homogeneous and",
                " mechanically stable.",
                "Each target was covered by a 10 um thick and 16 mm in",
                " diam. Al foil.",
                "Thus each sample consisted of an Al-Y2O3-Al sandwich."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Canberra 3106D high voltage power supply and",
                "Canberra 2026 spectroscopy amplifier coupled to a",
                " (TRUMP-8192) multichannel analyzer. The measured",
                "energy resolution was 2.0 keV for the gamma-ray of",
                "energy 1332.5 keV. To reduce the background, the",
                "detector was surrounded by a cylindrical lead shield",
                "with an inner layer of Cu to prevent gamma ray",
                "scattering."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " Several stacks were irradiated by a",
                "proton beam of current 200 nA and energy 18 MeV."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cu monitor foils were included in the stack to",
                " calculate the actual beam current during the",
                " irradiation."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The total uncertainty in the measured cross",
                "  section was in the range of 10% - 14%, depending on:",
                "  * the detector efficiency,",
                "  * counting statistics and",
                "  * beam current"
              ]
            }
          ],
