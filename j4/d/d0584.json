          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton induced reactions on 89Y with particular",
                " reference to the production of the medically",
                " interesting radionuclide 89Zr"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.M.Omara",
                "K.F.Hassan",
