            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RCA,97,467,2009",
                "code_unit": [
                  {
                    "unit": "J,RCA,97,467,2009",
                    "doi": "10.1524/ract.2009.1645",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "RCA",
