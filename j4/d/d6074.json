          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "7Li ions"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting thin metallic foils of the targets",
                "having thickness in the range of 500-750 mu-g/cm2,",
                "were mounted on the target ladder and placed at right",
                "angle to the beam"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " Alpha-particles emitted in the",
                "reactions were detected by two collimated silicon",
                "surface barrier dE-E (25 mu-m - 2 mm) detector",
                "telescopes mounted in the median (reaction) plane at",
                "back angles. The telescopes were of equal solid angle",
                "of 5.94 msr and were kept at 116. and 125. degr. for",
                "the first set and at 125. and 153.degr. for the",
                "second set. Another surface-barrier detector having a",
                "solid angle of 0.20 msr was mounted at 16. degr. for",
                "normalization with Rutherford scattering events. The",
                "telescopes were energy calibrated using",
                "alpha-particles from a 228,229Th source and with 7Li",
                "ions elastically scattered off a thin 197Au (209Bi in",
                "the second set) target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO"
              ],
              "free_text": [
                " Fourteen BGO detectors were mounted on top and",
                "bottom of the reaction plane in two close-packed groups",
                "of seven each. The two groups were placed at a distance",
                "of ~2.5 cm on either side of the reaction plane.",
                "The middle detector in each group was pulled out to",
                "nearly equalize the efficiency of all the detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Residue angular momentum and gamma-ray multiplicity,",
                "determination of the level-density parameter."
              ]
            }
          ],
