          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Zn-66 0.4 mg/cm2 rolled onto a 25 mg/cm2 Pb backing"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "BGO"
              ],
              "free_text": [
                " 5 HPGe detectors with FWHM between 1.9 -",
                " 2.2 keV at 1.33 MeV were used.",
                "Each detector has BGO anticompton shield."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                "8 NaI(Tl) crystals of hexagonal shape and size",
                " 5 cm x 10 cm were used as multiplicity detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The Legendre coefficients are derived from the",
                " fitting of the data of angular distribution of gamma",
                " rays emitted from the excited states in Mo-91 and",
                " Nb-89.",
                "The detectors were kept at 15, 30, 44, 60 and 90deg."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
