          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A high-purity (>99.99 %) molybdenum foil (100-um thick)",
                " with a natural isotopic composition.",
                "Monitor foils of Cu (100-um thick) and Al (100-um -",
                " 1.2-mm thick) with known cross-sections were also",
                " included in the stack.",
                "These three types of foils were stacked together as",
                " Al-Cu-Mo, and 5 groups were set together in an Al",
                " holder for the irradiation."
              ]
            }
          ],
