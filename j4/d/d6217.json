              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A high resolution 100 cc Ge(Li) spectrometer",
                "having resolution 2.0 keV for 1332 keV. The dead time",
                "was kept less than 10% by adjusting the sample",
                "detector separation. Energy and efficiency",
                "calibrations were done using a standard 152Eu gamma",
                "point source of known strength by keeping it at the",
                "target position."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
