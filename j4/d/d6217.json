          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacks of spectroscopically pure foils of Yttrium and",
                "Cesium Iodide of thickness 50 mu-g/cm2 and 2.0 mg/cm2",
                " (on aluminium backing of thickness 6.75 mg/cm2)",
                "respectively. Copper foil of thickness 10.68 mg/cm2",
                "was also used as flux monitor."
              ]
            }
          ],
          "FACILITY": [
