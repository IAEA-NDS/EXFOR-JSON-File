          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "CSICR",
                "NAICR"
              ],
              "free_text": [
                " CsI(Tl) and NaI(Tl) crystals 1.5-2.0 mm",
                "thick were used in the scintillation spectrometer. In",
                "the analysis of the reaction products, the deuterons",
                "were completely blocked by an Al foil and did not",
                "strike the spectrometer crystal. The scintillation",
                "spectrometer was placed in a reaction chamber mounted",
                "on a bracket that could rotate freely around the",
                "target. The distance from the spectrometer crystal to",
                "the target was 40-46 cm. The input aperture of the",
                "spectrometer was variable from 2.6 to 6.0 mm."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were used in the form of free metallic films",
                "enriched to 80-98 percent with the investigated",
                "isotope."
              ]
            }
