          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "124Sn target of thickness 2.47 +/- 0.4 mg/cm2 used",
                "for online gamma measurement.",
                "Three targets of 124Sn having thicknesses 3.3, 1.7 and",
                "3.2 mg/cm2 used for offline gamma measurement.",
                "Four targets of 159Tb having thicknesses 1.7-1.9 mg/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " Two Compton suppressed clover detectors were",
                "placed at a distance of 25 cm from the target center,",
                "one at 125 deg, for absolute cross-section estimation",
                "of various reaction channels."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " One Si surface barrier detector of thickness",
                "500 um was placed at 30 deg to monitor Rutherford",
                "scattering for absolute normalization."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The off-line gamma-ray counting was done using",
                "HPGe detector. The energy calibration and efficiency",
                "of the detector were measured by calibrated radioactive",
                "152Eu, 133Ba and 241Am sources."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam energies were corrected for the loss at half",
                "the target thickness"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Sources of error on data points were due",
                "to statistics, gamma-ray detection efficiency.",
                "For off-beam measurements, uncertainty in the target",
                "thickness was also included."
              ]
            }
          ],
