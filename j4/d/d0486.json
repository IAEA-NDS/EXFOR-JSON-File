          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Since at this angle the cross section for elastic",
                " scattering follows the Rutherford formula, knowing",
                " the solid angle of the monitor, we can easily obtain",
                " the absolute measurement of cross sections which is",
                " independent of target thickness and of integrated",
                " beam current."
              ]
            }
          ],
