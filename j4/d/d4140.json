          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions of 3He-particle induced nuclear",
                "reaction on iron"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3HUNDEB"
              },
              "free_text": [
                " MGC20E cyclotron"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Fe foils of 15 microns thick from Goodfellow."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked targets technique was",
                "used. Stacks were irradiated with He-3 beams of 27 MeV",
                "at Debrecen cyclotron. Beam current was measured in",
                "Faraday cup and was monitored by reactions on Ti foils",
                "inserted into the stacks. The energy of the incident",
                "beam was determined by magnetic deflection.",
                "Gamma spectrometry was used without chemical",
                "separation. Foils thickness was determined by measuring",
                "the weight and area of the samples. Nuclear data were",
                "taken from the Lund database",
                "http://nucleardata.nuclear.lu.se/",
                "Experimental data were assigned to the mid energy point",
                "in the target foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " pGe  gamma detectors"
              ]
            }
          ],
