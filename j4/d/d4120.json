          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The primary energy uncertainty was estimated to",
                "be 0.2 MeV and 2.4 MeV after about 40 MeV degradation",
                "in the stack. The energy uncertainty contains the",
                "cumulative effects of uncertainty of target thickness,",
                "energy straggling.",
                "The energy attenuation was calculated by",
                "using the polynomial approximation of Andersen and",
                "Ziegler along the stacks. Energy straggling was",
                "calculated by Monte Carlo method."
              ]
