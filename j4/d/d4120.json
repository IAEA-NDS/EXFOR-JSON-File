          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity metallic Fe foils (>99.9%) 12 microns were",
                "used as target foils and 12 micron Ti foils as monitors",
                "from Goodfellow."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                "used. Stacks contained Fe and Ti foils were irradiated",
                "at 34 and 44 MeV primary proton energies at 100 nA beam",
                "current for 30 min.",
                "Beam current was measured in Faraday-Cup and also",
                "monitored with natTi(p,x)48V reaction.",
                "Decay data were taken from R.B.Firestone, V.S.Shirley",
                "[Ed], Table of Isotopes, Wiley Interscience, New York,",
                "1996.",
                "Elemental Cross Section was Determined."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High Purity Ge Gamma Detector"
              ]
