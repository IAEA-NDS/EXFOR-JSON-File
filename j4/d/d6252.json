              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Five EJ-301(5cm x 5cm) liquid scintillation",
                "detectors, placed at a distance of 1.5 m at angles 0,",
                "30, 60, 90 and 120 degrees."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " To measure the energy distribution of emitted",
                "neutrons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " To separate neutrons from photons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "To account for the background contribution from the",
                "scattered neutrons from the nearby structural",
                "materials, shadow bar correction was carried out for",
                "individual detectors. Here,an iron bar of diameter 5",
                "cm and length 30cm was kept followed by high density",
                "poly-ethylene (HDPE) of same dimensions in the line",
                "of the target and the detector. The high energy",
                "neutrons undergo inelastic scatterings in the iron",
                "bar,gets reduced in energy and undergo elastic",
                "scattering in the hydrogen rich HDPE before finally",
                "getting captured."
              ]
            }
          ],
