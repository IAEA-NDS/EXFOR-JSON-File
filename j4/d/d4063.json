          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The contributions of the 159 KeV Gamma line of Sc-47",
                "produced in the Ti backing and the long lived Te-123m",
                "produced in the target material were subtracted from",
                "the total peak area. Contribution of 123Te(d,2n)",
                "process was corrected using the value of",
                "Scholten (see REL-REF). In the energy region from 14 to",
                "21 MeV extrapolation was used to estimate the",
                "contribution of the 123Te(d,2n) reaction supposing",
                "similar cross section shape for the 123Te(d,2n)",
                "reaction as the shape of the 124Te(d,2n) reaction."
              ]
            }
