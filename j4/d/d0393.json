          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "ACTIV",
                "TOF"
              ],
              "free_text": [
                "",
                "Current measurements were carried out by means of a",
                "computer-controlled integrator, resulting in less than",
                "2% uncertainty on total charge on target.",
                "Yields and cross-sections of the nuclides of interest",
                "were calculated from the gamma-emission rates using",
                "disintegration data from Browne and Firestone, 1986."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target stacks of 10-15 foils (>99.5% pure) were",
                "irradiated for 10-20 min with external beam currents",
                "up to 5 mu-A."
              ]
            }
          ],
