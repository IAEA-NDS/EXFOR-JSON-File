          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples of the 0.2-1.5 mg/cm**2 thickness and 15-mm",
                "diameter prepared by the electrolytic deposition",
                "technique of the high-clean zinc from natural",
                "composition and of the enriched Zn-64 and Zn-66",
                "isotopes were used. The enrichment of Zn-64 amounted to",
                "98.3%, of Zn-66 - to 96.9%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "The absolute efficiency was determined by means",
                "of the calibrated standard sources, the respective one",
                "was determined by means sources 184Re, 196Au, 226Ra."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "The overall uncertainty in each cross section",
                "was calculated as a root-mean square value of the major",
                "contributing uncertainties associated with the",
                "measurements of the surface density of target nuclei",
                "5%, incident particle beam current 3%, detector",
                "efficiency (5-7)%, counting statistics (1-10)%, and",
                "branching factor of gamma-transition of product nuclei",
                " (1-15)%."
              ]
            }
