          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The protons scattered by the He4 were recorded on",
                "photographic plates."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The He3 had practically no impurities. The tritium",
                "contained 0.8% hydrogen and 0.3% deuterium. The",
                "hydrogen and deuterium admixture amounted to 1.8%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A proton beam from the electrostatic accelerator",
                "entered a gas chamber filled with D2, T3, or He3,",
                "through a nickel foil 1.75 mg/cm2 thick. The gas",
                "chamber was made in the form of a cylinder. On the",
                "side surface of the cylinder was a window covered",
                "with mica foil 1.4 mg/cm2 thick."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DSCAT"
              ],
              "free_text": [
                " The degree of polarization was measured with",
                " He4. The He4 pressure in the analyzer was 780 mm Hg.",
                " Technical 99.7% pure helium was used for the analysis."
              ]
            }
          ],
