          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "64-GD-152",
                "field_identifier": "ENR",
                "value": 0.306
              },
              "free_text": [
                "",
                "Isotopically enriched 152Gd targets were produced by",
                " vacuum evaporation onto high purity thin Al backings",
                " (2.5 um thick) using Gd2O3 powder.",
                "The thickness of the targets varied between",
                " 0.220 mg/cm2 and 0.310 mg/cm2 determined by weight",
                " measurement.",
                "Targets with thickness of 0.310 mg/cm2 were also",
                " examined by Rutherford back scattering method."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 100% relative efficiency HPGe detector equipped",
                " with 4pi, 10 cm thick Pb shielding."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC",
                "EDEG",
                "SITA",
                "EXTB"
              ],
              "free_text": [
                "",
                "During the irradiation the target stability was",
                " monitored by an ion-implanted Si detector at 165 deg",
                " relative to the beam direction.",
                "Typical beam current was 2 uA.",
                "After each irradiation the target was transported to a",
                " low-background counting setup."
              ]
            }
          ],
