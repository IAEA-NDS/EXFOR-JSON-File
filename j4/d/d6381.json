              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A thick target disk of natural C (purity 99%,)",
                "having thickness 3.2 mm and diameter of 14.8 mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Five EJ-301 liquid scintillation detectors of",
                "dimensions 5.08 cm by 5.08 cm were mounted at angle",
                "of 0, 30, 60, 90 and 120 degrees with respect to the",
                "beam at a distance of 150 cm from the target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " To measure the energy distribution of emitted",
                "neutrons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " To separate neutrons from photons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The beam current utilized was about 5 nA."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In order to correct for the background contribution of",
                "scattered neutrons from the nearby structural",
                "materials, shadow bar correction was carried out for",
                "individual detectors.",
                "An iron bar of diameter 5 cm and length 30 cm was kept",
                "followed by high density poly-ethylene (HDPE) of same",
                "dimensions in the line of the target and the detector.",
                "The high energy neutrons undergo inelastic scatterings",
                "in the iron bar, gets reduced in energy and undergo",
                "elastic scattering in the hydrogen rich HDPE before",
                "finally getting captured."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 5.0,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " Statistical uncertainties in counts",
                "were < 5% in forward directions (0,30 and 60 degrees)",
                "and ~10% in the backward angles(90 and 120 degrees)"
              ]
            }
          ],
