          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Investigation of incomplete fusion in 19F+159Tb",
                " reaction at beam energy of ~ 5 MeV/Nucleon"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Amit Kumar",
                "K.Sudarshan",
                "Suparna Sodaye",
                "R.Tripathi",
                "P.K.Pujari"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3INDTRM"
              ],
              "free_text": [
                " Radiochemistry Division, BARC"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,IMP/E,20,2305,2011",
                "code_unit": [
                  {
                    "unit": "J,IMP/E,20,2305,2011",
                    "doi": "10.1142/S0218301311020307",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "IMP/E",
                        "number": null,
                        "volume": "20",
                        "part": null,
                        "issue": null,
                        "page": "2305"
                      },
