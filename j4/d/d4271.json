          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "SITA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "The irradiation was done in vacuum at different",
                " bombarding energies.",
                "The time dependence of the beam current was recorded",
                " for long irradiations.",
                "The beam current was kept below 1 uA.",
                "The gamma measurements took place in a low background",
                " laboratory.",
                "The spectra were stored regularly, every 10 min in the",
                " first five hours and every hour afterward.",
                "The decay of the different isotopes was followed in",
                " this way and a half-life analysis guaranteed that no",
                " short- or long-lived isotopes gave contributions to",
                " the studied peaks.",
                "The target stability was continuously monitored by",
                " detecting the backscattered alpha particles with a",
                " particle detector built into the chamber."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No monitor reaction was applied."
              ]
            }
