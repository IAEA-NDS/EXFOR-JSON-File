          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 100-mm-diam. gas cell, filled with helium (>99.995%",
                "purity) to a nominal absolute pressure of 1.5 bar at",
                "room temperature"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SILI"
              ],
              "free_text": [
                " For the 158 MeV runs the telescope",
                "consisted of a  50 mu-m thick Si surface-barrier",
                "deltaE detector, followed by two Si-Li detectors of",
                "5 mm nominal thickness each, followed by a 1 mm thick",
                "Si surface-barrier veto detector.",
                "For the 200 MeV runs the front deltaE element was",
                "replaced with a 2 mm thick Si surface-barrier detector."
              ]
            }
