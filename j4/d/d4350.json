            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Activity measurement of the reaction products",
                " was done by Gamma-spectrometry based on HPGe detectors"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " A stacked foils targets was irradiated with",
                " Proton beams of 17 MeV, 150 nA.",
                " Two stacks, 5-5 Sb samples and Cu monitor foils,"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDEG"
              ],
              "free_text": [
                " Energy degradation was calculated by using the",
                " polynomial approximation of Andersen and Ziegler."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " The irradiation was done on an extracted beam of",
                " the ATOMKI cyclotron.",
                " The activities of the produced radionuclides were",
                " measured nondestructively without chemical separation.",
                " The energy degradation as a function of depth in the",
                " stack was calculated from the input energy and target",
                " thicknesses."
              ]
            }
