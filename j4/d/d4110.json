                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "Total error of the data varied from 9% to 12%.",
                "Main contributing error components are:",
                "    Beam intensity                       3%",
                "    Detector efficiency                4-6%",
                "    Peak area and counting statistics  1-5%",
                "    Separation of complex peaks       0-10%",
