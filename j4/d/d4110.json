          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity metallic foils (>99.9%) from Goodfellow.",
                "       Mo 12 micron",
                "       Al 25 micron",
                "       Ti 12 micron",
                "       Ni 25 micron",
                "       Cu 25 micron"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                "used. Stacks contained foils in a Mo-Al-Cu-Ni-Ti",
                "sequence. Al foil served as energy degrader and catcher",
                "foil. Cu-Ni-Ti foils used as monitors. Beam current was",
                "measured in Faraday-cup. Irradiation lasted about 30",
                "min. With 200 nA beam current at 25 and 39 MeV.",
                "Decay data were taken from E.Browne, R.Firestone, Table",
                "of Radioactive Isotopes, V.S.Shirley [Ed], Wiley,",
                "London, 1986.",
                "Cumulative elemental cross section was determined."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High purity Ge gamma detector"
              ]
            }
          ],
