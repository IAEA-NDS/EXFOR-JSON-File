          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Investigation of the natMo(p,x)96mgTc nuclear reaction",
                "to monitor proton beams: New measurements and",
                "consequences on the earlier reported data"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Takacs",
                "F.Tarkanyi",
                "M.Sonck",
