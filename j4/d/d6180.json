              },
              "free_text": [
                " 450-580 ug/cm2.",
                "The targets were prepared by electrodeposition method",
                " on Al backing of thickness ~2 mg/cm2.",
                "The thickness of the targets was measured by",
                " Rutherford backscattering (RBS) using 60 MeV 16O beam",
                " as well as 4 MeV proton beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Beam flux was calculated by the total charge",
                " collected in the Faraday cup."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiated for 6-8 hours by ~40-100 nA."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The reaction product stopped in the target and",
                " Al backing were identified by their characteristics",
                " gamma ray by off-line counting using HPGE detector."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
