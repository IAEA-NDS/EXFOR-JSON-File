          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Evaluated activation cross sections of longer-lived",
                " radionuclides produced by deuteron induced reactions",
                " on natural titanium"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Takacs",
                "B.Kiraly",
