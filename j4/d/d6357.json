          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement and analysis of excitation functions of",
                "the residues from 12C + 89Y: A major production route",
                "for 97Ru"
              ]
            }
          ],
          "AUTHOR": [
