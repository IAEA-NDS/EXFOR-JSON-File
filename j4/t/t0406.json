          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural iridium metal powder deposited on graphite",
                " disks with upper segment removed to make flat plat-",
                " form for ionizer foil. Average target thickness 8",
                " mg/cm2. Stacks of 25 disks, separated by 0.3 mm",
                " graphite washers inserted into target-oven heated to",
                " 1600 C."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " Samples irradiated for 0.4 sec; data accumulated",
                " in four groups of 1 sec.",
                "Fission fragments stopped in graphite disks and alkali",
                " elements come out by the thermal diffusion process.",
                " The isotopes of Rb are selectively ionized at",
                " temperatures of about 1000 C."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for background and mass discrimination",
                " response of spectrometer.",
                "Proton energies corrected for attenuation in target."
              ]
            }
          ],
