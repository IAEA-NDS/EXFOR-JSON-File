              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam energy 90 MeV/nucleon. Tabulated beam energy is",
                " energy at center of targets."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target stacks containing of a 20.1 millig/cm**2",
                " natural copper foil surrounded by carbon forward",
                " and backward catcher foils.",
                "Guard foils, again of carbon, were also utilised to",
                " measure direct activation of the catcher foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " 30 min irradiation used to obtain information",
                " for short-lived products.  A second irradiation of 6",
                " hours was run for longer-lived products."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge detector",
                " For short irradiations, assay began about 30 min",
                " after irradiation (EOB) and lasted for about 24 hours.",
                " For longer irradiations, assay began 1 day after EOB",
                " and continued for several months."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "DG"
              ],
              "free_text": [
                " No information on decay data."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Tabulated uncertainties are the larger of",
                " standard deviation in the mean value and the",
                " estimated uncertainty of the individual determinations",
                "These uncertainties have several contribution factors:",
                " the propagation of the errors in the fits, detector",
                " efficiencies, and beam intensity determination.",
                " An additional 10% uncertainty has been folded into the",
                " overall uncertainty of cross sections based on a singl",
                " determination of a single gamma-ray."
              ]
            }
