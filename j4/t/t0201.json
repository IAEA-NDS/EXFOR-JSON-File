          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Evolution of the reaction dynamics in the interaction",
                " of copper with 15-90 MeV/nucleon 12C ions."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
