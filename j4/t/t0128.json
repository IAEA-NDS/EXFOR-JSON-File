          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "INTB"
              ],
              "free_text": [
                "",
                "Counting rates of the 64Cu-61Cu monitor were made",
                " with monitor samples were sandwiched between 2 Al",
                " absorbers to ensure annihilation of positrons in",
                " a well-defined geometry. A correction Of 1.3% was",
                " made for absorption of 55-keV gammas in Al absorbers."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Authors assume the production of 24Na in the 40Ca,",
                " 45Sc, and V reactions results from a binary break-up",
                " reaction resulting in two approximately equal",
                " fragments. This assumption is based mainly on the",
                " shape of the excitation function and an order of",
                " magnitude agreement with the fission cross section",
                " calculations from the Blann code."
              ]
            }
          ],
