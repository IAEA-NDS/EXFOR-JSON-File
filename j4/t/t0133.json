          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation Function For 15O Production Via the",
                " 14N(d,n)15O Reaction"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Incident beam energy ranged from 0.6 to 14.35 MeV.",
                "For energies below 2 MeV, the error in the energy",
                " spread of the initial beam is estimated to be not",
                " greater than 6%.",
                "Energy given in energy of degraded beam midway the",
                " target cell.",
                "Beam intensities ranged from 70-130 nanoamp with",
                " typical irradiation times of 10 to 20 sec."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nitrogen gas of high purity at pressures of 200 to 400",
                " Torr, in 3 to 5 cm long, 2 cm diameter quartz tubes",
                " with 21.51 mg/cm**2 thick Al windows."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                "  Energy losses in the Al windows of the gas",
                " target and the Faraday cup were calculated according",
                " to Williamson et al., CEA-R3042 (1966).",
                "Incident beam energy was magnetically analyzed.",
                "After irradiation, the 15O gas was cryogenically",
                " transferred from the target cells to a counting glass",
                " vial containing activated charcoal."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                ". Well crystal"
              ]
            }
          ],
