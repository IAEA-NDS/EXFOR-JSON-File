          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Contributions of 13N from the (d,dn) reaction and 11C",
                " from (d,an) the reaction were corrected for by",
                " following the radioactive decay for 20 to 50 minutes",
                " in 1 to 2 minutes intervals."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Overall errors of obtained by summing up all individual",
                "uncertainties in quadrature are of the order of 8-12%,",
                "and contain contributions due to uncertainty in:",
                ". window thickness (3%),",
                ". target thickness (2%),",
                ". transfer of the 15O activity to the counting vial",
                "  (4%),",
                ". dead time and detector efficiency (3%),",
                ". beam current integration (1%),",
                ". counting statistics and decay curve analysis (3%).",
                "Uncertainty in beam energy is estimated <50 keV."
              ]
            }
