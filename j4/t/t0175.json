          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Based on estimated average total symmetric fission",
                " = 2.0+-1.3 microb, asummetric fission = 2.7+-0.9",
                " microb, which are averages of the product of the",
                " production cross section and the estimated fission",
                " yield for each mass chain. Upper limits of 15% and",
                " 6% were placed on chain yields for symmetric and",
                " asymmetric mode, respectively. 42K and 77As were",
                " assumed to be products of asymmetricfission,",
                " remaining nuclides of symmetric fission."
              ]
            }
          ],
