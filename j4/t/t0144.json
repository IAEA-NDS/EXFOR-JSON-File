          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Theoretical and Experimental Excitation Functions for",
                " Proton Induced Nuclear Reactions on Z=10 to Z=82",
                " Target Nuclides."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ISOCY"
                ],
                "institute": "1USADAV"
              },
              "free_text": [
                " 1.93-m (76-in.) isochronous cyclotron."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets generally consisted of a stack of thin Metallic",
                " foils contained in a specially designed doubly",
                " collimated target.",
                "In some instances, targets of natural isotopic",
                " composition were prepared using a chemical compound",
                " - i.e., oxides, halides, sulfates, etc., containing",
                " the target element. Target thicknesses varied accordin",
                " to the particular experiment, but in such a manner as",
                " to attain a beam energy resolution of 1-3 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Incident proton energy measured using time-of-",
                " flight."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Total charge accumulated using Faraday cup."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation time and cooling time is not given."
              ]
            },
            {
