          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High-purity Ge detector coupled to a 8192-",
                " channel analyzer (Nuclear DaTA 66) used to assay",
                " short-lived (< 1 day) radionuclides."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Higher efficiency Ge(Li) coaxial detector used",
                " for longer half-lived radionuclides."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Detectors calibrated using a NIST Mixed-Radionuclide",
                " Point-Source Standard."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
