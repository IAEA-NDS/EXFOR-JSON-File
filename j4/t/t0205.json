              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Foils produced from metal powder by annealing and",
                " rolling. Thickness determined by measuring amount of",
                " energy degradation of known alpha particle groups",
                " from a 212Po Source. Foil oriented at an angle of 45",
                " degrees with respect to the beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                ". A Longitudinally Segmented Faraday Cup."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Coaxial Ge(Li) detectors used for in-beam and",
                " off-line measurements."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for target angle and enrichment, dead time",
                " losses, Faraday cup leakage and composite production",
                " of a species via both reactions and decay   ."
              ]
            }
          ],
