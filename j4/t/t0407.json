            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "MWPC",
                "SCIN"
              ],
              "free_text": [
                " Scattered protons detected in 2 pairs",
                " of range telescoped, placed symmetrically with regard",
                " to beam direction. Each telescope consisted of 2 thick",
                " plastic scintillators, a set of multiwire proportional",
                " counters, a copper absorber, and a thick NaI(Tl)",
                " detector."
              ]
            }
          ],
          "MONITOR": [
