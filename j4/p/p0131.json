          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " The tritium production cross section has been",
                "measured for Li bombarded by deuterons from 0.4 MeV",
                "to 4.0 MeV. The tritium was quantitatively recovered",
                "by cooking the sample twice at 1100 degree C in an",
                "atmosphere of argon containing 1% hydrogen. The gas",
                "was transferred to a beta proportional counter tube",
                "after cooling to 300 degree C and argon containing 10",
                "percent methane added for counting."
              ]
            }
          ],
