          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "UNFLD"
              ],
              "free_text": [
                " The  unfolding  of the reaction cross section",
                " using  the  photon  difference   method   from   the",
                " experimental  reaction  yield measured using the the",
                " direct fission fragment counting."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Mean-root-squared uncertainties.",
                " The  systematic uncertainties are  estimated  to be",
                " perhaps as large as a factor of 2."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photofission cross sections for Th-232 and U-235 have",
                " been measured in the energy range from 3.25 to  5.75",
                " MeV and  for  U-234 and U-236 at 3.5 MeV.  The cross",
                " sections change by over seven  orders  of  magnitude",
                " for this  energy  range.  Cross  section  shapes are",
                " significantly different   for   different   isotopes",
                " indicating a  strong  sensitivity to fission barrier",
                " parameters."
              ]
            }
          ],
