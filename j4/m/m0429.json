          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The activity of the Th-231 was measured by 84 keV",
                " line after waiting 16.hr in order to allow the Th-233",
                " that can be formed, to decay."
              ]
            }
          ],
