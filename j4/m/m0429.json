          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photoneutron cross section of Th-232 was",
                " measured by activation methods using monochromatic",
                " gamma-rays of energies from 5.43 to 10.83 MeV. The",
                " data for photofission of Th-232 together with the",
                " data of both types for U-238 are presented."
              ]
            }
