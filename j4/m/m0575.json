          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections were extracted from the experimental",
                " photoproton energy spectra by fitting four component",
                " for the final nucleus ground and three excited states",
                " plus a uniform background. The shape of each",
                " component in the computed proton end-point spectrum",
                " was determined mainly by that of the incident photon",
                " spectrum, but the additional contributions from the",
                " proton energy loss in target, the electron-beam",
                " energy resolution, and the spectrometer resolution",
                " were folded in."
              ]
            }
          ],
