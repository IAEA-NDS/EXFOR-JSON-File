          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target  was a thin-walled,  75-mm-radius vertical",
                " cylinder of Elgiloy  with  stainless  steel  endcaps",
                " filled  by gaseous deuterium at pressure of 06 - 0.8",
                " MPa and  a  temperature  of  40  -  50  K,  yielding",
                " densities of 2.3 - 2.7 mol/l."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MAGFR"
              ],
              "free_text": [
                " Particles  from  the  target  were   momentum",
                " analyzed by  a  90-degree  vertical   bend  magnetic",
                " spectrometer."
              ]
            }
          ],
