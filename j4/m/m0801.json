          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The virtual  photon  theory  (VPT)   was   used   for",
                " extracting photoreaction cross sections from results",
                " of measurements of  cross  sections  for  equivalent",
                " electron-induced reactions."
