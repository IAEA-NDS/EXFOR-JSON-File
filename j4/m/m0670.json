          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isomeric ratios of 197m,gPt and  197m,gHg  yields  in",
                " (g,n) reactions in energy range 8 - 17 MeV have been",
                " measured for the  first  time.  Isomeric  ratios  in",
                " 197m,gHg  have  been measured for (d,2n) reaction in",
                " energy range 8 - 50 MeV.  Comparison of experimental",
                " data   with   theoretical   calculations   has  been",
                " performed.  The influence of  low-lying  states  and",
                " yrast line has been shown."
              ]
            }
