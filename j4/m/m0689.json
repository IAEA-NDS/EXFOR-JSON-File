          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Final corrected deexcitation  gamma-ray  spectrum was",
                " unfolded using   the   responce  functions  for  all",
                " gamma-lines  to produce the final  fit,  from  which",
                " the number of  counts  included  in  each full-energy",
                " peak was determined."
              ]
            }
          ],
          "ERR-ANALYS": [
