          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "INTB"
              ],
              "free_text": [
                " A  g-ray  source (Sb or Y) was inserted in the",
                " beryllium shell and carefully mounted in  a  central",
                " position."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beryllium sample was in form of  spherical  shell",
                " of inner radius r1 = 15.31 mm and of outer radius r2",
                " = 16.81 mm (shell thickness t = 1.5 mm).  The  shell",
                " was  found  to Be spherical and of uniform thickness",
                " to within 0.005 mm.  The mass of the shell was 8.838",
                " g."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " The  neutron detector assembly consisted of BF3",
                " counters embedded  in  a  5-foot  diameter  graphite",
                " sphere moderator."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Counting statistics of 1%  were obtained and then the",
                " Be  shell was removed for the background count.  The",
                " true-counts-to-background  ratio  was  approximately",
                " 7:1 for the y case and 70:1 for the Sb source."
              ]
            }
          ],
