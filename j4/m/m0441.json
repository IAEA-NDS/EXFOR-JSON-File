          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Precision measurement of the Be-9(gamma,n) cross",
                " section."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
