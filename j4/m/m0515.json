              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Photofission fragments were detected by fission",
                " track registration technique in MAKROFOL KG (8 micron)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " Neutrons from (g,f) and (g,n) reactions were",
                " detected simultaneously with fission fragments by 4pi",
                " long-counter consisting of 60 He-3 detectors",
                " conventionally distributed inside a moderator",
                " material (polyethylene)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
