            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "4HE (80%) and CH-4 (20%) gases  mixture contained  in",
                " a time projection chamber (TPC)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " The TPC containing the mixture of 4He (80%) and",
                " CH-4 (20%) gases serves as an active target and",
                " provides the information of the track shapes and the",
                " energies of the charged particles produced in the",
                " reactions."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
