          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A convenient method for experimental determination  of",
                " yields  and isomeric ratios in photonuclear reactions",
                " measured by the activation technique."
              ]
            }
          ],
