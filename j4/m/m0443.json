          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beryllium,  carbon,  tin,  tantalum,  lead,   and",
                " bismuth targets."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "THRES",
                "NAICR"
              ],
              "free_text": [
                " An     Al-27(n,alpha)Na-24    threshold",
                " detector has been used to detect fast  photoneutrons",
                " emitted  from  various  nuclei.  The  residual Na-24",
                " activity (half-life of 15 hr,  Eg =  1.37  and  2.76",
                " MeV)   was   detected   with  a  carefully  shielded",
                " scintillation counter."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct detection of photoneutrons."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " No    information    about    source    of",
                " uncertainties."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Using an Al-27(n,alpha)Na-24 threshold detector,  the",
                " angular distributions of fast photoneutrons from six",
                " elements (beryllium,  carbon,  tin,  tantalum, lead,",
                " and   bismuth)   have  been  measured.  For  34  MeV",
                " bremsstrahlung the angular distributions were  found",
                " to   be  asymmetric  about  a  position  90  degrees",
                " relative  to   the   direction   of   the   incident",
                " bremsstrahlung   and   were  peaking  in  a  forward",
                " direction."
              ]
            }
          ],
