              "pointer": "",
              "coded_information": [
                "PLA"
              ],
              "free_text": [
                "  The  yield curve  has been analysed  using  the",
                " variable bin  Penfold-Leiss  method for cross section",
                " unfolding together with  the  Thies's  criterion  for",
                " decorrelation of the cross section errors."
              ]
            }
