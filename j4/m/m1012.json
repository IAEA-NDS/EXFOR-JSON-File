            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The decay of beta-activity induced in tin.",
                " In measurements of the reaction 120Sn(g,p)119In (T =",
                " 17.5 min) a 380-mg/cm**2 aluminium absorber was used",
                " to eliminate the small amount of activity induced by",
                " the reaction 124Sn(g,n)123Sn (T = 39.5 min, Ebeta =",
                " 1.3 MeV)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " The decay of beta activity induced in tin was",
                " measured by two SI-2B end-window counters."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The energies of g rays accompanying the beta",
                " decay of 119In was measured by means of two parallel",
                " scintillation counters, consisting of 40 x 40-mm",
                " NaI(Tl) crystals."
              ]
            }
          ],
