          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Li-7 photoneutron cross section was measured from",
                " threshold to  19.5 MeV  using bremsstrahlung from an",
                " electron synchrotron.",
                "The cross  section shows one major maximum at 17 MeV,",
                " and some less prominent structure at 13.75  MeV  and",
                " 14.65  MeV.  A  small resonance was observed at 7.46",
                " MeV which can be attributed to an M1  transition  to",
                " the known 7.456 MeV, 2.5**(-1) state in Li-7."
              ]
            }
          ],
