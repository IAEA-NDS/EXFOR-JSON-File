          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections of two kinds have been done:",
                " - for  small  16O  and  17O  contamination  using the",
                "   independent    measurements    and    correspondent",
                "   subtraction procedures;",
                " - for  18O(gamma,p)  reaction  contribution  because",
                "   following process: 18O -> 17N ->b-decay -> 17O -> N",
                "   -> (n,gamma), 6.9 MeV, t-1/2 = 4  sec   -   using",
                "   calculation of Zubanov (private communication)."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement has been made of the 18O(gamma,pn + np)",
                " cross section. The cross section rises to a maximum",
                " of 1.2 mb at 27.5 MeV, approximately one-tenth of the",
                " total (gamma,n) cross section there. The  integrated",
                " cross section is correspondingly small (11.8 MeV*mb",
                " to  43 MeV)."
              ]
            }
          ],
