          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The correction factor is 1/(p1*p2*p3*sigma), where p1",
                " = probability that a neutron does not collide in the",
                " Co target,  p2 = probability that a neutron does not",
                " collide in the lead screen,  p3 = probability that a",
                " proton  track  ends in  the  emulsion, sigma = cross",
                " section for the neutron-proton collision."
              ]
            }
