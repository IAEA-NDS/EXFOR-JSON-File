          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectra of gamma-ray cascades were obtained for",
                " groups of levels in 100 keV bins and used for",
                " determination of the intensity distribution of the",
                " ground state transitions and therefore branching",
                " ratio. By dividing the intensity of experimental",
                " intensity distribution of the ground-state",
                " transitions by corresponding branching ratio the",
                " absorption cross section was obtained."
              ]
            }
          ],
