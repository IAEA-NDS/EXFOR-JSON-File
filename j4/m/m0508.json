              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "LEAST"
              ],
              "free_text": [
                " Using DWBA E1 photon spectra the differential",
                " cross section of the (g,p) reaction  at  90-deg  was",
                " deduced from the (e,p) reaction yield curve."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "N",
                "subentry_number": null,
