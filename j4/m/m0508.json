                  }
                }
              },
              "free_text": [
                " DWBA      E1",
                " photon spectra."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "code": "N",
                "subentry_number": null,
                "author": "B.C.Cook",
                "reference": {
                  "code": "J,NIM,24,256,1963",
                  "field": {
                    "reference_type": "J",
                    "reference": {
