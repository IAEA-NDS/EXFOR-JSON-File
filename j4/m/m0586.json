          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inclusive photoproton cross section Cu(gamma,p)x have",
                " been measured for a photon energy of 300 MeV at",
                " proton angles 45, 90, and 135 degree, and for 150 MeV",
                " at 45  degree. The data were compared with an",
                " intranuclear-cascade calculation and with Ni(pi,p)",
                " data. The angular distribution was analyzed to obtain",
                " an estimate of the number of nucleons involved in the",
                " interaction."
              ]
            }
