              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Kr and Xe isotopes were identified by the",
                " decay gammas emitted by them or by their daughters",
                " for short-lived (T1/2 < 1 min) Kr and Xe isotopes."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HEJET"
              ],
              "free_text": [
                " Only Kr and Xe isotopes having T1/2 > 0.2 sec",
                " and their decay products were transported and",
                " measured."
              ]
            }
          ],
