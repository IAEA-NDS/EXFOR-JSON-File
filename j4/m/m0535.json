          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photofission cross  section  of  U-238  has  been",
                " measured at  six energies between 5.43 and 7.72 MeV,",
                " using nuclear emulsions  and  monochromatic  g-rays.",
                " The existence  of  minima  in   this  energy region,",
                " suggested by previous workers, has been confirmed."
              ]
            }
