          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Results  are presented from a  4He photodisintegration",
                " experiment performed with quasi-monochromatic photons",
                " using    a    large    solid-angle   detector.    The",
                " target-bremsstrahlung  technique   gave   a  reliable",
                " absolute mormalization.  In addition,  an unambigious",
                " separation  of the proton-triton channel  from  other",
                " photodisintegration channels was achieved."
              ]
            }
          ],
