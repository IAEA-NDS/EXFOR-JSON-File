          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy   spectra   of  photoalpha  particles  were",
                " measured with 32.5 MeV bremsstrahlung from Heidelberg",
                " betatron using   a   totally   depleted  solid  state",
                " detector of  90  micron  thickness.  Alpha  particles",
                " between 4  and  12.6  MeV  could  be detected.  Yield",
                " values in microbarn/MeV were found to be 22,  45, 23,",
                " and 5.5 for Ti, Ni, Cu and Nb, respectively."
              ]
            }
          ],
