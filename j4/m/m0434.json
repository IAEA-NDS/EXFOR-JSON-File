          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Plates loaded   and   not   loaded   with  Li-7  were",
                " irradiated under identical conditions.  The unloaded",
                " plate was used for background measurements. The laws",
                " of energy and momentum  conservation  were  used  to",
                " identify the reactions."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
