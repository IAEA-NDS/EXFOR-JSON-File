          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The sample specifications of the targets:",
                " Nucleus  Mass  Chemical Form   Purity   Princ.Impur.",
                "           (G)                 (Percent)  (Percent)",
                "  Zn-64    70         Zno         90       Zn-66  7",
                "                                           Zn-68  2",
                "  Ge-70    50        Metal        94       Ge-72  2",
                "                                           Ge-74  2.5",
                "  Ge-72    50        Metal        98       Ge-74  1",
                "  Ge-74    50        Metal        98",
                "  Ge-76    50       Ge(O-2)       70       Ge-70  6.4",
                "                                           Ge-72  8.7",
                "                                           Ge-73  3.7",
                "                                           Ge-74 11.4",
                "  Se-76    50        Metal        90.5     Se-77  1.4",
                "                                           Se-78  2.7",
                "                                           Se-80  4.7",
                "  Se-78    50        Metal        98       Se-80  1.3",
                "  Se-80    50        Metal        99",
                "  Se-82    50        Metal        92.2     Se-78  1.8",
                "                                           Se-80  4.8"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The direct  measurement  of  cross sections using the",
                " in-flight  annihilation  of monochromatic  positrons",
                " photon   monochromator  of  Saclay  linac  and  high",
                " efficiency neutron detecting  system  which  permits",
                " direct,  separate  and  simultaneous measurements of",
                " the partial  photoneutron  cross  sections  for  the",
                " reactions ((g,n) + (g,np)), (g,2n) etc., thus giving",
                " direct access to  the  total  photoneutron  reaction",
                " cross section ((g,n) + (g,np) + (g,2n) + ...)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Statistical errors are given."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photoneutron  cross sections for reactions ((g,n)",
                " + (g,np)) and (g,2n) of Zn-64,  Ga,  Ge-70,72,74,76,",
                " As-75,  And  Se-76,78,80,82  were  measured  with  a",
                " monochromatic photon  beam  and  a  high  efficiency",
                " neutron  detecting system in the photon-energy range",
                " Eg = 8 -  30  MeV.  Integrated  cross  sections  are",
                " discussed.  The  evolution  of  the  GDR as observed",
                " through the neutron exit channel only, is tentatively",
                " interpreted  in  terms  of  isospin  splitting or in",
                " terms of the dynamic collective model.",
                "The energy  resolution  is defined  by the full-width",
                " at half-maximum  of  the  quasimonochromatic  photon",
                " beam varies slowly from about 250 keV at Eg = 10 MeV",
                " to roughly 350 kev at Eg =  30  MeV.  The  following",
                " En-rsl-fw    data    were    obtained    by   linear",
                " interpolation."
              ]
            }
          ],
