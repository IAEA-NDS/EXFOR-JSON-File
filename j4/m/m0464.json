          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross  section  values  were determined by way of",
                " comparative measurement on a deuterium target. since",
                " it   was   assumed   that   the  photoneutrons  from",
                " disintegration  of  H-3,  as  those  from  H-2  have",
                " essentially  the  same angular distributions,  so no",
                " corrections  needed  to  be  introduced   for   this",
                " comparison."
              ]
            }
          ],
