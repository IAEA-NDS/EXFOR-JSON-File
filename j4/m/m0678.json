            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isomeric ratios for 120m,gSb, 122m,gSb, 117m,gIn",
                " produced in the reactions 121Sb(gamma,n)120m,gSb,",
                " 123Sb(gamma,n)122m,gSb, 118Sn(gamma,p)117m,g",
                " with incident end-point energy 15 and 16 MeV",
                " bremsstrahlung gamma-quanta from M-30 microtron were",
                " experimentally obtained. Experimental data were",
                " compared with isomeric ratios calculated using code",
                " EMPIRE II."
              ]
            }
