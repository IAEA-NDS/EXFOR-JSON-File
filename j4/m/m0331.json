          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "BETAT"
                ],
                "institute": "2GERGER"
              },
              "free_text": [
                " The   pulse   length   at   32.5  MeV",
                " end-point energy was 300-400 microsec. The frequency",
                " was 50 pulses per second."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                " The diameter of the gamma beam at the place of",
                " the sample was equal to 5 cm. The intensity of gamma",
                " irradiation  at  the  distance  of  1  m  from   the",
                " bremsstrahlung target was 300 erg/(cm2*sec)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The disk of lead (thickness = 8 mm,  diameter = 5 cm)",
                " was oriented at 45 degrees to the beam direction."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 2 mm thick Li-I crystal of  1*1/2  in**2  size",
                " screened by 12 mm thick lead shield."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The data were corrected for:",
                " (a) the cross section of Li-6(n,alpha) reaction;",
                " (b) the nonelastic scattering of neutrons within the",
                "     target and the lead screen;",
                " (c) the scattering of neutrons within the quartz ligh",
                "     conductor;",
                " (d) the background.",
                "The neutron  scattering  on the walls of detector and",
                " elastic scattering of neutrons within the target and",
                " the screen were negligible."
              ]
            }
          ],
