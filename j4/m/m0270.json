                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " The gamma-ray intensities  were  measured  by",
                " using  an end-window Geiger counter with a 5 mm lead",
                " converter on the front and its  counting  efficiency",
                " for Li-p gamma-ray was calibrated by Hough's method",
                "  - Beta counting at the end of Geiger window"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " + parafin for neutron detection. Ra+Be used for",
                " neutron detector calibration"
              ]
            }
          ],
