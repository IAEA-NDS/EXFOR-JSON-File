                ],
                "institute": null
              },
              "free_text": [
                "  Li  metal  targets  of   0.5  mm   thick  were",
                " were  bombarded  with  magnetically analysed protons",
                " which were accelerated to 500  keV  by  a  Cockcroft",
                " generator and whose intensities were about 50 mu-A ~",
                " 100 mu-A"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
