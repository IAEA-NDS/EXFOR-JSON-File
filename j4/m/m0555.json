          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The liquid helium target cell was elliptical in",
                " shape (50 x 100 mm) with a thickness varying between",
                " 6 and 13 mm and with the target plane at 34 degree to",
                " the photon beam."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors are given.",
                " Systematic errors about 6.5 % were obtained by adding",
                " quadrature the systematic uncertainties from the",
                " following sources:",
                " - photon flax                               3.4 %;",
                " - detector solid angle                      5.0 %;",
                " - target thickness                          2.0 %;",
                " - inelastic proton reactions in detector    1.0 %;",
                " - detector edge effects                     1.0 5;",
                " - multiple electron hits                  < 1.0 %."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 4He(g,p)3H reaction cross section has been",
                " measured with tagged photons of energy 81 - 158 MeV.",
                " Protons were detected over the angular range 55 -",
                " 125 degree. The scaling of the data as a function of",
                " momentum mismatch has been examined for two reaction",
                " models, the modified quasideuteron mechanism and",
                " quasifree knockout. Both models show clear scaling",
                " behavior but comparison of the predicted and",
                " measured scaling function shapes favours the modified",
                " quasideuteron mechanism at momenta up to about 500",
                " MeV/c."
              ]
            }
          ],
