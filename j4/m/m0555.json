          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Scaling of the 4He(g,p)t reaction in the Egamma = 80",
                " - 160 MeV region."
              ]
            }
          ],
          "FACILITY": [
            {
