          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The reaction 238U(g,f) has been studied in view of",
                " producing beams of neutron-rich radioactive nuclei",
                " 132Sn and 143Xe.",
                "The yields of isotopes 123,127,128Sn were determined",
                " by direct measurements, those of the isotopes",
                " 129,130,131,132Sn - by the daughter isotopes.",
                "Yields of xenon were determined by daughter isotopes."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of yields od Sn and Xe isotopes was",
                " carried out using vacuum thermochromatography of",
                " uranium fission fragments in the presence of CCl4."
              ]
            }
          ],
