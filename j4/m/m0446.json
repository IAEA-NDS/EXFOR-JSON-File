            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 120-g sample of  water,  isotopically  enriched  to",
                " 48.6% in O-17, was contained in a thin-walled lucite",
                " cylinder 3.81 cm in diameter, and 10.2 cm long."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Thin Ge(Li) low-energy photon  detector,  with",
                " the  data-acquisition system enabled to count for 70",
                " microsec starting 8.5 microsec after the beam burst."
              ]
            }
          ],
