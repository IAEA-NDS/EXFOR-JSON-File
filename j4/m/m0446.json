          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The number  of  deexcitation  g-rays  detected  at  a",
                " particular bremsstrahlung end-point energy  reflects",
                " the  differential  cross  section  over  the  energy",
                " region up  to  this  end-point  energy  weighted  by",
                " number  of  photons at each energy in bremsstrahlung",
                " spectra.  So the differential cross section and  the",
                " integrated    cross   sections   obtained   are   of",
                " \"bremsstrahlung-weighted\" type."
              ]
            }
          ],
