            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For the g-quanta energies 2.599, 2.752, and 3.270 MeV",
                " Coulomb  correction  term  to Delbruck scattering of",
                " the order alpha(z*alpha)**4 has been included."
              ]
            }
