          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples of BaO,  Ce-2(O-3),  Nd-2(O-3),  Sm-2(O-3)",
                " oxydes were used (natural and enriched 136Ba  (95  %)",
                " 138Ce (60 %),  144Sm (90 %) elements) all with weight",
                " of 200 mg.  Gases were enriched by isotopes 134Xe (90",
                " %) and  136Xe (95 %) and  used  inside  ampules  with",
                " volume ~ 1 cm**3 at pressure of 1 atm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 60 cm**3 volume Ge(Li)-detector with  2.8  keV",
                " resolution for Eg = 1.332 keV (60Co)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "AREA"
              ],
              "free_text": [
                " Isomer yield and ratio  measurement  using  the",
                " g-quanta energy spectrum lines data  separated  using",
                " the code  ACTIV.  The  integral  cross  sections were",
                " obtained  using  the  measured  isomeric  ratios  and",
                " published  total  photoneutron reaction cross section",
                " data."
              ]
            }
          ],
          "REL-REF": [
