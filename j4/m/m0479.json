          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cloud  chamber  filled  with  He-3  gas  with   a",
                " pressure  of  0.9  atm  was  used  simultaneously as",
                " detector and target."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Since in  the  (g,p)  reaction only two particles are",
                " emitted it is possible to determine  the  energy  of",
                " the  g-quantum  from  the  emission  angle  and  the",
                " momentum of  only  one  of  outgoing  particles.  By",
                " measuring   both   tracks  the  correctness  of this",
                " identification of event can  be  checked.  Then  the",
                " cross  section  can  be  obtained by dividing of the",
                " number  of  events  in  narrow  range  of   g-quanta",
                " energies  by  number of photons in the same range of",
                " bremsstrahlung spectrum."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The  systematic  errors  caused  by intensity",
                " measurements are only estimated to be about of 6%."
              ]
            }
          ],
