          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental test of bremsstrahlung cross section."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
