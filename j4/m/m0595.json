          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The (gamma,p) cross sections leading to the 39K ground",
                " state were extracted by fitting the measured",
                " photoproton energy spectra with a calculated spectrum",
                " containing the (unknown) cross sections and the",
                " (known) bremsstrahlung spectrum."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors quoted are the statistical",
                " uncertainties combined with those systematic errors",
                " which vary from run to run. These include",
                "  *  uncertainty in the dead time correction and an",
                "     energy dependent error, which varies from 1.7%",
                "     for Egamma < 151 MeV to 5.4 % at Egamma = 302",
                "     MeV,",
                "  * uncertainty in the correction for nuclear",
                "    interactions of the protons in the detector",
                "    system."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " systematic uncertainty of about 4% arising",
                " from the uncertainty in the incident photon flux."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The corrections for dead time and for nuclear",
                " interactions of the protons in the detector system."
              ]
            }
          ],
