          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "QMPH",
                  "TAGD"
                ],
                "reaction": null
              },
              "free_text": [
                "   Electron tagged bremsstrahlung:  Glasgow",
                " tagged photon  spectrometer  installed at the MAMI in",
                " Mainz."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "MICRT"
                ],
                "institute": "2GERMNZ"
              },
              "free_text": [
                " MAMI Mainz racetrack microtron."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Target cell inside the cryogenic target was a cylunder",
                " 25 cm  in  length and 4.3 cm in diameter the walls of",
                " which were made from 170 micron  thick  mylar  filled",
                " with  liquid hydrogen (17 K),  deuterium (17 K),  and",
                " helium (2.5 K)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN",
                "MWPC",
                "TELES"
              ],
              "free_text": [
                " The    large   acceptance   detector",
                " DAPHNE, developed by INFN, Italy and CEA-SPHN, Saclay",
                " France has a central tracking detector, consisting of",
                " three  coaxial   cylindrical   multiwire   proportion",
                " chambers,   surrounded  by  a  segmented  cylindrical",
                " scintillator E-dE telescope. The angular coverage run",
                " from  21  to  159  degree  in  the  polar direction a",
                " complete 360 degree in the azimutal  direction.  This",
                " corresponds to about 94 % of 4pi."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct measurement.   Total   photoabsorption    cross",
                " sections  was  obtained  as  a  sum  of  three  terms",
                " including number of charged events,  number of single",
                " measured  pi-0  events  with  no accompanying charged",
                " particles,   and   the   unmeasured   charged    pion",
                " contribution obtained by extrapolation."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
