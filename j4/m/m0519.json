            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Systematic errors."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total photoabsorption cross sections for H-1, H-2,",
                " and He-3  have  been  measured  for  incident  photon",
                " energies ranging  from 200 to 800 MeV.  The He-3 data",
                " are the first for this nucleus.  By ising  the  large",
                " acceptance detector   DAPHNE   in   conjunction  with",
                " the tagged photon beam facility of  MAMI  accelerator",
                " in Mainz,  cross sections of high precision have been",
                " obtained."
              ]
            }
          ],
