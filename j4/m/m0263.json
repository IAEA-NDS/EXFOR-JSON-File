          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The  elastic   scattering  differential  cross section",
                " was obtained as  a ratio of the number  of scattering",
                " photons  per   tagging  electron  to  the  number  of",
                " incident photons per tagging electron.",
                "The scattering cross sections, measured at 135 degree,",
                " were  converted  to  total  elastic scattering  cross",
                " sections  SIG-gg  by  assuming  purely dipole angular",
                " distributions."
              ]
            }
          ],
