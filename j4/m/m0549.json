          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical  errors.  Systematic  errors  were",
                " amounted to 4 %."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Differential cross  sections for elastic scattering of",
                " photons by 12C and 16O were measured at 58 and 75 MeV",
                " photon  energies  and  45  to  150  degree scattering",
                " angles using the tagged photon beam  of  the  95  MeV",
                " stretcher  ring  at  Lund.  The small-angle data were",
                " used to test the predictions obtained from the  total",
                " cross  sections for nuclear photoabsorption,  whereas",
                " the large-angle data provide information on the M1/E1",
                " mixing  ratio  of  the  bound-nucleon electromagnetic",
                " polarizabilities."
              ]
            }
          ],
