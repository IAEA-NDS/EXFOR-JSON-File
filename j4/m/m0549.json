          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of 58 and 75 MeV photons by",
                " 12C and 16O and electromagnetic polarizabilities",
                " of the bound nucleon."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "MICRT"
                ],
                "institute": "2SWDLND"
              },
              "free_text": [
                " MAX-laboratory racetrack microtron",
                " followed by a stretcher ring."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "TAGD"
                ],
                "reaction": null
              },
              "free_text": [
                " The magnetically tagged photons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A block of 9.5 g/cm**2 of carbon and 7 g/cm**2 of",
                " (H-2)O contained in a thin-walled Vessel."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
