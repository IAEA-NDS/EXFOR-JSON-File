          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fine structure in the Pb-208 photoneutron cross",
                " section between 9.9 and 11.2 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
