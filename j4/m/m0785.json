          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples of 232Th and 238U were built in  the  form  of",
                " pellets, using 17.76 g of (U-3)(O-8) depleted to 0.34",
                " % in 235U isotope and 19.93  g  of  natural  Th(O-2).",
                " These samples were packed inside an Al cylinder, 2.54",
                " cm internal diameter and 2.5 cm high."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " 4PI sr long-counter detector system with  high",
                " efficiency formed  by  36  3He proportional detectors",
                " distributed into  three  concentric  rings  inside  a",
                " polyethylene cube where neutrons are slowed down."
              ]
            }
          ],
