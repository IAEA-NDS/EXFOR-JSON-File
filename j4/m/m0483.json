          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photoneutron energy  spectrum  was  measured  and",
                " used  for  obtaining  of  partial differential cross",
                " section  using  the  data  on  the  shape   of   the",
                " bremsstrahlung  spectrum  together  with information",
                " about the  energy  dependence  of  neutron  detector",
                " efficiency. The  absolute  cross  section  scale was",
                " determined with the aid of data on cross section  of",
                " H-2(g,n) reaction."
              ]
            }
          ],
