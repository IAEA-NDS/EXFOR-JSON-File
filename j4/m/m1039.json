          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The weighted average yields of (gamma,p) reactions at",
                " 20 MeV bremsstrahlung on 179,180Hf and the isomeric",
                " ratio of the yields of 178m,gLu have been measured at",
                " the first time. Using weighted-average fluxes of",
                " bremsstrahlung gamma-rays the weighted-average",
                " reaction cross sections could be obtained and",
                " therefore only integrated cross sections are in fact",
                " measured in experiments."
              ]
            }
          ],
