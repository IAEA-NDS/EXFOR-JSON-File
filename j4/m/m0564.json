              "coded_information": [
                "TELES",
                "SCIN"
              ],
              "free_text": [
                " A large solid angle, position sensitive",
                " plastic scintillator telescope consisted of 3 layers",
                " of NE110 plastic scintillators. These were two thin",
                " transmission layers (dE detectors) and a stopping",
                " layer (E detector), of thicknesses 1 mm, 3 mm, and",
                " 110 mm, respectively. The total frontal area of the",
                " E elements was 1000.mm x 405. mm."
              ]
