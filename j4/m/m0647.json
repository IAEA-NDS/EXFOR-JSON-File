          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section and the SIGMA-asymmetry of the",
                " reaction d(g-pol,p)n) were measured in the energy",
                " interval Eg = 5 - 10 MeV. Cross sections",
                " dsig-parallel and dsig-perpendicular were derived",
                " from the measured quantities dsig-0 and",
                " SIGMA-asymmetry."
              ]
            }
          ],
