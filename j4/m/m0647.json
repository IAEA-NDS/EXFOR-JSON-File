              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                " The linearly polarized photons produced by",
                " channeling an E = 1 GeV electron beam through the",
                " plane (110) of a 500 micron thick silicon crystal.",
                " The degree of linear polarization of the beam changes",
                " significantly with photon energy, from ~ 83 % at Eg =",
                " 5 MeV to ~ 66 % at 10 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Silicon  surface  barrier detector 100 micron",
                " thick and 20 mm in diameter."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gaseous deuterium at pressures of 0.5 x 10**5 and",
                " 4 x 10**5 Pa."
              ]
            }
          ],
