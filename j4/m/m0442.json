              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MANGB"
              ],
              "free_text": [
                " The neutron yield was determined by comparing",
                " the (radioactive source - Be) photoneutron source to",
                " a Ra-Be standard source by means of a manganous",
                " sulfate bath (measurements of saturated manganese",
                " activity)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beryllium sample was in form of spherical shell",
                " with  outside diameter of 8.2 cm and a thickness",
                " of 0.645 cm."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "B-"
              ],
              "free_text": [
