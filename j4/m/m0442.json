              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " The saturated activity of manganese in",
                "manganous sulfate bath was measured by Geiger tube."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Some kinds of corrections to the data were used.",
                " These were corrections for:",
                " - peak-to-total ratio;",
                " - substraction of 2.09 MeV Compton tail;",
                " - half-life of Sb-124;",
                " - absolute strength of source;",
                " - neutron escape from manganous sulfate bath;",
                " - capture of fast neutrons in bath;",
                " - neutron counting statistics;",
                " - finite source-size;",
                " - gamma-ray attenuation in the Be shell;",
                " - neutrons produced by 2.09 MeV gamma rays."
              ]
            }
          ],
