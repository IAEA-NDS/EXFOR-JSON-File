          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The contribution  of  partial  reaction  (g,2n) cross",
                " section into the experimental total reaction  (g,xn)",
                " cross section  for   experiment   carried   out   at",
                " Livermore     was    evaluated    using    specially",
                " theoretically calculated ratio",
                "       F-theor = SIG-theor(g,2n)/SIG-theor(g,xn)",
                " by the way:",
                "           SIG-eval(g,2n) = F*SIG-exp(g,xn)."
              ]
            }
          ],
