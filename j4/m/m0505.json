          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target materials were 100 %  mono-isotopic thorium",
                " Th-232 and   Np-237  samples  and  separated  isotope",
                " uranium samples (isotopic content in mass per cent",
                "  data from Table 1):",
                "        A      233      234     235      236     238",
                " target",
                " U-233        98.33    0.010    O.0127           1.53",
                " U-234        93.44    4.87                      1.69",
                " U-235                 0.022   99.94             0.038",
                " U-236                 0.07     4.62     94.77   O.54",
                " U-238                 0.04                     99.96",
                "The samples were in form of oxide  films  of  about  1",
                " mg/sm**2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA"
              ],
