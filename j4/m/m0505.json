            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " 2PI geometry Baldwin and Klaiber type  fission",
                " chamber."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The direct fission fragment counting."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
