          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute cross section versus energy of the",
                " Cu-63(gamma,n) and Cu-63(gamma,2n) reactions."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.I.Berman",
                "K.L.Brown"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR,96,83,1954",
                "code_unit": [
                  {
                    "unit": "J,PR,96,83,1954",
                    "doi": "10.1103/PhysRev.96.83",
                    "field": {
                      "reference_type": "J",
