          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "By time-of-flight detection of photoneutrons from",
                " liquid deuterium target 1-H-2(g,n) the",
                " transmission of 3 to 30 MeV gamma-rays through Al,",
                " Ta, and Bi have been measured."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photon absorption by Al,  Ta, and Bi between 3 and 30",
                " MeV  was  measured  using as a photon spectrometer a",
                " photoneutron time-of-flight detector  and  a  liquid",
                " deuterium target.  the  atomic  cross  sections were",
                " obtained."
              ]
            }
          ],
