          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thickness of Be and Cu targets were 5.3 and",
                "7.0 mg/cm*2. The average value of the product of",
                "the volume of the oxygen gas target and the solid",
                "angle of the telescope was 1.21 cm*3/sr, the average",
                "thickness of the absorbing gas layer was 8.6 mg/cm*2,",
                "the gas density was 1.44 mg/cm*2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SCIN"
              ],
              "free_text": [
                ". Two telescopes symmetrically",
                "placed at the angle 90 degrees with respect to the",
                "gamma-ray beam direction. Each telescope consisted of",
                "a proportional counter and a scintillation counter."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "UNFLD",
                "PLA"
              ],
              "free_text": [
                " The differential cross section values",
                "were obtained from the experimental yield values",
                "using the Penfold-Leiss method."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors given for differential cross",
                "section values are the mean-square errors."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Differential cross sections are given as a",
                "functions of gamma-ray energy for the reactions",
                "Be-9(gamma,p), Be-9(gamma,d), and Be-9(gamma,t)",
                "accompanied by emission of particles of mean energy",
                "about 5 MeV, and for reaction O-16(gamma,d) with a mean",
                "deuteron energy of 7.5 MeV. The ratios of the number",
                "of deuterons and protons with energies from 3.6 to",
                "5.2 MeV in the photodisintegration of Cu are given."
              ]
            }
          ],
