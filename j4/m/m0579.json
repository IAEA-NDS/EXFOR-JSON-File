          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two-body photodisintegration of 4He in the",
                " 100 - 360 MeV region."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.A.Schumacher",
                "J.L.Matthews",
                "W.W.Sapp",
                "R.S.Turley",
                "G.S.Adams",
                "R.O.Owens"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,33,50,1986",
                "code_unit": [
                  {
                    "unit": "J,PR/C,33,50,1986",
                    "doi": "10.1103/PhysRevC.33.50",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "33",
                        "part": null,
                        "issue": null,
                        "page": "50"
                      },
                      "date": 1986
                    }
                  }
                ],
