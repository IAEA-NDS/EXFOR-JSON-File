          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear fission of Au-197, Pb-nat, and Bi-209 induced",
                " by polarized and monocromatic photons of",
                " 60 and 64 MeV."
              ]
            }
          ],
