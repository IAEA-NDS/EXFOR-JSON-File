              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "LCS"
                ],
                "reaction": null
              },
              "free_text": [
                " Monocromatic  'LADON'  photon  beam obtained by",
                " Compton backscattering of laser light  by  electrons",
                " circulating in storage ring."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "stacks of 24 thin foils of  gold,  natural  lead  and",
                " bismuth on thin mylar sheets."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
