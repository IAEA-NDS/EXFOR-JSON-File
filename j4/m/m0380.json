          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples consisted of high-purity tantalum,",
                " tungsten, and platinum metallic foils."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The direct  measurements   of   number   of   fission",
                " fragments  using the scanning of the MAKROFOL sheets",
                " by means of conventional optical microscopy."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total  errors  are given which are the sum of the",
                " statistical and systematic uncertainties."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A study of photofission on Ta-nat,  W-nat, and Pt-nat",
                " nuclei induced by monochromatic photons  of  69  MeV",
                " has  been  performed.  the  fission yields have been",
                " measured by using MAKROFOIL sheets as  fission-track",
                " detectors,   in  thick-target  2  Pi  geometry.  The",
                " absolute  photofossion  cross   sections   for   the",
                " tantalum,  tungsten, and platinum targets were found",
                " and  the  corresponding  deduced  fissilities   were",
                " obtained as (3.2 (0.7)), (3.4 (08)), and (6.4 (1.3))",
                " multiplied to 10**(-4)."
              ]
            }
          ],
