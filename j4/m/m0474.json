          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of a 10 cm  kapton  cell  filled",
                " with liquid He-3.  A possible He-4 contamination was",
                " negative down to a level of 0.1%."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "P"
              ],
              "free_text": [
                ""
