                      "part": null,
                      "issue": null,
                      "page": "128"
                    },
                    "date": 1964
                  }
                }
              },
              "free_text": [
                " Theoretical data on",
                "deuteron photodisintegration cross section."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The statistical errors are presented only.",
                " An error in the cross section arising from the",
                " inaccurately known value of coefficient 'beta' which",
                " determine the electrical quadrupole component in the",
                " measured dipole component was estimated to be not",
                " larger than 10%."
              ]
            }
          ],
