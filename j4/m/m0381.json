          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " For   fission   fragments   the   polycarbonate",
                " makrofoil  n  (BAYER  AG)  sheets  were  used,   for",
                " neutrons a 4 pi (long-counter) consisting of 60 He-3",
                " detector   conventionally   distributed   inside   a",
                " moderator material (polyethen) was used."
              ]
            }
          ],
          "METHOD": [
            {
