          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "PLA"
              ],
              "free_text": [
                "  The  yields  of  neutrons  was  determined  at",
                " bremsstrahlung  energies  ranging  from 10.0 to 16.0",
                " MeV at 100 keV intervals.  A total of 26 independent",
                " yield  curves  were  mesured.  the cross section was",
                " unfolded from the measured yield  curves  using  the",
                " variable bin Penfold-Leiss (VBPL) method."
              ]
            }
