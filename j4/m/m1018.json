          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Internal tensor polarized deuterium  target. The jet",
                " of tensor polarized deuterons from the polarized",
                " atomic source was held in the storage cell installed",
                " in the vacuum chamber of storage ring. The vector",
                " polarization of the jet was maintained close to zero",
                " (Pz < 0.02), whereas the tensor polarisation of the",
                " jet's atoms was close to the extreme values (Pz",
                " equal near +1 or -2). The sign of tensor polarization",
                " of the deuterium target was changed every 30 sec",
                " during the acquisition of the data."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "M",
