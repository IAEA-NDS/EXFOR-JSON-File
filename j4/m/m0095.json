          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The angular distributions of photoneutrons possessing",
                " energies > 10 MeV  produced by irradiating  Li and I",
                " with  bremsstrahlung  end-point  energy  90 MeV  were",
                " studied. The  energy  distributions  of  neutrons and",
                " protons   measured  with  the   same  apparatus  were",
                " compared. The yields  of fast photoneutrons from some",
                " elements were measured."
              ]
            }
          ],
