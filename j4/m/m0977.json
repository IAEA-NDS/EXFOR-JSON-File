          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The contribution of partial reaction (gamma,n)  cross",
                " section  into  the  experimental total neutron yield",
                " reaction (gamma,xn) cross  section  obtained   using",
                " quasimonoenergetic  annihilation  photons  at Saclay",
                " was    evaluated   using   specially   theoretically",
                " calculated transitional  multiplicity   function   -",
                " ratio",
                "    F1-theor = SIG-theor(gamma,n)/SIG-theor(gamma,xn)",
                " by the way",
                "  SIG-eval(gamma,n) = (F1-theor)x(SIG-exp(gamma,xn)).",
                "The  neutron  yield  cross section  was  obtained  at",
                " Saclay."
              ]
            }
          ],
