          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA"
              ],
              "free_text": [
                " The reaction yield curve  measurement.  A",
                " total  of  33  yield curves were taken with the 44Ca",
                " sample and 15 yield curves with the sample  removed,",
                " in  order  to determine te background effects due to",
                " the target holder."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "PLA"
              ],
              "free_text": [
                " The variable bin Penfold-Leiss method for cross",
                " section unfolding from the  averaged  neutron  yield",
                " curve.",
                "Above the   44Ca(G,2n)   threshold   at   19.1   MeV,",
                " allowance for neutron multiplicity was made  on  the",
                " basis of  a statistical model,  described by sambell",
                " and Spicer.                                  S"
              ]
            }
          ],
