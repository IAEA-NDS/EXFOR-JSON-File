          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements were       performed       for       the",
                " photodisintegration cross section  of  the  deuteron",
                " for  the  photon  energies  from  1.6 to 2.8 GeV and",
                " center-of-mass angles from  37  to  90  degree.  The",
                " measured  energy  dependence of the cross section at",
                " theta-cm =  90  degree  is  in  agreement  with  the",
                " constituent counting rules."
              ]
