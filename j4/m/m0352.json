          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photoneutron mean  energies  of  17   elements   were",
                " measured  as  a function of end-point bremsstrahlung",
                " energy from threshold of (g,n)-reaction to  25  MeV.",
                "Parameters of models  used for description of nuclear",
                " level density were found."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The mean neutron energy determination  was  based  on",
                " the   dependence   of   the   neutron   registration",
                " efficiency for different  neutron  energies  on  the",
                " paraffin  moderator  thickness between two groups of",
                " counters."
              ]
            }
          ],
