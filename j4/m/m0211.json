          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photoneutron cross section for the (g,n) reaction",
                " in natural lithium was measured and  found  to  have",
                " its maximum at 16.8 MeV, a peak value of 2.3 mb, and",
                " a width at half maximum of 9.3 MeV.  Fine  structure",
                " in the region to 10 MeV was resolved."
              ]
            }
