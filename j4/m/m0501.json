          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The  target  consisted  of  distilled  water  held  in",
                " a cylindrical aluminium cell of dimensions 90 mm x 50",
                " mm in   diameter.  Entrance  and  exit  foils  had  a",
                " thickness of  0.25  mm  which   was   negligible   in",
                " comparison to the water.",
                "The (D-2)-0 target for D(G,N) reaction measurements."
              ]
            }
          ],
