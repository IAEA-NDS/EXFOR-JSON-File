          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Differential  cross section values  were obtained from",
                " integrated areas of peaks in photoneutron energy  TOF",
                " spectra."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The  total (statistical   plus   systematic)",
                " errors are given. Systematic errors  amount to about",
                " 12.5 - 15 %."
              ]
            }
          ],
          "EN-SEC": [
            {
              "pointer": "",
