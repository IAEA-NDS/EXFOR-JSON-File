          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 29-Cu-65(g,3n)  reaction  has  been measured from",
                " threshold to 110 MeV.  The integrated cross  section",
                " at 110. MeV is 0.037(0.004) MeV*barn. The consequent",
                " error in bremsstrahlung monitoring through  ignoring",
                " this  contribution  varies from 0.9%  at 40 MeV.  To",
                " 1.4% at 110 MeV."
              ]
            }
          ],
