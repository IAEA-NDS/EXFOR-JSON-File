                "J.C.McGeorge",
                "R.O.Owens",
                "P.J.Thorley"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,442,215,1985",
                "code_unit": [
                  {
                    "unit": "J,NP/A,442,215,1985",
                    "doi": "10.1016/0375-9474(85)90142-3",
                    "field": {
                      "reference_type": "J",
