          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 7Li(gamma,n) and 7Li(e,n) reactions at",
                " intermediate photon energies."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.R.Sene",
                "I.Anthony",
                "D.Branford",
                "A.G.Flowers",
                "A.C.Shotter",
