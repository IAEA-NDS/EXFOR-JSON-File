          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photodisintegration of the deuteron by linearly",
                " polarised photons."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.-H.KRAUSE",
                "J.SOBOLEWSKI",
