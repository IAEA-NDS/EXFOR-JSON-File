          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " Thin polycarbonate Makrofol-KG film (10 mu-m",
                "thick and 100 x 100 mm2 area). To decrease the",
                "background due to electron scattering, the counter",
                "was located at 135. degr. with respect to the beam",
                "direction at 16 cm from the irradiated target."
              ]
            }
          ],
