          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Specially enriched (-98%) targets of the 237Np, 239Pu",
                " and 243Am isotopes and natural 238U were obtained by",
                " vacuum evaporation on thin (~ 100 mu-m) aluminum",
                " foils. The thickness of the targets (~100 mug/cm2)",
                " was determined by alpha-particle spectrometry."
              ]
            }
          ],
