          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental results    are    presented    for   the",
                " electrofission and  photofission  of  U-238  in  the",
                " energy range  6  to  60  MeV.  The importance of the",
                " inclusion of  the   Coulomb   corrections   in   the",
                " calculation of   the   virtual  photon  spectrum  is",
                " emphasized and the relative E1 contribution  to  the",
                " electrofission process  has been evaluated using the",
                " distorted-wave Born-approximation  analysis  of  the",
                " experimental data."
              ]
            }
          ],
