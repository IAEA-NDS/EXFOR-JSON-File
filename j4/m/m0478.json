          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section was determined from the number",
                " of proton-deuteron coincidence events by dividing",
                " of this number by corresponding number of photons",
                " in the bremsstrahlung spectrum."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Systematic errors are only estimated",
                " to be about 5%."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 90-degrees differential cross section for the",
                " photodisintegration of He-3 into a proton and a",
                " deuteron has been measured for incident photon",
                " energies between 8.5 and 22 MeV. The fact that the",
                " incident photon momentum is small at these energies",
                " provides a unique signature for this process. The",
                " proton and deuteron are emitted nearly back to back",
                " with equal momenta; hence the energy of the proton",
                " is about twice that of the deuteron."
              ]
            }
          ],
