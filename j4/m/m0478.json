              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The brass chamber with thin Alumiseal windows",
                " was filled with He-3 gas at slightly less than",
                " atmospheric pressure."
              ]
            }
          ],
