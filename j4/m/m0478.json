              "coded_information": {
                "incident_source": [
                  "QMPH",
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " The    source    of    gamma-quanta   is",
                " bremsstrahlung but in  case  of  full  geometry  the",
                " energy  of  photon  which  produced  each  event  is",
                " exactly the sum of the proton and deuteron  energies",
                " plus 5.49 MeV (the threshold of He-3(g,p) reaction)."
              ]
            }
          ],
