          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metal 25,26Mg targets with width correspondingly",
                " 56.9 and 53.34 mg/cm**2. MgO 24Mg (24Mg - 79%, 25Mg",
                " - 10%, and 26Mg - 11%) target with width 1010",
                " mg/cm**2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The yields of the nuclei Na-24, Na-22, F-18 and Be-7",
                "from the isotopes Mg-24, Mg-25 and Mg-26 have been",
                "studied for the photonuclear reactions induced by the",
                "bremstrahlung  photons  with the end-point energy of",
                "4.5 GeV. The isospin dependence of the yields has been",
                "obtained. The present data and the result of Batist",
                "et al. Concerning the proton-nuclear spallation",
                "reactions on the isotopes Mg-24, Mg-26 and Mg-26 and",
                "Al-27 have been compared to the theoretical estimates.",
                "An additional term depending upon the difference",
                "between the target nucleus and product nucleus",
                "isospins has been introduced into Rudstam's formula."
              ]
            }
          ],
