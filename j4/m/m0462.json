              "coded_information": {
                "code": "J,PR/C,36,1792,1987",
                "code_unit": [
                  {
                    "unit": "J,PR/C,36,1792,1987",
                    "doi": "10.1103/PhysRevC.36.1792",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
