          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The E1  and  E2  cross sections of the Y-89(gamma,p0)",
                " reaction have been obtained by integrating the  best",
                " fit  curves to experimental angular distributions of",
                " protons from the Y-89(e,p0) reaction over angle, and",
                " dividing  them  by  E1 and E2 virtual photon spectra",
                " obtained from distorted wave Born approximation."
              ]
            }
          ],
