          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Y-89(gamma,p0) cross   section   deduced   from   the",
                " Y-89(e,p0) reaction."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.Miyase",
                "H.Tsubota",
