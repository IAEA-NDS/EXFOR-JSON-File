                "MAGFR",
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A thin foil (9.9 mg/cm**2) of natural Y-89."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "SILI"
              ],
              "free_text": [
                " Browne-Buechner   type   of  broad-range",
                " magnetic spectrometer with a set of 100 Si(Li) solid",
                " state detectors in focal plane."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The differential  cross  sections  for  the   (e,p-0)",
                " reaction  were measured at 12 angles relative to the",
                " incident electron beam,  from 30 t0 140  degrees  in",
                " steps  of 10 degrees.  Since the first excited state",
                " in the residual nucleus Sr-88  is  at  1.84  MeV  to",
                " obtain  the pure p(0) differential cross section the",
                " measured proton  yields  were  integrated  from  the",
                " end-point energy down to 1.84 MeV."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The nuclear photoeffect in tritium  induced  by  32.5",
                " MeV  bremsstrahlung  has  been investigated.  Energy",
                " spectra of protons and deuterons from the  reactions",
                " H-3(gamma,p)2n  and  H-3(gamma,n)D  were  separately",
                " recorded by E-dE semiconductor telescope.  The cross",
                " section  of  the reaction H-3(gamma,n)D is given for",
                " Eg = 18 - 28 MeV."
              ]
            }
          ],
          "HISTORY": [
            {
