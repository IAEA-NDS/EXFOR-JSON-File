          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total photoabsorption cross section was extracted",
                " from  the  experimental elastic and inelastic photon",
                " scattering cross sections under the assumptions that",
                " the  scattering  is  dominated by dipole excitations",
                " (as expected from consideration of the E1,  M1,  and",
                " E2  sum rules) and that inelastic scattering to more",
                " highly excited states (than first excited state) can",
                " be neglected."
              ]
            }
          ],
