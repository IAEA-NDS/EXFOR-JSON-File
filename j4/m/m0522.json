          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,52,2097,1995",
                "code_unit": [
                  {
                    "unit": "J,PR/C,52,2097,1995",
                    "doi": "10.1103/PhysRevC.52.2097",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "52",
                        "part": null,
