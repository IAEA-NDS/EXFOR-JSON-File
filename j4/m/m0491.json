          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute photofission cross sections for  Th-232  and",
                " U-235,238 measured with monochromatic tagged photons",
                " (20 MeV < EG < 110 MeV)."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.Lepretre",
