          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The areas of the photopeaks of the corresponding",
                " g-lines of the radioisotopes under consideration",
                " obtained as a result of g-spectroscopic measurements",
                " were used to extract their yield Y, which in this",
                " work is defined as the number of radioisotope nuclei",
                " formed in the target per second of its irradiation",
                " with bremsstrahlung photons: formula (1) of the",
                " article.",
                " The flux-weighted average cross sections obtained",
                " using formula (3) of the article are presented."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors given."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The experimental result is an integral value",
                " expressed as a convolution of the excitation",
                " function SIG(Eg) of a given reaction with the",
                " spectrum W(Eg,Ee) of bremsstrahlung photons",
                " incident on the corresponding target.",
                "The experimental data are represented as a",
                " flux-weighted average cross sections."
              ]
            }
          ],
