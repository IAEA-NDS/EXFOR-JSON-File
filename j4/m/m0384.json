          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "This is the  first  measurement  of  the  total  cross",
                " section of  the  He-4(g,npp)n  reaction in the energy",
                " range of 135 -  455  MeV.  The  cross  section  which",
                " cannot  be  reproduced  by  any   model,  has similar",
                " Eg-dependence to cross section of the process  (He-4)",
                " + g  ->  all  channels.  The  average  ratio of cross",
                " sections of two kinds mentioned  above  is  equal  to",
                " 2.3 (0.3) %   and  is  compared  with   cascade-model",
                " calculation in  which  quasi-free   pion   production",
                " followed by pion reabsorption is assumed."
              ]
            }
          ],
