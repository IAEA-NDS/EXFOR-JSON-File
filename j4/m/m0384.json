          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Each of the events  includes two charged particles and",
                " one neutral particle.  The events were analyzed on an",
                " event-by-event basis to obtain the  momentum  vectors",
                " and masses  of  the  particles.  The missing mass and",
                " momentum on the nppx-type event,  where x  represents",
                " an unobserved  particle,  were calculated from the Eg",
                " and the reconstructed four-momentum of  the  detected",
                " particles.  When the missing mass was consistent with",
                " a neutron,  the event  was  classified  as  the  nnpp",
                " channel  and  the  missing momentum was attributed to",
                " the neutron."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
