              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made for nonideal  gas  behavior  of",
                " the  deuterium,  the  loss  of protons in traversing",
