            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam burst  lengthened to 350 microsec.  The beam was",
                " hardened by 30.5 cm of graphite  which  reduced  the",
                " number  of  photons  with  energy less then 3 MeV by",
                " several orders of magnitude."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Spectrometer  consisted  of 5.1 cm diameter by",
                " 2.5 cm thick  stilbene  crystal  with  2.5  cm  lead",
                " shield  in  front  of the detector.  The pulses were",
                " recorded  by   an   RCL   512-channel   pulse-height",
                " analyser."
              ]
            }
          ],
