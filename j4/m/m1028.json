          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The joint analysis  of the cross sections of total and",
                " partial (g,xn),  (g,n)  and (g,2n) reactions obtained",
                " in  different  experiments  was  carried out using an",
                " approach which consists in  analizing  the systematic",
                " disagreement among data, attributed to the systematic",
                " uncertainties. Transitional multiplicity functions",
                "             Fi-theor = SIG(g,in)/SIG(g,xn)",
                " were  proposed  in  the  framework  of  the  combined",
                " photonucleon  reaction  model  in  order  to evaluate",
                " photonuclear  partial  reaction cross sections  using",
                " experimental  neutron  yields  SIG-exp(g,xn), without",
                " the problems  related  to  the  neutron  multiplicity",
                " sorting procedure",
                "          SIG-eval(g,in) = Fi-theor x SIG-exp(g,xn)."
              ]
            }
          ],
