          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The experimental neutron spectra have  been  obtained",
                " taking  into  account  the  behaviour  of  the cross",
                " section of (n,p) scattering and the probability that",
                " a proton recoil tracks ends in the emulsion."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The direct emission  contributes  about  50%  to  the",
                " neutron yield in the region E >  2  MeV  and  occurs",
                " prevalently at En-max = 16,  18,  19.4,  21.2, 22.5,",
                " and  26.5  MeV.  The  energy  distribution  of   the",
                " evaporated   neutrons   behaves  like  the  function",
                " f(e) = e*exp(-e/t) with t = 1.3 MeV."
              ]
            }
          ],
