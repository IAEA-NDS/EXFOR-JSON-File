          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute photofission cross section of Au-197, Pb-nat,",
                " Bi-209, Th-232,  U-238,  and U-235 nuclei  by  69-MeV",
                " monochromatic and polarized photons."
              ]
            }
          ],
