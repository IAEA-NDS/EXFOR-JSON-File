          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High resolution mesurements of C-12(gamma,n) and the",
                " inplications   for   the  (gamma,nucleon)  reaction",
                " mechanism at intermediate energy."
              ]
            }
          ],
