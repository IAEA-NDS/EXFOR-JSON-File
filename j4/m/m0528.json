          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SHAPE"
              ],
              "free_text": [
                "    Pulse shape analysis distinguished neutron",
                " signals from electromagnetic background  and  charged",
                " particles."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "   Statistical  uncertainties,   which  include",
                " uncertainties  arising from the four gaussian  fiting",
                " procedure   used   to  extract  the  peak  areas  are",
                " presented."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Systematic uncertainties are estimated to be",
                " 20 %."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High resolution measurements of the reaction C-12(g,n)",
                " at eg about 58 MeV are presented. The distribution of",
                " strength to  the  resolved bound final states in C-12",
                " is compared with that of B-11  obtained  in  previous",
                " analogous (g,p) measurements and the implications for",
                " the theoretical description of  (g,n)  reactions  are",
                " discussed. these  new  results confirm the importance",
                " of two-nucleon effects in intermediate energy  photon",
                " absorption and      highlight     inadequacies     in",
                " state-of-the-art mucroscopic  calculations  of  (g,n)",
                " reactions."
              ]
            }
          ],
