          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photodisintegration runs were made at six  laboratory",
                " angles  Theta-n  = 30,  45,  60,  90,  120,  and 135",
                " degrees.  For each angle the photoneutron yield  was",
                " determined   by   integrating   the  counts  in  the",
                " photoneutron peak and by normalizing to  a  constant",
                " flux of incident 2.75 MeV gamma rays."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made for background,  geometry, dead",
                " time  losses,  and  relative detection efficiency of",
                " neutron detector."
              ]
            }
          ],
