          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two-body photodosintegration of He-3 between 150",
                " and 350 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "D.I.Sober",
                "H.Crannell",
                "B.M.K.Nefkens",
