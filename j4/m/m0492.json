          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct measurements  of  cross  section  values   for",
                " coincidence counts between the tagged electrons from",
                " linac and the fission detector taking  into  account",
                " such   quantities   as  efficiency  of  tagging  and",
                " equivalent thickness of the target."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The  quoted  error   bars   contain   both",
                " statistical and systematic uncertainties."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute photofission cross sections of U-235,238",
                " have been measured in the ehergy range 40 - 105  MeV",
                " with tagged photons,  using parallel plate avalanche",
                " counters for  a  direct  detection  of  the  fission",
                " fragments.  The  measured  cross sections are nearly",
                " constant in the investigated energy range and amount",
                " to about 17 mb for both isotopes."
              ]
            }
          ],
