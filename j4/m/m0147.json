          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for",
                "a) variation of nuclear emulsion thickness,",
                "B) dependence of the (n,p) cross-section on neutron",
                "   energy,",
                "C) the probability that proton tracks end outside the",
                "   emulsion,",
                "d) back-ground."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The angular distributions were approximated with",
                "formula A+B*sin**2 .",
                "The asymmetry observed by some authors at the",
                "energy E-gamma-max=20 MeV,is not confirmed by the",
                "present work.",
                "The obtained results indicate an increase of the",
                "anisotropy with the neutron energy."
              ]
            }
