          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target chamber was constracted of brass, with",
                "thin alumiseal (a mylar-aluminium laminate) windows.",
                "The target chamber was filled with 3He gas at",
                "slightly less than atmospheric pressure, so that",
                "the chamber was a constant-volume device of 0.5",
                "liter capacity."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "PHD",
                "PSD"
              ],
              "free_text": [
                " Proton-deuteron coincidencies."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Two CsI(Tl) crystals."
              ]
            }
          ],
          "PART-DET": [
            {
