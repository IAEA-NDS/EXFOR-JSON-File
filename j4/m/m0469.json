          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Coincidencies were demanded between the proton and",
                "deuteron from the two-body 3He disintegration. The",
                "particle energies were determined by pulse-height",
                "measurement, and electrons were rejected by pulse-",
                "shape analysis. The yield was obtained from the",
                "corrected numbers of p-d coincidencies and then was",
                "used for obtaining the differential cross section",
                "for two-body 3He disintegration. The three-body",
                "3He disintegration cross section was obtained with",
                "the aid of p-p events."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical and total errors are presented.",
                " Systematic error was estimated to be about",
                " 5%."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 90-degrees photodisintegration cross sections for",
                "3He were measured for incident photon energies",
                "between 8.5 and 21.5 MeV by detecting proton-deuteron",
                "coincidencies in CsI(Tl) scintillators immersed in",
                "1 atm gas. The source of gamma-quanta was the",
                "Bremsstrahlung beam of the University of Illinois",
                "22 MeV betatron. The particle energies were",
                "determined by pulse-height measurement, and electrons",
                "were rejected by pulse-shape analysis."
              ]
            }
          ],
