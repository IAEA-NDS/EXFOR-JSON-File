          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross  section  values  were  obtained  using the",
                " equation: sig(Eg)=k*c(s)/i(s)*delta(Eg)*epsilon(En),",
                " where  'k' is a constant which depends only upon the",
                " shape of the be target,  'c(s)' is the counting rate",
                " of  neutrons  due  to  the source 's' with intensity",
                " 'i(s)',  energy 'Eg', and emission rate 'delta', and",
                " 'epsilon(En)'  is  the  efficiency  of  the  neutron",
                " detector for neutrons with energy 'En'."
              ]
            }
          ],
