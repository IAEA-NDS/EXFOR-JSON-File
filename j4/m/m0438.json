          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Six kinds of radioisotopes were used to measure cross",
                " section   of   the   Be-9(g,n)   reaction  near  its",
                " threshold.  Because all other possible  photonuclear",
                " reactions  have  a  larger thresholds this is a pure",
                " reaction Be-9(g,n)."
              ]
            }
          ],
