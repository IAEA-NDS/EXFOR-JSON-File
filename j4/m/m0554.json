              "free_text": [
                " Each of three telescopes consisted",
                " of a thin (500 or 600 micron) Si transmission",
                " dE-detector and LN-cooled thick (10 or 20 mm) HPGe",
                " stopping E-detector."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A beryllium oxide ceramic sheet with a thickness of",
                " 82.65 mg/cm2 or 151.1 mg/cm2."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DIFFR"
              ],
              "free_text": [
                " The angular distributions for the protons",
                " leaving the final nucleus in the ground state were",
                " extracted from the tip region of the photoproton",
                " energy spectra."
              ]
            }
          ],
          "FLAG": [
            {
              "pointer": "",
              "coded_information": [
                1.0
              ],
              "free_text": [
