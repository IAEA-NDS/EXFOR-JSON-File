          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct measurement of  the  reaction  cross  section.",
                " Data were taken in several runs for effective photon",
                " mean energies eg = 14.7,  19.3,  28.9,  38.2,  47.5,",
                " 57.5,  and 74.0 MeV, with deuterium and hydrogen gas",
                " (for background measurements)  in  turn  as  target.",
                " data   were   also   taken   with   use   only   the",
                " bremsstrahlung component of the beam."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were   made   for   the  proton  detector",
                " efficiency,  including  the  effect  of  the  proton",
                " energy  threshold  (0.7  MeV  at  Eg = 14.7 MeV) and",
                " angular acceptance."
              ]
            }
          ],
