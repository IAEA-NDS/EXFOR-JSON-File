          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SCIN"
              ],
              "free_text": [
                " Protons were registered by a",
                " telescope consisting of three proportional counters",
                " and one scintillation counter.",
                "The proportional counters were glass cylinders of",
                " 60-mm diameter and 200 mm length. The counters were",
                " filled with argon and 1% CO2 at 500 mm Hg.",
                "The scintillation counter consisted of a plastic",
                " scintillator (p-terphenyl in polystyrene) 60 mm in",
                " diameter and 5.5 mm thick for measurements at 16, 24,",
                " 36, and 44 degree, or 0.3 mm thick for measurements",
                " at 56 and 64 degree."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The g-ray counter consisted of two liquid",
                " scintillators (p-terphenyl in phenylcyclohexane) in",
                " Plexiglass containers of 150 mm diamete and 30 mm",
                " thickness."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The experimental investigation of elastic g-ray",
                " scattering on hydrogen using identifying the process",
                " \"g + p -> p' + g'\"  against the background of the",
                " process \"g + p -> p' + PIO -> g1 + g2\"."
              ]
            }
          ],
