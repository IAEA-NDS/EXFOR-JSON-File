          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Plane target  and  cylindrical  targets  were used to",
                " study the energy spectrum of photoneutrons from C-12",
                " and  angular  distributions  of  photoneutrons  from",
                " Be-9, C-12 and Al-27 respectively.  Sizes of targets",
                " WERE CHOSEN  TO  RESTRICT  A  FRACTION  OF  NEUTRONS",
                " scattered  inelastically in a sample and a lead slab",
                " before detector by 5  p.  c.  to  study  the  energy",
                " spectrum   and   10   p.c.   to  study  the  angular",
                " distributions."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " A paraffin disk was used as a converter."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "P"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                "  a  lead  slab  was  placed  before",
                " converter    and    detector   for   absorption   of",
                " photoprotons and main part of electrons emitted by a",
                " target."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The angular distributions were corrected for (a)  the",
                " thickness  of  the  converter,(b)  the dependence of",
                " efficiency of registration on neutron energy and (c)",
                " the angle of (n,p)-scattering."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  Statistical  errors  of   measurements.  The",
                " background  was negligible.  It was less than 3 p.c.",
                " for measurements of angular distributions and 5 p.c.",
                " for measurement of energy spectrum."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "N",
