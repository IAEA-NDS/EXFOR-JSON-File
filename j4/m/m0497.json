          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "UNFLD",
                "LEAST"
              ],
              "free_text": [
                " Cross  sections  were obtained from the",
                " reduced yields using the unfolding 'least-structure'",
                " method   developed  by  Cook.  In  this  method  the",
                " smoothest  cross  section  statistically  consistent",
                " with  the  reduced yields and their estimated errors",
                " is  calculated.  For   experimental   yield   curves",
                " obtained  from  residual  radioactivity measurements",
                " the  raw  data were recorded as a  series  of  g-ray",
                " spectra  containing  peaks  from  all  activities of",
                " interest,  an computer code was  devised  to  locate",
                " desired  peaks,  obtain  the area of each peak,  and",
                " correct for the response of the  beam  monitor.  The",
                " actual  peak  areas  were  calculated  by  numerical",
                " integration after  fitting  and  stripping  off  the",
                " background  spectrum.  Once  the experimental yields",
                " were determined,  a reduced yield was calculated  by",
                " application  of  an  energy dependent correction for",
                " the response of the beam monitor."
              ]
            }
          ],
          "REL-REF": [
            {
