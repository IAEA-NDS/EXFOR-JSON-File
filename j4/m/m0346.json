                      "part": null,
                      "issue": null,
                      "page": "593"
                    },
                    "date": 1954
                  }
                }
              },
              "free_text": [
                " The first results",
                "on the total photoneutron cross section of Ar-40 were",
                "received for giant dipole resonance at 20 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "code": "N",
                "subentry_number": null,
                "author": "G.G.Bunatyan+",
                "reference": {
                  "code": "J,SNP,13,695,1971",
                  "field": {
