          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "1USAPEN"
              },
              "free_text": [
                "  It provided a proton beam at energies",
                " above 3.8 MeV."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "MPH",
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Gamma-rays from the T(p,g)He4 reaction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "NAICR",
                "NAICR"
              ],
              "free_text": [
                ". Neutrons  were  detected by means",
                " of  the  positron  radioactivity   of   C-11   using",
                " coincidences  of the annihilation radiation from the",
                " positrons.",
                "The gamma-rays were monitored by 4.5 in.-diameter NaI",
                " crystal collimated with a 2 in. hole in a 4 in. lead",
                " shield and placed 2 ft from the target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of thickness 428, 1110 and 1543 g/cm-sq were",
                " used."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "B+"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "AR"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross  section  of  C-12(g,n)C-11  reaction   was",
                " measured in the energy range from the treshold up to",
                " 26.7 mev.  The peak cross section was 7.8 mb at both",
                " 22.15 and 23.0 MeV, and the additional structure was",
                " observed at 25.6 MeV.",
                "The comparision   with    theoretical    calculations",
                " indicates that the deformed nucleus assumption comes",
                " closest  to  describing  the  experimental  results.",
                " comparision   of  cross  section  for  C-12(g,n)C-11",
                " reaction   was   suggested    some    isotropic-spin",
                " impurities  in  the  C-12  states  of  giant  dipole",
                " resonance."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ". Comparision with experimental data  of  early",
                " cross  section  measurements  C-12(g,n)C-11 reaction",
                " was made."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "E-DIS"
              ],
              "free_text": [
                "  Energy  distribution of gamma quanta used in",
                " the experiment."
              ]
            }
          ],
