          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy  spectrum  of photoneutrons from 14N shows",
                " maxima at 3.0,  6.5 and 11.0 MeV.  Whereas  that  of",
                " neutrons  from  18O  contains  only an indication of",
                " structure for  both  nuclei.  Emission  of  neutrons",
                " seems  to  proceed  mainly  through transitions into",
                " excited levels of the final nuclei."
              ]
            }
          ],
