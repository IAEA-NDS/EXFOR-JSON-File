          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For neutron energies greater than about 5 MeV this is",
                " simple  to   obtain  from  the   data,   since   the",
                " contribution  by  the  evaporated  neutrons  to  the",
                " spectrum  is small  at high energies.  The situation",
                " for  En < 5 MeV  is much  more difficult to resolve,",
                " however,  since  the fraction  of the neutrons which",
                " are produced  by the direct  process is  not  known.",
                " Also,  the shape of the statistical spectrum  may be",
                " in error,  even  though  it  appears to fit  the low",
                " energy data well.  Nevertheless, if this spectrum is",
                " assumed to be correct, then 20 % of the neutrons are",
                " found to be produced by a direct process."
              ]
            }
          ],
