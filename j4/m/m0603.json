          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total gamma-absorption cross sections have",
                " been measured using absorption method.",
                "The nuclear absorption cross section is the",
                " difference between the total absorption cross",
                " section calculated from the directly measured",
                " attenuation coefficients, and the sum of",
                " electromagnetic (atomic) cross sections:",
                " Compton, pair production and photoelectric."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
