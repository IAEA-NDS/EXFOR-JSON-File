                "correlation_property": null
              },
              "free_text": [
                " Mean-root-squared uncertainties."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The evolution of the Th-232, U-235, U-238, and Pu-239",
                " total photoabsorption cross sections measured by the",
                " absorption method versus z changing from 90 to 94 is",
                " investigated."
              ]
            }
          ],
