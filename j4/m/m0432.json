          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photofission cross sections of Th-232 and U-236",
                "from threshold to 8 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.V.Yester",
