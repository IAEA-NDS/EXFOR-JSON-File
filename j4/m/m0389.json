          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute  numbers  of photoneutrons with measured",
                " kinetic   energy   were   used   to    obtain    the",
                " double-differential reaction cross section."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
