          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Since the   photon   energy   and   the  momenta  and",
                " directions  of  two  detected  protons   are   known",
                " precisely,  the ppn kinematics is overdetermined and",
                " a  kinematic  fit  can  be  performed  in  order  to",
                " eliminate all competing reactions in which pions are",
                " produced."
              ]
            }
          ],
