          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MANGB",
                "ACTIV"
              ],
              "free_text": [
                " saturated   solutions   of  sodium  and",
                " potassium  permanganate  were   used.   the   active",
                " Mn-56(O-2) precipitated from the solution on neutron",
                " capture in manganese,  was filtered off and  counted",
                " by Geiger counter."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The berillium target."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " saturated solutions of sodium  and  potassium",
                " permanganate   were  used  as  the  Szilard-Chalmers",
                " neutron detector.  The activity  of  Mn-56(o-2)  was",
                " measured by geiger counter."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors given are statistical."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "six major corrections were required.  These were  the",
                " corrections for:",
                " - the differential absorption of gamma-rays in",
                "   beryllium and heavy water (used for background",
                "   measurements);",
                " - the slight difference in geometry of the samples",
                "   (beryllium and heavy water);",
                " - the (n,2n) reaction occuring in beryllium,",
                "   produced by photoneutrons;",
                " - the differential escape of neutrons from the",
                "   detector;",
                " - the collisions of neutrons and Be-9, with loss",
                "   of neutron energy, incide the blocks;",
                " - the Be-al alloy used in place of beryllium for",
                "   one experiment."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections for  the  reaction  Be-9(g,n)Be-8  for",
                " monochromatic  gamma  rays  in the energy range from",
                " 2.6 to 8.1 MeV have  been  obtained  using  a  large",
                " Szilard-Chalmers neutron detector."
              ]
            }
          ],
