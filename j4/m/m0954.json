          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photoprotons were   detected    at    seven    angles",
                " simultaneously, ranging  from  37  to 143 degree and",
                " used for determination of the integrated-over-angles",
                " cross sections  of  photoproton reactions leading to",
                " various states (or groups of states) in the residual",
                " nucleus 88Sr."
              ]
            }
