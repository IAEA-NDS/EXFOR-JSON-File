              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The systematic error was estimated to be be",
                " about 3%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The total error was estimated to be about 6%."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute   differential  cross  section  for  the",
                " photodisintegration of the deuteron at 0 degrees for",
                " the outgoing protons has been measured at lab photon",
                " energies of 20, 30, 40, 75, 100, and 120 MeV using a",
                " magnetic spectrometer and a bremsstrahlung beam. The",
                " absolute cross section values have an error of about",
                " 6% and were determined with an angular resolution of",
                " 1.5 degrees."
              ]
            }
          ],
