          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "As a target a 94.2 % deuterated polyethylene foil was",
                " used with a total thickness of 9.76 mg/cm**2."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The experimental data were analyzed using Monte Carlo",
                " simulation of the entire reaction process, taking",
                " into account the energy loss and the multiple",
                " scattering of the protons in the target, the angular",
                " distribution of the emitted particles, and the energy",
                " dependence of the cross section."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 2H(gamma,p)n cross section was measured absolutely",
                " at 0 degree for the outgoing proton, for photon",
                " energies between 8 and 18 MeV. The rising trend",
                " observed in the cross section in this energy region",
                " indicates the existence of the theoretically predicted",
                " minimum. The results obtained at Egamma about 10 MeV",
                " are well described by recent relativistic",
                " calculations, the data around 15 MeV, on the contrary,",
                " are commonly underestimated."
              ]
            }
          ],
