          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three samples   were  used.  These  were  (D-2)O  (to",
                " monitor  photon  distribution),  (H-2)O  (the   O-16",
                " sample),  and  a  'blank'  (an  empty  container  to",
                " measure the backgrounds)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute total  ground-state  cross  section  was",
                " determined   from   the   series   of   photoneutron",
                " time-of-flight spectra by using  their  highest  5.2",
                " MeV  regions  of bremsstrahlung tip which correspond",
                " unambigiously to the ground-state  transitions  (the",
                " first excited state in O-15 is at 5.2 MeV)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " No information."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photoneutron energy   spectra   from   the   reaction",
                " O-16(g,n0)O-15  were  measured  as  a  functions  of",
                " laboratory angle over a range of excitation energies",
                " from 30 to 35 MeV.  These spectra  and  photoneutron",
                " angular   distributions  were  used  to  obtain  the",
                " absolute photoneutron ground-state cross section and",
                " its quadrupole component."
              ]
            }
          ],
