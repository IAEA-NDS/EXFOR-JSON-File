            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Above    two-neutron    reaction    threshold     the",
                " reaction  (g,2n) cross section was  calculated using",
                " the Weisskopf's   formulae  assuming  a  statistical",
                " decay of the GDR states."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
