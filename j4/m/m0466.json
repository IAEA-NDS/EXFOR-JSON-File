          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A foreground spectrum was derived at each angle.  The",
                " spectrum was assigned as an equivalent photon energy",
                " scale and the counts were  distributed  into  photon",
                " energy  bins of equal width (500 keV).  Spectra thus",
                " obtained   had   been   corrected    for    measured",
                " backgrounds,  dead-time  losses,  and  photon energy",
                " loss.  After that at each angle a differential cross",
                " section  was derived using the procedure of division",
                " of the reaction yield by photon spectrum. The schiff",
                " thin-target  integral-over-angles  spectrum was used",
                " in this procedure."
              ]
            }
          ],
          "REL-REF": [
            {
