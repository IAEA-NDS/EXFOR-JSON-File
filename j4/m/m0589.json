          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photon scattering from 12C and 4He nuclei near the",
                " DELTA (1232) resonance."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "1CANSAS"
              },
              "free_text": [
                " 300 MeV linac at Saskatchevan",
                " Accelerator Laboratory pulse stretcher ring."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " The Boston university large NaI(Tl) gamma",
                " spectrometer with 1.7 % resolution which is a",
                " 26.7 cm diameter cylindrical core of NaI surrounded",
                " by 10.8 cm thick quadrant crystals of NaI."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two carbon targets were used, one 3.98 g/cm**2 thick,",
                " the other 1.6 g/cm**2.",
                "No information about helium target."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "AREA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Systematic errors the major sources of which",
                " were the quantameter calibration and the NaI energy",
                " calibration."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distributions for photon scattering from 12C",
                " and 4He have been measured using continuous wave",
                " bremsstrahlung from the Saskatchevan Accelerator",
                " Laboratory pulse stretcher ring. Data for carbon",
                " were taken at 158.8, 195.2, 197.2, 247.2, and 290.2",
                " MeV end-point energies, and for helium were taken at",
                " an end-point energy of 158.8 MeV. A large NaI(Tl)",
                " gamma ray spectrometer with 1.7 % resolution was",
                " used to detect scattered photons at laboratory",
                " scattering angles, ranging from 20 to 150 degree.",
                " The excellent energy resolution of the NaI detector",
                " allowed a separation of elastic from inelastic",
                " photon scattering for the first time at these",
                " energies. The angular distributions for elastic",
                " scattering are in only fair agreement with delta-hole",
                " theory and theory based on the optical theorem at",
                " forward angles, and completely disagree with theory",
                " at backward angles. Measured cross sections for",
                " inelastic scattering leading to the 4.43 MeV state",
                " in carbon are small compared to the elastic",
                " scattering at forward angles, but are dominant at",
                " backward angles. This experiment is the first to",
                " separate elastic from inelastic photon scattering",
                " at these energies."
              ]
            }
          ],
