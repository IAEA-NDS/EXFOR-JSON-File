          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Photon scattering from 12C and 4He nuclei near the",
                " DELTA (1232) resonance."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
