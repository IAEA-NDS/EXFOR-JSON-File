          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photo-ejected  deuterons  d1 and d2 were detected",
                " in coincidence with the use  of  two  time-of-flight",
                " spectrometers   consisting   of  thin  scintillation",
                " counters.  In each arm the mass, energy and angle of",
                " the detected particle were determined.  This gives a",
                " kinematical overdetermination of the reaction  which",
                " was   used   to  suppress  the  high  background  of",
                " accidental coincidencies and uncorrelated particles."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-energy differential  cross-section  measurements",
                " of the He-4(g,d)d reaction are presented.  The cross",
                " sections are considerably  smaller  than  previously",
                " published  results  and  are  not  consistent with a",
                " predicted E2 transition."
              ]
            }
          ],
