                      "number": null,
                      "volume": "40",
                      "part": null,
                      "issue": null,
                      "page": "441"
                    },
                    "date": 1965
                  }
                }
              },
              "free_text": [
                ".",
                "The spectra  of  photoneutrons  from Li-7 are in very",
                " good agreement for E > 4.5 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "code": "A",
                "subentry_number": "M0282001",
                "author": "M.N.THOMPSON+",
