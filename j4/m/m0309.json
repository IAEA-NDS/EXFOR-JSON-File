          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A diameter of the g-ray beam was 4 cm."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural lithium target (92.5% Li-7, 7.5% Li-6) was",
                " a cylinder (11.9 cm long with a diameter of 5.4 cm)",
                " sealed in a plexiglass container (1 mm thick) with",
                " the front walls of thin mylar. The axis of the target",
                " was parallel to the gamma-ray beam.",
                "The natural berillium target (100% Be-9) was a",
                " parallelepiped (5 cm *  5 cm * 10 cm) with the 10 cm",
                " edge parallel to the direction of the gamma-ray beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " Collection of recoils - 4He."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " A diffusion cloud chamber filled with helium at",
                " 2.3 absolute atm."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors are presented."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photoneutron spectra obtained for Li and Be at 90",
                "degrees are compared with the spectra at 135 degrees",
                "previously measured, for the same targets, gamma-ray",
                "dose and solid angle of acceptance of the detector.",
                "The energies of the states in Li-7 and Be-9 were",
                "deduced from the spectra."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The ratio between the number of photoneutrons from Li",
                "at 90 degrees and at 135 degrees is (1.07 with error",
                "of 0.04) for 0.8<E<12 MeV while for be this ratio is",
                "2.5 for 0.8<e<5 mev and rises for higher photoneutron",
                "energies. In the case of Li-7 there is no indication",
                "of polarization, but for Be-9 there is an indication",
                "of negative polarization for the photoneutrons with",
                "an energy lower than 4 MeV."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "A",
                "subentry_number": "M0306001",
                "author": "A.WATAGHIN+",
                "reference": {
                  "code": "J,NC/B,40,441,1965",
