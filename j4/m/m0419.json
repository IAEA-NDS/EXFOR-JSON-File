          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute cross sections were obtained from",
                "relative cross sections by comparing the",
                "intensity of the compton scattered peak at 7",
                "degrees from special al target with the",
                "corresponding compton cross section obtained from",
                "the Klein-Nishina formula multiplied by the",
                "incoherent scattering function tabulated by",
                "Hubbel et al."
              ]
            }
          ],
