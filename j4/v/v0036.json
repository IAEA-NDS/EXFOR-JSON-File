          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Review of U-238 radiative capture cross-sections",
                " - E(n)=1 keV to 20 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
