          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Evaluation. All experiments were surveyed according to",
                " three different experimental methods,i.e. activation",
                " method, instant gamma spectrometry and spherical-",
                " shell transmission method.",
                "The results were grouped as",
                " A. Absolute measurement;",
                " B. Relative to U-235(n,f) cross-section;",
                " C. Relative to other cross-section value;",
                " D. No experimental detail given",
                "    (least weight for evaluation);",
                " E. Not taken into evaluation."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross-section at 30 keV is used as 'standard value'",
                " then renormalization was performed."
              ]
            }
          ],
