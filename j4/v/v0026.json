          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calculation.",
                "Molecular model based on vibrational frequency",
                " spectrum of SPERVAK, a rotational spectrum adjusted",
                " to reproduce the Glaeser data (W.Glaesser et al.,",
                " Proc.Symp.Inelastic scatt.of Neutrons,Vol.II,P.167,",
                " Bombay(1965)) and diffusion motion, from this a",
                " unique frequency spectrum for the whole molecule was",
                " obtained through a new theoretical scheme to",
                " represent the complex molecular system dynamics.",
                " Further details are to be mentioned as 'New approach",
                " to neutron thermalization, application to benzene'",
                " (Accepted for publication in Atomkernenergie,1980)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Scattering law from GASKET code.",
                " J.Koppel et al., GASKET-A unified code for thermal",
                "  scattering, GA-7417(Rev.),(1967).",
                "Scattering cross-sections from FLANGE-1 code.",
                " M.J.Abbate, NYR190, Version del Programa FLANGE-1,",
                "  ACNYR,CAB. Argentina (1973).",
                "Capture cross section was assumed to follow 1/v,",
                " with 1.9932 barn at 0.0253 eV.",
                "Free scattering cross section = 150.42 barn."
              ]
            }
          ],
