          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear model calculation (see also EXFOR VIEN0027.).",
                "Kerma values are obtained from charged particle and",
                " recoil nuclear spectra.",
                "GNASH computer code, which is a multistep Hauser-",
                " Feshbach statistical model code including a pre-",
                " equilibrium correction for binary channels, produces",
                " particle spectra in centre-of-mass system.",
                "Kerma (total) value is the sum of the initial kinetic",
                " energies of all the charged particles liberated by",
                " indirectly ionising particles."
              ]
            }
          ],
          "REL-REF": [
            {
