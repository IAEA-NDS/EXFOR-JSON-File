          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "p-wave strength function"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.K.Rathi",
                "H.M.Agarwal"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
