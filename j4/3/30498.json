              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Light-charged-particle emission in keV neutron-induced",
                "fission of Pu-239."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
