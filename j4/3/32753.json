            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross section and isomeric cross-section",
                "ratio for the 151Eu(n,a)148m,gPm process from",
                "threshold up to 20 MeV"
              ]
            }
          ],
