          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The weights of natural Mo, Nd and Au metal foils are",
                "0.399 g, 0.161 g and 0.142 g, respectively.",
                "The size of each foil was about 0.88 cm2, 1.44 cm2 and",
                "1.43 cm2, respectively.",
                "Each of the metal foils are wrapped with 0.011 mm thick",
                "Al foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-ray counting of irradiate samples",
                "have been done by using a lead shielded 185-cc Baltic",
                "detector coupled to a PC-based 4096 channel analyzer.",
                "The relative efficiency of the detector is 30 % with",
                "respect to a 3 in. x 3 in. size NaI (Tl) detector.",
                "The resolution of the HPGe detector has a FWHM of",
                "1.8 keV at the photo-peak of 1332.5 keV gamma-ray of",
                "60Co."
              ]
            }
          ],
