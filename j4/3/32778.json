          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A low background, high efficiency HPGe",
                "detector (ORTEC, made in USA) with a relative",
                "efficiency of about 68%, and an energy resolution of",
                "1.7 keV (FWHM) at 1.33 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three ThO2 samples"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The samples were placed at 0, 45 and 90 deg",
                "angles relative to the deuterium beam direction and",
                "centered about the T-Ti target at distance of 35 mm.",
                "The irradiation lasted about 110 min. The cooling time",
                "was about 5 min. The gamma collection were",
                "recorded every one min."
              ]
            }
          ],
