              "coded_information": [
                "3INDTRM"
              ],
              "free_text": [
                " Atomic Energy Establishment, Trombay, Bombay"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR,137,B511,1965",
                "code_unit": [
                  {
                    "unit": "J,PR,137,B511,1965",
                    "doi": "10.1103/PhysRev.137.B511",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR",
