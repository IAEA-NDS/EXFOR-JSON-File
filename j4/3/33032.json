          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Kinetic-energy distributions and the correlation of",
                " anisotropy and asymmetry in the 4-MeV neutron-induced",
                " fission of U235"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.S.Kapoor",
                "D.M.Nadkarni",
                "R.Ramanna",
