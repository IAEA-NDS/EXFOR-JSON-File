          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural Zirconium metal foils of 0.1113 g and 0.2265 g",
                "wrapped with 0.025 mm thick super pure Al foils.",
                "The Gold metal foils of 0.0528 g and 0.0623 g also",
                "wrapped with a 0.025 mm thick Al foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A pre-calibrated 105 cm3 HPGe detector coupled",
                "to a PC-based 4094 channel analyzer.",
                "The resolution of the detector system had a FWHM of",
                " 1.8 keV at 1332.5 keV of 60Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The Al wrapped Au-Zr metal foils were",
                "irradiated with effective neutron energies of 0.61",
                "and 1.05 MeV for 8.53 h and 7.75 h, respectively.",
                "The irradiated zirconium foils were then cooled for",
                "2.97 h and 2.82 h, respectively.",
                "The gold foils were cooled for 21.76-70.80 h and",
                "42.90-92.28 h, respectively."
              ]
            }
          ],
