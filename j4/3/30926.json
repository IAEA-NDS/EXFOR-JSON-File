          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A well mixed sample of natural nickel and melamine",
                " (C3-H6-N6) contained within a reactor grade graphite",
                "capsule."
              ]
            }
          ],
          "FACILITY": [
            {
