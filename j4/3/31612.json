              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN"
              ],
              "free_text": [
                "Activity measurements were performed with a",
                "63-cm3 ORTEC intrinsic N-type germanium coaxial",
                "detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                "",
                "Seven irradiations were performed. Irradiation times",
                "ranged from ~5 to ~ 6min. Every sample and a",
                " (0.1003+-0.0012) wt% gold-aluminum flux monitor were",
                "placed inside a 1-mm-thick Cd cover."
              ]
            }
          ],
