          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "              SAMPLE  PARAMETERS",
                "ISOTOPE    TARGET    RADIUS    WEIGHT    ISOTOPE(10**3)",
                "                      (cm)      (g)       (atom b*-1)",
                " F-19       CF2      10*10      74.12        17.86",
                "                      5.0       57.22        17.55",
                "MG-24      METAL      5.0       22.42         5.659",
                "AL-27      METAL      5.0       44.2         12.57",
                "SI-28      POWDER    10*9.7    136.3         27.87",
                "FE-56      METAL      5.0      147.1         18.49",
                "AU-197     METAL      5.0       52.68         2.08",
                "PB-207     METAL      5.0      365.22         2.99"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Radioactive widths have been measured relative to gold",
                "in the 20-80 keV neutron energy range",
                "Moxon-rae gamma ray detectors were used with time of",
                "flight discrimination of scattered neutron events.",
                "Measurements were alternatively made at about five",
                "minute intervals on the capture sample,carbon,no sample",
                "and gold targets."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MOXR"
              ],
              "free_text": [
                " Two Moxon-Rae detectors,one of which used",
                " a C-Bi convertor."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1 mm thick Li-6 glass scintillator monitored the",
                "transmitted neutron beam"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 19831025,
                "history": "C"
              },
              "free_text": [
                " DG.-"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "date": 20060712,
                "history": "A"
              },
              "free_text": [
                " Date formats and ref.date corrected,",
                " reaction in subentries 5 and 6 corrected"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " -Standard gold cross section 4 per-cent",
                " -Resonance self-shielding and multiple scattering",
                "  5 per-cent",
                " -Agreement with the Moxon codes 1 per-cent",
                " -Gamma ray self-absorption in the sample 5 per-cent",
                " -Statistical errors in the background-subtracted",
                "  gold yields 2 to 6 per-cent",
                " -Resonance gamma ray yields have statistical errors",
                "  of a few per-cent",
                " -Uncertainties in background subtraction are in the",
                "  range 5 to 10 per-cent and for Mg as much as",
                "  15 per-cent"
              ]
            }
          ],
