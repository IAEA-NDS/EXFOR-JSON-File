          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                "",
                "Path 1:",
                " 200 m station with 4 ns burst, useful data down to",
                " about 25 keV. The high resolution dE/E=0.05 to 0.1%",
                " FWHM achieved.",
                "Path 2:",
                " 80 m station, covering the lower energy range below",
                " 25 keV, operating with 7.5 ns burst and energy",
                " resolution of about 0.1%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The detectors were shielded from the low energy",
