          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SLA"
              ],
              "free_text": [
                " The area and the shape of the transmission dip",
                " were analysed using a nonlinear least squares fitting",
                " routine written at the AAEC Lucas heights, which uses",
                " Doppler-broadened Breit-Wigner single-level resonance",
                " theory."
              ]
