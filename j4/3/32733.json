          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples were made from natural Dy2O3 (99.995%",
                "purity) powder, and pellets, about 0.2 cm in",
                "thickness and 20 mm in diameter were obtained using",
                "the press method (10 t/cm2). Two such pellets were",
                "prepared. The samples were sandwiched between two",
                "standard Nb foils (99.999% purity, 0.5 mm thickness",
                "each) of the same diameter utilized to monitor the",
                "neutron fluence via the 93Nb(n,2n)92mNb reaction."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " A T-Ti target was used in the generator, with a",
                "thickness of 2.40 mg/cm2, and the diameter of the",
                "active zone was 12 mm. An effective deuteron beam",
                "energy of 134 keV and beam current of 260 uA."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High-purity germanium (HPGe) detector (ORTEC,",
                "model GEM 60P, crystal diameter: 70.1 mm, crystal",
                "length: 72.3 mm) with a relative efficiency of about",
                "68% and an energy resolution of 1.69 keV at 1.332 MeV",
                "for 60Co. The efficiency of the detector was",
                "pre-calibrated using various standard gamma sources,",
                "namely 57Co, 60Co, 109Cd, 133Ba, 137Cs, 152Eu, 241Am",
                "and 226Ra."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " An Au-Si surface barrier detector was located",
                "at 135 degree to accompany the a-particle tube placed",
                "at a distance of 1.10 m from the target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation of the samples was lasted about",
                "60 min with a neutron yield about 3 to 4E10",
                "n/(4pi*s). The groups of samples were placed at 0 or",
                "135 degree angles relative to the beam direction and",
                "were centered about the tritium-titanium (T-Ti)",
                "target at distances of about 40 mm."
              ]
            }
          ],
