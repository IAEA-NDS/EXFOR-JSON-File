              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3ARGCNE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "C,88MITO,,123,198806",
                "code_unit": [
                  {
                    "unit": "C,88MITO,,123,198806",
                    "doi": null,
                    "field": {
                      "reference_type": "C",
                      "reference": {
                        "code": "88MITO",
                        "number": null,
