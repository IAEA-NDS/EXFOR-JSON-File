          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3ARGCNE"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "100 - 200 microgram/cm**2 thin deposits of natural-",
                "and depleted-uranium-(23ppm U-235) oxide (U3O8) and",
                "thorium-232 oxide (ThO2) were prepared by molecular",
                "plating on polished aluminium disks as to ensure",
                "adequate deposit uniformity. The masses were deter-",
                "mined by alpha-counting assay (uranium) and gamma-",
                "counting assay (thorium).",
                "Indium-115: no further details are given of this",
                "sample."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH",
                "TRD",
                "D4PI",
                "GELI"
              ],
              "free_text": [
                " A miniature fission chamber",
                "and a solid-state nuclear track detector (SSNTD) for",
                "fission fragment counting, a 4Pi-beta proportional",
                "gas flow counter for determining the beta activity of",
                "Mn-56 and a GeLi detector for measuring the gamma",
                "activities of Mn-56 and In-115-m. The aluminium",
                "electroplated deposit is the grounded kathode plate of",
                "the fission chamber. In the SSNTD measurements the",
                "deposits are placed in close contact with the mica",
                "disks between a aluminium back plate and a ring holder."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "ACTIV"
              ],
              "free_text": [
                " External beam irradiation of SSNTD and",
                "fission chamber, activation measurement of the",
                "In-115(n,n)In-115-m reaction relative to Mn monitor."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Radial neutron beam of the RA3 research reactor"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " For In-115(n,n)In-115-m reaction.",
                "From the experimentally determined fission-rate",
                "ratios: depleted uranium/natural uranium and",
                "thorium-232/depleted uranium, and the In-115-m/Mn-56",
                "cross section ratios the ratios presented in subents",
                "002 - 005 were obtained."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections have been made for fission fragment self-",
                "absorption in the deposits, flux perturbation in",
                "the neutron beam and ssntd stack absorption."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Errors are obtained by quadrature sum of",
                "independent error components:",
                "1) Statistics of fission product counting and",
                "systematic errors in fission fragment absorption",
                "corrections, the same for alphas in uranium mass",
                "assay.",
                "2) Statistics of gamma counting uncertainty",
                "and self-absorption for thorium mass assay.",
                "3) Statistics of gamma counting errors and gamma",
                "efficiency calibrations for In-115-m/Mn56 ratio."
              ]
            }
          ],
