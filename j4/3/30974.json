          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of absolute fission rate of natural",
                "depleted uranium and thorium and microscopic cross",
                "section ratios in the radial beam of the RA3."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.Bovisio de Ricabarra",
                "L.Cohen de Porto",
                "D.Walsman",
