              },
              "free_text": [
                " the reaction T(d,n)He4 was used"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " the coincidence circuit between alpha and gamma",
                " detectors with time resolution of 70 ns gated 400",
                " channel pulse height analyser,which recorded the gamma",
                " rays spectra."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " the alpha particles defining the cone of 14.1",
                " MeV neutrons were detected with scintillation counter.",
                " gamma rays from samples were detected with a 2.5 cm",
                " diameter and 5cm long NaI-scintillation counter placed",
                " at 13 cm from the sample."
              ]
            }
          ],
