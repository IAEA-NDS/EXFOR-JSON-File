          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons were produced via the 3H(d,n)4He",
                "reaction with 250 keV deuteron beam and a solid TiT",
                "target (about 2.5 mg/cm2)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A stack was composed with natural isotope abundance",
                "of zinc (0.2 mm, 99.99% purity), niobium (0.2 mm,",
                "99.9% purity), zirconium (0.3 mm, 99.8% purity),",
                "aluminum (1 mm, 99.5% purity), gold (0.4 mm, 99.99%",
                "purity) and indium (0.4 mm, 99.99% purity) foils. All",
                "foils were cut into round disk with a diameter of 18",
                "mm. The precise weight of each foil was determined",
                "with an analytic balance(+-0.01 mg). The stack was",
                "arranged in a sequence of Nb-Zr-In-Au-Zn-Al-Nb and",
                "placed at about 90 degree angle relative to the",
                "deuteron beam direction at a distance of 5 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " The neutron flux was monitored by accompanied",
                "alpha particle with a silicon detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activation of each foil was measured non-",
                "destructively by using a lead shielded HPGe detector",
                "with 25% relative efficiency and 1.9keV energy",
                "resolution at 1332.5 keV of 60Co. The energy and",
                "absolute photopeak efficiency of the HPGe detector",
                "were precalibrated via standard gamma sources (109Cd,",
                "133Ba, 152Eu and 137Cs)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV"
              ],
              "free_text": [
                " Cooling time is 37.0 hours, measurement",
