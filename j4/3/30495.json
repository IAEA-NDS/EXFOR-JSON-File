          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Absolute fission yield measurements by",
                " track-etch-cum-gamma spectrometry"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " CIRUS reactor"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Diluted solution of fissile material in polypropylene",
                " tubes, to determine number of fissions.",
                ".3 micrograms of solution evaporated on superpure Al",
                " foil, to count fission product activities."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ". The mica detector was immersed in the target material",
                "solution, which was irradiated simultaneously with the",
                "target foil. after irradiation, the mica detector was",
                "etched, and the tracks counted.",
                ". the target foil was dissolved, a 5 ml aliquot part",
                "was counted on the Ge-Li detector.",
                "The track registration efficiency was determined by",
                "comparison of the track density obtained in the present",
                "'wet' method with the number of tracks obtained in the",
                "'dry' method (see Nucl.Inst.Meth. 115,p.23)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                ".mica - for counting number of fissions."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ".60cm3, calibrated with standard gamma-sources -",
                "for fission product activities."
              ]
            }
          ],
