              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " Li-7(p,n)Be-7 reaction, using metallic lithium",
                "target of 500 micr-gram/cm2 on tantalum backing."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural nickel metal with purity of 99.99%.",
                "2.54 cm in diameter.  Thicknesses of nickel vary",
                "between 0.4839 and 0.4925 cm for various energies of",
                "bombarding neutrons."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "  The post irradiation gammas after decay of",
                "Co-58 were measured.",
                ".Incident neutron fluxes were measured with a proton",
                "recoil telescope."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " About 40 cm3 laboratory fabricated Ge(Li)",
                "detector.  Calibration was carried out with gamma-gamma",
                "coincidence method using the Ge(Li) to detect 0.51 MeV",
                "gammas and a NaI(Tl) to detect the 0.81 MeV gamma(Co58)",
                ".For the determination of absolute neutron flux, the",
                " proton recoil telescope, which was similar as the one",
                "by Kaeppelar+Froehner,IAEA Proc.Conf.on Nucl.Data for",
                "Reactor,vol.I, 221, Helsinki,(1970), was designed."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A 500 micron n-type silicon surface barrier",
                "detector was used to detect the scattered protons",
                "from the radiator."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " .For neutron monitoring, a long counter and a",
                "shielded NE213 liquid scintillation detector with",
                " (n,gamma) discrimination were used."
              ]
            }
          ],
          "MONITOR": [
            {
