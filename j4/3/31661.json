          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross sections for 190Os(n,p)190m,gRe,",
                "188Os(n,p)188Re and 190Os(n,n')190mOs reactions",
                "from 13.5 to 14.8 MeV"
              ]
            }
          ],
