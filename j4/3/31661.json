          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " the K-400 Neutron Generator at",
                "Chinese Academy of Engineering Physics (CAEP) and",
                "lasted 2 to 3 h with a yield ~4 to 5 x 10**10 n/s."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "About 6 g of Os powder of natural isotopic",
                "composition (99.95% pure) was pressed at 10 ton/cm2,",
                "and a pellet, 0.2 cm thick and 2.0 cm in diameter,",
                "was obtained. Two such pellets were prepared.",
                "Monitor foils of Nb (99.99% pure, 0.2 mm thick) of",
                "the same diameter as the pellets were then attached",
                "in the front and at the back of each sample."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons were produced by the T(d,n)4He reaction",
                "with an effective deuteron beam energy of 134 keV and",
                "beam current of 230 mu-A. The tritium-titanium (T-Ti)",
                "target used in the generator was 2.18 mg/cm2 thick.",
                "The neutron flux was monitored by a uranium fission",
                "chamber so that corrections could be made for small",
                "variations in the yield."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "41-NB-93(N,2N)41-NB-92-M,,SIG",
                  "code_unit": [
                    {
                      "unit": "41-NB-93(N,2N)41-NB-92-M,,SIG",
