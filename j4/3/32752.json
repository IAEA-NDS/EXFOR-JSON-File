          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron-induced activation cross-sections on natural",
                "cerium up to 20 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
