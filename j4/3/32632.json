          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched metallic uranium (more than 90% of",
                "U-235), 16mm diameter, weight (1.0-1.5) g/cm2"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " Light-water swimming-pool reactor and",
                "heavy-water reactor"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spontaneous fission neutrons of Cf-252 source used for",
                "measured reaction.The neutron intensity was 5. x 10**7",
                "neutrons/4Pi/sec, thermal neutrons from thermalizing",
                "column  used for thermal irradiation."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "RVAL"
              ],
              "free_text": [
                " The following formula were used:",
                "Y(x1)=r(x)*Y(x2)*(Y(S1)/Y(S2))",
                "R(x)=(a(x1)*a(S2))/(a(x2)*a(S1))",
                "here Y=absolute yield, a=decay rate,",
                "     x=measured nuclide, S=standard nuclide,",
                "     1=measured reaction, 2=standard reaction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 130 cm2 high resolution coaxial Ge(Li)",
                "detector together with SCORPIO-3000 Multi Channel-",
                "Computer system used for fission products gamma ray",
                "spectrum measurement.The resolution (FWHM) was 2.0 keV",
                "at 1.332 MeV of Co-60,efficiency more than 30 percent."
              ]
            }
          ],
