          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The final cross sections were corrected for",
                " attenuation of the neutron flux through the 2 mm",
                " thick aluminum wall of the ionization chamber.",
                "Using the total neutron cross section of aluminum in",
                " ENDF/B-VII.0, this correction factor was calculated",
                " to be 0.971, 0.972 and 0.975 for 4.0, 5.0 and 6.0 MeV",
                " neutrons, respectively."
