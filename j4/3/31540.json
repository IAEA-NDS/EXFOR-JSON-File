          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples consisted of highly purified and",
                "isotopically enriched metal: 90.5% in 6Li and 95.2%",
                "in 7Li respectively. Both samples were encapsulated in",
                "0.1 mm thick Al cans. The samples are cylinders 4 cm in",
                "length and 2 cm in diameter for 6Li and 2.5 cm in",
                "diameter for 7Li. An identical empty Al can was also",
                "prepared for sample out background measurements."
              ]
            }
          ],
