          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The recoiling fission product from the 244-Cm target",
                "were collected on the 0.0075 cm thick Lexan",
                " (polycarbonate) catcher foils by exposing it at a",
                "distance of 6 mm from the target in 2pai geometry from",
                "a known length of time."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
