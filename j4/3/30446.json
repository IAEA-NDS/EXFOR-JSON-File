            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 16 cm3 Ge(Li) detector. Resolution of 2.5 keV",
                "at 1332 keV gamma-ray."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Ge(Li) detector, gated in a fast-slow coincidence mode",
                "by the NaI(Tl) detector investigated the population of",
                "215.38 keV,(t(1/2)= 48 nsec), isomeric level of Ag-108."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Relative intensities are given.",
                "Hf-180m,Na-22,Na-24,Sc-46 and Co-60 were used to obtain",
                "the total energy peak efficiency curve and",
                "Cr-53(n,g), Ti-48(n,g) and S-32(n,g) reactions to",
                "determine the double-escape peak efficiency."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron separation energy in Ag-108 was determined",
                "to be 7269.1 +- 0.7 keV."
              ]
            }
          ],
