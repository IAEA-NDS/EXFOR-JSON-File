          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A study of (n,d) and (n,t) reactions on Li-7"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
