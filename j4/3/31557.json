          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In order to check that the neutron spectrum at the",
                "irradiation position was an undisturbed 235U fission",
                "neutron flux, several high-purity activation detectors,",
                "ranging in effective threshold energy from 2.6 to",
                "13.4 MeV, were packed together and irradiated at that",
                "position."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation time 2 min.",
                " First measurement 30 to 50 s after irr. and then 4",
                " to 6 times with collecting tomes 2 to 4 min."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 67 cm3 Ortec HPGe intrinsic-N coaxial detector",
                "which has a resolution of 2.0 keV FWHM at 1.33 MeV"
              ]
            }
          ],
