          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron flux calculated for 8.04 +- 0.30 MeV and",
                "11.90 +- 0.35 MeV neutron energies are obtained to be",
                " (3.56 +- 0.03) x 10**6 and (1.30 +- 0.02) x 10**7",
                "n/cm2/s corresponding to the proton energy of 10",
                "and 14 MeV,respectively."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The contribution from the tail region has been",
                "estimated using the ENDF/B-VII.0 and JENDL-4.0 by",
                "folding the cross-sections with neutron flux",
                "distributions in Poppe et al. (1976) and S.Mashnik et",
                "al. (2008). The actual value due to the neutrons from",
                "the main peak of the n0 and n1 groups of the neutron",
                "spectrum is obtained after subtracting the average",
                "cross-section due to neutrons from the tail region."
              ]
            }
          ],
