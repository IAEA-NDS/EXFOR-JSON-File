          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                " The relative efficiency of the scintillator",
                "was calculated by Monte Carlo method and was",
                "normalized at 2 MeV by T(p,n) neutrons.",
                "A Maxwellian spectrum with average energy 2.15 MeV",
                " (T=1.43 MeV) was considered for the 252Cf spontaneous",
                "fission neutron spectrum.",
                "A coincidence between pulses from the 252Cf ion",
                " chamber and liquid scintillator (from prompt fission",
                "gamma rays and neutron-proton recoil events) initiated",
                "40 mu-s counting 585 ns after fission."
              ]
            }
          ],
