          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD",
                "INTED"
              ],
              "free_text": [
                " The experimental (n,p) proton spectrum",
                "was obtained in a fitting procedure of the sum of the",
                "calculated (n,p) and (n,np) spectra to the angle-",
                "integrated experimental spectrum at proton energies >",
                "5 MeV. The (n,p) cross section was obtained by",
                "integrating this (n,p) spectrum over the whole",
                "energy range."
              ]
            }
