          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements on zirconium isotopes for",
                "about 14 MeV neutrons and their theoretical",
                "calculations of excitation functions"
              ]
            }
          ],
