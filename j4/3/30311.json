          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total cross-section of chromium at low neutron energies"
              ]
            }
          ],
          "EXP-YEAR": [
            {
              "pointer": "",
              "coded_information": [
                1974
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "LINAC"
                ],
                "institute": null
              },
              "free_text": [
                " Pulsed 25 MeV electron linear accelerator at",
                "the Centro Atomico Bariloche.",
                "The Linac was run at 25 pps, 2.5 Micro-A average",
                "current for 17 m path and 12.5 pps, 1 micro-A for 3.6m"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Lead target was located inside a liquid nitrogen-cooled",
                "paraffin-moderator for increase of low energy neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Chromium in powder form.  Small contamination of Si,Al,",
                "Fe,Cu,Mn and Mg (ca 0.1%). Aluminium sample",
                "container.  2 Samples, 7.10 and 1.56 mg/cm2 for 17",
                "and 3.6 m flight paths were used respectively.",
                "Sample was kept at the temperature of 20 +- 0.5 Deg C."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight technique, flight path = 17 m and",
                "3.6 m( to measure low energy tail).",
                "For 17 m path measurement, the sample-in-sample-out",
                "method was used, with the sample changer placed at",
                "8.40 m from the neutron source.",
                "For 3.6 m path, He-3 monitor was used instead of the",
                "sample-in-sample-out method to normalize the spectra."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HE3SP"
              ],
              "free_text": [
                " Seven He-3 counters, each of 2.5 cm diam. and",
                "15 cm active length, with 10 atm filling gas pressure."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute, transmission measurement."
              ]
