          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron energy spectrum is generated for the",
                " coincidence region (prompt neutron zone) of TOF",
                " spectra.",
                "The spectrum is normalized to the number of fission",
                " events and the solid angle of the neutron detector",
                " and corrected with the measured neutron detection",
                " efficiency."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An energy spectrum corresponding to a constant",
                " background of a width similar to the coincidence",
                " region of the TOF is also generated by appropriately",
                " shifting the time scale.",
                "The neutron energy spectra corresponding background",
                " region is subtracted from the coincidence region."
              ]
            }
          ],
