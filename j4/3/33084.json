          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " 6MV Folded Tandem Ion Accelerator"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " The produced neutrons are allowed to fall on",
                " a 238U target mounted on the cathode plate of a",
                " fission chamber.",
                "The fission fragments produced in the 238U(n,f)",
                " reaction are detected in 2pi geometry in the fission",
                " chamber.",
                "The cathode plate was kept at ground potential, while",
                " the anode was biased to 600 V through a preamplifier.",
                "The fission fragments ionize the air between the two",
                " plates, generating electron-ion pairs.",
                "The generated electron-ion pairs are then collected at",
                " their respective electrodes, leading to an electrical",
                " pulse, signing a fission event which is then used as",
                " a start pulse for the time-of-flight measurement."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Two EJ301 liquid organic scintillator",
                " detectors (12.7 cm diameter and 5 cm thick) were",
                " placed at a distance of about 70 cm from the fission",
                " chamber, making an angle of 60 degree with respect to",
                " the incident neutron beam direction on either side of",
                " the beam.",
                "The detection efficiency was determined by measuring",
                " the 252Cf neutron spectrum."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF",
