          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal:",
                " 0.3268 g and ~1 mm thick natural Zr metal foil, and",
                " 0.0215 g Au metal foil (neutron flux monitor) wrapped",
                " separately with 0.025 mm thick aluminium foil in",
                " alkathene bags.",
                "2.45 MeV:",
                " Two samples, 0.0952 g, 1 mm thick natural Zr metal",
                " foil and 0.057 g of In metal foil (neutron flux",
                " monitor) wrapped separately with 0.025 mm thick Al",
                " foil in alkathene bags.",
                "9.85 MeV:",
                " 0.1694 g natural Zr metal foil and 1 mm thick of In",
                " metal foil (neutron flux monitor) wrapped separately",
                " with 0.025 mm thick Al foil in alkathene bags."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 80 cm3 HPGe detector coupled to a personal",
                " computer-based 4 K multichannel analyzer.",
                "The efficiency of the detector was 20% with energy",
                " resolution of 2.0 keV FWHM at 1332.0 KeV."
              ]
            }
          ],
