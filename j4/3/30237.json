          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The time distribution of gammas emitted by the",
                "short-lived isomers is measured using =",
                "     -the recoiled alpha particle from the d-t reaction",
                "        to determine the zero of time",
                "     -a pulsed beam to improve the effect-to-background",
                "        ratio"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Decay gammas from metastable states are detected",
                "by a plastic scintillator NE102/A associated with a",
                "photomultiplier XP 1040.",
                "The recoiled alpha particles are detected by a thin",
                "plastic scintillator NE102/A associated with a",
                "photomultiplier 56AVP."
              ]
            }
          ],
