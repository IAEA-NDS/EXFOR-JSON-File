          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " 220 KeV deuteron beam and the average beam",
                " current is 350 uA.",
                "The solid T-Ti target used was 2.18 mg/cm2 in thick.",
                "The neutron flux was monitored by a uranium fission",
                " chamber."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-purity NaBr (99.9%) of natural Bromine isotopes",
                " pressed into 20 mm diameter and 4.78-10.78 mm thick",
                " slices.",
                "Each NaBr sample was sandwiched between two Nb foils",
                " (the thickness of each Nb foil: less than 0.20 mm),",
                " and the purity of the Nb foils was better than",
                " 99.99%.",
                "One Nb foil and one Zr foil had been put together as",
                " a group and used to determine the neutron energy in",
                " the experiment."
              ]
            }
          ],
