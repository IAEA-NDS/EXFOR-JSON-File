          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A cylindrical brass chamber, 19 cm in diam. and 6.6 cm",
                "in height was filled with the gas under study at",
                "atmospheric pressure. Natural neon gas consists of",
                "90.92% 20Ne, 0.26% 21Ne and 8.82% 22Ne."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three exposures were made:",
                "  a) with neon gas at atmospheric pressure,",
                "  b) with vacuum in the chamber which served as the",
                "     background for hydrogen as well as neon,",
                "  c) with hydrogen gas at atmospheric pressure which",
                "     served as the standard for determination of the",
                "     neon cross-section; this was also used as a check",
                "     on the geometry employed, by studying the known",
                "     energy and angular distributions of the recoil",
                "     protons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " Ilford K2 emulsions of 400 mu-m thickness were",
                "           used as detectors."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The neutron flux was monitored with a gamma-",
                " insensitive boron-plastic zinc-sulphide scintillator."
              ]
            }
          ],
