                      "data_type": null,
                      "general_quantity_modifier": null,
                      "quantity_236": ",TEM"
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "   for evaporation of 1st neutrons."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In Mn-55(n,2n)Mn-54 reactions, the neutron spectra of",
                "1st and 2nd neutron-emissions were assumed to be fitted",
                "with the constant-temperature type formula,",
                "A*E*(exp(-E/T)) after correction for the detector",
                "efficiency. E, T and A are kinetic energy of the",
                "neutron, nuclear temperature and normalization constant",
                "respectively."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
              "coded_information": [
                "MISC"
              ],
              "free_text": [
                "   Nuclear temperature for evaporation of 2nd",
                "neutrons."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The ratio of the number from the first to the second",
                "neutrons in the Mn-55(n,2n) process is,",
                "      3.6 +- 1.5.",
                "and this indicates a strong neutron-gamma competition",
                "than expectation on the usual statistical assumption."
              ]
            }
          ],
          "ENDBIB": {
            "N1": 0,
            "N2": 0
