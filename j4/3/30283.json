          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Raw data were corrected for deadtime, mean emission",
                "time and background. Inscattering and multiple scatte-",
                "ring corrections were found negligible.",
                "The 20 total cross-sections curves were averaged as",
                "follows=",
                " 1. Region below 10**-2 eV:  weights 3, 2 and 1 were",
                "    respectively attributed to the 1 cm, 1.4 cm and",
                "    1.8 cm samples.",
                " 2. Region above 1 eV:  weights 3, 2 and 1 were respec-",
                "    tively attributed to the 1.8 cm, 1.4cm and 1 cm",
                "    samples.",
                " 3. Region between 10**-2 and 1eV:  equal weights for",
                "    the 3 samples.",
                "Correction was also performed for H-O-D (0.41%)",
                "contamination."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Data errors include statistical +systemati-",
                "cal errors which consist of the",
                " .Error due to temperature variations (upper limit was",
                "   estimated to 0.2% at 10**-3 eV by using the",
                "   value of the total cross section at 9 degrees-C by",
                "   Whittemore,60Wien,511(1960).",
                " .Error due to the sample thickness (0.1%).",
                " .Errors arising from the non-uniformity of the",
                "   containers glass walls  (0.2%)."
              ]
            }
