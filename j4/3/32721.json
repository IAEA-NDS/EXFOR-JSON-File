          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FPGAM"
              ],
              "free_text": [
                " The yields of fission products 89Rb, 92Sr,",
                "94Y and 138Cs at thermal neutron were obtained by",
                "applying the emission rate of high-energy delayed",
                "gamma-rays per fission."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR",
                "HPGE"
              ],
              "free_text": [
                " The geometry of NaI detector is 300x200",
                "mm in diameter and length, the energy non-linearity is",
                "less than 2.%, and energy discrimination for 137Cs",
                "0.662 MeV gamma ray is 29%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Decay gamma spectrum area was determined with SPAN",
                "code, and cumulative fission yield was calculated by",
                "FYAUTOLS code."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " To subtract the contamination from interfere",
                "nuclides, the half-life analysis method was adopted."
              ]
            }
          ],
