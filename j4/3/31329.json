          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Samples of enriched isotopes of 94Zr, 91Zr, 108Pd,",
                "110Pd, 184W and 186W in the powder form along with",
                "natural Zr and Pd foils and natural W powder were",
                "bombarded with 14.8 MeV neutrons."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "    Activation"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " Low-background beta-counter with a background",
                "     of 2.8 counts per min."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation gamma-ray spectrometer fitted with",
                "     an automatic scanner and a rate meter."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The (n,d) type cross section values in Zr, Pd and W",
                "isotopes were obtained in relation to the cross",
                "sections of 64 hr activity in 90Zr(n,p)90Y, 14 hr",
                "activity in 110Pd(n,2n)109Pd and 8.7 hr activity in",
                "184W(n,p)184Ta serving as internal standards. The",
                "cross-sections for these 64 hr, 14 hr and 8,7 hr",
                "activities of these internal standards were in turn",
                "cross checked and determined accurately in comparison",
                "with Yasumi's value (see J.Phys.Soc.Japan,12,443,1957)",
                "of 556 mb for the 63Cu(n,2n)62Cu reaction."
              ]
            }
          ],
