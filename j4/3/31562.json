          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Tin-foil (0.1 mm thick, 99.999% pure) weighing 50 mg,",
                "was sealed in a quartz ampoule, studded with neutron",
                "flux monitor foils and then placed in an NRX type",
                "irradiation capsule. The monitor foils were washed",
                "with acetone; dried and weighed before attaching to",
                "the ampoules."
              ]
            }
          ],
