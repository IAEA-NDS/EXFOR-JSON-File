          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of thermal neutron capture cross-section",
                "and resonance integral for the 165Ho(n,gamma)166gHo",
                "reaction by the activation method"
              ]
            }
          ],
