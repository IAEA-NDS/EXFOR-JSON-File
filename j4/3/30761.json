          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The aim of this work is to investigate the structure",
                "in the low energy part of the long-range alpha-particle",
                " (LRA)spectrum in spontaneous fission of Cf-252. The",
                "authors found that there exists a weak structure in",
                "the region 10-14 MeV of the LRA spectrum in the case",
                "of angle 67deg laboratory system(the emission angle of3",
                "the LRA with respect to the direction of the light",
                "fragment)."
              ]
            }
          ],
