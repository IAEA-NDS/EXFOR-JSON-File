          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of fission neutron spectrum averaged cross",
                "sections of some threshold reactions on ruthenium:",
                "small scale production of 96Tc in a nuclear reactor"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
