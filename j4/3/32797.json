          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " K-400 Intense Neutron Generator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons in the 14 MeV region with a yield of",
                "about 5E10 n/s were produced with a deuteron beam",
                "energy of 255 keV and a beam current of 320 uA. T-Ti",
                "target was about 2.19 mg/cm2 thick. The neutron flux",
                "was monitored by the accompanied alpha-particles."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural tungsten foils, 99.99% in purity and 2mm in",
                "thickness, were made into circular samples with",
                "diameter of 20 mm. Each was sandwiched between two",
                "99.99% pure circular niobium foils with a diameter of",
                "20mm and 1mm thickness, and then wrapped in 99.95%",
                "pure cadmium foil with 1mm thickness. Groups of",
                "samples were placed at 45 and 135 deg with respect to",
                "the deuteron beam direction. The distances of samples",
                "from the T-Ti target were about 3-5 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " GEM-60P coaxial high-purity germanium (HPGe)",
                "detector (crystal diameter 70.1 mm, crystal length",
                "72.3mm) with a relative efficiency of about 68% and",
                "an energy resolution of 1.69 keV at 1332 keV for 60Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiations was from 2 to 3 hours. The",
                "cooling time of the sample after the end of",
                "irradiation was about 5 min, it take about 1 hour to",
                "measure the sample."
              ]
            }
          ],
