          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of the cross-sections of produced",
                "short-lived nuclei induced by neutrons around 14 MeV",
                "on isotopes of tungsten"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Xiao-Jun Sun",
