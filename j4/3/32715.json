          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of activation cross-sections for the",
                "101Ru(n,p)101Tc reaction for neutrons with energies",
                "between 13 and 15 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Junhua Luo",
