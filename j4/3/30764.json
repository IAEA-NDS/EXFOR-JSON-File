          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets characteristics",
                "*****************************************************",
                "Element   Nuclei         Length     Area      Purity",
                "          density",
                "        (10**22/cm2)     ( cm )    ( cm-2 )    ( % )",
                "C         11.30           3.00       4.95       99.0",
                "MG         4.30           3.02       5.11       99.7",
                "AL         6.01           2.54       5.01       99.7",
                "CU         8.46           1.50       5.07       99.7",
                "GE         4.40           2.64       6.84       99.7",
                "PB         3.30           2.00       6.25       99.7",
                "*****************************************************"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute measurements"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3CHLSAN"
              },
              "free_text": [
