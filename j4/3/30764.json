          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "",
                "* Deuteron beam of 3.41 +- 0.08 MeV",
                "* The beam intensity was restricted to about 1 m AMP",
                "* Faraday cup used for deuteron beam monitoring"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Transmission measurements"
              ]
