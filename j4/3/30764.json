            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "",
                "* Two neutron detectors were used to determine the",
                "number of neutrons coming from the Ti-T target; each",
                "one consists of a rectangular sheet of plastic",
                "scintillator NE-102 of 0.8 mm in thickness and",
                "35.8 x 58.7 mm2 in area. The neutron to proton",
                "converter was a 2 mm paraffin sheet preceded by a",
                "2 mm graphite sheet.",
                "* A third detector , a 5.04 cm height by 5.02 cm",
                "diameter NE-102 pastic scint.,was used to monitor",
                "the gamma flash from the target."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Several corrections were considered, most of them are",
                "eliminated by the ratio involving target in and out.",
                "One that remains is due to low energy neutrons from",
                "reactions between deuterons and backing materials and",
                "from the Pb in Faraday cup.",
                "This represent less than 4 % to the measured sigma."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
