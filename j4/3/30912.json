          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "OLMS"
              ],
              "free_text": [
                " The fission yield measurements were performed",
                "with a negative surface  ionization integrated",
                "target-ion source. This source selectively ionizes",
                "only  Br and I isotopes, while the ionization",
                "efficiency for the potential  contaminants Se and Te",
                "is two orders of magnitude lower. Only Se and Te are",
                "considered since they are nuclei with relatively high",
                "electron affinities i.e.  1.97eV and 2.02 eV,",
                "respectively. Whereas other potential contaminants",
                "i.e.  As. Rb, Sb  or Cs, have electron affinities of",
                "                                            < 1.0 eV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BSPEC"
              ],
              "free_text": [
                ".Beta activity scans at collector over desired",
                " mass region."
              ]
