              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Cross section was calculated from the pure",
                "activity of Te-132 which was determined from the net",
                "area under the 228.2 keV photopeak."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The net area of the 228.2 keV photopeak of Te-132 was",
                "corrected for branching ratio, gamma-ray self",
                "absorption, fission yield, detector efficiency,",
                "irradiation time, decay time, counting time and",
                "interferences from neighbouring photopeaks of Np-239",
                "and Pa-234. The relative contributions from these",
                "photopeaks to the 228.20 keV peak of Te-132 were",
                "determined by measuring the net areas under 278.0 keV",
                "and 1001.0 keV of Np-239 and Pa-234 respectively."
              ]
            }
          ],
