          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural and depleted uranium foils of 9 mm diameter",
                "and 0.1 to 0.32 mm thick. Purity was determined to be",
                "92.5% by neutron activation, using standard uranium",
                "foil, and chemical analysis."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "CF252"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutron flux was determined from the informa-",
                "tion provided by the manufacturer. The contribution of",
                "spontaneous fission neutrons of Cm-248 to the neutron",
                "flux density was estimated to be 0.13%."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cf-252 fission neutron spectrum"
              ]
            }
          ],
