          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Three gamma spectrometers, collected on the",
                "basis of HPGe Canberra and Ortec detectors. The",
                "energy resolutions of HPGe spectrometers were 1.8 -",
                "2.0 keV for the gamma-line of 1332 keV of 60Co.",
                "The efficiency of detecting gamma-decay quanta was",
                "determined using standard calibration sources of",
                "152,154 Eu and 133Ba."
              ]
            }
          ],
