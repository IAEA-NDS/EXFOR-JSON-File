          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Foils for irradiation were assembled and included a",
                "monitor target made of metallic aluminium foil with",
                "thickness of 200 mu-m, which was initially placed;",
                "behind it the investigated lutetium target with a",
                "thickness of 170 mu-m and mass of 165 mg was located.",
                "Two monitor targets were placed behind it, and made",
                "of metallic aluminium with thickness of 200 mu-m and",
                "metallic niobium with a thickness of 100 mu-m."
              ]
            }
          ],
