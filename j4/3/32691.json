              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "About 3 g of HfO2 powder of natural isotopic",
                "composition (>99.95% pure) was pressed at 10 ton/cm2,",
                "and a pellet, 0.3 cm thick and 2.0 cm in diameter was",
                "obtained."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " CH8403 coaxial high-purity germanium detector",
                "made in the People's Republic of China with a",
                "relative efficiency of 20% and an energy resolution",
                "of 3 keV at at 1332 keV gamma ray from Co-60."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The Au-Si surface barrier detector used in",
                "135 deg. accompanying alpha particle tube was at a",
                "distance of 119.7 cm from the target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation of the samples was carried out at",
                "the ZF-300-II Intense Neutron Generator at Lanzhou",
                "University and lasted about 22 h with a yield around",
                "0.8E11 to 2.4E11 n/s."
              ]
            }
          ],
