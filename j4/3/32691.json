          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The tritium-titanium (T-Ti) target used in the",
                "generator was 0.9 mg/cm2 thick. The effective source",
                "neutron energy at irradiation position was determined",
                "by the Nb/Zr method, and the uncertainty in the",
                "neutron energy at around 5 cm was estimated to",
                "be 200 keV from a consideration of the sample sizes,",
                "beam diameter of about 3-4mm, and the uncertainty in",
                "the Nb/Zr method."
              ]
            }
          ],
