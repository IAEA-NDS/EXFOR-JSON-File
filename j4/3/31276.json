          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The outcoming neutrons were detected by an indium foil",
                " of thickness 110 g/cm2. The indium foil was activated",
                " for nearly five half-lives of 116In, and the induced",
                " activity was followed for 1.5 hrs. The counting rate",
                " was extrapolated to zero time. Initial activity due",
                " to thermal neutrons only was obtained by the cadmium",
                " difference technique."
              ]
            }
