          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,ARI,147,144,2019",
                "code_unit": [
                  {
                    "unit": "J,ARI,147,144,2019",
                    "doi": "10.1016/j.apradiso.2019.03.012",
                    "field": {
