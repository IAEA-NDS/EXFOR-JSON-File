          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " Two Ge-detectors:",
                "  1) the coaxial HPGE detector with sensitive volume",
                "     110 cm3;",
                "  2) planar GE detector with thin beryllium window",
                "     10x7 mm, beryllium thickness 127 micro-m.",
                "The energy resolution of the spectrometers was 2.1 keV",
                " at Eg=1332 keV and 184 eV at 4.46 keV."
              ]
            }
          ],
