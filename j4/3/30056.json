          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The data at 1.17 MeV was compared with theoretical",
                "distributions based on Hauser-Feshbach-Satchler",
                "formalism indicating a high M1+E2 admixture for 0.89MeV",
                "gamma-rays. Its excitation function was also measured",
                "up to 2MeV and compared with H-F theory. Clear evidence",
                "for     a cascade transition between the first two",
                "excited states was found"
              ]
            }
