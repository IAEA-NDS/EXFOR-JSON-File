          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Ground-state and isomeric-state cross-sections for",
                "74Se(n,2n)73Se reaction in the 13-15 MeV energy region"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
