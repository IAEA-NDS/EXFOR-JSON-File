          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "2 mil. thick pure thorium metal foils of size 0.8 cm",
                "x 1.5 cm. The target foil was sandwiched between two",
                "2.5 cm x 1.8 cm super pure aluminum foils of 1 mil.",
                "thickness and two similar aluminium foils for the",
                "determination of activation impurities. The whole",
                "assembly was wrapped in 1 mil. aluminium foil and",
                "then in 5 mil. aluminium foil. The target assembly",
                "was then wrapped in 0.5 mm thick cadmium foil."
              ]
            }
