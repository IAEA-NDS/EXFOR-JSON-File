          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples of Nb and Zr as foils 20 mm in diameter",
                "all were 99.99% purity. The Nb sample in each group",
                "was sandwiched between two Zr foils."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutron yield is around 3E12 n/s. T-Ti taret",
                "was around 0.9 mg/cm2 thick. The neutron energies at",
                "0, 50, 90 and 120 degree were determined by cross",
                "section ratios of 90-Zr(n,2n)89m+g-Zr and",
                "93-Nb(n,2n)92m-Nb."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A CH8403 coaxial high-purity germanium",
                "detector with a relative efficiency of 20% and an",
                "energy resolution of 3 keV at 1.33 MeV. In gamma ray",
                "measurement, the distance between sample and HPGe is",
                "2 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " The neutron flux was monitored by a uranium",
                "fission chamber."
              ]
            }
          ],
          "METHOD": [
