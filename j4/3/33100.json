          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "About 0.0657 gm (for 3.12 MeV) and 0.0166 gm (for 4.12",
                "MeV) of MnO2 powder and 1 mm thick natural indium",
                "metal foils of same size were wrapped separately with",
                "0.025 mm thick super pure Al foil. The size of the",
                "Al wrapped MnO2 powder sample was 1.0 cm2 with a",
                "thickness of 29.3 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High purity germanium detector coupled to a",
                "personal computer-based 4K channel analyzer."
              ]
            }
          ],
