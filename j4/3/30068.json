          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Investigations on the angular distribution of neutron-",
                "induced 238-U fission using solid state track detectors"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuterium tritium reaction"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uranium layers of 1 mg/cm2 thick and 5mm diam deposited",
                "on 0.1 mm thick Al foil through electrolysis"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission fragment detection",
                "sample placed at 45 degrees with n-beam, 15 cm from",
                "target. Angular dist from 0-90 and 90-180 degrees was",
                "measured on independent samples(both sides of Al foil)",
                "detectors were placed on circle of 10cm diam around the",
                "sample in a vacuum chamber"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                " solid-state track detector (Zeiss glass",
                "microscope cover slides)."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "92-U-238(N,F),,SIG",
                  "code_unit": [
                    {
                      "unit": "92-U-238(N,F),,SIG",
                      "field": {
                        "reaction": "92-U-238(N,F)",
                        "target": "92-U-238",
                        "projectile": "N",
                        "process": "F",
                        "product": "",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " Data normalized to sigma(n,f) = 1.22 barn"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                " Fission fragments"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In all 7500 tracks were measured in forward and back-",
                "ward directions. A curve of form",
                "    sigma(theta) = A + B*(cos(theta))**2",
                "was fitted to the data giving A= 84.9 and B= 36.3 mb/sr",
                "anisotropy W(0)/W(90) was 1.43 +- 0.05 in agreement",
                "with previous results"
              ]
            }
          ],
