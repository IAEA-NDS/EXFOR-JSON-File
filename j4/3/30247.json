          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The p-wave strength functions were extracted from the",
                "average capture cross sections by subtracting the",
                "S-wave contribution,which was calculated from known",
                "average resonance parameters under the assumptions that",
                "radiation width is the same for s- and p-wave capture",
                "and average level spacing for p-waves is one-third of",
                "the s-wave level spacing."
              ]
            }
          ],
