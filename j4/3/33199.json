          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For short-lived fission products, nitrate solution of",
                "245Cm (~1 ug) sealed in two different polypropylene",
                "tubes were wrapped separately with 1 mm thick Cd foil.",
                "For long-lived fission products, two different",
                "electrodeposited (0.5 cm diam.) targets of 245Cm",
                " (~4 ug) were covered with 0.075 mm thick Lexan foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 120 cm3 detector with 1.8 keV FWHM resolution at",
                "the 1332.5 keV 60Co photo-peak."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Off-line gamma-ray spectrometry.",
                "For short-lived target were irradiated one at a",
                "time for 16-21 min at a flux of 1.2 X 10**12 n/cm2/sec.",
                "For long-lived target were irradiated one at a time",
                " for 60-92 min"
              ]
            }
          ],
