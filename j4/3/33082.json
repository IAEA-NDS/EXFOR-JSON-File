          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "About 100 mu-g of 235U was deposited",
                "electrostatically over a 5 mm spot on a 5 cm diameter",
                "aluminum."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "IOCH",
                "SCIN"
              ],
              "free_text": [
                " A 5 cm diameter aluminium plate at",
                "a positive potential acts as collecting electrode of",
                "the gas ionization chamber (GIC). The fission",
                "fragments traversed a distance of 35 mm before",
                "striking a 1 cm diameter exposed area of the thin",
                "film scintillation detector (TFSD). The thickness of",
                "the TFSD was about 15 micro-m. The experimental",
                "chamber was filled with argon gas at a pressure of 85",
                "mm of mercury."
              ]
            }
          ],
