          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " According to authors, almost the whole inelastic",
                " scattering process procedes through the 847 keV gamma",
                " line which was measured in conincidence with neutrons.",
                " Therefore these data represent the partial cross",
                " section for a certain energy range of outgoing",
                " neutrons."
              ]
            }
          ],
