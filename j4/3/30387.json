            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Although the existence of 855-keV state was proved by",
                "the presence of its de-excitation gamma-rays of 237 and",
                "274 keV, no transition from the 855-keV level to the",
                "ground state was observed in this experiment,",
                "apparently due to the low transition rate and heavy",
                "background in this energy region."
              ]
            }
          ],
