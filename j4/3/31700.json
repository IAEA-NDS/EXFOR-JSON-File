          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "56-BA-138",
                "field_identifier": "NAT",
                "value": 0.717
              },
              "free_text": [
                "",
                "A 10 ppm standard solution of barium. The certified",
                "concentration of the barium in the barium standard",
                "solution was 9.92 +/- 0.03 mg/g",
                "Comparator isotope Mn-56, was also contained in a",
                "10 ppm standard solution of manganese. The certified",
                "concentration of manganese in the manganese standard",
                "was 10.01 +/- 0.03 mg/g.",
                "About 10 ml of the solution was poured into",
                "a polyethylene capsule (12.00 mm in outer diameter and",
                "24.00 mm in outer length) for the irradiation within a",
                "Cd capsule."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " After the irradiation, induced radioactivity",
                "in the target samples were counted from a distance of",
                "7.20 cm from the detector using a high purity Ge-",
                "detector (ORTEC) with relative efficiency of 25% and",
                "an energy resolution of 1.8 keV (FWHM) at 1.33 MeV of",
                "60Co."
              ]
            }
          ],
          "METHOD": [
            {
