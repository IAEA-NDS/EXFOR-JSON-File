          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Irradiations of samples were performed at a thermal",
                "power level of 15 kW, which corresponds to thermal",
                "neutron flux value of 1x10**11 n/cm**2/s. The epitherma",
                "neutron shaping factor (a) of the inner irradiation",
                "channel 2 which was used for the measurement is",
                "0.961 +/- 0.034 and the Cadmium ratio are 3.47 +/- 0.07",
                " and 2.36 +/- 0.01 for 94Zr and 197Au respectively."
              ]
            }
