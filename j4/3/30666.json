          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The collection efficiency for Kr and Xe were checked by",
                "measuring the activities of I-135 and Xe-135 (trapped",
                "in different columns) and was found almost 100%.",
                "Gamma spectra were analysed and fission yields",
                "calculated from genetic relationships in beta-decay",
                "mass chains using relevant decay data."
              ]
