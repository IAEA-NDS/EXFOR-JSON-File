              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " gamma-gamma coincidence (70 ns) between the",
                "start trigger and any one of the 25 detectors in the",
                "LAMBDA array. High threshold (4 MeV) was chosen to",
                "ensure fission events."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The neutron-gamma discrimination of the events in",
                "the high energy spectrometer."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " To reject neutron detection by measuring the",
                "charge deposition over two integrating time intervals",
                " (50 ns and 2 us) in each of the detectors."
              ]
            }
