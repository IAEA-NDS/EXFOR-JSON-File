          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " K-400 Neutron Generator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The T-Mo target used in the generator, had a",
                "thickness of 0.57 mg/cm2, and an active zone diameter",
                "of 12 mm. Neutrons were generated with a mean",
                "deuteron beam energy of 125 keV and a beam current of",
                "300 uA. Throughout the process of irradiation, the",
                "neutron flux was monitored by the accompanying",
                "alpha-particles, so that corrections could be",
                "performed for small variations in the yield."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three samples were made from natural Te (99.995%",
                "purity) powder, and each one in the form of a pellet,",
                "about 1.8 mm in thickness and 20 mm in diameter.",
                "These pellets were then sandwiched between two",
                "standard Nb foils (99.999% purity, 0.5 mm thick each)",
                "having equal diameter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The entire process for irradiation of all the",
                "three samples was lasted about 3 hours with a yield",
                "about 3 to 4 E10 n/(4 pai s). The groups of samples",
                "were positioned at 0, 90 and 135 deg relative to the",
                "beam direction. Cooling time is 27 hours."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " An Au-Si surface barrier detector used to",
                "detect accompanying alpha-particles was positioned at",
                "135 deg relative to the beam direction and a distance",
                "of 1.10 m from the target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-ray activities of 121mTe, 121gTe",
                "and 93mNb were measured by using a high-purity",
                "germanium detector."
              ]
            }
          ],
