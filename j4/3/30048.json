          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distributions of alpha particles from the",
                "reaction 16O(n,alfa)13C at En=14.1 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": null
              },
              "free_text": [
                "      Cockcroft-Walton accelerator working as a",
                "pulsed neutron source synchronized to the detector"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "      T(d,n)He4 reaction with 150 keV deuterons"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "See detector"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stereoscopic photography of the tracks with 2 cameras.",
                "track lengths and angles measured optically.",
                "Evaluation of alpha-particle energy made by means of",
                "range-energy table of whaling.(Encyclopedia of Physics",
                "XXXIV,193,1958) and checked  experimentally with Po-210",
                "alpha source"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                "      Expansion cloud chamber 40 cm diameter and",
                "20 cm height filled with oxygen gas at 1 atm."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Theoretical fits to observed angular distributions",
                "attempted in terms of heavy-particle stripping process",
                "for backward angles and of knock-on process for forward",
                "angles using simple butler formula. Reasonably well fit",
                "except in most backward angles."
              ]
            }
          ],
