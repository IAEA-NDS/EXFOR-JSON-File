              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Proton recoil telescopes (PRTs) were",
                "downstream installed in a chamber after FIXM for",
                "measuring the n-p scattering. The chamber was",
                "maintained at 5E-3 Pa during the measurement."
              ]
            }
          ],
