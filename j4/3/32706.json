          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Author did not do a vacant target experiment, but the",
                " new T-Ti target was used in the present work, and the",
                " time of irradiating the samples was short around 2 h.",
                "Furthermore, the samples were wrapped in cadmium foil",
                " and placed at the appropriate positions, which were",
                " both far and also near around 3 to 5 cm away from the",
                " center of the T-Ti target, so the influence of",
                " low-energy neutrons was reduced to a very low level."
              ]
            }
