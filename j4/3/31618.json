          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross sections for (n,2n), (n,p) and (n,alpha)",
                "reactions on osmium isotopes in the neutron energy",
                "range of 13.5 - 14.8 MeV"
              ]
            }
          ],
