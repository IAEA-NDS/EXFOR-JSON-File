          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Li- and Be-intensities relative to the emission of",
                "100 alpha particles were calculated with",
                "  the extrapolated spectrum of alpha particles,",
                "  the measured parts of the Li and Be spectra",
                "                    (''experimental  yields''), and",
                "  the extrapolated spectra of these nuclei",
                "                    (''extrapolated yields'').",
                "The extrapolation was performed assuming a symmetrical",
                "shape of the energy distributions of all particles."
              ]
            }
