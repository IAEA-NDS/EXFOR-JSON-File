            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Li and Be nuclei emitted during the thermal neutron",
                "fission of U-235."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " EWA reactor."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal spectrum.  Neutron flux was about",
                "6. x 10**8/cm2/sec and the cadmium ratio was 34."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "2 mg/cm2 U(3)-O(8), enriched in U-235 to 95%,",
                "with a 25 mm diam. was deposited onto a 18 mg/cm2",
                "platinum backing."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Measurement with a two-counter telescope."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SIBAR"
              ],
              "free_text": [
                " Two-counter telescope with a",
                "proportional counter as the delta-E detector (filled",
                "with Kr+5% Co2 to a pressure of 90 mm Hg).  To avoid",
                "delta-E detector from overloading by FF and the natural",
                "alpha radioactivity of the target, a 13 mg/cm2 tantalum",
                "window was used.",
                " As E-detector, a surface-barrier silicon detector with",
                "a depletion layer of 300 micron was placed inside pro-",
                "portional counter."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
