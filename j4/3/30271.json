          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-sections of (n,t) reactions with 14.7 MeV",
                "neutrons determined by direct beta-counting of tritium"
              ]
            }
          ],
          "EXP-YEAR": [
