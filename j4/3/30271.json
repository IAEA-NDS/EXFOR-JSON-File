                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " T(d,n) alpha reaction"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metallic samples of 1 to 20 g were wrapped three-fold",
                "in aluminium and plastic foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Tritium produced in metallic samples was extracted by",
                "inductional heating in presence of hydrogen carrier",
                "in vacuum system and measured by internal gas propor-",
                "tional counting."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Internal gas proportional counter. Low back-",
                "ground was achieved by anticoincidence guard ring and/",
                "or by pulse shape discrimination. The overall efficien-",
                "cy of the system, including vacuum apparatus and coun-",
                "ter, is about 50%."
              ]
            }
          ],
