          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A high purity (99.90%) natural bismuth metal plate",
                " (9.8 g/cm3) shaped as square sheets (50.06 +- 0.01 mm",
                " x 50.14 +- 0.01 mm) and with a thickness of",
                " 3.0 +- 0.1 mm was used as the transmission",
                " measurement sample.",
                "A set of notch filters of Co, In, and Cd plates which",
                " have the same size as that of Bi sample were used for",
                " the background measurement and energy calibration."
              ]
            }
