          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The correction coefficient F = Fs * Fc * Fg,",
                "Fs is the self-absorption correction coefficient,",
                "Fc is the cascade coincidence correction coefficient,",
                "Fg is the geometric correction coefficient."
              ]
            }
          ],
