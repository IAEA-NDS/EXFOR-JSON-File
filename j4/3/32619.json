          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " The average energy 1.35 and 1.80 MeV deuteron",
                "      beam from the Van De Graaff bombarding a D-Ti",
                "      target to generate 4.5 and 5.0 MeV neutrons.",
                "      The deuteron beam of 3.7 and 5.03 MeV from the",
                "      cyclotron bombarding the solid Ti-D target",
                "      (thickness 2.04 mg/cm2) to generate 6.3 and 7.6",
                "      MeV neutrons; The deuteron beam bombarding the",
                "      gaseous deuteron target to generate the 10.0 and",
                "      11.4 MeV neutrons; The 200 keV deuteron beam",
                "      from the Cockcroft-Walton accelerator bombarding",
                "      the Ti-T target (thickness=0.5 mg/cm2) to get",
                "      13-15 MeV neutrons;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " 2.1 MeV deuteron beam from the Van De Graaff",
                "      bombarding Ti-T target (thickness 2.05-2.34",
                "      mg/cm2) to generate 12-18 MeV neutrons."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " A diameter 100*75 mm nai(tl) crystal was used",
                "        for gamma-ray detection, the efficiency of",
                "        full energy peak was calibrated using standard",
                "        sources:",
                "         In-114m (0.192 MeV)",
                "         Au-198  (0.412 MeV)",
                "         Cs-137  (0.662 MeV)",
                "         Mn-56   (0.845 MeV)",
                "         Sc-46   (0.89  MeV, 1.12 MeV)",
                "         Na-24   (1.37  MeV, 2.75 MeV)"
              ]
            }
          ],
