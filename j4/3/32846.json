          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Five samples As2S3 (powder of > 98% purity) were",
                "pressed into circular disks with a diameter of 20 mm",
                "and a thickness of 1 mm. Each sample was wrapped in",
                "0.1 mm thick aluminium foils, sandwiched between two",
                "monitor gold foils (purity > 99.99%) with thickness",
                "0.1 mm, and then wrapped in 0.3 mm thick cadmium",
                "foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " To monitor neutron flux."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-ray activities of 76As and 98Au were",
                "determined."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The samples were irradiated simultaneously at",
                "0, 30, 60, 90 and 120 deg with respect to the",
                "incident beam. The irradiation lasted 27 h and 17.5 h",
                "by the neutrons were produced by Li-7(p,n) and T(p,n)",
                "reaction, respectively."
              ]
            }
          ],
