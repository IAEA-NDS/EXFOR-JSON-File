              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRLNZ"
              },
              "free_text": [
                " The ZF-300-II Intense Neutron Generator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The metallic natural samples of Re and Al as foils 20",
                "mm in diameter were 99.9% and 99.999% purity. The Re",
                "sample in each group was sandwiched between two Al",
                "foils."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " An effective deuteron beam energy and beam",
                "current is 125 keV and 20 mA. T-Ti target was around",
                "0.9 mg/cm2 thick. The neutron energies for various",
                "directions were determined by cross section ratios of",
                "90-Zr(n,2n)89m+g-Zr and 93-Nb(n,2n)92m-Nb."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A CH8403 coaxial high-purity germanium",
                "detector with a relative efficiency of 20% and an",
                "energy resolution of 3 keV at 1.33 MeV. The",
                "efficiency was calibrated by a standard gamma-source,",
                "standard reference material 4275 from the National",
                "Institute of Standards and Technology."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " The neutron flux was monitored by a uranium",
                "fission chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation was lasted 2.5 hours with a",
                "yield of 1 to 3E12 n/s. Groups of samples were placed",
                "at 0 to 130 degree relative to the beam direction and",
                "centered about the T-Ti target at distances of 2-20 cm."
              ]
            }
          ],
          "MONITOR": [
