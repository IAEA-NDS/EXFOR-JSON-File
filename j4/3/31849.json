              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two bismuth disc of purity 99.9999%. Each disc was 8 mm",
                "in diam. and 1 mm thick, and weighed 0.484(4) g.",
                "Each was placed in a separate quartz flask, where one",
                "of the flasks was covered with 0.5 mm thick Cd foil.",
                "The flasks were placed end to end lenthwise is a known",
                "location near the core at a known flux and gold cadmium",
                "ratio 3.1."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma activity of irradiated samples was",
                "measured with HPGe detector with normal efficiency of",
                "31% with respect to a 2-in. X 2-in. NaI."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation divided into three separate",
                "irradiations, the total irradiation time was about",
                "20 hrs."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Cooling time was 809.0 days without Cd-covered,",
                "and 825.8 days with Cd-covered sample.",
                "The gamma activation measurement time is 8.11 days",
                "without Cd-covered and 8.17 days with Cd-covered sample"
              ]
            }
          ],
