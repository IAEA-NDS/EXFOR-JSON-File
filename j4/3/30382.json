            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron burst width was 30 ns which gave energy",
                "resolution (dE/E) less than 0.2%.  Beam filter",
                "of 0.45 g/cm2 of B-10 was used to eliminate overlap",
                "neutrons from the beam."
              ]
            }
          ],
