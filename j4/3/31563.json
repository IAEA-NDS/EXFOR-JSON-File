          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission neutron spectrum averaged cross sections of",
                "some threshold reactions on tellurium: estimation",
                "of radioactive impurities in (n,g)-produced 131Te-131I"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "M.Arif",
