          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inelastic scattering of 14.8 MeV neutrons from deuteron"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Transformer type neutron generator",
                "   at Pinstech, Nilore, Rawalpindi."
              ]
            }
          ],
          "INC-SOURCE": [
