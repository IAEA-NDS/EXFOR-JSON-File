          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " NE-213 scintillator, 2 inch X 2 inch, placed in",
                " a borated wax and lead shielding.",
                ". NE-230 scintillator as scatterer provided a stop",
                " signal for the time-to-pulse amplitude converter.",
                ". Neutron-gamma pulse shape discrimination was applied."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "ASSOP"
              ],
              "free_text": [
                " The scatterer(NE-230) was placed at about",
                "12 cm from the neutron target."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No standard used. Neutron flux was determined by",
                " associated particle method. The absolute efficiency",
                " of the neutron detector was experimentally determined",
                " from its response to the known flux of monoenergetic",
                " neutrons.(See Waheed et al.,Pinstech Int.Rep.No.5(NPD)",
                " (FNPG).  Then the measured efficiency was fitted to",
                " the value obtained with Monte Carlo calculation.",
                "The side experiment of carbon breakup was used to",
                " verify the efficiency curve."
              ]
            }
          ],
