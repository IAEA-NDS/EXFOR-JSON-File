          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of the cross section for (n,p) reaction",
                " with producing short-lived nuclei on the 162,163Dy",
                " isotopes at 13.5 and 14.8 MeV"
              ]
            }
          ],
