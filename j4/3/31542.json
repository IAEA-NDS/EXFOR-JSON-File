          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Naturally high pure W, Gd and Ag metallic foils in",
                " disk shape (2.54 cm diam, 0.05 mm thick).",
                "Each sample was sandwiched between two Au foils",
                " in disk shape (2.54 cm diam, 0.01 mm thick) as the",
                " neutron flux monitors.",
                "The sample groups were wrapped in Cd covers",
                " (0.5 mm thick) to reject most of thermal neutron",
                " background."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FNB"
              ],
              "free_text": [
                " The structures of the filters are",
                "  Si(98 cm) +S(35g/cm2)+10B(0.2g/cm2)   for En=55 keV,",
                "  Si(98 cm) +Ti(1 cm)  +10B (0.2 g/cm2) for En=144 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High resolution and efficiency calibrated HPGe",
                "  detector.",
                " The samples were placed on the surface of the",
                "  detector because of their weak activities."
              ]
            }
