          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions and isomeric cross section ratios",
                "of the 63Cu(n,alpha)Co-60-m,g, 65Cu(n,alpha)Co-62-m,g",
                "and 60Ni(n,p)Co-60-m,g processes from 6 to 15 MeV."
              ]
            }
          ],
          "AUTHOR": [
