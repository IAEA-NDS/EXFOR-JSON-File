              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "3HUNKOS"
              },
              "free_text": [
                " 13.7-14.8 MeV neutrons, neutron genera-",
                "tor."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2GERJUL"
              },
              "free_text": [
                " 6.3-9.2 and 10.1-11.94 MeV neutrons,",
                "variable-energy compact Cyclotron CV28."
              ]
            }
          ],
