          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Samples were placed at zero degrees with",
                "respect to the deuteron beam at a distance of 1 cm",
                "from the back of the beams top. The energy of the",
                "deuteron beam was varied between 4. And 9.5 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Monoenergetic neutrons were produced via the",
                "3H(d,n)4He reaction on a solid TiT target in the",
                "experiment with the Debrecen neutron generator. The",
                "neutron energy was selected by the angular position",
                "of the sample with respect to the deuteron beam axis."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
