          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural Manganese powder of 99.9% purity was made",
                " into circular thin samples with a diameter of 20 mm",
                " and the thickness of 1.5-2.6 mm, which were",
                " sandwiched between two disks of thin Al of the same",
                " diameter. The purity of the Al metal was better than",
                " 99.99%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A well-calibrated GEM-60P coaxial high-purity",
                " germanium (HPGe) detector was used with 70.1x72.3 mm",
                " in diameter and length for the crystal, respectively.",
                "The relative efficiency was about 68%, and the energy",
                " resolution was about 1.69 keV (FWHM) at 1.33 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                " Irradiation of the samples was carried",
                " out and lasted 15 min with a neutron yield of about",
                " 3E10 to 5E10 n/s."
              ]
            }
          ],
