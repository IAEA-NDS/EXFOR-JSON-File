                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " CIRUS reactor Trombay"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "92-U-235",
                "field_identifier": "ENR",
                "value": 0.94
              },
              "free_text": [
                " Sample thickness 18 ug/cm2 and",
                "diameter of 1 cm was electro-sprayed on a thin gold",
                "coated VYNS film."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Common cathode back-to-back ionization",
                "chamber. The common cathode contained the sample of",
                "235U. The grid-cathode and grid-collector distances",
                "were 2.8 and 0.6 cm respectively. The two collectors",
                "had thin aluminium windows of 2 mg/cm2 thickness at",
                "their centres. The chamber was filled with a gas",
                "mixture of argon (95 %) and methane (5%) to a",
                "pressure of 92 cm of mercury to stop the fission",
                "fragments in the cathode-grid region."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Behind the ionization chamber two",
                "semiconductor detectors with depletion depth of 500",
                "um and area of 2 cm2 were mounted to detect the LRAs",
                "emitted in fission."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Alpha particles were measured in coincidence",
                "with fission fragments."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutron flux 3x10E+7 n/cm2.s"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calibration constants for the conversion of collector",
                "and grid pulse heights into energy and angle of the",
                "fission fragments were obtained using binary data.",
                "The energy of the fission fragments were converted",
                "into mass using the momentum and mass conservation",
                "relations. The most probable values and the standard",
                "deviations of the energy distributions are extracted",
                "as a function of mass of heavier fission fragment."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A",
                "FF"
              ],
              "free_text": [
                " Alpha and fission fragments"
              ]
            }
          ],
