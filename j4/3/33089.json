          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Multiparameter study of the long-range a-particles",
                "emitted in the thermal neutron induced fission of 235U"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
