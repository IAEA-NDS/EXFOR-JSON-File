          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3CZRUJF"
              },
              "free_text": [
                "  VVR-S reactor at Rez"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal spectrum at the horizontal channel of the VVR-S",
                "reactor (neutron flux of about 10**8 n/cm2.sec)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin layer (0.1 mg/cm2) of U-O2 (enriched in U-235 to",
                "90%) deposited on an Al backing (18 mg/cm2, 1 cm",
                "in diameter)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The telescope was not shielded by an Al-foil. Such an",
                "arrangement does not require correction for the energy",
                "of detected alphas thus resulting in a lower background"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Charged particle telescope consisting of a",
                " - totally depleted gold surface barrier silicon diode",
                "   (80 mm2, 27 mu thick) for the 'dE/dx' detector,",
                " - gold surface barrier silicon diode (300 mm2, 700 mu",
                "   thick for the depletion layer) for the 'E' detector.",
                "Before each run the energy calibration was checked",
                "using the natural alpha-radioactivity of U-235. The",
                "energy resolution was found to be 50 keV for the 'E'",
                "detector and 160 keV for the telescope."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                " Alpha particles"
              ]
            }
