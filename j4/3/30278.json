          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The investigation of LRA fission of U-235 by",
                "non-shielded semiconductor telescope"
              ]
            }
          ],
          "EXP-YEAR": [
            {
              "pointer": "",
              "coded_information": [
                1974
              ],
              "free_text": [
                ""
              ]
