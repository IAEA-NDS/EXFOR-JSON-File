          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total neutron cross sections of Be, C and F near 14 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron generator."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " T(d,n)He-4 reaction using a thick tritiated",
                "titanium target."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy resolution is 50 keV at En = 13.70 MeV",
                "                         20 keV at En = 14.00 MeV",
                "                        110 keV at En = 14.60 MeV"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Approximately 2 cm in diameter. The lengths were chosen",
                "so that the transmissions were about 50%"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Transmission measurements in  good geometry"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The detector was a 2*2 cm stilbene scintillator.",
                "The monitor was a 2.2*3 cm anthracene crystal.",
                "Both are mounted on rca 6810a photomultipliers. Pulse-",
                "shape discrimination was used against gamma-ray",
                "background. The bias-window method was used to",
                "eliminate electronic instability.",
                "Tritium target-detector distance = 60 cm, the sample",
                "was placed midway between them."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                " neutrons."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measured data are averaged over 4 or 5 independent",
                "measurements."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The statistical errors in the transmission",
                "data are less than 0.5%. After background and",
                "in-scattering corrections they amount to 1%"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Systematic errors (e.g. in the weight and",
                "diameter of sample) are identical at all energies and",
                "also amount to about 1%",
                "Statistical and systematic errors on carbone and teflon",
                "total cross-sections are combined to obtain the 2%",
                "errors on fluor total cross-section"
              ]
            }
          ],
