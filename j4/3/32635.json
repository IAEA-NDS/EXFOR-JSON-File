          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measurement of cumulative fission yield of U-235",
                "induced by thermo- and  fission spectrum neutrons by",
                "using Ge(Li) detector"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
