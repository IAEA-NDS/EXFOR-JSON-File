          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Both U3O8 and metallic uranium were used for sample,",
                "its weight are as follows :",
                "sample       weight for fission     weight for thermal",
                "             neutron (Mg)           neutrons (mg)",
                "metallic U    744.15 and 839.10      754.80 and 812.80",
                "U3O8               632.13               630.85",
                "isotopes component are as follows :",
                "U-234      U-235      U-236      U-238",
                "0.011      0.902      0.003      0.084"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3CPRAEP"
              },
              "free_text": [
                " Heavy-water reactor"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutrons from horizontal hole of reactor. The",
                "fission spectrum neutrons were produced by a 150 gram",
                "enriched uranium (90% of U-235) convertor",
                "irradiated by the thermal neutrons beam. The intensity",
                "was about 1. x 10**9 n/4Pi/sec"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FPGAM"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 145 cm3 coaxial Ge(Li) detector with",
                "resolution 2.0 keV at 1332.5 keV gamma ray of Co-60",
                "was used for gamma measurement. The absolute efficiency",
                "was calibrated with a series of standard sources :",
                "Sc-46,(Zr-95)-(Nb-95),Ag-108m,Cs-137,Ce-144,",
                " (Ba-140)-(La-140),Ta-182."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " a back-to-back fission ionization chamber was",
                "used for fission rate measurement."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made for",
                ". pulse pile-up",
                ". gamma self-absorption in U-235 sample",
                ". geometry"
              ]
            }
          ],
