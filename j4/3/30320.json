          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " EWA reactor. The original neutron spectrum is",
                " relatively rich in fast neutron. Full pile spectrum",
                " and epicadmium neutrons were used for measurement of",
                " the hydrogen isotopes, for correction of background",
                " due to (n,p) process induced by fast neutrons.",
                " For He isotopes, only full reactor neutron spectrum",
                " was used."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " About 6 mg/cm2 thick Pu-239 target deposited on",
                " tantalum foil of 13.25mg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Counter telescope with semiconductor detectors"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SOLST",
                "SOLST"
              ],
              "free_text": [
                " Semiconductor telescope.",
                " The delta-E- and E- detectors are 50 mu and 1500 mu",
                " thick, respectively. For the detection of helium",
                " isotopes, a thinner delta- E-semiconductor detector",
                " (25 mu) was used."
              ]
            }
          ],
