          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "94-PU-239",
                "field_identifier": "ENR",
                "value": 0.95
              },
              "free_text": [
                "",
                "Plutonium containing about 95% 239Pu, enriched",
                "uranium containing about 90% 235U and uranium-233",
                "were purified chemically and used for target",
                "preparation. The targets were prepared by",
                "electroplating. The amount of fissionable material",
                "on a target varied from 10 to 50 mu-g depending on the",
                "length of irradiation and nuclides of interest."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 2 cm3-(4 cm2 area x 5 mm depl.) Ge(Li)"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The yields of nuclides in the thermal-neutron-induced",
                "fission of 239Pu were determined relative to that of",
                "235U. The nuclides determined in the work were not",
                "sufficient for plotting mass-yield curve for",
                "normalization. The ratio of 99Mo yields in 239Pu to",
                "235U fission was used."
              ]
            },
