          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of (n,xn) reaction cross sections on",
                "113,115In isotopes using quasi-monoenergetic neutrons",
                "within 10-20 MeV"
              ]
            }
          ],
