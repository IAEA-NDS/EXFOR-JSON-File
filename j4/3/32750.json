                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " The K-400 Intense Neutron Generator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two samples (ThO2 powder of 99.5% purity) and monitor",
                " Al (thin Al foil of 99.99% purity) are made into",
                " round disks with a diameter of 2.0 cm; the",
                " thicknesses of samples are around 1.0 mm (THO2) and",
                " 0.05 mm (Al).",
                "The samples were placed at 0, 45 and 90 deg. relative",
                " to the deuteron beam direction and centered about the",
                " target at distances of 35 mm."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " A deuteron beam of 220-250 keV and beam current",
                " of 230 uA used.",
                "The solid tritium-titanium target used in the neutron",
                " generator was about 2.18 mg/cm2.",
                "The neutron energies in the measurements are",
                " determined by the cross section ratio of the",
                " 90Zr(n,2n)89Zr to 93Nb(n,2n)92mNb reactions."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The relative efficiency is 68%, and the energy",
                " resolution is around 1.7 keV at 1332.5 keV."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                " The neutron flux is about 2x10E11 n/s monitored",
                " by accompanying alpha particle."
              ]
            }
          ],
