          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The isomeric-ratio-method to derive the spin-cut-off",
                "parameter given by Huizenga and Vandenbosch in Phys.",
                "Rev. Vol 120,pages 1305+1313 (1960) is applied. In",
                "this method the number of gamma rays emitted in the",
                "process of compound nucleus de-excitation and the spin",
                "cut-off parameter are both variables. If one of these",
                "parameters is known, the other can be calculated by",
                "comparing the measured values of the isomeric-cross",
                "section ratio with the theoretically computed values.",
                "Here in this article (Nucl.Phys. Vol A117,page 545",
                " (1968)) the gamma ray parameter is known by making",
                "use of the references(65Geneva vol 15,page 138 Groshev)",
                "and (Nuovo Cimento vol 22,page 1327 (1961) Erba)",
                "whereas the experimental cross section ratio of these",
                "authors (Chaubey and Sehgal) is taken."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "53-I-127(N,G)53-I-128,,SIG",
                  "code_unit": [
                    {
                      "unit": "53-I-127(N,G)53-I-128,,SIG",
