          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-purity GeO2 (99.99%), PdCl2 (99.9%), and Yb2O3",
                " (99.99%) of natural isotopic composition was pressed",
                " into 20 mm diameter and 2.0-3.9mm thickness slice.",
                "Each of them was sandwiched between two Nb foils or",
                " Al foils, and the purity of the Nb and Al foils were",
                "better than 99.99%."
              ]
            }
