          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "71-LU-175",
                "field_identifier": "NAT",
                "value": 0.97401
              },
              "free_text": [
                " Three samples Lu2O3 (powder",
                "of > 99.99% purity) were pressed into circular disks",
                "with a diameter of 1.27 cm, the thickness of samples",
                "was around 2 mm. Each sample was sandwiched between",
                "two monitor aluminum (99.99% purity and about 3 um",
                "thickness) foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High efficiency HPGe detector with a relative",
                "efficiency of about 68% and an energy resolution of",
                "1.7 keV (FWHM) at 1.33 MeV. The detection efficiency",
                "was calibrated by the standard sources 60Co, 109Cd,",
                "137Cs, 152Eu, 226Ra, and 241Am."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiating time was about 240 min. The",
                "samples were placed at 0, 45 and 90 deg angles",
                "relative to the deuterium beam direction and centered",
                "about the T-Ti target at distance of 4.0 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Off-line gamma-ray spectrometry"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
