            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for",
                " - neutron flux fluctuation  (K),",
                " - geometry                 (Fg),",
                " - coincidence sum effect   (Fc),",
                " - gamma self-absorption    (Fs)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties mainly came from the",
                "detection efficiency and statistical uncertainty of",
                "counts of the full-energy gamma-ray peaks, and also",
                "including the other parts: correction factor F,",
                "neutron flux fluctuation factor K, decay constant,",
                "mass and corresponding geometric conditions."
              ]
