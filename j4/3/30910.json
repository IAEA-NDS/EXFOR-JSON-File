          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The separation-time activities of I-132-m and",
                "I-132-g were determined from a least-square fit of the",
                "observed I-132-g activity as function of cooling time,",
                "using standard decay-growth equations, and were",
                "correlated to the corresponding fractional independent",
                "yield ratio. The contribution of the decay of the",
                "precursor Te-132 to the I-132-g activity, which was",
                "found to be 6-7% from a calculation, was neglected."
              ]
            }
