            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Compiler considers",
                "measured \"thermal\" cross section given in this work",
                "as equal to the value at 0.0253 eV energy point",
                "because corrections at deviation of cross sections",
                "from 1/V and spectrum in epithermal region from",
                "1/E dependence are introduced"
              ]
            }
