          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for accidental coincidence, dead time and",
                "decay.",
                "For thermal cross section: corrected at the",
                "contribution in the activation from 0.308 eV and 0.573",
                "eV resonances, at the departure of the epithermal",
                "neutron spectrum from 1/E dependence and at the",
                "non-ideal Cd cut-off of thermal neutrons with Monte",
                "Carlo simulation calculations.",
                "For resonance integral, the Monte Carlo simulated",
                "corrections was equal to 7.5%, corrected at resonance",
                "self-shielding"
              ]
            }
          ],
