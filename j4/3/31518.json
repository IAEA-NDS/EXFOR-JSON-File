          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the thermal neutron capture cross",
                "section and resonance integral of Am-241"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation method with measuring the",
                "activity with 4Pi-beta-gamma coincidence system",
                "applying the tracer technique. 30 min irradiation time",
                "for thermal cross section measurements and 60 min for",
                "resonance integral measurements. Time interval between",
                "the end of irradiation and counting is about 60 min.",
                "2 irradiations for thermal cross section determination",
                "After irradiation the sample",
                "was diluted in 1 M HNO3 solution and activity was",
                "measured in 4-Pi-beta-gamma system for source prepared.",
                "Details are given in the paper"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " IEA-R1 pool-type IPEN research reactor operating",
                "at 2 MW power"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Core of the reactor"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Flux of thermal neutrons 2.8E+12 n/cm*2/sec with",
                "epithermal index in the Westcott r*sqrt(T/T0)",
                "convention equals to 0.036. A slight variation in the",
                "epithermal neutron spectrum with respect to the usual",
                "1/E form was observed"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "PROPC",
                "NAICR"
              ],
              "free_text": [
                " gas flow proportional counter with",
                "4-Pi geometry (90%Ar + 10%CH4, 0.1 MPA) as the beta",
                "detector in the coincidence with",
                "two 7.6*7.6-cm NaI(Tl) scintillation counter",
                "as gamma-detector. The selected gamma-channel window",
                "covered both 1173 and 1332 keV peaks of Co-60"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "40 MBq Am target sealed inside a double 0.2 mm thick",
                "polyethylene and placed inside polyethylene rabbit"
              ]
            }
          ],
