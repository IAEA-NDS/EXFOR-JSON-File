          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural samples of W (99.97%) with thickness 1.0",
                "mm and about a quarter of a circle with radius 1 to 3",
                "cm were used.",
                "The Gd samples were made in the form of a pellet with",
                "radius of 0.65 cm and thickness from 0.5 to 1.0 mm",
                "using Gd2O3 (99.9%) powder."
              ]
            }
          ],
