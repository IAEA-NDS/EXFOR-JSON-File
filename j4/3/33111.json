              ],
              "free_text": [
                " A precalibrated high purity germanium (HPGe)",
                "detector with 4-K channels was used to measure the",
                "gamma ray spectra. The detector was calibrated using",
                "standard 152Eu multi-gamma-ray source."
              ]
            }
