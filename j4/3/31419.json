          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An activation stack was composed of a titanium foil as",
                "sample, 1.25 mm thick and 0.5 cm in diameter, and of",
                "aluminium, niobium and gold foils."
              ]
            }
          ],
