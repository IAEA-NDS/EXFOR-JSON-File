          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total correction factor of the activity were made up",
                "of fs and fg: F=fs*fg. fs and fg were the correction",
                "factors for the self-absorption of the sample at a",
                "given gamma-ray energy and the counting geometry.",
                "Correction factors for the self-absorption at 139.68",
                "and 264.6 keV gamma-rays are 1.163, 1.067 for sample",
                "1 (0.1863 cm), and 1.081, 1.034 for sample 2 (0.0948",
                "cm)."
              ]
            }
          ],
