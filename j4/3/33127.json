          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sample was the mixture of natural CeCl3 (99.99%) powder",
                "and thin pieces of aluminum foil (99.99%), of total",
                "weight of ~ 1.5 g, in a polythene bag.",
                "By folding the polythene bag the cerium-aluminum sample",
                "of size ~10 mm X 10 mm X 3 mm was obtained."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " To measure gamma-ray activities of the",
                "irradiation samples.",
                "The detection efficiency was measured with a Canberra",
                "make Multi Standard MGS-3 gamma-ray source.",
                "The resolution of detector was ~2.5 keV at 1332 keV",
                "gamma-rays of 60Co source."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation for 240 sec., then measured for",
