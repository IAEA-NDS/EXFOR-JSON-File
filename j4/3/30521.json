          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "0.75 mg/cm2 U-235, deposited on 0.5 mg/cm2 Ni-foil."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                ". Of light fragment, heavy fragment and light",
                "charged particle ('LCP')."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ".",
                "Geometry: Maximum angle between the LCP and fission",
