          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy spectrum of prompt neutrons from Cf-252",
                "spontaneous fission was measured for energy range 0.9",
                "to 14.5 MeV. Three data sets obtained from different",
                "flight path were fitted to a 'Maxwellian distribution'",
                "respectively, and the weighted average value was",
                "t=1.418+-0.015 MeV."
              ]
            }
          ],
