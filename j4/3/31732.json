          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total capture cross section was derived from:",
                "1) the sum of all the partial cross sections of primary",
                "transitions depopulating the capture state;",
                "2) the sum of the partial capture cross sections of the",
                "transitions feeding the ground state; or",
                "3) the sum of all the observed partial cross sections",
                "weighted with the energy of the transition divided by",
                "the total g-ray energy liberated in the capture event"
              ]
            }
