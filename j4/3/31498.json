          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron-Induced Reaction Cross Sections between 9",
                "and 14 MeV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3BZLIEN"
              },
              "free_text": [
                " CV-28 cyclotron"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " 30 mm long 12 mm diameter cylindrical chamber",
                "filled with 2 atm of deuterium gas was bombarded with",
                "deutron beams of app. 2 mcA extracted from CV-28",
                "cyclotron. Neutron flux was on the order of 10E+7",
                "n/sec*cm2."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural nickel, cobalt and vanadium targets of 10 mm",
                "diameter and 0.1 mm thickness, stacked with aluminium",
                "foils of the same dimension, were placed 2 cm away",
                "from the neutron source. Stacks were irradiated for",
                "approximatly 5 h."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activity induced by the continous spectrum D-D",
                "break up neutrons (0 - 6 MeV) was subtracted by an",
                "unfolding technique using the aluminium monitor."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Gamma ray activity was determined by high-purity",
                "detector shielded with 5 cm of lead with energy",
                "resolution of 1.75 KeV at 1.33 MeV."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
