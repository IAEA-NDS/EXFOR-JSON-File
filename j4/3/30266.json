          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " High resolution Si(Li) x-ray spectrometer. The",
                "shape of the efficiency curve in the 20 keV energy",
                "region was calculated from the relative intensity of",
                "K-alpha and K-beta lines of In and Rh. A U-235 source",
                "of known activity was used for calibration."
              ]
            }
          ],
