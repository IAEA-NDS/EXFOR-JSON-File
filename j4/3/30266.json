          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The self-absorption of K x-rays was determined using",
                "different sample thicknesses from 43 to 150 mg/cm2"
              ]
            }
          ],
          "METHOD": [
            {
