          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " neutron intensity of about 3-4 x 10**10 n/s.",
                "Neutrons were produced by the T(d,n)4He reaction",
                "with an effective d+ beam energy of 220 KeV and the",
                "average beam current is 350 mu-A. A solid tritium-",
                "titanium (T-Ti) target with 2.18 mg/cm2 thickness",
                "was used."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-purity GeO2 (99.99%)of natural isotopic",
                "composition was pressed into 20 mm diameter and",
                "2.5-3.9 mm thickness slice. Each Germanium sample",
                "was sandwiched between two Al foils, and the purity",
                "of the Al foils is better than 99.99%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                "coaxial HPGe detector (ORTEC, made in USA)",
                "with a relative efficiency of 68% and an energy",
                "resolution of 1.69 keV FWHM at 1.33 MeV."
              ]
            }
          ],
