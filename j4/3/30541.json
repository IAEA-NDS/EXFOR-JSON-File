          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "First, the fraction of each delayed neutron group",
                " present in each chopper speed was calculated.",
                "Then the average energies for each group could be",
                " derived."
              ]
            }
          ],
