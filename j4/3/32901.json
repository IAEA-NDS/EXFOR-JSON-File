          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Based on the HI-13 tandem accelerator.",
                "A deuterium gas target to produce neutrons, a grid",
                "ionization chamber (GIC) with a 238U3O8 sample",
                " (99.999%) to measure the neutron fluences, the",
                "diamond detector as an active target and the particle",
                "detector, and a EJ-309 liquid scintillator to measure",
                "the neutron energy spectra. The deuteron beam current",
                "was about 1.5 uA and the total beam duration was",
                "about 8 h."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Based on the Cockcroft-Walton generator.",
                "A T-Ti solid target to produce neutrons, a Au-Si",
                "surface barrier de tector for associated alpha",
                "particle detection and the diamond detector as an",
                "active target and the charged particle detector.",
                "The deuteron beam current was about 200 uA and",
                "the total beam duration was about 6 h."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A single crystal chemical vapor deposited (sCVD)",
                "diamond detector as both the particle detector and",
                "the target, with an area of 4.0 X 4.0 mm2 and a",
                "thickness of 500 um."
              ]
            }
          ],
