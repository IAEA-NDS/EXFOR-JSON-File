          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of the yields for the rare-earth",
                "nuclides from 14 MeV neutron fission of U-238 using",
                "a Ge(Li) detector."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Li Wenxin",
