          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "",
                "neutron flux about (1-2) x 10**11 neutrons/4Pi/sec,",
                "average neutron energy=14.7+-0.4 MeV"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "FPGAM"
              ],
              "free_text": [
                "",
                "first, fission products were separated from the",
                "irradiated samples by radiochemistry methods and",
                "weighted for the determination of the chemical yield.",
                "Then fission product gamma rays were measured with",
                "calibrated Ge(Li) detector for determining the",
                "cumulative fission yield."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 140 cm3 coaxial Ge(Li) detector, resolution",
                "was 2.8 keV at 1.332 MeV of Co-60, together with a",
                "4096 channel analyser. The relative detection",
                "efficiency was calibrated using well know intensity",
                "gamma ray sources."
              ]
            }
          ],
