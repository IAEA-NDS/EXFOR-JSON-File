              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma-spectrum photopeak analysis; decay of samples",
                " was checked for correct half lives and radiochemical",
                " purity. Standard equations were used for calculation",
                " of activities from photopeak areas and for buildup",
                " and decay."
              ]
