          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "kT=30 keV MACS of an evaluated cross section",
                " renormalized by the ratio of the measured cross",
                " section to the evaluated cross section folded by the",
                " LiLiT spectrum (0.93+/-0.01 for Ep=1910 keV,",
                " 1.08+/-0.03 for Ep=1946 keV), and multiplied by",
                " 2/sqrt(pi).",
                "The evaluation cross section was taken from JEFF and",
                " ROSFOND the MACS with the two libraries are averaged.",
                "The weighted averaged was obtained from the MACS from",
                " Ep=1910 keV irradiation (404(41)mb) and Ep=1946 keV",
                " irradiation (364(38) mb)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
