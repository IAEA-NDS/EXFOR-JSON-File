          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural metal foil of Pd,Fe and Nb were 20mm in",
                "diameter and 2mm 0.5mm 0.2mm in thickness and 99.9%",
                "99.95% and 99.9% in purity, respectively. The Pd sample",
                "in each group was sandwiched between two Fe or Nb",
                "foils. The groups of samples were irradiated at",
                "distances 3cm-23cm away from the neutron source and at",
                "angles 0-140 with respect to the beam direction."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section for 46-Pd-110(n,2n)46-Pd-109",
                "reaction were corrected for the influence of neutron",
                "capture in Pd-108 present in the natural samples."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The error in the work result from:",
                " 1. counting statistics",
                " 2. standard cross sections uncertainties",
                " 3. detector efficiency",
                " 4. weight of samples",
                " 5. self-absorption of gamma-rays",
                " 6. the coincidence sum effect of cascade gamma-rays",
                " 7. 1.5%, the absolute efficiency curve at 2cm",
                " 8. 1.0%, the activity of the standard source for",
                "          calibration"
              ]
            }
