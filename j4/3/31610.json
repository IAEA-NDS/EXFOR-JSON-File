          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The As2S2 powder of 99.9% purity is made into",
                "circular thin samples with a diameter of 20 mm and",
                "thickness of 3-5 mm and were sandwiched between",
                "disks of thin Al of the same diameter, all the Al",
                "metals with purities better than 99.99%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " well-calibrated GEM-60P coaxial high-purity",
                "germanium (HPGe) ORTEC detector (crystal diam. 70.1 mm,",
                "crystal length 72.3 mm) with a relative efficiency",
                "of 68% and an energy resolution of 1.69 keV FWHM at",
                "1.33 MeV."
              ]
            }
