          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correlations of neutron multiplicity and gamma-ray",
                "multiplicity with fragment mass and total kinetic",
                "energy in spontaneous fission of 252Cf"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Taofeng Wang",
                "Guangwu Li",
                "Liping Zhu",
                "Qinghua Meng",
                "Liming Wang",
                "Hongyin Han",
                "Wenhui Zhang",
                "Haihong Xia",
                "Long Hou",
                "Ramona Vogt",
                "Jorgen Randrup"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3CPRBHN",
                "3CPRAEP",
                "1USALRL",
                "1USADAV",
                "1USABRK"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "3CPRCPR"
              ],
              "free_text": [
                " International Research Center for Nuclei",
                "and Particles in the Cosmos, Beijing."
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,93,014606,2016",
                "code_unit": [
                  {
                    "unit": "J,PR/C,93,014606,2016",
                    "doi": "10.1103/PhysRevC.93.014606",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "93",
                        "part": null,
                        "issue": null,
                        "page": "014606"
                      },
                      "date": 2016
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "#doi:10.1103/PhysRevC.93.014606"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The fission source was mounted between two",
                "silicon surface barrier detectors (F1 and F2) face to",
                "face, which were employed to measure the fission",
                "fragment kinetic energies. The distances from the",
                "fission source to F1 and F2 were 6 and 4 cm,",
                "respectively. Both surface barrier detectors with",
                "diameter 20 mm were collimated down to 16 mm in",
                "diameter to avoid the edge effect."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STANK"
              ],
              "free_text": [
                " A cylindrical liquid scintillator (diameter",
                "10 cm x 5 cm) held with wire 46 cm behind F1 served",
                "as a neutron detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A high-purity germanium detector behind F2,",
                "with efficiency 60% relative to a NaI(Tl) gamma-ray",
                "detector, was placed 36 cm from F2. The HPGe detector",
                "was shielded by lead bricks. Separate data were taken",
                "with the HPGe detector in locations 0 and 90 degree."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The assignment of individual fragment gamma-ray",
                "multiplicities were made by employing the Doppler",
                "shift method."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The neutron multiplicity was determined by",
                "comparing the number of coincident fission neutrons",
                "to the number of fissions, obtained from the",
                "detection of F1 or F2."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections due to neutron and gamma-ray scattering",
                "and absorption were carried out during the data",
                "analysis"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The total uncertainties were calculated from",
                "statistical errors together with the systematic errors."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The contributions of extrapolation of the gamma",
                "-ray pulse height spectrum below the discrimination",
                "level is around 0.8%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
