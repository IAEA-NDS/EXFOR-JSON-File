          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*The diff. cross section of deuterons produced was",
                "determined by comparison of the experimental angular",
                "distribution with the result of a Monte Carlo simula-",
                "tion including energy and angular distribution of in-",
                "coming neutrons, multiple scattering and energy loss",
                "of deuterons, detector efficiencies and resolutions,",
                "and geometrical effects.-"
              ]
            }
