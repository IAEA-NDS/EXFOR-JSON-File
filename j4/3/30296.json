          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Capture cross section of 14 MeV neutrons."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": null
              },
              "free_text": [
                " Cockcroft-Walton accelerator, H.T. was stabilized",
                "and voltage variation was within +-0.1 %  over 150KV"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron-tritium,",
                "to minimize scattering material nearby, liquid coolant",
                "in the target was dispensed with and forced air cooling",
                "was used.  And no extra backing was used for the thin",
                "copper disc of the Ti-T target foil."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron energy of 14.8 +- 0.08 MeV and the flux was",
                "constant to a deviation of +- 5 %."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Except iodine, samples were oxide or carbonate powder.",
                "Sample holders made from pressed graphite, were in the",
                "form of a circular pot of diam. 2.5cm, in which samples",
                "were pressed to form tablets of max. thickness of 2 mm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Activation.",
                ".Reference for the cited half-life is not given.",
                " (Compiler)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "End window G-M counter of 2.4 mg/cm2 window thickness.",
                ".Heavily biased plastic scintillator detector monitored",
                "neutron flux"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "B-"
              ],
              "free_text": [
                " Decay beta-."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for thick-sample beta-counting, including",
                "self-absorption and self-scattering in the sample.",
                "===Compiler's Note===",
                "             No correction for the influence of lower",
                "  energy neutrons (from scattering inside the sample",
                "  and accelerator target) on the cross section is",
                "  mentioned. This effect could possibly account for",
                "  the discrepancy e.g. in the  I-127 cross section",
                "  (this work 2.74 mb, several other authors about 1.1",
                "  mb). See e.g. Phys.Lett.39B,1972,625, Nuovo Cim.Lett.",
                "  10,1974,1,  Nucl.Phys.A264,1976,105.   (1978/02/24)"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Statistical error only is given.  But",
                "systematic error in detail was discussed in text."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data obtained are very much larger than those predicted",
                "by the compound nucleus theory."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data from Trans. Bose Res. Inst. 40, 81, 1977"
