          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural W, Mo, and Zr metallic foils of the purity",
                "99.99%;  and 0.23 mm, 0.15 mm and 125 mu-m in",
                "thickness altogether  with Au samples which are",
                "diluted in Al (0.1%) were  wrapped with aluminum",
                "foils and irradiated without Cd  shield in two",
                "different positions at the ETRR-2. The irradiation",
                "time varied from 2 to 3 h."
              ]
            }
          ],
