              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of the thermal neutron cross-sections",
                "and resonance integrals for 186W(n,gamma)187W  and",
                "98Mo(n,gamma)99Mo reactions"
              ]
            }
