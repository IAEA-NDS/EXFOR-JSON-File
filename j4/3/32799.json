          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutron flux was monitored by accompanying",
                "alpha-particle and the neutron energies were",
                "determined by the cross-section ratio of",
                "90Zr(n,2n)89Zr to 93Nb(n,2n)92mNb reaction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A well calibrated low-background",
                "       HPGe-gamma system"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The nitrate of uranium oxide (UO2(NO3)2) powder was",
                "pressed into wafers with a diameter of 12 mm and a",
                "thickness of about 1.0 mm. The sample wafer was",
                "sealed with a polyethylene film, and then sandwiched",
                "between two monitor aluminum (99.99% purity, 0.05 mm",
                "thickness) foils and standard niobium and zirconium",
                " (99.99% purity, 0.5 mm thickness) foil."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Three samples were placed at 0, 45 and 90 deg",
                "angles relative to the deuteron beam direction and",
                "centered about the T-Ti target at a distance of 4.0 cm,",
                "were irradiated for about 110 min. After a short",
                "cooling time (about 4.5 min), the gamma spectrum of",
                "the irradiated sample was recorded every minute",
                "within the measurement time of about 90.0 min."
              ]
            }
          ],
