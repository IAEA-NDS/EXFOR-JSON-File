          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nuclear charge distribution in the spontaneous fission",
                " of 252Cf: Determination of fractional cumulative",
                " yields of 133mTe and 133gTe"
              ]
            }
          ],
