          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples used for irradiation were natural 232-Th",
                " metal foil and natural In metal foil, which were",
                " wrapped separately with 0.025 mm thick aluminum foil",
                " to prevent contamination from one to the other.",
                "The size of 232-Th metal foil was 1.0 cm**2 with",
                " thickness of 29.3 mg/cm**2, whereas indium metal foil",
                " is also of same size with thickness of 2.6 mg/cm**2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-rays of fission/reaction products",
                " from the irradiated Th and In samples were counted",
                " in an energy and efficiency calibrated 80 c.c.",
                "HPGe detector coupled to a PC-based 4K channel analyzer"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                " The 232Th(n,g) reaction cross-section",
                " at average neutron energy of 3.7 MeV and 9.85 MeV has",
                " been determined for the first time using activation",
                " and off-line gamma-ray spectrometric technique.",
                "The observed photo-peak activity (Aobs) of gamma-lines",
                " was obtained using PHAST peak fitting programme."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutron beam was obtained from the",
                " 7-Li(p,n) reaction by using the proton beam main",
                " line at 6 m above the analyzing magnet of the",
                " Pelletron facility to utilize the maximum proton",
                " current from the accelerator."
              ]
            }
          ],
