          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The alfa-spectra above 10MeV were recorded in",
                "coincidence with the fission fragments.",
                "Each fast neutron run was preceded and followed by a",
                "thermal neutron run, in order to check the detector",
                "stability."
              ]
            }
          ],
