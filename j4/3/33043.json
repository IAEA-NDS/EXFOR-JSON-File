          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                "The neutron beam was obtained from the 7-",
                "Li(p,n) reaction by using the proton beam. The",
                "lithium foil was made up of natural lithium with",
                "thickness of 3.7 mg/cm2, sandwiched between two",
                "tantalum foils of different thickness."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples consist of natural 238-U metal foil and",
                " natural indium metal foil, which were wrapped",
                " separately with 0.025 mm thick aluminum foil to",
                " prevent contamination from one to the other.",
                "The size of 238-U metal foil was 1.0 cm2 with",
                " thickness of 29.3 mg/cm2, whereas indium metal foil",
                " is also of same size with thickness of 2.6 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-rays of reaction products from the",
                "irradiated U and In samples were counted in an energy",
                "and efficiency calibrated 80 c.c. HPGe detector",
                "coupled to a PC-based 4K channel analyzer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
