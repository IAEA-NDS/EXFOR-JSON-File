          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The differential cross section for radiative capture",
                "of 14.1 MeV neutron can be obtained from real gamma",
                "spectrum 'S' and the effective number of neutrons in",
                "the sample 'I', if also the geometry of experiment",
                "'4Pi/omega' and the number of sample nuclei in a unit",
                "volume 'n' are taken into consideration.",
                "D-sig/d-E(g) = (4Pi/omega)*(1/(n*I*r))*S(micro-B/.5MeV)",
                "where 'r' stands for the effective sample radius."
              ]
            }
          ],
