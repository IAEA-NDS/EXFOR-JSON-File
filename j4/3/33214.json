          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Independent isomeric yield ratios of fission products",
                " in the epi-cadmium neutron induced fission of 235U"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
