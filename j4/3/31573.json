          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was prepared by taking a known aliquot of",
                "233U solution (approx.30 mu-g/ml) solution in a",
                "polypropylene tube. A 200 Pl of dilute  solution of",
                "233U (approx.70 ng/ml) containing a strip of Lexan,",
                "the solid  state track detector was sealed in a",
                "polypropylene tube.  Both the samples were wrapped in",
                "1 mm thick cadmium  foil."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fast neutron spectra"
              ]
            }
          ],
