          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron flux was determined individually for",
                "both of two Au-foils irradiated at the front and",
                "back of W-foil, and the obtained values are 1.423 x",
                "10**5 and 1.408 x 10**5 n/cm2/s, respectively."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A foil of tungsten (1.2 cm diam. x 200mu-m thick;",
                "purity 99.99%) of natural isotopic composition:",
                "180W(0.127 0.01%), 182W(26.507 0.16%), 183W(14.317",
                "0.04%) 184W(30.647 0.02%), and 186W(28.427 0.19%) and",
                "thin goldfoils (1.2cm diam. x 25mmu-m thick; purity",
                "99.99%) Two gold foils of approximately same size and",
                "weight were attached at the front and back of the",
                "tungsten foil, respectively to check the difference in",
                "neutron beam intensity between entrance and exit of the",
                "target.To follow the effect of epithermal neutrons and",
                "fastneutrons, the cadmium-covered gold foil and bare",
                "aluminum foil were also irradiated."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The high-purity germanium (HPGe) gamma-ray",
                "spectroscopy (Canberra, 15% relative efficiency,",
                "1.8 keV resolution at 1332.5 keV of 60Co) coupled with",
                "digital gamma spectrometry system and Maestro data",
                "acquisition software."
              ]
            }
          ],
