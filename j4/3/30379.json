                ],
                "reaction": null
              },
              "free_text": [
                " IRT-1000 research reactor at Institut fuer Kern-",
                "Forschung u.Kernenegetik, Sofia.",
                "N-flux=6.x 10**12 n/s/cm2"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The ratio of thermal and fission component in neutron",
                "flux was determined to be '5.4', using the reactions of",
                "S-32(n,p)P-32 (=69mb for fission neutron),and P-31(n,g)",
                "P-32 (=190mb for thermal neutron) and their Cd-ratios."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "NH(4)-Br, natural sample. 200 to 250 mg."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "ACTIV"
              ],
              "free_text": [
                "",
                "The sample of NH(4)-Br was irradiated with 10 to 12 mg",
                "Se-O(2) in 2 hours. With radiochemical technique,",
                "Br-isotopes (Br-80m, Br-80, Br-82m and Br-82) were",
                "separated from Se-81m activity(t(1/2)=57min).",
                "103keV gamma from Se-181m was measured by Ge(Li)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 10 cm3 Ge(Li) detector with Didac 4000 multi-",
                "channel analyzer."
              ]
            }
          ],
