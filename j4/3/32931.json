          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of fast-neutron activation cross section",
                " of the 109Ag(n,2n)108mAg reaction and its theoretical",
                " calculation of excitation function"
              ]
            }
          ],
