          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The authors first determine angular distribution of",
                "long-range alphas (i.e., non-decay alpha) normalized",
                "to 1 at 90 deg, and then extracted the anisotropy",
                "parameter alpha using the expression W(theta) = 1 + a",
                "* (cos(theta)**2), where the parameter a represents",
                "the anisotropy"
              ]
            }
