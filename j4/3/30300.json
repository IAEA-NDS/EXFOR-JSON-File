          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct detection of alpha particles by means of a",
                "telescope."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SIBAR"
              ],
              "free_text": [
                " Telescope consisting of two gas",
                "proportional counters followed by a silicon surface",
                "barrier detector the energy calibration of the e",
                "counter was performed using alpha particles from the",
                "Si-28(n,alpha)Mg-25 reaction."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
