          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "From the average ratio of track densities on both",
                "U-238 and Th-232 coated plastics, which were irradia-",
                "ted for different lengths of time, the ratio of",
                "neutron-induced fission cross sections of Th-232 to",
                "U-238 was determined."
              ]
            }
