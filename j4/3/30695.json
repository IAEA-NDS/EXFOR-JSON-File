              },
              "free_text": [
                "",
                "Neutron flux about (1-2)*E+11 neutrons/4pi/sec"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Th(NO3)4.6H2O,pure thorium sample"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                "",
                "First, fission products were separated from the",
                "irradiated samples by radiochemistry methods and",
                "weighed for the determination of the chemical yield.",
                "Then fission product gamma rays were measured with",
                "calibrated Ge(Li) detectors for determining",
                "independent fission yields."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 80 cm3 and 140 cm3, resolution 1.9 and 2.4 keV",
                "FWHM at 1332 keV respectively, together with a",
                "multi-channel analyser. The detector efficiency was",
                "calibrated using well known gamma-ray standards."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Made for the loss of photoelectrons due to random pulse",
                "pile-up, and for precursor decay in the case of Ag-112,",
                "I-132 and I-134 independent yield determination."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Errors given in the data tables are total experimental",
                "errors. The errors due to the errors of half life,",
                "gamma intensity, and reference fission yield used for",
                "fission yield calculation were not included"
              ]
            }
