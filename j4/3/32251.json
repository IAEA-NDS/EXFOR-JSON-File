          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "It was estimated:",
                "The contribution of the 196 Hg(n, X)196 Au",
                "nuclear interference to the 196g Au production was",
                "less than 1% (taking into account that the evaluated",
                "cross sections of the 196Hg(n, X)196Au reaction are",
                "9.6 mb at En = 6.0 MeV and 24.5 mb at En = 6.8 MeV).",
                "The contribution of the 197 Au(n, 2n)196g Au reaction",
                "to the measured net areas of the gamma peaks observed",
                "at 332.983 and 355.983 keV energies is about 6.e-4%.",
                "The contribution of the 196 Hg(n, p)196g Au nuclear",
                "reaction to 196g Au production in the samples of gold",
                "via this nuclear reaction channel is about 1.4e-11%."
              ]
            }
          ],
