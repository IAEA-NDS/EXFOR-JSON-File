          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutrons were produced with an effective",
                "deuteron beam energy of 134 keV, and a beam current",
                "of 240 uA."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation of the samples was carried",
                "out with a total duration of approximately 2 h with a",
                "neutron yield 4 to 5 E10 n/s in the 4 Pi solid angle.",
                "Each sample was measured twice. More specifically,",
                "the first set of measurements was performed between",
                "12 and 49 min after the end of the irradiation, and",
                "the second set 20 h after the end of the irradiation.",
                "The measuring time is 119 s."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "35-BR-81",
                "field_identifier": "NAT",
                "value": 0.4931
              },
              "free_text": [
                " Approximately 0.6-0.9 g of NaBr",
                "powder (99.99% pure) was put within a sample box",
                " (polymethyl methacrylate). Subsequently, four samples",
                "with a diameter of 20 mm and eight monitors",
                " (niobium foil of 99.99% purity) with the same",
                "diameter were prepared for the irradiation experiments.",
                "*******************************************************",
                "Sample Mass  Thickness 81Br isotope weight       Number",
                "No.     (g)      (cm)     in the sample(g)   atoms(E21)",
                "*******************************************************",
                "1    0.6721     0.0668              0.2574       1.9134",
                "2    0.8516     0.0846              0.3261       2.4244",
                "3    0.9445     0.0939              0.3617       2.6889",
                "4    0.9267     0.0921              0.3549       2.6382",
                "*******************************************************"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A low background high-purity germanium (HPGe)",
                "detector (ORTEC, model GEM 60P, crystal diameter of",
                "70.1 mm, crystal length of 72.3 mm) with a relative",
                "efficiency of about 68% and an energy resolution of",
                "1.69 keV at 1.332 MeV for 60Co. To secure the energy",
                "and efficiency of the detector, a calibration process",
                "was carried out by using the standard gamma-ray",
                "sources 133Ba, 137Cs, 152Eu, and 226Ra. The curve of",
                "absolute efficiency calibration was acquired at 8 cm",
                "from the surface of the germanium crystal."
              ]
            }
          ],
