          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of the 128Te(n,2n)127m,gTe reaction",
                " cross sections and isomeric cross section ratio of",
                " 127m,gTe at the neutron energy of 14 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Junhua Luo",
                "Long He",
                "Liang Zhou",
