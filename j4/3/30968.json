          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SIBAR",
                "HPGE",
                "NAICR"
              ],
              "free_text": [
                " A silicon-surface-barrier",
                "detector, detected the fission fragments, the HPGe",
                "the K X-rays, and the NaI(Tl) detectors the gammas",
                "low-energy threshold of both NaI(Tl) was 80 keV",
                "the fission detector and the HPGe detector were kept",
                "at right angles to each other. Two NaI(Tl) detectors",
                "were kept in a plane perpendicular to the direction",
                "of the HPGe and placed symmetrically with respect to",
                "direction of fragment motion"
              ]
            }
          ],
