          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three anhydrous uranium nitrate (UO2(NO3)2) powder",
                "samples (98% purity, impurities: 1.34% Fe(NO3)3,",
                "0.28% Ga(NO3)2, 0.17% KNO3, 0.14% NaNO3, 0.04%",
                "Al(NO3)2, 0.02% Mg(NO3)2, 0.01% others) were made",
                "into round disks of diameter 14 mm and thicknesses",
                "4.3 mm, 4.5 mm and 5.4 mm, respectively. The three",
                "samples were placed about 3.5 cm away from the T-Ti",
                "target relative to the deuteron beam incident",
                "direction for 0 deg, 45 deg, and 90 deg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The HPGe detectors (Produced by ORTEC, GEM",
                "30P4) with an energy resolution of 1.7 keV FWHM at",
                "1.33 MeV, which was calibrated by standard point",
                "sources: 152Eu, 137Cs, and 60Co."
              ]
            }
          ],
