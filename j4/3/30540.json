          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Quasi-monoenergetic neutrons, energy of which is around",
                "2 keV. The neutrons were passed through a filter of",
                "185 g/cm2 (600mm, diam.of 20mm, pressed into lead",
                "rings) pure metallic scandium.",
                " (2.4+-0.4)*10**6/cm2/sec with an energy of 2keV and",
                "FWHM of 900 eV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched Sm-147. Sm(2)-O(3),5./10**4 g/cm2 thick.",
                "Sample was in a vacuum chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD",
                "FNB"
              ],
              "free_text": [
                "",
                "The alpha spectrum was accumulated during 870 hours",
                "and background was measured for 206 hours with neutron",
                "beam additionally filtered by 18.1 g/cm2 manganese and",
                "2.7 g/cm2 cerium."
              ]
            }
          ],
          "DETECTOR": [
