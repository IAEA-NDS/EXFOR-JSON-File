          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of 233U and 239Pu were prepared on 10 mil",
                "superpure aluminium foils (precoated with gold layer",
                "of ~50 mu-g/cm2) by electrodeposition from isopropyl",
                "alcohol. They were deposited as a circle of 1 cm",
                "diameter and then covered with a stack of 0.3 mil",
                "superpure aluminium foils of 1.5 cm diameter. The",
                "assembly was wrapped in 1 mil superpure aluminium",
                "foil and sealed with polyethylene."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 2 cc active volume detector coupled with a",
                "400 channel pulse height analyser for gamma counting."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Sugarman type end-window gas flow",
                "proportional counter for beta counting."
              ]
            }
          ],
