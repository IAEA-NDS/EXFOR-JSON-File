              "coded_information": [
                "RANGE"
              ],
              "free_text": [
                " Recoil ranges of fission products from",
                "thermal neutron fission of 233U and 239Pu are given",
                "in tables 1 and 2 of J. Inorg. Nucl. Chem., 34(1972)",
                "2685."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Recoil ranges of secondary fragments are converted",
                "into kinetic energies for corresponding primary",
                "fragments by using four different range-energy",
                "equations."
              ]
            }
