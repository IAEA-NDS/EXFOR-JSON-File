          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of nuclear constants of reactions",
                "induced on zinc by short irradiations with the",
                "epithermal and fast components of a reactor",
                "neutron spectrum"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "I.M.Cohen",
