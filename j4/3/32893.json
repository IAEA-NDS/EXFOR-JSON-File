          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The deuterons (250 keV) were accelerated and",
                "bombarded on the Ti-T target to produce the neutron",
                "beam of energy around 14 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples were made into foils with the diameter",
                "about 18 mm and the thickness about 0.2 or 0.3 mm.",
                "The weight of each foil was determined with an",
                "analytic balance (+-0.01 mg)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The stability of neutron flux at the natural",
                "titanium sample was monitored with an Au-Si surface",
                "barrier detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A low background high purity germanium",
                "detector with a 25% relative efficiency and 1.9 keV",
                "energy resolution (FWHM) at 1.33 MeV of 60Co. The",
                "detection efficiency was calibrated by standard",
                "sources 133Ba, 109Cd, 137Cs and 152Eu. The energy",
                "calibration was determined by standard gamma sources",
                "22Na, 109Cd and 137Cs."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The sample was irradiated for about 20,",
                "cooled for about 110 h and measured for 1.5 h."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " The stacked foil was arranged in a sequence of",
                "Nb-Zr-Ti-Nb."
              ]
            }
          ],
