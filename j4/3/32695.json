          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " K-400 intense neutron generator at",
                "Chinese Academy of Engineering Physics (CAEP)"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural nickel foils of 99.9% purity and",
                "0.5-0.7 mm thickness were made into circular samples",
                "with a diameter of 2.0 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A well-calibrated GEM-60P coaxial HPGe",
                "detector with a relative efficiency of around 68% and",
                "an energy resolution of around 1.69 keV FWHM at 1.33",
                "MeV gamma ray from Co-60. And the crystal geometry is",
                "70.1 x 72.3 mm in diameter and length."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiations were carried out at the K-400",
                "Intense Neutron Generator and lasted from 0.5 to 1 hour",
                "with a yield of about around 3E10 - 4E10 n/s."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
