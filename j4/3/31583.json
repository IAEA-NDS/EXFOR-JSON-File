              "free_text": [
                "",
                "Two of each of the four neutron flux monitor foils (Au,",
                "Co, Fe and Ni) were placed in a cylindrical arrangement"
              ]
            }
          ],
          "MONIT-REF": [
            {
              "pointer": "",
              "coded_information": {
