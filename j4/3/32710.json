          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " TD-300 Neutron Generator for sample",
                "irradiations."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectroscopically pure neodymium oxide and gadolinium",
                "oxide were made into circular samples with a diameter",
                "of 2.0 cm and thickness of 0.5 cm, which were",
                "sandwiched by two Al foil with the same diameter.",
                "Al metal purity was better than 99.99%. They were",
                "placed at 0, 90 and 135 degree angles relative to the",
                "deuteron beam direction and centered about the T-Ti",
                "target at distances of 1.2-3.0 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A well-calibrated GEM-60P coaxial high-purity",
                "germanium (HPGe) detector was used with 70.1x72.3 mm",
                "in diameter and length for the crystal. The relative",
                "efficiency was about 68%, and the energy resolution",
                "was about 1.69 keV (FWHM) at 1.33 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation of the samples was carried out and",
                "lasted 40 min with a neutron yield of about 3E10 to",
                " 5E10 n/s. The neutron flux was monitored by the",
                "accompanying alpha particles."
              ]
            }
          ],
          "MONITOR": [
