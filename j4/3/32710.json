          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-sections for (n,2n) and (n,p) reactions on",
                "neodymium isotopes and 160Gd(n,a)157Sm at neutron",
                "energy between 13.5 and 14.7 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Yanbin Zhang",
                "Liangyong Zhao",
