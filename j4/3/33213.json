                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " APSARA reactor"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For short-lived fission products, nitrate solutions",
                "of 239Pu (~2 ug) were sealed in polypropylene tubes and",
                "individually wrapped with 1-mm-thick cadmium foils.",
                "For long-lived fission products, an electrodeposited",
                "target of 239Pu (~100 ug) was covered with",
                "0.075-mm-thick Lexan foils.",
                "All samples were wrapped with 1-mm-thick cadmium foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 120 cm3 detector (1.8 keV energy resolution",
                "for 1332.5 keV gamma-line of 60Co.)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Off-line gamma-ray spectrometry.",
                "For short-lived fission products targets were",
                "irradiated for 10-21 min at a flux of",
                "1.2 X 10**12 n/cm2/sec.",
                "For long-lived fission products targets were",
                "irradiated for 60-90 min."
              ]
            }
          ],
