              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3DDRTUD",
                "3DDRROS",
                "2GERPTB"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NSE,106,353,1990",
                "code_unit": [
                  {
                    "unit": "J,NSE,106,353,1990",
                    "doi": "10.13182/NSE90-A29063",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NSE",
                        "number": null,
                        "volume": "106",
                        "part": null,
                        "issue": null,
                        "page": "353"
                      },
                      "date": 1990
                    }
