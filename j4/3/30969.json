          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Cf-252(sf) neutron spectrum in the 5- to 20-MeV",
                "energy range"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.Maerten",
                "D.Richter",
                "D.Seeliger",
