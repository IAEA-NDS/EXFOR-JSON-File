              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Rh in 3.9mg/cm2 thickness on Au-foil",
                "natural indium in 4.9mg/cm2 thickness on Al-foil"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
