              ]
            }
          ],
          "EN-SEC": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy resolution of approximately 800.keV for medium",
                "energy alpha particles was mainly determined by alpha",
                "energy loss in the target (see E-RSL = 800.keV)."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In the (n,alpha) reactions on",
                "Rh-103      In-115      In-113       alphas from the",
                "Q= 3.4 MeV  Q= 2.7 MeV  Q= 3.8 MeV   Q-values are",
                "                                     observed,whereas",
                "Q=-3.4 MeV  Q=-3.8 MeV  Q=-3.0 MeV   for these Q-values",
                "                                     no alphas were",
                "                                     observed."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gold foils of same size were used to measure background"
              ]
            }
          ],
