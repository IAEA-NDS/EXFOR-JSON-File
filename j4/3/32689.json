                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "A 238U film sample was applied to determine the",
                "absolute neutron flux. It was placed at the forward",
                "direction of the 3rd position of the sample changer",
                "for fission fragments measurement."
              ]
            }
          ],
