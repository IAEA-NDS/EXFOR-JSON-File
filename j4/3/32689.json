              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " The deuterium gas cell was 2.0 cm in length and",
                " 0.9 cm in diameter with molybdenum film 5.0 micron",
                " in thickness.",
                "The deuterium gas pressure was 2.9-3.1 atm during",
                " experiments.",
                "The energy of accelerated deuteron beam before",
                " entering the molybdenum film were 3.281, 2.455 and",
                " 1.790 MeV, respectively.",
                "From Monte Carlo simulation, the corresponding energy",
                " of produced neutrons on the sample were 6.0, 5.0 and",
                " 4.0 MeV, with the energy spreads of 0.12, 0.16 and",
                " 0.23 MeV."
              ]
            }
