          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The weights of 93Nb, natMo and 197Au foils are 102.6,",
                "399.3, 126.4 mg, respectively. The size of each foil",
                "was about 1.2 cm x 1.2 cm.",
                "The thickness of both 93Nb and natMo foils are 0.5 mm",
                "each, whereas for Au, it was 0.025 mm.",
                "The 93Nb, natMo and 197Au foils were wrapped",
                "individually with 0.011 mm thick Al foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A pre-calibrated 185-cc Baltic HPGe detector",
                "coupled to a PC-based 4K channel analyzer.",
                "The resolution of the HPGe detector had a FWHM of",
                "1.8 keV at the photo peak of 1332.5 keV gamma-ray of",
                "60Co."
              ]
            }
          ],
