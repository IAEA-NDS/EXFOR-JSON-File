          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "47Co has a half-life of 270 days, decaying by electron",
                "capture to the 136 kV excited state of the stable",
                "isotope 57Fe, while the 57Fe decays to the ground",
                "state by emitting a 136 kV gamma-ray. The ratio of the",
                "intensities of this gamma-ray for fhe two separations",
                "is proportional to the ratio of the cross section:",
                "58Ni(n,np)57Co/58Ni(n,2n)57Ni. The measured ratio was",
                "found to be 4.2, with a cousistency of +-10%.",
                "Cross section for the  58Ni(n,x)57Co was derived",
                "from this ratio."
              ]
            }
          ],
