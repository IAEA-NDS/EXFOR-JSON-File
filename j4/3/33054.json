          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self supporting 238U target of thickness of 2.3",
                "mg/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier",
                "detector telescopes, referred to as dE(150 mu-m and",
                "100 mu-m) detectors and identical E(thickness 1.0 mm)",
                "detectors, were mounted in a reaction plane at angles",
                "of 85 and 105 degrees, respectively, to identify",
                "projectile-like fragments."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " A large-area (450 mm2) solid state detector",
                "was kept at an angle of 160 deg. with respect to the",
                "beam direction and subtended a solid angle of 63 msr",
                "with an angular opening of 16 deg. to detect fission",
                "fragments in coincidence with PLFs."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence between PLFs and fission fragments"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SURGT"
              ],
              "free_text": [
                " Cross sections for 239Np(n,f) and 240Np(n,f)",
                "determined by Hybrid surrogate ratio method.",
                "Reactions 238U(6Li,af)240Np and 238U(6Li,df)242Np for",
                "239Np(n,f) cross-section determination, and reactions",
                "238U(7Li,af)241Np and 238U(7Li,tf)242Pu for",
                "240Np(n,f) cross-section determination using cross",
                "sections of 241Pu(n,f) as standard reference in both",
                "the cases."
              ]
            }
          ],
