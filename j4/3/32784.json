          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the cross sections for 238U(n,g)239U",
                "reaction in the energy range of 14.1-14.8 MeV using",
                "neutron activation method"
              ]
            }
          ],
