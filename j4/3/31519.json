          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron flux spectra and mean energies were determined",
                "by the multiple foil activation technique combined with",
                "the unfolding code SULSA and a pulse height response",
                "spectrometer. The mean energy of neutrons has been",
                "controlled by using NEUT code. The variation of neutron",
                "flux in time was monitored by a BF3 long-counter"
              ]
            }
          ],
