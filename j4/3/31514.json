          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The average neutron flux at the place of irradiation",
                " was approx. 10**7 n/cm2/s"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neodymium oxide (Nd2O3) powder of enriched isotopes.",
                "The samples were made by uniform spreading the",
                " powdered sample within perspex ring of diameter",
                " 1.6 cm and were sandwiched between two thin cellulose",
                " tapes.",
                "The samples were irradiated simultaneously by wrapping",
                " them in cadmium foil."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation of contribution the sample was",
                " performed in zero degree forward direction at a",
                " distance of 2.0 and 2.5 cm, respectively, from",
                " lithium and tritium targets.",
                "The product nuclei were identified by their",
                " characteristic gamma transitions following their",
                " decay.",
                "ORTEC detector with associated electronics was coupled",
                " with 4096 channel ND-100 analyser."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
