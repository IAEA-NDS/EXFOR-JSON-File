          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin layer of U-O2 (0.5 mg/cm2) deposited on a Al",
                "backing (5.5 mg/cm2)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SOLST"
              ],
              "free_text": [
                "",
                "   Charged particle telescope consisting of a",
                " - totally depleted gold surface barrier silicon diode",
                "   (100 mm2, 17 mu thick) for the 'dE/dx' detector,",
                " - gold surface barrier silicon diode (50 mm2, 320 mu",
                "   thick for the depletion layer) for the 'E' detector.",
                "Before each experimental run the energy calibration",
                "was checked with an americium alpha particles source.",
                "Resolution for 5.48 MeV alpha particles = 80 keV"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
