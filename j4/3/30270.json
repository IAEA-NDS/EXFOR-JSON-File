              ],
              "free_text": [
                " Alpha particles"
              ]
            }
          ],
          "EN-SEC": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy of alpha particles, corrected for absorption",
                "in the Al foil which protects the detector against",
                "bombardment by fission fragments and alpha particles",
                "of natural U-235 activity, is given in the data tables",
                "under 'E'"
              ]
            }
