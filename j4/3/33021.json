          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " Research Reactor APSARA in B.A.R.C,",
                "Trombay, Mumbai"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Electrodeposited target of 241-Pu (~50 micro gram)",
                "covered with 0.00254 cm thick superpure aluminium",
                "foil was irradiated in the Apsara reactor at a flux",
                "of 2.0x10**12 n/cm2/sec."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC",
                "CHSEP",
                "GSPEC"
              ],
              "free_text": [
                " Fission products were collected",
                "using recoil catcher technique. Tellurium and iodine",
                "were separated using standard radiochemical procedure",
                "after dissolution of the catcher foil within  20-30",
                "min from the end of the irradiations. After the",
                "separation the samples were counted on a 45c.c. HPGe",
                "detector in conjunction with a 4k analyzer in live",
                "time mode."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The resolution of the detector system was 2.6",
                "keV at 1332.0 keV.  The dead time was maintained below",
                "10%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "AREA"
              ],
              "free_text": [
                " Linear Compton subtraction was done while",
                "computing the peak areas under the photo peaks of",
                "interest. The gamma-ray spectra of the separated",
                "samples were checked for the absence of the precursor",
                "activities. The observed activity profiles as a",
                "function of time were analyzed using standard decay",
                "growth equations to arrive at the separation time",
                "activities of the meta-stable and ground states."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The quoted limits of errors on the",
                "independent yield ratios  were obtained taking into",
                "account the observed precision with errors in",
                "calculated peak area statistics, precursor yield",
                "values and the least square fitting of the activity",
                "profiles. The limits of the error on the RMS angular",
                "momentum value arise from the errors on the",
                "independent isomeric yield ratios."
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The details of the isobaric decay chains involved in",
                "the work, the yield of the fission product monitor",
                "along with the relevant nuclear spectroscopic data",
                "taken from:",
                "B.F.Rider, Vallecitos Nuclear Centre, Report NEDO-",
                "12151-1/1981/unpublished and",
