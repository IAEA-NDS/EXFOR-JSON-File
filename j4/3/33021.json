          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Effect of shell closure proximity on fragment angular",
                "momenta in 241-Pu(n,F)"
              ]
            }
          ],
          "AUTHOR": [
