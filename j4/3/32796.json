          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cesium iodide (CsI) powder of natural isotopic",
                "composition (purity 99.99%) was pressed into a",
                "pellet, approximately 20.0 mm in diameter, and 1.5 mm",
                "in thickness."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A lead-shielded HPGe detector (ORTEC, USA).",
                "The efficiency of the detector was calibrated using",
                "152Eu standard sources. The relative efficiency of",
                "the detector was 68% compared to the NaI detector,",
                "and the energy resolution was 1.82 keV (FWHM) at 1.33",
                "MeV of 60Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation was lasted approximately 17 h.",
                "Three groups of samples were placed at 35, 75, and",
                "112 deg relative to the deuteron beam direction and",
                "centered around the T-Ti target at a distance of",
                "approximately 4.5 cm."
              ]
            }
          ],
