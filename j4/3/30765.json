          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Approx. 100 microgram, prepared by electrodeposition",
                "from isopropyl alcohol medium on Al-foil, covered with",
                "0.007 cm Al catcher foil, wrapped in 0.002 cm Cd foil.",
                "Original sample purified from Pu, Am. Alpha spectrum",
                "showed less than 0.004 % 239Pu."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " Apsara swimming pool reactor",
                " neutron flux is about 10**12 n/cm2/s"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal reactor spectrum - sample shielded by 0.002 cm",
                "  cadmium, estimated Cd ratio is 200 (assumed by the",
                "  compiler. In the publication the number is called",
                "  cadmium cutoff). Cd-wrapping used to reduce 238Np",
                "  fissions (calculated to be less than 0.05 % of",
                "  237Np fissions).",
                "Irradiation times were up to a maximum of 30 minutes."
              ]
            }
          ],
