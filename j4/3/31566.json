          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission neutron spectrum averaged cross sections of",
                "some threshold reactions on cadmium: production",
                "feasibility of no-carrier-added 103Pd in a nuclear",
                "reactor"
              ]
            }
          ],
          "AUTHOR": [
