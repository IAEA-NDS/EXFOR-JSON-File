          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Maxwellian neutron spectrum, with the cadmium ratio for",
                "gold being measured to be larger than 10**4."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thorium and uranium metal foils of the diameter,12.5 mm",
                "and the thicknesses between 0.12 and 0.25 mm.",
                ".Np-237,Am-243 used were of about 0.05 micro-Curie with",
                "deposited diameters of 12.5mm, 0.5mm thick stainless",
                "steel."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct measurement of the neutron capture rate for",
                "232Th relative to that for 238U, with simultaneous use",
                "of Np-237 and 243Am as the long-lived and",
                "alpha-emitting parents of Pa-233 and of Np-239,",
                "respectively. See the decay chains,",
                "                            Np-237(alpha-emitter)",
                "                                  ' (downward)",
                " Th232 + n --- Th-233 --(B-)-- 'Pa-233' --(B-)-- U-233",
                " U-238 + n ---  U-239 --(B-)-- 'Np-239' --(B-)-- Pu-239",
                "                                  ' (upward)",
                "                                Am-243(alpha-emitter)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 60 cc, coaxial Ge(Li) detector.",
                ".Low geometry alpha counter."
              ]
            }
          ],
