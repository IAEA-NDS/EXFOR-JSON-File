              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sample thickness of 200-300 ug/cm2, diameter of 50 mm",
                " and nonuniformity of less than 15%. The isotopic",
                " purity of U-235 and U -238 sample were 99.985% and",
                " 99.998%, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Multi-cell fast fission ionization chamber.",
                " Two U-235 cells, three U-238 cells and one empty cell",
                " were mounted in the detector. The detection",
                " efficiency of the 5 uranium cells was determined as",
                " 94%-96%, with relative uncertainties of 0.30%-0.40%."
              ]
            }
          ],
