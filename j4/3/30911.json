          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Separation time activities for Cs-138-m and",
                "Cs-138-g were evaluated from least square fitting of",
                "the time dependent activity profile, using standard",
                "decay-growth equations, and were correlated to the",
                "corresponding independent isomeric yields and the",
                "fractional cumulative yield of Xe-138, of which the",
                "values for U-233, Pu-239 and Pu-241 were taken from",
                "literature."
              ]
            }
          ],
