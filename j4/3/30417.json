          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Determination of cross-sections of threshold reactions",
                "with fission neutrons,study of Cl-35(n,a)P-32 reaction-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "2GERZFK"
              },
