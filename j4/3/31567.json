          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,68,067602,2003",
                "code_unit": [
                  {
                    "unit": "J,PR/C,68,067602,2003",
                    "doi": "10.1103/PhysRevC.68.067602",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
