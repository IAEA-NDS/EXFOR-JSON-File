          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "0.312 g natural tellurium-oxide powder to determine the",
                "relative intensities of gamma rays in the natural Te",
                "In separate experiments with 0.194g natural",
                "telluriumoxide dissolved in 2.151g 20 mol %",
                "hydrochloride acid the elemental partial gamma-ray",
                "cross section for the 603 keV transition from the",
                "123Te(n,gamma) reaction was redetermined."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Combining Rez and Budapest results, the thermal",
                "neutron capture cross sections for the tellurium",
                "isotopes were calculated from the absolute",
                "gamma-intensities (i.e., emission probabilities per",
                "capture) and the new elemental partial gamma-ray",
                "cross sections."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3HUNKFI"
              },
              "free_text": [
                " the new cold neutron PGAA facility"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron flux is 5x10**7/cm2/s"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total uncertainty. In order to reduce the",
                "statistical uncertainties the total capture cross",
                "sections were obtained as averaged values from at",
                "least three different lines for each isotope."
              ]
            }
          ],
