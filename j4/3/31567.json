          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutron capture cross sections of tellurium",
                "isotopes"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "I.Tomandl",
