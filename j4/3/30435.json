          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the angular distribution of fragments",
                "by means of solid-state track detector.",
                "After etching in 6n NaOH solution, the fission tracks",
                "were observed by an optical micro-scope."
              ]
