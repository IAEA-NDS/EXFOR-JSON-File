          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The angular distribution of fragments is approximately",
                "given by",
                "    W(theta) = 1 + B*cos(theta)**2",
                "where (theta) is the angle between the fission fragment",
                "and the incident neutron. B is found to be 34."
              ]
