          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity ruthenium sponge, titanium sponge, europium",
                "oxide or dysprosium oxide, weighing 25-50 mg each, was",
                "filled in a quartz ampoule, sealed and then placed in",
                "an NRX type alummum irradiation capsule. Two of each",
                "of the three neutron flux monitor foils (Au, Fe and Ni)",
                "were placed in a cylindrical arrangement around the",
                "ampoule in such a way that the same neutron flux",
                "monitor material was on opposite sides of the ampoule."
              ]
            }
          ],
