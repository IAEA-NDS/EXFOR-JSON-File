          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mass distribution in the reactor neutron fission of",
                "231Pa and 237Np"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " Swimming pool reactor \"Apsara\""
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor pile spectrum, but the samples were covered",
                "with cadmium foils thick enough to cut off the thermal",
                "neutron flux almost completely.",
                "Irradiation times varied from 6 to 24 hrs."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "RCHEM"
              ],
              "free_text": [
                ".using standard procedures"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "RVAL"
              ],
              "free_text": [
                ".relative to U-235 thermal fission with Ba-140 as",
                "internal standard. Absolute yields were obtained by",
                "normalization of the mass yield distribution to 200%,",
                "which was generated by drawing a smooth curve through",
                "the measured points and extrapolating it at the light",
                "and heavy mass wing of the distribution.",
                "The measured R-values are not given."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Sugarman type methane flow proportional counter"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The values given are averages of all determinations."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The errors given are the mean quare deviations of the",
                "respective number of determinations.",
                "Compiler's comments:",
                "- Apparantly only statistical errors are given as one",
                "  standard deviation.",
                "- A general statement is made that probably refers to",
                "  the estimated maximum overall error: \"The maximum",
                "  expected error in the values in the region of high",
                "  yields is about 10% and in the region of low yields",
                "  about 20%.\""
              ]
            }
          ],
