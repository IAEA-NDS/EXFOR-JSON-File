          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The estimation of the upper limit of (n,alpha) sigma",
                "was done by superimposing the expected alpha peaks at",
                "appropriate places in the measured alpha spectrum.",
                "Their widths were chosen taking into account the self-",
                "absorption in the target layer and the straggling in",
                "the aluminium foil. Sigma was deduced from the ratio of",
                "areas under the indicated profiles and the measured",
                "spectrum."
              ]
            }
          ],
          "FLAG": [
            {
              "pointer": "",
              "coded_information": [
                1.0
              ],
              "free_text": [
                " for transition to the ground state the alpha",
                "energy is 10.7 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                2.0
              ],
              "free_text": [
                " for transition to the excited states up to 5 MeV",
                "the alpha energy is less than 10.7 MeV"
              ]
            }
          ],
