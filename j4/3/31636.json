              "free_text": [
                "  - number of the atoms in 64Zn (1.2%)",
                "         - neutron flux determination",
                "           3.6% (5.0 MeV) and 4.2% (6.0 MeV)",
                "           (including the uncertainty of the fission",
                "           counts 2.2%, the error of the reference",
                "           cross section at 5.0 MeV 2.6%, the 238U",
                "           atom number error l.3%, and the BF3",
                "           relative efficiency shape error in 5-6 MeV",
                "           range 2.0%)."
              ]
            }
