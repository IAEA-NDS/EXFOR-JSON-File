          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Standardization of the gamma-ray cross sections was",
                "performed by irradiating a stoichiometric natEuCl3",
                "target at the cold-neutron-beam facility of the",
                "Garching Research Reactor. The cross sections for the",
                "89.9- and 221.2-keV secondary gamma-rays in 152Eu and",
                "the 68.2-keV gamma-ray in 154Eu were measured",
                "relative to the 6.51 +/- 0.30 cross for the 1951-keV",
                "from the 35Cl(n,g)36Cl reaction . All other gamma-ray",
                "cross sections were obtained relative to these",
                "standardized cross sections."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STATD"
              ],
              "free_text": [
                " The thermal cross section was determined as",
                "a sum of observed gamma-ray cross sections populating",
                "the ground state and estimated unobserved intensities",
                "based on statistical calculations using DICEBOX Monte",
                "Carlo code."
              ]
            }
          ],
