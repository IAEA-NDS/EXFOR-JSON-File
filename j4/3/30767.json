          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor pile spectrum, sample wrapped in cadmium foil",
                "to reduce thermal neutron component;",
                "neutron flux = 10**11 neutrons/cm2/s"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "500 mg containg natural uranium as UO2(NO3)2"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "5 samples, each irradiated for 10 min"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "RCHEM"
              ],
              "free_text": [
                " performed at fixed separation times of  8, 30,",
                " 75, 261 and 1177 min after the end of irradiation.",
                " Purified iodine precipitated as AgI, filtered,",
                " enclosed in polyethylene and covered with Al-foil for",
                " counting."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " of separated samples at varying cooling times",
                " after the fixed separation times."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " of 26 cm3 coupled to 4000-channel analyzer"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Equations for growth and decay were set up describing",
                "the genetic relationships beween fission products in",
                "the investigated mass chains A=131-135.",
                "Genetic relationships: for A=131 see SE3: DECAY DATA;",
                "for A=132-135 they were taken from R.W. Parsons and",
                "H.D. Sharma, J.Inorg.Nucl.Chem. 36(1974)2392.",
                "Independent yields were derived by least squares",
                "analysis of curves obtained from different samples at",
                "different separation times."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For decay and buildup as described above.No corrections",
                "necessary for chemical yield as all activities were in",
                "the same samples for a given run."
              ]
            }
          ],
