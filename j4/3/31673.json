          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting 99.99% pure metallic 238U foil of",
                "thickness 4709 + - 235 Angstroms (761 +- 38 mu-g/cm2)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " one 140 mu-m and one 1000 mu-m Micron",
                "S2 type silicon detectors as a dE+E particle telescope",
                "covering an angular range of 36. to 66. degr. with",
                "respect to the beam axis. Another 140 mu-m silicon",
                "detector was used to detect fission fragments during",
                "the experiment over the backward angular range of 106.",
                "to 131.degr.",
                "All silicon detectors were energy calibrated using",
                " 241Am and 226Ra alpha-lines."
              ]
            }
          ],
