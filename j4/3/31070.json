          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The (n,2n) reaction cross section of 31P, 64Zn, 69Ga,",
                "and 107Ag for 14.8 MeV neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Except in the case of phosphorus samples in the form",
                "of either powder or foil. Contained in graphite holders",
                "where the holders were pots of diameter 2.5 cm and",
                "had a rim-height of 2 mm. These were of nearly uniform",
                "weight of about 1g each."
              ]
            }
          ],
