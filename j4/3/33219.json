              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RPC,217,111505,2024",
                "code_unit": [
                  {
                    "unit": "J,RPC,217,111505,2024",
                    "doi": "10.1016/j.radphyschem.2023.111505",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "RPC",
                        "number": null,
