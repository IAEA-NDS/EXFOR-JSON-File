          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3INDTRM"
              },
              "free_text": [
                " APSARA reactor"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For short-lived fission products, 100 uL of nitrate",
                " solutions of 238Pu (50 ug/ml) were sealed in three",
                " different polypropylene tubes of about 2 cm long and",
                " 3-mm inner diameter.",
                "For long-lived fission products, an electrodeposited",
                " target of 238Pu (~20 ug) was covered with",
                " 0.075-mm-thick Lexan catcher foils, sealed with",
                " alkathene bags.",
                " The individual targets were wrapped with 1-mm-thick",
                " cadmium foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " 120 cm3 detector (1.8 keV energy resolution",
                " for 1332.5 keV gamma-line of 60Co.)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Off-line gamma-ray spectrometry: for short-lived",
                " fission products targets were irradiated for 10-11 min",
                " at a flux of 1.2 X 10**12 n/cm2/sec, while for",
                " long-lived fission products targets were irradiated",
                "  for 55-60 min."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
              "coded_information": [
                "MISC"
              ],
              "free_text": [
                " fission fragment angular momenta Jrms"
              ]
            }
          ],
