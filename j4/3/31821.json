          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " 19-36 MeV proton (energy uncertainty and",
                " spread are typically 0.3 and around 0.2 MeV",
                " respectively) on natural Li foil followed by a 10 mm",
                " thick carbon slab.",
                "The Li foils used in the 2011 and 2013 experiments",
                " were bought in the same shipment in 2003. The foil",
                " thickness was determined to 0.55+/-0.05 mm for the",
                " 2011 experiment by direct measurement, weighting,",
                " 7Be activity measurement and foil activation, and the",
                " same thickness and uncertainty were assumed to the",
                " foil used in the 2013 experiment."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Only neutrons in a broad peak due to (p,n0)+(p,n1)",
                " are relevant to the 12C(n,a0), (n,p0) and (n,d0)",
                " reactions."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Diamond detector acted as sample"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Diamond detector with sensitive volume of",
                " 4.09x4.09x0.5 mm3.",
                "The fraction of escaped charged particles was",
                " estimated by FLUKA assuming isotropic angular",
                " distribution in the centre-of-mass system.",
                "The Li target-detector distance was 18.7 and 30 cm for",
                " 2011 and 2013 campaign, respectively."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The number of neutrons was determined by",
                " - proton charge deposited on Li and slab",
                " - 7Li(p,n)7Be cross section",
                " - index of forwardness of peak neutrons",
                "with overall uncertainty of 13% of which",
                " - 10% from the number of 7Li nuclei,",
                " - 6% from the 7Li(p,n)7Be cross section,",
                " - 6% from the peak neutron index."
              ]
            }
          ],
