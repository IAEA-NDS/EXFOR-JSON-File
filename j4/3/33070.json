          "CRITIQUE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The authors extracted 5 min and 25 min states of",
                "178Lu from (n,a) as well as 115 days state of 182Ta",
                "from decay curve analysis and derive the following",
                "ratios: 181Ta(n,a)178Lu(5 min)/181Ta(n,g)182 Ta(115",
                "d)=(194+/-17)E-08 and 181Ta(n,a)178Lu(25",
                "min)/181Ta(n,g)182Ta(115 d)=(528+/-39)E-08. Because",
                "the 5 min state is not known now, the compiler assumes",
                "that the observed 25 min state of 178Lu is",
                "corresponding to both ~28 min and ~23 min states of",
                "178Lu."
              ]
            }
          ],
