          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutron flux of ~5.0E12 n/cm2-sec"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of 229-Th (~30 micro gram) were prepared on",
                "platinum backing by electro deposition using",
                "isopropyl alcohol"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
                " The fission fragments were collected by the",
                "thin target-recoil-catcher technique."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The decay of the fission products were",
                "followed as a function of time using",
                "gamma ray spectrometry"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                "Thermal neutron from Cirus reactor were used"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "RELFY"
              ],
              "free_text": [
                " The growth and decay of the daughter product",
                "related with the fractional cumulative yield (FCY) of",
                "the parent and fractional independent yield (FIY) of",
                "the daughter product with suitable equations as",
                "described in the paper."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 60 cm3 Ge(Li) detector Resolution 2.6 keV at",
                " 1332 keV"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The deacy of each daughter product in a given",
                "mass chain was followed for suitable length of time."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The correction for the decay and growth during the",
                "irradiation for the parent and daughter product",
                "were incorporated in the equations",
                "The errors due detector efficiency, self absorption",
                "and scattering were getting cancelled as the samples",
                "were counted in similar geometry.",
                "The corrections for the loss of 135-Xe due to its high",
                "absorption cross section were applied during",
                "irradiation"
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Taken from chart of nuclides prepared by",
                "Seelmann-Eggebert W., Pfenning, G., and Munzel, H.",
                "Institute for Radiochemie,",
                "Kernforschungszentrum, Karlsruhe, 1974."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "TABLE"
                ],
                "subentry_number": null,
                "author": null,
                "reference": null
              },
              "free_text": [
                " Data is taken from table 1 and 2 of this paper",
                " (Ref. Journal RCA,33,189,1983)"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors listed are the standard",
                "deviations between the results from five different",
                "irradiations and various gamma rays.",
                "Errors are statistical, given as 1 standard deviation."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The FCY values for 135-I published in",
                "Phy.Rev. C17, 188 (1978) for 252Cf(s,f) and in",
                "Phy.Rev. C21, 1411(1980) for 245Cm(n,f) have been",
                "corrected  in this paper.",
                "This comment is mentioned in this paper",
                "  (J,RCA,33,189,1983) on page 192.",
                "Though this data have been coded in EXFOR under entry",
                "number 30516001. The modified values are being given",
                "in this entry."
              ]
            }
          ],
