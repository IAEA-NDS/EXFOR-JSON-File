          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thorium metal foil 5 mm thick were sealed in",
                "polyethylene bag and covered with 0.2 cm cadmium",
                "capsule, which in turn was placed in a plastic carrier",
                "filled with 2 cm of boron carbide."
              ]
            }
          ],
