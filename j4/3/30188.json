          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Anomalous 96Zr resonance integral to thermal activation",
                "cross-section ratio and the neutron activation",
                "resonance integral of 94Zr and 96Zr"
              ]
            }
          ],
          "EXP-YEAR": [
            {
              "pointer": "",
              "coded_information": [
                1970
              ],
              "free_text": [
                ""
              ]
            }
