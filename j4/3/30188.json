                      "general_quantity_modifier": null,
                      "quantity_236": ",SIG"
                    }
                  }
                ],
                "unit_combination": "((%)//(%))"
              },
              "free_text": [
                "",
                "               Ratio of reduced resonance integral",
                "               to thermal capture    cross section.",
                "      Average value of three different determinations."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mixture of 24 millig/cm2 zirconium and 0.02 millig/cm2",
                "of gold for measurement relative to gold.",
                "Metallic zirconium foils 13 millig/cm2 thick and 99.99%",
                "purity for the direct measurements."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cadmium ratios determined by three different methods:",
                "1.Relative to gold-cadmium ratio by measuring the 743.3",
                "keV gamma-ray of Nb-97-ms and 658.1 keV gamma ray of",
                "Nb-97 relative to the 412 keV gamma-ray of Au-198",
                "2. Direct measurement of zirconium-cadmium ratio in a",
                "reactor spectrum by measuring the 743.3keV and 658.1keV",
                "gamma rays of Nb-97-ms and Nb-97 respectively",
                "3. Direct measurement of the zirconium cadmium ratio in",
                "a quasi-thermal spectrum"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Partial results from the three methods",
                "1.Relative to gold         S0=1308+-305",
                "                      I/sigma=1160+-270",
                "2. Reactor spectrum        S0= 945+-40",
                "                      I/sigma= 838+-34",
                "3. Quasi-thermal spectrum  S0=1009+-120",
                "                      I/sigma= 895+-107",
                "weighted average S0 value = 992+-108"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental results corrected for neutron epithermal",
                "self shielding and for deviation from 1/e spectrum."
              ]
            }
          ],
