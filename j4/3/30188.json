                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " Used in the determination of absorption",
                "resonance integrals. Value taken from Goldberg et al.,",
                "BNL-325,2nd ed.,Suppl.2. 1966.",
                "The S0 values (Westcott formalism) were determined",
                "relative to S0=17.7 for gold."
              ]
            }
          ],
