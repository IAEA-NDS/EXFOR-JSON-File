              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Internal graphite reflector of the reactor RA-1."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mixed samples prepared from a very dilute solution",
                "containing Zr and standard used for S0 determinations,",
                "metallic Zr foils for resonance integral measurements."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Ratios of reduced  capture  integral to the thermal",
                "capture    cross section were measured using the",
                "cadmium ratio technique.",
                "Absorption resonance integrals were determined by",
                "measuring the ratio of effective absorption cross",
                "section of zirconium to Mn-55. Calibrated gamma sources",
                "were used to determine the absolute activities."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge-Li gamma-ray spectrometer"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "25-MN-55(N,G)25-MN-56,,SIG",
                  "code_unit": [
