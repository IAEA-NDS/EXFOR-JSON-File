            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross-sections for the 185Re(n,2n)",
                "reaction and the isomeric cross-section ratio of",
                "184m,gRe in the neutron energy range of 13-15 MeV"
              ]
            }
          ],
