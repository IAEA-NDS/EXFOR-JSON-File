          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " A beam with an effective deuteron beam energy",
                "of 136 keV and current of 260 uA. The neutron",
                "production target was a tritium-titanium target 2.20",
                "mg/cm2 in thickness."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "75-RE-185",
                "field_identifier": "NAT",
                "value": 0.374
              },
              "free_text": [
                " Disk of natural rhenium metal",
                " (purity 99.99%, about 1.0 mm in thickness, 2.0 cm in",
                "diameter, China New Metal Materials Technology Co,",
                "Ltd.) was sandwiched between disks of niobium (purity",
                "99.99%, 0.12 mm in thickness) of the same diameter.",
                "Three such samples (Nb-Re-Nb) were prepared for",
                "irradiation. The thicknesses were 0.0984, 0.0973, and",
                "0.0939 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The neutron yield was 3 to 4E10 n/4pi/s.",
                "Groups of samples were placed at 0, 90 or 135 deg",
                "with respect to the beam line and centered about the",
                "T-Ti target at distances of about 40 mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The detector was about 68% relative",
                "efficiency, and 1.69 keV resolution at 1332.5 keV of",
                "60Co. The detector was connected to a digital gamma",
                "spectrometry system (ORTEC, model GEM 60P) and",
                "Maestro data acquisition software. The separation",
                "between sample and detector was variable within a",
                "range of 0 to 8 cm."
              ]
            }
          ],
