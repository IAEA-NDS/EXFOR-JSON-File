          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-purity Y2O3 powder (4.0g, 99.999%) was pressed at",
                "10 tonne/cm2 into pellets of 2.0 cm diam. and 0.43 cm",
                "thickness. The disks obtained were packed in thin",
                "Al-capsules to ensure mechanical stability. Aluminium",
                "and iron monitor foils (Al 1.00 mm and Fe 0.50 mm",
                "thick) of the same size as a sample were attached in",
                "front and at the back of each capsule."
              ]
            }
