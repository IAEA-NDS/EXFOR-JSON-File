          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was a 232Th metallic foil with 20 mm in",
                "diameter and  bout 1. gram in mass, and wraped by",
                "aluminium foil with 20 um thickness to restraint the",
                "escaping of fission fragments."
              ]
            }
          ],
          "INC-SOURCE": [
