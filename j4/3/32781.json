            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of cross sections and isomeric",
                "cross-section ratios for the (n,2n) reactions on",
                "196,198Hg at energies between 13 and 15 MeV"
              ]
            }
