          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "30-ZN-64",
                "field_identifier": "ENR",
                "value": 0.994
              },
              "free_text": [
                "",
                "Two 64Zn samples (mass 4.05 +/- 0.05 mg and thickness",
                " 266.3 mg/cm2 each) attached back-to-back to the",
                " common cathode were used for simultaneous alpha event",
                " measurements of forward (0 to 90 deg) and backward",
                " (90 to 180 deg) angles.",
                "The isotopic abundance of the 64Zn samples was 99.4%.",
                " Each sample was vacuumevaporated on a tantalum",
                " backing 4.8 cm in diameter and 50 mm in thickness."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Twin-gridded ionization chamber.",
                "The working gas of the ionization chamber was",
                " Kr + 2.68%CO2. The pressures of the working gas were",
                " 1.40, and 1.65 atm for the 5.03, and 5.95 MeV",
                " measurements, respectively."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " A BF3 long counter as a neutron flux monitor."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "92-U-238(N,F),,SIG",
                  "code_unit": [
                    {
                      "unit": "92-U-238(N,F),,SIG",
                      "field": {
                        "reaction": "92-U-238(N,F)",
                        "target": "92-U-238",
                        "projectile": "N",
                        "process": "F",
                        "product": "",
                        "quantity": ",SIG",
