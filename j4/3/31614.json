                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "The absolute neutron flux was determined by measuring",
                " the fission rate with a 238Ufoil (diam. 4.50 cm,",
                " mass 7.85 +/- 0.10 mg, and abundance 99.999%) placed",
                " at the third position of the sample changer."
              ]
            }
