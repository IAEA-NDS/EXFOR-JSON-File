              "coded_information": null,
              "free_text": [
                "Sample deposited on stainless steel backing which is",
                "secured to detector with cellotape"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Catcher foil at 1.5-cm from target used to stop recoil-",
                "ing uranium nuclei. Background runs made using Th-232",
                "which has no shape isomers. Fission fragments near",
                "target and detector stopped by six layers of alumin-",
                "ized mylar."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Annular polycarbonate (Makrofol) track detector",
                "used in recoil geometry. Small Makrofol detector",
                "placed on catcher foil to monitor neutron flux"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Boron-loaded zinc sulphide neutron flux detector",
                "Helium neutron flux detector",
                "Makrofol detector efficiency relative to Cf-252",
                "spontaneous fission nu(bar) = 3.729+-0.015."
              ]
            }
          ],
