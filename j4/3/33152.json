            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The weights of the foils used in the irradiations are",
                "In foils of 0.2756 and 0.3177 g, Au foils of 0.3343",
                "and 0.1421 g and Al foils of 0.0297 and 0.0249 g,",
                "respectively.",
                "The sizes of the In, Au and Al samples were 1.4, 2.8",
                "and 1.43 cm2, respectively.",
                "They were separately wrapped with 0.011 mm thick Al",
                "foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma-ray counting of irradiate samples",
                "have been done by using a lead shielded 185-cc Baltic",
                "detector having 30 % relative efficiency coupled to a",
                "PC-based 4096 channel analyzer.",
                "The resolution of the HPGe detector has a FWHM of",
                "1.8 keV at the photo-peak of 1332.5 keV gamma-ray of",
                "60Co."
              ]
            }
          ],
