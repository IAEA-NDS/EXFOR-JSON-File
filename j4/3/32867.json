          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons were produced with deuteron beam (250",
                "keV) and a solid T-Ti target (about 2.5 mg/cm2). The",
                "fluctuation of neutron flux was monitored by the",
                "accompanied alpha particle with a silicon detector."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A stack was composed with natural isotope abundance",
                "of tin (0.25 mm, 99.9% purity), zirconium (0.3 mm,",
                "99.8% purity), niobium (0.2 mm, 99.9% purity) and",
                "aluminum (1 mm, 99.5% purity) foils. All of these",
                "foils were cut into round disk with diameter of 18 mm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation was lasted for 20 h. The",
                "stack was arranged in a sequence of Nb-Zr-Sn-Al-Nb",
                "and placed at about 120 deg angle relative to the",
                "deuteron beam direction at a distance of 5 cm. The",
                "cooling time is 11.9 d and measuring time is 1.8 d."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activation of each foil was measured with",
                "a lead shielded HPGe detector (ORTEC Corp., 25%",
                "relative efficiency, 1.9 keV resolution at 1332.5 keV",
                "of 60Co). Gamma Vision software (ORTEC Corp.,",
                "version 6.08) was used to record and analyze the",
                "gamma-ray spectrometry. The detector was",
                "precalibrated via stand gamma sources (109Cd, 133Ba,",
                "152Eu and 137Cs)."
              ]
            }
          ],
