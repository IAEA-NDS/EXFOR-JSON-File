          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Depleted uranium oxide(U3O8)waas used as the target.",
                "the target with thickness of 0.07cm  were sealed in",
                "polyethylene bag and coverd with 0.2cm cadmium capsule,",
                "which in turn was placed in a plastic carrier filled",
                "with 2 cm of boron carbide"
              ]
            }
