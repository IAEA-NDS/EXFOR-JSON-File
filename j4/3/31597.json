          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Averaged cross sections for the reactions",
                "68Zn(n,p)68gCu and 68Zn(n,p)68mCu for a 235U fission",
                "neutron spectrum"
              ]
            }
          ],
