          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Investigation of the reaction T(n,2n)d at En=13.95 MeV",
                "and the neutron-neutron scattering length"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "200-kV Kaman nuclear A-1003 deuteron accelerator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuterium-tritium"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "13.94+-0.22 MeV neutrons emitted at angle of 100 deg."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1) Tritium-titanium 9.2 mg/cm2 on gold base to produce",
                "   deuterons from T(n,2n)D reaction.",
                "2) Titanium 9.3 mg/cm2 for background subtraction.",
                "3) Deuterated-paraffin 16.5 mg/cm2 for direct",
                "   measurement of resolution function by simulation of",
                "   the resolution of a 7.69-MeV deuteron produced in",
                "   target 1).",
                "Targets were placed 20 cm from accelerator tip at an",
                "angle of 100 deg to the accelerated deuteron beam."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "EDE"
              ],
              "free_text": [
                " Direct detection, coincidence.",
                "The electronic system separated deuterons from",
                "background by:",
                "1) time coincidence in 5 counters",
                "2) limitation of E and delta-E to the relevant ranges",
                "3) final identification of particles by E*delta-E",
                "   multiplication.Product approximately proportional",
                "   to m*(Z**2),m=particle mass,Z=particle charge.",
                "Counting rate,0.3/min. Data given represent 30 runs of",
                "4-hr each."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "PROPC",
                "SOLST"
              ],
              "free_text": [
                " Counter telescope (see Nucl.Phys.",
                "A178,321 for schematic of telescope and electronics)",
                "consisting of six proportional counters, two for",
                "delta-E, the others to determine geometry and decrease",
                " accidental coincidences and",
                "solid-state total energy detector (1.7 cm diam)",
                "located 300 mm from target."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron-neutron scattering length has been derived",
                "and compared with theory."
              ]
            }
