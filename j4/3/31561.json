          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "From measurement of the fast/thermal -neutron flux",
                " ratio for monitor reactions having different",
                " threshold it was concluded that the neutron spectrum",
                " used was approximately a fission spectrum."
              ]
            }
          ],
