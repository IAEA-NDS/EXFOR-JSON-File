          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "54-XE-134-M",
                "field_identifier": "NAT",
                "value": 0.104357
              },
              "free_text": [
                " Naturally pure Xe",
                " (99.999%, 2.3-5.2g) gas pressurized to 120-250 atm",
                "was placed in a 1-mm thick spherical stain less steel",
                "container 20 mm in diameter. The samples and monitors",
                "were combined as ZrNbAl-Xe-AlNbZr for irradiatior."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A lead-shielded coaxial HPGe detector, with",
                "crystal diameter, length, relative efficiencies, and",
                "energy resolution (1.332 MeV) of 70.1 mm, 72.3 mm,",
                "68%, and 1.69 keV. The detector efficiency was",
                "calibrated using 152Eu, 133Ba, 137Cs, and 226Ra",
                "standard sources."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Five samples were allowed to decay after",
                "irradiation ((4-5) E10 n/s yield for 2 h) for 2.9 d,",
                "3.9 d, 5.0 d, 4.0 d, and 5.0 d, respectively. The",
                "measuring time is 23.4 hours."
              ]
            }
