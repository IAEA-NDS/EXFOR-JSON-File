          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Level density parameter was deduced from the slope of",
                "the line that is given as a result of plotting",
                "   ln((square(E)*n(E'))/(E'*sigma(E')))",
                "as a function of square root(E),were",
                "E=excitation energy of the residual nucleus,",
                "E'=kinetic energy of the alpha particle in c.m. system,",
                "n(E')=number of alpha particles emmitted between",
                "      energies of E' and E'+dE',",
                "sigma(E')=cross-section for the formation of the",
                "          compound nucleus in the inverse reaction.",
                "the formula for nuclear temperature T,",
                "   1/T=(square root(a/E))-2/E",
                "where a=level density parameter"
              ]
            }
          ],
