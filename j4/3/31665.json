            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activated samples were studied for their",
                " gamma-activities by a low background, high efficiency",
                " gamma-ray spectrometry, using a well calibrated",
                " GEM-60P coaxial high-purity germanium (HPGe) detector",
                " (crystal diam.: 70.1 mm, crystal length: 72.3 mm) with",
                " a relative  efficiency of ~68% and an energy resolutio",
                " of ~1.7 keV (FWHM) at 1.33 MeV."
              ]
            }
          ],
