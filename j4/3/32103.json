          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Be-7 sample was prepared from 0.1 micro-g/micro-l",
                "solution of Be-7Cl in diluted HCl. Solution was drop-",
                "deposited onto a 4 micro-m thick policarbon foil.",
                "Sample was covered by a very thin polyvinyl cloride",
                "film in order to prevent activity losses. Total number",
                "of Be-7 atoms was determined by measuring the intensity",
                "of 477.6 keV gamma rays."
              ]
            }
