          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The uranium target prepared by electroplating 235U on",
                "a 10 mg/cm2 Al backing. The uranium coating was about",
                "1 mg/cm2 ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Three silicon surface barrier type solid-",
                "state detectors were used to detect the long-range",
                "alpha particles.",
                "The active area of the detector was about 200 mm2, and",
                "was operated with a positive bias of 100 V.",
                "Two thin detectors, D2 and D3, were used to detect",
                "alpha particles emitted at 0 degree and 90 degree with",
                "angular resolution of about +- 18 degree."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The fission fragments were detected by a gas",
                "scintillation counter."
              ]
            }
          ],
