            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 238U sample is depleted uranium whose purity is",
                "99.9% and size is 10x10x2 cm. The sample is placed at",
                "the distance of 10 cm from the neutron source, and of",
                "40 cm from the emulsions. The normal of the sample is",
                "at 30 deg relative to the incident neutron beam and",
                "60 deg to the emulsions."
              ]
            }
          ],
