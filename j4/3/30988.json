          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements of neutron induced",
                "reactions on the zirconium isotopes in the energy",
                "range of 5.4 to 12.3 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3HUNDEB"
              },
              "free_text": [
                " MGC-29 compact cyclotron, Debrecen"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                " Monoenergetic neutrons were produced by bombar-",
                "ding a D-2 gas target with an analyzed beam of deute-",
                "rons. Neutron energy was varied with deuteron energy.",
                "Neutron energy distributions, calculated from reaction",
                "kinematics on the basis of deuteron energy losses and",
                "differential cross sections, were checked by scanning",
                "the neutron resonance absorption curve of C-12 around",
                "6.3 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Zr sample foils, 630 mg/cm**2, 19 mm diameter."
              ]
            }
          ],
          "METHOD": [
