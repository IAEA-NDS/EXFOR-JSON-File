          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutron capture gamma-ray studies of natural",
                "xenon"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " WWRS-reactor"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " thermal neutron flux = 6*10**6 neutrons/sec/cm2",
                "at the target position"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutron beam from the WWR-S reactor"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Solid-   1 g of solid XeF2 in a quartz capsule surroun-",
                "ded by a 6 mm thick metallic Li-6 cylinder"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct detection of the gamma rays. The peaks",
                "of the spectrum are fitted by a series of Gaussian",
                "curves, the background is approximated by a low order",
                "polynomial."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 4,10,30 cm3 Ge(Li) detectors shielded by lead"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Q values have been deduced =",
                "    Q = 9300.7 +-1.8 keV for Xe-129(n,g)Xe-130",
                "    Q = 8940.6 +-1.1 keV for Xe-131(n,g)Xe-132"
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                " gammas"
              ]
            }
          ],
          "EN-SEC": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calibration of the gamma ray spectrum =",
                " .From 0.2 to 3MeV,by radioactive isotopes(Na-22,Co-60,",
                " Co-57,Na-24)",
                " .From 3 to 9.3MeV,by (n,g) reactions on Cl, Co, Cr-53"
              ]
            }
          ],
          "FLAG": [
            {
              "pointer": "",
              "coded_information": [
                1.0
              ],
              "free_text": [
                " Assignment to Xe-129(n,g)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                2.0
              ],
              "free_text": [
                " Assignment to Xe-131(n,g)"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross sections and abundances of xenon natural",
                "isotopes are such that the (n,gamma) gamma spectrum of",
                "natural xenon is effectively that of Xe-129 and",
                "Xe-131(n,gamma)."
              ]
            }
          ],
