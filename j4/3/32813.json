          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The correction coefficient of the events induced by",
                "low-energy neutrons are 1.064 - 1.132, 1.125 - 1.164,",
                "and 1.090 - 1.127 for the 58Ni(n,a)55Fe, 60Ni(n,a)57Fe,",
                "and 61Ni(n,a)58Fe reactions, respectively.",
                "The proportion of alpha events arising from the",
                "impurity isotope are about 0% for the 58Ni(n,a)55Fe",
                "reaction, 0.89% - 1.07% for the 60Ni(n,a)57Fe reaction,",
                "and 11.69% - 12.95% for the 61Ni(n,a)58Fe reaction."
              ]
            }
          ],
