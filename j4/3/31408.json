                      "quantity_236": ",SIG"
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "the contributing 30-Zn-64(n,g)30-Zn-65",
                "reaction also can proceed by scattered and background",
                "neutrons with lower energies as well as by the D-D",
                "neutrons from the self build-up D-target reaction."
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": {
                "flag": null,
                "nuclide": "30-ZN-65",
                "half-life": {
                  "value": 244.1,
                  "unit": "D"
                },
                "radiation": [
                  {
                    "radiation_type": [
                      "DG"
                    ],
                    "energy": [
                      1116.0
                    ],
                    "intensity": 0.5075
                  }
                ]
              },
              "free_text": [
                " The gamma rays are",
                "mixed with those of Ni-65 which originate from the",
                "Zn-68(n,alpha)Ni-65 reaction and have the same energy",
                "of 1116 keV. Since the half live corresponding to the",
                "latter is much shorter ( 2.52hr) the activity of Zn-65",
                "could be determined after long enough cooling time."
              ]
            }
          ],
