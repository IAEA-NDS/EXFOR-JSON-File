          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements of (n,p) and (n, np+pn+d)",
                "reactions for some titanium, chromium, iron, cobalt,",
                "nickel and zinc isotopes around 14 MeV."
              ]
            }
          ],
