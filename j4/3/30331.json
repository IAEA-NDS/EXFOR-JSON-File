          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Deuterated liquid scintillators, NE 230,",
                "encapsulated in cylindrical glass cells.  The cells",
                "were all of diameter 27 mm and their lengths were 12,25",
                "and 37 mm respectively.  Pulse shape discrimination was",
                "used to distinguish recoil deuteron and breakup proton."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two methods were used to determine the breakup cross-",
                "section from the ratio of integrals of proton and",
                "deuteron spectra (R). One is to use the elastic data",
                "and other one to use the total neutron cross-section.",
                "The data obtained by two methods are in good agreement",
                "and the mean values are given."
              ]
            }
          ],
