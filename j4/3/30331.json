          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The integrals to calculate the ratio R were corrected",
                "for multiple neutron scattering in the scintillator,",
                "and for the effects of proton and deuteron escape.",
                "The proton integral was also corrected for such as",
                "C-12(n,p)B-12 rection and n-p scattering on small",
                " (1.39%) hydrogen impurity in the scintillator."
              ]
