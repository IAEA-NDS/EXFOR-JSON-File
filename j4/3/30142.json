          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pile and epicadmium neutrons. Flux density about",
                "10.**12 n/cm2/sec. Irradiation time,10 hours."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "0.03 mu-gram of Ra-223 as nitrate was dried on",
                "cellulose nitrate cups, wrapped in polyethylene, sealed",
                "in a quartz tube which was sealed in an aluminum can.",
                "A blank sample was prepared under identical conditions.",
                "Cellulose nitrate gave no Sr-91 activation product."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Following irradiation and chemical isolation of Sr-91,",
                "the fission cross section was estimated from Sr-91",
                "activity compared with the Sr-91 activity produced in a",
                "known amount of simultaneously irradiated uranium.Sr-91",
                "fission yield was assumed identical for Ra-223 and",
                "uranium."
              ]
            }
          ],
          "DETECTOR": [
            {
