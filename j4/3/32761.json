          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections could be made for variance of neutron",
                "yield during the irradiation. Some corrections were",
                "made for the effects of neutron intensity fluctuation,",
                "gamma ray self-absorption in the sample, the sum",
                "peak effects in the investigated nuclide and the",
                "counting geometry."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors were from counting statistics,",
                "standard cross sections, detector efficiency,",
                "weighting of samples, self-absorption of gamma-gay,",
                "coincidence sum effect of cascade gamma-rays."
              ]
            },
            {
