          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRLNZ"
              },
              "free_text": [
                " ZF-300-II intense neutron generator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Deuteron beam was 125 keV effective energy and",
                "20 mA current. The thickness of T-Ti target was about",
                "0.9 mg/cm2. The neutron flux fluctuation was",
                "monitored by a uranium fission chamber."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural oxide mercury powder was pressed in to disc",
                "of 20 mm diameter and packed in a thin polyethylene",
                "foil. Each sample was sandwiched between two iron",
                "foils, which used to measure the neutron fluence on",
                "the sample. 5 groups of samples were placed",
                "respectively at 5 angles distances ranging from 0",
                "deg to 120 deg relative to the beam direction and",
                "distances of samples from the target were about 5 to",
                "25 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The irradiation lasted up to 61 hours with neutron",
                "intensity of about 1-3E12 n/s/4pi."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activities of the samples and monitors",
                "were measured by gamma ray spectroscopy using a",
                "CH8403 coaxial HPGe detector made in China in",
                "conjunction with a EG and ORTEC 7450 Multichannel",
                "Analyzer. The energy resolution of the detector is",
                "2.7 keV for 1.33 MeV gamma ray."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "26-FE-54(N,P)25-MN-54,,SIG",
                  "code_unit": [
                    {
                      "unit": "26-FE-54(N,P)25-MN-54,,SIG",
                      "field": {
                        "reaction": "26-FE-54(N,P)25-MN-54",
