          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the cross sections ratios for the",
                "reactions 90Zr(n,2n)89m+gZr by 93Nb(n,2n)92mNb-,",
                "63Cu(n,2n)62Cu by 27Al(n,p)27Mg and 27Al(n,a)24Na by",
                "27A(n,p)27Mg for the purpose of neutron spectrometry",
                "around 14 MeV"
              ]
            }
          ],
