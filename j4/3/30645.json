          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron energy was calculated allowing for the",
                "following considerations",
                " 1) The angle of emission of the neutron",
                " 2) The existence of two groups of neutron energies",
                "    due to the presence of atomic and molecular ions",
                "    in the deuteron beam that is not analyzed.",
                " 3) The energy spread due to the profile of the",
                "    tritium in the titanium layer the energy spread",
                "    due to the final angular apertures spanned by the",
                "    beam spot and samples dimensions"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin foils of 1 cm diameter and placed at 11 cm from",
                "the center of the Ti-T target"
              ]
            }
          ],
