          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The results of the determination of the neutron energy",
                "by using the above ratio were neither consistent nor",
                "reproducible. The reason for that is apparently due to",
                "the large sensitivity of the annihilation process of",
                "b+ used to determine 63Cu(n,2n) cross section on the",
                "spatial arrangements of masses during the measurements."
              ]
            }
