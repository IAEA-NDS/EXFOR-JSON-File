          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of fission cross sections for",
                "232Th(n,f)Z-X-84 reaction around the neutron energy of",
                "14 MeV"
              ]
            }
          ],
