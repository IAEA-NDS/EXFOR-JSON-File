          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron flux was monitored by a uranium fission",
                "chamber so that corrections were made for small",
                "variations in the yield. The self-absorption of the",
                "sample at a given gamma-energy, the coincidence sum",
                "effect of cascade gamma-rays in the investigated",
                "nuclide and in the counting geometry were taken into",
                "account in data analysis, respectively."
              ]
            }
