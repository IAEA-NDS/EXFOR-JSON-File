          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of activation cross sections for",
                "175Lu(n,a)172Tm, 176Lu(n,a)173Tm and",
                "175Lu(n,p)175m+gYb reactions induced by neutrons",
                "around 14 MeV"
              ]
            }
          ],
