          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "F=fs*fg*fc, is the total correction factor:",
                " - fs is the correction factor for the self-absorption",
                "   of the sample at a given gamma energy;",
                " - fg is the correction factor for the counting",
                "   geometry;",
                " - fc is the correction factor for the coincidence",
                "   sum effect of cascade gamma rays in the investigated",
                "   nuclide.",
                "Correction factors for the self-absorption at",
                " 333.97/406.52 keV were,",
                " - 1.106/1.076 for sample 1 (0.1427 cm thick),",
                " - 1.128/1.092 for sample 2 (0.1718 cm thick),",
                " - 1.078/1.057 for sample 3 (0.1065 cm thick)."
              ]
            }
