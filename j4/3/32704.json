          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " Pd-300 neutron generator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "About 8 gram Ga2O3 powder of natural isotope",
                "composition sample (>99.99% purity) was pressed at 10",
                "ton/cm2, and a pellet, 0.4 cm thick and 2.0 cm in",
                "diameter was obtained. Monitor foils of Al (99.999%",
                "pure, 0.04 mm thick) of the same diameter as the",
                "pellets were then attached in front and at the back of",
                "each sample. Finally, wrapped in 1 mm thick cadmium",
                "foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The crystal geometry is 70.1 x 72.3 mm in",
                "diameter and length. The relative efficiency is about",
                "68%, and energy resolution is 1.69 keV at 1332 keV",
                "gamma ray from Co-60. The efficiency of the detector",
                "was pre-calibrated using various standard gamma",
                "sources such as Mn-54, Co-57, Co-60, Cd-119, Ba-133,",
                "Cs-137, Eu-152, Am-241 and Ra-226."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation of the samples was lasted 121 min",
                "with a yield around 3E10 to 4E10 n/s."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
