          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Chain yields were derived from cumulative yields using",
                "Wahl's charge distribution systematics (A.C.Wahl et al,",
                "2nd IAEA Symposium on Physics and Chemistry of Fission,",
                "Vienna, Austria, 28 July-1 August 1969, proceedings,",
                "page 813).",
                "Zp and the Gaussian width parameter SIGz of the",
                "distribution were calculated according to:",
                "Zp(A) = A/(1+(N/Z)p)",
                "SIGz(A) = 0.04A/((1+N/Z)p)**2",
                "where: (N/Z)p = (N/Z)f-0.05",
                "derived in: A.Goswami et al, J.Phys.26(1986)179"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error given in the DATA table for the chain",
                "yield is the same as that of the cumulative yield which",
                "is given as 1 standard deviation of 4 determinations."
              ]
            }
          ],
          "ASSUMED": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ASSUM",
                "reaction": {
