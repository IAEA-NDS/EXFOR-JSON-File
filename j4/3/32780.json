          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isomer ratios and cross sections for the isomeric",
                "pair 122mSb and 122gSb in the 123Sb(n,2n) reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
