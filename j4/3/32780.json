          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "F is the total correction factor of the activity,",
                "F=fc*fs. fc is the correction factor for the",
                "coincidence sum effect of the cascading gamma-rays in",
                "the investigated nuclide and fs is the correction",
                "factor for self-absorption of the sample for a given",
                "gamma energy. Correction factors for the",
                "self-absorption of the sample at 61.4, 76.06, 564.24",
                "and 692.65 keV are 2.890, 2.065, 1.012 and 1.010."
              ]
            }
          ],
