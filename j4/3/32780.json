          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "NGEN"
                ],
                "institute": "3CPRNPC"
              },
              "free_text": [
                " K-400 neutron generator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons were produced with an effective",
                "deuteron beam energy of 136 keV and beam current of",
                "260 uA. During irradiation, the neutron flux was",
                "monitored by accompanying alpha-particles so that",
                "corrections could be made for small variations in the",
                "yield."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "51-SB-123",
                "field_identifier": "NAT",
                "value": 0.4279
              },
              "free_text": [
                " Approximately 6.1 g of Sb with",
                "natural isotopic composition (of 99.99% purity) was",
                "formed into a pellet of 0.097 cm thick and 2.0 cm in",
                "diameter. Three samples and six monitors (niobium",
                "foils of 99.99% purity) with identical diameters were",
                "irradiated."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " a stack of Nb-Sb-Nb was assembled from these",
                "three samples and mounted at 0, 90 and 135 deg",
                "relative to the beam direction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High-purity germanium (HPGE) gamma-ray",
                "spectroscopy methods (about 68% relative efficiency,",
                "1.69 keV resolution at 1332.5 keV of 60Co). The",
                "detector was coupled to a digital gamma spectrometry",
                "system (ORTEC, model GEM 60 P) and maestro data",
                "acquisition software. The distance from the sample to",
                "detector end cap was 0-8 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The Au-Si surface barrier detector used to",
                "detect accompanying alpha-particle was at 135 deg and",
                "a distance of 110 cm from the target."
              ]
            }
          ],
