          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The infinite-dilution resonance integral was obtained",
                "by extrapolating the experimental values of IXG(R) to",
                "zero thickness using the calculated resonance self-",
                "shielding correction factor, G(R),as a parameter"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-shielding correction,G(R),was calculated for every",
                "resonance using the parameters of Maletzki et al.(Energ",
                "AT 24 80 1968) and the narrow resonance approximation.",
                "Experimental determination of resonance self-shielding",
                "was made by measuring the cadmium ratio for two",
                "different sample thicknesses"
              ]
            }
          ],
