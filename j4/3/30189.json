          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cadmium ratio technique was applied to determine",
                "the ratio of the reduced resonance integral (I),to the",
                "thermal capture cross section."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
