          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The detected neutron energy is given under 'E',",
                "the fixed detector angle under 'ANG'.",
                "Data of this kinematically complete experiment have",
                "been analysed with an exact three-body calculation",
                "using S-wave separable potentials. The analysis",
                "of the n-n and n-p final state interaction peaks gave",
                "-16.3+-1.6 fm for the n-n 1S0 scattering length and",
                "3.15+-0.7 fm for the effective range."
              ]
            }
