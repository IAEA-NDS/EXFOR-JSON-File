          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Disks of natural indium metal 20mm in diameter and",
                " 0.3-0.5mm in thickness was sandwiched between disks",
                " of thin Al of the same diameter, all the metals with",
                " purities better than 99.9%. Abundance of target",
                " isotope: In-115 95.7%,In-113 4.3%. To prevent thermal",
                " neutrons, these foils were wrapped with 1mm thick Cd",
                " foils during the irradiation."
              ]
            }
