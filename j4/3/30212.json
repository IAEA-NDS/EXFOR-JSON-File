          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement on beryllium with polarized neutrons",
                "of the energy 2.60 - 2.77 MeV."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "130 keV deuteron beam"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "    D(d,n)He-3 reaction,rotating heavy ice target"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In short time intervals spectra on the right side",
                "and on the left side measured with and without",
                "scatterer.",
                "Scattering angle 50.0 +- 0.2 deg lab system",
                "measured asymmetry p1*p2 = (l-r)/(l+r)",
                "p1  polarization of neutrons",
                "p2  polarization power of scatterer",
                "l   left intensity of scattered neutrons",
                "r  right intensity of scattered neutrons"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Cylindrical stilbene scintillation counter"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutron intensities l,r in the above formula have",
                "been replaced by the energy derivatives of the",
                "respective recoil proton intensities. The recoil proton",
                "spectra have been smoothed and differentiated",
                "numerically."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                "      Neutrons via recoil protons"
              ]
