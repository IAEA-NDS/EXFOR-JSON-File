          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SHAPE"
              ],
              "free_text": [
                " Experimental data were analyzed by a peak-",
                "fitting program which is capable of resolving multi-",
                "plets."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections for neutron flux attenuation and gamma",
                "ray self-absorption in the sample were calculated with",
                "Monte Carlo simulation. Also multiple scattering,",
                "absorption of neutrons by target backing and cooling",
                "water and size and anisotropy of the neutron source",
                "were taken into account in the determination of the",
                "cross sections."
              ]
            }
          ],
