          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Hollow cylindrical Si samples, 3 cm high and 3 cm in",
                "diameter, with the natural abundance and high chemical",
                "purity."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "GSPEC",
                "ASSOP"
              ],
              "free_text": [
                " The pulsed-beam time-of-flight",
                "technique was used for reducing background caused by",
                "primary and scattered neutrons. Absolute neutron flux",
                "was determined by counting the associated alpha par-",
                "ticles produced in the T(d,n)He-4 reaction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
