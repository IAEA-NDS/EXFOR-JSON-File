          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Integration over differential neutron emission cross-",
                "section (Exfor 30275.024),",
                "and fitting with the sum of Weisskopf-Ewing formula",
                " (equilibrium emission) and exciton model",
                "formula(non-equilibrium emission),",
                "   K(1)*g(E,T) + K(2)*n(E) where K(1)=2.25*E-7/(MeV)**2",
                "                                 K(2)=8.0 *E-4/(MeV)**2",
                " and E is for emitted neutron energy and T for nuclear",
                " temperature.",
                "Then extrapolation to E=0, and integration over the",
                "range E=0 to E0, yields emission cross-section."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron source strength was absolutely determined by",
                "the associated particle method."
              ]
            }
          ],
