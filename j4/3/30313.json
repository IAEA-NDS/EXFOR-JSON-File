          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Total(n,2n) cross-section was deduced from",
                "sig(n-emission)=sig(non-elast)+sig(n2n)-sig(na)-sig(np)",
                "data were taken from:",
                " * 2000 mb by Blow,J.Nucl.Energy,26(1972)9 and",
                " * neglecting the small contributions,10mb of sig(na)",
                " * 20mb of sig(np), both the approximate values from",
                "Cuzzocrea et al.,Nuov.Cim.4A(1971)251 and Qaim,Z.Naturf",
                "25A(1970)1977.",
                "The value of the neutron emission cross-section is",
                "taken from one in subent.2."
              ]
            }
