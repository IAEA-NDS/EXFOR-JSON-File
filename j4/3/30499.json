          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "200 micro-g/cm2 235U electrosprayed on VYNS-film.",
                " area=1 cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Fragments and LRA for the ternary fission.",
                "Binary data were collected simultaneously.",
                "Fragment masses were calculated from the measured",
                " energies through the conservation of momentum. Thus,",
                " for the binary events a 2-dimensional fragment-mass",
                " and energy matrix, and for the ternary events a 3-",
                " dimensional fragment mass/fragment energy/LRA energy",
                " matrix was obtained."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Back-to-back gridded ionization chamber,filled",
                " with a mixture of argon (97%) and methane (3%),",
                " press=1.5 atm. The 235U source served as cathode,",
                " the two collector plates were formed of Al foils",
                " (3 mg/cm2)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " 2 semiconductor detectors were placed behind",
                " the collector windows, to detect LRA."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "TABLE"
                ],
                "subentry_number": null,
                "author": null,
                "reference": null
              },
              "free_text": [
