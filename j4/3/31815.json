          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "147Pm deposited in circular areas (22 mm in diam.)",
                " onto two 5 um thick Al foils, each glued onto a 6 um",
                " Mylar foil, then placed face-to-face into a plastic",
                " ring (60 mm diam.) served as the target holder.",
                "Prepared by neutron irradiation of 146Nd2O3 (enriched",
                " to 98.8%) at ILL in summer 2013 followed by chemical",
                " separation and purification at PSI.",
                "Au foil (118.8(1) mg, 12.5 um thick 25 mm in diam.)",
                " as a neutron monitor attached to the back of the",
                " target holder during 147Pm irradiation."
              ]
            }
          ],
