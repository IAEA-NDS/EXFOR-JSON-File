          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The fission product yields from Th-232 (=Y(fp,2)) are",
                "   calculated from the measured R-values (=R) and the",
                "   U-235 fission yields (=Y(fp,5)) according to:",
                "       Y(fp,2) = R * Y(99,2) * Y(fp,5)/Y(99,5)",
                "   where Y(99,2) and Y(99,5) are the corresponding",
                "   Mo-99 yields."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "MONIT1",
                "reaction": {
                  "code": "90-TH-232(N,F)42-MO-99,CUM,FY,,FIS",
                  "code_unit": [
                    {
                      "unit": "90-TH-232(N,F)42-MO-99,CUM,FY,,FIS",
                      "field": {
                        "reaction": "90-TH-232(N,F)42-MO-99",
                        "target": "90-TH-232",
                        "projectile": "N",
                        "process": "F",
                        "product": "42-MO-99",
                        "quantity": "CUM,FY",
                        "data_type": null,
                        "general_quantity_modifier": "FIS",
                        "quantity_236": "CUM,FY"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " = Y(99,2)",
                "   obtained by normalising the relative Th-232 yields",
                "   (including estimated yields) to a total of 200%."
              ]
            },
