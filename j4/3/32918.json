          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " neutrons are produced by spallation reactions",
                "induced by double bunches per pulsed, 41 ns wide",
                " (FWHM) and the interval between the two bunches is",
                "410 ns, 1.6 GeV/c proton beam with a typical",
                "repetition rate of 25 Hz, impinging on a",
                "tantalum-cladded and water-cooled sliced tungsten",
                "target."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural thorium sample with a diameter of 50.0 mm and",
                "a thickness of 0.5 mm, corresponding to 1.518E-3",
                "atoms/b. The chemical purity of the 232Th sample is",
                "99.5%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "PHWT"
              ],
              "free_text": [
                " At the sample position located at a flight",
                "length of about 76 m."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Four C6D6 detectors (EJ315). The distance",
                "between the center of the front face of these C6D6",
                "detectors and the sample center was about 15.0 cm.",
                "The volume of the detector is 5.0 * 3.0 inches. The",
                "array was placed upstream of the sample at an angle",
                "of 125 degrees."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " The neutron flux during the measurement was",
                "monitored by the proton beam intensity and a",
                "6LiF-silicon detector."
              ]
            }
          ],
