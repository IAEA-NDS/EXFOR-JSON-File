                ],
                "reaction": null
              },
              "free_text": [
                " Deuterons have been accelerated to 440 keV and to",
                "990 keV in order to obtain monoenergetic neutrons"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "consisted  of metallic Zr cylinders"
              ]
            }
          ],
