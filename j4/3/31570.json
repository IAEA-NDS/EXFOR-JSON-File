          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Empty run was done for about 60 hrs to measure",
                " background.",
                "Two graphite samples (203 and 562 mg, 99.999% purity)",
                " were also irradiated for about 50 hrs to estimate",
                " background variation due to scattering effect of the",
