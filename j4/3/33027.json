          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-section for the formation of isomeric pair",
                "75Ge-m,g through (n,2n),(n,p) and (n,alpha) reactions",
                "measured over 13.73 MeV to 14.77 MeV and calculated",
                "from near threshold to 20 MeV neutron energies"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
