            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "These cross-sections were obtained with the assumption",
                "that the Os-190(n,n') reaction cross-section is",
                "constant in the neutron energy range 16.6 - 18.8 MeV",
                "and equals to the value 10.0 mb measured at energies",
                "lower than 16.6 MeV."
              ]
            }
