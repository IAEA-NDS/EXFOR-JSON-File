          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal neutron flux of about 10**8 n/cm2/sec.",
                "Compiler's note =",
                "For this kind of experiments, incoming neutron energy",
                "is desirable to be close to the neutron resonance",
                " (whether positive or negative),from where (n,a) could",
                "be observable, and high neutron flux is essential to",
                "get this low probability phenomena. 'SPA' has been used",
                "in this sense."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " Direct counting of emitted alpha by the counter",
                "telescope."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SOLST"
              ],
              "free_text": [
                "",
                "Telescope consisting of 'dE/dx' and 'E' silicone",
                "surface barriers detectors with the thickness of",
                "1.1/10**3 and 1./10**2 cm, respectively.",
                "Energy and efficiency calibration were performed with",
                "alpha spectrum from Sm-149(n,a) reaction."
              ]
            }
          ],
