          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement and evaluation of the activation resonance",
                "integral of Nd-146,Nd-148 and Nd-150"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Central graphite reflector of reactor RA-1"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neodymium-gold samples 3mg/cm2 thick containing 3 parts",
                "of gold per 10000 parts of neodymium."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cadmium ratio technique was applied to determine",
                "the ratio of the reduced epithermal resonance integral",
                "to the thermal capture cross section"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The reduced resonance integral was obtained by",
                "multiplying the epithermal integral by a correction",
                "factor, F, which represents the ratio of epithermal",
                "neutron captures in a 1/E spectrum to the epithermal",
                "neutron captures in the actual reactor spectrum.",
                "A calculation and an evaluation of the reduced",
                "epithermal and resonance integral was also undertaken",
                "taking into account resonance parameters obtained from",
                "different published time of flight experiments. A",
                "calculation of the unresolved resonance integral was",
                "made using high energy radiative cross sections",
                "obtained from published statistical model calculations."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Ratios of reduced capture resonance integral to thermal",
                "cross section determined relative to gold, with a gold-",
                "cadmium ratio of 1.684+-0.003 and a value of the ratio",
                "of resonance integral to thermal cross section of gold",
                "of 15.7"
              ]
            }
          ],
          "STATUS": [
