          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The high resolution gamma-ray spectrometer used",
                "for the determination of induced activity in",
                "radioactive samples employed a high purity germanium",
                "detector, having a resolution of 1.90 keV at 1332.5 keV",
                "gamma-ray peak of 60Co. The detector was covered with a",
                "special shielding arrangement which contained lead,",
                "cadmium, copper and PVC layers to avoid the",
                "interference of potentially occurring lead X-ray in",
                "the vicinity of our peak of interest (80.6 keV)."
              ]
            }
          ],
