          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thermal neutron cross section of the reaction",
                "was deduced from the ratio of the sub-cadmium",
                "reaction rates to the thermal neutron flux. The same",
                "was also determined from the ratio of subcadmium",
                "reaction rates of holmium to the same ratio of the",
                "co-irradiated cobalt monitor, subsequently",
                "multiplied with the thermal cross section of 59Co."
              ]
            }
          ],
