          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distributions of fission fragments at the",
                "U-238(n,2nf) threshold"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
