          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the 239Pu(n,f) cross section from 4",
                "keV to 100 MeV using the white neutron source at the",
                "CSNS Back-n facility"
              ]
            }
          ],
