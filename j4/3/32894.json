          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The total uncertainty including unfolding",
                "error (2.6% to 15%). It is reduced to 1.7% to 5.8%",
                "if the unfolding error is excluded."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
