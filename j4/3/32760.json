          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements for 111Cd(n,p)111mAg,",
                "106Cd(n,2n)105Cd, 110Cd(n,2n)109Cd,",
                "116Cd(n,2n)115mCd and 116Cd(n,2n)115gCd reactions"
              ]
            }
          ],
