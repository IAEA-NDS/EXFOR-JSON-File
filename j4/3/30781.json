          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The photopeak area of 459 keV g-ray was extracted with",
                " the computer code SAMPO, which fits each gamma-ray",
                " with Gaussian + two exponentials.",
                "The fitting parameters for the code were determined by",
                " using standard monoenerg. gamma-sources."
              ]
            }
          ],
