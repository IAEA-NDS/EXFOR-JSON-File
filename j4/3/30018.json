          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A fit to the measured data in energy range 1.1-2.5",
                " milli-eV was made using the least square method with",
                " weighted points. The function chosen was of the form",
                " sigma=a+B*lambda, where lambda=wave-length of neutrons",
                " in angstroms. B was found to be 54.47+-0.10 Barn/",
                " angstrom. From this the sigma value at 2200 m/sec was",
                " calculated."
              ]
            }
          ],
