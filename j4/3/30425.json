            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The gamma ray spectra of these noble gases and",
                " their daughters were measured and the corresponding",
                " independent yields were calculated.",
                " The gamma tin and antimony ray spectra were measured",
                " and the corresponding independent yields were",
                " calculated directly besides for Sn-131 which was",
                " calculated by comparing the measurements from Th-232",
                " to those from U-235."
              ]
            }
