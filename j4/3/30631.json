          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute yields of fission products in the thermal-",
                "neutron induced fission of 245Cm"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " Natural uranium heavy water reactor cirus",
                "with neutron flux 1*10**13 n/cm**2/sec"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Predominantly thermal"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The isotopic composition was (in atom percentage)",
                " 96-Cm-244 - 93.86%",
                " 96-Cm-245 -  2.01%",
                " 96-Cm-246 -  4.13%",
                "Samples were prepared by evaporating a known weight of",
                "the solution of curium (about 100 microgramm) in",
                "dilute nitric acid on super pure aluminium foils",
                "since 245Cm  has a thermal neutron cross-section",
                "about 1924 times higher than that of 244Cm, 99%",
                "of the total fission  in the thermal neutron",
                "irradiation will be from 245Cm"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Track-etch-cum gamma-ray spectrometric technique",
                " (see A.Ramaswami et al.,J.Inorg.Nucl.Chem.,41(1979)",
                "1531, ibid.42(1980)1213)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " A mica strip track detector for registration",
                "of the number of the fission events occuring in the",
                "sample"
              ]
            },
