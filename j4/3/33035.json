          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "100 mu-g/cm2 electro-deposited on 160 mu-g/cm2 Ni",
                " backing"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Used in the 1st experiment:",
                " A 5 cm x 5 cm NE213 scintillation neutron detector",
                " was placed collinear to the two fragment detectors at",
                " a distance of 66.8 cm from the 235-U target.",
                "The neutron detector was well shielded with 7 cm of",
                " lead surrounded by 50 cm of borated paraffin in a",
                " cylindrical geometry to reduce the background."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Used in the 1st experiment:",
                " The surface barrier detectors were located at",
                " 2.5 cm x 3.5 cm on either side of the target, which",
                " ensured that both the fragments were detected in",
                " coincidence without any bias due to loss of",
                " collinearity of the two fragments from the extended",
                " source and due to neutron emission effects."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Used in the 2nd experiment:",
                " A back to back gridded ionization chamber was used to",
                " measure the energy and angle of both the fission",
                " fragments.",
                "The chamber consisted of a central cathode and two",
                " parallel plate ionization chambers with frisch grids",
                " in a back to back geometry.",
                "The distance between the anode and the grid was 0.7 cm",
                " and between the cathode and grid it was 3.0 cm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " The neutron time of flight was derived with the",
                " start signal taken from the common cathode of the",
                " ion-chamber and the stop signal taken from the",
                " neutron detector.",
                "The pulse heights of the signals from the collectors,",
                " the grids, the pulse shape and energy signals of the",
                " neutron detector and neutron time of flight were",
                " recorded in list mode for further offline analysis."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Two fission fragments detected in coincidence"
              ]
            }
          ],
