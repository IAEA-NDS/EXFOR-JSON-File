          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-Determination of the cross section of K-41(n,a)Cl-38",
                " for fission neutrons.-"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
