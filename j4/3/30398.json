              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " IRT-1000 Research Reactor at Institut fuer Kern-",
                "forschung U. Kernenergetik in Sofia.",
                "n-flux = 4. x 10**12 n/s/cm2."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The ratio of thermal and fast component in the neutron",
                "flux was determined to be ' 5.4 ' using the reaction of",
                "S-32(n,p)P-32 (=69 mb for fission neutrons) and",
                "P-31(n,g)P-32(=190mb for thermal neutrons) and their",
                "Cd-ratios."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "K(2)-SO(4) or K-NO(3),100 to 150mg, used together with",
                "NH(4)-Cl as the standard sample."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP",
                "MOMIX"
              ],
              "free_text": [
                "",
                "K(2)-SO(4) or K-NO(3) was irradiated together with",
                "NH(4)-Cl as chlorine standard in the neutron flux 90min",
                "after radiochemical separation of Cl-38 from KNO(3) and",
                "K(2)-SO(4), 1.64- and 2.17-MeV gamma peaks from Cl-38",
                "was measured by Ge(Li) detector."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 18 cm3 Ge(Li) detector with DIDAC 4000 multi-",
                "channel analyzer."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "DG"
              ],
              "free_text": [
                " Decay gamma of 1.64 and 2.17 MeV from Cl-38."
              ]
            }
          ],
