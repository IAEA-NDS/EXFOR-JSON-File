          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of fission neutron spectrum averaged cross",
                " sections of some threshold reactions on europium:",
                " small scale production of no-carrier-added 153Sm in",
                " a nuclear reactor"
              ]
            }
          ],
          "AUTHOR": [
