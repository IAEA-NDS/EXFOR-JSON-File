          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In converting the count rates to decay rates",
                " corrections were applied for radiochemical yields,",
                " gamma-ray intensities, detector efficiencies,",
                " counting geometry, absorption, self-absorption,",
                " pile-up effects and coincidence losses."
              ]
            }
          ],
