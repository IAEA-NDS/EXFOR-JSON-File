          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "3PAKNIL"
              },
              "free_text": [
                " 10 MW swimming pool type Pakistan",
                "research reactor (PARR-I) at Pinstech."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity dysprosium oxide (99.999% pure), weighing",
                "25-50 mg, was filled in a quartz ampoule, sealed and",
                "then placed in an NRX type aluminum irradiation capsule"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " The radioactivity of the reaction products and",
                "the monitor reactions was determined by gamma-ray",
                "spectrometry using a coaxial 30 cm3 Ge(Li) detector in",
                "conjunction with a 4 K Canberra Series 85 multichannel",
                "analyzer."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fast neutron flux density was 7. X 10**13 n/cm2/sec",
                "and the thermal neutron flux density was",
                "2. X 10**14 n/cm2/sec.",
                "  Thermal neutron flux density measurement:",
                "   197Au(n,g)198Au      98.8 +/- 0.3 b",
                "   59Co(n,g)60Co        37.2 +/- 0.2 b",
                " Fast neutron flux density measurement:",
                "  54Fe(n,p)54Mn       82.5 +/- 5.0 mb",
                "  56Fe(n,p)56Mn       1.07 +/- 0.08 mb",
                "  58Ni(n,p)58Co       113. +/- 7.0 mb",
                "  60Ni(n,p)60Co       2.3 +/- 0.4 mb",
                "From measurement of the fast/thermal-neutron flux",
                "ratio for monitor reactions having different threshold",
                "it was concluded that the neutron spectrum used was",
                "approximately a fission spectrum."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                " The irradiation time varied from 1 hr to",
                "10 hr depending upon the half-life of the radionuclide."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " A new radiochemical separation was proposed."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In converting the count rates to decay rates correc-",
                "tions were applied for radiochemical yields, gamma-ray",
                "intensities, detector efficiencies, counting geometry,",
                "absorption, self-absorption, pile-up effects and",
                "coincidence losses."
              ]
            }
          ],
