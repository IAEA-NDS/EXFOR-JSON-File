          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of fission neutron spectrum averaged cross",
                "sections of some threshold reactions on dysprosium:",
                "small scale production of no-carrier-added 153Gd",
                "in a nuclear reactor"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Waheed",
                "J.H.Zaidi",
                "S.Ahmad",
                "M.Saleem"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RCA,90,443,2002",
                "code_unit": [
                  {
                    "unit": "J,RCA,90,443,2002",
                    "doi": "10.1524/ract.2002.90.8_2002.443",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "RCA",
                        "number": null,
