          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "918 'Hammer stars' from the reaction",
                "11B(n,a)8Li(B-)8Be(2a) were recorded, giving (1.)",
                "spatial orientations of the 3 alphas and the 8Li",
                "particle and (2.) the energies of the 3 alphas."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " Boron-loaded nuclear emulsions were used",
                "both as a target and detector"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calculated were",
                "-energy of 8Li nucleus",
                "-Q-value for each event, giving information on whether",
                " 8Li was left in ground or first excited state.",
                "The outgoing system was kinematically overdetermined",
                "which was valuable particularly for efficient",
                "background subtraction."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No information"
              ]
            }
          ],
