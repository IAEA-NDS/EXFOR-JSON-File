          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "252Cf electrodeposited target (1.7 ug) were collected",
                "on 0.5 mm, Al-catcher foil at 1 mm distance.",
                "245Cm target 3 ug, electrodeposited. Covered with the",
                "Al-catcher foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 60 cm3 with resolution 1.5 keV at 122 keV and",
                "3.9 keV at 1332 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Collection of fission fragments on Al-catcher foil.",
                "The amounts of the investigated fission product",
                "nuclei and of their daughters was determined by",
                "measuring the daughters' gamma activities at",
                "different cooling times."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The required half-lives of the fission products and",
                "their daughters were taken from the 'Karlsruhe",
                "Nuklid-karte' 1974.",
                "From the numbers of nuclei of a given fission product",
                "'m', n(m), and of its daughter 'd', n(d) , at the end",
                "of irradiation, the fractional cumulative yield ('FCY')",
                "was obtained from the relation FCY(m)= n(m)/n(m)+n(d)."
              ]
            }
          ],
