          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutron beams from the heavy-water reactor were",
                "first collimated and then reached a NaCl(200) mono-",
                "chromator. Through Bragg diffraction in NaCl(200) the",
                "monoenergetic 0.0253 eV neutrons were selected. Between",
                "the NaCl(200) monochromator and the measured sample a",
                "mechanical monochromator was inserted in order to cut",
                "off the neutrons with high energy."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gold foils, purity 99.9%, diameter 4.2 cm, thickness",
                "1.527g/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "MANGB"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Using 80% enriched boron-10."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "D4PI"
              ],
              "free_text": [
                " using manganese sulphate solution as detector",
                "medium."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For the total cross section corrections have been made",
                "for the secondary-neutron effect and dead time of",
                "detecting system. For the absorption cross section",
                "of gold corrections have been made for the reflected-",
                "neutron effect, secondary-neutron effect, escaped-",
                "neutron effect and the boundary effect of the sample."
              ]
            }
          ],
