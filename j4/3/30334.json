          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 30 cm3 coaxial Ge(Li) detector. The gamma-line",
                "intensities correspond to an observation angle of 90",
                "deg to the primary beam of neutrons."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Reactor fast neutrons-Neutron beam was passed",
                "through a filter consisting of 0.5 mm cadmium, 1 cm",
                "B4C and 9 cm of lead, for filtering off thermal",
                "neutrons and gamma-rays. To a first approximation, at",
                "neutron energy higher than 1.5 MeV the spectrum of",
                "reactor fast neutrons falls off according to the",
                "exp(-0.72E(n))-law. (Nucl.Instr.and Meth.117(1974)533)."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-absorption of gamma-rays in the sample was",
                "corrected."
              ]
            }
          ],
