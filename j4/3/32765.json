          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of fission cross section for",
                "232Th(n,f)Z-X-131 (Z = 50, 51, 52, 53) reaction",
                "induced by neutrons around 14 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Chang-Lin Lan",
                "Yi-Jia Qiu",
