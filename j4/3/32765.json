          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,EPJ/A,53,131,2017",
                "code_unit": [
                  {
                    "unit": "J,EPJ/A,53,131,2017",
                    "doi": "10.1140/epja/i2017-12318-2",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "EPJ/A",
                        "number": null,
                        "volume": "53",
                        "part": null,
                        "issue": null,
