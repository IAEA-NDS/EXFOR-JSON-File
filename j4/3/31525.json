          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Only the overall error is given as the square root of",
                "the sum of squares of:",
                "    standard deviation of the average",
                "    and the errors of:",
                "       fission rate determination",
                "       error of fission rate determination",
