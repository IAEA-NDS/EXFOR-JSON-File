                "reaction": null
              },
              "free_text": [
                " deuterium ions with an energy of 175 keV on a",
                "8 Ci tritium target. The beam had a 4 mm diam. and beam",
                "current of ~100 uA."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Nd2O3 powder (99.9% pure) sample of natural isotopic",
                "abundance. The 2 gm of powder was measured with a",
                "microbalance with an accuracy of +/- 10 ug, which was",
                "covered in a polyethylene bag.",
                "The sample was wrapped with Al foil (0.3 gm), and size",
                " (10 mm X 10 mm) for neutron flux monitoring."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " detector having 30% relative efficiency and",
                "1.5 keV energy resolution at 1.33 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The sample was irradiated for a period of",
                "3600 sec."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Irradiated samples were corrected for",
                "- the self-absorption due to interaction of gamma rays",
                "with itself",
                "- the coincidence summing effect due to cascade gammas3"
              ]
            }
