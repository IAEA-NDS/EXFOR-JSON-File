          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Electrodeposited target of 241Am (~20 ug) were covered",
                "with superpure aluminum  catcher foil and together were",
                "wrapped in 1 mil cadmium foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Samples were assayed gamma-spectrometrically",
                "an 8% HPGe detector coupled to a 4096 channel analyser",
                "The resolution of the detector is 2.1 keV at 1332 keV",
                "in live time mode."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " The aluminum foil was dissolved in sodium",
                "hydroxide. Five milliliters of this solution assayed",
                "for the activity of tellurium isotopes without radio",
                "chemical separations.",
                "The rest of the solution was used for the separation",
                "of fission product iodine by using solvent extraction",
                "technique."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron flux 8 X 10**12 n/cm2/sec2 for suitable length",
                "of time (t = 30-150 min.)"
              ]
            }
          ],
