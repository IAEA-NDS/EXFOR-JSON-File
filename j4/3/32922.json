          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental measurement of 91Zr(n,g)92Zr at the",
                "CSNS Back-n facility from 0.82 keV to 229 keV"
              ]
            }
          ],
