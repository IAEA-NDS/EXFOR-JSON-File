          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": "3CPRIHP"
              },
              "free_text": [
                " The Back-n white neutron source at",
                "China Spallation Neutron Source (CSNS)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "SPALL"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutrons are generated through the",
                "bombardment of a spallation target by a proton beam",
                "with an energy of 1.6 GeV and a frequency of 25 Hz."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A natural Zr target with an abundance of 91Zr at",
                "11.23%, has a diameter of 30 mm and a thickness of",
                "7.8 mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " An HPGe detector was positioned 202 mm behind",
                "and to the left of the experimental target, forming a",
                "125-degree angle with the beam direction, to detect",
                "the gamma rays emitted during the reaction. As the",
                "detection efficiency of the detector at 934.3 keV is",
                "approximately 0.0048%. The energy and efficiency",
                "calibration of the detector were performed using the",
                "standard radioactive sources, specifically 60Co and",
                "152Eu."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " A flight path about 76 m."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Not corrected for direct capture contribution, which",
                "is estimated to be less than 0.6% according to RADCAP",
                "code"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 5.0,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The statistical error of the",
                "characteristic gamma rays predominantly ranges",
                "between 5% and 10%, with some errors exceeding 20%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": 1.0,
                "correlation_property": null
              },
              "free_text": [
                " The error in neutron intensity is based",
                "on data provided by CSNS. Its relative error",
                "decreases gradually with increasing neutron incident",
                "energy, with a maximum value of approximately 1%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error introduced by the detector energy",
                "efficiency curve is approximately 2.5%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Since the gamma characteristic peaks of other",
                "de-excitation paths were not identified in this",
                "experiment, their error contribution is taken as 3.3%."
              ]
            }
          ],
