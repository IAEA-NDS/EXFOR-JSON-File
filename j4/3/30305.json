              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of flight. Fast coincidence (resolution 3ns)",
                "between the signals from the recoil alpha particle",
                "detector and the primary neutron detector gives the",
                "start signal for TOF.  Energy of the elastically",
                "scattered neutrons from a plastic scintillation",
                "detector(primary 1inch detector), can be selected by",
                "changing the angle of scattering in the TOF arrangement",
                "the stop signal is obtained from 2inch thick liquid",
                "scintillator(final neutron detector)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
