          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "23-V-51",
                "field_identifier": "NAT",
                "value": 0.9975
              },
              "free_text": [
                " The samples of V and Al as",
                "foils 20 mm in diameter were 99.5% and 99.999% in",
                "purity, and 0.3 and 0.2 mm in thickness. The distance",
                "between target and sample is 5~28 cm. The V sample in",
                "each group was sandwiched between two Al foils."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " An effective deuteron beam energy and beam",
                "current is 125 keV and about 20 mA. T-Ti target was",
                "around 0.9 mg/cm2 thick. Neutron yield is 2E12 n/s."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A CH8403 coaxial high-purity germanium",
                "detector with a relative efficiency of 20% and an",
                "energy resolution of 2.6 keV at 1.33 MeV. The",
                "efficiency was calibrated by a standard gamma-source,",
                "standard reference material 4275 from the National",
                "Institute of Standards and Technology. In gamma ray",
                "measurement, the distance between sample and HPGe is",
                "2 cm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " The neutron flux was monitored by a uranium",
                "fission chamber."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation was lasted 0.5 and 6 hours,",
                "the angle is from 0 to 130 degree between deuteron",
                "beam and target."
              ]
            }
          ],
