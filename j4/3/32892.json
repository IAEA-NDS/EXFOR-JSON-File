          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-purity (99.9%) 124Xe and 78Kr gas. The effective",
                "volume were designed to be about 18 mm in diameter",
                "and 10 mm in height. The containers are made of",
                "organic glass with an end face thickness of 1 mm."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Monoenergetic neutrons are produced with",
                "charged deuteron beam energy of 220 keV and current",
                "of 200 uA. The neutron yield was about 2E10 - 3E10 n/s."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The accompanying alpha-particles was recorded",
                "moment to moment by an Au-Si surface barrier detector",
                "at 178 degree with distance of 637 mm, for monitoring",
                "the variation of neutron flux."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A planar High Purity Germanium (HPGe) detector",
                "with a relative efficiency of 40%, and a coaxial HPGe",
                "detector with a relative efficiency of 60%. The",
                "detectors were calibrated using a series of standard",
                "surface sources of 133Ba, 152Eu, 60Co, 137Cs and",
                "166mHo with 18 mm in diameter."
              ]
            }
          ],
