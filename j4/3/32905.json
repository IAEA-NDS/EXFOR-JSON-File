          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Neutrons with a yield of (4-5)E10 n/s,",
                "produced with a deuteron beam energy of 255 keV and a",
                "beam current of 350 uA. The solid tritium-titanium",
                "target was about 2.19 mg/cm2 thick."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural titanium plates of 99.99% purity and 0.3",
                "cm thickness were made into thin disc-shaped samples",
                "with a diameter of 2.0 cm. Four such thin disc-shaped",
                "samples were placed at angles of 0, 45, 90 and 135",
                "deg relative to the direction of the deuteron beam.",
                "The distances of the samples from the center of the",
                "T-Ti target were 3.0-5.0 cm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A coaxial HPGe detector (ORTEC, GEM-60P,",
                "diameter of 7.01 cm, length of 7.23 cm) with a",
                "relative efficiency of about 68% and an energy",
                "resolution of about 1.69 keV FWHM at 1332 keV for 60Co."
              ]
            }
          ],
