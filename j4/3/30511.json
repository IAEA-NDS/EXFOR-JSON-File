              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " End window gas flow proportional counter for",
                "low yield products."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "235U targets (2 micrograms) were irradiated together",
                "with the 232U targets. activities of the 235U fission",
                "products were measured in the same way as those of",
                "232U.",
                "The 235U fission product yields were taken from the",
                "compilation of meek+rider."
              ]
            }
