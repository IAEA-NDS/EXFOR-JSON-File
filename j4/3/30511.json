          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- The relative 'r-value' method was applied, starting",
                "from the respective 235U fission yields with 99Mo",
                "as internal standard."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "REC"
              ],
              "free_text": [
