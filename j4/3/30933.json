          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Study of the excitation functions of Al-27(n,a),",
                "Al-27(n,p) and Si-28(n,p) reactions."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "3HUNKOS"
              },
              "free_text": [
                "",
                "-Neutron generator at the Institute of Experimental",
                " Physics,Kossuth Univ.,Debrecen; using:",
                "-210 keV analysed d-beam",
                "-Liquid nitrogen-jet cooled TiT target of low-mass",
                " constructions.",
                "-5 mm diam of beam spot"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "3TAICHM"
              },
              "free_text": [
                "",
                "Measurements were repeated in the range of",
                "13.84-14.70 MeV by J25 neut.generator at Chiang Mai",
                "University,employing :",
                "-a nonanalysed d-beam of 150 keV",
                "-10 mm diam of beam spot",
                "-cold water cooled TiT target of low-mass constructions"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                "",
                "Several neutron emission angles have been used to vary",
                "the neutron energy between 13.5 and 14.8 MeV.",
                "The neutron energy as a function of emission angle has",
                "been determined(both for analysed and nonanalysed",
                "d-beams)using the ratio of the specific activities of",
                "Zr,Au,Ta and Nb foils"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Rectangular-shaped al,si samples of 15*10*0.5 mm-3."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
