              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " NaI(Tl) detector",
                " The energy-efficiency curve of the detectors was",
                " determined by standard g-sources."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
