          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental investigations of neutron cross-sections",
                "of tungsten isotope atomic nuclei: radioactive W-181",
                " (T 1/2 =121.2 days) and stable W-180"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
