          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three 252Cf sources-two with source strengths of about",
                "10E+5 fissions/min for measuring ternary fission events",
                "and one weaker source with about 900 fissions/min for",
                "measuring binary fission events."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Binary fission events were recorded by measuring",
                "fission fragments in coincidence with prompt",
                "gamma-rays emitted from these fragments.",
                "Simultaneously ternary fission events were recorded by",
                "measuring light charged particles (LCP) from fission in",
                "coincidence with prompt gamma-rays emitted from lcp",
                "accompanied fragments.",
                "The two strong sources were covered with 7 mg/cm3 thick",
                "aluminum foils to stop fission fragments and decay",
                "alphas,so that only lcp reach the detectors."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 30 cm3 detector for gamma-rays."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " Three semiconductor detectors, one for binary",
                "fission fragments, two for LCP, in coincidence mode",
                "with the Ge(Li) detector."
              ]
            }
          ],
