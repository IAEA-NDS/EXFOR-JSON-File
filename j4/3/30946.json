          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The assumed values were used for conversion of the",
                "measured values to independent fission yields.",
                "Compilers note: since the yields were obtained from",
                "relative activities of iodine fission product isotopes,",
                "all assumed values were used for the complete",
                "analysis of raw data."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "by commpiler: apparently was the independent yield of",
                "I-134 used to normalize the measured relative direct",
                "yields obtained by method 1). It was calculated from",
                "the fractional independent yield given by Wahl",
                " (ASSUM3) and the I-134 cumulative yield by Katcoff."
              ]
            }
