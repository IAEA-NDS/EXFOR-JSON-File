          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of independent yields of I131 and I133",
                "in thermal neutron fission of 235U by selective recoil",
                "labelling"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No information given, but the compiler assumes that the",
                "irradiations were done at the IRR-1 swimming pool type",
                "reactor at the Soreq Nuclear Research Center."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "RCHEM"
              ],
              "free_text": [
                " 2 methods were employed:",
                " 1) The apparent direct yields of I-133,I-134 and I-135",
                "    were obtained by selective labelling;",
                " 2) the respective cumulative yields by conventional",
                "    wet radiochemistry."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The amounts obtained by method 1) were expressed as",
                "fractions of those obtained by method 2), giving the",
                "apparent fractional independent yield. The real",
                "independent yields were obtained by extrapolation of",
                "the apparent fractional yields to zero time after",
                "irradiation."
              ]
            }
          ],
