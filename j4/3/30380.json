          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The same experimental set-up was used to measure the",
                " angular distribution of 32S(n,a)29Si using 14 MeV",
                " neutrons.",
                "No alpha particle was detected even with a thicker",
                " target and with shorter distance between detector and",
                " target (decreased up to 5 mm).",
                "An upper limit for the value of the total cross",
                " section for 32S(n,a0)29Si was estimated."
              ]
            }
          ],
