              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The iron film of 99.99% purity was tailored into",
                "circular samples with a diameter of 15 mm and a",
                "thickness of 0.1 mm. Each Iron target was sandwiched",
                "between natural niobium foil and zirconium foil with",
                "the same diameter."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A well calibrated GEM-60P coaxial high-purity",
                "germanium detector. The relative efficiency of this",
                "low background gamma-ray spectroscopy was 68% and the",
                "energy resolution was 1.69 keV FWHM at 1.33 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Three natural abundance iron samples",
                "sandwiched with zirconium and niobium foil were",
                "irradiated at three angles for 50 min. Due to the",
                "short half-lives of the product isotopes,",
                "measurements were started within 10 min after",
                "irradiation."
              ]
            }
          ],
