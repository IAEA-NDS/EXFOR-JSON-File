          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The independent isomeric yield ratio for Pd-111m,g",
                "was deduced from the fractional independent yield",
                " (F.I.Y) of Pd-111m, determined experimentally, and",
                "total F.I.Y. of Pd-111m,g evaluated employing the",
                "charge distribution parameters: most probable charge",
                "44.37 and width 0.72. the charge distribution systema-",
                "tics were based on observation in the neighbouring",
                "mass chain 112 (from private communication with",
                "author)."
              ]
            }
          ],
