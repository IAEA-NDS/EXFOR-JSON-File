          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The separation-time activities were determined",
                "from the observed activity profiles as functions of",
                "time using standard decay growth equations and were",
                "correlated to the fractional independent yields."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections have been made for precursors'",
                "contributions."
              ]
            }
          ],
