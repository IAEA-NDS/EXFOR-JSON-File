          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "RCHEM"
              ],
              "free_text": [
                " Fission products were collected using recoil",
                "catcher techniques. Subsequently the catcher foils",
                "were dissolved and, if necessary, the fission products",
                "were separated using standard radiochemical procedures",
                "within a few minutes from the end of the collection."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Electrodeposited Cf-252 source, ca. 5 micro-g"
              ]
            }
          ],
