                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "'R-value method'"
              ]
            },
            {
              "pointer": "2",
              "coded_information": {
                "code": "94-PU-239(N,F)42-MO-99,CUM,FY,,MXW",
                "code_unit": [
                  {
                    "unit": "94-PU-239(N,F)42-MO-99,CUM,FY,,MXW",
                    "field": {
                      "reaction": "94-PU-239(N,F)42-MO-99",
                      "target": "94-PU-239",
                      "projectile": "N",
                      "process": "F",
                      "product": "42-MO-99",
                      "quantity": "CUM,FY",
                      "data_type": null,
                      "general_quantity_modifier": "MXW",
                      "quantity_236": "CUM,FY"
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "'Modified compari-",
                "son method'."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "1",
              "coded_information": [
                "RVAL"
              ],
              "free_text": [
                " Using the following terminology",
                "   Y(f,p)=yield of product with mass p, from fissile",
                "          with mass f,  and",
                "   A(f,p)=activity (counts/sec) of product p from",
                "          fissile f,",
                "   the Mo-99 yield is obtained by the 'R-value' method",
                "   through the following formula",
                "        Y(239,99)= R * (Y(239,140)/Y(235,140)), with",
                "        R= (A(239,99)/(A(239,140))*",
                "           (A(235,140)/(A(235,99))"
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
                "Using the same terminology, plus  n(f) and sig(f)=",
                "   number of atoms and fission cross-section of fissile",
                "   f respectively, the Mo-99 yield is obtained by the",
                "   'Modified comparison' method through the following",
                "   formula",
                "        Y(239,99)=(A(239,99)/A(235,99))*(n(235)/n(239))",
                "                  *(sig(235)/sig(239)) * Y(235,99)"
              ]
            }
          ],
