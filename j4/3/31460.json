          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-T"
                ],
                "reaction": null
              },
              "free_text": [
                " The neutron energy was selected by the angular",
                "position of the sample with respect to the deuteron",
                "beam axis. The effective energy distributions of",
                "neutrons incident on the samples were calculated with",
                "the monte-carlo method. Deuteron energy spread,",
                "deuteron energy loss in the tritriated titanium",
                "layer, the dependence of neutron energy upon the",
                "emission angle, the angular distribution of emitted",
                "neutrons and the source to sample geometry were",
                "accounted for in these calculations. The neutron",
                "energies and their spread were evaluated from the",
                "calculated energy distributions."
              ]
            }
          ],
          "SAMPLE": [
            {
