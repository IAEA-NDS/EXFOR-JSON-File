          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "146-MeV alpha beam."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam energy spread, straggling in the target,and",
                "reaction kinematics limited the overall energy",
                "resolution to 350-650 keV depending on the scattering",
                "angle."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR"
              ],
              "free_text": [
                "Reaction products were detected and",
                "identified with cooled dE-E telescopes consisting of",
                "four 2-mm Si surface-barrier counters."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural oxygen gas was contained in a gas cell with",
                "2 mg/cm2 Havar windows at a pressure of about 200 Torr."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "At extreme forward angles, where the gas target",
                "presented some difficulties,supplementary normalization",
                "runs were performed with a 350 mu-g/cm2 Mylar target",
                "yielding an overall resolution of 220 keV."
              ]
            }
          ],
          "METHOD": [
