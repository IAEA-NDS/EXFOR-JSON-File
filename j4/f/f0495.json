          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target gas was chemically  pure natural oxygen.",
                "The gas cell was made of brass pieces welded and bolted",
                "together to form a cylinder 8 cm in diameter 2 cm",
                "useful height. The 320 degr. azimuthal opening was",
                "closed by a Havar window 5 micro thick."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "SIBAR",
                "SILI"
              ],
              "free_text": [
                " The detector system consisted of",
                "four silicon detectors 1 mm thick fixed on a turntable",
                "rotating around the target cell. At 69.5 Mev were used",
                "Si(li) detectors 3 mm thick.",
                "A fixed monitor detector was placed at 165 degr. with",
                "respect to the beam axis."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
