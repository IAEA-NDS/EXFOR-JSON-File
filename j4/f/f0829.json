          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute differential cross sections were obtained by",
                "normalising the counts in the elastic peak of the",
                "isotope of interest to the monitor counts and assuming",
