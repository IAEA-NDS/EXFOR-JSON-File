          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin foil targets were used. The target, at the axis",
                "of the magnetic particle spectrometer, was situated",
                "inside a target chamber, which was connected to the",
                "spectrometer vacuum box by a sliding seal, thus",
                "enabling reaction product spectra to be viewed at any",
                "angle to the incident proton beam from -10 degr. to",
                "+130 degr. Targets of 200 mu-g/cm2 self-supporting gold",
                "leaf were set at 0 degr. to the incident beam."
              ]
            }
