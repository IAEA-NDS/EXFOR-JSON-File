          "FLAG": [
            {
              "pointer": "",
              "coded_information": [
                1.0
              ],
              "free_text": [
                " The scatterer consisted of a thin metallic",
                "container filled with liquid hydrogen and placed in",
                "vacuum. The thickness of the hydrogen was 2.1 g/cm2.",
                "The measurements were carried out with the chamber",
                "first filled with liquid hydrogen and then empty."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                2.0
              ],
              "free_text": [
                " Polyethylene and graphite scatterers were used."
