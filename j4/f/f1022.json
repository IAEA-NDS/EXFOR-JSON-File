          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 58Fe target of 0.97 mg/cm2 thickness was used.",
                "Two contaminant isotopes were present in 58Fe target.",
                "The presence of the 57 isotope (2% abundance) had a",
                "negligible effect on the deuteron spectra. The only",
                "interfering group resulting from the 56Fe isotope (187%",
                "abundance) in the 58Fe target was the 57Co ground-state",
                "group."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Since the 110 keV resolution in the present",
                "experiment was not sufficient to allow identification",
                "and separation of 57Co ground state group in the 59Co",
                "data channel by channel correction in the data at",
                "each scattering angle was performed. The required",
                "correction to the data was never more than 10% of the",
                "cross section of either of the affected 59Co angular",
                "distributions."
              ]
            }
          ],
