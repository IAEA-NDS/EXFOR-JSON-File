          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI"
              ],
              "free_text": [
                "7Be nuclei were detected with a telescope",
                "consisting  of two silicon counters with the thickness",
                "of 50 mu-m and 1 mm, correspondingly.Energy resolution",
                "was determined mainly by energy spread in a beam and",
                "was 500-600 keV. An additional single silicon counter",
                "with the thickness of 1 mm included in a scheme of",
                "two-dimensional analysis: energy - time of light was",
                "used for measurements near 0 degr. Energy resolution",
                "in this case did exceed 400 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Lithium targets were prepared by vacuum",
                "evaporation of enriched 6Li and 7Li isotopes onto a",
                "thin (0.2 mu-m) organic film. Enrichment in 6Li and 7Li",
                "was 90.9 and 99.9%, correspondingly.  Targets with the",
                "thickness of 0.5-0.7 mg/cm2 were used."
              ]
            }
          ],
