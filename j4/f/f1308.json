              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "CSICR"
              ],
              "free_text": [
                " The detection was performed by two",
                "Si deltaE detectors 300 mu-m (32 horizontal striped",
                "detector with the size 64*64 mm) and 1000 mu-m (32",
