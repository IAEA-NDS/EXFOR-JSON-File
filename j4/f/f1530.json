          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Boron ion beam from 0.6 to 3.2 MeV that corresponded",
                "to the energy range of deuterons for the reaction in",
                "direct kinematics from 0.05 to 0.57 MeV. The charge",
                "state of the boron ions was 2+ in the energy range of",
                "1.0-3.2 MeV and 1+ for energies of 0.6 and 0.8 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Two scintillation detectors based on the",
                "150x100 mm NaI(Tl) crystals were used as gamma-ray",
                "detectors. Both detectors were located on the same",
                "axis with the target at angles of +-30 degr. relative",
                "to the beam axis."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
