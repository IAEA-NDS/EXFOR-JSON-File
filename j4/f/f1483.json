          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Maximum beam intensity was of 3 p mu-A."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets consisted of the enriched isotopes and were",
                "produced by electrodeposition on a 0.62-mg/cm2 Ti",
                "backing. Targets consisted of 12 sectors which were",
                "mounted on a periphery of a disk with a diameter of",
                "24 cm and 10-mm target layer opened for the beam and",
                "were rotated at 980 rpm. The total active surface",
                "area was 69 mg/cm2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The reaction products were analyzed by means",
                "of Dubna Gas Filled Recoil Separator (DGFRS-2)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " The focal detector of 48 mm in vertical and",
                "220 mm in horizontal directions consisted of two 48 x",
                "128-mm double-sided silicon strip detectors (DSSDs).",
                "They were mounted one by one in such a way that the",
                "front detector shielded part of the rear detector.",
                "Forty eight 1-mm front horizontal strips of both",
                "detectors were connected. The back strips were paired",
                "together to form 110 strips of 2 mm width. These",
                "detectors were surrounded by eight silicon single-",
                "sided 60 x 120-mm side detectors (SSSDs), each with",
                "eight strips, forming a box with a depth of 120 mm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Two multiwire proportional chambers were used",
                "to register the nuclei passing through the separator."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The decay properties of 286Fl and 287Fl, as",
                "well as their descendants, have been refined from 25",
                "and 69 new decay chains, respectively."
              ]
            }
          ],
          "ERR-ANALYS": [
