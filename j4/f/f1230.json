          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The layer of the TiD was deposited on a stainless-",
                "steel backing by magnetron sputtering. The thickness",
                "of the TiD layer was 1.5-2 mu-m. The target diameter",
                "was 97 mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Gamma rays with the energy 5.5 MeV from",
                "reaction were measured by eight NaI(Tl)-based",
                "detectors (100*100*400mm) placed around the target.",
                "The energy resolution measured with the Co-60 source",
                "and averaged over all eight detectors was 4.3% for",
                "the 2.5 MeV total absorption peak line."
              ]
            }
