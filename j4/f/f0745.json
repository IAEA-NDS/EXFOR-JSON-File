              "coded_information": [
                "TELES",
                "PS"
              ],
              "free_text": [
                " The reaction products were detected and",
                "identified using a dE-E counter telescope. It consisted",
                "of a 9 cm long ionization chamber filled with 75 torr",
                "P-10 gas backed by 45*45 mm2 Hamamatsu two dimensional",
                "position sensitive silicon detector (PSSD) of 450",
                "mu-m in thickness. The distance between the reaction",
                "target and PSSD was 10 cm."
              ]
            }
          ],
