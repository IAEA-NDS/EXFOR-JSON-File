            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A deuterated polyethylene [(CD2)n] foil of 0.97 mg/cm2",
                "in thickness was used as the secondary target to study",
                "the reaction, and a polyethylene [(CH2)n] foil was",
                "used to determine the background."
              ]
            }
          ],
