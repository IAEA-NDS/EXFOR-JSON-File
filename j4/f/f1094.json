          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Ta218O2 nuclear reaction analysis targets were",
                "prepared at a constant voltage of 100 V and current",
                "density of 10 mA/cm2 in pure water, ammonium citrate",
                "solutions (pH of 6.0-6.4), and enriched and natural",
                "biological solutions (pH of 6.4-8.0). The target",
                "chamber was evacuated to a pressure on the order of",
                "10**(-5) Torr. The tantalum film (enriched in O-18",
                "to 23.3%) of 0.12 mu-m thickness with 13 mu-m Kapton",
                "absorber placed in front of the detector at 150 degree",
                "detection angle was used."
              ]
            }
          ],
