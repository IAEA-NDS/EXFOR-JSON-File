          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two radiometers of fast neutrons RBN-A1 with",
                "spectrometric diamond detectors are used. The AD-1",
                "detector is manufactured from a single-crystal CVD",
                "plate with dimensions 4.5x4.5x0.5 mm3 (the contact",
                "area is 12.25 mm2). The B68 detector is manufactured",
                "from a single-crystal CVD film with dimensions",
                "4.0x4.0x0.09 mm3 (the contact area is 9 mm2)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The lithium target was a copper disk 144 mm in",
                "diameter and 8 mm in thickness. The thickness of the",
                "lithium layer was 1.79+-0.07 mu-m. The content of",
                "lithium-7 was assumed to be 92.5%."
              ]
            }
          ],
