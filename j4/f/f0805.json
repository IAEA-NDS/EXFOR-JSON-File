          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of 14C enriched to 74% and",
                "deposited on a thick gold backing. The effective",
                "surface density of 14C showed marked fluctuations over",
                "the target area as was checked by beta-decay",
                "measurements. After correcting the beta-counting rates",
                "for counter geometry, back-scattering and absorption,",
                "an average 14C thickness of 10.7 mu-g/cm2 +-25% was",
                "obtained for the exposed target area."
              ]
            }
          ],
          "STATUS": [
            {
