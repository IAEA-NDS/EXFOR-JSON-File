          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of argon gas enriched to 99.5% in",
                "36Ar and was enclosed in a small volume perspex cell of",
                "14 mm diam.The gas was separated from the main vacuum",
                "system by thin mylar (1.5 mg/cm2)entrance and exit",
                "windows. At a pressure of 1 atm. the windows could",
                "resist 6-8 hours continuous irradiation with a 14 MeV",
                "alpha-beam of around 1nA."
              ]
            }
