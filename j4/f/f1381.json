          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Method of ganged telescopes was used to separate p-d",
                "elastic and of p-p and p-n quasi-elastic scattering",
                "from the variety of meson-producing proton- deuteron",
                "interactions."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN"
              ],
              "free_text": [
                " Two telescopes were used to detect the",
                "charged particles, each telescope consisting of three",
                "scintillation counters (photomultiplier and toluene",
                "crystal). The resolution time of the coincidence",
                "counts from the scintillation counters in the",
                "telescope was 4 x 10**(-8) sec. The resolution time",
                "of the coincidence counts from the telescopes was",
                "8 x 10**(-8) sec."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Heavy and ordinary water in aluminium cylindrical",
                "containers were used as targets."
              ]
            }
          ],
