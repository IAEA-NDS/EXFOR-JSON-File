          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An additional selection of the elastic p-d scattering",
                "events and a decrease in the number of counts in the",
                "deuteron counting telescope were accomplished by",
                "placing behind the telescope a deuteron-absorbing",
                "copper filter together with a scintillation",
                "set for anti-coincidence."
              ]
            }
