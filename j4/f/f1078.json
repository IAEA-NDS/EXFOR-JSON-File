          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 13C target had a thickness of approximately 500",
                "mu-g/cm**2 and  was prepared by cracking 90% enriched",
                "acetylene on a tantalum  disc. The energy loss in the",
                "target amounted to 160 and 65 keV at the deuteron",
                "energies Ed=1.2 and 4.2 MeV, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " A 25.4 cm long and 25.4 cm diameter NaI(Tl)",
                "crystal spectrometer was  used. Its axis formed a 95",
                "degree angle with the deuteron beam. The NaI  crystal",
                "was collimated and surrounded by a 10 cm thick lead",
                "shield and a 40  cm paraffin layer to minimize",
                "back-ground radiation."
              ]
            }
          ],
          "METHOD": [
            {
