          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST",
                "SIBAR"
              ],
              "free_text": [
                " A solid-state detecting system with a",
                "resolution in energy of about 1% was used. The solid",
                "angle of detection was 1.2*10-3 sr. The detector used",
                "was of a gold-silicon surface barrier type properly",
                "biased to keep its sensitive region thick enough for",
                "the total stopping of the detected alpha group."
              ]
            }
          ],
