            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Composite angular distribution of the reaction",
                "9Be(d,p)10Be populating the doublet at 5.96 MeV",
                "excitation ( the J=1- and J=2 states)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
