          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The stack consisted of two different metal foils;",
                "natZn (99.9% purity), with isotopic composition of",
                "64Zn-(49.17%), 66Zn-(27.73%), 67Zn-(4.04%), 68Zn-",
                " (18.45%) and 70Zn-(0.61%) was used as the main",
                "target, and natCu foil (99.9% purity) composed of",
                "63Cu-(69.15%) and 65Cu-(30.85%) was used as monitor.",
                "Both zinc and copper foils were 10+-0.15 mu-m thick.",
                "Eleven sets of Cu-Zn-Cu foil sandwiches were stacked",
                "to form the target with an aluminum support",
                "containing a 10 mm aperture to collimate the deuteron",
                "beam and hold the foils in place."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " High-purity Canberra Ge detector (type GC1020,",
                "diameter 46.5 mm, length 32 mm, 10% relative efficiency",
                "and energy resolution of 2 keV for the 1.332 MeV",
                "gamma-line of the 60Co standard source) coupled with",
                "a multi-channel analyzer, was used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "GSPEC",
                "EDEG"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The target was irradiated for 20 minutes with",
                "a current below 20 nA."
              ]
            }
          ],
