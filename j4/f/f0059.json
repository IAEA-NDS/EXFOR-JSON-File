          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two samples, Sn2O (600 nm) and Ti2O (320 nm), both",
                "prepared by argon sputtering onto carbon substrates,",
                "were used for the 1H ion scattering cross section",
                "measurements of oxygen. The stoichiometry and thickness",
                "of each of the oxide layers were carefully determined",
                "before and after each H run by 4He backscattering from",
                "the same spots as for the H measurements."
              ]
            }
          ],
