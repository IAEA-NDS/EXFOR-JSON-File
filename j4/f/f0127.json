          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were beryllium foils. The foils were",
                "0.005 in. thick within a few percent over the foil",
                "area"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "ACTIV"
              ],
              "free_text": [
                " For the (d,t) reaction aluminum foils,",
                "stopping of the emergent tritons in aluminum foils",
                "by heating in a hydrogen atmosphere followed by",
                "an absolute determination of the number of tritons",
                "formed by a gas counting method.",
                "The reactions producing 10Be, the experimental",
                "method consisted of the bombardment of a thick",
                "beryllium target with a measured number of deuteron",
                "followed by the milling of the target into thin section",
                "and the measurement of the 10Be content of each of the",
                "thin sections."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The uncertainty in the cross section may be considered",
                "as a resultant of two components, that which changes",
                "from sample to sample and that which applies to all",
                "samples:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Systematic amounted to about 12% and was",
                "chiefly attributable to the counting efficiency",
                "uncertainty;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The nonsystematic errors amounted to",
                "approximately 2% in all samples."
              ]
            }
          ],
