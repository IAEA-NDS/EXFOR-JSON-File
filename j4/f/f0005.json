          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The layer of 6Li (thickness 10 mu-g/cm**2) was",
                "evaporated onto the thin backing of nickel and copper",
                " (total thickness 30 mu-g/cm**2) or aluminium (total",
                "thickness 20 mu-g/cm**2)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD",
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "3-LI-6(P,EL)3-LI-6,,DA,,RTH",
                  "code_unit": [
                    {
                      "unit": "3-LI-6(P,EL)3-LI-6,,DA,,RTH",
                      "field": {
                        "reaction": "3-LI-6(P,EL)3-LI-6",
                        "target": "3-LI-6",
                        "projectile": "P",
                        "process": "EL",
                        "product": "3-LI-6",
                        "quantity": ",DA,,RTH",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA,,RTH"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " -",
                "The target thickness was monitored by observing the",
                "Rutherford scattered protons from the target.",
                "The energy resolution of the monitoring detector",
                "was about 10 keV for 400 keV protons"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CCW"
                ],
                "institute": "2JPNTOH"
              },
              "free_text": [
                " For hydrogen ion beams below 400 keV.",
                "Energy resolution 5 keV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "DYNAM"
                ],
                "institute": "2JPNTOH"
              },
              "free_text": [
                " For ion beams above 400 keV.",
                "Energy resolution 2 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface-barrier detectors for",
                "detecting the reaction products,3He and 4He, were",
                "mounted on a turntable at distances of 8.8 cm and",
                "9.5 cm from the center of the scattering chamber.",
                "The third silicon surface-barrier detector was placed",
                "at a distance of 14 cm from the axis of the chamber at",
                "an angle of 150 degr. with respect to the proton beam.",
                "The energy resolution of the monitoring detector was",
                "about 10 keV for 400 keV protons."
              ]
            }
          ],
