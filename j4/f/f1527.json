          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam size of 5 mm x 5 mm with an intensity of 30 nA",
                "was used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " High-resolution magnetic spectrometer MAVR."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI"
              ],
              "free_text": [
                " Three three-layer semiconductor telescopes",
                "were used. The first two thin detectors deltaE1,",
                "deltaE2 were 50 and 300 mu-m thick, respectively. The",
                "third detector ER was 3.2-mm thick and measured the",
                "residual energy of the reaction products after they",
                "passed through the first two detectors."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting 5-mu-m thick 9Be foil was used. The",
                "target purity was higher than 99%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " Theoretical analysis of the contributions of the",
                "one-step and two-step neutron transfer mechanisms is",
                "performed using the distorted wave Born approximation",
                "method with the Fresco code."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The relative error in cross-section",
                "measurements was about 15%. This error is predominantly",
                "due to the following factors: statistical errors in",
                "counting events, errors in target thickness",
                "determination, inaccuracies in solid angle values, and",
                "errors in beam intensity measurements."
              ]
            }
          ],
