          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "56-BA-135",
                "field_identifier": "ENR",
                "value": 0.949
              },
              "free_text": [
                " Thin targets of 135BaCO3",
                " (1.9-4.5 mg/cm2) of isotopic composition 135Ba",
                " (135Ba-94.9%, 136Ba-2.31%, 138Ba-2.01%, 137Ba-0.59%,",
                "134Ba-0.19%) were deposited on an aluminum substrate",
                " (~30 mu-m) by sedimentation method from a suspension",
                "with acetone and collodium."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma spectrometer with an ORTEC GEM 35P4 high",
                "purity germanium was used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "EDEG"
              ],
              "free_text": [
                " Aluminum degraders were placed in a stack",
                "between 7 targets."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation time was 30 min. Each target of",
                "135Ba was measured 2-3 times within 2-3 days after the",
                "irradiation."
              ]
            }
          ],
