          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Alpha particle induced reactions on 151Eu:",
                "Possibility of production of 152Tb radioisotope for",
                "PET imaging"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
