          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mono-energetic proton beam."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy spread of proton beam entering the beam line is",
                "less than 1 keV. Magnetic quadrupole lenses were used",
                "to focus the beam onto the target. Beam spot sizes were",
                "less than 1 mm diameter."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "40 mu-g/cm2 self-supporting foil of 99.99% pure 12C",
                "separated isotope target was used. Target ladder could",
                "hold two carbon target. Target was placed at 45 degrees",
                "to the beam direction to provide good transmission of",
                "back-scattered protons and protons through the target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Thin annular NE102A plastic scintillator was",
                "mounted onto a Perspex light guide and a photo-",
                "multiplier arrangement."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Surface barrier (S.B.) detector was placed at",
                "90 degrees to the beam for normalization of the charge",
                "collection system and for measuring the proton back-",
                "scattering yield."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                "",
                " Gold target was used for calibration purposes.",
                "Carbon build-up on the target was monitored by",
                "regularly measuring the proton back-scattering yield."
              ]
            }
          ],
