                "BCINT"
              ],
              "free_text": [
                "",
                " The 7Be(p,gamma)8B cross section was measured by",
                "detecting the delayed alpha particles following the",
                "beta+ decay of 8B."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "MONIT",
                "reaction": {
                  "code": "3-LI-7(D,P)3-LI-8,,SIG",
                  "code_unit": [
                    {
                      "unit": "3-LI-7(D,P)3-LI-8,,SIG",
