              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The activity of radionuclide 103Ru was determined by",
                "the peak of total absorption of gamma quanta along",
                "the line Eg = 497.085 keV after irradiation and about",
                "7 days of exposure."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calculated corrections were introduced, including",
                "correction for the decay of the radionuclide during",
                "the measurement and correction for self-absorption of",
                "gamma quanta in targets."
              ]
            }
          ],
          "ERR-ANALYS": [
