          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets in the form of disks with a diameter of 8 mm",
                "and a thickness of 3 to 9 mm from ThO2 powder were",
                "packed into target devices with window of aluminum",
                "foil with a thickness of 40 microns at the entrance",
                "of the beam. The targets had a bulk density of",
                "2.15-3.6 g/cm3, determined by weighing. The targets",
                "were installed at a distance of 6-42 cm from the",
                "surface of the detector."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam current was ~0.15 mu-A, total charge of ~0.1 mu-Ah"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The measurements were carried out using an",
                "ORTEC GEM 35P4 gamma spectrometer with a detector made",
                "of ultrapure germanium with a volume ~100 cm3."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DECAY-DATA": [
            {
              "pointer": "",
              "coded_information": {
                "flag": null,
                "nuclide": "44-RU-103",
                "half-life": {
