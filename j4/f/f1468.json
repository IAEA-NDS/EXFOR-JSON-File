            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of cumulative yield of the 103Ru",
                "radionuclide for 4He-, 3He-, proton-and",
                "deuteron-induced reactions on ThO2 targets"
              ]
            }
          ],
          "AUTHOR": [
