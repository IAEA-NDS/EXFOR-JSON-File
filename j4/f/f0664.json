          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting target of 300 ug/cm2 was",
                "used. For E=15.2 MeV a 1100 ug/cm2 gold layer",
                "was evaporated onto the target to stop the recoiling",
                "nuclei."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " An annular detector was placed at 180 degrees",
                "to the beam. It had a thickness of 1.5 mm and was",
                "covered with a 20 microns Al foil to smear out alpha-",
                "particles groups."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " These 100 cm**3 detectors were placed at 0,30,",
                "45,60,and 75 degrees. At E=15.2 MeV the measurement",
                "was performed with detector at 0, 60 and 90 degrees",
                "with respect to the beam."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "In the measurement at E =15.2 MeV it was attempted to",
                "obtain information on mean lives of levels by using the",
                "Doppler-shift attenuation method."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 30 mu-A alpha-particle beam of 13,15 and 15.2 MeV",
