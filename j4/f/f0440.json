          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets consisted of enriched 10B evaporated onto",
                "formvar backings and were rotated continuously",
                "during bombardment."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                " Because of the high center-of-mass motion in",
                "this reaction, two runs with different magnetic field",
                "settings were required to record the groups of",
                "interest at all angles. The two runs were normalized",
                "to each other through the 90. degr. yield which was",
                "measured in each run."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A scale for absolute cross section was obtained by",
                "comparing the yield of the (d,n) reaction with the",
                "yield of elastically scattered deuterons. The results",
                "of Lee and Siemssen (not published) were used for the",
                "absolute cross section for elastic scattering at 4.0",
                "and 8.0 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " MIT multiple-gap spectrograph."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " Ilford type K0 nuclear-track plates to",
                "discriminate against deuteron and proton tracks."
              ]
            }
          ],
