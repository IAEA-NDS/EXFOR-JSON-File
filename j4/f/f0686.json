            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,JP/A,7,1977,1974",
                "code_unit": [
                  {
                    "unit": "J,JP/A,7,1977,1974",
                    "doi": "10.1088/0305-4470/7/16/002",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "JP/A",
                        "number": null,
                        "volume": "7",
                        "part": null,
                        "issue": null,
