          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High spin negative parity states in 35Cl"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "P.R.G.Lornie",
