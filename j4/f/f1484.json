              "pointer": "",
              "coded_information": null,
              "free_text": [
                "First experiment at the Super Heavy Element Factory:",
                "High cross section of 288Mc in the 243Am+48Ca",
                "reaction and identification of the new isotope 264Lr"
              ]
            }
