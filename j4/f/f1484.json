          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "95-AM-243",
                "field_identifier": "ENR",
                "value": 0.995
              },
              "free_text": [
                " The targets consisting of the",
                "enriched isotope 243Am were produced by",
                "layer-by-layer electrodeposition. Six target sectors",
                "were mounted on a disk with a diameter of 15 cm and",
                "rotated at 1500 rpm."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam intensity was gradually increased to",
                "1.2-1.3 p mu-A."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The reaction products were analyzed by means",
                "of Dubna Gas Filled Recoil Separator (DGFRS-2) ."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " The focal detector of 48 mm in vertical and",
                "220 mm in horizontal directions consisted of two",
                "double-sided strip detectors (DSSD) covering 48x128 mm2",
                "with 1 mm wide strips in such a way that the front",
                "detector shielded part of the rear detector. Each two",
                "of the 48 front horizontal strips of both detectors",
                "were connected. The back strips were paired together",
                "to form 110 strips of 2 mm width. The focal detector",
                "was surrounded by eight 60x120 mm2 side detectors, each",
                "with 8 strips, forming a box with a depth of 120 mm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Two multiwire proportional chambers were used",
                "to register the nuclei passing through the separator."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam energy was measured with a systematic",
                "uncertainty of 1 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total uncertainty is given."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Fifty-five new decay chains of 288Mc and six",
                "chains assigned to 289Mc were detected. A new",
                "spontaneously fissioning isotope 264Lr was identified."
              ]
            }
          ],
