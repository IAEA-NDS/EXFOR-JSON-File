              "pointer": "",
              "coded_information": null,
              "free_text": [
                "External proton beam was used. The pulse repetition",
                "rate was ~0.25 1/s and the duration was ~1 mu-s.",
                "The irradiation time for each sandwich ranged from 20",
                "to 90 min."
              ]
            }
          ],
