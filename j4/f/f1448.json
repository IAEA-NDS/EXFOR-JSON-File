              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Two gamma-spectrometers based on high-purity",
                "Ge detectors of the GC2518 type and the DSA1000 pulse",
                "analyzers were used in the measurements."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental samples of 206,207,208,natPb, and 209Bi",
                "were prepared by pressing the small pieces of lead",
                "with the corresponding compositions and bismuth",
                "powder. The samples were manufactured as sandwiches",
                " (targets + monitor foils). Total content of",
                "chemical impurities in the samples of 206,207,208,",
                "natPb, and 209Bi did not exceed 0.89, 110, 83, 190",
                "and 100 appm, respectively. The experimental monitor",
                "samples were cut out of 0.5 mm thick aluminum foil.",
                "The diameter of the foils are identical and equal to",
                "10.5 mm."
              ]
            }
          ],
