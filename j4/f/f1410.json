          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A pure Bi-209 target, having a natural isotopic",
                "composition, was prepared in the form of four stacked",
                "foils in the form of discs of diameter 1.4 cm each.",
                "The total weight of the target was 2.55 g and a total",
                "thickness of 600 mu-m. Each target was sandwiched by a",
                "pair of 50 mu-m Al foils with the same size. All foils",
                "were piled up together and aligned perpendicularly to",
                "the beam direction."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Four HpGe detectors with energy resolution",
                "0.23% at an energy of 1332 keV. The energy-dependent",
                "detection efficiency of the detectors was measured",
                "with standard calibration sources of Mn-54, Co-57,60,",
                "Cs-137, Eu-154, Eu-152, and Ba-133."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The irradiation time was 5.3 h at proton-beam",
                "intensity of 1.67 x 10**9 particles per second."
              ]
            }
          ],
