              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The reaction products were analyzed with a",
                "Buechner magnetic spectrometer. Angular distributions",
                "of inelastic deuteron groups corresponding to",
                "quadrupole and octupole excitations in the residual",
                "nucleus were measured using two PSD appropriately",
                "placed in the focal plane of the spectrometer."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PS",
                "SOLST"
              ],
              "free_text": [
                ""
              ]
