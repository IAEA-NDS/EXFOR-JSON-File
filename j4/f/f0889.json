              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The inelastic cross sections were normalized by",
                "measuring a known elastic scattering cross section at",
                "the same or nearly the same energy. Any effects of",
                "target non-uniformity and deterioration in the present",
                "measurements were eliminated by using the counts from",
                "a monitor detector."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting targets with the thickness of 1 mg/cm2",
                "were used."
