          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Charged particles were detected with a 700 mu-m Si",
                "annular surface barrier detector placed at 180 degr.",
                "with respect to the beam direction. The effective",
                "detection angle was 172.5+-4.0 degr. A monitor charged",
                "particle detector was placed at 125 degr. with respect",
                "to the beam direction for dead time and target pressure",
                "variation corrections."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Gamma rays coincident with protons at 180 degr.",
                "were detected with a 70cm3 Ge(Li)-detector at six",
                "different angles evenly spaced in cos**2(theta) between",
                " 0 and 90 degr."
              ]
            }
          ],
