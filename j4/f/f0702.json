          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Scattered protons were detected at four different",
                "angles ranging from 90 to 150 degr. The different",
                "proton spectra associated with a particular angle were",
                "summed after corrections for kinematic shift."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A surface barrier particle detector placed at",
                "an angle of 120 degr. with respect to the direction of",
                "the incident beam was used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Coincident gamma rays were detected with a 70",
                "cm3 Ge(Li) detector placed at 90 degr. with respect to",
                "the average direction of motion of recoiling residual",
                "nuclei."
              ]
            }
          ],
          "SAMPLE": [
