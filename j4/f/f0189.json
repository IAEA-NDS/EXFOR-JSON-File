          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 11B targets were vacuum evaporated by electron",
                "bombardment of a 2g boron pellet. The boron thus served",
                "as its own boat and hence there were no heavy",
                "constituents present on the targets. The boron was",
                "evaporated onto glass slides which had been previously",
                "coated with NaCl. The foils were then floated off and",
                "picked up as self-supporting foils. Boron targets in a",
                "range from 20 to 75 mu-g/cm**2 were prepared."
              ]
            }
          ],
