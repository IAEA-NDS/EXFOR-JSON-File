          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target of enriched 98% 28 Si was prepared by",
                "evaporation in vacuum. The density is 15 - 20",
                "mu-g/cm**2. The rotative target allows to avoid one",
                "side heating. The target is placed on a copper stand."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " It is a block of NaI. The size is 12.5 cm x",
                "12.5 cm. One detector is fixed in vertical plane at 90",
                "degrees angle to the beam direction and at 14 cm",
                "distance from the target. Another detector is mobile",
                "in horizontal plane. This detector is surrounded by a",
                "lead ring of 5 cm thickness."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " The volume of detector is 80 cm**3. The",
                "resolution of detector is 4 - 5 keV for radiation of",
                "60Co 1.17 - 1.33 MeV energies."
              ]
            }
          ],
