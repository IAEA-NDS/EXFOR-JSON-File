                        "product": "4-BE-7",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "An absolute cross section for the Be9(p,n)B9 reaction",
                "was determined by comparing the yield from a weighed",
                "beryllium target with that from a weighed lithium",
                "target at bombarding energies such that the neutrons",
                "from both the Be9(p,n) and Li7(p,n) reactions had an",
                "energy of 0.4 MeV; the cross section for the",
                "Li7(p,n)Be7 reaction measured by Taschek (see",
                "MONIT-REF) was then used."
              ]
            }
          ],
