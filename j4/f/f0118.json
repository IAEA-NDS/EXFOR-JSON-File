          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was beryllium metal evaporated on to a",
                "tungsten backing and was approximately 5-keV thick to",
                "2-MeV protons."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "3-LI-7(P,N)4-BE-7,,SIG",
                  "code_unit": [
                    {
                      "unit": "3-LI-7(P,N)4-BE-7,,SIG",
                      "field": {
                        "reaction": "3-LI-7(P,N)4-BE-7",
                        "target": "3-LI-7",
                        "projectile": "P",
