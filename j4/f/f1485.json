          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "95-AM-243",
                "field_identifier": "ENR",
                "value": 0.995
              },
              "free_text": [
                " The target consisted of the",
                "enriched isotope 243Am and was produced by",
                "electrodeposition and had an average Am layer",
                "thickness of 0.36 mg/cm2. Six target sectors were",
                "mounted on a disk with a diameter of 15 cm and",
                "rotated with a frequency of 1500 or 1700 rpm."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The maximum beam intensity was 1.2-1.3 p mu-A."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The reaction products were analyzed by means",
                "of Dubna Gas Filled Recoil Separator (DGFRS-2)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " The focal detector consisted of 48 1-mm",
                "horizontal strips and 110 2-mm vertical strips. It is",
                "assembled out of two 48x128-mm2 double-sided strip",
                "detectors, mounted in such a way that the front",
                "detector shields a part of the rear detector. The 48",
                "front horizontal strips of both detectors were",
                "connected. The back strips were paired together to",
                "form 110 strips of 2 mm width. The focal detector was",
                "surrounded by eight 60x120-mm2 side detectors, each",
                "with eight strips, forming a box with a depth of 120 mm"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Two mmultiwire proportional chambers were used",
                "to register nuclei arriving from the separator."
              ]
            }
          ],
          "ERR-ANALYS": [
