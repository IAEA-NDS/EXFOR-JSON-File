          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Errors are attributed to counting statistics",
                "decay-curve analysis, and to uncertainties in decay",
                "parameters, counting efficiencies, Faraday-cup",
                "readings, and target composition and thickness."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy intervals in Table II correspond to the",
                "kinetic energies of the 3He ions that enter and leave",
                "a particular target foil; these two energies reflect",
                "the degradation of the 3He energy, caused successively",
                "by the first recoil-catcher foil, and by the target",
                "foil itself. To calculate these energy intervals,",
                "range-energy curves were constructed for the different",
                "targets from existing range-energy data for hydrogen,",
                "beryllium, carbon, nitrogen, oxygen, and fluorine."
              ]
            }
          ],
