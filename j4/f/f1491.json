              "coded_information": null,
              "free_text": [
                "Targets in the form of disks 8 mm in diameter made",
                "from ThO2 powder were packed in target devices with",
                "40 mu-m thick aluminum foil windows at the beam",
                "entrance. The targets had bulk density of 2.2 g/cm3",
                "determined by weighing."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
