          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A beam of singly charged helium ions collimated to a",
                "circular area of 1 mm diameter entered a scattering",
                "chamber through a differential pumping system."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " A movable proportional counter filled with",
                "nitrogen to 7 cm Hg subtended an angle of about two",
                "degrees at the scattering volume and was accurately at",
                "angles up to 147.5 degr. in the laboratory. A very thin",
                "window of Formvar some 6-8 mu-g/cm2 thick allowed us",
                "to efficiently detect alpha particles down to about",
                "40 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gas target was used.  The scattering gas pressure",
                "was kept around 3 mm Hg. The effective target thickness",
                "was of the order of 400 eV and was therefore completely",
                "negligible."
              ]
            }
          ],
