              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "74-W-186",
                "field_identifier": "ENR",
                "value": 0.997
              },
              "free_text": [
                " Targets in the form of 8 mm in",
                "diameter and 1.2 mm thick discs made of the metallic",
                "powder of 186W with enrichment 99.7% were packed in",
                "target setups with 0.1 mm thick aluminum windows at",
                "beam ingress. The bulk density of the targets was",
                "equal to 6.385-6.169 g/cm3."
              ]
            }
          ],
