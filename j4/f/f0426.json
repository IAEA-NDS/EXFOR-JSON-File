          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were prepared by vacuum evaporation of B metal",
                " (96% 10B) onto thick tantalum and tungsten backings.",
                "Most of the measurements were made with target",
                "estimated to be about 350 mu-g/cm2 thick."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements made with a thinner target(150 ug/cm2)",
                "from about 2.1 to 2.7 MeV showed a somewhat different",
                "shape for the 10B (p,alpha+gamma) reaction from that",
                "displayed in fig.2 indicating incomplete resolution",
                "for the resonances in this region."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 7.6 x 7.6 cm NaI crystal."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Statistical errors are less than size of the points"
