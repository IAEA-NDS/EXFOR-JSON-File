          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Two hyperpure germanium and two germanium-",
                "lithium detectors are used,all with an active volume",
                "of about 100 cm**3 and a resolution of 2.0 keV at",
                "Eg=1.33 MeV. One germanium detector is used as part of",
                "a Compton-suppression spectrometer (LACSS), which",
                "reduced the Compton continuum by a factor of 10 to 20.",
                "A moveable detector is placed at D=4 cm and at angle",
                "equal 0,30,45,60 and 90 degrees and a monitor detector",
                "at D=10 cm and at a fixed backward angle."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets are produced by evaporating about",
                "40 mu-g/cm**2 natural calcium onto 0.3 mm thick",
                "tantalum backings,which are baked out before depositing",
                "the target material.This target thickness corresponds",
                "to an energy loss of about 10 keV for protons at",
                "Ep=1850 keV."
              ]
            }
          ],
