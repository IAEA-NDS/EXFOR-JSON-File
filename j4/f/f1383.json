          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The irradiation was carried out on piles consisting",
                "of 10-15 nickel foils on which thin gold layers were",
                "deposited. The piles were fastened at the internal",
                "test chamber of the cyclotron in front of the current",
                "collector. The nickel foils were 1.5-2.0 microns",
                "thick, the gold layer on the foils comprised",
                "0.1-0.3 mg/cm2."
              ]
            }
