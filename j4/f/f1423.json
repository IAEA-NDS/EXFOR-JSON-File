          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Fission fragments were registered with a",
                "surface-barrier semiconductor detector of 25 mm2",
                "working area, made of n-type silicon having",
                "resistivity of the order 150 Omega-cm; the amplitude",
                "resolution of the detector was 2% in recording the",
                "spectrum of Am-241 alpha particles. Measurements were",
                "performed with a small (4 V) bias on the detector,",
                "so that only the fragment ranges would fit within the",
                "registering layer and scattered deuterons would lose",
                "a minimal fraction of their energy."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "PHD"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target backing was aluminum foil 5 mu-m thick. A",
                "uniform layer of fissionable material was deposited",
                "by vacuum evaporation of the low-melting compounds",
                "UF4 and ThF4."
              ]
            }
          ],
