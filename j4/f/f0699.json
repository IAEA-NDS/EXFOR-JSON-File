          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polarization measurement of fast neutrons from the",
                "9Be(a,n)12C and the 13C(a,n)16O reaction using a",
                "high-pressure 4He-polarimeter in a new design."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "W.Weiss",
                "W.Grum",
                "J.W.Hammer",
                "M.Koch",
                "G.Schreder"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2GERIFS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/A,292,359,1990",
                "code_unit": [
                  {
                    "unit": "J,NIM/A,292,359,1990",
                    "doi": "10.1016/0168-9002(90)90392-J",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NIM/A",
                        "number": null,
                        "volume": "292",
                        "part": null,
                        "issue": null,
                        "page": "359"
                      },
                      "date": 1990
                    }
