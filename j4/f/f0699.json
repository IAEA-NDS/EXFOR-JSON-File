            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "DYNAM"
                ],
                "institute": null
              },
              "free_text": [
                " Stuttgart neutron scattering facility SCORPION."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Four shielded neutron detectors (NE 213) were",
                "positioned and the range of the accessible reaction",
                "angles was between 21 and 124 degr. with a symmetric",
                "position of left and right detector. The minimum",
                "angular distance between two detectors was limited by",
                "the extension of the detector shielding to 42 degr.",
                "Two detectors were at a forward scattering angle",
                "of 50 degr and two detectors under a backscattering",
                "angle of 124 degr."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "All measurements were performed using high-pressure",
                " 4He polarimeters."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  Definition error",
                "Energetic resolution varied between 12% (13C, 5.4 MeV)",
                "and 10% (9Be, 8.5 MeV).",
                "The errors of the present experiment could be kept",
                "small because of the use of the SCORPION facility",
                "favouring small systematic errors and the fourfold",
                "redundant measurement."
              ]
            }
          ],
