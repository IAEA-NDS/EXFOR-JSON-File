          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " GABRIELA detector array was used to detect the",
                "residues and their subsequent alpha decay or fission",
                "as well as gamma rays, X rays and conversion",
                "electrons. The evaporation residues pass through a",
                "time of flight detector and are then implanted into a",
                "10x10 cm2 500 mu-m thick double-sided silicon strip",
                "detector. Particles escaping from the DSSD are",
                "detected in eight 6x5 cm2 DSSDs with 16 strips on each",
                "side."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                "The Ge array consists of a large clover detector",
                "installed just behind the DSSD and 4 coaxial detectors",
                "forming a cross around the DSSD."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "OLMS"
              ],
              "free_text": [
                " The separator for heavy elements spectroscopy",
                " (SHELS) was used to select the evaporation residues."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "ASPEC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Two fission activities with half-lives of",
                "52.8(4.4) mu-sec and 9.9(1.2) ms were measured for",
                "253Rf. A third state, at much higher excitation",
                "energy, was also observed 0.66 (+0.40/-0.18) ms."
              ]
            }
          ],
