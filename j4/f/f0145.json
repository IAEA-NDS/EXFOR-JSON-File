          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The polarization of protons from the 2H(d,p)3H reaction",
                "for deutron energies below 1 MeV."
              ]
            }
          ],
          "AUTHOR": [
