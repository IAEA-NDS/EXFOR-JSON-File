              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 5*5in. crystal,surrounded by an anticoincidence",
                "shield consisting of a hollow cylinder of plastic",
                "scintillator, 10-in. o.d., 5.5-IN. i.d., and 8-in.",
                "long, with four symmetrically mounted DuMont 6292",
                "photomultiplier tubes."
              ]
            }
