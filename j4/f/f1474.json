          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "74-W-186",
                "field_identifier": "ENR",
                "value": 0.9996
              },
              "free_text": [
                " A layer of metallic tungsten",
                "powder with 17-25 mg/cm2 thickness deposited onto",
                "high purity aluminum backings with 40 mu-m thickness",
                "was used. Diameter of the layer was 10 mm. The",
                "targets were produced by sedimentation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " ORTEC GEM 35P4 series HPGe detector was used.",
                "The dead time did not exceed 5%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "STTA",
                "EDEG",
                "GSPEC"
              ],
              "free_text": [
                " Aluminum foils (40 and 50 mu-m",
                "thick) were placed between the 12 targets."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation time was 1 hr."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Average beam current was 0.1 mu-A."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " The results were compared to the data from the",
                "TENDL-2019 library."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The uncertainties of the energy were calculated using",
                "the SRIM software based on the spread in the initial",
                "beam energy of + - 1 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total experimental uncertainty was 12-25% with",
                "confidence interval 68%. Components of the uncertainty:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 8.0,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " uncertainty in determining the",
                "efficiency of the detector;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": 8.0,
                "maximum_value": 20.0,
                "correlation_property": null
              },
              "free_text": [
                " uncertainty in determining the areas",
                "of the peaks of the total absorption of gamma quanta;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": 4.0,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " uncertainty in determining the number",
                "of 186W nuclei in the target;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-4",
                "minimum_value": 3.0,
                "maximum_value": 9.0,
                "correlation_property": null
              },
              "free_text": [
