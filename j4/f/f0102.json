          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN"
              ],
              "free_text": [
                " The detector was a 3/4-inch. by a 20-mil",
                "CsI(Th) crystal mounted on a small glass light pipe.",
                "This in turn was coupled to an RCA6342A photomultiplier",
                "tube using silicone oil as the optical coupling.",
                "RCA 6810A photomultiplier tubes were employed to detect",
                "the rare gas scintillations."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A proton recoil spectrometer utilizing a xenon gaz",
                "scintillation trigger was developed to study this",
                "problem. This spectrometer operated with a resolution",
                "of the order 7%  at the neutron energies involved in",
                "this reaction."
              ]
            }
