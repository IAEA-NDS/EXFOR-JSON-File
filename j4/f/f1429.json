          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The primary beam of 15N nuclei with an energy of 49.7",
                "MeV/A was focused on a producing 2-mm thick 9Be",
                "target. The secondary beam of fragmentation products",
                "was formed and purified by the magnetic system of the",
                "fragment separator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target (a dE Si-PIN detector, 243-mu-m thick) was",
                "located in a thin-walled (2-mm thick) vacuum-tight",
                "cylindrical stainless steel chamber."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI"
              ],
              "free_text": [
                " A set of scintillation detectors was used:",
                "scintillation detector AC1; position sensitive 16X-",
                "16Y Si detector dE (300-mu-m thick); start dE0 Si",
                "detector (380-mu-m thick); scintillation detector AC2;",
                "target dE Si-PIN detector; six CsI(Tl) scintillation",
                "detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                ""
              ]
            }
          ],
