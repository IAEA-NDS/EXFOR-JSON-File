              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma-ray spectrometer SEG-1KP-IPTP 12. HPGe",
                "gamma-ray spectrometer was used for the energy range",
                "from 0.65 to 2.064 MeV. It was located at a distance",
                "of 4.83 m and at an angle of 15 degrees while the",
                "energy was below 1.882 MeV. For higher energies it",
                "was moved backward by 1.6 m and its sensitive volume",
                "was covered with cadmium."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " 51 mm x 51 mm NaI(Tl) scintillator. The NaI",
                "spectrometer was used for the energy range from 1.875",
                "to 2.225 MeV at a constant distance of 4.83 m."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were prepared by vacuum evaporation of",
                "lithium. The percentage of lithium-7 in natural",
                "lithium was 92.5%."
              ]
            }
          ],
