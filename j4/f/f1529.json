          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The average intensity of the 6He beam was 10**4",
                "particles per second with an energy of 156+-9 MeV and",
                "the beam spot at the target was about 20 mm in",
                "diameter."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Primary 15N beam was focused onto a target of natural",
                "beryllium with the 2 mm thickness. The secondary beam",
                "of 6He ions was directed onto the deuterated polythene",
                " (CD2) targets with the thicknesses of 100 and 200 mu-m"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "CSICR"
              ],
              "free_text": [
                " The reaction products were detected",
                "in two identical telescopes, each consisting of a 1 mm",
                "thick double-sided silicon detector (DSSD) and a",
                "cesium-iodide scintillator [CsI(Tl)]. The telescopes",
                "were placed on the left and right sides of the beam",
                "axis. The DSSD had 32 strips on the horizontal axis",
                "and 16 strips on the vertical axis. The CsI(Tl)",
                "detectors were thick enough to stop the reaction",
                "products and measure their remaining energy."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Beam tracking was performed with two multiwire",
                "proportional chambers located 27 and 82 cm upstream",
                "of the secondary target."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "TOF"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The elastic scattering events were identified",
                "by simultaneous registration of a 6He in the right",
                "telescope and a proton or deuteron in the left",
                "telescope."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Effective potentials for the p+6He and d+6He systems",
                "were derived from optical model analyses of the data."
              ]
            }
          ],
