          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ISOCY"
                ],
                "institute": "4RUSKUR"
              },
              "free_text": [
                " U-150 isochronous cyclotron"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Dysprosium oxide targets of natural isotopic",
                "composition (natDy2O3, 99.8% purity, + 1-1.5%",
                "dinitrocellulose, 14 layers) were used. Dy2O3 layer",
                "thickness was 5-9 mg/cm2 with 10% uncertainty, spot",
                "diameter 20 mm. The surface of each target was",
                "additionally covered with 8.3 mu-m aluminum foil to",
                "prevent them from sticking together during irradiation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma spectrometer with an ORTEC GEM 35P4 high",
                "purity germanium detector with energy resolution 850 eV",
                "for the 122 keV line and 1.8 keV for the 1330 keV",
                "line was used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation time was 15 min at a beam",
                "current of 235 nA. Uncertainty of beam current was 10%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "EDEG",
                "GSPEC"
              ],
              "free_text": [
                " Natural Al foils (30 mu-m) were used",
                "as degraders."
              ]
            }
          ],
