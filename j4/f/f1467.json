          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "New experimental data on natDy(a,x) reactions: Details",
                "on the production of the medically relevant 161Er,",
                "160Er, and 161Ho Auger emitters"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "E.S.Kormazeva",
                "I.A.Khomenko",
                "V.N.Unezhev",
