          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The boron target was a thin layer of boron deposited",
                "on a copper disk with the diameter of 50 mm and the",
                "thickness of 4 mm. Boron layer thickness was assumed",
                "equal to (9.0+-0.9)*10**18 atoms/cm2 (0.7+-0.07 mu-m",
                "boron crystalline density). The content of 11B isotope",
                "was considered equal to 80.2%."
              ]
