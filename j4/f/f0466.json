          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute cross-section scale was obtained by",
                "measuring spectra for the reaction 11B(p,gamma) 12C,",
                "taken with the same target and the same geometry as",
                "were used for the 11B(3He,gamma) 14N experiment. The",
                "11B(p,gamma) spectra were taken at Ep = 1.42 MeV, at",
                "the peak of the broad (Gcm = 1.15 MeV),",
                "Eexc = 17.26 MeV, resonance. The absolute cross-section",
                "measurements of Segel etc.(see REL-REF) were used for",
                "an absolute normalisation."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets, of thickness approximately 25 ug/cm2,",
                "were obtained by electrongun evaporation of",
                "isotopically enriched (>99%) 11B onto thick copper",
                "or tungsten backings."
              ]
            }
          ],
