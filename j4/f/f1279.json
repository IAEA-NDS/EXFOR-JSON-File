          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " 235U and 238U fission chambers. The 235U",
                "chamber with 235U was covered by 10B and Cd. The 235U",
                "fission chamber efficiency was calibrated by",
                "7Li(p,n)7Be neutron yields at various angles, and the",
                "total neutron yields was estimated by measuring 7Be",
                "activity measured by a NaI(Tl) spectrometer. The 238U",
                "fission chamber efficiency was calibrated relative to",
                "the 235U chamber by using 9Be(d,n)10Be neutrons."
              ]
            }
          ],
