          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A cylindrical steel target chamber was used at the",
                "cyclotron, the wall thickness in front of gamma-ray",
                "detectors being only 0.7 mm. A self-supporting 50Ti",
                "metallic target of approximately 1.5 mg/cm**2 and 75%",
                "enrichment was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Home-made Ge(Li)detectors had active volumes",
                "between 25 and 38 cm**3 and energy resolution between",
                "3.5 and 5 keV at 1.33 MeV. For the angular",
                "distribution measurements two detectors were used:",
                "movable detector rotating around the target chamber at",
                "12 cm from its axis and a fixed detector at 90 degr. to",
                "the beam direction."
              ]
            }
          ],
