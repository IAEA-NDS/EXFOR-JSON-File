              "free_text": [
                " Multilayers stack was used as a",
                "target. All tungsten layers were in circle form with",
                "12 mm diameter. The main target of the stacked-foil",
                "are high purity tungsten foils (>99.99 % purity, 20",
                "mu-m thickness). In addition, the stack includes",
                "copper foils (99.98 % purity, 20 mu-m thickness) of",
                "natural composition (63Cu - 69.17 %, 65Cu - 30.83 %)",
                "and aluminum (99.0 % purity, 15 mu-m thickness) ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector from ORTEC completed by the",
                "DSPEC-LF Digital Gamma-Ray Spectrometer (analyzer)",
                "was used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The assembled target was irradiated by 18 MeV",
                "proton beam for 10 min with 1 mu-A beam current."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "EDEG"
              ],
              "free_text": [
                " The copper and aluminum foils were used",
                "to monitor the beam intensity and to degrade the beam",
                "energy."
              ]
            }
