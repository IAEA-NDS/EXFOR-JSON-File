                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polyethylene target with 10 mu-m thickness and carbon",
                "target with 8 mu-m thickness were used."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Statistical error includes the uncertainties",
                "in the number of elastic deuteron - proton events and",
                "the number of PP monitoring events."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The systematic uncertainty is determined by",
                "the procedure of CH2 - C subtraction, the Jacobian",
                "determinant for the transition, the solid angle of",
                "the deuteron detector and the normalization",
                "coefficient."
              ]
            }
