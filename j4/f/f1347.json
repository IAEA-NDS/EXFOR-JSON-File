          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Elastically scattered deuterons and protons",
                "were recorded by two pairs of detectors placed",
                "symmetrically with respect to the ion-guide axis. In",
                "addition to these detectors, two monitoring counters",
                "were used in order to detect products of quasielastic",
                "pp scattering (PP detectors). The DP counters were",
                "rotated over the angular range of Theta-lab =19 - 50",
                "degrees. Each counter was a structure formed by a",
                "scintillation detector and a Hamamatsu H7416MOD",
                "photomultiplier tube that were connected by a light",
                "guide. The dimensions of the scintillators in the P,",
                "D, and PP counters were 20x60x20, 10x40x24, and",
                "50x50x10 mm, respectively."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
