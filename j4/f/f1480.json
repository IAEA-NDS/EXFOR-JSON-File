              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": 5.0,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " the errors in determination of peak",
                "areas of the total absorption of gamma quanta in the",
                "instrument spectra;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
