          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of the yield of protactinium",
                "radioisotopes 230,232,233Pa on irradiation of ThO2",
                "targets by 1,2H and 3,4He nuclei"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.A.Smirnov",
                "M.N.German",
