          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets in the form of disks 8 mm in diameter and 3",
                "to 9 mm thick made from ThO2 powder were packed in",
                "target devices with 40 mu-m thick aluminum foil",
                "windows at the beam entrance. The targets had bulk",
                "density of 2.15-2.6 g/cm3 determined by weighing.",
                "During measurements, the targets were arranged at",
                "distances 6-40 cm above the detector surface."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Beam current was ~0.15 mu-A, total charge of ~0.3 mu-Ah"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The measurements were performed using a gamma",
                "spectrometer with an ultrapure germanium detector",
                "ORTEC. The dead time during measurements did not",
                "exceed 5%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The activity of each radioisotope 230,232,233Pa",
                "was measured over approximately three half-lives."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Computed corrections were made for the decay of a",
                "radionuclide over the measurement time and",
                "self-absorption of gamma-rays in the targets."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " Comparison with the computed yield using the",
                "nuclear data from the TENDL-2019 library."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors of the measured values include:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 7.0,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " the error in determining the detector",
