          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " The experimental cross sections were compared",
                "with the data from TENDL-2021 library."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties in the experimental cross",
                "sections were between 15% and 36% at a fiducial",
                "probability of 68%. These uncertainties received",
                "contributions from the error in determining the",
                "detector efficiency, the error in determining the areas",
                "under the peaks of total proton absorption in the",
                "spectrum, and the error in the quantum yields used to",
                "determine activities. The uncertainties in the energy",
                "of 4He were determined using SRIM software from the",
                "scatter of + -1 MeV in the initial energy of 4He,",
                "which is specified by the parameters of the cyclotron."
              ]
            }
          ],
