                "BCINT"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Seven foils were combined into one single",
                "stack of targets."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDEG"
              ],
              "free_text": [
                " Aluminum foils with a different thickness were",
                "placed between thorium targets, using as beam",
                "monitors or degraders."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Average beam current was 0.1 mu-A. Irradiation was",
                "carried out until a total charge of 0.3 mu-A h was",
                "reached."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activity was measured on gamma spectrometer",
                "with ultrapure germanium detector ORTEC GEM."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mechanically stable thorium oxide layers 12 to 15",
                "mg/cm2 thick were used. Thorium oxide was deposited",
                "onto aluminum substrates by the sedimentation method.",
                "The diameter of the deposited spot was 20 mm."
              ]
            }
          ],
