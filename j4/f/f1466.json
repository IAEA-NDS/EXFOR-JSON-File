          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Uncertainties in the experimental values of",
                "the cross sections were between 13 and 25 % at a",
                "fiducial probability of 68 % and include:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": 8.0,
                "maximum_value": 12.0,
                "correlation_property": null
              },
              "free_text": [
                " the error in determining the detector",
                "efficiency;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": 10.0,
                "maximum_value": 15.0,
                "correlation_property": null
              },
              "free_text": [
                " the error in determining the areas",
                "under the peaks of total photon absorption in the",
                "spectrum;"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": 3.0,
                "maximum_value": 18.0,
                "correlation_property": null
              },
              "free_text": [
                " the error in the quantum yields used",
                "to determine the activities."
              ]
            }
          ],
