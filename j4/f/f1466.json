          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of cross sections for the reactions",
                "232Th(3He,p4n)230Pa, 232Th(3He,p2n)232Pa, and",
                "232Th(3He,2p+pn)233Pa induced by the irradiation of",
                "a ThO2 target with 3He nuclei"
              ]
            }
          ],
