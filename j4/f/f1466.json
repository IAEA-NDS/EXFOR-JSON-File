          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The activity of each protoactinium",
                "radionuclide was measured several times during three",
                "half-life periods and determined on the basis of the",
                "peaks of total photon absorption."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Eleven foils were combined into one single",
                "stack of targets."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDEG"
              ],
              "free_text": [
                " Aluminum foils with a thickness from 9 to 30",
                "mu-m were placed between thorium targets, using as",
                "beam monitors or degraders."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Average beam current was 0.1 mu-A. Irradiation was",
                "carried out until a total charge of 0.3 mu-A h was",
                "reached."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The measurements were performed on gamma",
                "spectrometer with ultrapure-germanium detector ORTEC.",
                "The distance from the target to the detector during",
                "measurements was from 6 to 40 cm, depending on the",
                "radiation intensity."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of thorium oxide with the thickness from 7 to",
                "11 mg/cm2 and spot diameter of 20 mm deposited by",
                "means of sedimentation on aluminum foils were used."
              ]
            }
          ],
          "REL-REF": [
