          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Investigation of the gamma radiation produced by",
                "irradiating 10B with protons in the energy range",
                "0.7 to 3.0 MeV"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.E.Hunt",
                "R.A.Pope",
                "W.W.Evans"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2UK ALD"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR,106,1012,1957",
                "code_unit": [
                  {
                    "unit": "J,PR,106,1012,1957",
                    "doi": "10.1103/PhysRev.106.1012",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR",
                        "number": null,
                        "volume": "106",
                        "part": null,
                        "issue": null,
                        "page": "1012"
                      },
                      "date": 1957
                    }
                  }
                ],
