              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2UK ALD"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets consisted of 10B of the least 99% purity of",
                "thickness 10 ug/cm2 and 100 ug/cm2, separated by mass",
                "spectrographic deposition on copper or tungsten",
                "backings"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-section measurements were made by comparing the",
                "yield of the 9.7 MeV gamma ray from the 10B(p,gamma)11C",
                "reaction with that of the 6.14 MeV gamma ray from",
                "the 19F(p,alpha+gamma)16O reaction at the 1.348 MeV",
                "resonance using the same geometry. This was taken as",
                "89 mb from the work of Chao et al. (see Subent 003)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The gamma-ray spectrometer consisted of a 4-in.",
                "diam. thallium-activated sodium iodide crystal 4 in.",
                "mounted with 0.5-in. long Perspex light pipe."
              ]
            }
          ],
