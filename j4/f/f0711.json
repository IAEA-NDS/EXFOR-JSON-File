          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuteron beam entered through a 7.5 um thick",
                "tantalum window. At 7 MeV the energy loss was 420 keV",
                "with a straggle of about 40 keV and at 11 and 12 MeV",
                "the energy loss was 300 keV. The beam was stop in a",
                "0.025 cm tantalum lining to the cell."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gaseous target of spectroscopically pure natural oxygen",
                "was used. The target chamber consisted of a piece of",
                "2.5 cm diameter 25 um thick stainless steel tube."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " Neutron time-of-flight spectrometer."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Neutron flight path of 3.46 m was used for the",
                "7.73 and 11 MeV measurements and a 6 m flight path was",
                "used for the 12 MeV measurements.",
                "Measurements were taken at a gas pressure of 60 cm Hg."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron spectra were analyzed using a peak fitting",
