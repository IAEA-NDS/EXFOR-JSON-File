          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Random errors attributable to individual measurements",
                "were in the current measurement (0.3-0.95%), in the",
                "estimation of the asymptotic count rate (0.09-2.17%)",
                "and in the fraction of the protons striking the walls",
                "of the Faraday cup (0.5%). Systematic errors arose",
                "from uncertainties in the"
              ]
            },
