              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " the manganese half-life,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " the bath calibration factor, and from the",
                "bath correction factors. The ranges in the latter",
                "case were:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-4",
                "minimum_value": 0.04,
                "maximum_value": 0.2,
                "correlation_property": null
              },
              "free_text": [
                " oxygen and sulphur losses,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-5",
                "minimum_value": 0.18,
                "maximum_value": 0.66,
                "correlation_property": null
              },
              "free_text": [
                " leakage"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-6",
                "minimum_value": 0.15,
                "maximum_value": 0.51,
                "correlation_property": null
              },
              "free_text": [
