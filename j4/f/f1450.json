              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Type GC1020, diameter 46.5 mm, length 32 mm,",
                "10 % relative efficiency and energy resolution of 2 keV",
                "for the 1.332 MeV gamma-line of the 60Co standard",
                "source. The samples were counted from 40 min up to 24 h"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy of the primary alpha-particle beam was",
                "27.2 MeV with a beam intensity of less than 100 nA.",
                "The irradiation times were 2 and 3 h for the first",
                "and second stack foils, respectively."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two stacks of foils were used. Each stack was made of",
                "several groups of targets:",
                "natZr (98.2 % purity),"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "40-ZR-90",
