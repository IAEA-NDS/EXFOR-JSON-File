            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting 9Be target 50 mu-g/cm**2 thick. The",
                "target was prepared by evaporating beryllium metal in",
                "vacuo from a tantalum boat."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The two halves of the angular distributions were",
                "normalized to the yield of reaction products from 9Be",
                "+ 3He in a fixed monitor solid state counter placed",
                "at 90.degr. to the beam."
              ]
            }
          ],
