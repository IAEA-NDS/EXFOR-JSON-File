              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam current was I=40 microA, which was measured",
                "with a standard current integrator with estimated",
                "uncertainty of 3%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TTM"
              ],
              "free_text": [
                " Thick target was used, the alpha-particles were",
