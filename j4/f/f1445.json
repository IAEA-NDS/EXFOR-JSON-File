              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The primary beam of 15N nuclei with an energy of 49.7",
                "MeV/A was focused on a producing 9Be target. The",
                "secondary beam of fragmentation reaction products was",
                "formed and purified by the magnetic system of the",
                "fragment separator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target (natural Si, 243-mu-m thick) was located",
                "in the reaction chamber which was a thin-walled",
                "vacuum cylinder of stainless steel."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI"
              ],
              "free_text": [
                " A set of detectors was used: scintillation",
                "detector AC1; position sensitive 16X- 16Y Si detector",
                "dE (300-mu-m thick); start dE0 Si detector (380-mu-m",
                "thick); scintillation detector AC2; target dET Si",
                "detector; six CsI(Tl) scintillation detectors."
              ]
            }
          ],
