          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Exp.gamma distributions were fitted as:",
                " F(E)=Peak(E)+Compton(E)+Background(E) ;",
                " Peak(E)=(A/(SIG*sqrt(2*PI)))*exp( -(E-E0)**2/2*SIG**2)",
                " E0 - peak centroid,",
                " SIG - standard deviation ( Gaussian),",
                " A - area under peak,",
                " Compton(E) -  Compton scattering contribution,",
                " Background(E) - background of random events."
              ]
