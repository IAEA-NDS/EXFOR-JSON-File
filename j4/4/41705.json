          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC",
                "IOCH"
              ],
              "free_text": [
                " Two proportional multi-wire counters (9",
                "and 8 mm thickness) placed next to each other and",
                "chamber (10 cm thickness) with grid.",
                " Filled with pure Ar at atmospheric pressure.",
                " Energy calibration by alpha particles from Po-212,",
                " Bi-212, Po-214 sources. Also calibrated by ions",
                " Li-7, Be-9, B-11, C-12, N-14, O-16."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " He-4 were measured in 6-22 MeV energy range.",
                " Measurement time: Li - 394 hr, Be - 407 hr,",
                " B - 439 hr, C - 178 hr, N - 78 hr,",
                " O - 3.5 and 4.5 days, F -  78 hr and 44 hr ."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " TKE was taken as 167 MeV."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For energy loss with accuracy 5-10%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".  Energy spectra ( counts/(hr*MeV) )on Figs.",
                "3 - Li (1296 counts), Be (3225 counts),",
                "7 - Be-8 (33 counts),",
                "8 - B (102 counts), C (957 counts)",
                ". Spectra at the moment, when particle appeared, were",
                "derived from measured spectra and were approximated as",
                " N(E0)=A*exp(-E0/T), E0- energy at initial moment,",
                "          T for A=0.2       T for A=0.4",
                " 2-He-4   0.78+-0.04 MeV   1.74+-0.14 MeV",
                " 4-Be-10  0.66+-0.03 MeV",
                "   Li     0.62+-0.02 MeV   1.23+-0.08 MeV",
                "   Be                      1.20+-0.04 MeV",
                "   B      0.79+-0.14 MeV   1.37+-0.21 MeV",
                "   C      0.69+-0.04 MeV   1.16+-0.06 MeV",
                " Data are in Table II of Sov.Nucl.Phys.,v.8,p.22,1969,",
                "      and note on page 27 of Sov.Nucl.Phys.,v.8,p.22,19"
              ]
            }
