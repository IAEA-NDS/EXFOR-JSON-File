            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Pu-239 fission neutron spectrum,",
                "flux at the moderator surface up to 1.E+16 n/cm2/sec.",
                "Samples were irradiated by thermalized prompt fission",
                "neutron spectrum of Pu, the mean energy of spectrum",
                "0.27 MeV ( from calculation ).",
                "DETECTOR   (HPGE) Gamma-spectra of activated samples we",
                "during March 2022 in different positions (5 cm, 10 cm,",
                "15 cm, or 25 cm) by HPGe detector (Canberra GC10021)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiation time 12 days (12-24 April,2021)",
                "at 1.5 MW power.",
                " Reaction     Cooling   Measurement  Net peak area",
                "              time,sec  time,sec",
                " 46Ti(n,p)    2691138   790.4         121194",
                " 54Fe(n,p)    26914113  202.9         165896",
