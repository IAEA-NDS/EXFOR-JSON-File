          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Strength functions of U-235 and Pu-239 for S and P",
                "neutrons ."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SLA"
              ],
              "free_text": [
                " Single  level  analysis.  In  energy  region less",
                "     than  50 keV  (fission width + gamma width  much",
                "     larger  than neutron width) reaction  cross",
                "     section calculated by Breit-Wigner formula and",
                "     and compared with sum measured averaged fission",
                "     and  capture  cross  sections.",
                "  Partial wave  analysis. Neutron partial wave",
                "     contributions in reaction cross section have",
                "     different energy law  dependence. Due to that",
                "     contributions distinguished by Least Square Method"
              ]
            }
          ],
