          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " ALF(E)= (A*(Ngamma(E)/Nf((E)-1)/(B-C*(Ngamma(E)/Nf(E))",
                "Nf, Ngamma- fission and gamma counting rates,",
                "A,B,C- ratios of counting efficiencies in the",
                "respective channels of fis.neutrons and fis.gammas,",
                "capture and fis. gammas, capture gammas in the fis.",
                "channel and fis. gammas, respectively;",
                "values of constants A,B,C were determined from",
                "normalizing to know values of ALF for low energy",
                "resonances and correcting for energy dependence of",
                "NUprompt to be A=0.26, B=0.66, C=0.0054 ."
              ]
