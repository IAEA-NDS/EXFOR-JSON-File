          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Some features of the spontaneous fission of U-238."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Double coincidence.",
                "Number of registered coincidences : ~2400 for U-238,",
                "~12000 for Pu-240. Three exp.runs."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Two multilayer ionization chambers to detect",
                "spontaneous fission of U-238. Filled with Ar at 5 atm",
                "pressure.",
                "Identical chamber with Pu. Filled with 90%Ar + 10%CO(2)",
                "at 35 mm Hg pressure."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " The fis.chambers were surrounded by 24",
                "proportional B-10F(3) counters in paraffin.",
                "Efficiency of prompt fis.neutrons registration ~4.%.",
                "Time resolution of electronic equipment ~6E-4 sec."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "12 g of uranium depleted of U-235 were deposited as",
                "layers 2 mg/cm2 thick on both sides of Al foils.",
                "2.5 mg mass, Pu-240 - 92%, Pu-238 - 8.%.",
                "On platinum foil."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- Random coincidences for Pu-240 - < 0.2%,",
                "for U-238 - ~0.01%, were not taken into account.",
                "- for nonuniform efficiency along the neutron detector."
              ]
            }
          ],
