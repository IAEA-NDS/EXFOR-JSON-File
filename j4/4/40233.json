          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular distributions of fragments in the fission",
                "of Pu-238 by 0.06-7.20 MeV neutrons"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "4RUSFEI"
              },
              "free_text": [
                " Accelerator"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                "      Proton-tritium reaction"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "D-D"
                ],
                "reaction": null
              },
              "free_text": [
                "      Deuteron-deuterium reaction"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pu-O2 oxide,0.7-0.8 mg/cm**2 thickness, 82.4% Pu-238,",
                "14.0% Pu-239, 2.6% Pu-240, 1.0% Pu-241"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FISCT"
              ],
              "free_text": [
                " Direct detection",
                "Measurements at angles 4.5, 11.5, 20.5, 30, 40, 50, 60,",
                "70, 80, 88 degrees and for 62 values of neutron",
                "energies."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GLASD"
              ],
              "free_text": [
                "    Glass detectors"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular anisotropy is found from the least-squares fit",
                "to measurements at various angles according",
                "to the formula W(phi)/W(90.deg.)=1+A*cos(phi)**2,",
                "where phi is the angle between the neutron direction",
                "and the fragment direction"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For spontaneous fission <2%.",
                "For fission of other Pu isotopes < 1.5%.",
                "For non-uniformity of the neutron flux over sample",
                "area <1.1%.",
                "For effect of mass center motion."
              ]
            }
          ],
