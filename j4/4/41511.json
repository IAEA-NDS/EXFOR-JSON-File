          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                "     Neutron beam of IBR-30 reactor.",
                " Al (70 mm),NaF (10 mm), B4C (4 mm) resonance filters",
                " were permanently installed in neutron beam tp remove",
                " background from recycled neutrons and to determine",
                "  background components in measured TOF spectra."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thin metallic disk of U-235 of 48mm diameter, 0.25mm",
                " thickness or 0.00137 at/b, U-235 content -90%, U-238",
                " - 10%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " 16-sections liquid (n,gamma)-detector PARUS.",
                "Consists of two equal tanks of total volume 80 l.",
                "Scintillation liquid - solution from 100 g of",
                "scintillation additions, 11 l of trimethyl borate",
                "enriched to 94% in B-10 and 69 l of toluene. Total",
                "length 80 cm, diameter 40 cm. Throughgoing hole of",
                "110 mm diameter. Every section is viewed by",
                "photomultiplier FEU-110. Registration efficiency 30 %,",
                "geometric efficiency 98 %. Energy resolution was",
                "estimated to be about 30 % for 662 keV Cs gamma-quanta."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " - Neutron detector as battery of three B-10",
                "  counters SNM-13.Efficiency about 0.5% at 4.3 eV.",
                "-Two neutron counters SNM-12 were placed in neutron",
                " beam at 114m distance from active zone of IBR-30 to",
                " control the power level of IBR-30."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " 120 m flight path of IBR-30 reactor.",
                "COINC) TOF spectra from 1-st to 12-th gamma-ray",
