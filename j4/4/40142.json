          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ". Maximal systematic error 1 b due to oxygen cross",
                " section dependence from neutron energy ( oxygen",
                " cross section was taken constant 4.2 b)",
                ". Total cross section measurements made with two",
                "samples, metallic V and V(2)O(5) of natural V,",
                "measurement results diverge in limits of few percent.",
                "A reason of deviation is not clear, probably due to",
                "scattering on microcrystals of V(2)O(5).",
                "This deviation can lead to systematical error not",
                "higher than 10 %."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".For oxygen contribution the oxygen total cross section",
                "was taken equal to oxygen bound-atom scattering cross",
                "section 4.2 b in considered energy range.",
                ". For V-51 presence using experimental result obtained",
                "by natural V(2)O(5) sample."
              ]
            }
