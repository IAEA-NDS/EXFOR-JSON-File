              },
              "free_text": [
                " Heavy water reactor of AS USSR."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A disc (81.8mm diameter, 2 mm thickness, 200 g weight)",
                "of 50% enriched in U-235, placed in thermal column."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutrons produced at U-235 fission by thermal neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ". ~ 1 microgram, mass was determined by alpha-activity.",
                "Placed inside ionization chamber, served for fission",
                "events counting.",
                ". ~ 300 mg, mass was determined by weighting.",
                "Placed outside ionization chamber."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " For fission events registration. Working gas Ar."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "D4PI"
              ],
              "free_text": [
                " Beta activity was measured by a 4PI counter or b",
                "an end-window counter (window thickness",
                "0.005+-0.001 mg/cm2)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Irradiation time 10-20 hr,",
                " cooling time usually < 1-1.5 half-life of isotope.",
                " Yield of isotope was determined from 6-8 independent",
                "measurements."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Au-foil (8-10 mg/cm2) stacked to thick sample was",
                "served as integral neutron flux, beta-activity of",
                "Au-198 was measured by end-window counter."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Number of fission events in thick sample was calculated",
                "by number of fissions in thin sample and mass ratio",
                "for thick and thin samples."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For neutron flux difference in thin and thick samples",
                "~5%."
              ]
            }
          ],
