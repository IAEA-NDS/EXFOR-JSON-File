              ],
              "free_text": [
                " Electronic pair detector for gammas. Na-I(Tl)",
                " crystals 40*40 mm (central) and two side 80*50 mm",
                " were used. Resolution of the spectrometer is 6-7 %",
                " for energies 4.43 MeV (Po-Be n-source) and 2.62 MeV",
                " for gammas from Tl-208"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Standard neutron sources were used for efficiency",
                " determination"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections were made for multiple scattering of",
                " neutrons in sample, for attenuation of neutrons and",
                " energy decrease, attenuation of gammas in the cone",
                " made of Pb and for the peculiarity of the background",
                " spectrum.",
                " Total correction factor 1.5."
              ]
            }
          ],
