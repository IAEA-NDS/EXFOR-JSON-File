            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For energies above U-238 fission threshold the U-238",
                "fission products were removed by chemical purification",
                "before measurement of induced activity."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for fluctuation of neutron number",
                "background of neutrons scattered in target chamber",
                "was less than 1%",
                "Neutrons emitting from molybdenum backing made",
                "following contributions in counting rate of",
                "fission chamber 30-50%, in induced activity of",
                "the sample 60-80%.",
                "Correction for inelastic scattering of neutrons",
                "on the construction materials and for admixture",
                "of other fissile  nuclei was 5-8% calculating",
                "with accuracy 15%"
              ]
            }
