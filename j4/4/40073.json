              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Experiment Was Made On Neutron Time-of-flight",
                "Spectrometer With Flight Path 1.125 m And Time",
                "Resolution 18.0 nsec/m For Neutron Energy Range From",
