          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental studies of the absolute total delayed",
                "neutron yields from neutron induced fission of U-236",
                "in the energy rage 1-5 MeV."
              ]
            }
          ],
