          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Formula for n,2n cross section calculation is given",
                "on page 310 of SJA,8,310,1961:",
                " SIGn,2n=((Nth*HLth)/(Nmo*HLmo))*",
                " (SIGufis*Ymou*(232Pu/238Pth)+SIGthfis*Ymoth)),",
                " where",
                "SIGufis, SIGthfis - fission cross-section for U238 and",
                "Th232 at 14 MeV;",
                "HLth, HLmo - half-life of Th231 and Mo99 (or Ba140);",
                "Nth, Nmo - number of Th231, Mo99 (or Ba140)",
                "disintegrations per time unit at the end irradiation",
                "and referred to the total amounts of Th232 and U-238;",
                "Ymou, YYmoth - Mo ( or Ba) yield at fission of U238 and",
                "Th232  at 14 MeV;",
                "Pth, Pu - weights of Th232 and U238."
              ]
            }
          ],
