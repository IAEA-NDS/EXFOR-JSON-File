          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Method of determining the d-neutron strength functions",
                "for even-even nuclei from radiation capture",
                "cross sections"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A new method for determining of the d-neutron strength",
                "functions for even-even nuclei radiation capture",
                "cross-section was used.  A drop due to the",
                "competition of the inelastic scattering has been",
                "observed in capture sigma of even-even nuclei.",
                "measuring of magnitude of this decrease gives the",
                "partial sigma of the orbital momentum L=2 neutron",
                "capture and the corresponding neutron strength",
                "functions"
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "                 Dependent data. Independent data from",
                "REL-REFs of A.E.Johnsrud+ and V.N.Kononov+"
              ]
            }
