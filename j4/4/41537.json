          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Cf-252 layer on stainless steel backing of 20 mm",
                " diameter, 0.2 mm thickness.Cf-252 layer spot size",
                " about 5 mm, intensity about 1.E+5 fis/sec ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Two detectors , placed at 40-70 cm from Cf source",
                " at variable angle between detectors and variable",
                " distances. Each detector was made on the base of",
                " stilbene crystal of about 60 mm diameter,",
                " about 40 mm thickness and FEU Hamamatsu R1307,",
                " protected by 40 mm lead and 40 mm polyethylene."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " Pulse shape - to split neutrons from gammas."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Every TOF spectrum consists of gamma-gamma, n-n",
                " and gamma-n components."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " N-N coincidences were used.",
                "Energy scale was graduated by standard sources of Na-22",
                "Co-60, Cs-137, Bi-207."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "S",
              "coded_information": null,
              "free_text": [
                " For detection efficiency decreasing at increasing of",
                " distance of Cf source - detector from 40 to 70 cm,",
                " at angles 20-40 degrees."
