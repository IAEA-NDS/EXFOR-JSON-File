          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation detector (indium-chloride solution into",
                "water, In working content 80 g/l, with admixture",
                "of cadmium into solution, in a cone of 340 mm length)",
                "was placed into water tank which surrounded sample.",
                " In was used as resonance absorber"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Sodium-iodide crystal (60x70 mm) connected with",
                "FEU-11 photomultiplier was used for gamma activity",
                "measurement of the solution.",
                "Neutron efficiency registration changed on 0.01 % in",
                "energy range from 0.001 to 10.MeV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "     Calculation of absorption cross section was",
                "carried out from transmission in one-velocity transport",
                "approximation for point source by Monte-Carlo",
                "method."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For finite size of neutron source.",
                "For neutron absorption in Be shall surrounding the",
                "neutron source.",
                "For self-absorption."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
