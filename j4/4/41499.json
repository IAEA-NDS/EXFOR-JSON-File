          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Two samples of metallic plutonium as sphere covered",
                " twice by stainless steel of 2mm thickness:",
                "  1. Mass - 82.93g, Radius - 1.05 cm.",
                "  2. Mass - 41.46g, Radius - 0.83cm.",
                " Content: Pu-238 < 1.E-4%, Pu-239 - (7.86 +- 0.01)%,",
                "  Pu-240 - (91.07 +- 0.01)%, Pu-241 - (0.88 +- 0.01)%,",
                "  Pu-242 - (0.17 +- 0.01)%.",
                "  Am-241 content - about 3% of plutonium mass."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " Coaxial germanium detector, protected by borated",
                "     polyethylene (40mm), lead (4mm) and cadmium (2mm).",
                " Efficiency - 60%, resolution - 1.9 keV for",
                " E-gamma=1332 keV.",
                " Energy dependence of detector efficiency was defined",
                " by Eu-152 and Ra-226 sources."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The spontaneous fission yields are calculated by",
                " ratio of counts in gamma-peaks of fission products and",
                " counts in peak og 642. keV gamma-ray of Pu-240."
              ]
            }
          ],
