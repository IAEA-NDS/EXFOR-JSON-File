          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Np-oxide placed in thin-walled containers of 10 mm",
                "diameter, 2-3 mm height. Samples weight 140-400 mg.",
                "Np was prepurified from Pu isotopes by a factor of",
                "about 10**5. Background of Pu-236 was within 0.1% of",
                "the induced one."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "CHSEP"
              ],
              "free_text": [
                " Each sample was irradiated for 80-100 hr.",
                "Np-236 decays to Pu-236 by beta(-) emission.",
                "Cross section for Np-237(n,2n)Np-236 reaction was",
                "measured by detection of alpha particle emission",
                "from Pu-236.",
                "After irradiation,Pu-236 was radiochemically separated.",
                "For this purpose, Pu-239 was used as tracer and",
                "the cross section was calculated by formula",
                " sigma(n,2n)=A*(n(Pu-236)/n(Pu-239))*(1/(N*f*l*W))",
                " where",
                "A- Pu-239 activity",
                "n(Pu-236)/n(Pu-239) - ratio of alpha intensities from",
                "                     Pu-236 and Pu-239",
                "N- number of Np-237 nuclei in the sample",
                "f- neutron flux",
                "l- decay constant for Pu-236",
                "W- beta(-) decay probability for Np-236 = 0.48+-0.01"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  Correction on neutron flux fluctuations < 10% ."
              ]
            }
          ],
