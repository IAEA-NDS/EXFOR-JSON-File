          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "  Activated samples were sealed by glue in",
                " aluminum foil of 6 mg/cm**2 thickness.",
                " Aluminum filter of about 220 mg/cm**2 to remove beta-",
                " particles of energy < 0.7 MeV. Dependence of beta-",
                " radiation attenuation by filter was measured in energy",
                " range 0.6 - 3.2 MeV.",
                " Activation of samples of different isotopic abundance",
                " allowed to define Se-76 (n,p) and (n,d)+(n,np)",
                " reactions."
              ]
            }
          ],
