          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SPECC"
                ],
                "institute": "4ZZZDUB"
              },
              "free_text": [
                " TOF spectrometer CORSET (Correlation",
                " Setup) consists of two identical TOF arms to measure",
                " velocity of both reaction fragments and several",
                " telescopes."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "MCPLT",
                "MCPLT",
                "SOLST"
              ],
              "free_text": [
                " V-E telescopes to measure",
                "mass and energy of one of binary reaction products.",
                "Consists of \"start\" and \"stop\" micro-channel plate",
                "detectors with electrostatic mirror and semiconductor",
                "detector of 2cm*2xcm size."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                " Each arm contains two detectors-compact \"start\"",
                "and position sensitive detector \"stop\"."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Four surface barrier semiconductor detectors -",
                "        for beam monitoring.",
                " Parameters of CORSET setup :",
                "                 Two-arms spectrometer  V-E telescope",
                "Time resolution-    150 picosec          180 picosec",
                "                    for each arm",
                "Angular resolution- about 0.3 deg        +- 1.5 deg",
                "Geometry efficiency- about 3%            about 0.15 %",
                "Registration",
                "efficiency-          about 67%           about 67 %.",
                "Mass resolution-       3 (FWHM)           4(FWHM)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Flight path - 18cm from start to stop detector of",
                " each arms.",
                " From sample to start detector - 3-5 cm.",
                " Flight path 10cm from \"start\" to \"stop\" detectors of",
                " V-E telescopes.",
                " 2V method, V-E method, 2V-E method.",
                " Time resolution 150 ps, mass resolution 3 a.m.,",
                " angular resolution 0.3 deg."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Mass and energy of fragment was defined by iterative",
                " method using lows of conservation of impulse and",
                " number of nucleons."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For events of reaction fragment interference with",
                " electrostatic mirror guide  - about 5%.",
                " For size of \"stop\" MCPLT detectors.",
                " For dead time of \"start\" detectors - less 10%."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Of compiler M.M.",
                " Data of Fig.11a of J,PTE,1,51,2008 -",
                "yield of FF vs. their mass and TKE -",
                " 3D-figure data are not possible to digitize.",
                "Request for data was sent 11.04.2008",
                "             to E.M.Kozulin - no reply."
              ]
            }
