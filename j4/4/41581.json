          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Time-of-flight spectrometer CORSET for measuring the",
                "binary products of nuclear reactions."
              ]
            }
          ],
          "AUTHOR": [
            {
