          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "4ZZZDUB"
              },
              "free_text": [
                " Fm-256 was synthesized in the internal",
                "Ne-22 (130 MeV ion energy, about 6E+13 prt/sec",
                "intensity) ion beam of U-300 cyclotron by reaction",
                "U-238(Ne-22,p3n)Md-256 -> E.C.(90.%,HL=1.33hr -> Fm-256",
                "which cross-section is about 2.E-33 cm**2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                "  The coincidences between the impulses from",
                " neutron detectors and fission fragment detectors."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "LONGC",
                "SIBAR"
              ],
              "free_text": [
                "     Long counter for recording of",
                " neutrons; consists of 36 He-3 counters placed into",
                "plexiglas block. For recording of fission fragments",
                "the surface-barrier Si(Au) detectors were used.",
                "The efficiency of fission-neutron registration",
                "determined for Cm-244 was 48.5%;",
                "background < 0.001 n/fis."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Background due to spontaneous fission of Cf-246 and",
                "Fm-252 (presented in investigated source) can not",
                "introduce an error > 0.1 % in measured NU."
              ]
            }
          ],
