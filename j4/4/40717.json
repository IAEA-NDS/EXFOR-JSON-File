          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of absorption cross-sections for neutrons",
                "with a mean energy of 24 keV by transmission in a",
                "spherical geometry"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "T.S.Belanova",
                "A.A.Van'kov",
                "F.F.Mikhaylus",
                "Yu.Ya.Stavisskiy"
              ],
              "free_text": [
                ""
              ]
            }
          ],
