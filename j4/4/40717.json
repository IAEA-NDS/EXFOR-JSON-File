          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  Sb-Be neutron source of 30 mm diameter, Be thickness",
                " 2-4 mm, intensity ~10**8 n/sec.",
                "Mean neutron energy 24 keV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Spherical layers"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SHELT"
              ],
              "free_text": [
                " Spherical shell transmission.",
                " Independent measurements by",
                "1) long counter and",
                "2) fission chambers in water tank.",
                " To search resonance blocking of fast neutrons,",
                " the samples deluted by Pb-Bi alloy ( volume content",
                " in sample ~ 70 %) and samples of different thickness",
                " were used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " System of long counters was used for neutrons",
                "detection."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " Water tank with little fission chambers",
                "containing U-235 layer was used for neutrons detection."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Monte-Carlo method to calculate transmissions.",
                " Table 2 contains resulting data obtained from",
                " measurements by long counter and water tank with",
                " fission chambers."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Absolute measurements"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " . For",
                " non-monoenergetic neutrons;",
                " neutron source dimensions and absorption in the",
                " neutron source;",
                " attenuation of neutrons in the water tank;",
                " absorption in Pb-Bi alloy;",
                " fission of U-235 admixture in natural U-238.",
                " Total correction was in a range 5 - 25 %."
              ]
            }
          ],
