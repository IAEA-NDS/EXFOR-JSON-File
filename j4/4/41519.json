          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Investigation of the resonance structure of neutron",
                " cross-sections of Mo, Ho, Ta, W at the 50 m flight",
                " path of the MMF (INR, Troitsk)"
              ]
            }
          ],
          "AUTHOR": [
            {
