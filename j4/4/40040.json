            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pressed powdery ring samples were 242.g for",
                "La-oxide and 285.g for Pr-oxide, in some cases 190.g",
                "and 273.g for both respectively.Background was measured",
                "by using graphite sample placed in such container as",
                "for samples under study.",
                "Iron sample was in same form, 895.g in weight."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "        Direct detection. Usual ring geometry."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "1",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " NaI(Tl) 40*40 mm scintillation counter in",
                "contact with photomultiplier. Resolution was equal",
                "10% for 661.keV gamma energy."
              ]
            },
            {
              "pointer": "2",
              "coded_information": [
                "LONGC",
                "BF3"
              ],
              "free_text": [
                " Neutron flux was controlled by long",
                "proportional counter filled by BF3 and placed in",
                "paraffin shielding"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Data were calculated from",
                "measured excitation cross section of distinct",
                "gamma-lines and relative probabilities of direct and",
                "cascade transitions"
              ]
            }
          ],
