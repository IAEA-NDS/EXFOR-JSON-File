              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Cross section for oxygen was taken equal 3.8 b.",
                " Correction for self-screening and neutron absorption",
                " was equal to 8-14 %."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Energy dependence of magnetic scattering by Yb+++ was",
                " assumed to be the same as that for Er+++, i.e.",
                " SIGMA(Yb+++)/SIGMA(Er+++) is equal 0.224 according to",
                " magnetic momentum value. Data were averaged over runs",
                " of different resolutions. Magnetic scattering",
                "cross-sections were subtracted."
              ]
            }
          ],
