          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Least squares fit to Legendre expansion according",
                "to the formula SIGMA(THETA)=P(0)+A2*P(2,THETA), where",
                "P(L,THETA) - Legendre polynomial of the order L, L=0,2,",
                "was used to define anisotropy coefficients",
                "SIGMA(0deg)/SIGMA(90deg) - data on Fig.1b of YFI-12."
              ]
            }
