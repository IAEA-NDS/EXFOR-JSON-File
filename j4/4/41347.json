          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".INVESTIGATION OF NEUTRON RESONANCES IN RH-103"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " IBR Fast Pulsed Reactor. Pulse duration is 36",
                " microsec, pulse repetition rate 8.3Hz,"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Samples of Metallic Rhodium For Transmission",
                " Measurements had Thicknesses of 2.805E21, 1.38E22 and",
                " 5.68E22 Atoms/Cm2, Capture Measurements had",
                " Thicknesses of 1.4E21, 7.0E21, 14.E21, 28.E21, and",
                " 56.E21 Atoms/Cm-Sq, and Scattering Measurements had",
                " Thicknesses of 6.7E20, 2.82E21, and 6.73E21 Atoms/Cm2"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Time of Flight with a 1000 M Path Length and",
                " 0.036 Microsec/M Resolution For Transmission",
                " Measurements (TOTAL CROSS SECTIONS),750 M Path Length",
                " And 0.05 Microsec/M Resolution For Capture",
                " Measurements, and a 500 M and 0.08 Microsec/M",
                " Resolution For Scattering Measurements"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Detectors were Methyl Borate For Transmission",
                " Neutrons, Liquid Paraterphenyl and Popop For Capture",
                " Gamma-Rays, and ZnS(Ag) For Scattered Neutrons As",
                " Scintillators"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "AREA"
              ],
              "free_text": [
                " Area Analysis Applied to Transmission Data to",
                " Obtain Resonance Energies and Neutron Widths,",
                " Self-Indication to Determined Widths and Level Spins",
                " From Capture Data, and Scattering Data in Conjunction",
                " With the Other Measurements to Determine Stat-W G"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Corrections made for neutron background which was",
                " measured with the help of Cobalt and Silver folters"
              ]
            }
          ],
