              ],
              "free_text": [
                " Lithium-glass detector for neutrons",
                " NE-912 (45 mm diameter, 9.5 mm thickness,",
                " Li-6 containing)",
                " or NE-913 (same dimensions, Li-7 containing)",
                " - to measure background of delayed gammas.",
                " Solid angle of neutron detection (0.0176 +- 0.0002) sr",
                " Measurements of the efficiency of the NE-912 glass",
                " were performed with reference to the 0.0835 cm NE-908",
                " glass."
              ]
            },
