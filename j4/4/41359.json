          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Measured KS-1 leakage spectrum is presented on",
                " Fig.2.a of C,97TRIEST, Fig.6 of C,96MITO,2,E-338,1996.",
                " Unfolded by the measured in the center of critical",
                " assembly values of fission and activation integrals",
                " neutron spectrum in the center of critical assembly is",
                " given of Fig.4 of C,96MITO,2,E-338,1996.",
                " Energy spectrum was measured from 0.5 to 8 MeV.",
                " Cf-252 spontaneous fission neutron spectrum was",
                " measured for validation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC",
                "PROPC"
              ],
              "free_text": [
                " Proportional gas counter was used to",
                " measure the neutron leakage spectrum of KS-1.",
                " Length of cylinder-cathode - 1 m, internal diameter",
                " 7.5 cm, wall thickens 1 mm, material -stainless steel.",
                " Tungsten wire-anode of 40 microm diameter. High-purity",
                " methane as working gas at pressure about 300kPa(3atm);",
                " 0.4 volume % of He-3 added- for energy calibration by",
                " He-3(n,p)T exothermic reaction ( 0.764 MeV recoil",
                " protons energy peak). At voltage 2.5 kV the energy",
                " resolution 3.8 %, at 3 kV - 4 %. Efficiency of neutron",
                " registration high as 1 %."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Small-sized ionization chambers with",
                " metrologically tested layers of U-235,U-238,Pu-239,",
                " Pu-240, Np-237 - for measurement of neutron spectra",
                " in the center of critical assemblies."
              ]
            }
          ],
          "ADD-RES": [
