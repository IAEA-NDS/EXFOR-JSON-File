          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Difference in number of recoil protons was determined",
                "for paraffin and graphite samples.",
                "Absolute values of neutron differential cross-sections",
                "were determined by normalization to total elastic",
                "cross-section (26.0 +- 3. mb), which was defined as",
                "difference of total cross-section (36. +- 2. mb) from",
                "REL-REF(Dzhelepov+) and cross-section of pi-mesons",
                "production(10. +- 2. mb) at n-p interactions. Differen.",
                "cross-section was assumed to be about constant at",
                "angles   < 35 deg in CM system and was equal to value",
                "at 35 deg.,as it was defined in experiments at energy",
                "range 300-400 MeV(see REL-REF of Hartzler+ for details)"
              ]
            }
          ],
