          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Probability of delayed neutron emission from halogens."
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "4RUSRUS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Br and I precursors were separated chemically",
                "from fission products of U-238 and Th-232 irradiated",
                "by 14-MeV neutrons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Beta and neutron was measured simultaneously."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N",
                "B"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron and beta decay curves were analyzed to",
                "determine the activity of isotopes. Probability of",
                "delayed neutrons was defined as ratio of the neutron",
                "activity to the beta-activity of the same amount of",
                "the investigated isotope."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BF3"
              ],
              "free_text": [
                " Neutron detector consists of six boron counters",
                "in paraffin block. Total efficiency 3.0+-0.2 %",
                "determined by calibrated neutron sources with neutron",
                "energies 50-800 keV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Beta detectors were two 4PI scintillators",
                "of 15cm3 volume, each equipped by two photomultipliers,",
                "placed in front and behind absorber."
              ]
            }
          ],
