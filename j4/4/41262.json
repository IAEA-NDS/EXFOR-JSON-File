          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Total cross sections of Ni isotopes can be represented",
                "by formula: SIGtot=SIGscattering + K*t, where",
                "t - time of flight of a neutron for one meter distance,",
                "K - coefficient determined from experimental data.",
                "Isotope      K",
                "Ni-61       (6.1+-2.)*10**-3",
                "Ni-62       (3.0+-0.3)*10**-2",
                "Ni-64       (4.65+-1.2)*10**-3"
              ]
            }
          ],
