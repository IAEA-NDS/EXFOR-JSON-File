          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 14.6 MeV neutrons. 5.E+8 n/sec with accuracy 10-15%."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Relative measurement."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " U samples were",
                " - UO(3) for Mo-101 and Mo-102,",
                " - salt UO(2)(NO(3))(2)*6H(2)O for I131+Te-131",
                " - U(3)O(8) for Sr-89, Sr-91, Zr-95, Zr-97, Ru-105,",
                " Ag-111, Ag-113, Cd-115, Ba-140.",
                " Pu samples were oxide PuO(2) of ~1g weight each.",
                " Boron carbide was used to shield the samples against",
                " thermal neutrons."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " 36 experiments.",
                " Irradiation time - few minutes to 8 hr.",
                " Isotopic dilution method was used to separate fission",
                "products. Carriers were natural isotopic elements in",
                "chemical separation. Radiochemical purification was",
                "used to remove contaminations. Separated powder ( e.g.",
                "ZrO(2), CdO, SrSO(4), BrCrO(4)) was compressed in a",
                "lead cup to form a disk of 8 mm diameter and weighting",
                "40.0+-0.3 mg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ". End-window counter for beta-activity detection.",
                " Detection efficiency of end-window counter was checked",
                " by thin (<0.3mg/cm2) sample using 4PI beta counter.",
                ". For Mo-101 and Mo-102 - a counter with increased",
                " efficiency ( ~30%) was used."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For saturation and decay during irradiation."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " In Table 1 of J.Nucl.Energy,part A, v.10, p.80,1959",
                "there are data of partial yield of last member of",
                "chains in %, estimated from measured cumulated yields",
                "by assumption of NU from light fragment = 2 or 3."
