          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Total alpha-widths Ga were calculated from sums of",
                "alpha-counts Na in the individual resonances as:",
                " (Ga)k=((Na)k/(Na)0))*((PI0*A0*Gk)/(PIk*Ak*G0))*(Ga)0,",
                " where",
                "k and 0 - k-th and standard resonance,",
                "G - total resonance width,",
                "A - area above the transmission curve,",
                "PI - neutron flux density .",
                "Total widths G were calculated from the sum",
                "2*g*Gn+Ggamma or 2*g*Gn+,Ggamma>,",
                "<Ggamma>=53 meV."
              ]
            }
          ],
