          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The course of the cross section of radiation capture",
                "of I-127 neutrons was calculated from the dependence",
                "of the fission cross section of U-235 on the neutron",
                "energy. Mean values of the fission cross sections of",
                "U-235 were used (see the continuous curve in D.Hughes,",
                "etc. Neutron Cross Sections, New York, 1958.)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Errors in the obtained values of radiation capture",
                "cross sections of 1m neutrons were mainly determined",
                "by errors in the fission cross sections of U-235, which",
                "were ~25% for En < 60 keV, ~12% for En = 60-150 keV,",
                "~8% for neutrons of higher energies (see REL-REF)."
              ]
            },
