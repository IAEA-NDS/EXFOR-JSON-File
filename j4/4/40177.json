              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for:",
                " * background of scattered neutrons(1-2%),",
                " * neutrons inelastic scattering on construction",
                "   materials (10-12% for the sample and 2% for the",
                "   fission chamber),",
                " * neutrons emitting from the target's backing(10-80%",
                "   for U-238 and 2-25% for the fission chamber) and",
                " * admixture of the other fissile  nuclei(4%) were",
                "   taken into account for the first region of the",
                "   measurements for the second one were induced the",
                "   corrections for background of neutrons(2%),",
                " * inelastic scattering (10%) and",
                " * neutrons emitting from the target backing (10-80%",
                "   for U-238 and 2-20% for Al foil)"
              ]
            }
          ],
