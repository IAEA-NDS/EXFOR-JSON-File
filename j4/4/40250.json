          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Spectra of the prompt neutrons arising from the",
                "spontaneous fission of Cf-252,Cm-244 and Pu-240"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation detector. Stilbene crystal  of",
                " 3 cm diameter, 3 cm height. Photomultiplier FEU-13.",
                " Placed at 3 cm  from samples. Lead plate of 1 cm",
                " thickness between sample and crystal  to suppress",
                " gamma background.",
                " Stability of registration was checked by Tl-208",
                " gamma-source.",
                " Energy scale was calibrated at accelerator using",
                " monoenergetic neutrons from p-t, d-d, d-t reactions."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "N"
              ],
              "free_text": [
                "  Neutrons"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Influence of distance from source to crystal was",
                " checked in additional measurement by Cf-252 at 2cm",
                " and 75 cm and was found to be negligible."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For coincidence was estimated to be less 1 %.",
                " Influence of lead plate was investigated by Cf-252",
                " spectrum measurement with and without lead plate and",
                " was found to be negligible ."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Spectrum temperature was defined for Cf-252, Cm-244,",
                " Pu-240 to be 1.42+-.03, 1.33+-0.03, 1.27+-0.03 MeV,",
                " respectively."
              ]
            }
          ],
          "HISTORY": [
            {
