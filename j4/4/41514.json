          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " In irradiated layer the nuclei of Am-241, Am-242m,",
                " Am-242g are contained and the accumulation of Cm-242",
                " nuclei takes place.Am-242m fission of Am-241",
                " sub-barrier fission contribute too large to yield of",
                " fission fragments. Statistical analysis of data made",
                " possible to get upper value."
              ]
            }
