          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " VEC-25 and VEC-28 channels."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thermal maxwellian neutron flux and cadmium ratio were",
                "determined experimentally by capture in gold,as a rule.",
                " For VEC-25 - neutron flux 1.98E13 n/cm**2/sec,",
                " cadmium ratio 5.06 .",
                " For VEC-28 - neutron flux 5.75E10 n/cm**2/sec,",
                " cadmium ratio 13.5 .",
                " Error of neutron flux about 4 % ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Am-241 of high enrichment. Relative content of Am-242m",
                " and Am-243 atoms in samples < 3.E-6. Electrodeposition",
                " from alcoholic solution was used for fission samples,",
                " spot diameter 6.0+-0.1 mm .",
                " For radiative capture - several ampules of quartz",
                " glass containing purified nitrate of Am-241.",
                " Am-241 content in layers from 12.9 to 16.8 microg,",
                " in ampoules - from 32.3 to 35.5 microg .",
                " U-235 or Pu-239 certified layers - for additional",
                " control and normalization."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Coaxial semiconductor detector of extra-purity",
                " germanium - for flux measurements."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Dielectric track detectors - plates of silicate",
                "glass of 6.00+-0.02 mm diameter at 6.00+-0.02 mm",
                "distance from surface layer. Probability of one of",
                "fission fragments hit to the area of detector sensitive",
                "surface - (9.37+-0.10)% ."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                "  Three layers of Am-241 (3.60, 4.05, 3.19 10**6",
                "nuclei of Am) in aluminum chambers were irradiated in",
                "VEC-25 within 30min, 1.0hour, 1.5hour, respectively .",
                "Immediately after irradiation dielectric track",
                "detectors were established in chambers,and measurements",
                "were continued in VEC-28.",
                "Irradiation with and without cadmium."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ASPEC"
              ],
              "free_text": [
                " Alpha-particle spectra were registered by",
                "semiconductor alpha-spectrometer with 30keV resolution.",
                " Two ampoules with Am-241 nitrate were irradiated in",
                " VEC-25 within 69.6 hour (neutron fluence",
                " (0.495+-0.021)*10**19 n/cm**2) ."
              ]
            }
          ],
