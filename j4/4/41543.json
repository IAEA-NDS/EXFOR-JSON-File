          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Powders of neodymium oxide of mass about 20 g of metal,",
                "area 4cmX5cm, enrichment 95.7%, 97.4%, 97.4%, 92.8%",
                "for Nd-142, -144, -146, -150, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " Double-crystal Compton polarimeter with Ge",
                "crystals of 40 mm diameter, 40 mm thick. Distance",
                "between crystal surfaces 5 cm. Used for gamma-ray",
                "detection. Lead collimator of 2cmX4cm size was placed",
                "in front of crystal scatterer.",
                "Resolution 2.3 keV at E-gamma 1.6 MeV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Linear polarization P was determined by N = ratio of",
                "counts measured at 90 degrees to 0 degrees by",
                "polarimeter and R = sensitivity of polarimeter,",
                "using relation P=(1-N*R)/(N-R)."
              ]
            }
          ],
