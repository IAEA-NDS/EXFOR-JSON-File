          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target materials consists of high density powder-",
                "HDP-uranium carbide, obtained from the fragmentation",
                "of high density rod uranium carbide, UC(2), of density",
                " 11.2 g/cm**3.The HDP-target of 8mm diameter and 28mm",
                " length has a volume of 1.4 cm**3",
                "and contains about 10-grams of uranium with an",
                "effective density of 7.36 g/cm**3, corresponding to a",
                "target thickness of about 20 g/cm**2.The Average grain",
                "size was about 10-20-mum. The using of graphite",
                " container in tungsten container allows to keep target",
                " temperature as high as needed and to preserve from",
                " aggressive chemical corrosion of uranium."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The overall efficiencies as a function of the target",
                "temperature have been measured."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 1 GeV Proton beam is transported over a distance of",
                "60-m to the target area, is deflected by a magnet to",
                "impinge on tantalum converter of 20mm*15mm*60mm sizes",
                " to generate fast neutrons"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " EN-DUMMY - energy of fast neutron, produced in",
                " tantalum converter by 1 GeV proton beam, was not",
                " pointed in the article."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " 160-cm**3 Ge(Li)-detector of 1.2% total peak",
                "efficiency at 1.3-MeV placed at about 1.5 cm from the",
                "tape."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCY"
                ],
                "institute": "4RUSLIN"
              },
              "free_text": [
