          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Average kinetic energy of fragments was calculated",
                "according to the formula Ek=Z**2*(Mh*(A-Mh))/A**(7/3)*F",
                "here Z,A - charge and mass-number of fissile nucleus,",
                "     Mh - average mass-number of heavy fragments,",
                "     F -  form-factor taking into account deformation",
                "          of nucleus at the time of division"
              ]
            }
          ],
