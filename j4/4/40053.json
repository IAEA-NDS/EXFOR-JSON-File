          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma ray spectra produced upon capture of thermal",
                "neutrons by the nuclei Zn-64,66,67,68"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
