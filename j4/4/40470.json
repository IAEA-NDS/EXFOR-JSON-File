                "code": "94-PU-239(N,ABS),,ALF,,SDT",
                "code_unit": [
                  {
                    "unit": "94-PU-239(N,ABS),,ALF,,SDT",
                    "field": {
                      "reaction": "94-PU-239(N,ABS)",
                      "target": "94-PU-239",
                      "projectile": "N",
                      "process": "ABS",
                      "product": "",
                      "quantity": ",ALF",
                      "data_type": null,
                      "general_quantity_modifier": "SDT",
                      "quantity_236": ",ALF"
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Au sample of 1.8E+21 at/cm**2 was used for",
                "normalization - in measurement with carbon prism by",
                "thermal neutrons and \"thin\" Pu sample.",
                "Measurements with \"thick\" Pu samples were calibrated by",
                "\"thin\" sample measurement in energy range 8 - 23 keV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "ALF(E) value was defined by formula:",
                " ALF(E) - ALF(T) =",
                " ((IgammaPu(E)*IfPu(T))/(IfPu(E)*IgammaPu(T))-1.)*",
                " ((IgammaPu(T)*SIGcapAu(T)*Pau*Apu*Bau)/",
                " (IgammaAu(T)*SIGfPu(T)*Ppu*Aau*Bpu*delta)), where",
                " IgammaPu, IgammaAu - gamma counts for Pu and Au,",
                " IfPu - fission counts for Pu,",
                "at",
                " E - investigated incident neutron energy,",
                " T - thermal neutron Maxwellian spectrum at 22 deg C",
                "     temperature;",
                " SIGcapAu(T) - Au capture cross section (value not",
                "               given),",
                " SIGfPu(T) - Pu fission cross section (value not",
                "           given),",
                "Pau,Ppu,Aau,Apu,Bau,Bpu - sample weight, atomic weight,",
                "binding energy for Au and Pu;",
                "delta - coefficient depending from Au and Pu samples",
                "radii;",
                "ALF(T) - ALPHA value for thermal Maxwellian spectrum at",
                "22 deg temperature, = 0.398+-0.004 (ASSUM)."
              ]
            }
          ],
          "ASSUMED": [
            {
              "pointer": "",
              "coded_information": {
