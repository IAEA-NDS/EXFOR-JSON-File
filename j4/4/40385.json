          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of NU(eff) and fission + capture for fast",
                "neutrons in U235 and Pu239."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "PHOTO"
                ],
                "reaction": null
              },
              "free_text": [
                "  Sb-Be for  24-keV neutrons ,",
                "        Na-D(2)O for 240-keV neutrons,",
                "         Na-Be for 880-keV neutrons.",
                "Relative intensities of neutron sources were measured",
                "in a water tank."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SHELT"
              ],
              "free_text": [
                " Spherical shell transmission"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " U-235 fis.chamber - for neutron absorption in",
                "spheres. U-238 fis.chamber  - for secondary neutrons at",
                "center of sphere, these affects were subtracted from",
                "results of U-235 fis.chamber."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spheres of metallic U-235(90% enriched) and Pu-239 of",
                "internal diameter 5 cm, 1cm wall thickness."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering could be neglected in the first",
                "approximation.",
                "Multiplication and elastic scattering of fission",
                "neutrons in the spheres were measured experimentally by",
                "exposing  to thermal neutrons."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutrons scattered from walls of apparatus, the finite",
                "distances between  sources and detectors, the",
                "uncertainties in size of sources and detectors, the",
                "U-238 and U-235 content and a number of less important",
                "factor were taken into account in analysis."
              ]
            }
          ],
          "ERR-ANALYS": [
