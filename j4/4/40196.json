          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Excitation of low-lying Ge70 and Ge72 states in",
                " inelastic neutron scattering near threshold"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "4RUSLEB"
              },
              "free_text": [
                " Electrostatic accelerator of",
                "  protons (EG-2.5)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-T"
                ],
                "reaction": null
              },
              "free_text": [
                " Ti-tritium target ."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The width of neutron energy spectrum was determined",
                "mainly from the proton energy loss in the target (about",
                "25.keV for protons energy 2.MeV).",
                "Neutron flux was measured by two ways:",
                "- long counter calibrated by Pu-Be source whose",
                "intensity was known with 10% accuracy;",
                "- surface-barrier Si detector measuring recoiling",
                "protons from polyethylene and using np scattering CS",
                "4.3 b for 930-keV neutrons.",
                "The difference between the fluxes measured by these two",
                "ways was ~5% ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Germanium-lithium detector was used simultaneously as",
                "sample.",
                " Natural Ge and Fe - for normalization purpose at",
                " measurement with scintillation spectrometer."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Gamma-spectrometer having a NaI crystal and"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detector with thickness 3.5 mm to measure",
                " relative gamma yield, which was normalized to data",
                " obtained by scintillation spectrometer."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "LONGC"
              ],
              "free_text": [
                " The neutron yield was monitored with a",
                "        'long' counter"
              ]
            }
          ],
