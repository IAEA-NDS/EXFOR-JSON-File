          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Each series of films, obtained in an explosures of the",
                "chamber  to one momentum neutrons, was scanned 3 times.",
                "As result, in different scanning the values of Ni/Ntot",
                "for i=1,3,5,and for all momenta were found to coincide",
                "within one statistical error."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Topological cross sections of 1-,3-,5-,7-prong events",
                " were defined as:",
                "SIGi=Ni*(SIGtot/Ntot), where",
                "i = 1,3,5,7 ;",
                "Ni - number of events of this topology.",
                "The incident neutron momentum was estimated by",
                "selecting the reaction np -> p p PI- whose total",
                "secondary particle momentum is equal to the neutron",
                "momentum."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for backgrounds due to:",
                " (1) \"glass-bottom\" events,",
                " (2) low energy neutrons,",
                " (3) secondary neutrons.",
                " Inc.neutr.mometum  (1)   (2)    (3)   Total correction",
                "   1.25             5.%   6.%    6.5%   17.5+-1. %",
                "   3.83             10.%  12.%   11.%   33+-2 %",
                "   5.09             12.%  14.5%  12.5%  39.+-2 %",
