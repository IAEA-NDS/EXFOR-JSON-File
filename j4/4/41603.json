          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "    Neutron beam was produced by stripping of deuterons",
                "on 1cm thick Al target.",
                "Neutrons outgoing at 0 deg angle relative to deuteron",
                "beam were collimated by two steel collimators to obtain",
                "5x4.7 cm2 size on the front wall of the chamber.",
                "Other particles were absent due to cleaning.",
                "Distance from target to the chamber 140m."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Quasi-monochromatic neutrons.",
