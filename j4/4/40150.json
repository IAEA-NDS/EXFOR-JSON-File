          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " - U reference sample content:",
                "U-235 - (1.640+-0.025)*10**15 nuclei,",
                "U-238 - (1.82 +-0.03 )*10**14 nuclei,",
                "U-234 - (2.30 +-0.04 )*10**12 nuclei ,",
                "determined from alpha-activity ; isotopic composition",
