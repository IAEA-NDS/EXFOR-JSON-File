          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 252-Cf of 6 mm diameter had 50 microg/cm**2 Al2-O3",
                "support.",
                "Cm-248 of 10 mm diameter had Ti support of 1.5 microm",
                " thickness."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "CSICR"
              ],
              "free_text": [
                " Two identical detectors on the basis of CsI(Tl)",
                "of 20 mm diameter, 0.5 mm long (Harshaw Chemical Comp.)",
                "and FEU-176 (Novosibirsk,Russia) with photocathode",
                "diameter 44 mm and spectral range of 300-850 nm.",
                "Positioned at distance of 4 mm on both sides of sample.",
                "Total geometry efficiency of set-up - about 60 %.",
                "Both crystals had 2.5 microm Al mylar reflector on the",
                "front polish surface.",
                "27 microm thickness Al foils were installed in front of",
                "the scintillation counters to absorb the natural",
                "alpha-activity and fission fragments.",
                " Energy resolution of each detector (E-alpha=8.78 MeV)",
                " at T1 gate was 2.8 %."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PSD"
              ],
              "free_text": [
                " Pulse shape analysis method ."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Simultaneous detection of two LCP had gate",
                " duration of 2 microsec."
              ]
            }
          ],
