          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Liquid He-3 in container. Target area 30 cm**2,",
                " thickness 3E+22 nuclei/cm**2 ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " Na-I(Tl) crystal of 10 cm diameter, 10 cm",
                "thickness, placed at 90 and 45 degrees angles relative",
                "to beam. Screen of 10 cm paraffin, 4 cm boron carbide,",
                "1 cm lead was placed between target and detector.",
                "Detector efficiency was calculated, correctness was",
                "checked (see REL-REF of R.W.Zurmuhle+) and was",
                "reconfirmed in calibrated measurements of the known",
                "partial width of direct transition ( 9.0 MeV ) for",
                "neutron capture in nickel."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For attenuation of gamma-rays by the screen.",
                " For contribution of faster neutrons."
              ]
            }
