          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The absolute total delayed neutron yields, relative",
                "abundances and half-lives of delayed neutron groups",
                "from neutron induced fission of 232Th, 233U, 236U,",
                "239Pu and 241Am"
              ]
            }
          ],
