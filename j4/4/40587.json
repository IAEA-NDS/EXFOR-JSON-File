          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " measurement of the fission cross-section for",
                " U-233 and U-235 at the neutron energy 24.5 keV"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": null
              },
              "free_text": [
                " VBR-M"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "REAC"
                ],
                "reaction": null
              },
              "free_text": [
                " Quasimonoenergetic neutrons were obtained by",
                "    means of the interference filters, consisted of",
                "    iron    195 gram/cm**2, aluminum  95 gram/cm**2,",
                "    sulphur 13 gram/cm**2 .",
                " Collimators system of 3600 mm length, output diameter",
                " 24 mm."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " In incident neutron spectrum there were the neutrons",
                " of energies 72, 133, 279, 357 keV - 3.6% of 24.5 keV",
                " neutrons.",
                " 24.5 keV neutron beam - 2.E+5 n/cm**2/sec .",
                " Additional Ti filter of 7.1 g/cm**2 to define",
                " neutrons of energy > 24.5 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Thermal neutron transmission was measured by",
                " Ge(Li) detector and \"black\" B-10 sample :",
                " for U-233 - 0.232 (+-0.8%),",
                " for U-235 - 0.244 (+-0.6%) ."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                "  Stilbene scintillation detector.",
                " For U-233 measurement - crystal  of 30mm diameter,",
                " 20 mm length.",
                " For U-235 measurement - crystal  of 40mm diameter,",
                " 40 mm length.",
                " Cf-252 source was used for neutron registration",
                " efficiency control."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " Hydrogen proportional counter SNM-38 for",
                " neutron spectrum measurement after filters."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Ge(Li) detector of about 40 cm**3 for neutron",
                " beam measurement via reaction B-10(n,A+G)Li-7 on B-10",
                " sample of 0.11 g/cm**2 , 28.35 mm diameter.",
                " Calibration of registration efficiency of stilbene and",
                "Ge(Li) detectors were made in thermal neutron beam with",
                "the same samples."
              ]
            }
          ],
