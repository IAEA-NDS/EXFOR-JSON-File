              ],
              "free_text": [
                "  Li-6 thin glass detector for neutrons",
                "Efficiency of 0.95 cm thick NE 912 glass neutron",
                "detector was determined independently by using 0.0835cm",
                "thin glass detector as a reference, whose efficiency",
                "was determined by Monte Carlo calculations."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                "  For fission fragments .",
                " Filled with 90% Ar + 10% CO2 at 3 Torr."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Cf-252 source of 10**4 fis/sec, 6mm diameter."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " 30 cm flight path.",
                " Four series of measurements: with NE 912 and NE 913",
                "glass scintillators, both with and without shadow cone.",
                " Total number of fission events 1.5*10**10 for each of",
                " four runs."
              ]
            }
          ],
