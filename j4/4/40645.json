          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Solid plastic scintillation detector of 15 mm",
                "diameter, connected with FEU-29. The recoil-proton",
                "spectrum from FEU-29 was analyzed by 50-channel",
                "amplitude analyzer after amplification."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Transmission T was determined as the ratio of",
                " the above-threshold integral recoil-proton spectra",
                " with and without the sphere.",
                " Formula was used:",
                " T=exp(-SIGne*X*N), where",
                " SIGne - nonelastic C-S,",
                " X - thickness of the sphere,",
                " N - density of nuclei ."
              ]
            }
          ],
