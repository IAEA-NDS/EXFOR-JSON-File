          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Angular distribution was measured in the range",
                " 0.24 < COS(THETA) < 1.0 , step COS(theta)=0.01;",
                " was approximated (formula (1) in JETP Letters,v.110,",
                " p.242,2019) by Legendre polynomials of 2nd and 4th",
                " order.",
                " Anisotropy was calculated by coefficients A2, A4 as",
                " W(0deg)/W(90deg)=(1+A2+A4)/(1-A2/2+3*A4/8)"
              ]
            }
          ],
