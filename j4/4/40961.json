          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FNB"
              ],
              "free_text": [
                " -High purity scandium distillate(disks of 20-25mm",
                "thickness each in form of cone):",
                "Sc-1 - 48 to 25 mm diameter,Sc(960mm)+B(0.24g/cm2)",
                "  for 2.0+-0.65 keV neutrons of 5.E+6 n/sec/cm2,",
                "  fast neutrons 24%.",
                "Sc-2 - 48 to 27 mm diameter, Sc(850mm)+Al(60mm)+",
                "  Co(30mm)+V(6.5mm)+Ti(2mm) for 2.0+-0.80 keV neutrons",
                "  of 3.E+6 n/sec/cm2, fast neutrons 7.4%.",
                "Fe - Fe(300mm)+Al(400mm)+S(70mm)+B(0.164g/cm2) of 44 to",
                "  40 mm diameter  for 24.5+-2.0 keV neutrons of",
                "  5.E+5 n/sec/cm2, fast neutrons 2%.",
                "Si - Single-crystal silicon of 114 cm thickness +",
                "  Ti(15mm)+B(0.2 g/cm2) for 144+-20 keV neutrons of",
                "~10E+7 n/sec/cm2, fast neutrons < 1%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " For neutron spectra measurement."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " For background measurement using He-3 detector."
              ]
