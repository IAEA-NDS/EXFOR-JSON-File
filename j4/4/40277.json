          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The quantity of angular anisotropy A",
                "is defined according to the statistical model",
                "of the nuclear fission.",
                "Angular anisotropy is found from the least-squares fit",
                "to measurements at various angles according to",
                "the formula W(PHI)/W(90.deg.)=1+A*COS(PHI)**2,",
                "where PHI- is angle between incident neutron direction",
                "and the fragment direction."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For nonuniformity of neutron beam on sample square.",
                " For center mass moving effect."
              ]
            }
          ],
