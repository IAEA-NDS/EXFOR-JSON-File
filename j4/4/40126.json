          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " About 7.0 microgram of Bk-249, obtained by treating",
                "curium target irradiated in SM-2 reactor; separation",
                "and purification were performed by the oxidation -",
                "reduction extractive-chromatographic method.",
                "Cf-252 content was no more than 10.E-10;",
                "Cf-249 content was less or equal to 0.3%"
              ]
