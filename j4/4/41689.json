          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Number and spectra of neutrons for fixed fragments at",
                "spontaneous fission of 252Cf"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Layer of Cf-252,diameter 7.mm, activity 1.E+5 fis/sec,",
                "on Al backing of 30 mug/cm2 thickness. Weight 1.5 mug."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Cyclic measurements with coincidence:",
                " fission fragment-neutron (calibration) -",
                "  3.28E+5 coincidences at 1st series,",
                "  1.43E+5 coincidences at 2nd series,",
                " fission fragment-fission fragment -",
                "  1.80E+5 coincidences at 1st series,",
                "  1.47E+5 coincidences at 2nd series,",
                " fission fragment-fission fragment-neutron-",
                "  1.02E+6 coincidences at 1st series,",
                "  6.00E+5 coincidences at 2nd series."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two Si surface-barrier detectors of 2 cm",
                "diameter - for FF registration."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Stilbene crystal with FEU-13 photomultiplier,",
                "placed at 50 cm distance from sample - for neutrons.",
                "Neutron detector was placed:",
                "1st series - at 8.7 deg angle between neutron and",
                "fission fragment motion, measurement time 200 hr;",
                "2nd series - 90 deg angle between neutron and fission",
                "fragment motion, measurement time 550 hr.",
                ". Detection efficiency was measured by standard Cf-252",
                "source (3.E+3 n/sec)."
              ]
            }
          ],
