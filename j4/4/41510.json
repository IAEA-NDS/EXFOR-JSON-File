          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  Pulse neutron source RADEX (Radiational experiments).",
                " System of collimators as carbon and lead disks."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Eight-sections liquid scintillator as aluminum",
                " tank of 40 l volume, 40 cm length, 40 cm diameter,",
                " with hole of 110 mm diameter; solution",
                " of scintillation admixtures and 5.5 liter of trimethyl",
                " borate B(OCH3)3 and 34.5 l of toluene C6H5CH3",
                " as scintillation liquid. For TOF spectra measurement",
                " as (n,gamma)-detector. Registration efficiency 30%,",
                " geometrical efficiency 96%, energy resolution about",
                " 30% for gamma-lines 662 keV of cesium source at",
                " voltage of +1500 V."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " He-3  cylindrical counter of high efficiency as",
                "  neutron detector in form  of cylinder of 12 cm",
                "  diameter and 3.5 cm thickness , made from stainless",
                "  steel of 1 mm thickness. Filled by gas mixture of",
                "  He-3 at 7 Athm. and Ar at 3 Athm. Thermal neutron",
                "  efficiency registration about 100%. Anode voltage",
                "  +2500 V.",
                "  Other He-3 proportional counter SNM-18 for neutron",
                "  source intensity monitoring.",
                " Lead and boron carbid protection around",
                " (n,gamma)- and neutron detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Coincidence multiplicities from pulses of eight",
                " spectrometric channels."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Flight path 50 m."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TRN"
              ],
              "free_text": [
                " Transmission measurement for total cross-sections",
                "      determination.",
                " Resonance filters from manganese and cadmium for",
                " background determination."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Thin metallic disks of 80 mm diameter."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Radiative capture reaction group cross-sections were",
                " defined from TOF spectra using normalization on",
                " U-238 standard cross-sections.",
                " Program GRUCON was used for group cross-section",
                " calculations."
              ]
            }
          ],
