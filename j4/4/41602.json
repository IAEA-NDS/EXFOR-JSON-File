          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "    Neutron beam was produced by stripping of deuterons",
                "on 1cm Al target placed inside vacuum chamber.",
                "Neutrons outgoing at 0 deg angle relative to deuteron",
                "beam were cleared from charged particles and gammas.",
                "Set of collimators was used.",
                "In HBC - neutron beam parameters :",
                "impulse resolution 2.5 %,",
                "solid angle 10**-7 sr."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Quasi-monochromatic neutrons."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Hydrogen bubble chamber - HBC."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Accuracy of track impulse measurement in HBC - 2-3 %,",
                " accuracy of angle measurement 0.5 deg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BUBLC"
              ],
              "free_text": [
                " 1 m hydrogen bubble chamber placed at about",
                "130 m from Al target.",
                "Registration of particles in 4PI geometry."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Processes of elastic np-scattering, both without",
                " (cos(ANGLEp) < 0) and with charge-exchange",
                " (cos(ANGLEp) > 0) of nucleons, are analyzed,",
                " where ANGLEp - angle of outer secondary proton in",
                " C.M. system."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For loses of counts for slow protons ."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "THEO"
              ],
              "free_text": [
                " The suggested pole model includes exchange by",
                "PI-meson, RHO-meson and in addition allows for the",
                "peripheral exchange mechanism. This model permits one",
                "to get a good description of the data of elastic",
                "np-scattering at the energy region 1-10 GeV."
              ]
            }
          ],
