          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Yield of i-th fission product at U-238 reactor neutron",
                "fission was defined as",
                "Yi(U238)=Yi(U235thrm)*(Y(238,La)*Ai(238)*A(235,La))/",
                "        (Y(235,La)*Ai(235)*A(238,La)) , where",
                "Yi(U235thrm) - yield of i-th product at U-235 thermal",
                "           neutron fission;",
                "Y(238,La),Y(235,La) - yields of La-140 at U-238 and",
                "           U-235  fission;",
                "Ai(238), Ai(235) - photopeaks areas for i-th product in",
                "           gamma-spectra of U-238 ( depleted sample)",
                "           and U-235 (enriched sample);",
                "A(238,La), A(235,La) - La-140 activities in depleted",
                "           and enriched sample."
              ]
            }
          ],
