                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "Coherent scattering amplitude."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Determined from system of equations:",
                " bi=SUM(aij * bj), where",
                " bi - coherent amplitude for i-th mixture of isotopes,",
                " bj - coherent amplitude of i-th isotope,",
                " aij - content of j-th isotope in the i-th mixture;",
                " W-180 was neglected due to its small content."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " For incoherent scattering for W-192 and W-184 ."
              ]
            }
          ],
