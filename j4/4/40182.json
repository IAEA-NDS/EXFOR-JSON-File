          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectra of gamma rays and level schemes of Xe-130 and",
                "Xe-132 from the reaction (n,gamma)."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "4RUSKUR"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The flux of thermal neutrons from the reactor IRT-M",
                " ~ 3. x 10.**7 neutrons/cm2/sec.",
                "Filters of single-crystal quartz ( 200 mm length) and",
                "bismuth (50 mm length) were used to suppress background",
                "of fast neutrons and gamma radiation from reactor."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural and enriched samples."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Direct detection of gammas",
                "Spectrum of background was measured by empty sample.",
                "Co-60 and Cs-137 sources and annihilation lines were",
                "used to define energy of Xe gamma-lines.",
                "The measurements were made in two intervals 0.4-1.5 MeV",
                "and 4.5-9.5 MeV",
                "In region 4.5-9.5 MeV the background gamma lines of",
                "O-16 and Pb were used for calibration."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "     Germanium-lithium detector with sensible",
                "volume 2.5 cm**3",
                "Energy resolution of spectrometer 6-16 keV in energy",
                "region 0.5-9 MeV.",
                "The detector efficiency was determined by measurement",
                "of gamma-ray spectrum from Cl-35 thermal neutron",
                "capture."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "G"
              ],
              "free_text": [
                "        Gammas"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "           Area analysis"
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "As energy standards in the low energy range the sources",
                "of Co-60 and Cs-137 and annihilation gamma-line were",
                "used, in the high energy range (4.5-9.5 MeV)",
                "the background gamma-lines of O-16,Cu and Pb were used.",
                "The last data from Nucl.Data,Sec.A,3,N4-6,1967 and",
                "Nucl.Data,Sec.A,5,N3-4,1969",
                "For the relative efficiency determination of the",
                "detector the data of the reaction Cl-35(n,gamma)",
                "from Nucl.Data,Sec.A,3,N4-6,1967 were used",
                "for absolute efficiency determination. In the high",
                "energy range 6.466 MeV gamma-line were used from",
                "G.A.Bartholomew,S.J.Nagvi.Bull.Amer.Phys.Soc,7,470,1962"
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction for background were introduced"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "E-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Energy errors were 1-2 keV in the high energy",
                "range and +-0.5 keV in the low energy range"
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "     Decay schemes for XE-130, -132."
              ]
            }
          ],
