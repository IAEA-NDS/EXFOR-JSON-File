          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The long-living 236Np isomer's fission cross section",
                " for thermal neutrons"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "1",
              "coded_information": {
                "facility": [
                  "REAC"
                ],
                "institute": "4RUSLIN"
              },
              "free_text": [
                "  Source of neutrons for cross-section",
                "                measurements"
              ]
            },
            {
              "pointer": "1",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "4KASKAZ"
              },
              "free_text": [
                "  Cyclotron U-150, proton energy 30 MeV,",
                "       average current 8. microAmp, used for Np-236",
                "       preparation from reaction U-238(p,3n)Np-236-m2"
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                "  Horizontal thermal neutron beam with Maxwell",
                "  spectrum having temperature 330 deg. Cadmium ratio",
                "  on U-235(N,F) is 42.7 +- 2.4 for Cd thickness 1 mm.",
                "  Neutron flux 2.E+8 n/cm2/sec ."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Np-236 was electrolitically extracted on stainless",
                " steel backing. Sample mass is 36.2 +- 1.3 nanogram",
                " - average of 37.9+-1.5ng (measured by gammas via GeLi)",
                " and 35.2+-1.2ng ( measured by mass-spectrometer using",
                " isotopes ratio",
                " Np235/Nm236m/Np237=(0.053+-0.004)/(0.1385+-0.0014)/1.",
                " Np-237 content is 254 +- 8 nanogram.",
                " U-235/U-238/Np-237 mass ratio is 0.011/0.044/1.",
                " Pu-236 admixture is 8.E-5 nanogram"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                "  MIca detector for fission cross-section",
                "         measurement.",
                "         Detection efficiency 96.+-1. % ."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "  Ge-Li detector for Np-236 mass measurement",
                "        on induced gamma activity using Cd filter.",
                "  Detection efficiency 0.0239+-0.0005 in gamma energy",
                " about 160 keV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CADMB"
              ],
              "free_text": [
                " Measurement with and without Cd shield."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "  For U-235 fission contribution - 1.6%.",
                " Np-235, Np-237, U-238 , Pu-236 contributions were",
                " neglected.",
                " For contribution of Np and U fission by epi-cadmium",
                " neutrons - 0.4 % ."
              ]
            }
          ],
