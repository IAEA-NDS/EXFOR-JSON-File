          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gallium-nickel alloy (Ga4-Ni) of 3 mm in thickness",
                "compressed in a copper target holder. The front face",
                "was covered by a 24 micron titanium foil. During",
                "irradiation the target was cooled at the back by a",
                "water flow and at the front by a current of helium. By",
                "this system the target may be irradiated with a 45",
                "microampere proton current of 20 MeV for about 60",
                "hours."
              ]
            }
          ],
