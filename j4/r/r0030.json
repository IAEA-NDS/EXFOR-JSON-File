          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isolation procedures of radiokrypton from target",
                "materials irradiated with 65 MeV protons and 40 MeV",
                "3He particles were discussed. Thick target yields of",
                "76Kr and 77Kr through the particle energies of up to",
                "40 MeV for the 34Se(3He,xn) reaction were given."
              ]
            }
          ],
