          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calcium fluoride of enriched Ca was distilled in vacuum",
                "on to tantalum discs of 0.25mm thick. Thickness of",
                "deposited targets was about 200ug/cm2 which could be",
                "reproduced with a relative precision of about 4%. The",
                "The thickness of each target was determined by",
                "weighing. Up to 12 sample discs were mounted on a",
                "rotating sample holder in a vacuum chamber and rotated",
                "at about 100 rpm. Al foils of different thicknesses",
                "were placed in front of each target in order to obtain",
                "data at 12 different deuteron energies simultaneously.",
                "Accurate beam flux measurements were made in a faraday",
                "cup with single targets at different bombarding",
                "energies. The relative precision of the beam current",
                "measurements was 0.1% and its accuracy about 1%."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy spread in the incident beam was lass than 0.1%."
              ]
            }
          ],
