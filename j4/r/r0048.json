          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uncertainties in counting efficiency was +-10%, in",
                "beam current integration +-3%, in target thickness",
                "measurements +-2% and in certain cases uncertainties",
                "in the resolution of decay curves +-5 to 15% were",
                "included. The loss of 95Ru activity from target foils",
                "by recoil following the 92Mo(a,n) reaction was",
                "measured for the thinnest foils employed (7.21 mg/cm2)",
                "at 20.2 MeV incident energy and found to be 3% of that",
                "retained in the foil. So any errors from recoil losses",
                "were considered negligible compared with errors from",
                "other sources."
              ]
            }
          ],
