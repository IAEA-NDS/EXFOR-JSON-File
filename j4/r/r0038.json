          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Argon:Contained in a cylindrical brass chamber with a",
                "   thin aluminium window. The chamber was lined with",
                "   1.8mg/cm2 aluminium foil. Over 90 percent of the",
                "   chlorine activity settled on this liner and could",
                "   be recovered by removing the liner after",
                "   bombardment.",
                "   Incident deuteron energy was degraded with iron",
                "   foils of appropriate thickness placed immediately",
                "   in front of the aluminium window.",
                "Zinc:Fine zinc oxide powder was settled on a 1.8",
                "   mg/cm2 Al foil coated with about 0.2 mg/cm2 shellac",
                "   the foil was heated briefly in an oven which soften",
                "   the shellac and binds the target tightly to the Al",
                "   foil. Zinc oxide thickness was 5-8 mg/cm2."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Undegraded incident beam energy was 15.5 +- 0.1 MeV."
              ]
            }
          ],
