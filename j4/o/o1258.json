          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated thin hydrocarbon a-C-d-film. The thickness",
                "of the film was measured with tactile profilometry to",
                "be 50 nm. A 8.5 nm thick Au film was evaporated on the",
                "a-C-D film to make a dose correction of 3He ions via",
                "RBS. The thickness of the Au film was determined by RBS",
                "at three points of the sample. The thickness",
                "homogeneity of the Au film was better than 99.5%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "  The detector located at an angle of 135 degree",
                "a parabolic slit with a width of 3mm and height of",
                "17mm. The detector target distance is about 40 mm. The",
                "detector depletion depth is 2000 um.",
                "The 144.5-degree detector aperture is circular with a",
                "diameter of 18 mm. The detector-target distance",
                "is 100 mm. The detector depletion depth is 1500 um",
                "thick.",
                "The detector at 175-degree is an annular detector with",
                "an inner diameter of 11.8 mm and an outer diameter of",
                "17 mm. The detector-target distance is 84 mm. Its",
                "geometrical solid angle is 16.3 msr and it has a",
                "depletion depth of 2000 um."
              ]
            }
          ],
          "FACILITY": [
