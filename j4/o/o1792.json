          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A HPGe gamma-detector with 5% absolute",
                "efficiency at 188 keV was used to identify 239Cm by",
                "gamma-spectroscopic measurements."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Passivated Implanted Planar Silicon detector.",
                "Samples were first measured by gamma-spectroscopy to",
                "monitor the chemical yield of Pm, and then were assayed",
                "for alpha-activities by 450 mm**2 PIPS detectors"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By* authors*.Cross sections were also calculated from",
                "the abundance and efficiency-corrected measured alpha-",
                "activities 238Cm and 240Cm and gamma-activities 239Cm,",
                "taking into account the number of 232Th atoms in the",
                "target, the integrated beam intensity, and assuming",
                "that 100% of the products of interest recoiled out of",
                "the target and were collected in the copper catcher",
                "foils."
              ]
            }
          ],
