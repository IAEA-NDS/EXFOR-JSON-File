          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Th-232 targets were prepared by molecular plating",
                "The target consisted of three banana-shaped segments on",
                " 15-mum thick Be with thicknesses of 900, 910, and",
                " 1000 mg/cm**2.",
                "The stationary targets, 360 mg/cm**2 Th on 15 mum Be",
                "and 1-mum Cu catcher foils were used to confirm that no",
                "products were lost in the set up with the rotating",
                "wheel and to further reduce the background."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Actinide separation"
