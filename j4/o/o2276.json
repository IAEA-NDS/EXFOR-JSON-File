          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A radioactive neutron-rich beam of 98Rb at a nominal",
                "energy of 2.85 MeV/nucleon with an average intensity of",
                "2.0*E+04 particles per second was sent onto a",
                "1.5-mg/cm**2-thick 7Li enriched LiF target. Due to",
                "energy loss, the beam energy at midtarget was",
                "2.49 MeV/nucleon."
              ]
            }
          ],
