          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The cross-sections for the production of",
                "the isotopes Th-214 and Th-213 cannot be obtained",
                "individually for these isotopes, because their ground-",
                "state properties(alpha energies and half-lives) are",
                "almost identical. These values include the production",
                "of the ground states directly in the reaction and",
                "feeding by the decay of the isomers."
              ]
            }
          ],
