          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The He-6 beam was produced by the Li-7(p,2p)He-6",
                "reaction in a LiF powder target with a graphite",
                "container. The atomic beam was ionized in an ECR ion",
                "source, purified by magnetic separation  and re-",
                "accelerated in the Cyclone-110 at the CRC facility."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "82-PB-208",
                "field_identifier": "ENR",
                "value": 0.87
              },
              "free_text": [
                " A self-supported foils of enriched",
                "Pb-208(87%) with a thickness of 0.950-mg/cm**2 were",
                "used as target for the 12 MeV He-4 and 14, 16, 18 MeV",
                "He-6 beams and  2.080-mg/cm**2 for the 22 MeV He-6 beam",
                "The latter was used to compensate for the low intensity",
                "of the beam."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "82-PB-208(A,EL)82-PB-208,,DA",
                  "code_unit": [
                    {
                      "unit": "82-PB-208(A,EL)82-PB-208,,DA",
