          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The B-10 targets were prepared by electromagnetic",
                "deposition of the isotope on copper. Two thin targets",
                "of 90 ug/cm2 and 120 ug/cm2 (accurate to 10%) and",
                "one thick target,400 mug/cm**2, were used. The",
                "thickness of this last target was determined by",
                "weighing the backing foil before and after deposition."
              ]
            }
          ],
