          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two series of zinc targets, thicknesses 179 and",
                "4.13 mg/cm**2, isotopic composition:",
                "Zn-64 48.9%, Zn-66 27.8%, Zn-67 41%, Zn-68 18.6%,",
                "Zn-70 0.6%, were used."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "TTY-C"
              ],
              "free_text": [
                " Evaluations were made both of target thickness",
                "and proton energy in order to optimize the Ga-67",
                "production rate at the same time minimizing",
                "contamination by the Ga-66.  Optimal irradiation",
                "conditions, depending both on the beam current",
                "available and on the power dissipated into the target",
                "were determined."
              ]
            }
          ],
