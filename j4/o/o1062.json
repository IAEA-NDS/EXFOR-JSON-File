          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Optimization of irradiation parameters for Ga-67",
                "production from Zn-nat(p,xn) nuclear reactions."
              ]
            }
          ],
          "AUTHOR": [
            {
