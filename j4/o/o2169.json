          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 8He beam was produced by the ISOL technique",
                "and accelerated to 15.4 A*MeV by the CIME cyclotron at",
                "the SPIRAL facility via the fragmentation of a 75 A*MeV",
                "C-13 beam in a thick carbon target."
              ]
            }
          ],
