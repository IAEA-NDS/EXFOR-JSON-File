          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A deuterium-enriched polypropylene targets (CD2)n of",
                "320 mug/cm**2 or 550 mug/cm**2 thickness."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "CSICR"
              ],
              "free_text": [
                "  four telescopes of the new MUST2",
                "Si-strip array at forward angles. The first stage",
                "is a 300 mum thick double-sided Si-strip detector with",
                "an active area of 10*10 cm**2 and a 4 cm-thick CsI-",
                "crystal detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " a 20*20 mm**2, 1 mm thick NE102 plastic",
