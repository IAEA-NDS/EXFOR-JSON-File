            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " The gamma-rays were detected with a 14-cm**3",
                "Ge(Li)-detector or with a 7.6-cm*7.6-cm NaI(Tl)",
