          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting targets of Pb-208, enriched to 99.3%,",
                "were prepared by evaporation.  The metal was evaporated",
                "onto approximately 30-mug/cm**2 carbon films.  Fairly",
                "homogeneous targets of 60-150-mug/cm**2 thickness of",
                "Pb-208 were obtained.  The main impurity in the target,",
                "apart from carbon and oxygen was 0.7% of Pb-207."
              ]
            }
          ],
          "ADD-RES": [
            {
