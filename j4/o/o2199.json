          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets approximately 1.0 mg/cm**2 thick,were obtained",
                "by evaporating tellurium enriched to 98.7% in Te-126",
                "and 97.8% in Te-128 onto 0.25 mm thick gold backing.",
                "In the case of the Te-126 targets additional",
                "measurements were made using 0.25 mm thick tantalum",
                "backing because of contamination of important gamma-",
                "rays by gamma rays from the gold backing"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Gamma ray linear polarizations were measured at",
                "90 degrees to the beam direction using a three Ge(Li)",
                "Compton polarimeter.",
                "An escape-suppressed spectrometer was used to measure",
                "the angular distributions."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections were made for gamma-ray absorption in the",
                "target backing material."
              ]
            }
