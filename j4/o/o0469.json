          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Foils of Natural Uranium, 0.002-In. thick, Cleaned with",
                "Nitric Acid Before Irradiation were used as targets.",
                "Stacks of Aluminum foils, irradiated with the Uranium",
                "targets, served as recoil catchers and monitors of the",
                "Proton-Beam intensity by the Al-27(P,N+3P)Na-24",
                "reaction."
              ]
            }
          ],
