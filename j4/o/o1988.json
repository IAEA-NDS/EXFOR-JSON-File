          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BAF2"
              ],
              "free_text": [
                " The Karlsruhe 4 pi BaF(2) detector, consisting",
                "of 42 independent modules forming a spherical shell of",
                "BaF(2) that is 15 cm thick and has an inner radius of",
                "10 cm."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The C-12 was deposited with an energy of only 200 eV",
                "on a gold-coated copper backing or directly onto a very",
                "pure 99.9999% copper backing until very stable layers",
                "between 30 and 120 mug/cm**2 had been obtained. The",
                "120 mug/cm**2 thick samples could preferentially be",
                "used for improving the measured count rates at low",
                "energies, because the energy loss in the sample",
                "required only a comparably small correction"
              ]
            }
          ],
