                "code_unit": [
                  {
                    "unit": "J,PR,180,1122,1969",
                    "doi": "10.1103/PhysRev.180.1122",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR",
                        "number": null,
                        "volume": "180",
                        "part": null,
                        "issue": null,
