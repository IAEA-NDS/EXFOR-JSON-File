          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-energy-proton fission cross sections of U,Bi,Au",
                "and Ag measured with mica track detectors"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Hudis",
                "S.Katcoff"
              ],
              "free_text": [
                ""
              ]
            }
          ],
