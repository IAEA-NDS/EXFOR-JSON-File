          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were prepared using Yb(2)O(3) which was",
                "reduced by Hf and subsequently evaporated onto 1 mm",
                "thick high-purity Al backings. The isotopic",
                "enrichment in Yb-168 amounts to 35.2+-0.5%(for one",
                "target 13.7+-0.5%), an areal particle density of Yb-168",
                "target nuclei of 1.7*10E+17 1/cm**2 to",
                "5.2*10E+17 1/cm**2."
              ]
            }
          ],
