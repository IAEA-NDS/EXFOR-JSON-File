          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NIM/B,267,3500,2009",
                "code_unit": [
                  {
                    "unit": "J,NIM/B,267,3500,2009",
                    "doi": "10.1016/j.nimb.2009.08.016",
                    "field": {
                      "reference_type": "J",
                      "reference": {
