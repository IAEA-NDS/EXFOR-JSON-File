          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fissioning layers on aluminium backing, thickness of",
                "1 mg/cm**2, were used."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " Theoretical model.",
                "Authors were measured relative fission cross section",
                "for deuterons, for Bi-209, Th-232, U-238 and Np-237",
                "were measured the number fission nuclei on 1-mg",
                "targets materials, it is 803+-90, 3622+-360, 4410+-440,",
                " 4429+-440, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Solid-state nuclear track detectors (SSNTD)",
                "based on a 6-mu-m film from Dupont polyester fiber (its",
                "commercial name is Dacron), which were adjacent to",
                "fissile layers."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "13-AL-27(P,X)11-NA-24,CUM,SIG",
                  "code_unit": [
                    {
                      "unit": "13-AL-27(P,X)11-NA-24,CUM,SIG",
