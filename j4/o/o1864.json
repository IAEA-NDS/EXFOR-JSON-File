          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The two resonances at E-cm=65 keV and E-cm= 183 keV,",
                "which dominate the reaction rate inside the Gamow",
                "window, have been observed, and the strength of the",
                " 65 keV resonance has been deduced."
              ]
