          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of uranium and neptunium-oxide (236,238U(3)O(8)",
                "and 237Np-O(2)) were prepared by multiple thermal",
                "decomposition of uranium or neptunium nitrate cellulose",
                "painted on 10-mum, 50-mum and 100-mum thick Al-backing.",
                "The average thickness of the actinide layer was 60-120",
                "mug/cm**2 for the thin targets and 1.5-2-mg/cm**2 for",
                "the thick targets. The thickness variations were within",
                " 3% for all types of targets used."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "TTY-C"
              ],
              "free_text": [
                ".The calculated thick-target yield of Np-235",
                " at 42.4-MeV projectile energy is 5.8-kbq/mua*hr."
              ]
            }
          ],
