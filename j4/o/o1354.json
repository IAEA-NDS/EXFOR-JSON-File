          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " For alpha activity of Pu-236 and Pu-238.",
                "The energy resolution of the alpha spectrometers was",
                " 20-35-KeV at 5767-KeV. The efficiency errors were 3-",
                " 6%, but as a results of the negative covariance",
                " coefficients the error of the efficiency ratio was",
                " less than 1% for all alpha detector assemblies."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " And hpge-detector for X-ray activity of Np-235",
                " and Pu-237. Gamma spectra were measured with energy",
                " resolutions of 1.8-KeV at 1332.5-KeV. The error of the",
                " gamma detector efficiency was about 2%."
              ]
            }
          ],
