          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pure iron (5.8% 54Fe, 91.8% 56Fe, 2.15% 57Fe,",
                "0.25% 58Fe) thin rolled high purity iron foils. The",
                "average thickness was determined to (16.41 +-0.18) mum."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ".A Liquid nitrogen cooled high purity Ge detector",
                " The cylindrical crystal has a diameter of 5.45 cm and",
                "a length of 6.44 cm this results in a volume",
                "of 150.25 cm3."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".The ALICE code uses the Hybrid model and the",
                "Weisskopf-Ewing evaporation model. Additionally,",
                "different nuclear level densities, the Fermi level",
                "density (FLD) and the Kataria-Rarnamurthy level",
                "density (KRLD), were used."
              ]
            }
          ],
