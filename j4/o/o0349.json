          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "ISOCY"
                ],
                "institute": "2SF ABA"
              },
              "free_text": [
                ".The 103 cm AVF Cyclotron (MGC-20)."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets of uranium-oxide (U(3)O(8)) and neptunium-oxide",
                " (NPO(2)) were prepared by multiple thermal",
                "decomposition of uranium nitrate and neptunium nitrate",
                "painted on 0.1 mm and 6.03 mum thick aluminium",
                "backings, respectively. The transformation was",
                "ascertained using alpha-spectrometry and direct",
                "weighing.   The  average  thickness  of the 236-U-oxide",
                "layer was 100 mug/cm**2 and that  of  the  Np-237-oxide",
                "layer   110  mug/cm**2. The  thickness variations  were",
                "within 3%.  The average thicknesses were determined by",
                "weighing."
              ]
            }
          ],
          "ERR-ANALYS": [
