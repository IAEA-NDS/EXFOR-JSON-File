          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton and He-3 induced nuclear reactions in uranium",
                "and neptunium targets. Production of neptunium and",
                "plutonium tracers with a low-energy cyclotron."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Aaltonen",
                "E.Karttunen",
