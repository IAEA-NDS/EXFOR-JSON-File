          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Bismuth-209 was Used As Target.",
                "Bismuth was Evaporated on to the Aluminum Foils to a",
                "Thickness of About 100 Mug/Cm**2 Over an Area of",
                " 16 Cm**2."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".Statistical Model.",
                "Threshold of the Bi-209(P,2N)Po-208 Reaction.",
                "Total Cross Section."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Total Alpha Activity of Each Foil was Measured",
                "After the Proton Bombardment and then the Foils were",
                "Pulse Analyzed to Determined the Relative Amounts of",
                "The Polonium Isotopes Produced.",
                "Other Information is Absent."
              ]
            }
          ],
