          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets consisted of approx. 100-mug/cm**2 Ca-40,",
                "greater than 99% enrichment, evaporated onto thin",
                " 5-mug/cm**2 carbon backing.",
                "The targets were evaporated, transferred, stored and",
                "bombarded in carbon free vacuum system, thus minimizing",
                "contamination by oxygen, hydrogen and carbon."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "",
                "A ninefold delta-E-E ionization chamber surface barrier",
                "detector system."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "79-AU-197(4-BE-9,EL)79-AU-197,,DA",
                  "code_unit": [
                    {
                      "unit": "79-AU-197(4-BE-9,EL)79-AU-197,,DA",
                      "field": {
                        "reaction": "79-AU-197(4-BE-9,EL)79-AU-197",
