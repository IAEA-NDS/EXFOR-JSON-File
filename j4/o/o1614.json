          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A 10 mg/cm**2 thick polypropylene target, density",
                "of 0.896 g/cm**3.",
                "With the polypropylene reaction target containing both",
                "hydrogen and carbon nuclei."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Be-10,11 secondary beams were produced by the",
                "fragmentation of a 75 MeV/nucleon primary O-18 on a",
                "carbon production target located between the two",
                "superconducting solenoids of the SISSI  device. The",
                "Be-10,11 beams were obtained at energies of 39.1A and",
                " 38.4 A MeV, with intensities of the order 10E+5 pps",
                "and 3.4 x 10E+4 pps, respectively."
              ]
            }
          ],
          "MONITOR": [
