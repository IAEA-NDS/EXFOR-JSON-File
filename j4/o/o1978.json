          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The F-17 radioactive beam was produced at the EXOTIC",
                "facility by means of the in-flight technique and by",
                "using the reaction 1H(17O,17F)n. The 17O primary beam",
                "was delivered from the LNL-XTU Tandem Van de Graaff",
                "accelerator with an intensity of approx.70 to 100 pnA",
                "and at an energy of 105 MeV."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 0.93 mg/cm**2 thick CH(2) target was used."
              ]
            }
          ],
