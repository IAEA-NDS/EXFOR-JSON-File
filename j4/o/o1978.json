          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " The DINEX Si-detector array consists of four",
                "triple Si telescopes. Each telescope provided three",
                "detection stages-delta-E1=40 mum double-sided silicon-",
                "strip detector(DSSSD), delta-E2=500 mum silicon pad",
                "detector and E-res=1000 mum DSSSD."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
