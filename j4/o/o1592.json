            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The Ne-18 atoms were produced via the F-19(p,2n)",
                " reaction by bombarding a LiF target with an intense",
                " 30 MeV proton beam from the CYCLONE30 cyclotron."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2BLGLVN"
              },
              "free_text": [
                " CRC-RIB facility at Louvain-la-Neuve,",
                " Belgium. The Ne-18 beam was post-accelerated to",
                " 66 MeV by the CYCLONE110."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
