              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two targets were used-a scattering target of 206Pb",
                "metal, 97% with a thickness of 0.5 mg/cm**2 evaporated",
                "onto a 0.042 mg/cm**2 carbon foil and an activation",
                "stack of targets formed by evaporating 206PbS compound",
                " 94% onto Ti foils used for the fusion measurement."
              ]
            }
          ],
          "DETECTOR": [
