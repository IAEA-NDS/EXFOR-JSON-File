              ]
            },
            {
              "pointer": "3",
              "coded_information": [
                "P"
              ],
              "free_text": [
                " Protons Scattered by the Monitor Film."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Faraday Cup was Used For Absolute Calibration of the",
                "Beam Monitors Described in 'Detector'."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Performed: For Neutrons Produced in the Beam Monitor",
                "Film, the Ionization Chamber, and the Target Frame, by",
                "Making Empty-Target Measurements.",
                "For Change of Efficiency Due to Neutron Interactions",
