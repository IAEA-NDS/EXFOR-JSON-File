          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " It is assumed that the shape of the angular",
                "distribution of gamma rays does not depend on",
                "the energy.  Then the intensity of the gamma rays",
                "emitted in the direction 90 degrees and corrected with",
                "respect to gamma feeding is proportional to the total",
                "cross section for the excitation of the 2+ level by",
                "inelastic proton scattering."
              ]
            }
