          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectroscopically purity yttrium and terbium stacks,",
                "enrichment 99.9%, were prepared by the vacuum",
                "evaporation technique. The samples were prepared from",
                "yttrium oxide and terbium oxide, by depositing",
                "uniformly on aluminium foils of thickness 6.75",
                "mg/cm**2.  Thickness of Y-89 and Tb-159 deposits were",
                "790 and 800 mug/cm**2, respectively."
              ]
            }
          ],
