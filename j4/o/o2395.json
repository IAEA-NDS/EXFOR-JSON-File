            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " JYFLTRAP double Penning trap mass spectrometer."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ASEP"
              ],
              "free_text": [
                " Phase-imaging ion cyclotron- resonance (PI-ICR)",
                "technique allowing states with energy separation as",
                "low as 100 keV can be resolved."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The isomeric yield ratio is defined as the high-spin",
                "state yield over the total yield of the isotope."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Correction applied for the radioactive decay losses due",
                "to 22-512 ms ion accumulation in the cooler.",
                "The total time the ions spend in the Penning traps",
                "varies from 420 to 922 ms."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties of the isomeric yield",
                "ratios include the statistical uncertainty, as well",
                "as the uncertainty due to applied corrections."
              ]
            }
          ],
