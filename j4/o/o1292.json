          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supported target with the following isotopic",
                "composition- Pb-208 87(2)%, Pb-207 1.20(2)%, Pb-206",
                " 11.2(2)%. A target of 0.950-mg/cm**2 thickness was",
                "used for each energy except for 22 MeV, where beam",
                "intensity was lower and a thickness of 2.080-mg/cm**2",
                "was used."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "82-PB-208(A,EL)82-PB-208,,DA",
                  "code_unit": [
                    {
                      "unit": "82-PB-208(A,EL)82-PB-208,,DA",
                      "field": {
                        "reaction": "82-PB-208(A,EL)82-PB-208",
                        "target": "82-PB-208",
                        "projectile": "A",
                        "process": "EL",
                        "product": "82-PB-208",
                        "quantity": ",DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " this reaction was",
                " measured to normalize data and to cancel systematic",
                " errors in the He-6+Pb-208 elastic cross sections."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SISD"
              ],
              "free_text": [
                " The reaction products were detected",
                "in a detection system consisting of a LEDA, a LAMP and",
                "DINEX. LEDA- silicon strip detectors. The DENIX",
                "detector array consists of four 90-degree circular",
                "silicon telescopes, of thickness 40 mum(front) and",
                " 500 mum(back). LEDA, LAMP and DINEX detector arrays",
                " cover three different angular ranges-",
                " -LEDA 5-10-degree with an angular resolution of 0.5-",
                " degree,",
                " -LAMP 20-64-degree with an angular resolution of",
                " 3-degree,",
                " -DENIX 135-170-degree with angular resolution of 5-",
                " degree."
              ]
            }
          ],
