          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets studied were enriched isotopes from iron to",
                "zinc. For this particular mass range, strong self-",
                "supporting targets are readily available, thicknesses",
                "of less than 3 mg/cm**2,with isotopic purity exceeding",
                " 95%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " High--energy proton spectra were obtained."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "G-SPC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " The protons were detected at 90 degr. to the",
                "beam by a 6.4*15.2 cm Na-I crystal surrounded by an",
                "anti-coincidence annulus of NaI as well as by a",
                "massive amount of shielding designed to keep down the",
                "effects of neutrons. The detector crystal (at 84 cm",
                "from target) viewed the target through a 5.1 cm inner",
                "diam. lead pipe filled with Li(6)-H."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "SHAPE"
              ],
              "free_text": [
                " Response Function."
