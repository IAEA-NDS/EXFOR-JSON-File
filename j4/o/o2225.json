          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A relative normalization of the measurements at",
                "48.8 MeV and 59.8 MeV excess energy is obtained from",
                "the simultaneous analysis of the p+d-> 3He + PI",
                "reaction. The acceptance and cross section corrected",
                "ratio of the respective pi-yields corresponds to the",
                "ratio of the integrated luminosities. For both energies",
                "the acceptances were found to be identical within their",
                "uncertainties."
              ]
            }
