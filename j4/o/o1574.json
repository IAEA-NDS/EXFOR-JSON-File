          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Effect of the alpha-transfer reaction on the elastic",
                "scattering of C-12+Mg-24."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
