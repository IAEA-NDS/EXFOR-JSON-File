              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,26,2487,1982",
                "code_unit": [
                  {
                    "unit": "J,PR/C,26,2487,1982",
                    "doi": "10.1103/PhysRevC.26.2487",
                    "field": {
                      "reference_type": "J",
