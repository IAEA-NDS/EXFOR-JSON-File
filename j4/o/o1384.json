          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of plutonium tracers in 237-Np nuclear",
                "reactions with 3-He-ions in the energy range from 26 to",
                "60 MeV"
              ]
            }
          ],
