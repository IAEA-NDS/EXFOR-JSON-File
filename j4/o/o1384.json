          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neptunium layers were prepared by multiple thermal",
                "decomposition of neptunium nitrate on 10 mumeters thick",
                "aluminium backings.  The thickness of the 237-Np layer",
                "on each target was about 100 mug/cm2."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2SF JYV"
              },
              "free_text": [
                " K-130 cyclotron."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Two sets of eight targets each separated by 10",
                "mumeters thick aluminium foils were irradiated in two",
                "irradiations."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " 40 MeV He+ and 60 MeV He++ ion beams the beam",
                "current in both irradiation was about 3 micro-amperes."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " During 12 (40 MeV) and 4 (60 MeV) hours."
              ]
            },
