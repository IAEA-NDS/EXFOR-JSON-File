          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron orbit sizes in the ground states of the",
                "molybdenum isotopes."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "S.Sen",
                "R.Chapman",
                "J.L.Durell",
                "J.N.Mo",
                "A.Simcock",
                "P.Woods"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2UK MAN"
              ],
              "free_text": [
                ". Schuster Laboratory, Dep. of Physics, UK."
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,JP/G,9,99,1983",
                "code_unit": [
                  {
                    "unit": "J,JP/G,9,99,1983",
                    "doi": "10.1088/0305-4616/9/1/015",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "JP/G",
