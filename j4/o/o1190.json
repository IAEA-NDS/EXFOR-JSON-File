              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2UK MAN"
              },
              "free_text": [
                " 6 MV Van de Graaff accelerator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isotopically enriched targets of molybdenum-",
                "Mo-92 98.5%, Mo-94 95.6% and Mo-96 97.7%, rolled",
                "down to an approximate thickness of 250-300-mug/cm**2",
                "were used as targets."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The charged reaction products were detected in",
                "an array of seven Ortec surface-barrier detectors"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Three delta-E-E counter telescopes, thickness",
                " of the E and delta-E counters were 300-500 mum and",
                " 40-50 mum, respectively for identification of deuteron",
                " groups in the presence of elastically scattered",
                " tritons."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The triton elastic scattering cross",
                "sections were determined for each molybdenum target",
                "by comparing the triton yields with those from the gold",
                "target for which the cross sections follow the",
                "Rutherford scattering predictions."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".DWBA analysis.",
                " A typical particle energy spectrum, measured during",
                "the bombardment of a Mo-92 target with 4.50 MeV tritons",
                "was represent on fig 1.",
                "Triton and deuteron energy spectra from the Mo-96(t,d)",
                "reaction measured at an angle of 152.4 degree and with",
                "a triton bombarding energy of 4.50 MeV were represent",
                "on fig 2."
              ]
            }
          ],
