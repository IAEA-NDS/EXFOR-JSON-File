          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin samples were prepared by electrolytic deposition",
                "of 122-Te on 25 mumeters thick Ti foils of 13 or 15 mm",
                "diameter.",
                "The tellurium deposit (2-4 mg/cm-sq) was covered by 10",
                "mumeters thick aluminium foil and the sandwich sample",
                "Ti-122-Te-Al was then read for irradiation.",
                "Isotopic composition:",
                "120-Te - <0.05%,",
                "122-Te - 97.12%,",
                "123-Te - 0.15%,",
                "124-Te - 0.23%,",
                "125-Te - 0.28%,",
                "126-Te - 0.70%,",
                "128-Te - 1.06%,",
                "130-Te - 0.46%."
              ]
            }
          ],
