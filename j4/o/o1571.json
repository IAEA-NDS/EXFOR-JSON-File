              "coded_information": null,
              "free_text": [
                "The target consisted of self-supporting Al(2)O(3) with",
                "thickness of 350 mug/cm**2, was used."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
