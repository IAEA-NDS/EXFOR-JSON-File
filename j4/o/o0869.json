                "institute": "2SF HLS"
              },
              "free_text": [
                " The 7-Li(2+) ion beam was generated by",
                "the 5 MV EGP-10-II tandem accelerator"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2SF HLS"
              },
              "free_text": [
                " The 4-He+ ion beam from the 2.5 MV Van de",
                " Graaff accelerator."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                "  A silicon surface barrier detector [100 mm**2,",
                "60 mum] positioned at a scattering angle of 170",
                "degrees.  The energy resolution of the detection system",
                "was 28 KeV at E/Li= 3 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                " An Sn-O/2 layer vacuum evaporated on a carbon",
                "substrate was used for obtaining the elastic scattering",
                "cross-sections for oxygen.  For reference purposes a",
                "thick target of the carbon substrate material was also",
                "used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MOMIX"
              ],
              "free_text": [
                " For the absolute oxygen cross section values",
                "the Rutherford cross section for tin was assumed to be",
                "valid."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
