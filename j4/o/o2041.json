          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Th-232, U-235, U-238, Pu-239, Pu-242, Am-241 and Am-242",
                "targets were used. The Th-232 target was a thin foil of",
                "natural metal prepared by rolling specimen sandwiched",
                "between chromium-plated steel plates. Uranium targets",
                "were prepared by vacuum evaporation of the oxides into",
                "thin carbon foils. The Pu and Am targets were prepared",
                "by the molecular plating method. The targets material",
                "was placed onto the Ni side of a Ni-Cu foil which",
                "consisted of 225 mug/cm**2 Ni supported on a approx.",
                "2 mg/cm**2 Cu backing. Target thicknesses were in most",
                "cases determinate from the alpha-disintegration rates",
                "measured with a 2pi gas flow proportional counter. The",
                "electrodeposited targets were typically of thickness",
                "100-400 mug/cm**2."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " No production of an isomer (20 ms< T(1/2)< 1 hr) was",
                "detected in 232Th, 235,238U, 239Pu and 241,243Am(d,2n)",
                "at E(d)=12 MeV and 243Am(p,2n) reaction at E(p)=13 MeV"
              ]
            }
