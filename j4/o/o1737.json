          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural molybdenum foil, 99.99% pure, 25.7 mg/cm**2",
                " +-1.4% thickness was used as targets.",
                "Two stacks containing 7 and 9 Mo foils respectively",
                "were separately irradiated by 15 and 18 MeV initial",
                "proton energy.",
                "Al foils inserted in the target assembly served as",
                "energy absorbers. Copper foils of 10 and 20 mum thick",
                "inserted between the target stacks were used for",
                "monitoring of proton energy and current."
              ]
            }
          ],
