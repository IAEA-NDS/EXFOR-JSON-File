          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin Th-232 targets were prepared by sputter deposition",
                "from a Th-232 metal source in an Ar plasma as thin",
                "films. Zinc or Al foils of 200 mum thickness(99.99%)",
                "were used at appropriate positions in the stacks as",
                "proton-energy degrader. A copper foil of 12.5 mum",
                "thickness(99.99%) was placed as a monitor foil."
              ]
            }
          ],
