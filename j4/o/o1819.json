          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting foil of isotopically enriched 99%",
                "Sn-116 with thickness of approximately 500 mug/cm**2",
                "was used."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".Multistep DWBA calculations.",
                "Energy spectra of Sn-116(p,t)  and Sn-116(p,d) at",
                "E(p)=25.1-MeV were observed."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Four detector telescopes each consisting",
                "of a combination of a 200-mum and a 2-mm thick silicon",
                "detector."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*EN-RSL-FW*.The overall energy resolution."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
