          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Radioisotopes were identified by half-life",
                "and, in some cases, by beta-radiation energy",
                "determined by absorption in aluminium foils.",
                " The total fission cross section was determined",
                "from the integrated area under the mass yield curve."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Performed: self-absorption and self-scattering in the",
                "sample, absorption of the radiation in sample cover,",
                "in air and in the counter window. Reflection of the",
                "radiation from sample backing. Solid angle corrections.",
                " Additional corrections performed for products",
                "decaying by electron capture: counter efficiency and",
                "fluorescent yield."
              ]
            }
          ],
