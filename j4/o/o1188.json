          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The overall normalization was determined",
                "from the target thickness, measured detector solid",
                "angle and the integrated beam current recorded in",
                "a Faraday cup behind the target.",
                "The target thickness(140-mug/cm**2) was only a nominal",
                "value determined during the manufacturing process.",
                "The normalization was checked by comparing the most",
                "forward angle elastic scattering data(11.6-degree) with",
                "tabulated cross section(see A.M.Shahabuddin, 1973,",
                "Thesis University of London) for the elastic scattering",
                "of 42.6 MeV alphas on Mg-25. This comparison suggested",
                "a target thickness of 134-mug/cm**2 compared with the",
                "nominal 140-mug/cm**2 quoted. All cross sections quoted",
                "assume this lower target thickness(134-mug/cm**2)."
              ]
            }
          ],
