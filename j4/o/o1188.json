          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 140 mug/cm**2 thick Na-23 target in the form of NaCl",
                "deposited on a 10 mug/cm**2 thick carbon foil was used."
              ]
            }
          ],
