          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Activation cross sections for proton-induced reactions",
                "on calcium isotopes up to 5.6-MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
