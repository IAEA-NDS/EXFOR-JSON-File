          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Each error value listed in the table is the",
                "root mean square error calculated from all the relevant",
                "experimental conditions pertaining to the measurement.",
                "The errors includes:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The relative accuracy of the absolute",
                "calibration of the spectrometer."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error in determining of average thickness."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The thickness variations.",
                "Statistical uncertainties of the number of events",
                "counted and the relative importance of the subtracted",
                "background."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "EN-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ". The uncertainty in the energy of the proton",
                "beam. For targets of 200-mug/cm**2 the energy spread",
                "within the target would be +-11-KeV at 2-MeV and",
                " +-5-KeV at 5.5-MeV, which is negligible."
              ]
            }
          ],
