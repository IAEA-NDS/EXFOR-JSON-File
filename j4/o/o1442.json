          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.In order to compare the fission fragment",
                "mass and energy distributions(MED) measured in the",
                "reaction Th-232(Li-6,f), were consider results obtained",
                "for neighboring fissioning nuclei produced in the",
                "reaction U-236,238(p,f).See REL-REF."
              ]
            }
