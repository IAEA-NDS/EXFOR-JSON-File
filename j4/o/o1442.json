          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ". The values of the ratio between the complete",
                "and incomplete fusion cross sections have been obtained",
                "from a combined analysis of MED and FFFAD.",
                "It has been found that the contribution of complete",
                "fusion into the total fusion-fission cross section is",
                "only approx. 27% at the lithium projectile energy",
                "E(lab)=28.5 MeV, approx. 2 MeV below the Coulomb",
                "barrier."
              ]
            }
