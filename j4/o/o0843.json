          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Seven stacks containing high purity 26-mum thick Rh-",
                "foils more 99% pure, major impurities 100-ppm Fe and",
                " 100-ppm and high purity Ti, Cu and Ni monitor foils,",
                "purity more 99%, were used."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Normalized excitation function for the contaminating",
                "56-Fe(p,n)60-Co process.",
                "Correction for self-absorption was applied."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By Authors*.At all energies systematic contamination",
                "with Co-56 is observed. The most probable route is",
                "through activation of the Fe present in the Rh foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " Stacked target technique was",
                "used. Seven stacks were irradiated with 14.7, 22.5 and",
                "29.4  MeV proton beam. Beam current was monitored and",
                "measured in Faraday-cup. Irradiation lasted from 1 hour",
                "to two hours with 200-500 nA beam current.",
                "Decay data were taken from E.Browne, R.Firestone, Table",
                "of Radioactive Isotopes, V.S. Shirley [Ed], Wiley,",
                "London, 1986., and D. De Frenne, Nucl. Data Sheets",
                "83,535,1998."
              ]
            }
          ],
