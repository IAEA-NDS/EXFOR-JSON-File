              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural antimony of spectroscopic purity greater than",
                " 99.99% was used for taking targets. Targets are",
                "prepared by vacuum evaporation technique of thickness",
                " 1.6 mg/cm**2. The stack was formed by placing",
                "alternatively 13.5 mg/cm**2 aluminium foils which act",
                "as energy degraders."
              ]
            }
