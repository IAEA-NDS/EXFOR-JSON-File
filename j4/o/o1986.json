            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The NE-18 beam was produced through the projectile",
                "fragmentation of a Ne-20 primary beam at 95 A*MeV on",
                "a carbon target and accelerated to 7.2A MeV by the",
                "CIME cyclotron at the SPIRAL facility."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The surrogate-reaction method. See Rel-Ref"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The stable Yb-174 target, a thickness of 250 mug/cm**2",
                "was deposited onto a natural C foil with a thickness of",
                "40 mug/cm**2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SILI"
              ],
              "free_text": [
                " Two large-area delta-E-E telescopes",
                "placed symmetrically at 130 degree with respect to the",
                "3He beam. The delta-E detectors were two 300 mum thick",
                "double-sided silicon strip detectors with an active",
                "area of 50*50 mm**2. The E-detectors were two Si(Li)",
                "detectors of 3 mm thickness. Four C(6)D(6) liquid",
                "scintillators were used for counting gamma rays with",
                "energies up to 10 MeV."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Six high-volume (70% efficiency) high-purity",
                "germanium detectors were located symmetrically at 70",
                "degrees with respect to the beam line and were used to",
                "determine the gamma-decay probability"
              ]
            }
          ],
