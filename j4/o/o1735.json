          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Interaction of 26 MeV deuterons with C-12."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.Van Dantzig",
                "L.A.Ch.Koerts"
