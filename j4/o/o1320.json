            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pb-208 targets of two different thicknesses were used-",
                " 150-mug/cm**2 with 10-mug/cm**2 carbon backing",
                "and 200-mug/cm**2 self-supporting."
              ]
            }
          ],
