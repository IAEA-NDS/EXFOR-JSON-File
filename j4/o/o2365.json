          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA",
                "TOF"
              ],
              "free_text": [
                " Double differential cross sections",
                "were measured for the 12C(p,d)11C reaction at zero",
                "degrees, near the eta prime emission threshold. The",
                "proton beam with energy of 2499.1 +/-2.0 MeV was",
                "provided by the synchrotron SIS-18. The beam",
                "intensity was 10**10 1/s, while the spill length and",
                "the cycle were 4 s and 7 s, respectively. Typical",
                "horizontal beam spot was 1 mm. The GSI-FRS was used",
                "as a spectrometer with special settings: the central",
                "focal plane (F2) was momentum-achromatic, while the",
                "final focal point (F4) was dispersive with a",
                "resolving power of 3.8*10**3."
              ]
            }
          ],
