          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Calcium deposition onto tantalum backings was",
                "achieved under vacuum by the decomposition of CaCO3",
                " (enriched to 99.96 % in 40Ca) and subsequent",
                "reduction of the CaO by zirconium. A thin layer of",
                "gold was evaporated onto calcium to minimize calcium",
                "oxidation and deterioration. Target thicknesses,",
                "measured at the narrow Ep = 1842.7 keV resonance,",
                "were ranging from 20 to 40 keV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " two Ge(Li) detectors of 22.3% and 18.5%",
                "efficiency, respectively, both placed at a distance of",
                "4.4 cm from the target."
              ]
            }
