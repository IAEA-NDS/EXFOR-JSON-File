          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A primary 18O beam accelerated to about 820 MeV/A (6He)",
                " and 730 MeV/A (8He) directed to a 9Be fragmentation",
                " target located at the entrance of the FRS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Liquid-hydrogen target (LH2).",
                "The target cell consists of a vessel (cylindrical",
                " shape with 100 mm \"useful\" length,  3 cm diam.,",
                " 708 mg/cm2).",
                "The target cell is surrounded laterally by a 100 um",
                " Mylar foil while the entrance and exit windows are",
                " made from 90 um Mylar."
              ]
            }
          ],
