          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section measurements of the 89-Y(p,gamma)90-Zr",
                "reaction at energies relevant to P-process",
                "nucleosynthesis"
              ]
            }
          ],
          "REFERENCE": [
