              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "GE-IN"
              ],
              "free_text": [
                " The outgoing protons were detected",
                "with a 4.2 millisr solid state detector telescope",
                "consisting of a 500 um Si surface barrier and 15 mm",
                "intrinsic Ge detector. The outgoing alpha particles",
                "were detected in a 1.3 msr E-dE telescope."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "EDE"
              ],
              "free_text": [
                " The proton telescope was fixed at angle",
                "equal 70 degrees and alpha telescope set on the",
                "opposite side of the beam at an angle such that zero",
                "recoil momentum of the residual nucleus in its ground",
                "state was kinematically allowed."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " DWIA analysis. Deduced spectroscopic factors."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "/By authors/ For each target an energy sharing",
                "distribution (cross section as a function of detected",
                "proton energy-E) was obtained at a single quasifree",
                "coplanar angle pair."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors are dominated by statistics,",
                "but include relative errors such as target thickness",
                "uncertainties."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " The absolute error due to target",
                "thicknesses, Faraday cup, solid angles, uncertainties",
                "in dead time corrections, etc. , was less than 10%."
              ]
            }
          ],
