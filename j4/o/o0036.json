          "EN-SEC": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "E",
                "particle": "P"
              },
              "free_text": [
                " The energy of outgoing protons."
              ]
            }
          ],
          "ANG-SEC": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ANG1",
                "particle": "P"
              },
