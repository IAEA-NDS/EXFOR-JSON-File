          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Alpha-clustering systematics from the quasifree",
                " (p,p+alpha) knockout reaction"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
