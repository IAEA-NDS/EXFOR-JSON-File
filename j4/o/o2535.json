          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The carbon isotopes were produced through",
                "fragmentation of the 22Ne primary beam interacting",
                "with a 8 g/cm2 thick Be target."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Secondary beams with an energy of 700 MeV/u and an",
                "energy spread of 1.3%. The mean energies of the beam",
                "particles determined with an accuracy of about 0.1%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " IKAR is an ionization chamber which serves as",
                "a hydrogen target and a detector of the recoil protons"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Multi-wire proportional chambers for measuring",
                "the projectile scattering angle"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillator detectors for beam identification",
                "and triggering",
                " - ALADIN magnet with the drift chamber and a",
                "scintillator wall are for identification of",
                "scattered projectiles"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The scattered beam particles were registered",
                "in coincidence with the recoil protons."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Possible contributions of inelastic scattering to the",
                "measured cross sections were estimated by",
                "calculations using the eikonal model."
              ]
            }
          ],
          "ERR-ANALYS": [
