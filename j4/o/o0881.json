          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Proton elastic scattering cross section of carbon,",
                "nitrogen and silicon for backscattering analysis in the",
                "energy range 0.7-2.5 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
