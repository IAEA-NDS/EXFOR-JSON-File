          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A carbon-backed NaCl target(evaporating NaCl onto a",
                "10 mug/cm**2 carbon foil)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Two double-sided silicon strip detectors.",
                "A 322-mum annular DSSD was mounted upstream of the",
                "target, covering laboratory angles between 140-degree",
                "and 163-degree and a 40-mum-thick, quadratic DSSD",
                "provided coverage at laboratory angles between 60 and",
                "120. The annular detector was mounted with the junction",
                "side, which has a 4-mum dead layer, facing the target.",
                "Protons populating the ground and first excited states",
                "in 26Mg were sufficiently energetic to punch through",
                "the quadratic DSSD and were stopped, and unambiguously",
                "identified, in a 1500-mum silicon pad detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energies given are the effective center of mass",
                "energies, corrected for the target thickness."
              ]
            }
