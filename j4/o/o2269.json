          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Na-23(a,p)Mg-26 reaction rate at astrophysically",
                "relevant energies."
              ]
            }
          ],
          "AUTHOR": [
