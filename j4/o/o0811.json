          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Dy foils were analyzed spectroscopically, and the",
                "impurities were smaller than 0.1%.  The surface density",
                "of these foils was about 21.38 mg/cm2.",
                "Each one of the 27 dysprosium foils of the target was",
                "wrapped in Al of surface density of 3.72 mg/cm2, in",
                "order to avoid the loss of radioactive nuclei by",
                "recoil."
              ]
            }
          ],
