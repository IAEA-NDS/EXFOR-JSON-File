          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 20 mug/cm**2 25Mg targets have been manufactured",
                "by evaporation of isotopically enriched 25MgO (97%) on",
                "a carbon backing of approximately 15 mug/cm**2.",
                "A thin layer of 0.2 mug/cm**2 of 209Bi was evaporated",
                "on the carbon backing for normalization purposes."
              ]
            }
          ],
