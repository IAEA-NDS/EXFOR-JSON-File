          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The gold foils were cut in squares of 1-cm*1-cm and",
                "weighed individually. The average surface density was",
                " 57-mg/cm**2. Aluminium foils, with a surface density",
                "of 4.5-mg/cm**2, were sandwiched between the gold",
                "foils. The purity of the aluminium and gold was",
                "spectroscopically analysed to be 99.9% and 99.7%,",
                "respectively."
              ]
            }
