          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 35Ar excitation energies were determined from",
                "the triton spectrum of 36Ar(d,t)35Ar, and the",
                "excitation energies were converted to the 34Cl+p",
                "resonance energy by subtraction of the proton",
                "separation energy of the 35ArS(p)=5896.3+/-0.8 keV",
                "This S(p) value was given by Catheleen Fry on 9 June."
              ]
            }
