          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By authors. Two separate runs were performed:",
                " 1. Measurement of angular distribution at E(lab)=4-MeV",
                " between 10- and 70-degree in laboratory system. Three",
                " telescopes, separated by 20-degree, were used",
                " simultaneously.",
                " 2. Measurement of three-point angular distribution",
                " at E(lab)=3, 5, 6, 7, 8-MeV and angle=10, 35, 70-",
                " degree."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metallic Li-6 target, 95% enrichment, a thickness of",
                " 134-mug/cm**2, evaporated on 90-mug/cm**2",
                "Ni-backing were used for 1-run measurement and",
                "Li-6 targets of 72-mug/cm**2 on 60-mug/cm**2 Ni-",
                "backing were used for 2-run measurement.",
                "Aluminium foils were used in front of apertures to",
                "absorb elastically scattered beam particles."
              ]
            }
          ],
