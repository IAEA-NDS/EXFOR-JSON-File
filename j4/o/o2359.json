          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "5-B-10",
                "field_identifier": "ENR",
                "value": 0.93
              },
              "free_text": [
                " Isotopically enriched 10B targets,",
                "evaporated on thin carbon backings. Targets with",
                "thicknesses of 25, 60, and 100 ug/cm2 were used.",
                "Target thickness and elemental composition were",
                "measured by using Rutherford backscattering and",
                "nuclear reaction analysis."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Two HPGe detectors facing each other in",
                "coaxial geometry. The entire measurement setup was",
                "shielded by few cm of copper and 10 cm of lead. The",
                "irradiated targets were placed between the two",
                "detectors, 2.5 cm away from each detector surface."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "EXTB",
                "GSPEC",
                "REC",
                "SITA"
              ],
              "free_text": [
                " The astrophysical S-",
                "factor of the 10B(p,a)7Be reaction was measured by",
                "activation for centre-of-mass energies 249-1182 keV.",
                "0.2 mm thick Al catcher foil was positioned around",
                "the target, covering 99.8% of the total solid angle,",
                "in order to catch the recoiling 7Be ions. After the",
                "irradiation the activity of the catcher foils and the",
                "targets was determined separately. The measurements",
                "were repeated for each sample several times in the",
                "three months following the experiment."
              ]
            }
          ],
