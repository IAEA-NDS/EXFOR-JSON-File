              ]
            },
            {
              "pointer": "",
              "coded_information": [
                2.0
              ],
              "free_text": [
                " n+p --> d+pi0 channel, two cross sections",
                "corresponding to the two kinematical solutions for the",
                "deuteron emission angle were derived.  The difference",
                "between the cross sections obtained by using  the np-pn",
                "channel with those obtained in case of np-d+pi0",
                "reactions does not exceed 15%."
              ]
            }
