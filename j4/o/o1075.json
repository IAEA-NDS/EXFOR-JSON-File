          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By authors. The method is based on the detection of",
                "particles produced by the interaction of neuterons with",
                "an hydrogen converter. The mass resolution was good",
                "enough to allow the identification  of  protons,",
                "deuterons and pions. The absolute calibration of the",
                "deuterons flux was performed through an activation",
                "measurement of carbon foils irradiated by the deuteron",
                "beam."
              ]
            }
          ],
          "FLAG": [
            {
              "pointer": "",
              "coded_information": [
                1.0
              ],
              "free_text": [
