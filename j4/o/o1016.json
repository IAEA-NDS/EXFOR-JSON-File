          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The overall uncertainty in each cross section (ERR-T)",
                "was obtained by taking the square root of the sum of",
                "the squares of the individual uncertainties, which were",
                "considered to be as follows:"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " target mass ~ 2%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": 5.0,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " Inhomogeneity in target thickness-5%-10%"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 2.0,
                "maximum_value": 10.0,
                "correlation_property": null
              },
              "free_text": [
                " Statistical errors-2-10%, for energy",
                " point near the threshold up to 20%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
