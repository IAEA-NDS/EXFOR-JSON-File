          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A 8Li beam was produced by bombarding a Ta-foil target",
                "with a pulsed 1.4 GeV proton beam from the PS Booster",
                "in combination with a tungsten hot-surface ion source."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were deuterated polyethylen,(with a",
                "thickness of 9.8 mum), polyethylene (12.7 mum), 109Ag",
                " (0.92 mum), and 12C (7.7 mum) foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD"
              ],
              "free_text": [
                " Two double-sided silicon-strip detectors",
                " (DSSSD) were used as delta-E detectors, having 32*32",
                "strips and an active area of 6.4 *6.4 cm**2. The",
                "thickness of the delta-E detector was 61 mum in the",
                "forward direction and 62 mum in the backward direction.",
                "The E-detectors had the same area as the delta-E",
                "detectors and a thickness of 1500 mum."
              ]
            }
          ],
