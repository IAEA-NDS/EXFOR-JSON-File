          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "For the primary production target and the secondary",
                "reaction target, 4 g/cm**2 of beryllium and 4 g/cm**2",
                "of aluminum, were used.",
                "To obtain comparable results by the two methods, an",
                "aluminum primary target of 1 g/cm**2 was used for this",
                "test instead of beryllium."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".The intranuclear-cascade plus evaporation model.",
                "The statistical abrasion-ablation model."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " Two-stage magnetic spectrometer."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                ". Two scintillation detectors."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                ""
              ]
            }
          ],
