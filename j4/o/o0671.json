          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "CEREN"
              ],
              "free_text": [
                " Three 1.27-cm thick plastic Cerenkov counters,",
                "Consisted of 15.2*15.2-cm Pilot 425 Cerenkov material,",
                "which contains a wavelength shifter."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " One 0.64-cm Thick Scintillation Counter.",
                "A veto scintillation counter rejected cosmic rays with",
                " 90% efficiency. The time profile of the beam was",
                "monitored with a 10-cm deep plastic-scintillator",
                "charged-particle counter situated at approximately 40",
                "degree and 1.5-m from target."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAINU"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The average proton current was collected in",
                "Faraday cup and integrated. Time-averaged beam currents",
                "varied between 5 and 20 nA."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
