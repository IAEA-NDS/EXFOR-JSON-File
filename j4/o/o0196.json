          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "8-O-16",
                "field_identifier": "NAT",
                "value": 0.998
              },
              "free_text": [
                " An O(2) gas target (99.8% O-16)",
                "contained in a cylindrical cell 10.2 cm in diam. and",
                "2.5 cm high. The gas cell had a 25 um thick 'H-foil'",
                "window and it was placed in the center of a 40 cm diam.",
                "evacuated scattering chamber."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "DRFTC"
              ],
              "free_text": [
                " The outer chamber housed two",
                "coplanar detector telescopes each of which consisted",
                "of a 300 um thick surface-barrier detector for",
                "measuring delta E, a stacked parallel combination of",
                "two 3 mm thick Li-drifted silicon detectors for",
                "measuring E, and a 3 mm thick Li-drifted veto",
                "detector. Each detector telescope was cooled by a",
                "P eltier thermoelectric diode having a water-cooled",
                "heat sink.The angular acceptance in the scattering",
                "plane was 2 degree for each detector, and the",
                "detectors accepted events which were coplanar within",
                "the same angular range."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA",
                "BCINT",
                "EDE"
              ],
              "free_text": [
                ""
              ]
