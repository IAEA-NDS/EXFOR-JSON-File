          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The two targets consisted of polished pyrolytic",
                "graphite with a evaporated aluminium layer with a",
                "thickness of about 3.4E+18 Al atoms/cm**2 on top.",
                "On top of the aluminium a boron layer with a thickness",
                "of 8.2E+17 B-atoms/cm**2 and a gold layer with a",
                "thickness of 5.1E+16 Au-atoms/cm**2 were evaporated.",
                "The homogeneity of all layers was checked by special",
                "experiments and was better than 1%."
              ]
            }
