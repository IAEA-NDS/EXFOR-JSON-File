            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.A larger variety of triggering reaction",
                "mechanisms-",
                "Exclusive breakup-7Be->3He + 4He",
                "3He-stripping- 7Be + 58Ni->4He + 61Zn,",
                "n-stripping-7Be + 58Ni-> 6Be(= 4He + p + p) + 59Ni,",
                "n-pickup- 7Be + 58Ni->8Be(= 4He + 4He) + 57Ni,",
                "4He-evaporation after a compound nucleus reaction."
              ]
            }
