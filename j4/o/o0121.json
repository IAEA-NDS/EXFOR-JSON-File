          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were a 40 to 60 ug/cm2 layer of either",
                "Ni-58 (99.9% enriched) and Au-197 (99.9% pure)",
                "evaporated onto a 1 cm**2,0.008 cm thick piece of",
                "aluminuim."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                "",
                "The separation of the total (p,pn) reaction cross",
                "section into the three major reaction mechanism:",
                "clean knock-out, inelastic scattering followed by",
                "evaporation, charge exchange scattering followed by",
                "evaporation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
