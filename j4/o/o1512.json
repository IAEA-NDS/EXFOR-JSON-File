          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Excitation functions of (a,xn) reactions on Rb-natural",
                "and Sr-natural from threshold up to 26 MeV: possibility",
                "of production of Y-87, Y-88 and Zr-89"
              ]
            }
          ],
          "AUTHOR": [
            {
