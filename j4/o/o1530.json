          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " Distorted-wave Born approximation calculations",
                "zero degree spectra of the reactions C-12(Li6,He6)N-12,",
                "O-18(Li6,He6)F-18, Mg-26(Li6,He6)Al-27 and",
                "Ca-42(Li6,He6)Sc-42 1+ states are indicated on figura 1",
                "the evaluated cross sections for Gamow-Teller",
                "transitions at 0-degree and the corresponding strengths",
                "of analogous beta decays are compared."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
