          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of natural sulphur pressed to an",
                "oval pellet of 8.8-mg/cm**2 thickness. This is",
                "equivalent to 8.4-mg/cm**2 of S-32. The pellet, whose",
                "size was about 4*10-mm**2, was embedded into a carbon",
                "frame and covered on both sides with thin carbon foils",
                "each of about 0.1-mg/cm**2."
              ]
            }
