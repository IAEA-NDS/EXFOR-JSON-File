          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                "  The first counter was a thin",
                "surface barrier detector, made from 25 to 35-mum slices",
                "silicon, which was transparent to all particles of",
                "interest and which gave an indication of the rate of",
                "energy loss.",
                "The second was a high resistivity guard ring detector",
                "of thickness 0.12 to 0.15-cm, which stopped the",
                "reaction products of interest but was traversed by",
                "elastically scattered protons.",
                "The third counter was a surface-barrier counter to",
                "detect elastically scatterd protons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A Ne102A plastic scintillation counter for",
                "elastically scattered protons at 30 degrees."
              ]
            }
