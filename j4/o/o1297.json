          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 92-Mo ions were directed onto a beryllium target",
                "of thickness 4007.0 mg/cm2 placed at the entrance of",
                "the fragment separator."
              ]
            }
          ],
