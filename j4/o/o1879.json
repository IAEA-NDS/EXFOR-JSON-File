            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "PRJFS"
                ],
                "institute": "2FR GAN"
              },
              "free_text": [
                " Secondary beams were obtained through",
                "projectile fragmentation of an O-18 primary beam",
                "impinging at 76 MeV/A onto a 360-mg/cm**2 Be target,",
                "followed by 2900 mg/cm**2 of carbon",
                "The separation of the secondary beams was made by means",
                "of the doubly achromatic spectrometer LISE."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " Sensitive silicon detector delta-El,",
                "thick of 71 mg/cm**2  was used to check the beam purity",
                "during the tuning and subsequently to trigger the data",
                "acquisition system. Position sensitive silicon detector",
                "delta-E2, thick of 104 mg/cm**2 was used as an active",
                "target. The scattered particles were detected by two",
                "circular silicon detectors of 69 mm diameter, one with",
                " 16 concentric strips-delta-E3 and the other with 8",
                "radial sectors-delta-E4. The circular detectors were",
                "followed by an array of 7 BGO detectors."
              ]
            }
          ],
