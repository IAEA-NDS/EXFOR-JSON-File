                  }
                }
              },
              "free_text": [
                "",
                "In-beam measurements and a large-volume eightfold",
                "segmented NaI(Tl) crystal described."
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
