          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The overall uncertainties in the cross section",
                "values were obtained by taking the square root of the",
                "sum of the squares of individual uncertainties.  The",
                "individual uncertainties in % considered were as",
                "follows-",
                "-target thickness - i.e Number of nuclei in the target",
                "approx. 2%.",
                "-Inhomogenety in target thickness approx. 5%.",
                "-Bombarding beam intensity approx. 10%.",
                "-Detector efficiency and sample-detector geometry",
                "approx. 5%.",
                "-Peak area analysis approx. 5%.",
                "For the  SR-nat(P,XN) reactions investigated the",
                "typical overall uncertainty was 13%."
              ]
            },
