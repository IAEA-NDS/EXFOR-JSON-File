          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Inclusive (p,pi+) cross sections near threshold"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.E.Marrs",
                "R.E.Pollock"
