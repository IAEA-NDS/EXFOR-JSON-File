          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A natural titanium plate of 99.9% purity was rolled",
                "down to foil with thickness from 1 to 2 mg/cm**2. Each",
                "titanium foil was covered by both of aluminium foils",
                "with 1.2 and 1.5 mg/cm**2 thickness to prevent the loss",
                "of activity owing to atom recoil. The aluminium foils",
                "were a purity of 99.9%. Target thickness was determined",
                "in all case by weight. The inhomogeneity of the",
                "titanium foil thickness was less than 3%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
