          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " A 4-pi array of Si+CsI(Tl)-telescopes was made",
                " of two parts-a 'wall' and a'ball (this part was",
                "needed here) consists of 18-segments, each segment is",
                "made of 7-detectors, each single detector is located at",
                " 15-cm from the target and consists of a delta-E",
                " silicon detector, 300-mum thick, backed by a CsI-",
                " scintillator 5-mm thick. The delta-E detector can",
                " stop up to 25-MeV alpha-particle."
              ]
            }
          ],
