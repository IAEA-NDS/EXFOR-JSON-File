          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Each deuterated target was produced in the folowing",
                "way. A fresh materials  with a purity of better than",
                "99% was bombarded with 10-KeV deuterons, whereby the",
                "proton yield of d(d,p)t was recorded as a function of",
                "implantation charge. The yield reached usually a",
                "saturation level after a charge of about 1 Coulomb.",
                "The procedure was repeated at Ed = 30-KeV.  For most of",
                "The materials the distribution was uniform within 10%",
                "from the surface down to depth consistent with the",
                "range of the implanted deuterons."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Summary of screening potentials for 34 materials."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Four Si detectors, active area=600 mm**2,",
                "effective thickness=100-mum were used."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "2GERBOC"
              },
              "free_text": [
                " The 100 kV accelerator."
