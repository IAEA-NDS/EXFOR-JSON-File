          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The correction factors have been calculated using a",
                "Monte-Carlo code taking into account not only the",
                "energy losses of the different isotopes, but also the",
                "quenching of the light output of the scintillator, the",
                "geometry of the experiment, the different straggling",
                "phenomena and the energy distribution of the light",
                "particles-protons and neutrons, produced in the",
                "interaction of the secondary beam with the target or",
                "the detectors."
              ]
            }
          ],
