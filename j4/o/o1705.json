              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A solid cryogenic D(2) target, thickness 17 mg/cm**2,",
                "was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " the VAMOS magnetic spectrometer, allowing an",
                "identification of ejectiles and a counting rate",
                "measurement of reaction products and Ne-26 beam",
                "particles."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " Photons were measured in the EXOGAM",
                "spectrometer. The intrinsic energy resolution of the",
                "whole system was measured to be 2.6 keV(FWHM) at",
                " 1332 keV and the corresponding photo-peak efficiency",
                "was estimated to be 4.8%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MCPLT"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
