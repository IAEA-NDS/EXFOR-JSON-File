            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " 'E/Delta E' Information was used to separate",
                "fission fragments from lighter nuclei."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " Faraday cup was used at the lowest energies.",
                "At higher energies, a secondary-electron-emission",
                "detector was used, calibrated with the use of the",
                " Faraday cup."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "IOCH",
                "IOCH"
              ],
              "free_text": [
                " Two identical position-sensitive",
                "ionization chambers. One of them was movable in a",
                "vertical plane, from -2 to +12 degrees, and was placed",
                "at angle -90 degrees with respect to the beam",
                "direction. The second one was movable in a horizontal",
                "plane from 10 to 170 degrees on the opposite side of",
                "the beam and had an angular aperture of 8 degrees."
              ]
            }
          ],
