          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting targets, about 1 mg/cm**2 thick, were",
                "made by evaporation for gold and by rolling for",
                "thorium. The targets were oriented at 45 degrees with",
                "respect to the beam direction."
              ]
            }
          ],
