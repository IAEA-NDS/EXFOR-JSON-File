          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross-section measurement of 44mSc,47Sc, 48Sc and",
                "47Ca for an optimized 47Sc production with an 18 MeV",
                "medical PET cyclotron"
              ]
            }
          ],
