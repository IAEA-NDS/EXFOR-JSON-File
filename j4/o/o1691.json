          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enhancement of two-proton transfer in N=82 nuclei. A",
                "study of 1p, 2p and (2p+2n) transfer reactions induced",
                "by O-16 on Ce-140, Nd-142 and Sm-144 near the coulomb",
                "barrier."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "W.Von Oertzen",
                "H.G.Bohlen",
                "B.Gebauer"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USABRK"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
