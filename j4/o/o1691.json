          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets ranged in thickness from 100 to 300 mug/",
                "cm**2 and were deposited on C-12 backings. All targets",
                "were made from material enriched to more than 98%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " The particles were identified using delta-E-E",
                "telescopes. The delta-E counters were of thickness",
                "between 18 and 25 mum. The heaviest particles, O-16",
                "and N-15, left up to 3/4 of their total energy in the",
                "delta-E counter. The delta-E and E pulses were added at",
                "high level and given onto two-dimensional analyzers",
                " (128*128). Up to three delta-E-E telescopes were used",
                "simultaneously using two ND 128*128 analyzers. The",
                "separation of C-12 and C-14 was usually complete with",
                "delta-E counters with a thickness larger than 20 mum."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*EN-RSL*.The energy resolution was typically 400 to 500",
                " keV."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " During all the measurements the elastic scattering",
                "was recorded simultaneously with the total nitrogen",
                "and carbon spectra. Thus the normalization of the data",
                "was made with respect to the elastic scattering.",
                "Deterioration of the target, if it occurred, therefore",
                "could not interfere with the normalization of the data."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Spectra of C-12 and C-14 from reactions induced by",
                "O-16 on Ce-140, Nd-142 were reported."
              ]
            }
          ],
