                "2GERMPH"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,207,91,1973",
                "code_unit": [
                  {
                    "unit": "J,NP/A,207,91,1973",
                    "doi": "10.1016/0375-9474(73)90025-0",
                    "field": {
