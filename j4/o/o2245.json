          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were thin metallic foils of vanadium and cobalt",
                "and of parated isotopes of nickel and copper.",
                "The V-foil was prepared by electropolishing an 0.001 cm",
                "foil until the thickness was 1.85 mg/cm**2.",
                "The cobalt foil,1.2 mg/cm**2, was made by",
                "electroplating cobalt onto a molybdenum.",
                "Foils of Ni-58,0.27 mg/cm**2, isotopic purity more than",
                "99%, and Ni-60,0.24 mg/cm**2, isotopic purity more than",
                "99%, on a backing foil of gold,0.16 mg/cm**2, were made",
                "by electrolysis.",
                "Self-supporting foils of Cu-63,1.3 mg/cm**2, isotopic",
                "purity 99.7% and Cu-65,1.75 mg/cm**2, isotopic",
                "purity 99.4%, were used."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections for absorption in the material in front of",
                "the ionization chamber were applied."
              ]
