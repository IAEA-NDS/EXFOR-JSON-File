          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " All REACTION codes are given with SF8=MSC. It means",
                "that total cross sections were determined approximately",
                "In charged-particle induced reaction, angular",
                "differential cross section diverges at the most",
                "forwarded angle because of long-range character of",
                "Coulomb interaction. Therefore elastic scattering",
                "cross section and total cross section are infinity for",
                "charged-particle induced reactions. Authors used",
                "the extrapolation to zero solid angle and correction",
                "for Coulomb-Nuclear Interference (see CORRECTION)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The detection system consisted of seven",
                "transmission counters, 5 mm thick.  The counters",
                "covered solid angles in the sequence 1, 2, 3, 4, 5,  7,",
                "9, the smallest and largest counters being 15 and 45 cm",
                "in diameter, respectively."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental data are corrected for Coulomb-Nuclear",
                "Interference in elastic scattering at small angles.",
                "The interference correction dominates all other",
                "problems both in the statistical fitting of the",
                "various functions, but more important, in the basic",
                "formulation of the fitting procedure. The details of",
                "this interference correction are quite different for",
                "the three cases, hydrogen, deuterium and light complex",
                "nuclei."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Method of Coulomb Interaction Correction."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total uncertainty of cross section.",
                "Fairly minor contributions come from -"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ".Error in counting statistics is 0.2%,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ".Error in stability of the efficiency of the",
                "scintillation Counters is 0.05%,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-3",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ".Error in accidental coincidences is 0.1%"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-4",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                ".Error in the background correction is 0.15%,"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-5",
                "minimum_value": 0.2,
                "maximum_value": 0.5,
                "correlation_property": null
              },
              "free_text": [
                ".Error in the  Target Length is 0.2%,",
                "except for deuterium where one was assumed as 0.5%.",
                "The Energy measurement when converted to an error in",
                "the cross section is normally negligible less than",
                " 0.2%, except for the energy  region between 400 and",
                " 600 MeV where it reaches 0.3% for p-d cross sections",
                "and 0.6% for p-p cross sections."
              ]
            }
