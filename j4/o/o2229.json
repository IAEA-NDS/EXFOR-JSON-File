            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target thickness values were determined to be 74",
                "and 82 mug/cm**2, respectively, for the Re-185,187",
                "targets. The targets were prepared by vacuum",
                "evaporation of isotopically enriched samples,",
                "containing 96.7% and 98.7% Re-185,187 onto 8 mug/cm**2",
                "C-nat  and 19 mug/cm**2 C-12 foils, respectively."
              ]
            }
