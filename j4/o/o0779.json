          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Streamer chamber study of the cross sections and",
                "multiplicities in nucleus-nucleus interactions at the",
                "incident momentum of 4.5 GeV/c per nucleon."
              ]
            }
          ],
