            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "TOF"
              ],
              "free_text": [
                " The 3He particles of interest were identified",
                "by combination of their time of flight, dE signal in",
                "the 20-um strip detectors and E deposit in the",
                "Must-2 DSSSD."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " Four Must-2 telescopes consist of double-sided",
                "silicon strip detector (DSSSD) of 300 um, four silicon",
                "strip detectors with nominal thickness of 20 um were",
                "therefore added in front of the Must-2 array."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
