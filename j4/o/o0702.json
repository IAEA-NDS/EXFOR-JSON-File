            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A radioactive beam of 72Zn at 38 MeV/u and a rate of",
                "1.5 x 10**5 particles per second was obtained from",
                "the fragmentation of a primary 76Ge beam on a",
                "beryllium target of 733 um thickness."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A deuterated polypropylene target of 0.26 mg/cm2",
