          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of a CaF(2) layer,30 mug/cm**2",
                "thick, evaporated onto a natural carbon backing,",
                "20 mug/cm**2 thick and was frequently changed to avoid",
                "degradation."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " The detection system consisted of 12 silicon",
                "detectors mounted at various polar angles and placed at",
                "10-12 cm from the target centre. The detectors, 300 mum",
                "thick, have 1*1 cm**2 active area. A thin aluminium",
                "absorber, 8 mum thick, was placed in front of the",
                "silicon detectors in order to suppress scattered",
                "protons."
              ]
            }
          ],
