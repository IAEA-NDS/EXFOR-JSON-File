          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uranium-238 (99.9%) metallic disks,of 0.0025 and 0.005",
                "cm thickness and 2.5 cm diam., were interlaced with",
                "aluminum and copper foils. Three aluminum foils,with",
                "different thickness,were always used between the",
                "uranium disks-the thinner one (0.0005 cm),was used to",
                "stop the fission products,the second one,was used to",
                "degrade the proton energy (with different thicknesses",
                "according to calculations), the last foil (0.01 cm),was",
                "used as a beam monitor. Copper foils (0.005 cm) were",
                "also used to check the proton beam current along the",
                "target stack."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE-IN",
                "HPGE"
              ],
              "free_text": [
                " The Np sample was counted in a Ge low",
                "energy photon detector and also in a Gamma High Purity",
                "Ge-Detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The plutonium fraction was counted in a silicon",
                "surface barrier detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " An alpha liquid scintillation detector for",
                "plutonium fraction."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2UK HAR"
              },
              "free_text": [
                " The Variable Energy Cyclotron."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "BCINT"
              ],
              "free_text": [
                "",
                "Two irradiations were done-The first with a 37 MeV",
                "proton energy beam, 0.5 mu-Ampere current and 8 hours",
                "duration, the second one with a 56 MeV proton energy",
                "beam,1 mu-Ampere current and duration of 7 hours."
              ]
            },
            {
