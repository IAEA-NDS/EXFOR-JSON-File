          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Layers of gold of a thickness of 200-500 Angstrom",
                "were evaporated in vacuum onto one of the detector",
                "foils on the inner side.",
                "The surface of the sample was parallel to the proton",
                "beam for the irradiation at 12.2 GeV and normal to the",
                "proton beam for irradiations at the other energies."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FISCT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Makrofol polycarbonate detectors consisted of",
                "two sheets of a size of 3*4*0.02 cm forming a sandwich.",
                "Detector was sensitive to fragments with A>=16. Heavy",
                "reaction fragments were stopped inside the Makrofol",
                "sheets and could thus be detected in a 4pi geometry."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Performed: Loss of events of about 2% due to removal",
                "of the detector material in the course of chemical",
                "treatment.",
                "Negligible:  Casual coincidences between two individual",
                "tracks and an individual track with binary events."
              ]
            }
          ],
