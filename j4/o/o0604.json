          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "An analysis of gold fission induced by high-energy",
                "protons"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- By Authors - The high-energy binary and ternary",
                "fission is defined as a decay of a nucleus into two and",
                "three fragments of comparable mass, respectively."
              ]
            }
          ],
