          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections for beam flux variations - in cases where",
                "the half-life of the product is less than or of the",
                "same order as the length of the irradiation, the",
                "calculated yield was multiplied by a correction factor."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors* The low values of experimental isomer",
                "ratios-high spin/low spin compared to theoretical",
                "predictions indicate that a considerable fraction of",
                "nuclei are by-passing the high-spin isomer to populate",
                "the low spin-state. This fraction has been estimated as",
                " 27.5% for the (a,n) reaction, 16.7% for the (a,3n)",
                "reaction and 18.2% for the (a,5n) reaction."
              ]
            }
