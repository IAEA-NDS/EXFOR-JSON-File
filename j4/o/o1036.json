          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The statistical errors for the measurements of",
                "neutron rates were below 10% for E(p) approx. 1.45 MeV",
                "and better at higher energies."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By authors. Because the threshold energy for",
                " Au-197(p,n) is equal 1.203-MeV, background",
                "neutrons were produced by the target backing. Neutrons",
                "produced by the Au-197(p,n) reactions were measured on",
                "a gold target over the range more or equal 1.58-MeV and",
                "less or equal 2.65-MeV in steps of 100-KeV. When",
                "calculating the neutron counting rates from the",
                " Cu-65(p,n) reactions, the energy loss of the protons",
                "in copper layer was carefully taken into account. Since",
                "the thickness of the copper layer was 320-mug/cm**2,",
                "equivalent to an energy loss of roughly 30-KeV, the",
                "neutron rates for the Cu-65(p,n)Zn-65 reactions for a",
                "particular energy were determined by subtracting the",
                "background neutrons from the Au-197(p,n) reactions at",
                " 30-KeV lower proton energy. The total neutron rates",
                "from E-CM  less or 2.1-MeV are practically equal to",
                "those of the Au-197(p,n) reactions from the gold",
                "backing."
              ]
            }
          ],
