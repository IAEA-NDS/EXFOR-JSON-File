          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "14-SI-28",
                "field_identifier": "ENR",
                "value": 0.998
              },
              "free_text": [
                " Targets were prepared by vacuum",
                "evaporation onto tantalum backings of SiO2 enriched to",
                "99.8% in 28Si. Target thicknesses corresponding to",
                "5-15 keV for 1 .4 MeV protons were used.",
                "Enriched SiO2 on thin carbon backings was evaporated",
                "simultaneously with the targets used in the experiments"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " two Ge(Li) detectors of volumes 70 and 75 cm3",
                "respectively, both placed at 5 cm from the beam spot.",
                "Detailed angular distributions at 0., 30., 55. and",
                "90. degr. were measured at eight different proton",
                "energies by means of the 75 cm3 detector, with the",
                "70 cm3 detector used as a monitor."
              ]
            }
          ],
