          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "205Tl targets were obtained by electroplating onto",
                "thin, high-quality gold foil (15 um thick), each",
                "accompanied by Ni and Ti monitors (20 um and 15 um",
                "thick, respectively) for measuring beam flux. Al",
                "degrader foils of varying thicknesses (100 um, 500",
                "um, and 800 um) were also included in the stack."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "BCINT"
              ],
              "free_text": [
                " Each irradiation lasted for 60 min.",
                "The stacks from 1 to 5 was 50 nA and 100 nA for the",
                "last stack."
              ]
            }
