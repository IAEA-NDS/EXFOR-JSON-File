          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " 5- \"octupole\" states in Nd-146,148 and Sm-148 via",
                "proton scattering."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
