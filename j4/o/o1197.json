          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Au/Ti/Si samples were used for the cross section",
                "measurement. A layer of about 70-nm Ti-film was",
                "deposited onto the silicon substrate and further coated",
                "with thin gold film, about 5-nm, for ion dose",
                "normalization. The gold film could also prevent",
                "titanium from being oxidized."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A proton backscattering measurement of TiD(X) film was",
                "performed at 151-degree at the energy of 2.785 MeV on",
                "the molybdenum substrate."
              ]
            }
