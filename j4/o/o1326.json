          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Only statistical errors in the cross section are given.",
                "The systematic error of the cross section normalization",
                "is estimated to be 3% except for the case of Li-9. For",
                "this isotope the cross section normalization was not",
                "determined experimentally. In this particular case the",
                "normalization was performed on the basis of a",
                "comparison of the experimental data with the",
                "differential cross-section calculated within the",
                "Glauber model."
              ]
            }
          ],
