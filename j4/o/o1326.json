          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
                "code": "R",
                "subentry_number": "A0493001",
                "author": "S.R.NEUMAIER+",
                "reference": {
                  "code": "J,NP/A,712,247,2002",
