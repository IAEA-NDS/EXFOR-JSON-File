          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "2ITYCAT"
              },
              "free_text": [
                " The 2H(10B,a7Be)n experiment was",
                "performed at the Laboratori Nazionali del Sud, Catania,",
                "Italy. The SMP Tandem Van de Graaff accelerator",
                "provided a 24.4 MeV 10B beam with intensities",
                "up to 1 nA."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supported deuterated polyethylene targets CD(2)",
                "of about 200-mug/cm**2 thickness was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "IOCH",
                "PS"
              ],
              "free_text": [
                " The detection setup consisted of an",
                "ionization chamber and a silicon position sensitive",
                "detector (PSDA) to discriminate Be nuclei and of two",
                "silicon position sensitive detectors PSDB and PSDC",
                "placed on the opposite side with respect to the beam",
                "direction."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
