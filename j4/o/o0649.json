          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements of Absolute Cross Sections of Fission",
                "Induced by 156-MeV Protons, Using Mica As a Fission",
                "Fragment Detector."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
