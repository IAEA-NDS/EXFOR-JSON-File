                ],
                "institute": "2FR PAR"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metal Layers of Bismuth, Gold, Tantalum,",
                "Praseodimium, Lanthanum, Natural Antimony,",
                "Natural Tin, Natural Indium, and Natural Cadmium. The",
                "Purity of the Samples was not Worse Than 99.999%. No",
                "Information on Sample Thickness is Given by Authors."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " The Sheets of Mica were Placed on Each Side of",
                "The Fissile Target."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "FF"
              ],
              "free_text": [
                " Only the Fission Fragments Left Microscopically",
                "Identifiable Traces in the Detectors."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FISCT"
              ],
              "free_text": [
                "."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
              "coded_information": [
                "MISC"
              ],
              "free_text": [
                " Forward to Backward Ratio For the Detected",
                "Fission Fragments."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Performed: to Take Account of Self-Absorption, the",
                "Ratio of Yields Between Thin and Thick Targets was",
                "Determined For Uranium and Gold, and Then Extrapolated",
                "To the Other Elements.",
                " Negligible: Fission of Impurities in the Samples and",
                "The Detectors."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By Compiler- For Lighter Nuclei, Forward to Backward",
                "Ratio For the Detected Fission Fragments Given Under",
                "'Misc' Column is Much Higher Than the One Expected",
                "From Linear Momentum Transfer Considerations. It May",
                "Indicate Decrease in Detection Efficiency in the",
                "Backward Hemisphere For Fragments of the Element Under",
                "Study, in Comparison with the Efficiency For the",
                "Monitor. Not Clear Whether the Appropriate Correction",
                "Is Introduced to the Fission Cross Sections."
              ]
            }
          ],
          "ERR-ANALYS": [
