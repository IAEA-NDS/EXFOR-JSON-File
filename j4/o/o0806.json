          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Rh foils were analyzed spectroscopically and it was",
                "found that the quantities of impurities were",
                "negligible.  The thickness of these foils was about",
                "16.86 mg/cm2, whereas the one corresponding to Cu was",
                "about 16.6 mg/cm2."
              ]
            }
          ],
