          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The NE-18 beam was produced through the projectile",
                "fragmentation of a Ne-20 primary beam at 95 A*MeV on",
                "a carbon target and accelerated to 7.2A MeV by the",
                "CIME cyclotron at the SPIRAL facility."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A pure 1 mm thick hydrogen target was used. The target",
                "was made using a metal frame to which mylar windows,",
                " 6 mum, were glued. A stack of frames has formed a H(2)",
                "target cell with a He cell on either side of the",
                "target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SILI"
              ],
              "free_text": [
                " The scattered protons escaped from",
                "the cryogenic target and were detected in a telescope",
                "of 3 silicon detectors 50*50 mm in size.",
                "A 150 mum delta-E detector, a 1 mm double-sided strip",
                "detector and a 3.5 mm thick Si(Li) detector."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two corrections were applied to the data to obtain the",
                "excitation function-",
                " -for energy loss of the protons inside the hydrogen",
                "target,",
                " -for normalization"
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Two new states in the compound nucleus Na-19 were",
                "observed. The two-proton events have been interpreted",
                "to arise from a sequential decay and three new states",
                "with large width have been determined in Na-19."
              ]
            }
          ],
