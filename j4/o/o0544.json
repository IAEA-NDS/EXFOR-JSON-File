          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets consisted of 0.001- or 0.002-in.-thick depleted",
                "uranium foils sandwiched between 0.001-in.-thick",
                "aluminum of high (99.999%) purity. The aluminum foils",
                "were slightly larger than the target foil in order to",
                "insure the collection of recoils escaping from the",
                "edges."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
