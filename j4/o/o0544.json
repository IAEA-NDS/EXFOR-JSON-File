          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Energy dependence of the recoil properties of products",
                "from the interaction of U-238 with 0.45-11.5-GeV",
                "protons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
