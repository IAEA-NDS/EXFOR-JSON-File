          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By author. The B-11(p,a)Be-8 reaction was studied",
                " from 1-MeV down to astrophysical energies by means",
                " of the Trojan-horse-method applied to the",
                " d(B-11,a+Be-8)n three-body reaction performed at",
                " an incident energy of 27-MeV."
              ]
            }
          ],
