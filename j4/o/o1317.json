          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Deuterated polyethylene targets CD(2) of about",
                " 170 ug/cm2 was bombarded with a 27-MeV B-11 beam."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " A silicon delta-E-E telescope was placed",
                " at a distance d=65-cm from the target and at",
                " angle=45-degree with respect to the beam axis.",
                "The detection setup consisted of a dual position",
                " sensitive  detector (DPSD), made of two 5 x1 cm2,",
                " 1000 um thick detectors and three 5x1 cm2 1000 um",
                " thick position sensitive detectors",
                " (PSD1,PSD2 and PSD3)."
              ]
            }
          ],
