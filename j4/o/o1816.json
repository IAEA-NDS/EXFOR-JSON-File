          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Isospin mixing observed in the reaction",
                "C-12(Li-6,a)N-14."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.Schwenzel",
