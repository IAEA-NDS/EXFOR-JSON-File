          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "DYNAM"
                ],
                "institute": "2GERBOC"
              },
              "free_text": [
                "  Dynamitron Tandem accelerator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin self-supporting carbon target, thickness of",
                " 60 mug/cm**2, was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Several surface barrier detectors of nominal",
                "thickness 250 and 500 mum each subtending a solid angle",
                "of roughly 5 msr were used.",
                "A monitor detector was kept fixed at ang=160 degree.",
                "Thin, 15 mum Al foils were placed in front of the",
                "detectors used for the forward angles to stop",
                "elastically scattered Li-6 ions."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.Since contributions of the background",
                "reactions C-13(Li-6,a)N-15 and O-16(Li-6,a) started to",
                "increase tremendously when the bombarding energy rose",
                "above 6 MeV, the angular distributions of the weak a1",
                "transition measured above this energy were only",
                "analysed to get an upper limit of the total cross",
                "sections."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".Hauser-Feshbach calculations."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The error associated with these differential cross",
                "sections are estimated to be +-30% for the isospin-",
                "allowed and +-50% for the isospin-forbidden",
                "transitions."
              ]
            }
          ],
