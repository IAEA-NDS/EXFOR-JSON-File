                "2GERBOC"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,367,145,1981",
                "code_unit": [
                  {
                    "unit": "J,NP/A,367,145,1981",
                    "doi": "10.1016/0375-9474(81)90282-7",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NP/A",
