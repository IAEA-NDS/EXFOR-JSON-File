            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The self-supporting targets were isotopically enriched",
                "to 94.7% and 94.2% and had a thickness of 3.4 mg/cm**2",
                "and 2.1 mg/cm**2 for Fe-57 and Mo-97, respectively."
              ]
            }
          ],
