              "free_text": [
                " The fragment separator was used in",
                " energy-loss mode to transmit the O-23 secondary beam",
                " to the breakup carbon target at the intermediate focal",
                " plane and the O-22 fragments to the final focal plane."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " a Ar-40 primary beam with an energy of",
                " 1.0 GeV/nucleon, delivered by the heavy-ion",
                "synchrotron SIS in a 4-g/cm**2 Be target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The O-22 fragments were detected in coincidence",
                "with de-exciting gamma rays."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
