              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": "2SF HLS"
              },
              "free_text": [
                " Van de Graaff accelerator of the",
                " University of Helsinki."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                "",
                "Two methods of deriving the scattering cross sections",
                "from the experimental data were employed.",
                "For the thin layer sample Zn-S is given by the ratio of",
                "the total number of counts of the corresponding",
                "backscattering signals.",
                "For the thick mg sample, a simulated computer fit",
                "provided the cross sections using of the dependence",
                "between the ion collision energy as a function of",
                "depth, stopping and scattering cross sections."
              ]
            }
          ],
          "REL-REF": [
            {
              "pointer": "",
              "coded_information": {
