          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Two targets containing natural sulfur and magnesium",
                "were used.   The  former one consisted of a 2.5*10e+18",
                "atoms/ cm**2 layer of Zn-S on aluminium backing, the",
                "latter of a 92*10E+15 atoms/cm**2 gold film evaporated",
                "onto a thick magnesium substrate.  The thickness of the",
                "Zn-S layer corresponds to 16 KeV energy loss for 2.4",
                "MeV protons.  The 1:1 stoichiometry of the Zn-S was",
                "verified, and the areal densities of the Au and Zn-S",
                "films were determined several times during the",
                "measurements by 2-MeV He-4 ion backscattering.  In the",
                "case of the Au/mg sample, the number of Au atoms/cm**2",
                "was obtained, using the Au yield relative to the yield",
                "from the bulk mg of the same sample."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                ""
              ]
            }
          ],
