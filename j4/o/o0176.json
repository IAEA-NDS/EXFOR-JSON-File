              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".Semiclassical Preequilibrium Models.",
                "Time-Of-Flight Spectra."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "N-SPC"
              ],
              "free_text": [
                " The size of neutron spectra figures does not",
