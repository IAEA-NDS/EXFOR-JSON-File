          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched Zn-70 metal was obtained in the form of an",
                "electrolytically deposited sheet of 99.8% purity with",
                "less than 10 ppm of Cu impurity content. It was",
                "enriched to 95.35%, with isotopic impurities of 4.49%",
                "Zn-68, 0.16% Zn-67 and less than 0.02% each of Zn-64",
                "and Zn-66. The 0.5 mm thick sheet was divided into",
                "several smaller pieces, which were cold-rolled to form",
                "foils of approximately 12 mum thickness. Ti foils of",
                "12 mum and 99.6% purity were used for beam current",
                "monitoring together with 10-20 mum Al catchers and",
                "degraders."
              ]
            }
          ],
