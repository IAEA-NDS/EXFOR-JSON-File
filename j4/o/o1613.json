          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Maya active target was fulled with deuterium gas,",
                "at a pressure of 1050 mbar, forming a pure deuterium",
                "target of 1.6-mg/cm**2(equivalent to a target of",
                " 6.3 mg/cm**2 of CD(2).)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " All the cross sections presented in this paper",
                " are those from the analysis of the coincidence",
                " spectra."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
