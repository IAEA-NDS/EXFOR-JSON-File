          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "About 30g of Pure Water was Used As Target.",
                "Three Deposited Sample Plates of the Water Concentrates",
                "After Irradiation and Mass-Spectrometric Analysis were",
                "Used- A, B and C Samples.  Since Samples A and B (see",
                "TABLE 1) Were Irradiated on the Same Date with 135 MeV",
                "Protons and the Expected Be-10 Activity was Small in",
                "Each Case, the A and B Samples were Combined."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                ".A Flat 5.08 Cm Diameter NaI(Tl) Crystal.",
                "The Be-7 Gamma-Activities As Well As the Total Activity",
                "Monitored by the Gas-Flow B-Counter Decreased with a",
                "Half-Life of 54 D in Agreement with the Expectations",
                "For Be-7 (HALF-LIFE=53.6 D)."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GEMUC"
              ],
              "free_text": [
                " Beta Counting was Carried Out Using a Flow-Gas",
                "Type Low-Level Geiger Counter of Background About 5",
                "Counts Per Hour and Having a 38% Efficiency For K-40",
                "Beta-Rays."
              ]
            }
          ],
