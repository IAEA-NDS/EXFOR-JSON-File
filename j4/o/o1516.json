          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Enriched He-3 gas, isotopic purity more than 99.95%,",
                "pressure 0.7-mbar, target thickness 8-10 keV, was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " A 100-mum thick silicon detector detects",
                "projectiles that have been elastically scattered first",
                "in the target gas and subsequently in a movable 15-",
                "mug/cm**2 carbon foil."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Prompt gamma-rays are counted with a  135% ultra",
                " low-background HPGE detectors shielded with 5-cm of",
                "OFHC copper and 25-cm of lead."
              ]
            }
          ],
