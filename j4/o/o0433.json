          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets consisted of 0.5-in. squares of Cu-65",
                " (enriched to 99.6%) vacuum deposited to a thickness",
                "of 2-3 ug/cm**2 onto 25-30 ug/cm2 formvar films.",
                " An additional angular distribution was obtained at",
                "2.8 GeV from targets with 6 ug/cm2 Cu-65 on 50 ug/cm2",
                "formvar in order to estimate the effect of scattering",
                "of the Cu-64 recoils in the target and backing.",
                " In some irradiations an extra 0.00025-in. mylar foil",
                "was included under the catcher foil in order to",
                "determine the activation blank of Cu-64 from mylar",
                "impurities in the mylar."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " The end-window, methane-flow, proportional",
                "counters."
              ]
            }
          ],
