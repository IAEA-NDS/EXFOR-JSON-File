          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thickness of the foils were determined by weighing",
                "and were found to be 20 mum and 87 mum for Au and Cu",
                "foils, respectively. In addition, two Al monitor foils,",
                "each 98 mum thick, were inserted at positions",
                "corresponding to E(a)=100 and 92 MeV. Finally, a 54 mum",
                "Al foil was put in front of the stack. The diameter of",
                "all foils was 16 mm."
              ]
            }
          ],
