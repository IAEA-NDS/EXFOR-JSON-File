          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The pure aluminum film of 200 angstroms was evaporated",
                "on a pyrolytic graphite substrate and coated with 100",
                "angstroms of silver.  The Na-F film of 400 angstroms",
                "was evaporated on a self-supporting carbon film (10",
                "mu-g/cm**2) and also coated with 100 angstroms of Ag."
              ]
            }
          ],
