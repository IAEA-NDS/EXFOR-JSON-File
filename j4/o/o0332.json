                "1USAPUR"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,JIN,30,2891,1968",
                "code_unit": [
                  {
                    "unit": "J,JIN,30,2891,1968",
                    "doi": "10.1016/0022-1902(68)80148-4",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "JIN",
                        "number": null,
                        "volume": "30",
                        "part": null,
                        "issue": null,
