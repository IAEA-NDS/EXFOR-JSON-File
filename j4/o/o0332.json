          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Recoil properties and charge distribution in the",
                "fission of Pb-208 by 450 MeV protons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "J.A.Panontin",
                "N.T.Porile"
