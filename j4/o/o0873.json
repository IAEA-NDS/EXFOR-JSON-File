          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Polyimide (C/22,H/10,N/2,O/5) foils of thickness",
                "27.6+/-1.0 microgramm/cm**2 deposited on mirror",
                "polished tantalum backing were used as targets.",
                "The target thickness was determined by interferometry,",
                "while the homogeneity controlled by irradiating",
                "different points over target surface.",
                "In order to test the stability of the organic polyimide",
                "samples under beam irradiation the same target point",
                "was repeatedly bombarded with 4-He+ beam of 4.5 MeV",
                "energy and 50 micro-curie dose. No deterioration was",
                "observed within the measurement accuracy after six",
                "irradiations."
              ]
            }
          ],
