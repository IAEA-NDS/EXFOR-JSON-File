          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two silicon surface barrier detectors were",
                "placed at backscattering angles of 140 and 170 degrees",
                "in a chamber."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The aluminum, silicon and titanium samples were",
                "prepared by vacuum evaporation of thin layers of",
                "natural Al - 100 nanometers, Si - 100 nanometers, and",
                "Ti - 75 nanometers on carbon substrates. Thin layers of",
                "gold - 25 nanometers were then evaporated on these",
                "films; the gold film was to serve as intrernal dose",
                "reference. Also a pure carbon target was used to enable",
                "the subtraction of the background yields generated by",
                "the carbon substrates."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20010503,
                "history": "C"
              },
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
