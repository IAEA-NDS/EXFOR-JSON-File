          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering cross sections for 6-Li and 7-ll",
                "scattering by aluminum, silicon and titanium below 12",
                "MeV at angles of 140 and 170 degrees."
              ]
            }
          ],
          "AUTHOR": [
