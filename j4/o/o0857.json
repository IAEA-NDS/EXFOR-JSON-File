                "history": "U"
              },
              "free_text": [
                " Last checking has been done."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The uncertainty in the cross section values due to",
                "statistical errors in the peak areas and the possible",
                "error in the background subtraction are less than 2% at",
                "low energies, 3% near the threshold energy and 6-12% by",
                "the end of the measured energy region for each",
                "ion-target pair."
              ]
            }
          ],
