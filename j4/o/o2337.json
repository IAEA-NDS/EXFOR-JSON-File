          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elemental arsenic powder of high purity,99.999%, was",
                "used as target material. For energy degradation",
                "or beam monitoring aluminum-99%, copper- 99.9% and",
                "titanium- 99.96% foils, were used. The aluminum foils",
                "were also applied as backing material.",
                "The targets consisted of 5-11 mg/cm**2 arsenic and were",
                "additionally covered by a 10-mu thick aluminum foil"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A special HPGe detector for low-energy gamma-",
                "rays with a thin Be-window of 300 mm thickness",
                "connected to a digital gamma spectrometry system."
              ]
            }
