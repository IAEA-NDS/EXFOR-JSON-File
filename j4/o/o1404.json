              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                "  The energy spectra and angular distributions of",
                "the gamma-rays emitted in the reactions studied have",
                "been measured with the multidetector janosik set-up"
              ]
            }
          ],
