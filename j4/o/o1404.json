          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-energy gamma-ray emission studies with JANOSIK",
                "set-up in 20-Ne+12-C at 5.2 MeV/U."
              ]
            }
          ],
