          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,14,1506,1976",
                "code_unit": [
                  {
                    "unit": "J,PR/C,14,1506,1976",
                    "doi": "10.1103/PhysRevC.14.1506",
                    "field": {
                      "reference_type": "J",
