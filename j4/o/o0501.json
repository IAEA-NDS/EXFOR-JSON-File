          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of Be-7, Na-22 and Mg-28 from Mg, Al and",
                "SiO(2) protons between 82 and 800 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
