          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The individual targets utilized were:",
                "1.  19.9-22.5 mg/cm**2 Mg purity >99.8%.",
                "admixtures:  Na <50 ppm, Al < ppm, (SI) Less 50 ppm),",
                "2.   5.29-7.27  mg/cm**2  Al purity >99.9%,",
                "admixtures:  Na+Mg < 500 ppm, Si < 500 ppm.",
                "3.   209-237 mg/cm**2 SiO(2) purity >99.9999%.",
                "admixtures:  Boron < 0.01 ppm, Na <0.1 ppm, Mg <0.1",
                "ppm, Al < 0.1 ppm.",
                "The Mg and SiO(2) targets were irradiated individually,",
                "The Al targets were nearly all run as portions of",
                "target stacks involving from 45 to 1000 mg/cm**2 of",
                "other (much higher Z) materials."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".Empirical formulas and Monte Carlo method."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                ".Some early radioactivity measurements (all on",
                "aluminum runs) were made with a 7.6 cm*7.6 cm NaI(Tl)",
                "multichannel analyzer system."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ".Two different 42 cm**3 Ge(Li). Multichannel",
