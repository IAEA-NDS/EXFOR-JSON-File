          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cloud chamber was filled with helium to a",
                "pressure of 60 atm and pure ethyl alcohol was used as",
                "the condensate"
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The 1456 p-He4 collisions that have been measured were",
                " analysed in the following three groups:",
                "  (a) coplanar events; viz., elastic and He4(p,d)He3",
                "      collisions,",
                "  (b) He4(p,pn)He3 reactions (two non-coplanar charged",
                "      particles),",
                "  (c) collisions resulting in three charged particles."
              ]
            }
          ],
