          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
                " Ilford C.2 plates, with emulsion thicknesses",
                "varying from 100 mum to 300 mum"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A thick lithium hydroxide target."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "To obtain from the observed spectra correct",
                "distributions of the numbers of neutrons, it was",
                "necessary to multiply the number of tracks",
                "corresponding to each neutron energy by a factor",
                "proportional to the neutron-proton scattering cross-",
                "section at this energy and inversely proportional to",
                "the fraction of such tracks which would be expected not",
                "to escape from the surfaces of the emulsion, this",
                "fraction depends on the neutron energy, the emulsion",
                "thickness and the maximum scattering angle for which",
                "tracks are recorded."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
