          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The neutrons emitted in the disintegration of lithium",
                "by deuterons."
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
