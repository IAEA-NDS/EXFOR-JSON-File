              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RCA,90,167,2002",
                "code_unit": [
                  {
                    "unit": "J,RCA,90,167,2002",
                    "doi": "10.1524/ract.2002.90.3_2002.167",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "RCA",
                        "number": null,
                        "volume": "90",
                        "part": null,
                        "issue": null,
