          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of the positron emitter Mn-51 via the",
                "Cr-50(d,N) reaction-targetry and separation of no-",
                "carrier-added radiomanganese."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "A.T.J.Klein",
                "F.Rosch",
