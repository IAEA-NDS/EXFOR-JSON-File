          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USAMIT"
              ],
              "free_text": [
                " P.G.R. and N.S.W."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "1USAMRY"
