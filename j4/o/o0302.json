          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "1USAHRV"
              },
              "free_text": [
                " Harvard University Cyclotron."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                "  Each target was mounted in an evacuated 13 inch",
                "diameter scattering chamber, with Mylar entrance and",
                "exit windows."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " Monoenergetic 160 MeV protons, stochastically",
                "extracted from the cyclotron, giving a beam intensity",
                "of 1.0e+08 - 1.0e+09 protons/second."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                "  Optical model"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "POT"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "NAICR"
              ],
              "free_text": [
                " The scattered protons were detected",
                "with a telescope, consisting of two plastic",
                "scintillators and a Harshaw 3 X 3 inch sodium iodide",
                "detector.",
                " The resolution was 1.35 MeV FWHM at 160 MeV. The",
                " angular resolution of the counter system was +/- 0.5",
                " degrees. The counter telescope was mounted on a 5 feet",
                " arm, which could be rotated on a track about the",
                " scattering chamber. The angle could be determined to",
                " within 0.1 degrees. The zero direction was determined",
                " to within +/- 0.1 degrees by measuring on both sides."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " A nonsaturating He ionization chamber was used",
                " to monitor the incident proton beam. This chamber was",
                " calibrated with a Faraday cup."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "6-C-12(P,INL)6-C-12,PAR,DA",
                  "code_unit": [
                    {
                      "unit": "6-C-12(P,INL)6-C-12,PAR,DA",
                      "field": {
                        "reaction": "6-C-12(P,INL)6-C-12",
                        "target": "6-C-12",
                        "projectile": "P",
                        "process": "INL",
                        "product": "6-C-12",
                        "quantity": "PAR,DA",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": "PAR,DA"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                " The cross sections were",
                "normalized to that of inelastic scattering from the",
                "4.44 MeV level in 12-C, previously measured to within",
                "+/- 5% at Orsay."
              ]
            }
          ],
