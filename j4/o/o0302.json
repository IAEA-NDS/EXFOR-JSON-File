          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of 160 MeV protons from 9-Be,",
                " 40-Ca, 58-Ni, 120-Sn and 208-Pb"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
