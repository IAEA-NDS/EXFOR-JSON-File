          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The total target thickness of 812 mg/cm**2 aluminum."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Four large-area multiwire proportional counters.",
                "These could be moved into the beam to tune the",
                "separator."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PHVC"
              ],
              "free_text": [
                " Sixty-four 220 mum thick silicon photodiodes",
                "with an active area of 10*10-mm**2. They were arranged",
                "into four subsequent layers of 16*1-cm**2, which were",
                "shifted against each preceding layer by 2.5-mm in",
                "horizontal direction."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CEREN"
              ],
              "free_text": [
                " The  velocities were measured with a",
                "ring-imaging cerenkov detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A second silicon detector array behind the",
                " Cerenkov detector with an active area of 60*30-mm**2",
                "served as an additional trigger detector."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": "2GERGSI"
              },
              "free_text": [
                " Heavy-ion synchrotron."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "FRS"
                ],
                "institute": "2GERGSI"
              },
              "free_text": [
                " Fragment separator."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The primary beam intensity was determined from",
                "the current induced by delta electrons in an aluminum",
                "converter foil in front of the target."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The fragment nuclear charge number was determined",
                "from a fourfold enery-loss measurement in the silicon",
                "detector array at central focal plane."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "RSD"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The ratio of correlated to uncorrelated events between",
                " MWPC and the silicon detector indicated an additional",
                "transmission loss of 5%."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                "  The overall efficiency, including ionic charge",
                "changes, secondary reactions in the detectors and",
                "deadtime was approximately 60%.",
                "The experimental errors are dominated by the beam",
                "intensity monitor 5-17% and the transmission",
                "determination 10-50%.  For isotopes with low",
                "transmission no reliable fit of the position",
                "distributions was possible.  But in most cases such",
                "isotopes were observed with higher transmission in an",
                "adjacent field setting.  For isotopes where the",
                "distributions could be fitted in two setting, the",
                "results agree within the extracted errors.  Only for",
                "distributions with low statistics, which did not allow",
                "a reliable fit, a Monte Carlo simulation of the",
                "spectrometer transmission was used.  This simulation",
                "agreed with the measured transmissions within about 6%."
              ]
            }
          ],
          "STATUS": [
            {
              "pointer": "",
              "coded_information": {
                "status": [
                  "TABLE"
                ],
                "subentry_number": null,
                "author": null,
                "reference": null
              },
              "free_text": [
                "  In the paper"
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " An intranuclear-cascade model.",
                "The average momentum and the width of the fragment",
                "momentum distributions were determined from the",
                "position spectra assuming a gaussian momentum",
                "distribution folded with a rectangular distribution."
              ]
            }
          ],
