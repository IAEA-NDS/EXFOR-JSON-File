          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "300 mm long differentially pumped windowless gas",
                "target was used. The He-4 target section was operated",
                "at 4 mbar. The effective target thickness was (0.54+/-",
                "0.03) *10**18 atoms/cm**2. After the He-4 target cell,",
                "an Ar post-stripper was used with thickness",
                "of (4.5+/-0.5)*10**16 atoms/cm**2."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH",
                "TELES"
              ],
              "free_text": [
                " ionziation chamber with fractioned anode"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " in 2. pumping stage to monitor scattering",
                "rate of N-15 on Ar post-stripper"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "EXTB",
                "REC",
                "TTM",
                "SITA"
              ],
              "free_text": [
                " Measurement was performed in",
                "inverse kinematics. The target profile was determined",
                "by measruement of the 7Li(a,ga')7Li resonance yield",
                "at 3325 keV. Transmission of recoils was 100%. A",
                "post-stripper after the target chamber was used so",
                "that the recoils could reach charge state equilibrium."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Values for the gamma and alpha widths were obtained by",
                "Monte Carlo sampling the measured yield curve, and",
                "fitting it with a Breit-Wigner shape convulated with",
                "the target profile."
              ]
            }
          ],
