          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of carbon in thin layers by means of the",
                " C-12(d,n)N-13 nuclear reaction using a 2-MeV Van de",
                " Graaff accelerator."
              ]
            }
          ],
          "AUTHOR": [
