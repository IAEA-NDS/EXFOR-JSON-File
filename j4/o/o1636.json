          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The enriched (99.9%) Cu target, thickness 30-mug/cm**2,",
                "evaporated onto a 5-mug/cm**2 carbon foil, for the low",
                "energy measurements 39 MeV<E(lab)< 46 MeV(or equal) and",
                "self-supporting targets with thickness between 60 and",
                " 80-mug/cm**2 for the high energy measurements",
                " 47 MeV <E(lab)< 64 MeV(or equal), were used.",
                "In both cases , a thin layer of gold was evaporated",
                "onto the targets for data normalization."
              ]
            }
          ],
