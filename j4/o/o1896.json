          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting natural C-12 target,",
                " 0.080+-0.004 mg/cm**2 thick and an initial purity",
                "of about 99.9% was used."
              ]
            }
          ],
          "FACILITY": [
