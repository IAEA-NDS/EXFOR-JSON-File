          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The proton and the deuteron targets were realised as",
                "liquid targets enclosed between thin titanium foils of",
                "a total thickness of 36.3 mg/cm2.  The thicknesses of",
                "the proton and deuteron targets were measured to be",
                "[87.3+/-2.2] mg/cm2 and [206+/-6] mg/cm2, respectively."
              ]
            }
          ],
