            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Four stacks have been arranged in two different setups,",
                "with each stack consisting of four targets made from",
                "natCr.",
                "The Ti(99.6% pure, 8.1 mg/cm2), Al (99.99% pure,",
                " 4.3 mg/cm2 and 13.4 mg/cm2) and Ir (99.9% pure,",
                "  55.9 mg/cm2 and 56.9 mg/cm2).",
                "The Cr targets were measured individually, obtaining a",
                "mass thickness in the range 10.5-17.0 mg/cm2"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " relative efficiency 15%, FWHM = 2.2 keV",
                " at 1.33 MeV"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA"
              ],
              "free_text": [
                " The irradiation duration lasted for 1 hr,",
                "covering an energy range from 1 to 28 MeV with a",
                "constant current of about 150 nA."
              ]
            }
          ],
