          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets used were self-supporting foils of 26-Mg",
                " (0.200 mg/cm2 and 1.50 mg/cm2), 30-Si (0.067 mg/cm2)",
                "and 28-Si (0.130 mg/cm2).  The target thicknesses were",
                "measured by 25 MeV alpha scattering experiments and",
                "confirmed by forward-angle elastic scattering searches.",
                "The thin 30-Si target had significant amounts of 16-O",
                "and 12-C impurities, which remained constant to within",
                "5% throughout the experiment and consequently allowed",
                "angular distributions to be obtained for these",
                "isotopes."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " The delta-E detectors were between",
                "118 and 155 mu-m thick and the E detectors were 5 mm",
                "thick.  Five telescopes were used."
              ]
            }
          ],
