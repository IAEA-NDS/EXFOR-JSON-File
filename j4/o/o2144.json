          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thorium layers of defined geometry containing 8.5-",
                "14.6 mug/cm**2 were used. Silver plates of 99.99%",
                "purity with 0.1-mm thickness and 16-mm diameter were",
                "used as cathode materials and a platinum wire was used",
                "as an anode. The silver disks were covered with",
                "aluminum foils, 22.5-mum thickness, 99.99%, which acted",
                "as catcher foils to avoid any losses of activity by",
                "recoil processes and were used as monitor foils."
              ]
            }
          ],
