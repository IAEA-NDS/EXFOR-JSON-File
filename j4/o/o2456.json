          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A primary 22Ne beam produced by the UNILAC-SIS",
                "accelerator complex was focused on an 8g/cm2 Be",
                "production target at the entrance of the FRagment",
                "Separator (FRS)."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The energy of the secondary beam at the centre of the",
                "hydrogen target: 701 MeV/u for 7Be and 702 MeV/u for",
                "8B with an energy spread of 1.3%. The mean energies",
                "of the beam particles determined with an accuracy of",
                "about 0.1%. The beam intensity was 3x10E3 1/s"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " Hydrogen-filled ionization chamber IKAR serves",
                "simultaneously as a gas target and a detector for",
                "recoil protons."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MWPC"
              ],
              "free_text": [
                " Four multi-wire proportional chambers PC1-PC4",
                "determines the scattering angle the projectile"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The scintillation counters are used for beam",
                "identification and triggering."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN"
              ],
              "free_text": [
                " The recoil protons were registered in",
                "coincidence with the scattered beam particles"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Pure hydrogen at a pressure of 10 bar."
              ]
            }
          ],
