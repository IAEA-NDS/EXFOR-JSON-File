          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets approxim 80-mug/cm** Sr metal evaporated on",
                "carbon backing with two different enrichments were",
                "used. One target was made using the material obtained",
                "from Harwell- Sr-87  60.2%, Sr-88 38.5% and the other",
                "was made using material from Oak Ridge- Sr-87 93.3%,",
                "Sr-88 6.0%."
              ]
            }
          ],
