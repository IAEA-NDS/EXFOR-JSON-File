          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " A beam purity better than 1.E-18 16-O ions per",
                "incident 12-C projectile has been achieved."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " A total suppression factor (the ratio between",
                "leaky 12-C events detected in the telescope and the",
                "number of 12-C projectiles) of better than 5.E-14."
              ]
            }
          ],
