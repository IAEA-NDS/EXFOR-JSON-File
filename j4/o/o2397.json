          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "TRN",
                "SITA",
                "EDE",
                "COINC"
              ],
              "free_text": [
                " The beam current was kept low",
                " (5 pA) to avoid accidental coincidences. Particle",
                "identification was based on dE-E measurements. The",
                "elastic scattering events were recognized by the two",
                "deuterons in coincidence, while the proton-transfer",
                "reaction was identified by the single tracks of 3He",
                "ions."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section data were normalized by a factor of",
                " (41.4 +/-3.3) *10**6 1/mb, which was determined by",
                "comparing the scattering cross sections to the data",
                "previously obtained at 180 and 130 MeV, in the",
                "momentum range of 200-290 MeV/c."
              ]
            }
