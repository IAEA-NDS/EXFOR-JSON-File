          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The new TIARA array is designed to exploit",
                "such transfer reactions with radioactive beams, using",
                "inverse kinematics with hydrogen polymer targets.",
                "The TIARA array is a highly efficient particle detector",
                "for almost all angles."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SISD",
                "GE"
              ],
              "free_text": [
                " TIARA, an array of silicon detectors",
                "spanning 85% of 4pi. The TIARA coverage from",
                "36.-144.degr. comprised an octagonal 'barrel' of",
                "position sensitive (resistive strip) detectors,",
                "400 um thick. The most backward angles (144.-169.degr.)",
                "were covered by an array of 400 um thick double-sided",
                "Si strip detectors. In very close proximity to the",
                "target (50 mm) the front faces of four EXOGAM segmented",
                "Ge detectors formed four sides of a cube spanning 66%",
                "of 4pi."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The VAMOS magnetic spectrometer operated in",
                "dispersive mode."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " The start signal for the timing was provided",
                "by a thin (10 um) plastic scintillator mounted 0.5 m",
                "upstream of the reaction target."
              ]
            }
          ],
