          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Monoenergetic 100.4 MeV protons."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " Drifted Ge-Li detectors with side Entry were",
                "used to detect the scattered protons. They were",
                "mounted in a thin window dewar which was one of the",
                "arms of a 75 cm radius scattering chamber. The energy",
                "resolution was in all cases better than 300 keV. The",
                "scattering angle was determined to within +- 0.04 degr.",
                "The angular resolution, as determined by the",
                "detector apertures, varied from 0.5 to 2.4 degr."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Corrections were made for dead-time and for a",
                "significant low-energy tail in one of the detectors.",
                "The data were also corrected for nuclear reactions in",
                "the detector."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": 1.0,
                "maximum_value": 3.0,
                "correlation_property": null
              },
              "free_text": [
                " The statistical errors were below 1% for",
                "data out to 50 degr., and did not exceed 3%",
                "below 80 degr."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": 4.0,
                "correlation_property": null
              },
              "free_text": [
                " The relative errors were in total",
                "            less than 4%"
              ]
            },
            {
