          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Elastic scattering of 100 MeV protons and systematic",
                " optical model analysis"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "K.Kwiatkowski",
                "N.S.Wall"
