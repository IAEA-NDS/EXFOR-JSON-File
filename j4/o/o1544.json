          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supporting foils of Sn-115, 39.8% enriched,",
                " 150-mug/cm**2 thick were used.",
                "In order to correct for the contributions from other",
                "Sn isotopes in the Sn-115 target experiments were also",
                "performed on Sn-116, 88.9% enriched and natural Sn."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " DWBA calculations and optical-model parameters.",
                "A spectrum of the Si-28(a,He2)si-30 reaction at Ang=",
                " 15-degree was measured."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Two delta-E-E silicon counter telescopes. The",
                "delta-E and E detector thickness are 0.15 and 5 mm,",
                "respectivily."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COIN"
              ],
              "free_text": [
                " The He-2 events were detected by requiring",
