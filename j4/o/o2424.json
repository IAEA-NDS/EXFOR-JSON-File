          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1 mm - 2 mmm thick target sheets from graphite and",
                "aluminum were used as target. All targets had a",
                "natural abundance of the corresponding isotopes."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe detector with active muon-veto, multi-",
                "layer inner shielding, and outer shielding with 10 m",
                "of water equivalent artificial overburden"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA",
                "TTM",
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                " The initial beam energy",
                "was 228 MeV, which then was reduced to 100 MeV or 180",
                "MeV with a wheel-mounted wedge. The experiment was",
                "done in a pencil-beam scanning treatment room. The",
                "exit nozzle of the beam treatment head was covered by",
                "a kevlar foil with thickness of 0.24 mm. The beam",
                "current was measured by Faraday cups."
              ]
            }
          ],
          "ERR-ANALYS": [
