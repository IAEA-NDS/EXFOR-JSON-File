          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By Authors*.For the absolute normalisation of the",
                "measured cross section, the particles scattered from",
                "a thin layers of gold evaporated onto the target were",
                "detected simultaneously. The relative thickness of both",
                "layers was determined from the observation of pure",
                "Rutherford scattering at a sufficiently reduced beam",
                "energy."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20071001,
                "history": "C"
              },
              "free_text": [
                " S.B"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thick C-12 foil, thickness approximately 50-mug/cm**2",
                "was used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " Telescopes consisting of an ionization chamber",
                " -delta-E counter and a semiconductor detector-E",
                " counter were used for particle detection and",
                " identification."
              ]
            }
          ],
