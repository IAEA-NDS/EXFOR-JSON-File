          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The error bars attached to the individual points",
                "include the statistical uncertainty as well as some",
                "nonstatistical contributions due to inaccuracies in the",
                "background subtraction, separation of the different",
                "particles in the mass spectra and determination of the",
                "solid angles of the detectors. The overall error in the",
                "absolute normalization is estimated to be around 5%."
              ]
