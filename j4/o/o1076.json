          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thin aluminium layer was deposited on the graphite",
                "crystal by evaporation in the vacuum environment, them",
                "the thin Au layer was evaporated on the Al layer in the",
                "same vacuum condition. In order to get mean proton",
                "energies in the Al layer and Au layer for energy",
                "corrections during data analysis, the target thickness",
                "was measured by both 2.5-MeV Li-7 and 400-KeV proton",
                " Rutherford backscattering. The thicknesses of Al layer",
                "and Au layer were 6.28+-0.26e+17 and 1.72+-0.14e+17",
                "atom/cm**2, respectively."
              ]
            }
          ],
