          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Only carefully selected experimental data have been",
                "used in this analysis. Explanations for this selection",
                "are given in detail in Rel-Ref. Nevertheless, the",
                "present analysis of the sigma(0) and sigma(1) states",
                "of cross-sections is consistent with earlier",
                "measurements of the total cross-section of the",
                "O-16(p,g)F-17 reaction from determination of the",
                "produced F-17 activity."
              ]
            }
          ],
