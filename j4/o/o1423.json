          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The gas target side was filled with 500 mbar of He gas.",
                "The scattering chamber- a thin carbon foil for beam",
                "diagnostic, a gold foil of thickness  200 mug/cm**2",
                "used for the normalization of the beam current,",
                "a nickel window of thickness 2 mg/cm**2 with a gold",
                "flash of 35 mug/cm**2 to contain the helium gas target,",
                "a nickel foil of thickness 5.8 mg/cm**2 to stop beam",
                "particles from damaging the silicon detectors."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SIBAR"
              ],
              "free_text": [
                " Three double sided silicon strip",
                "detectors of thicknesses 63 mum, 300 mum and 500 mum",
                "allow the reconstruction of trajectory for protons.",
                "Surface barrier detectors used for the normalization of",
                "the beam current."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
