          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "3IRNAMU"
              ],
              "free_text": [
                " Physics and Nuclear Science Department,",
                " Amir-Kabir University of Technology (Tehran",
                " Polytechnic),"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "3IRNNRT"
