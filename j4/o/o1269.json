          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fission of 209Bi and 197Au nuclei induced by 30 MeV",
                "protons"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NST,38,901,2001",
                "code_unit": [
                  {
                    "unit": "J,NST,38,901,2001",
