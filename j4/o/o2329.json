                  "VDGT"
                ],
                "institute": "2DENNBI"
              },
              "free_text": [
                " Tandem Van de Graaff accelerator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were produced by vacuum evaporation of",
                "oxides onto 1 mg/cm2 nickel foil. The target material",
                "was distributed over a spot 6-7 cm in diam., and",
                "targets were cut from this foil with a surgical knife",
                "or with a punch. The target thickness varied from 10",
                "to about 30mu-g/cm2. This gives recoil yields higher",
                "than 70% at the beam energies used."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "FISCH"
              ],
              "free_text": [
                " The detectors are polycarbonate",
                "        foils (Makrofol)"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "95-AM-243(D,P)95-AM-244-L,,SIG",
                  "code_unit": [
                    {
                      "unit": "95-AM-243(D,P)95-AM-244-L,,SIG",
                      "field": {
                        "reaction": "95-AM-243(D,P)95-AM-244-L",
                        "target": "95-AM-243",
                        "projectile": "D",
                        "process": "P",
                        "product": "95-AM-244-L",
                        "quantity": ",SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": ",SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                " The cross sections are calculated comparing the isomer",
                " yields with the yield of the 1 ms 244mAm under",
                " identical conditions"
              ]
            }
          ],
          "MONIT-REF": [
            {
              "pointer": "",
              "coded_information": {
