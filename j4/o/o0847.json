          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The krypton gas was contained in aluminium cylinders",
                "having a thin window made of tantalum, at a pressure of",
                "about  980 mbar.  The target thicknesses were 185, 230,",
                "310 and 520 keV at 40, 30, 20 and 10 MeV, respectively,"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2ITYMIL"
              },
              "free_text": [
                " Milan AVF cyclotron"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Irradiations were performed with durations of",
                "the order of 1 min and beam currents of about 100",
                "nanoampere."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " After irradiation, the targets were measured",
                "with a Ge(Li) detector, and followed over a period of",
                "time, in order to evaluate the activities of the",
                "various radioisotopes produced."
              ]
            }
          ],
