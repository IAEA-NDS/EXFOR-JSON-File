          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fragmentation cross section measurements of iron",
                "projectiles using CR-39 plastic nuclear track",
                "detectors."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "F.Flesch",
                "S.E.Hirzebruch",
                "G.Huentrup",
                "H.Rocher",
                "T.Streibel",
                "E.Winkel",
                "W.Heinrich"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "2GERGER"
              ],
              "free_text": [
                " University of Siegen"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RM,31,533,1999",
                "code_unit": [
                  {
                    "unit": "J,RM,31,533,1999",
                    "doi": "10.1016/S1350-4487(99)00140-7",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "RM",
                        "number": null,
                        "volume": "31",
                        "part": null,
                        "issue": null,
                        "page": "533"
                      },
                      "date": 1999
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                ""
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20020604,
