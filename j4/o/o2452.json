          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " Triple coincidences of the three alpha",
                "particles. The 12C excitation energy and the total",
                "momentum in the center of mass frame are both",
                "determined from the energies and positions of the three",
                "detected particles. The events that fulfill momentum",
                "conservation, but not energy conservation are",
                "interpreted as gamma-delayed 3alpha emissions from 12C."
              ]
