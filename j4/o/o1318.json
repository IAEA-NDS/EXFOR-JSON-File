          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " Many detector system.",
                " Detailed description see in Rel-Ref.",
                "The eta-meson could be detected directly through its",
                " 2-gamma decay mode, with the photons registered in the",
                "central detector, consisting of two arrays of Cs(I)",
                "crystal preceded by veto-counters. All protons and",
                "deuterons produced in p+d-p+d+eta reaction fall within",
                "the angular acceptance of the forward detector, in",
                "addition to the tracker, there are four set of",
                "scintillators. The forward trigger hodoscopes and",
                "forward range hodoscopes consisting of three 5-mm thick",
                "layers and four 11-cm layers, respectively, which are",
                "vital for particle identification and energy",
                "determination."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SRING"
                ],
                "institute": "2SWDUPP"
              },
              "free_text": [
                " The experiment was performed at the",
                " CELSIUS storage ring, using the WASA/PROMICE",
                "experimental setup."
              ]
            }
          ],
