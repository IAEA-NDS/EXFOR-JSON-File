            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The radioactive atoms of Mg-30 were produced by",
                "impinging 1.4-GeV protons, provided by the CERN PS",
                "Booster."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A secondary target is  5.6-mg/cm**2 thick polyethylene.",
                "A 10.9-mg/cm**2 thick carbon target was also used to",
                "determine effects from carbon-induced reactions in the",
                "polyethylene."
              ]
            }
          ],
