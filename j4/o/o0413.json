          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target assembly usually consisted of three target",
                "foils. The middle foil was used for analysis while the",
                "outer foils compensated for the loss of recoils from",
                "the targets.",
                "The target stack was surrounded on either side by",
                "three 0.001-in. thick aluminum monitor foils."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation times had durations of 15-30",
                "minutes."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "INTB"
              ],
              "free_text": [
                " The circulating beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SITA"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " The chemical yields were determined after the",
                "completion of the activity measurements by flame",
                "photometry. The yields ranged from 10 to 50%."
              ]
            }
