          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A target, consisting of 30-mug/cm**2 Ni-58 or Ni-62",
                "evaporated onto 10-mug/cm**2 carbon foil backing.",
                "A 60-mug/cm**2 self-supporting Ni-58 foil was used also",
                "for part of the experiment."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MWPC",
                "PS"
              ],
              "free_text": [
                " Fusion evaporation residues were detected",
                "using a compact velocity filter and a hybrid",
                "detector. The latter consisted of a",
                "position-sensitive, multiwire, gas proportional",
                "detector backed with a stopping position-sensitive",
                "silicon surface barrier detector. The velocity filter",
                "was operated to pass evaporation residues through to",
                "the detector and to deflect elastically scattered",
                "particles and other reaction residues."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Four silicon Sb monitor detectors"
