          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Angular Distributions of Recoil Products from Some",
                "Reactions Induced in Cu-65 and Au-197 by Proton of",
                "Energy 30-85 MeV."
              ]
            }
          ],
          "AUTHOR": [
