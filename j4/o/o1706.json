          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Sn-119 metal, enriched to 97.4%, was rolled to two thin",
                "foils with mean thicknesses of 5.34 and 11.73 mg/cm**2,",
                "respectivily. The thicknesses were determined from the",
                "weight and area of the foils."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "2DENRIS"
              },
              "free_text": [
                " The PET cyclotron"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GE"
              ],
              "free_text": [
                " A calibrated Ge detector was used for measuring",
                "the monitor foils and the enriched Sn-119 foils for any",
                "produced Sb-118-m and other impurities."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " For determining the produced Sb-119 activities",
                "a calibrated Si(Li) detector or a low-energy Ge",
                "detector was used."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " The Sb-119 activities were corrected for any",
                "simultaneously produced Sn-119-m(T(1/2)=293.1 d), which",
                "emits a single gamma-ray of the same energy-23.87 keV,",
                "by measuring the targets after the Sb-119 had decayed.",
                "The attenuation of the 23.87 keV gamma-ray in the",
                "Sn-119 foils was calculated to be maximum 8%."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                ""
              ]
