          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Production of the Auger emitter Sb-119 for targeted",
                "radionuclide therapy using a small PET-cyclotron."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "H.Thisgaard",
                "M.Jensen"
