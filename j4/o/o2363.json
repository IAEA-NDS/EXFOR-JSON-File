          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of a layer of Li between two 100",
                "micron thick Cu disks. The Li layer was thick enough",
                "to reduce the proton energy below the reaction",
                "threshold. The target was water cooled."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "BAF2"
              ],
              "free_text": [
                " The detector consisted of a neutron-gamma",
                "converter and a BaF2 scintillator. The neutron-gamma",
                "converter was highly enriched (>99%) B-10 powder,",
                "encapsulated in a 100 mm diameter and 10 mm thick",
                "conical carbon fiber container. The scintillating",
                "crystal had a diameter of 100 mm and a thickness of",
                "30 mm."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA",
                "TOF"
              ],
              "free_text": [
                " The forward emitted (+/-4 degrees)",
                "low energy tail (2-22 keV) of the neutron spectrum",
                "from the 7Li(p,n)7Be reaction was studied at proton",
                "energy of 1893.6 keV. The neutrons were detected by a",
                "BaF2 detector, positioned at 690 mm from the target",
                "at zero degree. The trigger for the ToF measurement",
                "was provided by the BaF2 detector, while the time",
                "reference was based on the signal of a capacitive",
                "pickup placed just before the target to detect the",
                "bombarding proton bunch. The signals for the BaF2",
                "detector and the pickup were digitized by a CAEN",
                "DT5751 digitizer and stored in list-mode format for",
                "off-line analysis."
              ]
            }
          ],
