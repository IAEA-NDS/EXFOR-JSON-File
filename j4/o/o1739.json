          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three stacks of terbium and one of lanthanum were used.",
                "Thin layers of terbium oxide, Tb(4)O(7), purity 99.9%",
                "and lanthanum oxide, La(2)O(3), purity 99.9999% on a",
                "high purity aluminum backing of thickness 250 mum were",
                "used. After drying the samples, accurate thicknesses of",
                "the sediment layer were determined by weighing each",
                "Al foil and subtract its weight before sedimentation.",
                "Each sample was covered with 10 mum Al foil to protect",
                "the formed layer in the stack during irradiation and",
                "measurements."
              ]
            }
          ],
