          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Spectroscopically pure cobalt foils with purity better",
                "than 99.9% were used as target. Target foils of",
                "thickness 11.25-mg/cm**2 were cut into pieces of 15-mm*",
                " 15-mm and glued with zapon onto identical aluminum",
                "holders with concentric holes of 10-mm diameter at",
                "their centers. Samples for irradiated were taken in the",
                "form of a stack of these targets. Aluminum target",
                "holders were used for rapid heat dissipation. In order",
                "to achieve the desired variation in incident energy,",
                "aluminum foils of thickness 6.75-mg/cm**2 were",
                "sandwiched between successive target samples of the",
                "stack as energy degraders."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " A 100-cm**3"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Eight cobalt foils along with aluminum energy",
                "degraders."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
