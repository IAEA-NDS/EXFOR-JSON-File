          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "STRUC"
              ],
              "free_text": [
                "  Excitation energies, mean lifetimes, gamma-ray",
                "branching ratios have been measured for levels of Sr-89"
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The presence in spectra of the two strong",
                "Sr-88 lines of energy 898 and 1836 keV, the lifetimes",
                "of which can be derived from inelastic electron",
                "scattering, should provide with a valuable check on",
                "possible errors in the assumed stopping power of the",
                "solid krypton."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                "  Two Ge(Li) detector were located 4-cm from the",
                "target for a gamma-gamma coincidences experiment."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "COMPL"
              ],
              "free_text": [
                " Three Ge(Li) Compton polarimeter for the gamma",
                "linear polarization"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target, enriched to 99.5%, was a solid gas layer,",
                "produced by spraying the gas on to a 250 um gold",
                "backing cooled to less than 15K. The target thickness",
                "was about 5 mg/cm**2."
              ]
            }
          ],
