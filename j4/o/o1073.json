          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 0.1-mm thick Ta target was oriented with its",
                "normal antiparallel to the beam direction.",
                "The deuterated Ta target was produced in the following",
                "way. A fresh Ta foil was bombarded with 10-KeV",
                "deuterons, whereby the deuterons were scanned over the",
                "target area leading to a 20% current reduction compared",
                "to the unscanned case, a stoichiometry Ta(X)D has been",
                "produced near the surface of the Ta sheet. The",
                "deuterated Ta sheet should thus represent an infinitely",
                "thick target for the incident deuterons. The deuteron",
                "distribution was uniform within 10% from the surface of",
                "the Ta sheet down to depths beyond the range of the",
                "implanted deuterons, apparently due to a rapid",
                "diffusion of D and Ta."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1. Thick-target yield curve for protons from D(D,P)T",
                "2. Electron screening potential has been found as 309",
                "+/- 12 eV."
              ]
            }
          ],
          "DETECTOR": [
