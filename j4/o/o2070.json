          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Mg-nat disks 10 mm in diameter and 10 mm thick. The",
                "disks have a purity of 99.9%.",
                "Ca-nat in form CaCO(3) disks. There Dicks had a average",
                "mass of 5.76+-0.23 mg, corresponding to a thickness of",
                "4.55+-0.18 mg/cm**2 or 16.8+-0.7 mum assuming a density",
                "for pure Al of 2.702 g/cm**3.",
                "Ni catcher and Al degrader foils wee used in stacks"
              ]
            }
