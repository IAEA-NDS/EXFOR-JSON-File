          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A liquid deuterium target with a thickness of 3.85 mm,",
                "with an uncertainty of 5%-for proton beam",
                "A solid organic CH(2) target with an effective",
                "thickness of 13.75+-0.24 mg/cm**2 for deuteron beam."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "POLIS"
                ],
                "reaction": null
              },
              "free_text": [
                " The polarization of the beams was measured",
                " using a Lamb-shift polarimeter in the low-energy beam",
                "line and by an in-beam polarimeter that was installed",
                "at the high-energy beam line after acceleration."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " BINA is a setup with a nearly 4-pi geometrical",
                "acceptance and has been used in various few-nucleon",
                "scattering experiments to measure the scattering angles",
                "and energies of proton and deuterons with the",
                "possibility for particle identification. The detector",
                "is composed of a forward part and a backward part. The",
                "forward part consists of a Multi-wire proportional",
                "chamber (MWPC) and a segmented hodoscope of vertically",
                "placed thin scintillators with a thickness of 2 mm",
                "followed by ten horizontally placed scintillators with",
                "a thickness of 12 cm each."
              ]
            }
          ],
          "FACILITY": [
