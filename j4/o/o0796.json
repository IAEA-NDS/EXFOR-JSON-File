                "ACTIV"
              ],
              "free_text": [
                " The time sequence of the complete cycle is:",
                "1.  1.5 s beam-on-target;",
                "2.  100 ms rotation;",
                "3.  1.5 s of target in the counting position;",
                "4.  100 ms rotation."
              ]
            }
