          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target consisted of a thin film of Na-Cl (14.4",
                "mug/cm2) evaporated on a self-supported thin film of",
                "Ag.  The stoichiometric ratio between the number of Na",
                "and Ag nuclei in the target was measured by Rutherford",
                "backscattering of 1.8 and 2.0 MeV alpha particles, at",
                "162 and at 140 degree.  These measurements were done",
                "before and after the cross-section measurement in order",
                "to verify the target stability."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "47-AG-0(P,EL)47-AG-0,,DA",
                  "code_unit": [
                    {
                      "unit": "47-AG-0(P,EL)47-AG-0,,DA",
