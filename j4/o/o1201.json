          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The detector was placed at an angle of 120 degr.",
                "to the beam axis."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " Proton beam currents around 200 nA were used."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                "A Faraday cup was used, surrounding the target",
                "and electrically connected to it, to measure the beam",
                "current."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SITA"
