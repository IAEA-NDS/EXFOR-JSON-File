          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " Two sheets of polycarbonate detectors, 200 um",
                "thick, with a fissile target in between.",
                "The detectors registered only ions with Z >= 8 with a",
                "length > 5 um."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " A calibrated end-window proportional counter",
                "was used for the monitoring measurement."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets, 15-100 um/cm**2 thick, were prepared by",
                "vacuum evaporation of uranium fluoride, thorium",
                "fluoride or metal bismuth upon one of the detector",
                "sheets."
              ]
            }
          ],
          "METHOD": [
            {
