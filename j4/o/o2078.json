          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The gas cell consisted of a thin brass cylinder closed",
                "at one end and was bolted on to the target chamber in",
                "place of the solid target. A thin platinum window of",
                "approximately 14 mg/cm**2 isolated the nitrogen gas",
                "from the cyclotron vacuum system. It was mounted behind",
                "an aperture of diameter 1 cm in a thick gold disc and",
                "would withstand a maximum pressure difference of about",
                "30-cm Hg. For this particular exposure, analytically",
                "pure nitrogen gas at a pressure of 22-cm Hg was used.",
                "The volume of the target was defined by the aperture in",
                "the gold disc and by the 2.0-cm length of the cell."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections having been applied for the volume of",
                "emulsion scanned and the variation of the n-p cross",
                "section with energy."
              ]
            }
