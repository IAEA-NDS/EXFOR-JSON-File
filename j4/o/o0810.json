          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 18-O targets have been prepared as Al/2-18O/3 films",
                "deposited onto 0.4-mm-thick Ta backings by reactive",
                "sputtering in an Ar/18-O/2 mixture at 0.4 Pa.  The",
                "18-O/2 gas was of high purity, >99.9% in chemical",
                "composition and 96.6% in isotopic enrichment, and an",
                "aluminum disk of high purity (99.999%) has been used as",
                "the sputtering cathode."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " The combination of Ge and BGO detectors together",
                "active and passive shield.  All details in REFERENCE."
              ]
