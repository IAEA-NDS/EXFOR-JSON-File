          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "- By authors.  The combination of the high resolution",
                "Ge detector and the high-efficiency BGO scintillators",
                "was instrumental for achieving the required detection",
                "sensitivity for investigating the very weak resonances",
                "at astrophysical energies.  The remarkable stability of",
                "the sputtered targets under the thermal load of high",
                "beam currents is an additional parameter contributing",
                "to the success of the measurement."
              ]
            }
