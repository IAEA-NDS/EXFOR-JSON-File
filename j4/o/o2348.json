          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "9Be target with thickness of 1720 mg/cm**2,",
                "positioned at the middle focal plane (F2) of the",
                "fragment separator"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " reaction products were momentum analyzed by",
                "the GSI Fragment Separator, a two-stage magnetic",
                "spectrometer"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Scintillation counters placed at focal planes",
                "F1, F2 and F4, measured the time-of-flight from F1",
                "to F2 and from F3 to F4."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SPEC"
              ],
              "free_text": [
                " Multi sampling ionization chambers at F2 and",
                "F4 were used to determine the energy loss, and thus",
                "the charge of the fragments. The position of the",
                "fragments was measured with six time projection",
                "chambers."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Gamma-rays were detected by the eight cluster",
                "detectors of the MINIBALL array, mounted after the",
                "target, at focal plane F2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF",
                "SITA",
                "GSPEC"
              ],
              "free_text": [
                " One neutron knockout was studied on",
                "51Sc, 52Sc, 53Sc, 54Sc, and 55Sc isotopes.",
                "Experimental values for the inclusive cross sections",
                "could be measured, whereas the individual",
                "contributions from L=1 and L=3 knockout reactions",
                "could be also identified via the measurement of",
                "longitudinal momentum distributions of the fragments."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The beam of 51-55Sc isotopes was produced in",
                "fragmentation reactions on a 9Be target of 1625",
                "mg/cm**2 thickness by a 500MeV/u 86Kr primary beam.",
                "The production target was placed at the entrance of",
                "the fragment separator."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Momentum distributions of Sc isotopes were corrected",
                "for the spectrometer acceptance (incomplete",
                "compensation of energy loss by the scaling of the",
                "magnets)."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
