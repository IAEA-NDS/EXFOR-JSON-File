            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The B-10 and O-16 targets were respectively obtained",
                "by a sandwich of four isotopically enriched B-10",
                "targets with thickness of 0.1-mg/cm**2 each and",
                "a 0.60-mg/cm**2 thick V(2)O(5) target. The B-10 target",
                "had some content of B-11 and impurity of O-16."
              ]
            }
          ],
