          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FISCT",
                "EXTB",
                "STTA",
                "EDEG"
              ],
              "free_text": [
                ". The Proton Beam with Initial",
                "Energy of 660 MeV was Passed Through Copper Filters to",
                "Degrade Its Energy. No Ref. Is Given to Stopping Power",
                "Tables. Thickness of the Degraders is Given Under",
                "'Misc4'."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PLATE"
              ],
              "free_text": [
