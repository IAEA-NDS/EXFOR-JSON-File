          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were prepared by vacuum evaporation of the",
                "respective material onto 20-mug/cm**2 carbon backings.",
                "The target thickness ranged from 100 to 200-mug/cm**2",
                "and isotopic abundance was 98.3%, 99.35% and 94% for",
                "Sm-152, Gd-154 and Gd-156, respectively."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                ".DWBA calculations.",
                "Triton and deuteron spectrum from the Sm-152(a,t)",
                "and Sm-152(He3,d) reactions at angle 40-",
                "and 25-degree are shown."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " An Enge split-pole magnetic spectrograph."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PS",
                "PROPC"
              ],
              "free_text": [
                ".A position-sensitive proportional counter,",
                "located in the focal plane of the spectrograph.",
                "An energy resolution of ~20-KeV-full width at half",
                "maximum for the (a,t) reactions and ~28-KeV for the",
                " (He3,d) reaction was obtained."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " A Si-surface-barrier monitor detector which",
                "was used to detect the elastically scattered",
                "projectiles."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By authors. Absolute differential reaction cross",
                "sections were obtained by normalizing the elastic",
                "scattering intensity measured with the monitor detector",
                "to results of DWBA-calculations of the elastic",
                "scatering. See table 1-3.",
                "-By compiler.  Some plots for angular distributions are",
                "presented in the original paper.  But size of the plots",
                "is very small. Therefore the data were not scanned."
              ]
            }
