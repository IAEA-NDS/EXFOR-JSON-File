          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "83-BI-209",
                "field_identifier": "NAT",
                "value": 1.0
              },
              "free_text": [
                " Metallic 209Bi targets, wrapped",
                "into 16 micron thick Al catcher foil."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
