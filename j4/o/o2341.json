          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "BCINT",
                "EXTB",
                "GSPEC",
                "TTM",
                "SITA",
                "MOSEP"
              ],
              "free_text": [
                " Thick-target",
                "yields of the 209Bi(a,2n)211At reaction were measured",
                "at 28.8 and 32.8 MeV bombarding energies. The targets",
                "were thick enough to ascertain the total absorption",
                "of alpha particles. The typical beam current was",
                "50-250 nA, while the integrated beam current amounted",
                "100-450 uC. Thin Cu foils were used as monitors.",
                "Thick target yields were determined by",
                "gamma-spectroscopy before the radiochemical",
                "separation. The overall radiochemical yield",
                "for 211At varied between 60 and 80%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "THEO"
              ],
              "free_text": [
