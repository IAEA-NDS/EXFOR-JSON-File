          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thick carbon, paraffin and water targets were used.",
                "The water targets were closed cells made of 3 mm thick",
                "plexiglass walls."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By authors. The total charge-changing cross sections",
                "were obtained from the numbers of matched tracks",
                "corresponding to the peak of carbon measured in the",
                "active detector areas in front of and behind a given",
                "target.",
                "The errors in total charge-changing cross section are",
                "statistical only.",
                "The partial cross section for the production of",
                "projectilelike fragments were measured."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                "  CR-39 track-etch detector.",
                "The detector plates were approx. 600-mum in thickness",
                "interleaved with the targets. Both the detectors",
                "and the targets were approx. 4*4 cm**2 in area. One",
                "detector plate was placed in front of the stack to",
                "monitor the primary beam and the accompanying particles",
                "produced in materials precceding the stack. The",
                "fragments produced in targets were measured all along",
                "the stacks, together with the primary ions and",
                "accompanying particles. In fact, two detector plates",
                "were put in between neighboring targets to increase the",
                "accuracy of track measurements."
              ]
            }
          ],
