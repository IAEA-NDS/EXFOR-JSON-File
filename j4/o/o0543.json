          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "/by Authors/.In the Polarization Measurements the Mean",
                "Incident Energy was 30.20+-0.33 MeV Owing to the",
                "Thicker Targets. However, For Convenience, All the Data",
                "Have Been Analysed Assuming a Scattering Energy of",
                " 30.50 MeV."
              ]
            }
          ],
