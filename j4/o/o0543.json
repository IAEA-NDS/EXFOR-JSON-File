          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Rolled Self-Supporting Metal Foils Approx.",
                " 5 mg/cm**2 Thick were Used As Target.",
                "The Main Impurities were Other Isotopes of Zinc Which",
                "Amounted to Approx. 4% For the Zn-66 Target and Approx.",
                " 1% For the Others.The Overall Energy Resolution was",
                "Approx. 100 KeV.",
                "For the Polarization Measurements the Target Thickness",
                "Was Increeased to Approx. 40 mg/cm**2 and the Overall",
                "Energy Resolution was Approx. 150 KeV."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
