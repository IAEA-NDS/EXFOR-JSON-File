          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "TRN",
                "SITA",
                "EDE",
                "TOF"
              ],
              "free_text": [
                " Charge-changing cross",
                "sections of Be+12C were measured by the transmisson",
                "method. Incident beams of 1 GeV/A 40Ar and 22Ne were",
                "used to produce secondary beams of various Be",
                "isotopes. The production target was 5 g/cm2 thick Be."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "POT"
              ],
              "free_text": [
                " The proton distribution radius of 14Be is",
                "determined based on the experimental cross section",
                "data, and was found to be 2.41 +/- 0.04 fm."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "THEO"
              ],
              "free_text": [
                " The experimental data were compared to their",
                "calculated values based on fermionic molecular",
                "dynamics and the harmonic oscillator model."
              ]
            }
          ],
