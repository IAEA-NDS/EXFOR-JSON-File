          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Pb-208 target with thickness 300 mug/cm**2 on",
                "a 30 mug/cm**2 carbon backing was used.",
                "An experiment at forward angles, including 0-degree",
                "was also performed with a Pb-208 self-supporting target",
                "of 1.3 mg/cm**2 in order to avoid reactions on",
                "contaminants such as carbon and oxygen."
              ]
            }
          ],
