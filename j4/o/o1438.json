          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By authors.The normalization between backward and",
                "forward exposures is assured by a more than one degree",
                "overlap between each runs. The beam emittance and the",
                "counting rate were such that it was possible to have",
                "0.4-degree bites for the angular distributions of the",
                "transfer reaction products."
              ]
            }
          ],
