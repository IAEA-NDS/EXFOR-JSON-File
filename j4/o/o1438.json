          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " Excitation and bombarding energies have been corrected",
                "to take into account the energy loss in the target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " magnetic spectrometer SPEG."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " The detection system included- two position",
                "drift chambers, giving a (X,Y) localization of 0.6 mm,",
                "a large ionization chamber giving energy loss",
                "information which also enclosed charge division",
                "proportional counters for alignment control,",
                "a plastic scintillator for the start signal, the stop",
                "signal was given by the cyclotron."
              ]
            }
          ],
