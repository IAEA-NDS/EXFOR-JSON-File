          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " (d,Li-6) alpha-transfer reaction on S-32 and S-34",
                "at E(d)=80 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "W.Oelert",
                "G.P.A.Berg",
