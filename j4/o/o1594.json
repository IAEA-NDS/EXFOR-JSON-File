              ],
              "free_text": [
                ""
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,28,73,1983",
                "code_unit": [
                  {
                    "unit": "J,PR/C,28,73,1983",
