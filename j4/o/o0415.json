          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets used in this experiment consisted of",
                "cylindrical pilot b plastic scintillators 1/8 in. thick",
                "and 5/8 in. diam., containing 91.55% carbon by",
                "weight.",
                "For each irradiation a target was carefully aligned",
                "with and taped directly to the upstream side of",
                "scintillation counters, which was the same size as",
                "the target.",
                "Each one of the targets was irradiated in the proton",
                "beam for approximately 20 min."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " A scintillation counter telescope.",
                "1/8-in. thick and either 5/8 or 1 in. diam. was",
                "optically coupled via a 6-in. -long by 1/8-in. -thick",
                "Lucite light pipe to a RCA-8575 photomultiplier."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " two NaI(Tl) well crystals"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Starting about 10 min after the end of an",
                "irradiation, the c-11 activity was measured either by",
                "internal scintillation counting or by positron-",
                "annihilation radiation counting."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " Pi+ Mesons contamination of the beam was less",
                "than 4%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " Each decay curve was analyzed."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The errors assigned to a measurement are made",
                "up of the standard deviation of the counting rate,",
                "the uncertainty in counting efficiency and"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-1",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " error in aligning the target with the counter",
