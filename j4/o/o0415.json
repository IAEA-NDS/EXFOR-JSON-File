              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-2",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " error 1.5% was assigned to represent the",
                "accuracy of the coincidence method of source",
                "calibration."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "/by Authors/. A secondary-effect correction was then",
                "calculated as a function of target thickness.",
                "After the target thickness correction was made, the",
                "cross section was then corrected for the pi+",
                "contamination of the beam by using the C-12(pin,pin+n)",
                "cross section and assuming that the pi+ cross section",
                "is the same as the pi- cross section and the pion cross",
                "section is the same at 8.5 GeV/C."
              ]
            }
          ],
