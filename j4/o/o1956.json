          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "FRAGM"
                ],
                "reaction": null
              },
              "free_text": [
                " 238U (950 AMeV) on Pb (650 mg/cm2 thick) to",
                " produce 132Sn secondary beam"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Be target (2.6 g/cm2 thick)"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "TPC",
                "IOCH",
                "SCIN"
              ],
              "free_text": [
                "",
                "The reaction products were analyzed with the magnetic",
                " spectrometer fragment separator (FRS).",
                "Time-projection chambers (TPC) provided the position of",
                " the nuclei at the intermediate and final focal planes",
                " of the spectrometer used to determine their magnetic",
                " rigidities.",
                "Three plastic scintillators were used to obtain the",
                " velocities of the ions in both sections from their",
                " time of flight.",
                "Two multi-sampling ionization chambers (MUSIC)",
                " provided the identification in atomic number from",
                " the energy lost by the nuclei traversing these",
                " detectors."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The yields were normalized to the number of 132Sn",
                " projectiles arriving at the intermediate focal plane",
                " and to the number of atoms per unit surface area of",
                " the target in order to obtain the production cross",
                " sections."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrected for optical transmission between the",
                " intermediate and final focal planes of the",
                " spectrometer."
              ]
            }
          ],
