          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The error of the measured values of the",
                "yields of In-111 and In-114-m was estimated to",
                "be about +-12%. No other information about source of",
                "uncertainties. This uncertainty presented on fig.1 in",
                "several cases."
              ]
            }
          ],
