          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Yield and excitation functions measurements of some",
                "nuclear reactions on natural thallium induced by",
                "protons leading to the production of medical",
                "radioisotopes Tl-201 and Pb-203"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "F.S.Al-Saleh",
                "A.A.Al-Harbi",
