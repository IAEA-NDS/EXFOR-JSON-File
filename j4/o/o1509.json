              ],
              "free_text": [
                " Nuclear physics department."
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,RCA,95,127,2007",
                "code_unit": [
                  {
                    "unit": "J,RCA,95,127,2007",
                    "doi": "10.1524/ract.2007.95.3.127",
                    "field": {
                      "reference_type": "J",
