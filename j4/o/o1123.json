          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Metallic Nb-93 of high purity was used as a target."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "4ZZZDUB"
              },
              "free_text": [
                " U-200 accelerator."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Self-supporting Nb-foils were packed into two",
                "different stacks together with appropriate Al",
                "degraders. The first stack was composed of 5 Nb foils",
                "with weights of 4.8 mg/cm**2 and additional Al energy",
                "degrading foils between them. The second stack was",
                "composed of 8 Nb foils with weights of 4.3 mg/cm**2."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The first stack was irradiated for 6.5 hours",
                "with the beam intensity corresponding to 8.6 milliCurie",
                "collected charge and the second one - for 3-hours with",
                "2.7 milliCurie collected charge."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " After a \"cooling time\" > 35 hours for first",
                "stack and 26 hours for second stack.  The measuring",
                "times were between 7 and 12 hours."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "EDEG"
              ],
              "free_text": [
                " The energy of primary He-3 beam was 48.3",
                "MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Two high-resolution gamma-spectrometers-with",
                "110-cm**3 and 72-cm**3 active volumes."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                "  COMPLET Code. The code combines preequilibrium",
                "and equilibrium reaction mechanisms."
              ]
            }
          ],
