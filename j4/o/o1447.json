          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target was a thin layer of material laid by",
                "vacuum evaporation on a thin-50-mm in diameter backing",
                "foil made of Al(2)O(3). The target diameter was 40-mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "COIN",
                "PPAC",
                "PPAC"
              ],
              "free_text": [
                " Two parallel-plate avalanche  gas",
                " counters were used as fission fragment detectors."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN",
                "SCIN",
                "SCIN"
              ],
              "free_text": [
                " A scintillation counter",
                "telescope was used for beam monitoring. The beam",
                "monitoring was done by two methods-by detection of",
                "the fission events from the calibration target U-238",
                "and by detecting the events of the pp-scattering on the",
                "auxiliary CH(2)-target with the two-arm scintillation",
                "telescope."
              ]
            }
          ],
