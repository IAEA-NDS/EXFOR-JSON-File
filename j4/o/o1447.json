            },
            {
              "pointer": "",
              "coded_information": [
                "EDEG"
              ],
              "free_text": [
                " Copper absorber was used to decrease beam",
                "energy. Proton energy distributions were measured at",
                "used target by time-of-flight method. The TOF spectra",
                "analysis showed that the pi+ mesons were practically",
                "absent."
              ]
            }
