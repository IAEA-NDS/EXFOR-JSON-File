          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target in the center of the setup is based on a",
                "thin strip of 500 mug/cm**2 thick metallic Ti foil",
                "loaded with an atomic ratio H-3/Ti of (CH2)n target",
                "of 1.5 corresponding to a target thickness of",
                " 40 mg/cm**2 H-3.The activity of the target was 10 GBq."
              ]
            }
          ],
