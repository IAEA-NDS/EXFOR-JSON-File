          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A self-supported 99.6% enriched Li-6, 110-mug/cm**2",
                "thick, was used. The target contained H and O-16",
                "the target surface was scanned with the beam and was",
                "found a uniformity of better than 1%.",
                "Contaminants."
              ]
            }
          ],
          "ADD-RES": [
            {
