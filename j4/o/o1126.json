              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "POT"
              ],
              "free_text": [
                " Optical potential parameters.",
                "Phase shifts."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SILI"
              ],
              "free_text": [
                " A 3-mm thick cooled Li-Si detector for angles",
                "between 5.5 and 100 degrees."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SIBAR",
                "SIBAR"
              ],
              "free_text": [
                " A telescope, consisting of two",
                "500-mum surface-barrier detectors in anticoincidence",
                "for angles between 100 and 120 degrees and the recoil",
                "Li-6 particles beyond this angular range."
              ]
            }
          ],
