          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements were Made For the Ten Elements Al,V,Cu,",
                "Zr,Ag,in,Ta,Pt,Au and U with 30 and 50 MeV Protons",
                "Using the Long Flight Path and For Au,Pt and U at 30",
                "MeV Using the Short Flight Path.",
                "The Neutron Production Targets were of the Natural",
                "Element in the Form of Foils and were Approximately",
                " 0.5 MeV Thick For 50 MeV."
              ]
            }
          ],
