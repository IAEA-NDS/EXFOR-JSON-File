          "FLAG": [
            {
              "pointer": "",
              "coded_information": [
                2.0
              ],
              "free_text": [
                " At the energy reaction In-115(p,n)Sn-113 is",
                "possible too. In-115 contribution has been excluded.",
                "See COMMENT."
              ]
            }
          ],
          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "-By authors. In order to separate out the contributions",
                "due to In-113(p,n) and In-115(p,3n) reactions at 18.31",
                "and 20 MeV, the ratio of cross-sections",
                " sigma(p,n)/sigma(p,3n) are calculated theoretically",
                "using the code ALICE-91, with those parameters which",
                "gave a satisfactory reproduction of the lower energy",
                "data for this reaction. The contribution of two",
                "reactions has been separated taking into account the",
                "relative abundances of 113-In and 115-In isotopes and",
                "the theoretical cross-section ratios. In this way the",
                "cross-sections for (p,3n) reaction at 18.31 and 20 MeV",
                "are found to be ~5.9 mb and ~43,3 mb respectively."
              ]
            }
          ],
