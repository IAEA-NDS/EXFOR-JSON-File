          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The self-scattering and self-absorption corrections.",
                "The multiplying factors used on the counting rates",
                "to allow for self-scattering and self-absorption,",
                "taken together, were 1.036 for 5.5 mg/cm**2, polythene",
                "and 1086 for 19 mg/cm**2 aluminium."
              ]
