          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thin U targets were produced by vacuum deposition",
                "of U-F4 onto cellulose acetate supporting films, about",
                "25 um/cm2 thick, mounted in 11*12 cm aluminum frames.",
                "For Ta targets the metal was deposited in vacuum onto a",
                "glass surface previously coated with about 5 um/cm2 of",
                "carbon to facilitate removal of the Ta by flotation on",
                "water. The metal film could then be placed in the",
                "center of a thin cellulose acetate support by raising",
                "the support film under the floating Ta.",
                "Target thicknesses were about 50 um/cm2 for U and about",
                "300 um/cm2 for Ta."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "FISCT",
