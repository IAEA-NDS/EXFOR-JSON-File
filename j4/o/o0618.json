          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Silicon surface-barrier detectors were used to",
                "detect and measure energies of the fission fragments.",
                "The sensitive volumes were cylindrical, mostly about",
                "24 mm in diameter and 50 um thick. Detectors",
                "were mounted on arms so that the angles they subtended",
                "at the target could be changed. Detector to",
                "target distance was 30 - 40 cm.",
                "Discriminators were set to cutoff pulses smaller than",
                "those corresponding to 30-MeV fission fragments.",
                "Energy calibration makes use of the results of",
                "Schmitt+, see REL-REF."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " A He-filled ionization chamber for relative",
                "beam monitoring, calibrated with the use of a Faraday",
                "cup."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
