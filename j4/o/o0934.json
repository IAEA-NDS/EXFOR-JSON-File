          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Evaporation residue cross sections were measured",
                "using the time-of-flight technique in connection with",
                "an electrostatic deflector which removed most of the",
                "beamlike flux. The evaporation residues were implanted",
                "behind the deflector into a surface barrier detector",
                "and the time of flight was measured against the signal",
                "of a plastic scintillator downstream from the target."
              ]
            }
