          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin samples of enriched 68-Zn (98.3%) were produced by",
                "electrolytic deposition on 10 and 12.5 micrometers",
                "thick gold backing."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA"
              ],
              "free_text": [
                " Several stacks were irradiated, each containing",
                "up to 12 samples and copper and aluminium foils as",
                "energy degraders and monitors for the proton beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " The primary proton energies used were:",
                "45.5 +/- 0.1 MeV at Julich and 71.0 +/- 0.2 MeV at",
                " Villigen"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " For studies on Cu-67 produced via the proton -",
                "induced nuclear reaction on 68-Zn a radiochemical",
                "separation of stable 68-Zn, radiogallium and",
                "radiocopper was neccessary."
              ]
            },
