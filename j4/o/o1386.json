          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " The average beam current intensity of 47 MeV/A",
                "12-C was 8 nanoAmperes.  The irradiation beam time was",
                "Separated for several sections in order to make mother",
                "- daughter decay modifications and to obtain the",
                "average production cross sections of residues."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The beam current was monitored by a Faraday",
                "cup. Both methods of beam current measurements gave",
                "the same results within the limit of error."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The whole irradiation time was 6.8 hours."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " Off-line gamma-spectroscopic method."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "CHSEP"
              ],
              "free_text": [
                " Reaction products from a part irradiated target",
                "were separated by a standard radiochemical separation",
                "method."
              ]
            }
          ],
