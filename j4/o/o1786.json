          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The absolute cross sections were obtained",
                "from a comparison with the simultaneously measured",
                "elastic scattering cross section from a thin gold",
                "layer evaporated onto the target, the ratio of gold to",
                "beryllium atoms was determined using a heavy-ion beam",
                "of sufficiently low energy so that for both elements",
                "the scattering was purely Rutherford scattering."
              ]
            }
