          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thin vanadium layer was deposited on the film",
                "by vacuum evaporation (2.E-03-Pa), then the thin gold",
                "layer was evaporated on the vanadium layer at the same",
                "vacuum conditions. The area densities of vanadium and",
                "gold layers were 6.91E+17-atom/cm**2 and 7.23E+16-atom/",
                "cm**2, respectivily. A thin carbon film was chosen to",
                "be substrate of the target."
              ]
            }
          ],
