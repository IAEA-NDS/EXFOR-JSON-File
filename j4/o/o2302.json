          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Determination of Be-9(p,p0)Be-9, Be-9(p,d0)Be-8 and",
                "Be-9(p,alpha0)Li-6 cross sections at 150-degree in the",
                "energy range 0.5-2.35 MeV."
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
