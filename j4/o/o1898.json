          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Thin antimony layers on titanium backings were prepared",
                "by sedimentation. The Ti-foil of 13 mm diameter and",
                " 12.5 mum thickness was fastened in a sedimentation",
                "cell.",
                "Two stacks were prepared for the natural antimony",
                "containing a total of 20 samples, each in the form of",
                "a sandwich mentioned above. Further two stacks were",
                "prepared with 18 sample of the 98.28% enriched Sb-123.",
                "Several additional Ti (12.5 mum) and Al(50 mum) foils",
                "were inserted in the stacks as energy degraders.",
                "The thickness of the antimony layer was 1-6 mg/cm**2."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
