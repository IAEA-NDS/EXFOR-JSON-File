          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A set of sandwich-type foils was used.  It consists of",
                "about 1.5 mg/cm2 metallic Bi targets obtained by vacuum",
                "evaporation onto 7 mum Al foils.  To reduce the helium",
                "ion energy 50-100 mum thick Al foil absorbers were used",
                "For the chosen target layer the efficiency of",
                "registration of fission fragments was (80+/-7)%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " For the registration of fission fragments 55 mum",
                "thick  polyterephthalate plastic and muscovite mica",
                "detectors were used."
              ]
            }
          ],
