          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 60Fe secondary beam was produced by fragmentation",
                "of a 64.5 MeV/u 64Ni beam in 500 microns thick 9Be",
                "target. The LISE3 spectrometer was used to select the",
                "60Fe beam."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PS",
                "MWPC"
              ],
              "free_text": [
                " two MWPC detectors for beam tracking,",
                "positioned upstream of the target"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SISD"
              ],
              "free_text": [
                " annular double-sided Si strip detector (DSSD)",
                "with thickness of 500 microns, positioned upstream of",
                "the target"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SILI"
              ],
              "free_text": [
                " four MUST2 telescopes, each",
                "consisting of a 300 microns thick DSSD, and a Si(Li)",
                "detector"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " four segmented Ge detectors from the EXOGAM",
                "array for detection of gamma-rays from the",
                "de-excitation of 61Fe"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " ionization chamber positioned behind the target"
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " plastic scintillator located behind the target",
                "for time-of-flight measurement"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "TRN",
                "SITA",
                "EDE",
                "TOF",
                "COINC",
                "BCINT"
              ],
              "free_text": [
                " Proton angular",
                "distributions were measured by the annular DSSD",
                "detector and the MUST2 telescope detectors. The",
                "analysis of data was done separately for the two",
                "systems, but combined at the end."
              ]
            }
          ],
