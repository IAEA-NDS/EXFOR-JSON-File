          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " Experimental data were compared with results",
                "from adiabatic disorted wave approximation. The",
                "direct capture cross section of the 60Fe(n,g)61Fe",
