          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A metallic uranium layer of 1-mg/cm**2 deposited by an",
                "electromagnetic mass separator on a thin graphite",
                "foil, 2.8-mg/cm**2, was used as target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The beam energy was degraded by Al-foils and",
                "measured by observing elastically scattered Ne-22",
                "from 50-mug/cm**2 gold foil with a calibrated and",
                "collimated surface barrier detector."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT",
                "OLMS"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                " A number corrections have been applied to the data-",
                " -corrections for radioactive decay",
                " -correction for cumulative products",
                " -normalization of the results (first, adjacent groups",
                " of masses were measured in such a way that there was",
                " at least on overlapping mass and second, yields for",
                " each mass number were reduced to the same integrated",
                " beam charge. This method is limited because of",
                " uncertainties in beam charge measurement. The",
                " agreement observed between the two method implies that",
                " the efficiency of the mass spectrometer was constant",
                " within 20%."
              ]
            }
          ],
