          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "All samples had a chemical purity of 99.9%. The V- and",
                "Lu-metal sheets and the Pd-V(10%) and Pd-Lu(10%) alloys",
                "were 0.5 and 0.4-mm thick, respectively. The VO(2) or",
                "Lu(2)O(3) powder was pressed into a cyllindrical hole,",
                "28-mm diameter, 5-mm deep, of a Cu-backing with a",
                "thickness of about 5-mm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "D4PI"
              ],
              "free_text": [
                " The neutron yields were measured using a 4-pi",
                "detector, consisting of eight He-3 filled proportional",
                "counters, embedded in a polyethylene-cylinder moderator",
                "with a central bore hole to install the target. The",
                "spectra of the 8-counters were summed, dead time",
                "effects were kept below 1%. The neutron efficiency as",
                "a function of neutron energy was calculated and tested",
                "using a calibrated Cf-252 source. The efficiency varies",
                "from 29% to 27% for both (p.n) reactions over the",
                "Energy range."
              ]
            }
          ],
