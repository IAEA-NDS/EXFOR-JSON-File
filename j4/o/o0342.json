          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Carbon, aluminium, iron, tin, gold and thorium were",
                "used as targets. Any additional information is absent."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A large part of the tritons is emitted in a forward",
                "direction by a secondary 'Pick up' Reaction.",
                "A spectrum was built-up for these tritons.Ratios of the",
                "number of tritons to 'prompt' protons were calculated",
                "for gold nuclei, one proton in 15 picks-up two neutrons",
                "on nuclear Boundaries whatever the energy in the range",
                " 15-42 MeV."
              ]
            }
