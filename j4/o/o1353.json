            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Carbon target, consisted of graphite pills, diameter",
                " 24-mm, height 16-mm, enriched to 82% in C-13,",
                "resulting in a density 0.67 g/cm**3. The pills were",
                "enclosed in a cylinder of 24.5-mm inner diameter with",
                "a wall thickness of 15-mm. The overall target length",
                "was 16-cm, equivalent to 10.7-g/cm**2, I.E. 20% larger",
                "than the proton range."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " EDEN-detectors. Each module is a cylinder of 20-",
                "cm diameter and 5-cm length containing NE213 liquid",
                "scintillator is used for neutron-gamma ray pulse shape",
                "discrimination.",
                "The proton detector placed in beam line upstream of the",
                "target was 2-mm thick NE102a plastic scintillator."
              ]
            }
