                        "quantity": "CUM,SIG",
                        "data_type": null,
                        "general_quantity_modifier": null,
                        "quantity_236": "CUM,SIG"
                      }
                    }
                  ],
                  "unit_combination": "(%)"
                }
              },
              "free_text": [
                "",
                "The standard excitation functions were used for the",
                "determinations of the energy of the incident beam and",
                "the flux of alpha-particles.  The fluxes obtained",
                "through both standard functions differ only in 1%,",
                "whereas the error in its determination is less than",
                "11%."
              ]
            }
          ],
