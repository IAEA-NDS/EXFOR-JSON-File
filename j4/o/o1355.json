            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "29-CU-63(A,X)30-ZN-65,CUM,SIG",
                  "code_unit": [
                    {
                      "unit": "29-CU-63(A,X)30-ZN-65,CUM,SIG",
                      "field": {
                        "reaction": "29-CU-63(A,X)30-ZN-65",
                        "target": "29-CU-63",
                        "projectile": "A",
                        "process": "X",
