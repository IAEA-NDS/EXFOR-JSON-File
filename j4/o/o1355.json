          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Au-foils were analyzed spectroscopically and it was",
                "found that the quantities of impurities were",
                "negligible.  The thickness of these foils was about",
                "19-mg/cm2, whereas the one corresponding to Cu was",
                "about 29-mg/cm2. Each foil was wrapped in Al  of",
                "surface density 3.72-mg/cm**2 in order to avoid the",
                "loss of radioactive nuclei by recoiling."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "29-CU-65(A,2N)31-GA-67,,SIG",
