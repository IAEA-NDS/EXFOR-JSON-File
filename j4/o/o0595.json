              },
              "free_text": [
                ""
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Corrections For Energy Loss For the Protons in the",
                "Target Itself were Calculated."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The Errors Associated with the Fractional Yield Data",
                "Are Due Mainly to Uncertainty in the Exact Proton",
                "Energy at Which the Bombardments were Made Due to the",
                "Radial Distribution of the Proton Beam and Energy",
                "Losses in the Target Itself.Nevertheless the Beam",
                "Energy was Probably Known to 2-5 MeV.The Disintegration",
                "Rates were Measured Relatively So That Errors",
                "Associated with these are Small Approx. 1%.The",
                "Graphical Decay Curve Analyses Associated Extrapolation",
                "Data and Chemical Analyses,Present No Difficulties and",
                "These Errors are Certainly Less Than 5%.It is Believed",
                "That an Uncertainty of +-10-15% on an Over-All Basis",
                "Would Cover the Above and Include Systematic Errors."
              ]
            }
          ],
