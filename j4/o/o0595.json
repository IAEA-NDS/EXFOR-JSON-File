          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Three Thorium Metal Foils of About 200 mg/cm**2 Super-",
                "Ficial Density were Used."
              ]
            }
          ],
          "FACILITY": [
            {
