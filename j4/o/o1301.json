          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 1023 mg/cm2 thick beryllium target placed at the",
                "entrance to the Projectile Fragment Separator (FRS)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SPEC",
