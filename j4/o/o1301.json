          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCH"
                ],
                "institute": "2GERGSI"
              },
              "free_text": [
                "",
                "The reaction products were separated by fragment",
                "separator (FRS). The FRS operated in the standard",
                "achromatic mode.  The FRS, combining two stages of",
                "magnetic selection and an energy loss in a degrader,",
                "allows a full identification of reaction products with",
                "respect to their nuclear charge Z and mass A."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " A 1 A GeV 238U beam in spills lasting 6 seconds",
                "with a repetition period of 10-18 seconds.  The primary",
                "beam intensity was of the order of 1.0e+8 ions/spill."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The 238U intensity was recorded by a",
                "secondary-electron transmission monitor."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE",
                "TOF"
              ],
              "free_text": [
                ""
              ]
