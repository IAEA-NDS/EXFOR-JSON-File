          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " High-energy gamma rays(E(g)=3-20 MeV) were",
                "detected in lead collimated 25*30 cm NAI detector",
                "located 60 cm from target. A 15 cm thick polyethylene",
                "cone was placed close to the target so as to slow down",
                "fast neutrons which could be separated from gamma-rays",
                "by their time-of-flight. The detector was energy",
                "calibrated using the B-1(d,n)C-12 reaction at",
                "E(lab)=17 MeV. Its resolution for 15 MeV gamma rays was",
                "approx. 5%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " For the evaporation residues. Efficiency varied",
                "between 60-70%."
