          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The measurements of the elastic and inelastic",
                "scattering cross sections were carried out in a 2-m",
                "diameter scattering chamber using a ninefold delta-E-E",
                "ionization chamber surface barrier detector system."
              ]
            }
          ],
