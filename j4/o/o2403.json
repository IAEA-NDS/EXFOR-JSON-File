          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB",
                "SITA",
                "EDE",
                "TOF",
                "FPGAM",
                "TRN",
                "COINC"
              ],
              "free_text": [
                " The experiment",
                "relied on the identification of the O-15 nucleus and",
                "the two protons from the breakup of Ne-17 in",
                "coincidence. The charge of the particles was measured",
                "via their energy loss, while their mass was",
                "determined from the magnetic rigidity."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross sections for Coulomb excitation of resonant",
                "states were obtained by subtracting the nuclear",
                "contribution from the cross sections measured with",
                "the lead target scaled with a factor 1.84(20). The",
                "scaling factor was determined experimentally."
              ]
            }
          ],
