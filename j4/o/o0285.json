              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "SYNCY"
                ],
                "institute": null
              },
              "free_text": [
                " The Ipn Synchrocyclotron."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Protons from the Ipn Synchrocyclotron."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                ".Monoenergetic 155 MeV Protons from the Ipn Synchro-",
                " Cyclotron. The Beam Spot Size on Target was 6 X 12 Mm2",
                " And the Beam Intensity on Target was 6 Nano-Amps. The",
                " Beam Energy Resolution was 0.6 MeV Fwhm."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP"
              ],
              "free_text": [
                " The Scattered Protons were Momentum Analyzed",
                " Using a 120 Degrees Magnetic Dipole Spectrometer,",
                " With a Solid Angle of 0.3 - 1.5 Msr. The Angular Reso-",
                " Lution was +/- 1 to +/- 1.5 Degrees."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SCIN"
              ],
              "free_text": [
                " The Protons were Detected at the Focal",
                " Plane Using a Two-Detector Plastic Scintillator Tele-",
                " Scope. The Polarization was Measured Using a Two-Arm",
                " Telescope System, with Telescopes Placed at + 12.5 and",
                " - 12.5 Degrees with Respect to the Protons, and",
                " Looking at a Carbon Target. Each Telescope Consisted",
                " Of Two Scintillators, with a Variable Thickness Copper",
                " Absorber in Front of the Last One."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " The Number of Incoming Protons was Counted with",
                " A Helium Ionization Chamber."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "P"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
