          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD"
              ],
              "free_text": [
                " Integration of smoothed experimental angular",
                "distributions, extrapolated to cover 0-180 deg. region."
              ]
            }
          ],
          "MISC-COL": [
            {
              "pointer": "",
              "coded_information": [
                "MISC"
              ],
              "free_text": [
                " Ratio of the average longitudinal velocity of",
                "the fissioning nucleus to the average velocity of the",
                "fission fragment."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Performed: counting of fission fragments from",
                "the neighboring target, up to 11%; solid angle",
                "corrections; corrections to the fission fragment",
                "angular distribution taking into account the",
                "dependence of the detection efficiency on the fragment",
                "energy.",
                " Negligible: the contribution from the uranium",
                "admixture, not more than 1%."
              ]
            }
