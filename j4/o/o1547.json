                "correlation_property": null
              },
              "free_text": [
                " The total uncertainty in cross-section values",
                "was estimated as the square  root of the sum of",
                "squares of the contributing relative uncertainties,",
                "such as-",
                "  * counting statistics of 2-4%,",
                "  * detector efficiency of 5-7%,",
                "  * irradiation time of 2-4%,",
                "  * beam current of 5-8%,",
                "  * dead time of 5%,",
                "  * target mass of 1-3%.",
                "The total uncertainty in each cross-section value was",
                "estimated to be 9-13.4%."
              ]
            }
