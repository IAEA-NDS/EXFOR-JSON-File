          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Targets were prepared via electrolytic deposition of",
                "natural zinc on commercially high purity natural Ni",
                "foils(99.9%). The stacks of thickness 12.6-mum were",
                "used as targets(circular foils of 10-mm diameter).",
                "Natural Cu and Al foils of varying thickness were",
                "sometimes inserted into the stacks as degraders.",
                "All the foils were individually weighed before",
                "irradiation for the accurate determination of foil",
                "thickness."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
