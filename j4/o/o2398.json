          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC",
                "TOF",
                "EXTB",
                "EDE",
                "SITA",
                "REC",
                "FPGAM"
              ],
              "free_text": [
                " The energy of the",
                "primary 12C beam was 400 MeV/ u. The exclusive",
                "12C(p,2p)11B cross section was measured in inverse",
                "kinematics. Beside the primary CH2 target, a",
                "complementary carbon target was also used, to extract",
                "the cross section on hydrogen. The detection",
                "efficiency was estimated to be 62%, by Monte Carlo",
                "simulation."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The cross section to the ground state was calculated",
                "by subtracting the contributions from the two excited",
                "states from the total cross section."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "COMP"
              ],
              "free_text": [
                " The obtained cross sections were compared with",
                "theoretical predictions, and previous values in",
                "literature.",
                "In addition to the cross sections, spectroscopic",
                "factors for the two excited, and the ground state were",
                "also derived."
              ]
            }
