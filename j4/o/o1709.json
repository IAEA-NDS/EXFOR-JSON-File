          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " A 100-mum thick silicon detector detects",
                "projectiles that have been elastically scattered first",
                "in the target gas and subsequently in a movable 15-",
                "mug/cm**2 carbon foil."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The  prompt gamma-rays were detected by a 137%",
                "relative efficiency HPGE detector positioned with its",
                "front face 7 cm from the beam axis.A massive 0.3 m**3",
                "copper and lead shielding was built around the detector",
                "and the target chamber, since the energies of the",
                "prompt gamma rays (0.4, 1.3 and 1.7 MeV) are in the",
                "energy region of natural radioactive isotopes."
              ]
            }
          ],
