          "MONITOR": [
            {
              "pointer": "",
              "coded_information": {
                "heading": null,
                "reaction": {
                  "code": "79-AU-197(4-BE-9,EL)79-AU-197,,DA",
                  "code_unit": [
                    {
                      "unit": "79-AU-197(4-BE-9,EL)79-AU-197,,DA",
                      "field": {
                        "reaction": "79-AU-197(4-BE-9,EL)79-AU-197",
