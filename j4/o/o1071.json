          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uranium and thorium tetrafluoride, natural bismuth,",
                "lead and gold were used. A thin layer of the target",
                "material is evaporated onto a part of a makrofol foil",
                "surface. Above and close to this evaporated layer, a",
                "foil similar to the first one is applied. Both foils",
                "was 400- or 600-mum total thickness."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "D4PI",
                "TRD"
              ],
              "free_text": [
                " A makrofol (a polycarbonate) detector."
              ]
            }
          ],
