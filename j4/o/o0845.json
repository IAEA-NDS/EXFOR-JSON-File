            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " The decay of the different radionuclides has",
                "been followed for not less than three half-lives (1",
                "year for the longer half-life radionuclides) and the",
                "times of measurement were chosen for each radionuclide",
                "so that the statistical error on the photo-peak area",
                "was always of the order of less than 0.1-1%."
              ]
            }
          ],
