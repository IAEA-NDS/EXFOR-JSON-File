          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*. A detailed analysis found no evidence for",
                "the presence of 44Ti(a,p) reactions in the data,",
                "leading to an upper limit of 40 microbarn, at a 68%",
                "confidence limit. This is about half the NON-SMOKER",
                "prediction, and constitutes a step towards explaining",
                "the 44Ti excesses already observed in CCSNe. Future",
                "experimental studies utilising this and other isotopes",
                "reclaimed from accelerator waste are anticipated,",
                "with improved beam intensities expected."
              ]
            }
          ],
