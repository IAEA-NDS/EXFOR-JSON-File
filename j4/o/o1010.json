          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurements and nuclear model calculations on proton-",
                "induced reactions on Rh-103 up to 40-MeV-evaluation of",
                "the excitation function of the Rh-103(p,n)Pd-103",
                "reaction relevant to the production of the therapeutic",
                "radionuclide Pd-103."
              ]
            }
          ],
          "AUTHOR": [
            {
