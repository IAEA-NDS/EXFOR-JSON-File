          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High-purity thin rhodium foils,",
                "isotopic  composition- 99.9% Rh-103, thickness 25 mum,",
                "were used as samples.",
                "In a given stack about six such foils were placed.",
                "Copper monitor foils were inserted in each stack to",
                "degrade the proton energy as well as to determine the",
                "incident particle energy and the beam intensity.",
                "All the foils used were cut from materials of",
                "different thickness, thereby allowing changes in the",
                "mean energies of the irradiated rhodium samples."
              ]
            }
          ],
