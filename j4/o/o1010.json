          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "*By authors*.The count rates were corrected for random",
                "pile-up losses as well as for gamma-ray abundance and",
                "the efficiency of the detector and self-absorption in",
                "the foils. Correction for coincidence loss was also",
                "taken into account."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
