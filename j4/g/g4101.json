              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A Canberra GC-2018 semiconductor HPGe detector",
                "with the relative detection efficiency of 20%. The",
                "resolution FWHM is 1.8 keV for energy Egamma=1332 keV",
                "and is 0.8 keV for Egamma=122 keV."
              ]
            }
