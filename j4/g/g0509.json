                "reaction": null
              },
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                "The bremsstrahlung radiation was generated by",
                "impinging the electron beam on a solid graphite beam",
                "dump for 20 MeV linac."
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
                "For 100 Mev linac, the bremsstrahlung was generated",
                "when a pulsed electron beam hit a thin tungsten metal",
                "foil with a size of 10.0 cm X 10.0 cm and a thickness",
                "of 0.1mm."
              ]
            }
          ],
