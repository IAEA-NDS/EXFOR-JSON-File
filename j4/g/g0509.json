          "SAMPLE": [
            {
              "pointer": "1",
              "coded_information": null,
              "free_text": [
                "Stack of natural Zr metal foil(purity ~99.999%, size",
                "~1 cm X 0.7-0.8 cm, thickness ~0.1mm,weight ~54.4-",
                "63.6 mg) and Au metal foil (size ~0.8 cm X 0.7-0.6",
                "cm, thickness ~0.1mm, weight ~83.2- 101.6 mg) was",
                "used for 20 Mev electron linac."
              ]
            },
            {
              "pointer": "2",
              "coded_information": null,
              "free_text": [
                "Stack of natural Zr metal foil(size ~1.0 cm X 1.0 cm,",
                "thickness ~0.1mm, weight ~71.6-75.3 mg) and similar",
                "size of Au metal foil was used for 100 Mev electron",
                "linac."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The dead time of the detector system was kept",
                "below 10% to avoid the coincidence and summing effects."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
