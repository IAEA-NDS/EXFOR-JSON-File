          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A weighted amount of 0.04859 g of Gd2O3 and 0.06983 g",
                "of CeO2 were wrapped in pure aluminium foil of",
                "thickness 0.025 mm. The amount of Gd and Ce in the",
                "oxides were 0.0421 +- 0.0008 g and 0.0568 +- 0.0011 g,",
                "respectively. The 197Au metal foil, weighing 0.0849 +-",
                "0.0017 g and of thickness 0.025 mm was wrapped",
                "separately with pure aluminium foil"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A pre-calibrated 150 cc HPGe detector, coupled",
                "to a PC based 4 K channel analyzer, having 20 %",
                "efficiency relative to a 3 inch diameter x 3 inch",
                "length NaI(Tl) detector. The detector resolution",
                "was 1.8 keV FWHM at 1332.5 keV gamma-ray peak of 60Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The target assembly was irradiated for 4 hours.",
                "During irradiation, the peak current of the electron",
                "beam was 33 mA with a frequency of 350 Hz pulse width",
                "of 10 us and beam power of 1.13 kW."
              ]
            }
