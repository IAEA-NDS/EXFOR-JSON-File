          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST",
                  "POLPS",
                  "KINDT"
                ],
                "reaction": null
              },
              "free_text": [
                " Linearly polarized photons obtained",
                "by coherent bremsstrahlung of high-energy electrons in",
                "a thin diamond crystal of 0.3mm thick. The photon beam",
                "had a maximum intensity and almost 90% degree of",
                "polarization at energies below 40 MeV. Polarization",
                "decreased from 88% in the range of the reaction",
                "threshold to 58% at Eg = 50 MeV."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TRD"
              ],
              "free_text": [
                " A two-gap streamer chamber with a working",
                "volume of 60x60x24 cm3, was filled with pure helium",
                "to a pressure of 101325 Pa. The chamber was placed in",
                "an axially symmetric magnetic field with intensity",
                "about 1 T, known with an accuracy of 0.2%. The",
                "working volume of the camera was photographed with a",
                "three-lens camera."
              ]
            }
          ],
          "SAMPLE": [
