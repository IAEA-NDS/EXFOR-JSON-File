            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Cross section asymmetry of the 12C(gamma,p0)11B and",
                "12C(gamma,p1) 11B reactions at photon energies",
                "40...55MeV"
              ]
            }
          ],
