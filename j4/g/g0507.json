          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Uranium metal foils of weight 0.6587 and 0.9050 g and",
                "thickness 3.0363 and 1.6575g/cm3 were wrapped by",
                "super pure Aluminium irradiated by 8 and 10 MeV. A",
                "4.6007g/cm2 thick gold metal foil of weight 0.05434g",
                "is wrapped with 0.025mm thick super pure Al foil in",
                "the case of 10MeV Bremsstrahlung"
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " Energy resolution of the detector is 2.0keV",
                "FWHM at 1332.0keV peak of Co-60. The detector volume",
                "of 80 cc coupled to a 4K channel analyser and 41.1 cc",
                "to a 16K channel analyser was used for 10 MeV and 8 MeV",
                "Bremsstrahlung irradiation experiment respectively."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                " When an electron beam hits a 0.188cm thick Ta",
                "target, 8MeV Bremsstrahlung radiation was produced",
                "whereas 10MeV radiation was produced by impinging the",
                "electron beam on 1mm thick Ta target."
              ]
            }
          ],
