            "transmission_identification": "G022"
          },
          "BIB": {
            "N1": 12,
            "N2": 0
          },
          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Electron and photon excitation of nuclear isomers"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "E.C.Booth",
                "J.Brownson"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "INSTITUTE": [
            {
              "pointer": "",
              "coded_information": [
                "1USABST"
              ],
              "free_text": [
                "Department of Physics, Boston University,",
                "Boston, Massachusetts"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,NP/A,98,529,1967",
                "code_unit": [
                  {
                    "unit": "J,NP/A,98,529,1967",
                    "doi": "10.1016/0375-9474(67)90097-8",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "NP/A",
                        "number": null,
                        "volume": "98",
                        "part": null,
                        "issue": null,
                        "page": "529"
                      },
                      "date": 1967
                    }
                  }
                ],
                "unit_combination": "(%)"
              },
              "free_text": [
                "",
                "#NSR 1967BO10",
                "#doi:10.1016/0375-9474(67)90097-8",
                "The cross sections for electron excitation of the",
                "isomeric states are included in ENTRY D5063"
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDG"
                ],
                "institute": null
              },
              "free_text": [
                "The photo-excitation measurements were performed",
                "with a 3 MeV electron Van de Graaff having an energy",
                "resolution of +-10 keV and a beam intensity of",
                "150 microA."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                " Targets of 55 mg/cm2 platinum backed by water",
                "were used to produce the bremsstrahlung."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Indium targets were natural metal foils, while",
                "strontium-87 and mercury-199 were in the form of oxide",
                "and epoxy targets sealed in aluminium."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI",
                "NAICR"
              ],
              "free_text": [
                "The intensity at resonance was obtained in",
                "two ways - by direct measurement using a Ge-Li solid",
                "state detector and by measuring the resonance",
                "fluorescence intensity from targets of light nuclei",
                "having known lifetimes. The angular distribution of",
                "bremsstrahlung flux at resonance was found by counting",
                "the activity in rings of cadmium and indium, as well as",
                "by angular distribution measurements using NaI",
                "detectors."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The counting results were corrected by a factor f+1,",
                "where f is the conversion coefficient, and by a factor",
                "of 0.96 for beta decay in the case of 1l5In. The",
                "conversion coefficients used were 0.28+-0.03, 0.5+-0.1,",
                "1.15+-0.09 for 87Sr, 113In 115In, respectively. The",
                "conversion coefficients of 199Hg were determined to be",
                "0.5+-0.1 for the 158 keV gamma ray and 4.0+-1 for the",
                "370 keV."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
