          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "the electrodisintegration cross section was measured",
                "for 208Pb,209Bi and 181Ta, from threshold to 22 MeV, by",
                "detecting the emitted neutrons. The quantity measured",
                "is sigma(e,xn)= sigma(e,n)+ 2sigma(e,2n). The results",
                "are analysed with DWBA virtual photon spectra for",
                "finite nuclei to obtain m1 and e2 strengths."
              ]
            }
          ],
