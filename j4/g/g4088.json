          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 175Lu(gamma,n)174Lu-G and 175Lu(gamma,2n) 173Lu",
                "reactions cross-sections were calculated with the",
                "step of 1 MeV by using the TALYS-1.6 and EMPIRE-3.2",
                "codes and checked on agreement with the experimental",
                "data from L0015019 and L0015020 in the energy regions",
                " (7.800-13.0)MeV and (14.06-19.3) MeV, respectively."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The overall uncertainty is the quadratic",
                "sum of both random and systematic errors. The random",
                "errors are due to uncertainties in sample mass and",
                "counting statistics. The systematic errors are due to",
                "uncertainties in the simulated bremsstrahlung",
                "spectrum due to the use of GEANT4 code, the",
                "experimental photon or neutron fluxes due to the use",
                "of the 175Lu(g,n) 174gLu, 175Lu(g,2n)173Lu or",
                "180Hf(n,g)181Hf monitor reactions cross-sections,",
                "detection efficiency and the decay intensities. The",
                "overall uncertainty is found to be 6.4-7.9%."
              ]
            }
          ],
