          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A stack of the natHf-natTa-natLu sample was made. The",
                "samples were wrapped with 0.040 mm thick aluminum",
                "foil with purity higher than 99.99% and put in the",
                "aluminum cylinder with diameter of 1.5 cm and height",
                "of 2 cm.",
                "The size of the natLu metal foil was 1x0.7x0.007 cm,",
                "weight 0.05 g."
              ]
            }
          ],
