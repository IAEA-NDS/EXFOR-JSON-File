          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "1. Determine the photon fluence at the target position.",
                "2. Subtract the room background.",
                "3. Correct the measured spectrum for detector response",
                "   and efficiency.",
                "4. Subtract the non-nuclear (atomic) background.",
                "5. Subtract inelastic transitions and correct for",
                "   branching, angular distribution effects, and elastic",
                "   enhancement.",
                "6. Normalize to a known cross section."
              ]
            }
          ],
