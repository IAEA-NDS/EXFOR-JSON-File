          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The pressed tablets with the 10 mm diameter and masses",
                "around 400 mg of metallic powder of ruthenium of",
                "natural isotopic composition were used.",
                "The self-supporting metallic foils of the 104Ru",
                "enriched (99.6%) isotope with the 20 mm diameter and",
                "the surface thicknesses around 5 mg/cm2 were used.",
                "Palladium samples: the natural and enriched foils of",
                "the 102Pd (54%) and 110Pd (99%) isotopes were used.",
                "The ruthenium and palladium targets were sandwiched",
                "with the gold foils of the known surface thicknesses",
                "around 15 mg/cm2 and suitable diameter."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "79-AU-197",
