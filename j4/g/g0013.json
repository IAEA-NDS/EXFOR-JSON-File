          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Absolute photoneutron cross section of I-127"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "R.P.Rassool",
