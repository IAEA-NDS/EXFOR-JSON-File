          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "BETAT"
                ],
                "institute": null
              },
              "free_text": [
                " 35 MeV betatron at the University of Melbourne"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "BRST"
                ],
                "reaction": null
              },
              "free_text": [
                ""
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "the photon dose was measured using a thin-walled",
                "transmission ion chamber the response of which was",
                "intercalibrated against that of a standard replica",
                "nbs p2 chamber."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "103 gram sample of solid iodine."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "D4PI",
                "BF3"
              ],
              "free_text": [
                " a halpern type neutron detector. The",
                "neutron detection efficiency was determined from",
                "measurements using calibrated neutron sources and",
                "confirmed from a measurement of the D(gamma,p)n",
                "reaction cross section."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EXTB"
              ],
              "free_text": [
                " 5 independent yield curves were collected at",
                "photon energies ranging from 8 to 25 MeV in 200 keV",
                "intervals from which an average yield curve was",
                "determined. A similar procedure was used to determine",
                "an average background yield curve without sample. The",
                "latter being small, amounting to 0.02% Of the sample-",
                "in yield at 15 MeV and rising to 0.4% At 28 MeV."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "PLA"
              ],
              "free_text": [
                " the cross section was analyzed using the",
                "variable-bin-penfold-leiss method. The resulting",
                "I-127( gamma,xn) reaction cross section includes the",
                "I-127( gamma,n) and twice the I-127( gamma,2n) reaction",
                "cross sections. Allowance for the latter cross section",
                "was done on the basis of a statistical decay model."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "the resulting net yield curve was corrected for",
                "dead-time effects (< 5%)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-S",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " the errors include statistical uncertainties"
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-SYS",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " an overall systematic uncertainty of 7% due",
                "primarily the uncertainty in the neutron detector",
                "efficiency."
              ]
            }
          ],
