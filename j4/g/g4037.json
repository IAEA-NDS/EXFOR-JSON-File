            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The bremsstrahlung photons' flux density in the",
                "target's location was calculated using a computer",
                "simulation of the primary electrons passage through",
                "the target. The library of the GEANT4 classes and the",
                "low-energy electromagnetic processes models EPDL97",
                "and EEDL97 were used."
              ]
            }
          ],
