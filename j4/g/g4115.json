          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The targets were made from metal foils of structural",
                "steels of known elemental composition. These foils",
                "were rectangular strips 1 x 1 x 0.01 cm in size and",
                "about 0.048 g in weight and contained Fe - 66.2%, Cr",
                "- 16.9%, Ni - 9.9%, O - 3.2%, Mn - 1.66%, Si - 0.7%,",
                "Ti - 0.57%, Co - 0.29%, Cu - 0.16%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " HPGe-detectors which have an energy resolution",
                " (FWHM) of 1.8-2.0 keV at the 1332.5 keV peak of 60Co."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Induced gamma-activity was measured."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Experimental data are compared with theoretical",
                "predictions calculated with TALYS-1.96 code."
              ]
            }
          ],
