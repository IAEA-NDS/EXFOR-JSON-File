              "pointer": "",
              "coded_information": {
                "incident_source": [
                  "P-LI7"
                ],
                "reaction": null
              },
              "free_text": [
                " 17.6 and 14.7 MeV gamma rays were produced",
                "at 441 keV resonance."
              ]
            }
          ],
          "INC-SPECT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "the intensity ratio of the 17.6 and 14.7 gamma-",
                "rays bombarding the copper disk was 2.2 /1.0"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " the copper disk was irradiated about 20",
                "minutes (two times the half life of Cu-62) in order",
                "the number of Cu-62 nuclei in the disk to be",
                "saturated."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " a NaI(Tl) scintillator detector to monitor",
                "the gamma-radiation from the Li-7(p,g) reaction",
                "and to detect residual activity of Cu-62.",
                "the irradiated copper disk was attached to the",
                "front surface of the detector."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "DECAY"
              ],
              "free_text": [
                " the saturated number of Cu-62 nuclei was",
                "determined from the number of 511 keV gamma-rays",
                "accumulated for 800 sec, 30 minutes after the irra-",
                "diation was turned off. from this number, the number",
                "of Cu-63 per unit area, the number of gamma-rays",
                "bombarding the disk per second, and the decay constant",
                "of Cu-62, the cross section was determined."
              ]
            }
          ],
