          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural metal Mg was evaporated onto a 3 mm thick",
                "copper to create an Mg target with a thickness of 40",
                "ug/cm2. A Cr layer of 23 nm was then sputtered on the",
                "surface of the Mg target."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " An HPGe detector with a relative efficiency of",
                "175% and a resolution of 2.1 keV at Eg = 1.3 MeV.",
                "The detector was placed at 55 degree with respect to",
                "the relative beam direction parallel to the target,",
                "the distance between the detector and the target was",
                "25 cm, and the summing-effect was less than 1%.",
                "The absolute efficiency of the HPGe detector was",
                "determined using a 56Co gamma-ray source with an",
                "uncertainty of 1%."
              ]
            }
          ],
