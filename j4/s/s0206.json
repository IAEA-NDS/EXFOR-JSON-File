          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic scattering of the proton drip line nuclei 7Be,",
                " 8B, and 9C on a lead target at energies around three",
                " times the Coulomb barriers"
              ]
            }
          ],
          "AUTHOR": [
            {
