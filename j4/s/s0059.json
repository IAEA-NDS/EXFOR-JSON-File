          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 68.6 MeV/nucleon 18-O primary beam was accelerated",
                "by HIRFL, the secondary beam of 16C at 47.5",
                "MeV/nucleon was produced by the projectile",
                "fragmentation process at a 2.5 mm thick 9Be target",
                "installed at the entrance of RIBLL. The purity of 16C",
                "beam was enhanced to about 99% by using a",
                "wedge-shaped Al degrader."
              ]
            }
          ],
