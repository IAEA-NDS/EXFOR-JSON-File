          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "2H(16O,17F). A primary beam of 16O8+ at 6.6 MeV/u",
                " and 560 euA bombarded a Deuterium gas target. The",
                " intensity of secondary beam 17F9+ is 2.5E5 PPS."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The hydrogen gas target with 99.995% purity was",
                " maintained within 600 Torr by a gas-flow system."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI"
              ],
              "free_text": [
                " Three Si telescopes at 3, 10, 18 deg."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PPAC"
              ],
              "free_text": [
                " To monitor the direction, angle, and intensity",
