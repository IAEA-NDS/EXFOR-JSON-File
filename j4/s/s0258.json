              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The energy, position and time of the particles",
                " were measured by dE detector (PSD, 60 um),",
                " the residual energy of the particles were measured",
                " by E detector (SSD, 1.5 mm)."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Assumes the angular distribution of the 1H(17F,a)14O",
                " reaction cross-section is isotropic. Using the",
                " weighted average of differential cross-sections",
                " provided by three sets of Si arrays to obtain the",
                " equivalent differential cross-section, and then",
                " performing spherical integration to calculate the",
                " total cross-section."
              ]
            }
          ],
