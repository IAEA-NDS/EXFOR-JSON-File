          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fusion reaction studies for the 9Be + 89Y system at",
                "above-barrier energies"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
