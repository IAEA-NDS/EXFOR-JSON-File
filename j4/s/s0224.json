          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,101,014606,2020",
                "code_unit": [
                  {
                    "unit": "J,PR/C,101,014606,2020",
                    "doi": "10.1103/PhysRevC.101.014606",
                    "field": {
