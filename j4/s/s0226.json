          "COMMENT": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Initially, the measured yield of the neutrons emitted",
                "from the target was deduced to be 1.91+-0.16",
                "n/proton. After taking into account the influence of",
                "the Au foils with Cd cover on the production of",
                "thermal neutrons. Finally, the value was determined",
                "to be 2.23+-0.19 n/proton."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measured neutron flux in those positions",
                "influenced by the Cd cover."
              ]
            }
