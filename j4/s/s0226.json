          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The gamma activity of Au foils was measured",
                "with several high-purity germanium (HPGe) detectors.",
                "The detectors relative efficiency were about 65% and",
                "energy resolutions were 1.90 keV at 1.33 MeV. The",
                "absolute efficiency was calibrated with the standard",
                "sources 60Co, 133Ba, 137Cs, and 152Eu."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " An air ionization chamber was placed in front",
                "of the target to monitor the beam current."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Water-bath gold activation-foil method."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation lasted about 22 h. The total",
                "number of protons was (1.69+-0.05)E12."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
