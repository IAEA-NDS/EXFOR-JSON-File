            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The specimen was prepared in a UHV evaporator. A layer",
                "of TiN thin film with the thickness of 35 nm was",
                "deposited onto a polished carbon substrate. A thick",
                "layer of the compound of W, Ti and N was deposited."
              ]
            }
