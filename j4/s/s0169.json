          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "12C ions beam, the average beam current is around 230",
                "nA, and the stability is better than 5%."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Self-supporting thin metallic Nb foils with 2.7",
                "mg/cm2 in thickness, and separate by Al foil",
                " (0.443mg/cm2)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                " For the short and long half life",
                "isotope, the irradiation time is around 10 min and 2",
                "hours, respectively."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "EDEG",
                "REC"
              ],
              "free_text": [
                " The Al foils were used to decrease",
                "incident carbon beam energy and collect the recoil",
                "residual nuclei."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Detectors were placed 5 cm from the irradiated samples."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The volume is 110 cm3, and the efficiency is",
                "about 20%."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                " The efficiency is 35%. The energy resolution",
                " (FWHM) is 1.8 keV for 1332.5 keV gamma ray of 60Co",
                "calibration source."
              ]
            }
          ],
