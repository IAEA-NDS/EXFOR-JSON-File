          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of neutron spectra from thick Be target",
                "bombarded with deuterons"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
