          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "3CPRAEP"
              },
              "free_text": [
                " 13 MV Tandem accelerator"
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The target with diameter 25 mm was composed of",
                "Be(99.2%), O(0.49%), Fe(0.115%), Al(0.056%), C(0.059%),",
                "Si(0.018%) and others(0.062%). It is necessary to take",
                "the target thickness of about 3 mm, to stop all",
                "deutrons with the highest incident energy (Ed=22 MeV)."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " In order to achieve a time interval of 1",
                "microsecond corresponding to a neutron energy range",
                "from 0.5 to 30 MeV for the flight path of 6.76 m,",
                "beam pulse frequency of the accelerator must be",
                "chosen as 1 MHz."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " A stilbene scintillator 1 inch in thickness",
                "and diameter covered with a cylindrical aluminum",
                "container. It was positioned at 0 degree with respect",
                "to the beam direct ion."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "No data given. In neutron spectrum measurements, the",
                "uncertainty of neutron detector efficiency is one of",
                "main error sources. In the energy range below 20 MeV,",
                "the efficiency curves of the neutron detector were",
                "determined by combining MC calculations using a",
                "standard code NEFF7 with experimental calibration",
                "measurement using a miniature 252Cf ionization",
                "chamber. In the energy range above 20 MeV, the",
                "efficiency were determined by measuring neutron",
                "angular distribution of T(d,n) reaction."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Neutron flux attenuation in air, target and the",
                "heavily shielded detector and scattering neutrons",
                "material was calculated."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The fluence-averaged mean neutron energies of the",
                "neutron spectra are given as a function of the",
                "incident energy for several thresholds. The full",
                "neutron spectra were obtained by treating high energy",
                "En>1.8 MeV and low energy En<2.0 MeV portion",
                "respectively and then connecting them in a small",
                "overlap energy range from 1.8 and 2.0 MeV."
              ]
            }
          ],
          "HISTORY": [
            {
              "pointer": "",
              "coded_information": {
                "date": 20140506,
                "history": "C"
              },
              "free_text": [
                " Compiled by ZHUANG Youxiang and",
                "CHEN Guochang (CNDC)."
              ]
            }
          ],
