          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " The activity of the irradiated Au foils were",
                "measured by a high-purity germanium (HPGe) detector.",
                "The relative efficiency and energy resolution of the",
                "detector were 65% and 1.90 keV at 1.33 MeV,",
                "respectively. The absolute efficiency was calibrated",
                "with the standard sources 60Co, 133Ba, 137Cs, and",
                "152Eu."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " An air ionization chamber was placed in front",
                "of the target to determine the beam intensity."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Water-bath activation-foil method."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation continued for 22 h to obtain",
                "sufficient beam fluence. The average carbon beam",
                "intensity was 1.15E7 pps."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " The activity for each Au foil was determined",
                "by measuring the peak intensities of the",
                "characteristic gamma ray with energy of 412 keV from",
                "198Au."
              ]
            }
          ],
          "CORRECTION": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Gamma self-absorption and neutron self-shielding",
                "effects."
              ]
            }
          ],
