          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The measurement was carried out with a 34 MeV and 7Li",
                "beam from the HI-13 tandem accelerator."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 90 ug/cm2 self-supporting 13C target with a purity",
                "of 94% was impinged by 150 enA 7Li beam. A 12C target",
                "with the same thickness served as the background",
                "measurement."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                "The relative normalization of measurements at",
                "angles of theta-lab less than 6 deg. was carried out",
                "by monitoring the elastic scattering events."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "SI"
              ],
              "free_text": [
                " The reaction products were focused and",
                " separated by a Q3D magnetic spectrometer (0.34 msr),",
                " and measured by a 50 x 50 mm two-dimensional position",
                " sensitive silicon detector (PSSD) on the focal plane."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " The elastic scattering events (> 6 deg) were",
                " measured by a counter telescope placed at 25 deg.",
                " downstream of the target."
              ]
            }
          ],
