          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Elastic recoil cross section determination of",
                "deuterium by helium-4 ions at 30 degree with the",
                "energy range of 2.6-7.4 MeV"
              ]
            }
