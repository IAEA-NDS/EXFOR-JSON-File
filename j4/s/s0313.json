          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Measurement of thick target neutron yield from 80.5",
                " MeV/u 12C incidence on Be, C, W, and Pb targets"
              ]
            }
          ],
