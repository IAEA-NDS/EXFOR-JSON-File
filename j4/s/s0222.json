          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,100,054601,2019",
                "code_unit": [
                  {
                    "unit": "J,PR/C,100,054601,2019",
                    "doi": "10.1103/PhysRevC.100.054601",
                    "field": {
