          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Fusion reactions in the 9Be + 197Au system above the",
                "Coulomb barrier"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
