          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "40-ZR-96",
                "field_identifier": "ENR",
                "value": 0.99
              },
              "free_text": [
                " A 96ZrO2 metallic foil with 550",
