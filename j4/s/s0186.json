              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two Si(Au) surface barrier detectors were",
                "positioned at 30 degree with respect to the beam",
                "direction."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO",
                "HPGE"
              ],
              "free_text": [
                " An array consisting of 9 Compton-",
                "suppressed BGO-HPGe spectrometers and two planar HpGe",
                "detectors was used to detect online gamma rays",
                "emitted by the reaction products."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SI",
                "SI"
              ],
              "free_text": [
                " one auxiliary Delta E-E telescope was",
                "located at 65 degree with the beam direction, for the",
                "single identification of the light charged particles",
                "The distance between the target center and the",
                "telescope center was 55.0 mm. The telescope is",
                "composed of a silicon detector with diameter of 8 mm",
                "and a thickness 30.0 mu-m, and a stop silicon",
                "detector with a diameter of 12.0 mm and a thickness",
                "1000 mu-m. A collimator with a diameter of 5.0mm is",
                "put before the telescope."
              ]
            }
          ],
