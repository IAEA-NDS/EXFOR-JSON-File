          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 6He ions were produced via the 2H(7Li,6He)3He",
                " reaction with a 46 MeV 7Li beam bombarding a",
                " deuterium gas cell of 1.5 atm pressure.",
                "The front and rear windows of the gas cell are Havar",
                " foils with the thickness of 1.9 mg/cm2.",
                "The intensity of the secondary beam was approximately",
                " 1000 particles/s, and the purity of 6He was better",
                " than 85%."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " The 6He secondary beam was identified and",
                " recorded with a 19.2 um thin ORTEC silicon detector."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SI"
              ],
              "free_text": [
                " dE-E telescope consists of a 67 um",
                " double-sided silicon strip detector (DSSSD), and two",
                " multi-guard silicon quadrant (MSQ) detectors with",
                " thickness of 1001 um and 982 um. The DSSSD is",
                " comprised of 16 strips on the front side and 16",
                " similar orthogonal strips on the back, thus providing",
                " two-dimension position information in a resolution of",
                " 3 mm*3 mm.",
                "Both MSQ detectors are 2*2 arrays of independent",
                " active area, separated by a 0.1 mm wide cross gap.",
                "dE-E detectors are all 50 mm*50 mm of active area.",
                "A 14*14 pixel array in the central part of DSSSD was",
                " used which covers the laboratory angular range from",
                " 0 to 10 degree.",
                "Angular resolution (2.06 deg) is due to",
                " - beam spot size (0.3 deg)",
                " - 6He angular divergence (0.2 deg)",
                " - 6He angular straggling in DE detector (0.22 deg)",
                " - 6He angular straggling in (CH2)n target (0.97 deg)"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TTM"
              ],
              "free_text": [
                " Thick-target inverse kinematic (TTIK) method.",
                "Only (6He,p) reaction at the effective thickness of",
                " 6.6+/-0.5 mg/cm2 (Ecm=4.30+/-0.16 MeV) was used in",
                " the present analysis."
              ]
            }
          ],
