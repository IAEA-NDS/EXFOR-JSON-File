          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "12-MG-25",
                "field_identifier": "ENR",
                "value": 0.992
              },
              "free_text": [
                " The target (~30 ug/cm2) was",
                "prepared by the vacuum evaporation of magnesium",
                "enriched to 99.2% in 25Mg onto a thin carbon backing",
                " (~10 ug/cm2)."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SOLST"
              ],
              "free_text": [
                " The outgoing alpha particles were detected by",
                "two solid-state detectors. One was mounted in the",
                "scattering chamber to rotate about the target, and",
                "the other was fixed at an angle of 90 deg, was used",
                "as a monitor."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "PHD"
              ],
              "free_text": [
                " Alpha particles pulse-height spectrum."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "INTAD"
              ],
              "free_text": [
                " The average integrated total cross sections",
                "of the alpha-particle groups, are integrated over the",
                "angles 35 to 155 deg, and averaged over deuteron",
                "energies of 2.00, 2.20, 2.40, 2.55, 2.70, 2.80 and",
                "3.00 MeV."
              ]
            }
          ],
          "PART-DET": [
            {
              "pointer": "",
              "coded_information": [
                "A"
              ],
              "free_text": [
                " Alpha particles"
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The deviation of the measured cross section from the",
                "pure Coulomb scattering was found to be less than 20%",
                "at backward angles. This method of the determining the",
                " (d,a) cross section may give an uncertainty of about",
                "10%. The overall uncertainty on the calculated",
                "absolute cross sections are estimated to be about 20%,",
                "and the relative cross section are uncertain by about",
                "10%."
              ]
            }
          ],
          "ADD-RES": [
            {
              "pointer": "",
              "coded_information": [
                "ANGD"
              ],
              "free_text": [
                " The angular distributions and the excitation",
                "functions of the alpha- particle groups are shown in",
                "fig.2 and fig.3 of J,NP/A,102,537,1967. The figures",
                "are indistinct, so the angular distributions and the",
                "excitation functions are not easy to digitize from",
                "the figures. We have no way to contact with the",
                "author, because there have no email or other ways. So",
                "we have not compiled the angular distributions and",
                "the excitation functions in this entry."
              ]
            }
          ],
