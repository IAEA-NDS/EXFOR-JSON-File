              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The thickness of 58Ni is 1.046 and 2.092 mg/cm2. The",
                "thickness of 64Ni and 115In is 1.063 and 4.81 mg/cm2,",
                "respectively. And the thickness of 197Au is 2.73 and",
                "4.53 mg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
