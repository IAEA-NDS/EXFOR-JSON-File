            },
            {
              "pointer": "",
              "coded_information": [
                "SI",
                "CSICR",
                "SIBAR"
              ],
              "free_text": [
                " The telescope detector consists",
                "of 2 silicon semiconductor detectors and one CsI(Tl)",
                "stopping detector with 325 um and 10 mm in thickness,",
