          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " A Faraday cup was used to collect the beam",
                "for normalizing the cross sections at larger than 6",
                "deg in Lab. The Faraday cup could be moved away when",
                "measuring the cross sections at less than 6 deg in Lab."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " A dE-E telescope placed at 25 deg in lab was",
                "employed for relative normalization of the cross",
                "sections at less than 6 deg in lab by monitoring the",
                "recoiled 11B particles from the 11B + 12C elastic",
                "scattering."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "PS",
                "SI"
              ],
              "free_text": [
                " Reaction products were focused and",
                "separated by the Q3D magnetic spectrometer, and",
                "measured by a 50x50 mm2 two dimensional position",
                "sensitive silicon detector (PSSD). Energy resolution",
                "of the Q3D magnetic spectrometer is as high as 0.02%."
              ]
            }
          ],
