          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 6Li3+ beam in the energy range from 16 to 28 MeV,",
                "the beam current was varied from 5.7 to 14.0 enA."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": {
                "nuclide": "40-ZR-96",
                "field_identifier": "ENR",
                "value": 0.99
              },
              "free_text": [
                " A 96ZrO2 metallic foil with 550",
                "mu-g/cm2 thickness and a 1.92 mg/cm2 gold backing."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Two Si(Au) surface barrier detectors were",
                "positioned at 30 degree with respect to the beam",
                "direction."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BGO",
                "HPGE"
              ],
              "free_text": [
                " An array consisting of 9 Compton-",
