          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": null
              },
              "free_text": [
                " To obtain the incident deuteron beam",
                "at 13.04 MeV. And according to the relation between",
                "energy and range to obtain the deuteron energy at each",
                "foils."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "NAICR"
              ],
              "free_text": [
                " To detect the gamma ray of residual nuclei.",
                "Using Co60 gamma source to do energy calibration",
                "before each measurements."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " Using Faraday cup to collect incident deutron",
                "charge and measured by a integral electronics."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "There could contain 4 sample foils in target cell and",
                "exchange sample position. The sample foil was cooling",
                "by water. Natural Cu, Zn and Cr mixture were obtained",
                "by electrolysis process, and the thickness of sample",
                "foil was around 10mg/cm2, and the uncertainty of",
                "uniformity is around 5%."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " Total uncertainty of measurement is around",
                "5%, including the uncertainty of beam current",
                "measurement, the thickness of sample foil etc."
              ]
            }
