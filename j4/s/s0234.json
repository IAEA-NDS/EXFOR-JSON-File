          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The collimated 9Be beam with an initial energy of",
                "50.4 MeV was delivered by HIRFL. The average beam",
                "current was about 13 enA."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Five 89Y targets with thickness of about 1.0 mg/cm2."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV",
                "GSPEC"
              ],
              "free_text": [
                " The offline gamma-ray spectroscopy",
                "in continuation to the online stacked-foil activation",
                "method. The irradiation lasted about 12 h."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The beam flux was extracted using a precise",
                "current-integrator device from the charge collected",
                "at the Faraday cup, which is biased with a negative",
                "400 V electrode and installed at the back of targets."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SI"
              ],
              "free_text": [
                " Two silicon detectors were mounted at +-30 deg",
                "with respect to the beam line to cross-check the beam",
                "flux that impinged on the targets."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " For performing offline measurements, a setup",
                "formed by five high-purity germanium (HPGe) detector",
                "groups was used. Each group composed of two HPGe",
                "detectors placed at an angle of 180 deg to each",
                "other. The gamma sources of 60Co, 133Ba, and 152Eu",
                "were used to calculate the absolute efficiency of the",
                "detectors."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The systematic uncertainties are added in",
                "quadrature to the statistical errors to get the total",
                "errors"
