          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 75+/-6 ug/cm2 self-supporting 13C target with a",
                " purity of 88% was impinged by 11B beam.",
                "Natural silicon monoxide of 86+-/7 ug/cm2 was prepared",
                " onto a 40+/-3 ug/cm2 carbon foil serving as the",
                " oxygen target.",
                "A 12C target with 66(+-5) ug/cm2 served as the",
                " calibration of the focal plane and the background",
                " measurement during the entire experiment."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The relative normalization of measurements at",
                " angles of theta-lab less than 6 deg. was carried out",
                " by monitoring the elastic scattering events."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "BCINT"
              ],
              "free_text": [
                " The Beam current was measured by a Faraday cup",
                " covering an angular range of +/-6 deg in Lab frame",
                " and used for the absolute normalization of the cross",
                " sections at > 6 deg."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "MAGSP",
                "SI"
              ],
              "free_text": [
                " The reaction products were focused and",
                " separated by a Q3D magnetic spectrometer (0.34 msr),",
                " and measured by a 50 x 50 mm two-dimensional position",
                " sensitive silicon detector (PSSD) on the focal plane."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES"
              ],
              "free_text": [
                " The elastic scattering events (> 6 deg) were",
                " measured by a counter telescope placed at 25 deg.",
                " downstream of the target."
              ]
            }
          ],
