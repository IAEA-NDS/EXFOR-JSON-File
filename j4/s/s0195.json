          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A single graphite crystal was chosen to be the",
                "substrate of the target. The thin magnesium layer was",
                "deposited on the graphite crystal by evaporation in",
                "the vacuum environment (2.0E-3 Pa), then the thin Au",
                "layer was evaporated on the Mg layer in the same",
                "vacuum condition. In order to get mean proton",
                "energies in the Mg and Au layers for energy",
                "corrections during data analysis, the target",
                "thickness was measured by using both 2.5 MeV 7Li and",
                "400 keV proton Rutherford backscattering. The area",
                "densities of Mg and Au layers were 5.91E17 and",
                "1.23E17 atom/cm2, respectively."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " Four silicon surface barrier detectors with a",
                "resolution of 12 keV, set at the laboratory back",
                "scattering angles of 140, 150, 160 and 170 degree,",
                "respectively, were used for the detection of",
                "backscattering protons and every detector had a",
                "tantalum cover with a hole whose diameter were 3 mm",
                "limited the detector solid angles to 1.21+-0.01 msr."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "DATA-ERR",
                "minimum_value": null,
                "maximum_value": 5.0,
                "correlation_property": null
              },
              "free_text": [
                " The overall standard error in the",
                "measured cross sections is estimated to be better",
                "than 5% at all the beam energies and angles."
              ]
            }
