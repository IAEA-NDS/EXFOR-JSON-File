          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,JP/G,41,105104,2014",
                "code_unit": [
                  {
                    "unit": "J,JP/G,41,105104,2014",
                    "doi": "10.1088/0954-3899/41/10/105104",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "JP/G",
                        "number": null,
                        "volume": "41",
                        "part": null,
                        "issue": null,
                        "page": "105104"
