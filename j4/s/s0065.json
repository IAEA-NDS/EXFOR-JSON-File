          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 17F secondary beam was identified and monitored",
                "with a 13.2 micron silicon detector.)"
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The 17F beam was produced via the 2H(16O,17F)n",
                "reaction by using a 96 Ne/v 16O beam bombarding in",
                "to a deuterium gas cell of 1.5 atm pressure. The",
                "secondary beam was separated and focused by the",
                "electro-magnetic dipole and quadrupoles and then",
                "further purified by the Danfysik Wein velocity filter.",
                "The beam intensity was approximately 6000 pps, and",
                "the 17F purity was better than 70%."
              ]
            }
          ],
          "ANALYSIS": [
            {
              "pointer": "",
              "coded_information": [
                "MLA"
              ],
              "free_text": [
                "The excitation function was analyzed by using",
                "multi-level R-matrix code MULTI7. The resonance",
                "parameters are deduced from the R-matrix fitting."
              ]
            }
          ],
