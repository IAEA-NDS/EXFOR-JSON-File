          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PROPC"
              ],
              "free_text": [
                " An array consisting of 24 3He-filled",
                "proportional counters. By placing 35-cm thick 7%",
                "borated polyethylene blocks and 1-mm thick cadmium",
                "sheets around the detection array, a background of",
                "4.7(2) events per hour was achieved, compared to",
                "1238(11) events per hour measured on the Earth's",
                "surface. The detection efficiency of the array was",
                "determined to be 26% for 2.5-MeV neutrons using the",
                "51V(p,n)51Cr reaction together with GEANT4 simulations."
              ]
            }
