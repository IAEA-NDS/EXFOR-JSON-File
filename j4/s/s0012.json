          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacked target were composed of 13 Au foils (purity",
                "99.99%, thickness 14 mg/cm2), each Au foil with 2 Al",
                "catcher foil (purity 99.9%, thickness 1.25 mg/cm2)."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3CPRSIU"
              },
              "free_text": [
                " 1.2 M cyclotron"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "STTA",
                "ACTIV"
              ],
              "free_text": [
                " The samples were cooled for 66 h",
                "after 120 min irradiation."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "13.3 MeV deuteron beam, the average intensity of beam",
                "current on the target was about 200 nA."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE",
                "GELI"
              ],
              "free_text": [
                " Two rounds of stacked target irradiation",
                "have been carried out using ORTEC GEM-30195",
                "high-purity germanium detector and Canberra 100 cm3",
                "coaxial Ge(Li) detector, with a energy resolution",
                " (FWHM) of 2.0 keV and 1.79 keV at 1332 keV gamma-ray",
                "of 60Co respectively. The absolute efficiency",
                "calibration was performed with 152Eu and 75Se",
                "standard sources, the uncertainty was about 3% above",
                "121 keV and about 6% below 121 keV."
              ]
            }
          ],
          "ERR-ANALYS": [
