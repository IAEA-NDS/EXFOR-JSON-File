          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "High purity natural iron foils. The area of the foils",
                "were large enough (d=24mm) to intercept the whole beam."
              ]
            }
          ],
          "FACILITY": [
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "VDGT"
                ],
                "institute": "3CPRAEP"
              },
              "free_text": [
                " HI-13 mV Tandem was used to produce the",
                "proton beams with the energies from 5 to 19 MeV."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "BCINT",
                "STTA"
              ],
              "free_text": [
                " In general, for one run experiment",
                "three stacks were irradiated at the primary incident",
                "energies of 19, 16 and 10 mev, respectively. Each",
                "stack consisted of iron foils and aluminum foils used",
                "as energy degraders.The beam current was measured with",
                "a Faraday cup and a beam current integrator."
              ]
            }
          ],
          "MONITOR": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The currents were monitored by Faraday cup."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "GELI"
              ],
              "free_text": [
                ""
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
              "coded_information": {
                "heading": "ERR-T",
                "minimum_value": null,
                "maximum_value": null,
                "correlation_property": null
              },
              "free_text": [
                " The uncertainties include:",
                "  * (1.5%-2.5%) for the efficiency of the Ge(li)",
                "                detector,",
                "  * 2% for beam current determination,",
                "  * (2%-3%) for the weight and uniformity of samples,",
                "  * (1%-4%) for measured repetition, etc.",
                " The total uncertaity is 4%-7%."
              ]
            }
