                " Science, Beijing"
              ]
            }
          ],
          "REFERENCE": [
            {
              "pointer": "",
              "coded_information": {
                "code": "J,PR/C,91,014608,2015",
                "code_unit": [
                  {
                    "unit": "J,PR/C,91,014608,2015",
                    "doi": "10.1103/PhysRevC.91.014608",
                    "field": {
                      "reference_type": "J",
                      "reference": {
                        "code": "PR/C",
                        "number": null,
                        "volume": "91",
                        "part": null,
                        "issue": null,
                        "page": "014608"
                      },
