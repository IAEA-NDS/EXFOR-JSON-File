          "TITLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Complete and incomplete fusion of 9Be+169Tm, 187Re at",
                "near-barrier energies"
              ]
            }
          ],
          "AUTHOR": [
            {
              "pointer": "",
              "coded_information": [
                "Y.D.Fang",
                "P.R.S.Gomes",
