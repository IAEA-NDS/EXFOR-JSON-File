                ],
                "institute": "3CPRIMP"
              },
              "free_text": [
                "Irradiation experiment was performed",
                "at the HIRFL-CSR in Lanzhou, China."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A Pb foil with 100 mm diameter and 0.15 mm thickness."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                ""
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "IOCH"
              ],
              "free_text": [
                " An ionization chamber was placed in front of",
                "the Pb foil to monitor the beam current."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV"
              ],
              "free_text": [
                " The irradiation was lasted about 20 h to make",
                "the beam fluence enough. The average beam intensity",
                "was 1.72*10**7 particles/s."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "GSPEC"
              ],
              "free_text": [
                " After irradiation, the gamma spectra of Pb",
                "foil were measured by a off-line gamma-spectrometry",
                "method. Three measurements were performed at 8 h, 28 h",
                "and 10 days after the end of irradiation."
              ]
            }
          ],
