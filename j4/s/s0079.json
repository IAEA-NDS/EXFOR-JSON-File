              "pointer": "",
              "coded_information": {
                "facility": [
                  "PRJFS"
                ],
                "institute": "3CPRIMP"
              },
              "free_text": [
                " Use Radioactive Ion Beam Line to",
                "produce secondary unstable nuclear beam."
              ]
            },
            {
              "pointer": "",
              "coded_information": {
                "facility": [
                  "CYCLO"
                ],
                "institute": "3CPRIMP"
              },
              "free_text": [
                " And the primary beam were accelerated",
                "by Heavy Ion Research Facility."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "4.2 mg/cm2 thick enriched 208Pb"
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "TOF"
              ],
              "free_text": [
                " Two fast scintillator detectors were placed at",
                "the two focal planes of the RIBLL a distance of 17 m."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "EDE"
              ],
              "free_text": [
                " The scattered particles were detected after the",
                "secondary target with two silicon-detector dE-E",
                "telescopes."
              ]
            }
          ],
          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A 54.2 MeV/A 12C primary beam was delivered to a 2615",
                "um thick Be primary target to produce secondary beam",
                "8B. The intensity of secondary beam was a few hundred",
                "particles per second with a primary beam intensity of",
                "~300 enA, while 7Be beam was ~5000 particles per",
                "second."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SCIN"
              ],
              "free_text": [
                " Two fast scintillator detectors were combined",
                "with dE detector and the magnetic rigidity setting to",
                "identify the secondary particles."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "PPAC"
              ],
              "free_text": [
                " The position and direction of the incident",
                "particles on the target were determined by two PPAC",
                "detectors with active area 80*80 mm2 and position",
                "resolution about 1 mm in both X and Y directions."
              ]
            },
            {
              "pointer": "",
              "coded_information": [
                "TELES",
                "SISD",
                "SI"
              ],
              "free_text": [
                " Each telescope consisted of a 150 um",
                "thick double-sided silicon strip detector with an",
                "active area of 48x48 mm2 as a dE detector and a 1500",
                "um thick silicon detector as E detector. The silicon",
                "strip detectors were perpendicularly segmented into",
                "48 strips on both sides and the position resolution",
                "was 1 mm in both the vertical and horizontal",
                "directions."
              ]
            }
          ],
