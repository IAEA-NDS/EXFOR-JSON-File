          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "COINC"
              ],
              "free_text": [
                " The time difference method was used. This",
                "method only needs to measure the difference and",
                "position information of the flight time of a pair of",
                "complementary outgoing particles, and use the time",
                "signal to obtain information about the mass",
                "distribution of fission fragments through kinematic",
                "reconstruction."
