          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The natural LiF with a 7Li thickness of 20.2 +- 1.0",
                "ug/cm2 was evaporated and deposited on a",
                "self-supporting 12C foil as the target. Based on the",
                "precision of the analytical balance and the error of",
                "the cross sections of the d + 7Li elastic scattering,",
                "an uncertainty of 5.0% was assigned for the target",
                "thickness."
              ]
            }
          ],
