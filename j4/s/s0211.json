          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "A strip of deuterated polyethylene target (CD2) of",
                "about 160 mu-g/cm2 in thickness and 1.0 mm in width",
                "in order to reduce the angle uncertainty coming from",
                "the large beam spot."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "PS"
              ],
              "free_text": [
                " A position-sensitive detector (PSD) was placed",
                "at 40+-5 degree with respect to the beam line and",
                "about 238 mm from the target to detect the outgoing",
                "triton. Another PSD was used at 78+-5 degree at",
                "opposite side with respect to the beam line at 245 mm",
                "from the target to detect the outgoing proton. The",
                "energy resolution of the two PSDs was about 0.6-0.8%",
                "for 5.48 MeV alpha source. The position resolution of",
                "PSDs was about 0.5 mm."
              ]
            }
          ],
