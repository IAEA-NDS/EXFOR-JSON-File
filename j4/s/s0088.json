          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The samples Pd/TiDx/Si were made by magnetron",
                "sputtering. A uniform TiDx film with the thickness of",
                "about 20 nm was first sputtered onto a Si substrate",
                "then an approximately 3 nm Pd overlayer was deposited",
                "on the TiDx film."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "SIBAR"
              ],
              "free_text": [
                " The backscattering spectra were detected at a",
                "laboratory angle of 165 deg by an Au/Si surface",
                "barrier detector with a solid angle of 1.83E-3 sr.",
                "The elastic recoil spectra were detected at 30 deg by",
                "another Au/Si surface barrier detector with a solid",
                "angle of 1.12E-3 sr. The angular resolution of both",
                "detectors were approximately +-0.5 deg and the energy",
                "resolution of the detection system was about 30 keV",
                "for C ions."
              ]
            }
          ],
