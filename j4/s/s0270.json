          "INC-SOURCE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "The initial proton energy of 18.6 MeV and a beam",
                "current of about 100 nA."
              ]
            }
          ],
          "SAMPLE": [
            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Natural isotopic abundance mental foils were placed",
                "as Cu (9.87 um), Cu (9.87 um), Ti (9.93 um),",
                "Ti (9.93 um), Mo (10.56 um), Al (105.60 um) and this",
                "sequence was repeated seven times. The second foils",
                "of Cu and Ti have a balance for the reaction products",
                "recoil-in and recoil-out. Al degrader was also used",
                "as recoil radionuclides catcher, and the",
                "radioactivity of Mo foil was measured together with",
                "the adjacent Al degrader."
              ]
            }
          ],
          "METHOD": [
            {
              "pointer": "",
              "coded_information": [
                "ACTIV",
                "STTA",
                "GSPEC"
              ],
              "free_text": [
                " The stack was irradiated in a",
                "vacuum chamber for 1 h. The targets were cooled 2 h.",
                "Activity measurements of the target were repeated",
                "several times over a period of two months according",
                "to the half-life of the radionuclides."
              ]
            }
          ],
          "DETECTOR": [
            {
              "pointer": "",
              "coded_information": [
                "HPGE"
              ],
              "free_text": [
                " A high-purity germanium (HPGe) detector",
                " (ORTEC, GEM25) was located in a low-background lead",
                "and coper shield cell. The energy and efficiency",
                "calibrations of HPGe detector were determined by",
                "using standard gamma sources (109Cd, 133Ba, 152Eu and",
                "137Cs). All targets were set at a distance of 10.5",
                "cm from the end-cap of the detector, and the effect",
                "of geometrical factor is less than 1% at such a",
                "distance. The detector dead time during measurement",
                "was below 6% (mostly < 2%)."
              ]
            }
          ],
          "ERR-ANALYS": [
            {
              "pointer": "",
