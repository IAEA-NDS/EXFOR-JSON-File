            {
              "pointer": "",
              "coded_information": null,
              "free_text": [
                "Stacked foils consisted of ten target foils, each",
                "prepared by vacuum evaporating Mn metal with",
                "thickness about 1 mg/cm2 onto 5.2 mg/cm2 thick Al",
                "foil and covered with 1.2 mg/cm2 thick Al catcher foil"
              ]
            }
          ],
